{"tag":"section","attrib":{"id":"iddd44a4de-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5007"},"text":null,"children":[{"tag":"num","attrib":{"value":"5007"},"text":"§ 5007.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expedited recredit procedures for banks","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd44a4df-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5007/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recredit claims","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd44a4e0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5007/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A bank may make a claim against an indemnifying bank for expedited recredit for which that bank is indemnified if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd44a4e1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5007/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the claimant bank (or a bank that the claimant bank has indemnified) has received a claim for expedited recredit from a consumer under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5006"},"text":"section 5006 of this title","children":[],"tail":" with respect to a substitute check or would have been subject to such a claim had the consumer’s account been charged;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd44a4e2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5007/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the claimant bank has suffered a resulting loss or is obligated to recredit a consumer account under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5006"},"text":"section 5006 of this title","children":[],"tail":" with respect to such substitute check; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd44a4e3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5007/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" production of the original check, another substitute check, or a better copy of the original check is necessary to determine the validity of the charge to the customer account or any warranty claim connected with such substitute check.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd44a4e4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5007/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 120-day period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any claim under paragraph (1) may be submitted by the claimant bank to an indemnifying bank before the end of the 120-day period beginning on the date of the transaction that gave rise to the claim.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd44a4e5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5007/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures for claims","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd44a4e6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5007/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To make a claim under subsection (a) for an expedited recredit relating to a substitute check, the claimant bank shall send to the indemnifying bank—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd44a4e7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5007/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd44a4e8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5007/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the claim, including an explanation of why the substitute check cannot be properly charged to the consumer account; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd44a4e9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5007/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the warranty claim;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd44a4ea-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5007/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement that the claimant bank has suffered a loss or is obligated to recredit the consumer’s account under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5006"},"text":"section 5006 of this title","children":[],"tail":", together with an estimate of the amount of the loss or recredit;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd44a4eb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5007/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reason why production of the original check, another substitute check, or a better copy of the original check is necessary to determine the validity of the charge to the consumer account or the warranty claim; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd44a4ec-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5007/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information sufficient for the indemnifying bank to identify the substitute check and to investigate the claim.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd44a4ed-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5007/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements relating to copies of substitute checks","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the information submitted by a claimant bank pursuant to paragraph (1) in connection with a claim for an expedited recredit includes a copy of any substitute check for which any such claim is made, the claimant bank shall take reasonable steps to ensure that any such copy cannot be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd44a4ee-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5007/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mistaken for the legal equivalent of the check under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5003/b"},"text":"section 5003(b) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd44a4ef-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5007/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sent or handled by any bank, including the indemnifying bank, as a forward collection or returned check.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd44a4f0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5007/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Claim in writing","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd44a4f1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5007/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An indemnifying bank may, in the discretion of the bank, require the claimant bank to submit the information required by paragraph (1) in writing, including a copy of the written or electronically submitted claim, if any, that the consumer provided in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5006/b"},"text":"section 5006(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd44a4f2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5007/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Means of submission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An indemnifying bank that requires a submission of information under subparagraph (A) may permit the claimant bank to make the submission electronically, if the claimant bank has agreed to communicate with the indemnifying bank in that manner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd44a4f3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5007/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recredit by indemnifying bank","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd44a4f4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5007/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prompt action required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No later than 10 business days after the business day on which an indemnifying bank receives a claim under subsection (a) from a claimant bank with respect to a substitute check, the indemnifying bank shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd44a4f5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5007/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide, to the claimant bank, the original check (with respect to such substitute check) or a copy of the original check (including an image or a substitute check) that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd44a4f6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5007/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accurately represents all of the information on the front and back of the original check (as of the time the original check was truncated); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd44a4f7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5007/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is otherwise sufficient to determine the bank’s claim is not valid; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd44a4f8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5007/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recredit the claimant bank for the amount of the claim up to the amount of the substitute check, plus interest if applicable; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd44a4f9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5007/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide information to the claimant bank as to why the indemnifying bank is not obligated to comply with subparagraph (A) or (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd44a4fa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5007/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recredit does not abrogate other liabilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Providing a recredit under this subsection to a claimant bank with respect to a substitute check shall not absolve the indemnifying bank from liability for claims brought under any other law or from additional damages under section 5005 or 5009 of this title with respect to such check.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd44a4fb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5007/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Refund to indemnifying bank","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a claimant bank reverses, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5006/e"},"text":"section 5006(e) of this title","children":[],"tail":", a recredit previously made to a consumer account under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5006/c"},"text":"section 5006(c) of this title","children":[],"tail":", or otherwise receives a credit or recredit with regard to such substitute check, the claimant bank shall promptly refund to any indemnifying bank any amount previously advanced by the indemnifying bank in connection with such substitute check."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd44a4fc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5007/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Production of original check or a sufficient copy governed by section 5005(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the indemnifying bank provides the claimant bank with the original check or a copy of the original check (including an image or a substitute check) under subsection (c)(1)(A), ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5005/d"},"text":"section 5005(d) of this title","children":[],"tail":" shall govern any right of the indemnifying bank to any repayment of any funds the indemnifying bank has recredited to the claimant bank pursuant to subsection (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd44a4fd-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/100/s8"},"text":"Pub. L. 108–100, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-10-28"},"text":"Oct. 28, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1186"},"text":"117 Stat. 1186","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd44a4fe-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd44a4ff-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd44a500-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective at the end of the 12-month period beginning on ","children":[{"tag":"date","attrib":{"date":"2003-10-28"},"text":"Oct. 28, 2003","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/100/s20"},"text":"section 20 of Pub. L. 108–100","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5001"},"text":"section 5001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
