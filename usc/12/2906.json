{"tag":"section","attrib":{"id":"iddcf85943-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2906"},"text":null,"children":[{"tag":"num","attrib":{"value":"2906"},"text":"§ 2906.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Written evaluations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcf85944-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2906/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcf85945-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2906/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon the conclusion of each examination of an insured depository institution under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2903"},"text":"section 2903 of this title","children":[],"tail":", the appropriate Federal financial supervisory agency shall prepare a written evaluation of the institution’s record of meeting the credit needs of its entire community, including low- and moderate-income neighborhoods."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf85946-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2906/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public and confidential sections","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each written evaluation required under paragraph (1) shall have a public section and a confidential section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcf85947-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2906/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public section of report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcf85948-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2906/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings and conclusions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcf85949-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2906/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of written evaluation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The public section of the written evaluation shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddcf8594a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2906/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" state the appropriate Federal financial supervisory agency’s conclusions for each assessment factor identified in the regulations prescribed by the Federal financial supervisory agencies to implement this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcf8594b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2906/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" discuss the facts and data supporting such conclusions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcf8594c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2906/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contain the institution’s rating and a statement describing the basis for the rating.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcf8594d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2906/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Metropolitan area distinctions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The information required by clauses (i) and (ii) of subparagraph (A) shall be presented separately for each metropolitan area in which a regulated depository institution maintains one or more domestic branch offices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf8594e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2906/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assigned rating","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The institution’s rating referred to in paragraph (1)(C) ","children":[{"tag":"ref","attrib":{"idref":"fn002326"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002326"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be paragraph “(1)(A)(iii)”."}],"tail":" shall be 1 of the following:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcf8594f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2906/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Outstanding record of meeting community credit needs”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcf85950-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2906/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Satisfactory record of meeting community credit needs”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcf85951-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2906/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Needs to improve record of meeting community credit needs”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcf85952-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2906/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Substantial noncompliance in meeting community credit needs”.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Such ratings shall be disclosed to the public on and after ","children":[{"tag":"date","attrib":{"date":"1990-07-01"},"text":"July 1, 1990","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcf85953-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2906/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidential section of report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcf85954-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2906/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Privacy of named individuals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The confidential section of the written evaluation shall contain all references that identify any customer of the institution, any employee or officer of the institution, or any person or organization that has provided information in confidence to a Federal or State financial supervisory agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf85955-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2906/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Topics not suitable for disclosure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The confidential section shall also contain any statements obtained or made by the appropriate Federal financial supervisory agency in the course of an examination which, in the judgment of the agency, are too sensitive or speculative in nature to disclose to the institution or the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf85956-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2906/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure to depository institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The confidential section may be disclosed, in whole or part, to the institution, if the appropriate Federal financial supervisory agency determines that such disclosure will promote the objectives of this chapter. However, disclosure under this paragraph shall not identify a person or organization that has provided information in confidence to a Federal or State financial supervisory agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcf85957-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2906/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institutions with interstate branches","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcf85958-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2906/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State-by-State evaluation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a regulated financial institution that maintains domestic branches in 2 or more States, the appropriate Federal financial supervisory agency shall prepare—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcf85959-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2906/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a written evaluation of the entire institution’s record of performance under this chapter, as required by subsections (a), (b), and (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcf8595a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2906/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each State in which the institution maintains 1 or more domestic branches, a separate written evaluation of the institution’s record of performance within such State under this chapter, as required by subsections (a), (b), and (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf8595b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2906/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multistate metropolitan areas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a regulated financial institution that maintains domestic branches in 2 or more States within a multistate metropolitan area, the appropriate Federal financial supervisory agency shall prepare a separate written evaluation of the institution’s record of performance within such metropolitan area under this chapter, as required by subsections (a), (b), and (c). If the agency prepares a written evaluation pursuant to this paragraph, the scope of the written evaluation required under paragraph (1)(B) shall be adjusted accordingly.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf8595c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2906/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content of State level evaluation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A written evaluation prepared pursuant to paragraph (1)(B) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcf8595d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2906/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" present the information required by subparagraphs (A) and (B) of subsection (b)(1) separately for each metropolitan area in which the institution maintains 1 or more domestic branch offices and separately for the remainder of the nonmetropolitan area of the State if the institution maintains 1 or more domestic branch offices in such nonmetropolitan area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcf8595e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2906/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe how the Federal financial supervisory agency has performed the examination of the institution, including a list of the individual branches examined.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcf8595f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2906/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section the following definitions shall apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcf85960-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2906/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Domestic branch","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “domestic branch” means any branch office or other facility of a regulated financial institution that accepts deposits, located in any State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf85961-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2906/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Metropolitan area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “metropolitan area” means any primary metropolitan statistical area, metropolitan statistical area, or consolidated metropolitan statistical area, as defined by the Director of the Office of Management and Budget, with a population of 250,000 or more, and any other area designated as such by the appropriate Federal financial supervisory agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf85962-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2906/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"section 1813 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcf85963-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/128/tVIII/s807"},"text":"Pub. L. 95–128, title VIII, § 807","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/73/tXII/s1212/b"},"text":"Pub. L. 101–73, title XII, § 1212(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/527"},"text":"103 Stat. 527","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/242/tII/s222"},"text":"Pub. L. 102–242, title II, § 222","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2306"},"text":"105 Stat. 2306","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/328/tI/s110"},"text":"Pub. L. 103–328, title I, § 110","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-29"},"text":"Sept. 29, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2364"},"text":"108 Stat. 2364","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcf85964-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcf85965-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddcf85966-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (b)(1)(A)(i) and (c)(3), was in the original “this Act” and was translated as reading “this title”, meaning title VIII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/128"},"text":"Pub. L. 95–128","children":[],"tail":", known as the Community Reinvestment Act of 1977, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcf85967-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/328/s110/b"},"text":"Pub. L. 103–328, § 110(b)","children":[],"tail":", redesignated existing provisions as subpar. (A) and former subpars. (A) to (C) as cls. (i) to (iii), respectively, of subpar. (A), inserted subpar. (A) heading, and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/328/s110/a"},"text":"Pub. L. 103–328, § 110(a)","children":[],"tail":", added subsecs. (d) and (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/s222/b/1"},"text":"Pub. L. 102–242, § 222(b)(1)","children":[],"tail":", substituted “financial supervisory” for “depository institutions regulatory”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/s222/b/2"},"text":"Pub. L. 102–242, § 222(b)(2)","children":[],"tail":", substituted “financial supervisory” for “depository institutions regulatory” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/s222/a"},"text":"Pub. L. 102–242, § 222(a)","children":[],"tail":", inserted “and data” after “facts”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/s222/b/3"},"text":"Pub. L. 102–242, § 222(b)(3)","children":[],"tail":", substituted “financial supervisory” for “depository institutions regulatory” wherever appearing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
