{"tag":"section","attrib":{"id":"iddd20ef5d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4402"},"text":null,"children":[{"tag":"num","attrib":{"value":"4402"},"text":"§ 4402.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd20ef5e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4402/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Broker or dealer","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “broker or dealer” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd20ef5f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4402/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any company that is registered or licensed under Federal or State law to engage in the business of brokering, underwriting, or dealing in securities in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd20ef60-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4402/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent consistent with this title,","children":[{"tag":"ref","attrib":{"idref":"fn002398"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002398"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" as determined by the Board of Governors of the Federal Reserve System, any company that is an affiliate of a company described in subparagraph (A) and that is engaged in the business of entering into netting contracts."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd20ef61-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4402/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clearing organization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “clearing organization” means a clearinghouse, clearing association, clearing corporation, or similar organization—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd20ef62-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4402/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that provides clearing, netting, or settlement services for its members and—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd20ef63-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4402/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in which all members other than the clearing organization itself are financial institutions or other clearing organizations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd20ef64-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4402/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is registered as a clearing agency under the Securities Exchange Act of 1934 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78a"},"text":"15 U.S.C. 78a","children":[],"tail":" et seq.], or is exempt from such registration by order of the Securities and Exchange Commission; or"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd20ef65-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4402/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is registered as a derivatives clearing organization under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7a–1"},"text":"section 7a–1 of title 7","children":[],"tail":", that has been granted an exemption under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s6/c/1"},"text":"section 6(c)(1) of title 7","children":[],"tail":", or that is a multilateral clearing organization (as defined in section 4421 "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd20ef66-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4402/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered clearing obligation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered clearing obligation” means an obligation of a member of a clearing organization to make payment to another member of a clearing organization, subject to a netting contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd20ef67-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4402/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered contractual payment entitlement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered contractual payment entitlement” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd20ef68-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4402/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an entitlement of a financial institution to receive a payment, subject to a netting contract from another financial institution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd20ef69-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4402/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an entitlement of a member of a clearing organization to receive payment, subject to a netting contract, from another member of a clearing organization of a covered clearing obligation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd20ef6a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4402/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered contractual payment obligation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered contractual payment obligation” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd20ef6b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4402/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an obligation of a financial institution to make payment, subject to a netting contract to another financial institution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd20ef6c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4402/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a covered clearing obligation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd20ef6d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4402/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Depository institution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “depository institution” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd20ef6e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4402/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a depository institution as defined in section 19(b)(1)(A) of the Federal Reserve Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s461/b/1/A"},"text":"12 U.S.C. 461(b)(1)(A)","children":[],"tail":"] (other than clause (vii));"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd20ef6f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4402/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an uninsured national bank or an uninsured State bank that is a member of the Federal Reserve System, if the national bank or State member bank is not eligible to make application to become an insured bank under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1815"},"text":"section 1815 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd20ef70-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4402/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a branch or agency of a foreign bank, a foreign bank and any branch or agency of the foreign bank, or the foreign bank that established the branch or agency, as those terms are defined in section 1(b) of the International Banking Act of 1978 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s3101"},"text":"12 U.S.C. 3101","children":[],"tail":"];"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd20ef71-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4402/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a corporation chartered under section 25(a) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of the Federal Reserve Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t12/s611"},"text":"12 U.S.C. 611","children":[],"tail":" et seq.]; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd20ef72-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4402/6/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a corporation having an agreement or undertaking with the Board of Governors of the Federal Reserve System under section 25 of the Federal Reserve Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s601"},"text":"12 U.S.C. 601","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd20ef73-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4402/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failed financial institution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “failed financial institution” means a financial institution that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd20ef74-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4402/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fails to satisfy a covered contractual payment obligation when due;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd20ef75-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4402/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has commenced or had commenced against it insolvency, liquidation, reorganization, receivership (including the appointment of a receiver), conservatorship, or similar proceedings; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd20ef76-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4402/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has generally ceased to meet its obligations when due.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd20ef77-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4402/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failed member","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “failed member” means any member that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd20ef78-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4402/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fails to satisfy a covered clearing obligation when due,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd20ef79-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4402/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has commenced or had commenced against it insolvency, liquidation, reorganization, receivership (including the appointment of a receiver), conservatorship, or similar proceedings, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd20ef7a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4402/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has generally ceased to meet its obligations when due.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd20ef7b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4402/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “financial institution” means a broker or dealer, a depository institution, a futures commission merchant, or any other institution as determined by the Board of Governors of the Federal Reserve System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd20ef7c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4402/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Futures commission merchant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “futures commission merchant” means a company that is registered or licensed under Federal law to engage in the business of selling futures and options in commodities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd20ef7d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4402/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Member","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “member” means a member of or participant in a clearing organization, and includes the clearing organization and any other clearing organization with which such clearing organization has a netting contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd20ef7e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4402/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Net entitlement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “net entitlement” means the amount by which the covered contractual payment entitlements of a financial institution or member exceed the covered contractual payment obligations of the institution or member after netting under a netting contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd20ef7f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4402/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Net obligation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “net obligation” means the amount by which the covered contractual payment obligations of a financial institution or member exceed the covered contractual payment entitlements of the institution or member after netting under a netting contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd20ef80-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4402/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Netting contract","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd20ef81-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4402/14/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “netting contract”—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd20ef82-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4402/14/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means a contract or agreement between 2 or more financial institutions, clearing organizations, or members that provides for netting present or future payment obligations or payment entitlements (including liquidation or close out values relating to such obligations or entitlements) among the parties to the agreement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd20ef83-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4402/14/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes the rules of a clearing organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd20ef84-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4402/14/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Invalid contracts not included","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “netting contract” does not include any contract or agreement that is invalid under or precluded by Federal law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd20ef85-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4402/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “payment” means a payment of United States dollars, another currency, or a composite currency, and a noncash delivery, including a payment or delivery to liquidate an unmatured obligation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd20ef86-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/tIV/s402"},"text":"Pub. L. 102–242, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2372"},"text":"105 Stat. 2372","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXVI/s1606/a"},"text":"Pub. L. 102–550, title XVI, § 1606(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4087"},"text":"106 Stat. 4087","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/5/tI/s112/a/2"},"text":"Pub. L. 106–554, § 1(a)(5) [title I, §§ 112(a)(2), 123(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–391, 2763A–411; "},{"tag":"ref","attrib":{"href":"/us/pl/109/8/tIX/s906/a"},"text":"Pub. L. 109–8, title IX, § 906(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/167"},"text":"119 Stat. 167","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd20ef87-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd20ef88-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd20ef89-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This title, referred to in par. (1)(B), means title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242"},"text":"Pub. L. 102–242","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2371"},"text":"105 Stat. 2371","children":[],"tail":". For complete classification of title IV to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Securities Exchange Act of 1934, referred to in par. (2)(A)(ii), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-06/ch404"},"text":"act June 6, 1934, ch. 404","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/881"},"text":"48 Stat. 881","children":[],"tail":", which is classified principally to chapter 2B (§ 78a et seq.) of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78a"},"text":"section 78a of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4421"},"text":"Section 4421 of this title","children":[],"tail":", referred to in par. (2)(B), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tVII/s740"},"text":"Pub. L. 111–203, title VII, § 740","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1729"},"text":"124 Stat. 1729","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 25(a) of the Federal Reserve Act, referred to in par. (6), which is classified to subchapter II (§ 611 et seq.) of chapter 6 of this title, was renumbered section 25A of that act by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/tI/s142/e/2"},"text":"Pub. L. 102–242, title I, § 142(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2281"},"text":"105 Stat. 2281","children":[],"tail":". Section 25 of the Federal Reserve Act is classified to subchapter I (§ 601 et seq.) of chapter 6 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd20ef8a-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—Par. (2)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/s906/a/1/A"},"text":"Pub. L. 109–8, § 906(a)(1)(A)","children":[],"tail":", inserted before semicolon “, or is exempt from such registration by order of the Securities and Exchange Commission”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/s906/a/1/B"},"text":"Pub. L. 109–8, § 906(a)(1)(B)","children":[],"tail":", inserted before period at end “, that has been granted an exemption under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s6/c/1"},"text":"section 6(c)(1) of title 7","children":[],"tail":", or that is a multilateral clearing organization (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4421"},"text":"section 4421 of this title","children":[],"tail":")”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (6)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/s906/a/2/B"},"text":"Pub. L. 109–8, § 906(a)(2)(B)","children":[],"tail":", added subpar. (B). Former subpar. (B) redesignated (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (6)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/s906/a/2/A"},"text":"Pub. L. 109–8, § 906(a)(2)(A)","children":[],"tail":", (C), redesignated subpar. (B) as (C) and amended it generally. Prior to amendment, subpar. (C) read as follows: “a branch or agency as defined in section 1(b) of the International Banking Act of 1978;”. Former subpar. (C) redesignated (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (6)(D), (E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/s906/a/2/A"},"text":"Pub. L. 109–8, § 906(a)(2)(A)","children":[],"tail":", redesignated subpars. (C) and (D) as (D) and (E), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/s906/a/3"},"text":"Pub. L. 109–8, § 906(a)(3)","children":[],"tail":", inserted before period at end “and any other clearing organization with which such clearing organization has a netting contract”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (14)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/s906/a/4"},"text":"Pub. L. 109–8, § 906(a)(4)","children":[],"tail":", amended cl. (i) generally. Prior to amendment, cl. (i) read as follows: “means a contract or agreement between 2 or more financial institutions or members, that—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(I) is governed by the laws of the United States, any State, or any political subdivision of any State, and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(II) provides for netting present or future payment obligations or payment entitlements (including liquidation or close-out values relating to the obligations or entitlements) among the parties to the agreement; and”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (15). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/s906/a/5"},"text":"Pub. L. 109–8, § 906(a)(5)","children":[],"tail":", added par. (15)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/5/tI/s112/a/2"},"text":"Pub. L. 106–554, § 1(a)(5) [title I, § 112(a)(2)]","children":[],"tail":", substituted “this subchapter” for “this chapter” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/5/tI/s123/b"},"text":"Pub. L. 106–554, § 1(a)(5) [title I, § 123(b)]","children":[],"tail":", added subpar. (B) and struck out former subpar. (B) which read as follows: “that performs clearing functions for a contract market designated pursuant to the Commodity Exchange Act.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Par. (14)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550"},"text":"Pub. L. 102–550","children":[],"tail":" substituted “Federal law” for “Federal commodities law”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd20ef8b-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd20ef8c-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2005 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment 