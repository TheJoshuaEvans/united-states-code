{"tag":"section","attrib":{"id":"iddd1e7ffa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4308"},"text":null,"children":[{"tag":"num","attrib":{"value":"4308"},"text":"§ 4308.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd1e7ffb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4308/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd1e7ffc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4308/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before the end of the 9-month period beginning on ","children":[{"tag":"date","attrib":{"date":"1991-12-19"},"text":"December 19, 1991","children":[],"tail":", the Bureau, after consultation with each agency referred to in "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4309/a"},"text":"section 4309(a) of this title","children":[],"tail":" and public notice and opportunity for comment, shall prescribe regulations to carry out the purpose and provisions of this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1e7ffd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4308/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date of regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The regulations prescribed under paragraph (1) shall take effect not later than 9 months after publication in final form.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1e7ffe-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4308/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The regulations prescribed under paragraph (1) may contain such classifications, differentiations, or other provisions, and may provide for such adjustments and exceptions for any class of accounts as, in the judgment of the Bureau, are necessary or proper to carry out the purposes of this chapter, to prevent circumvention or evasion of the requirements of this chapter, or to facilitate compliance with the requirements of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1e7fff-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4308/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Date of applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of this chapter shall not apply with respect to any depository institution before the effective date of regulations prescribed by the Bureau under this subsection (or by the National Credit Union Administration Bureau ","children":[{"tag":"ref","attrib":{"idref":"fn002393"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002393"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Board”."}],"tail":" under section 4311(b) "},{"tag":"ref","attrib":{"idref":"fn002394"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002394"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":" of this title, in the case of any depository institution described in clause (iv) of "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s461/b/1/A"},"text":"section 461(b)(1)(A) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1e8000-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4308/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Model forms and clauses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd1e8001-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4308/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Bureau shall publish model forms and clauses for common disclosures to facilitate compliance with this chapter. In devising such forms, the Bureau shall consider the use by depository institutions of data processing or similar automated machines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1e8002-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4308/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of forms and clauses deemed in compliance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this chapter may be construed to require a depository institution to use any such model form or clause prescribed by the Bureau under this subsection. A depository institution shall be deemed to be in compliance with the disclosure provisions of this chapter if the depository institution—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd1e8003-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4308/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uses any appropriate model form or clause as published by the Bureau; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd1e8004-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4308/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" uses any such model form or clause and changes it by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd1e8005-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4308/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deleting any information which is not required by this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd1e8006-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4308/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rearranging the format,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"if in making such deletion or rearranging the format, the depository institution does not affect the substance, clarity, or meaningful sequence of the disclosure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1e8007-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4308/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public notice and opportunity for comment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Model disclosure forms and clauses shall be adopted by the Bureau after duly given notice in the Federal Register and an opportunity for public comment in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd1e8008-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/tII/s269"},"text":"Pub. L. 102–242, title II, § 269","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2338"},"text":"105 Stat. 2338","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tIX/s957/b"},"text":"Pub. L. 102–550, title IX, § 957(b)","children":[],"tail":", title XVI, § 1604(e)(2)(D)–(H), "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3897"},"text":"106 Stat. 3897","children":[],"tail":", 4084; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1100B/1"},"text":"Pub. L. 111–203, title X, § 1100B(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2109"},"text":"124 Stat. 2109","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd1e8009-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd1e800a-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd1e800b-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4311/b"},"text":"Section 4311(b) of this title","children":[],"tail":", referred to in subsec. (a)(4), was in the original “section 12(b)”, probably meaning "},{"tag":"ref","attrib":{"href":"/us/pl/102/242/s12/b"},"text":"section 12(b) of Pub. L. 102–242","children":[],"tail":", and was translated as meaning "},{"tag":"ref","attrib":{"href":"/us/pl/102/242/s272/b"},"text":"section 272(b) of Pub. L. 102–242","children":[],"tail":", to reflect the probable intent of Congress. There is no "},{"tag":"ref","attrib":{"href":"/us/pl/102/242/s12"},"text":"section 12 of Pub. L. 102–242","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/102/242/s272/b"},"text":"section 272(b) of Pub. L. 102–242","children":[],"tail":" relates to regulations prescribed by the National Credit Union Administration Board."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd1e800c-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" substituted “Bureau” for “Board” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/s1604/e/2/D"},"text":"Pub. L. 102–550, § 1604(e)(2)(D)","children":[],"tail":"–(H), made technical amendment to references to “this chapter” wherever appearing to reflect correction of corresponding provision of original act."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/s957/b"},"text":"Pub. L. 102–550, § 957(b)","children":[],"tail":", substituted “9 months” for “6 months”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd1e800d-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd1e800e-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective on the designated transfer date, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1100H"},"text":"section 1100H of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd1e800f-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/s1604"},"text":"section 1604 of Pub. L. 102–550","children":[],"tail":" effective as if included in the Federal Deposit Insurance Corporation Improvement Act of 1991, "},{"tag":"ref","attrib":{"href":"/us/pl/102/242"},"text":"Pub. L. 102–242","children":[],"tail":", as of "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/p