{"tag":"section","attrib":{"id":"iddccb0824-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2213"},"text":null,"children":[{"tag":"num","attrib":{"value":"2213"},"text":"§ 2213.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulation and examination","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The corporations organized under this part shall be institutions of the Farm Credit System and shall be subject to the same regulation and examination by the Farm Credit Administration as are the organizing bank or banks under this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddccb0825-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tIV/s4"},"text":"Pub. L. 92–181, title IV, § 4","children":[],"tail":".27, as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/592/tIV/s404"},"text":"Pub. L. 96–592, title IV, § 404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-24"},"text":"Dec. 24, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3447"},"text":"94 Stat. 3447","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/205/tII/s205/f/10"},"text":"Pub. L. 99–205, title II, § 205(f)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1706"},"text":"99 Stat. 1706","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tVIII/s802/t"},"text":"Pub. L. 100–233, title VIII, § 802(t)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1712"},"text":"101 Stat. 1712","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddccb0826-3a6f-11f1-8fa0-c065796a7f06"},