{"tag":"section","attrib":{"id":"iddcc64ccf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2157"},"text":null,"children":[{"tag":"num","attrib":{"value":"2157"},"text":"§ 2157.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bonds as investments","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The bonds, debentures, and other similar obligations issued under the authority of this chapter shall be lawful investments for all fiduciary and trust funds and may be accepted as security for all public deposits.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddcc64cd0-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tIV/s4"},"text":"Pub. L. 92–181, title IV, § 4","children":[],"tail":".6, "},{"tag":"date","attrib":{"date":"1971-12-10"},"text":"Dec. 10, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/612"},"text":"85 Stat. 612","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
