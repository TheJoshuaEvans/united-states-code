{"tag":"section","attrib":{"id":"iddb7f9c6e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1444"},"text":null,"children":[{"tag":"num","attrib":{"value":"1444"},"text":"§ 1444.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility to membership in banks","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddb7f9c6f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1444/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any organization organized under the laws of any State and subject to inspection and regulation under the banking or similar laws of such State shall be eligible to become a member under this chapter if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb7f9c70-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1444/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is organized solely for the purpose of supplying credit to its members;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb7f9c71-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1444/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" its membership (A) is confined exclusively to building and loan associations, savings and loan associations, cooperative banks, and homestead associations; or (B) is confined exclusively to savings banks; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb7f9c72-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1444/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of the institutions to which its membership is confined which are organized within the State, its membership includes a majority of such institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb7f9c73-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1444/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In all respects, but subject to such additional rules and regulations as the Director may provide, any such organization shall be a member for the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddb7f9c74-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1932-07-22/ch522/s24"},"text":"July 22, 1932, ch. 522, § 24","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/47/739"},"text":"47 Stat. 739","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/73/tVII/s701/b/1"},"text":"Pub. L. 101–73, title VII, § 701(b)(1)","children":[],"tail":", (3)(A), "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/412"},"text":"103 Stat. 412","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tII/s1204/8"},"text":"Pub. L. 110–289, div. A, title II, § 1204(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2786"},"text":"122 Stat. 2786","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb7f9c75-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb7f9c76-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddb7f9c77-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289"},"text":"Pub. L. 110–289","children":[],"tail":" substituted “the Director” for “the Board”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73"},"text":"Pub. L. 101–73","children":[],"tail":" substituted “Board” for “board”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
