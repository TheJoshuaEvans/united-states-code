{"tag":"section","attrib":{"id":"iddd4715ec-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5103"},"text":null,"children":[{"tag":"num","attrib":{"value":"5103"},"text":"§ 5103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" License or registration required","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd4715ed-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the existence of a licensing or registration regime, as the case may be, an individual may not engage in the business of a loan originator without first—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd4715ee-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5103/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" obtaining, and maintaining annually—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd4715ef-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5103/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a registration as a registered loan originator; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd4715f0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5103/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a license and registration as a State-licensed loan originator; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4715f1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5103/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtaining a unique identifier.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd4715f2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan processors and underwriters","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd4715f3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5103/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supervised loan processors and underwriters","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A loan processor or underwriter who does not represent to the public, through advertising or other means of communicating or providing information (including the use of business cards, stationery, brochures, signs, rate lists, or other promotional items), that such individual can or will perform any of the activities of a loan originator shall not be required to be a State-licensed loan originator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4715f4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5103/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Independent contractors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An independent contractor may not engage in residential mortgage loan origination activities as a loan processor or underwriter unless such independent contractor is a State-licensed loan originator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd4715f5-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tV/s1504"},"text":"Pub. L. 110–289, div. A, title V, § 1504","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2814"},"text":"122 Stat. 2814","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
