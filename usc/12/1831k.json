{"tag":"section","attrib":{"id":"iddc96b109-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831k"},"text":null,"children":[{"tag":"num","attrib":{"value":"1831k"},"text":"§ 1831k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reward for information leading to recoveries or civil penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc96b10a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831k/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An appropriate Federal banking agency, with the concurrence of the Attorney General, may pay a reward to a person who provides original information which leads to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc96b10b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831k/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" recovery of a criminal fine, restitution, or civil penalty—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc96b10c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831k/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" under—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddc96b10d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831k/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc96b10e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831k/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Credit Union Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1751"},"text":"12 U.S.C. 1751","children":[],"tail":" et seq.];"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc96b10f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831k/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 93(b), 164, or 481 to 485 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc96b110-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831k/a/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Reserve Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s221"},"text":"12 U.S.C. 221","children":[],"tail":" et seq.];"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc96b111-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831k/a/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Bank Holding Company Act Amendments of 1970;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc96b112-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831k/a/1/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Bank Holding Company Act of 1956 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1841"},"text":"12 U.S.C. 1841","children":[],"tail":" et seq.];"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc96b113-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831k/a/1/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Home Owners’ Loan Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1461"},"text":"12 U.S.C. 1461","children":[],"tail":" et seq.]; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc96b114-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831k/a/1/A/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3663"},"text":"section 3663 of title 18","children":[],"tail":" pursuant to a conviction for an offense referred to in subparagraph (B) of this paragraph,"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc96b115-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831k/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pursuant to a conviction for an offense under section 215, 656, 657, 1005, 1006, 1007, 1014, 1341, 1343, or 1344 of title 18 affecting a depository institution insured by the Federal Deposit Insurance Corporation, or for a conspiracy to commit such an offense; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc96b116-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831k/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1833a"},"text":"section 1833a of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc96b117-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831k/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a forfeiture under section 981 or 982 of title 18 that arises in connection with a depository institution insured by the Federal Deposit Insurance Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc96b118-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831k/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Percentage limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An appropriate Federal banking agency may not pay a reward under subsection (a) of more than 25 percent of the amount of the fine, penalty, restitution, or forfeiture or $100,000, whichever is less.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc96b119-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831k/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Officials and persons ineligible","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An appropriate Federal banking agency may not pay a reward under subsection (a) to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc96b11a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831k/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an officer or employee of the United States or of a State or local government who provides information described in subsection (a), obtained in the performance of official duties; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc96b11b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831k/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a person who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc96b11c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831k/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deliberately causes or participates in the alleged violation of law or regulation, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc96b11d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831k/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly or recklessly provides substantially false information to such an agency or the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc96b11e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831k/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonreviewability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any agency decision under this section is final and not reviewable by any court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc96b11f-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-21/ch967/s2"},"text":"Sept. 21, 1950, ch. 967, § 2","children":[],"tail":"[34], as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/73/tIX/s933/a"},"text":"Pub. L. 101–73, title IX, § 933(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/495"},"text":"103 Stat. 495","children"