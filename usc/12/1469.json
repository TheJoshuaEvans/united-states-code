{"tag":"section","attrib":{"id":"iddb9c4bd4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1469"},"text":null,"children":[{"tag":"num","attrib":{"value":"1469"},"text":"§ 1469.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to invest in State housing corporations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Congress finds that Federal savings and loan associations and national banks should have the authority to assist in financing the organization and operation of any State housing corporation established under the laws of the State in which the corporation will carry on its operation. It is the purpose of this section to provide a means whereby private financial institutions can assist in providing housing, particularly for families of low- or moderate-income, by purchasing stock of and investing in loans to any such State housing corporation situated in the particular State in which the Federal savings and loan association or national bank involved is located.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddb9c4bd5-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/100/s5/a"},"text":"Pub. L. 93–100, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-08-16"},"text":"Aug. 16, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/343"},"text":"87 Stat. 343","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb9c4bd6-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb9c4bd7-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddb9c4bd8-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This section, referred to in text, means ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/100/s5"},"text":"section 5 of Pub. L. 93–100","children":[],"tail":", which enacted this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1470"},"text":"section 1470 of this title","children":[],"tail":" and amended sections 24 and 1464 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddb9c4bd9-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Home Owners’ Loan Act of 1933 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddb9c4bda-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddb9c4bdb-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/100/s8"},"text":"Pub. L. 93–100, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-08-16"},"text":"Aug. 16, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/348"},"text":"87 Stat. 348","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/93/100/s8"},"text":"“The provisions of this Act [enacting this section and sections 1470 and 1832 of this title, amending sections 24, 461 note, 1464, 1725, 1727 and 1828 of this title, and enacting provisions set out as notes under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s548"},"text":"section 548 of this title","children":[],"tail":"] shall take effect on the thirtieth day after the date of its enactment ["},{"tag":"date","attrib":{"date":"1973-08-16"},"text":"Aug. 16, 1973","children":[],"tail":"], except that the amendments made by sections 1 and 5 [enacting this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1470"},"text":"section 1470 of this title","children":[],"tail":" and amending sections 24, 461 note, and 1464 of this title] shall take effect on the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1973-08-16"},"text":"Aug. 16, 1973","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
