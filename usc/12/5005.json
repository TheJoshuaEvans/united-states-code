{"tag":"section","attrib":{"id":"iddd44a480-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5005"},"text":null,"children":[{"tag":"num","attrib":{"value":"5005"},"text":"§ 5005.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indemnity","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd44a481-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5005/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indemnity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A reconverting bank and each bank that subsequently transfers, presents, or returns a substitute check in any electronic or paper form, and receives consideration for such transfer, presentment, or return shall indemnify the transferee, any subsequent collecting or returning bank, the depositary bank, the drawee, the drawer, the payee, the depositor, and any endorser, up to the amount described in subsections (b) and (c), as applicable, to the extent of any loss incurred by any recipient of a substitute check if that loss occurred due to the receipt of a substitute check instead of the original check.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd44a482-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5005/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indemnity amount","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd44a483-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5005/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount in event of breach of warranty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of the indemnity under subsection (a) shall be the amount of any loss (including costs and reasonable attorney’s fees and other expenses of representation) proximately caused by a breach of a warranty provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5004"},"text":"section 5004 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd44a484-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5005/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount in absence of breach of warranty","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the absence of a breach of a warranty provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5004"},"text":"section 5004 of this title","children":[],"tail":", the amount of the indemnity under subsection (a) shall be the sum of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd44a485-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5005/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of any loss, up to the amount of the substitute check; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd44a486-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5005/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interest and expenses (including costs and reasonable attorney’s fees and other expenses of representation).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd44a487-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5005/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comparative negligence","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd44a488-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5005/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a loss described in subsection (a) results in whole or in part from the negligence or failure to act in good faith on the part of an indemnified party, then that party’s indemnification under this section shall be reduced in proportion to the amount of negligence or bad faith attributable to that party.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd44a489-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5005/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection reduces the rights of a consumer or any other person under the Uniform Commercial Code or other applicable provision of Federal or State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd44a48a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5005/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of producing original check or copy","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd44a48b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5005/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the indemnifying bank produces the original check or a copy of the original check (including an image or a substitute check) that accurately represents all of the information on the front and back of the original check (as of the time the original check was truncated) or is otherwise sufficient to determine whether or not a claim is valid, the indemnifying bank shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd44a48c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5005/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be liable under this section only for losses covered by the indemnity that are incurred up to the time that the original check or copy is provided to the indemnified party; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd44a48d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5005/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have a right to the return of any funds it has paid under the indemnity in excess of those losses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd44a48e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5005/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination of indemnity with implied warranty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The production of the original check, a substitute check, or a copy under paragraph (1) by an indemnifying bank shall not absolve the bank from any liability on a warranty established under this chapter or any other provision of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd44a48f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5005/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subrogation of rights","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd44a490-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5005/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each indemnifying bank shall be subrogated to the rights of any indemnified party to the extent of the indemnity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd44a491-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5005/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery under warranty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A bank that indemnifies a party under this section may attempt to recover from another party based on a warranty or other claim.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd44a492-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5005/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duty of indemnified party","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each indemnified party shall have a duty to comply with all reasonable requests for assistance from an indemnifying bank in connection with any claim the indemnifying bank brings against a warrantor or other party related to a check that forms the basis for the indemnification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd44a493-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/100/s6"},"text":"Pub. L. 108–100, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-10-28"},"text":"Oct. 28, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1181"},"text":"117 Stat. 1181","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd44a494-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd44a495-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd44a496-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (d)(2), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/100"},"text":"Pub. L. 108–100","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-10-28"},"text":"Oct. 28, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1177"},"text":"117 Stat. 1177","children":[],"tail":", which is classified generally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5001"},"text":"section 5001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd44a497-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd44a498-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective at the end of the 12-month period beginning on ","children":[{"tag":"date","attrib":{"date":"2003-10-28"},"text":"Oct. 28, 2003","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/100/s20"},"text":"section 20 of Pub. L. 108–100","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5001"},"text":"section 5001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
