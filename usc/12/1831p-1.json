{"tag":"section","attrib":{"id":"iddc9b6bc3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831p–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1831p–1"},"text":"§ 1831p–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards for safety and soundness","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc9b6bc4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831p–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operational and managerial standards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each appropriate Federal banking agency shall, for all insured depository institutions, prescribe—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc9b6bc5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831p–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" standards relating to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc9b6bc6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831p–1/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" internal controls, information systems, and internal audit systems, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1831m"},"text":"section 1831m of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9b6bc7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831p–1/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" loan documentation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9b6bc8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831p–1/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" credit underwriting;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9b6bc9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831p–1/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interest rate exposure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9b6bca-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831p–1/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" asset growth; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9b6bcb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831p–1/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compensation, fees, and benefits, in accordance with subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc9b6bcc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831p–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other operational and managerial standards as the agency determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc9b6bcd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831p–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Asset quality, earnings, and stock valuation standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each appropriate Federal banking agency shall prescribe standards, by regulation or guideline, for all insured depository institutions relating to asset quality, earnings, and stock valuation that the agency determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc9b6bce-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831p–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation standards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each appropriate Federal banking agency shall, for all insured depository institutions, prescribe—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc9b6bcf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831p–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" standards prohibiting as an unsafe and unsound practice any employment contract, compensation or benefit agreement, fee arrangement, perquisite, stock option plan, post­employment benefit, or other compensatory arrangement that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc9b6bd0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831p–1/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would provide any executive officer, employee, director, or principal shareholder of the institution with excessive compensation, fees or benefits; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9b6bd1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831p–1/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" could lead to material financial loss to the institution;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc9b6bd2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831p–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" standards specifying when compensation, fees, or benefits referred to in paragraph (1) are excessive, which shall require the agency to determine whether the amounts are unreasonable or disproportionate to the services actually performed by the individual by considering—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc9b6bd3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831p–1/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the combined value of all cash and noncash benefits provided to the individual;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9b6bd4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831p–1/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the compensation history of the individual and other individuals with comparable expertise at the institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9b6bd5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831p–1/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the financial condition of the institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9b6bd6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831p–1/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comparable compensation practices at comparable institutions, based upon such factors as asset size, geographic location, and the complexity of the loan portfolio or other assets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9b6bd7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831p–1/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for postemployment benefits, the projected total cost and benefit to the institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9b6bd8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831p–1/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any connection between the individual and any fraudulent act or omission, breach of trust or fiduciary duty, or insider abuse with regard to the institution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9b6bd9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831p–1/c/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other factors that the agency determines to be relevant; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc9b6bda-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831p–1/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other standards relating to compensation, fees, and benefits as the agency determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc9b6bdb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831p–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards to be prescribed","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc9b6bdc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831p–1/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Standards under subsections (a), (b), and (c) shall be prescribed by regulation or guideline. Such regulations or guidelines may not prescribe standards that set a specific level or range of compensation for directors, officers, or employees of insured depository institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc9b6bdd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831p–1/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of other laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall not affect the authority of any appropriate Federal banking agency to restrict the level of compensation, including golden parachute payments (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1828/k/4"},"text":"section 1828(k)(4) of this title","children":[],"tail":"), paid to any director, officer, or employee of an insured depository institution under any other provision of law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc9b6bde-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831p–1/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Senior executive officers at undercapitalized institutions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall not affect the authority of any appropriate Federal banking agency to restrict compensation paid to any senior executive officer of an undercapitalized insured depository institution pursuant to section 1831","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc9b6bdf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831p–1/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Safety and soundness or enforcement actions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) shall not be construed as affecting the authority of any appropriate Federal banking agency under any provision of this chapter other than this section, or under any other provision of law, to prescribe a specific level or range of compensation for any director, officer, or employee of an insured depository institution—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc9b6be0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831p–1/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to preserve the safety and soundness of the institution; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9b6be1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831p–1/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in connection with any action under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1818"},"text":"section 1818 of this title","children":[],"tail":" or any order issued by the agency, any agreement between the agency and the institution, or any condition imposed by the agency in connection with the agency’s approval of an application or other request by the institution, which is enforceable under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1818"},"text":"section 1818 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc9b6be2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831p–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to meet standards","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc9b6be3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831p–1/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan required","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc9b6be4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831p–1/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the appropriate Federal banking agency determines that an insured depository institution fails to meet any standard prescribed under subsection (a) or (b)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddc9b6be5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831p–1/e/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if such standard is prescribed by regulation of the agency, the agency shall require the institution to submit an acceptable plan to the agency within the time allowed by the agency under subparagraph (C); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc9b6be6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831p–1/e/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if such standard is prescribed by guideline, the agency may require the institution to submit a plan described in clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9b6be7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831p–1/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any plan required under subparagraph (A) shall specify the steps that the institution will take to correct the deficiency. If the institution is undercapitalized, the plan may be part of a capital restoration plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9b6be8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831p–1/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadlines for submission and review of plans","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The appropriate Federal banking agency shall by regulation establish deadlines that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddc9b6be9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831p–1/e/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide institutions with reasonable time to submit plans required under subparagraph (A), and generally require the institution to submit a plan not later than 30 days after the agency determines that the institution fails to meet any standard prescribed under subsection (a), (b), or (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc9b6bea-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831p–1/e/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require the agency to act on plans expeditiously, and generally not later than 30 days after the plan is submitted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc9b6beb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831p–1/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Order required if institution fails to submit or implement plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If an insured depository institution fails to submit an acceptable plan within the time allowed under paragraph (1)(C), or fails in any material respect to implement a plan accepted by the appropriate Federal banking agency, the agency, by order—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc9b6bec-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831p–1/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall require the institution to correct the deficiency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9b6bed-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831p–1/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may do 1 or more of the following until the deficiency has been corrected:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddc9b6bee-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831p–1/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Prohibit the institution from permitting its average total assets during any calendar quarter to exceed its average total assets during the preceding calendar quarter, or restrict the rate at which the average total assets of the institution may increase from one calendar quarter to another.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc9b6bef-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831p–1/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Require the institution to increase its ratio of tangible equity to assets.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc9b6bf0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831p–1/e/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Take the action described in section 1831","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":"(f)(2)(C) of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc9b6bf1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831p–1/e/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Require the institution to take any other action that the agency determines will better carry out the purpose of section 1831","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title than any of the actions described in this subparagraph."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc9b6bf2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831p–1/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions mandatory for certain institutions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In complying with paragraph (2), the appropriate Federal banking agency shall take 1 or more of the actions described in clauses (i) through (iii) of paragraph (2)(B) if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc9b6bf3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831p–1/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agency determines that the insured depository institution fails to meet any standard prescribed under subsection (a)(1) or (b)(1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9b6bf4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831p–1/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the institution has not corrected the deficiency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9b6bf5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831p–1/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" either—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddc9b6bf6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831p–1/e/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" during the 24-month period before the date on which the institution first failed to meet the standard—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddc9b6bf7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831p–1/e/3/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the institution commenced operations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddc9b6bf8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831p–1/e/3/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 or more persons acquired control of the institution; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc9b6bf9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831p–1/e/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the 18-month period before the date on which the institution first failed to meet the standard, the institution underwent extraordinary growth, as defined by the agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc9b6bfa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831p–1/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the terms “average” and “capital restoration plan” have the same meanings as in section 1831","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc9b6bfb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831p–1/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other authority not affected","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority granted by this section is in addition to any other authority of the Federal banking agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc9b6bfc-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-21/ch967/s2"},"text":"Sept. 21, 1950, ch. 967, § 2","children":[],"tail":"[39], as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/242/tI/s132/a"},"text":"Pub. L. 102–242, title I, § 132(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2267"},"text":"105 Stat. 2267","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tIX/s956"},"text":"Pub. L. 102–550, title IX, § 956","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3895"},"text":"106 Stat. 3895","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/325/tIII/s318/a"},"text":"Pub. L. 103–325, title III, § 318(a)","children":[],"tail":"–(c), "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2223"},"text":"108 Stat. 2223","children":[],"tail":", 2224.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc9b6bfd-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc9b6bfe-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddc9b6bff-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1831s"},"text":"section 1831s of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 2[39] of act ","children":[{"tag":"date","attrib":{"date":"1950-09-21"},"text":"Sept. 21, 1950","children":[],"tail":", was renumbered section 2[42] and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1831r–1"},"text":"section 1831r–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc9b6c00-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/s318/c/1"},"text":"Pub. L. 103–325, § 318(c)(1)","children":[],"tail":", struck out “and depository institution holding companies” before “, prescribe” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/s318/a"},"text":"Pub. L. 103–325, § 318(a)","children":[],"tail":", amended heading and text of subsec. (b) generally. Prior to amendment, text read as follows: “Each appropriate Federal banking agency shall, for all insured depository institutions and depository institution holding companies, prescribe—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) standards specifying—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) a maximum ratio of classified assets to capital;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) minimum earnings sufficient to absorb losses without impairing capital; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) to the extent feasible, a minimum ratio of market value to book value for publicly traded shares of the institution or company; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) such other standards relating to asset quality, earnings, and valuation as the agency determines to be appropriate.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/s318/b/1"},"text":"Pub. L. 103–325, § 318(b)(1)","children":[],"tail":", struck out “by regulation” after “Standards to be prescribed” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/s318/b/2"},"text":"Pub. L. 103–325, § 318(b)(2)","children":[],"tail":", inserted “or guideline” before period at end of first sentence and inserted “or guidelines” after “Such regulations” in second sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/s318/c/2/A"},"text":"Pub. L. 103–325, § 318(c)(2)(A)","children":[],"tail":"–(C), struck out “or depository institution holding company” after “insured depository institution”, substituted “or (b)—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) if such standard is prescribed by regulation of the agency, the agency shall require”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"for “or (b) of this section the agency shall require”, struck out “or company” before “to submit an acceptable plan”, substituted “; and” for period at end of cl. (i), and added cl. (ii).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/s318/c/2/A"},"text":"Pub. L. 103–325, § 318(c)(2)(A)","children":[],"tail":", struck out “or company” before “will take to correct”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1)(C)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/s318/c/2/A"},"text":"Pub. L. 103–325, § 318(c)(2)(A)","children":[],"tail":", (D), struck out “and companies” after “institutions” and struck out “or company” after “institution” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/s318/c/2/B"},"text":"Pub. L. 103–325, § 318(c)(2)(B)","children":[],"tail":", struck out “or depository institution holding company” after “insured depository institution” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2)(A), (B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/s318/c/2/A"},"text":"Pub. L. 103–325, § 318(c)(2)(A)","children":[],"tail":", struck out “or company” after “institution” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/s956/1"},"text":"Pub. L. 102–550, § 956(1)","children":[],"tail":", added subsec. (d) and struck out former subsec. (d) which read as follows: “Standards under subsections (a), (b), and (c) of this section shall be prescribed by regulation.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/s956/2"},"text":"Pub. L. 102–550, § 956(2)","children":[],"tail":", substituted “(a) or (b)” for “(a), (b), or (c)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc9b6c01-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddc9b6c02-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/tIII/s318/d"},"text":"Pub. L. 103–325, title III, § 318(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2224"},"text":"108 Stat. 2224","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/325/tIII/s318/d"},"text":"“The amendments made by this section [amending this section] shall be construed to have the same effective date as section 39 of the Federal Deposit Insurance Act [this section], as provided in section 132(c) of the Federal Deposit Insurance Corporation Improvement Act of 1991 [","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242"},"text":"Pub. L. 102–242","children":[],"tail":", set out as an Effective Date note below].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddc9b6c03-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/tI/s132/c"},"text":"Pub. L. 102–242, title I, § 132(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2270"},"text":"105 Stat. 2270","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/242/tI/s132/c"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The amendment made by subsection (a) [enacting this section] shall become effective on the earlier of—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which final regulations promulgated in accordance with subsection (b) [set out below] become effective [Final rules were published ","children":[{"tag":"date","attrib":{"date":"1995-07-10"},"text":"July 10, 1995","children":[],"tail":", 60 F.R. 35674, eff. "},{"tag":"date","attrib":{"date":"1995-08-09"},"text":"Aug. 9, 1995","children":[],"tail":".]; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"date","attrib":{"date":"1993-12-01"},"text":"December 1, 1993","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddc9b6c04-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/tI/s132/b"},"text":"Pub. L. 102–242, title I, § 132(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2270"},"text":"105 Stat. 2270","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/242/tI/s132/b"},"text":"“Each appropriate Federal banking agency (as defined in section 3 of the Federal Deposit Insurance Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"12 U.S.C. 1813","children":[],"tail":"]) shall promulgate final regulations under section 39 of the Federal Deposit Insurance Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1831p–1"},"text":"12 U.S.C. 1831p–1","children":[],"tail":"] (as added by subsection (a)) not later than "},{"tag":"date","attrib":{"date":"1993-08-01"},"text":"August 1, 1993","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
