{"tag":"section","attrib":{"id":"iddd1c35c1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4201"},"text":null,"children":[{"tag":"num","attrib":{"value":"4201"},"text":"§ 4201.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Filing of confidential declarations by private persons","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd1c35c2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4201/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person may file a declaration of a violation giving rise to an action for civil penalties under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1833a"},"text":"section 1833a of this title","children":[],"tail":" affecting a depository institution insured by the Federal Deposit Insurance Corporation or any other agency or entity of the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1c35c3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4201/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Place of filing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A declaration under subsection (a) shall be filed with the Attorney General of the United States or with an agent designated by the Attorney General for receiving declarations under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd1c35c4-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXV/s2561"},"text":"Pub. L. 101–647, title XXV, § 2561","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4894"},"text":"104 Stat. 4894","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd1c35c5-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd1c35c6-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"iddd1c35c7-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXV/s2560"},"text":"Pub. L. 101–647, title XXV, § 2560","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4893"},"text":"104 Stat. 4893","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/647/tXXV/s2560"},"text":"“This subtitle [subtitle H (§§ 2560–2594) of title XXV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647"},"text":"Pub. L. 101–647","children":[],"tail":", enacting this chapter and "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3059A"},"text":"section 3059A of Title 18","children":[],"tail":", Crimes and Criminal Procedure, and amending "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1831k"},"text":"section 1831k of this title","children":[],"tail":"] may be cited as the ‘Financial Institutions Anti-Fraud Enforcement Act of 1990’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
