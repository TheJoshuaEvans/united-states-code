{"tag":"section","attrib":{"id":"iddcd2336f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2272"},"text":null,"children":[{"tag":"num","attrib":{"value":"2272"},"text":"§ 2272.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of service","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any service required or authorized to be made by the Farm Credit Administration under this section may be made by registered mail, or in such other manner reasonably calculated to give actual notice as the Farm Credit Administration may by regulation or otherwise provide. Any such service by mail is complete upon mailing. Copies of any notice or order served by the Farm Credit Administration on any association or any director or officer thereof or other person participating in the conduct of its affairs, under the provisions of this part, shall also be sent to the supervisory bank.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddcd23370-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tV/s5"},"text":"Pub. L. 92–181, title V, § 5","children":[],"tail":".36, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/205/tII/s204"},"text":"Pub. L. 99–205, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1702"},"text":"99 Stat. 1702","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcd23371-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcd23372-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddcd23373-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective thirty days after ","children":[{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/205/s401"},"text":"section 401 of Pub. L. 99–205","children":[],"tail":", set out as an Effective Date of 1985 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2001"},"text":"section 2001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
