e Emergency Banking and Bank Conservation Act, which is classified to sections 51a, 51b, 51c, 51d, 95, 201 to 212, 248, 347b, 347c, 347d, and 445 of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4305"},"text":"section 4305 of Title 50","children":[],"tail":", War and National Defense, and classified as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4305"},"text":"section 4305 of Title 50","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s51d"},"text":"Section 51d of this title","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/act/1947-06-30/ch166/tII/s206/b"},"text":"act June 30, 1947, ch. 166, title II, § 206(b)","children":[],"tail":", ("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"), "},{"tag":"ref","attrib":{"href":"/us/stat/61/208"},"text":"61 Stat. 208","children":[],"tail":". For effect of the repeal on outstanding debentures held by banks, see References in Text note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s51b–1"},"text":"section 51b–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddb203db1-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section was not enacted as part of title II of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-03-09/ch1"},"text":"act Mar. 9, 1933, ch. 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/2"},"text":"48 Stat. 2","children":[],"tail":", which comprises this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
