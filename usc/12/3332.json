{"tag":"section","attrib":{"id":"iddd0467e1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3332"},"text":null,"children":[{"tag":"num","attrib":{"value":"3332"},"text":"§ 3332.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions of Appraisal Subcommittee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd0467e2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3332/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Appraisal Subcommittee shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd0467e3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3332/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" monitor the requirements established by States—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd0467e4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3332/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the certification and licensing of individuals who are qualified to perform appraisals in connection with federally related transactions, including a code of professional responsibility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd0467e5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3332/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the registration and supervision of the operations and activities of an appraisal management company;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd0467e6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3332/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" monitor the requirements established by the Federal financial institutions regulatory agencies with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd0467e7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3332/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appraisal standards for federally related transactions under their jurisdiction, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd0467e8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3332/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determinations as to which federally related transactions under their jurisdiction require the services of a State certified appraiser and which require the services of a State licensed appraiser;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd0467e9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3332/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain a national registry of State certified and licensed appraisers who are eligible to perform appraisals in federally related transactions; and ","children":[{"tag":"ref","attrib":{"idref":"fn002340"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002340"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The word “and” probably should not appear."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd0467ea-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3332/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Omitted","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd0467eb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3332/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transmit an annual report to the Congress not later than June 15 of each year that describes the manner in which each function assigned to the Appraisal Subcommittee has been carried out during the preceding year. The report shall also detail the activities of the Appraisal Subcommittee, including the results of all audits of State appraiser regulatory agencies, and provide an accounting of disapproved actions and warnings taken in the previous year, including a description of the conditions causing the disapproval and actions taken to achieve compliance.","children":[{"tag":"ref","attrib":{"idref":"fn002341"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002341"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “compliance; and”."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd0467ec-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3332/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain a national registry of appraisal management companies that either are registered with and subject to supervision of a State appraiser certifying and licensing agency or are operating subsidiaries of a Federally regulated financial institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd0467ed-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3332/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring and reviewing foundation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Appraisal Subcommittee shall monitor and review the practices, procedures, activities, and organizational structure of the Appraisal Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd0467ee-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/tXI/s1103"},"text":"Pub. L. 101–73, title XI, § 1103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/512"},"text":"103 Stat. 512","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tIII/s367/6"},"text":"Pub. L. 111–203, title III, § 367(6)","children":[],"tail":", title XIV, § 1473(b), (f)(1), "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1557"},"text":"124 Stat. 1557","children":[],"tail":", 2190, 2191.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd0467ef-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd0467f0-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd0467f1-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Paragraph (4) of subsection (a), which required the Appraisal Subcommittee to submit an annual report to Congress on the manner in which assigned functions were carried out, terminated, effective ","children":[{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", pursuant to "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance. See, also, page 170 of House Document No. 103–7."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd0467f2-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1473/f/1/A"},"text":"Pub. L. 111–203, § 1473(f)(1)(A)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) read as follows: “monitor the requirements established by States for the certification and licensing of individuals who are qualified to perform appraisals in connection with federally related transactions, including a code of professional responsibility;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s367/6"},"text":"Pub. L. 111–203, § 367(6)","children":[],"tail":", struck out “and the Resolution Trust Corporation” after “agencies” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1473/b"},"text":"Pub. L. 111–203, § 1473(b)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1473/f/1/B"},"text":"Pub. L. 111–203, § 1473(f)(1)(B)","children":[],"tail":", added par. (6)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd0467f3-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd0467f4-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s367/6"},"text":"section 367(6) of Pub. L. 111–203","children":[],"tail":" effective on the transfer date, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s351"},"text":"section 351 of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s906"},"text":"section 906 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by section 1473(b), (f)(1), of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective on the date on which final regulations implementing that amendment take effect, or on the date that is 18 months after the designated transfer date if such regulations have not been issued by that date, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1400/c"},"text":"section 1400(c) of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1601"},"text":"section 1601 of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
