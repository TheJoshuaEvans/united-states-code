{"tag":"section","attrib":{"id":"iddc302786-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1746a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1746a"},"text":"§ 1746a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of commitment authority under this subchapter","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this subchapter, no mortgage or loan shall be insured under any section of this subchapter after ","children":[{"tag":"date","attrib":{"date":"1954-08-02"},"text":"August 2, 1954","children":[],"tail":" except pursuant to a commitment to insure issued on or before such date."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc302787-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-27/ch847"},"text":"June 27, 1934, ch. 847","children":[],"tail":", title VI, § 612, as added "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-02/ch649"},"text":"Aug. 2, 1954, ch. 649","children":[],"tail":", title I, § 127, "},{"tag":"ref","attrib":{"href":"/us/stat/68/609"},"text":"68 Stat. 609","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
