{"tag":"section","attrib":{"id":"iddc244073-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1735a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1735a"},"text":"§ 1735a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prepayment of mortgages by nonprofit educational institutions; refunds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc244074-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1735a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of this chapter, no adjusted premium charge shall be collected in connection with the payment in full, prior to maturity, of any mortgage insured under this chapter, if the mortgagor certifies to the Secretary that the loan was paid in full by or on behalf of a nonprofit educational institution which intends to use the property for educational purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc244075-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1735a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall refund any adjusted premium charge collected subsequent to ","children":[{"tag":"date","attrib":{"date":"1962-07-01"},"text":"July 1, 1962","children":[],"tail":", and prior to "},{"tag":"date","attrib":{"date":"1964-09-02"},"text":"September 2, 1964","children":[],"tail":", in connection with the payment in full, prior to maturity, of any mortgage insured under this chapter, if the mortgagor under such mortgage makes the certification prescribed by subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc244076-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-27/ch847"},"text":"June 27, 1934, ch. 847","children":[],"tail":", title V, § 517, as added "},{"tag":"ref","attrib":{"href":"/us/pl/88/560/tI/s120"},"text":"Pub. L. 88–560, title I, § 120","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-09-02"},"text":"Sept. 2, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/782"},"text":"78 Stat. 782","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/90/19/s1/a/3"},"text":"Pub. L. 90–19, § 1(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-05-25"},"text":"May 25, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/17"},"text":"81 Stat. 17","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc244077-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc244078-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc244079-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1967—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/19"},"text":"Pub. L. 90–19","children":[],"tail":" substituted “Secretary” for “Commissioner” wherever appearing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
