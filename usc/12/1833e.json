{"tag":"section","attrib":{"id":"iddca4e2bc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1833e"},"text":null,"children":[{"tag":"num","attrib":{"value":"1833e"},"text":"§ 1833e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equal opportunity","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddca4e2bd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1833e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this Act, Executive Order Numbered 11478, providing for equal employment opportunity in the Federal Government, shall apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddca4e2be-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1833e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Comptroller of the Currency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca4e2bf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1833e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Housing Finance Agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca4e2c0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1833e/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Deposit Insurance Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca4e2c1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1833e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Affirmative program for equal employment opportunity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this Act, sections 1 and 2 of Executive Order Numbered 11478, providing for the adoption and implementation of equal employment opportunity, shall apply to the Federal Home Loan Banks, the Federal National Mortgage Association, and the Federal Home Loan Mortgage Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca4e2c2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1833e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Solicitation of contracts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal Deposit Insurance Corporation, the Comptroller of the Currency, and the Federal Housing Finance Agency, shall each prescribe regulations to establish and oversee a minority outreach program within each such agency to ensure inclusion, to the maximum extent possible, of minorities and women, and entities owned by minorities and women, including financial institutions, investment banking firms, underwriters, accountants, and providers of legal services, in all contracts entered into by the agency with such persons or entities, public and private, in order to manage the institutions and their assets for which the agency is responsible or to perform such other functions authorized under any law applicable to such agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca4e2c3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1833e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before the end of the 180-day period beginning on ","children":[{"tag":"date","attrib":{"date":"1989-08-09"},"text":"August 9, 1989","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddca4e2c4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1833e/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Deposit Insurance Corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca4e2c5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1833e/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Comptroller of the Currency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca4e2c6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1833e/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Housing Finance Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca4e2c7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1833e/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Home Loan Mortgage Corporation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca4e2c8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1833e/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal National Mortgage Association,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall each submit to the Congress a report containing a complete description of the actions taken by such agency pursuant to subsections (a) and (b) and such recommendations for administrative and legislative action as each such agency may determine to be appropriate to carry out the purposes of such subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddca4e2c9-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/tXII/s1216"},"text":"Pub. L. 101–73, title XII, § 1216","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/529"},"text":"103 Stat. 529","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/233/tIII/s302/a"},"text":"Pub. L. 102–233, title III, § 302(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-12"},"text":"Dec. 12, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1767"},"text":"105 Stat. 1767","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tII/s1216/g"},"text":"Pub. L. 110–289, div. A, title II, § 1216(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2793"},"text":"122 Stat. 2793","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tIII/s367/9"},"text":"Pub. L. 111–203, title III, § 367(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1557"},"text":"124 Stat. 1557","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddca4e2ca-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddca4e2cb-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddca4e2cc-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsecs. (a) and (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73"},"text":"Pub. L. 101–73","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/183"},"text":"103 Stat. 183","children":[],"tail":", known as the Financial Institutions Reform, Recovery, and Enforcement Act of 1989. For complete classification of this Act to the Code, see Short Title of 1989 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1811"},"text":"section 1811 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Executive Order Numbered 11478, referred to in subsecs. (a) and (b), is set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000e"},"text":"section 2000e of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddca4e2cd-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Financial Institutions Reform, Recovery, and Enforcement Act of 1989, and not as part of the Federal Deposit Insurance Act which comprises this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tII/s1216/g"},"text":"Pub. L. 110–289, div. A, title II, § 1216(g)","children":[],"tail":", which directed amendment of section 1216 of the “Financial Institutions Reform, Recovery, and Enhancement Act of 1989”, was executed to this section, which is section 1216 of the Financial Institutions Reform, Recovery, and Enforcement Act of 1989, to reflect the probable intent of Congress. See 2008 Amendment notes below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddca4e2ce-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s367/9/A/iii"},"text":"Pub. L. 111–203, § 367(9)(A)(iii)","children":[],"tail":", (iv), redesignated par. (3) as (2) and struck out former par. (2) which read as follows: “the Director of the Office of Thrift Supervision;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s367/9/A/iv"},"text":"Pub. L. 111–203, § 367(9)(A)(iv)","children":[],"tail":", redesignated par. (4) as (3). Former par. (3) redesignated (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s367/9/A/i"},"text":"Pub. L. 111–203, § 367(9)(A)(i)","children":[],"tail":", inserted “and” at the end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s367/9/A/iv"},"text":"Pub. L. 111–203, § 367(9)(A)(iv)","children":[],"tail":", redesignated par. (4) as (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s367/9/A/ii"},"text":"Pub. L. 111–203, § 367(9)(A)(ii)","children":[],"tail":", substituted a period for the semicolon at the end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5), (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s367/9/A/iii"},"text":"Pub. L. 111–203, § 367(9)(A)(iii)","children":[],"tail":", struck out pars. (5) and (6) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(5) the Thrift Depositor Protection Oversight Board of the Resolution Trust Corporation; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(6) the Resolution Trust Corporation.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s367/9/B"},"text":"Pub. L. 111–203, § 367(9)(B)","children":[],"tail":", substituted “and the Federal Housing Finance Agency,” for “the Director of the Office of Thrift Supervision, the Federal Housing Finance Agency, the Thrift Depositor Protection Oversight Board of the Resolution Trust Corporation, and the Resolution Trust Corporation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3) to (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s367/9/C"},"text":"Pub. L. 111–203, § 367(9)(C)","children":[],"tail":", redesignated pars. (4), (7), and (8) as (3) to (5), respectively, and struck out former pars. (3), (5), and (6) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) the Director of the Office of Thrift Supervision;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(5) the Thrift Depositor Protection Oversight Board of the Resolution Trust Corporation;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(6) the Resolution Trust Corporation;”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/s1216/g/1"},"text":"Pub. L. 110–289, § 1216(g)(1)","children":[],"tail":", added par. (3) and struck out former par. (3) which read as follows: “the Federal home loan banks;”. See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/s1216/g/2"},"text":"Pub. L. 110–289, § 1216(g)(2)","children":[],"tail":", substituted “Federal Home Loan Banks, the Federal National Mortgage Association,” for “Federal National Mortgage Association”. See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/s1216/g/3"},"text":"Pub. L. 110–289, § 1216(g)(3)","children":[],"tail":", substituted “Finance Agency” for “Finance Board”. See Codification note above."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddca4e2cf-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"iddca4e2d0-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Oversight Board redesignated Thrift Depositor Protection Oversight Board, effective ","children":[{"tag":"date","attrib":{"date":"1992-02-01"},"text":"Feb. 1, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/233/s302/a"},"text":"section 302(a) of Pub. L. 102–233","children":[],"tail":", formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1441a"},"text":"section 1441a of this title","children":[],"tail":". Thrift Depositor Protection Oversight Board abolished, see section 14(a)–(d) of "},{"tag":"ref","attrib":{"href":"/us/pl/105/216"},"text":"Pub. L. 105–216","children":[],"tail":", formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1441a"},"text":"section 1441a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddca4e2d1-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective on the transfer date, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s351"},"text":"section 351 of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s906"},"text":"section 906 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
