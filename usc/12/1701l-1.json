{"tag":"section","attrib":{"id":"iddba37829-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701l–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1701l–1"},"text":"§ 1701l–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mortgage proceeds fraudulently misappropriated by mortgagor; recovery of deficiency after foreclosure","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Housing and Urban Development shall take action to secure the payment of any deficiency after foreclosure on a mortgage insured or assisted under Federal law where the Secretary has reason to believe that the mortgage proceeds have been fraudulently misappropriated by the mortgagor.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddba3782a-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/383/tVIII/s819"},"text":"Pub. L. 93–383, title VIII, § 819","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-22"},"text":"Aug. 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/740"},"text":"88 Stat. 740","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddba3782b-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddba3782c-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddba3782d-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Housing and Community Development Act of 1974, and not as part of the National Housing Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
