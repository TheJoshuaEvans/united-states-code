{"tag":"section","attrib":{"id":"iddcec7352-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"2279bb–4"},"text":"§ 2279bb–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement levels","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcec7353-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall classify the Corporation, for purposes of this part, according to the following enforcement levels:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcec7354-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–4/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Level I","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Corporation shall be classified as within level I if the Corporation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcec7355-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–4/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintains an amount of regulatory capital that is equal to or exceeds the risk-based capital level established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2279bb–1"},"text":"section 2279bb–1 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcec7356-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–4/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equals or exceeds the minimum capital level established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2279bb–2"},"text":"section 2279bb–2 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcec7357-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–4/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Level II","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Corporation shall be classified as within level II if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcec7358-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–4/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Corporation—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddcec7359-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–4/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintains an amount of regulatory capital that is less than the risk-based capital level; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcec735a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–4/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equals or exceeds the minimum capital level; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcec735b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–4/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Corporation is otherwise classified as within level II under subsection (b) of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcec735c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–4/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Level III","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Corporation shall be classified as within level III if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcec735d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–4/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Corporation—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddcec735e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–4/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not equal or exceed the minimum capital level; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcec735f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–4/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equals or exceeds the critical capital level established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2279bb–3"},"text":"section 2279bb–3 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcec7360-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–4/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Corporation is otherwise classified as within level III under subsection (b) of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcec7361-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–4/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Level IV","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Corporation shall be classified as within level IV if the Corporation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcec7362-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–4/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not equal or exceed the critical capital level; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcec7363-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–4/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is otherwise classified as within level IV under subsection (b) of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcec7364-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discretionary classification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If at any time the Director determines in writing (and provides written notification to the Corporation and the Farm Credit Administration) that the Corporation is taking any action not approved by the Director that could result in a rapid depletion of core capital or that the value of the property subject to mortgages securitized by the Corporation or property underlying securities guaranteed by the Corporation, has decreased significantly, the Director may classify the Corporation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcec7365-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–4/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as within level II, if the Corporation is otherwise within level I;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcec7366-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–4/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as within level III, if the Corporation is otherwise within level II; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcec7367-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–4/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as within level IV, if the Corporation is otherwise within level III.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcec7368-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–4/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quarterly determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall determine the classification of the Corporation for purposes of this part on not less than a quarterly basis (and as appropriate under subsection (b)). The first such determination shall be made for the quarter ending ","children":[{"tag":"date","attrib":{"date":"1992-03-31"},"text":"March 31, 1992","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcec7369-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–4/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon determining under subsection (b) or (c) that the Corporation is within level II or III, the Director shall provide written notice to the Congress and to the Corporation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcec736a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–4/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the Corporation is within such level;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcec736b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–4/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the Corporation is subject to the provisions of section 2279bb–5 or 2279bb–6 of this title, as applicable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcec736c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–4/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stating the reasons for the classification of the Corporation within such level.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcec736d-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tVIII/s8"},"text":"Pub. L. 92–181, title VIII, § 8","children":[],"tail":".35, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tV/s503/b/2"},"text":"Pub. L. 102–237, title V, § 503(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1874"},"text":"105 Stat. 1874","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/105/tI/s116"},"text":"Pub. L. 104–105, title I, § 116","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/168"},"text":"110 Stat. 168","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tV/s5411/50"},"text":"Pub. L. 115–334, title V, § 5411(50)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4685"},"text":"132 Stat. 4685","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcec736e-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcec736f-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcec7370-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" struck out subsec. (e). Text read as follows: “Notwithstanding paragraphs (1) and (2) of subsection (a), during the period beginning on "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"December 13, 1991","children":[],"tail":", and ending on the effective date of the risk based capital regulation issued by the Director under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2279bb–1"},"text":"section 2279bb–1 of this title","children":[],"tail":", the Corporation shall be classified as within level I if the Corporation equals or exceeds the minimum capital level established under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2279bb–2"},"text":"section 2279bb–2 of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/105"},"text":"Pub. L. 104–105","children":[],"tail":" substituted “during the period beginning on "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"December 13, 1991","children":[],"tail":", and ending on the effective date of the risk based capital regulation issued by the Director under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2279bb–1"},"text":"section 2279bb–1 of this title","children":[],"tail":",” for “during the 30-month period beginning on "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"December 13, 1991","children":[],"tail":",”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
