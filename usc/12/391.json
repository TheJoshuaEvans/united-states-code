{"tag":"section","attrib":{"id":"iddb3f37bb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s391"},"text":null,"children":[{"tag":"num","attrib":{"value":"391"},"text":"§ 391.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal reserve banks as Government depositaries and fiscal agents","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The moneys held in the general fund of the Treasury, except the 5 per centum fund for the redemption of outstanding national-bank notes may, upon the direction of the Secretary of the Treasury, be deposited in Federal reserve banks, which banks, when required by the Secretary of the Treasury, shall act as fiscal agents of the United States; and the revenues of the Government or any part thereof may be deposited in such banks, and disbursements may be made by checks drawn against such deposits.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddb3f37bc-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1913-12-23/ch6/s15"},"text":"Dec. 23, 1913, ch. 6, § 15","children":[],"tail":" (par.), "},{"tag":"ref","attrib":{"href":"/us/stat/38/265"},"text":"38 Stat. 265","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/269/s2"},"text":"Pub. L. 90–269, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-03-18"},"text":"Mar. 18, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/50"},"text":"82 Stat. 50","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb3f37bd-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb3f37be-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddb3f37bf-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of first par. of section 15 of act ","children":[{"tag":"date","attrib":{"date":"1913-12-23"},"text":"Dec. 23, 1913","children":[],"tail":". Par. 2 of section 15 and par. 3 of section 15, as added "},{"tag":"ref","attrib":{"href":"/us/act/1923-03-04/ch252"},"text":"Mar. 4, 1923, ch. 252","children":[],"tail":", title IV, § 406, "},{"tag":"ref","attrib":{"href":"/us/stat/42/1480"},"text":"42 Stat. 1480","children":[],"tail":", are classified to sections 392 and 393, respectively, of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddb3f37c0-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1968—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/269"},"text":"Pub. L. 90–269","children":[],"tail":" struck out provision which excepted funds provided in this chapter for the redemption of Federal Reserve notes from deposit in Federal reserve banks."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
