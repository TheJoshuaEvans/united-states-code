{"tag":"section","attrib":{"id":"iddd177a16-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4106"},"text":null,"children":[{"tag":"num","attrib":{"value":"4106"},"text":"§ 4106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information from Secretary","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd177a17-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4106/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information to owners terminating affordability restrictions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide each owner who submits a notice of intent to terminate the low-income affordability restrictions on the housing under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4108"},"text":"section 4108 of this title","children":[],"tail":" with information under this section not later than 6 months after receipt of the notice of intent. The information shall include a description of the criteria for such termination specified under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4108"},"text":"section 4108 of this title","children":[],"tail":" and the documentation required to satisfy such criteria."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd177a18-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4106/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information to owners extending low-income affordability restrictions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall provide each owner who submits notice of intent to extend the low-income affordability restrictions on the housing under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4109"},"text":"section 4109 of this title","children":[],"tail":" or transfer the housing under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4110"},"text":"section 4110 of this title","children":[],"tail":" to a qualified purchaser with information under this subsection not later than 9 months after receipt of the notice of intent. The information shall include any information necessary for the owner to prepare a plan of action under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4107"},"text":"section 4107 of this title","children":[],"tail":", including the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd177a19-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4106/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preservation values","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A statement of the preservation value of the housing determined under paragraphs (1) and (2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4103/b"},"text":"section 4103(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd177a1a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4106/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preservation rent","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A statement of the preservation rent for the housing as calculated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4104/b"},"text":"section 4104(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd177a1b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4106/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal cost limits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A statement of the applicable Federal cost limits for the market area (or relevant local market area, if applicable) in which the housing is located, which shall explain the limitations under sections 4109 and 4110 of this title of the amount of assistance that the Secretary may provide based on such cost limits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd177a1c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4106/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal cost limit analysis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A statement of whether the aggregate preservation rents exceed the Federal cost limits and a direction to the owner to file a plan of action under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4107"},"text":"section 4107 of this title","children":[],"tail":" or submit a second notice of intent under subsection (d), whichever is applicable."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd177a1d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4106/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability to tenants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make any information provided to the owner under subsections (a) and (b) available to the tenants of the housing, together with other information relating to the rights and opportunities of the tenants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd177a1e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4106/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Second notice of intent","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd177a1f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4106/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Filing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each owner of eligible low-income housing that elects to transfer housing under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4110"},"text":"section 4110 of this title","children":[],"tail":" shall submit to the Secretary, in such form and manner as the Secretary prescribes, notice of intent to sell the housing under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4110"},"text":"section 4110 of this title","children":[],"tail":". To be eligible to prepay the mortgage or voluntarily terminate the insurance contract on the mortgage, an owner of housing for which the preservation rents exceed the Federal cost limits under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4105/b"},"text":"section 4105(b) of this title","children":[],"tail":" shall submit to the Secretary notice of such intent. The provisions of sections 4111 and 4113 of this title shall apply to any owner submitting a notice under the preceding sentence."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd177a20-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4106/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A second notice of intent under this subsection shall be submitted not later than 30 days after receipt of information from the Secretary under this section. If an owner fails to submit such notice within such period, the notice of intent submitted by the owner under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4102"},"text":"section 4102 of this title","children":[],"tail":" shall be void and ineffective for purposes of this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd177a21-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4106/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Filing with the State or local government, tenants, and mortgagee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon filing a second notice of intent under this subsection, the owner shall simultaneously file such notice of the intent with the chief executive officer of the appropriate State or local government for the jurisdiction within which the housing is located and with the mortgagee, and shall inform the tenants of the housing of the filing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd177a22-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/242/tII/s216"},"text":"Pub. L. 100–242, title II, § 216","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/625/tVI/s601/a"},"text":"Pub. L. 101–625, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4253"},"text":"104 Stat. 4253","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tIII"},"text":"Pub. L. 102–550, title III","children":[],"tail":", §§ 303, 317(a)(2), "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3763"},"text":"106 Stat. 3763","children":[],"tail":", 3772.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd177a23-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd177a24-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd177a25-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/s317/a/2"},"text":"Pub. L. 102–550, § 317(a)(2)","children":[],"tail":", substituted “exceed” for “exceeds”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/s303"},"text":"Pub. L. 102–550, § 303","children":[],"tail":", added par. (3)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
