{"tag":"section","attrib":{"id":"iddd36743f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4640"},"text":null,"children":[{"tag":"num","attrib":{"value":"4640"},"text":"§ 4640.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of service","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any service required or authorized to be made by the Director under this subchapter may be made by registered mail, or in such other manner reasonably calculated to give actual notice as the Director may by regulation or otherwise provide.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd367440-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXIII/s1379C"},"text":"Pub. L. 102–550, title XIII, § 1379C","children":[],"tail":", formerly § 1379A, "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3993"},"text":"106 Stat. 3993","children":[],"tail":"; renumbered § 1379C, "},{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tI/s1153/a/1"},"text":"Pub. L. 110–289, div. A, title I, § 1153(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2770"},"text":"122 Stat. 2770","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
