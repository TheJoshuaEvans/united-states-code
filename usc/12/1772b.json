{"tag":"section","attrib":{"id":"iddc433a00-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1772b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1772b"},"text":"§ 1772b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Apportionment","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, funds received by the Board pursuant to any method provided by this chapter, and interest, dividend, or other income thereon, shall not be subject to apportionment for the purpose of chapter 15 of title 31 or under any other authority.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc433a01-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-26/ch750"},"text":"June 26, 1934, ch. 750","children":[],"tail":", title I, § 128, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/86/tV/s505/e"},"text":"Pub. L. 100–86, title V, § 505(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-08-10"},"text":"Aug. 10, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/633"},"text":"101 Stat. 633","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
