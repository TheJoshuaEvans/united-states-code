{"tag":"section","attrib":{"id":"iddd3fea2b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4807"},"text":null,"children":[{"tag":"num","attrib":{"value":"4807"},"text":"§ 4807.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time limit on agency consideration of completed applications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd3fea2c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4807/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Federal banking agency shall take final action on any application to the agency before the end of the 1-year period beginning on the date on which a completed application is received by the agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3fea2d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4807/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver by applicant authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person submitting an application to a Federal banking agency may waive the applicability of subsection (a) with respect to such application at any time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd3fea2e-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/tIII/s343"},"text":"Pub. L. 103–325, title III, § 343","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2238"},"text":"108 Stat. 2238","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
