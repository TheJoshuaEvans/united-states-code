{"tag":"section","attrib":{"id":"iddc5b079a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1795b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1795b"},"text":"§ 1795b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Credit Union Administration Central Liquidity Facility; establishment; management; jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is created the National Credit Union Administration Central Liquidity Facility. The Central Liquidity Facility, an instrumentality of the United States, shall exist within the National Credit Union Administration and be managed by the Board. The United States district court shall have original jurisdiction over any case to which the Board on behalf of the Facility is a party, without regard to the amount in controversy.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc5b079b-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-26/ch750"},"text":"June 26, 1934, ch. 750","children":[],"tail":", title III, formerly subch. III, § 303, as added and amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/630/tV/s502/b"},"text":"Pub. L. 95–630, title V, § 502(b)","children":[],"tail":", title XVIII, § 1802, "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3681"},"text":"92 Stat. 3681","children":[],"tail":", 3720; "},{"tag":"ref","attrib":{"href":"/us/pl/96/221/tIII/s309/a/4"},"text":"Pub. L. 96–221, title III, § 309(a)(4)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"1980-03-31"},"text":"Mar. 31, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/149"},"text":"94 Stat. 149","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dB/tVIII/s2813/a/1"},"text":"Pub. L. 98–369, d