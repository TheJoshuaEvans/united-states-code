{"tag":"section","attrib":{"id":"iddb29da75-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s248a"},"text":null,"children":[{"tag":"num","attrib":{"value":"248a"},"text":"§ 248a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pricing of services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddb29da76-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s248a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication of pricing principles and proposed schedule of fees; effective date of schedule of fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than the first day of the sixth month after ","children":[{"tag":"date","attrib":{"date":"1980-03-31"},"text":"March 31, 1980","children":[],"tail":", the Board shall publish for public comment a set of pricing principles in accordance with this section and a proposed schedule of fees based upon those principles for Federal Reserve bank services to depository institutions, and not later than the first day of the eighteenth month after "},{"tag":"date","attrib":{"date":"1980-03-31"},"text":"March 31, 1980","children":[],"tail":", the Board shall begin to put into effect a schedule of fees for such services which is based on those principles."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb29da77-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s248a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The services which shall be covered by the schedule of fees under subsection (a) are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb29da78-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s248a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" currency and coin services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb29da79-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s248a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" check clearing and collection services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb29da7a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s248a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" wire transfer services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb29da7b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s248a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" automated clearinghouse services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb29da7c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s248a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" settlement services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb29da7d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s248a/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" securities safekeeping services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb29da7e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s248a/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal Reserve float; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb29da7f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s248a/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any new services which the Federal Reserve System offers, including but not limited to payment services to effectuate the electronic transfer of funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb29da80-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s248a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria applicable","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The schedule of fees prescribed pursuant to this section shall be based on the following principles:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb29da81-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s248a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All Federal Reserve bank services covered by the fee schedule shall be priced explicitly.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb29da82-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s248a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All Federal Reserve bank services covered by the fee schedule shall be available to nonmember depository institutions and such services shall be priced at the same fee schedule applicable to member banks, except that nonmembers shall be subject to any other terms, including a requirement of balances sufficient for clearing purposes, that the Board may determine are applicable to member banks.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb29da83-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s248a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Over the long run, fees shall be established on the basis of all direct and indirect costs actually incurred in providing the Federal Reserve services priced, including interest on items credited prior to actual collection, overhead, and an allocation of imputed costs which takes into account the taxes that would have been paid and the return on capital that would have been provided had the services been furnished by a private business firm, except that the pricing principles shall give due regard to competitive factors and the provision of an adequate level of such services nationwide.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb29da84-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s248a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Interest on items credited prior to collection shall be charged at the current rate applicable in the market for Federal funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb29da85-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s248a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Budgetary consequences of decline in volume of services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall require reductions in the operating budgets of the Federal Reserve banks commensurate with any actual or projected decline in the volume of services to be provided by such banks. The full amount of any savings so realized shall be paid into the United States Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb29da86-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s248a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Parity in clearing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All depository institutions, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s461/b/1"},"text":"section 461(b)(1) of this title","children":[],"tail":", may receive for deposit and as deposits any evidences of transaction accounts, as defined by "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s461/b/1"},"text":"section 461(b)(1) of this title","children":[],"tail":" from other depository institutions, as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s461/b/1"},"text":"section 461(b)(1) of this title","children":[],"tail":" or from any office of any Federal Reserve bank without regard to any Federal or State law restricting the number or the physical location or locations of such depository institutions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddb29da87-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1913-12-23/ch6/s11A"},"text":"Dec. 23, 1913, ch. 6, § 11A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/221/tI/s107"},"text":"Pub. L. 96–221, title I, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-03-31"},"text":"Mar. 31, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/140"},"text":"94 Stat. 140","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/86/tVI/s612/a"},"text":"Pub. L. 100–86, title VI, § 612(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-08-10"},"text":"Aug. 10, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/652"},"text":"101 Stat. 652","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb29da88-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb29da89-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddb29da8a-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1987—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/86"},"text":"Pub. L. 100–86","children":[],"tail":" added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddb29da8b-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddb29da8c-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1987 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/86/tVI/s612/b"},"text":"Pub. L. 100–86, title VI, § 612(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-08-10"},"text":"Aug. 10, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/652"},"text":"101 Stat. 652","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/86/tVI/s612/b"},"text":"“The amendment made by subsection (a) [amending this section] shall take effect on the date of enactment of this title [","children":[{"tag":"date","attrib":{"date":"1987-08-10"},"text":"Aug. 10, 1987","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddb29da8d-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on first day of sixth month which begins after ","children":[{"tag":"date","attrib":{"date":"1980-03-31"},"text":"Mar. 31, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/221/s108"},"text":"section 108 of Pub. L. 96–221","children":[],"tail":", set out as an Effective Date of 1980 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s248"},"text":"section 248 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
