{"tag":"section","attrib":{"id":"iddd281bc0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4523"},"text":null,"children":[{"tag":"num","attrib":{"value":"4523"},"text":"§ 4523.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on subsequent employment","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Neither the Director nor any former officer or employee of the Agency who, while employed by the Agency, was compensated at a rate in excess of the lowest rate for a position classified higher than GS–15 of the General Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5107"},"text":"section 5107 of title 5","children":[],"tail":" may accept compensation from an enterprise during the 2-year period beginning on the date of separation from employment by the Agency."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd281bc1-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXIII/s1319D"},"text":"Pub. L. 102–550, title XIII, § 1319D","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3951"},"text":"106 Stat. 3951","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tI/s1161/a/5"},"text":"Pub. L. 110–289, div. A, title I, § 1161(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2779"},"text":"122 Stat. 2779","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd281bc2-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd281bc3-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd281bc4-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289"},"text":"Pub. L. 110–289","children":[],"tail":" substituted “the Agency” for “the Office” wherever appearing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
