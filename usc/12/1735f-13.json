{"tag":"section","attrib":{"id":"iddc28fb2c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1735f–13"},"text":null,"children":[{"tag":"num","attrib":{"value":"1735f–13"},"text":"§ 1735f–13.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of requirement of minimum principal loan amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A mortgagee or lender may not require, as a condition of providing a loan insured under this chapter or secured by a mortgage insured under this chapter, that the principal amount of the loan exceed a minimum amount established by the mortgagee or lender.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc28fb2d-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-27/ch847"},"text":"June 27, 1934, ch. 847","children":[],"tail":", title V, § 535, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/242/tIV/s419/a"},"text":"Pub. L. 100–242, title IV, § 419(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-02-05"},"text":"Feb. 5, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1913"},"text":"101 Stat. 1913","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
