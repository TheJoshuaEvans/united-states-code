{"tag":"section","attrib":{"id":"iddcd2330b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2265a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2265a"},"text":"§ 2265a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal and prohibition authority; industry-wide prohibition","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcd2330c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2265a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of person","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “person” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcd2330d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2265a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd2330e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2265a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a specific determination by the Farm Credit Administration, a legal entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd2330f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2265a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Industry-wide prohibition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (c), any person who, pursuant to an order issued under section 2264 or 2265 of this title, has been removed or suspended from office at a System institution or prohibited from participating in the conduct of the affairs of a System institution shall not, during the period of effectiveness of the order, continue or commence to hold any office in, or participate in any manner in the conduct of the affairs of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcd23310-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2265a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any insured depository institution subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1818/e/7/A/i"},"text":"section 1818(e)(7)(A)(i) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd23311-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2265a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any institution subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1818/e/7/A/ii"},"text":"section 1818(e)(7)(A)(ii) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd23312-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2265a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any insured credit union under the Federal Credit Union Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1751"},"text":"12 U.S.C. 1751","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd23313-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2265a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any Federal home loan bank;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd23314-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2265a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any institution chartered under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd23315-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2265a/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any appropriate Federal financial institutions regulatory agency (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1818/e/7/D"},"text":"section 1818(e)(7)(D) of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd23316-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2265a/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Housing Finance Agency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd23317-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2265a/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Farm Credit Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd23318-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2265a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for institution-affiliated party that receives written consent","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcd23319-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2265a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcd2331a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2265a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Affiliated parties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If, on or after the date on which an order described in subsection (b) is issued that removes or suspends an institution-affiliated party from office at a System institution or prohibits an institution-affiliated party from participating in the conduct of the affairs of a System institution, that party receives written consent described in subparagraph (B), subsection (b) shall not apply to that party—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddcd2331b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2265a/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent provided in the written consent received; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcd2331c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2265a/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the institution described in each written consent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcd2331d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2265a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Written consent described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The written consent referred to in subparagraph (A) is written consent received from—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddcd2331e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2265a/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Farm Credit Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcd2331f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2265a/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each appropriate Federal financial institutions regulatory agency (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1818/e/7/D"},"text":"section 1818(e)(7)(D) of this title","children":[],"tail":") of the applicable institution described in any of paragraphs (1), (2), (3), or (4) of subsection (b) with respect to which the party proposes to be become "},{"tag":"ref","attrib":{"idref":"fn002300"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002300"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" an affiliated party."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd23320-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2265a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any agency described in clause (i) or (ii) of paragraph (1)(B) that provides a written consent under that paragraph shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcd23321-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2265a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report the action to the Farm Credit Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcd23322-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2265a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publicly disclose the action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd23323-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2265a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation between agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The agencies described in clauses (i) and (ii) of paragraph (1)(B) shall consult with each other before providing any written consent under that paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd23324-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2265a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A violation of subsection (b) by any person who is subject to an order described in that subsection shall be treated as violation ","children":[{"tag":"ref","attrib":{"idref":"fn002301"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002301"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be preceded by “a”."}],"tail":" of that order."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcd23325-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tV/s5"},"text":"Pub. L. 92–181, title V, § 5","children":[],"tail":".29A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tV/s5406"},"text":"Pub. L. 115–334, title V, § 5406","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4676"},"text":"132 Stat. 4676","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcd23326-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcd23327-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddcd23328-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Credit Union Act, referred to in subsec. (b)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-26/ch750"},"text":"act June 26, 1934, ch. 750","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/1216"},"text":"48 Stat. 1216","children":[],"tail":", which is classified generally to chapter 14 (§ 1751 et seq.) of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1751"},"text":"section 1751 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
