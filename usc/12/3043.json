{"tag":"section","attrib":{"id":"iddcfd3b6f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3043"},"text":null,"children":[{"tag":"num","attrib":{"value":"3043"},"text":"§ 3043.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advances","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcfd3b70-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3043/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capital investment advances; criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Office may make a capital investment advance to any eligible cooperative, either in conjunction with or without a loan if the Office determines that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcfd3b71-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3043/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcfd3b72-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3043/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant’s initial or supplemental capital requirements exceeds its ability to obtain such capital through a loan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s3018"},"text":"section 3018 of this title","children":[],"tail":" or from other sources; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcfd3b73-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3043/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the membership of the applicant is, or will consist, substantially of low-income persons, as defined by the Board of Directors, or the applicant proposes to undertake to provide specialized goods, services, or facilities to serve their needs; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcfd3b74-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3043/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant cannot obtain sufficient funds through a loan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s3018"},"text":"section 3018 of this title","children":[],"tail":" or otherwise, and the applicant presents a plan which the Office determines will permit the replacement of a capital investment advance out of member equities within a period not to exceed thirty years."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcfd3b75-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3043/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest supplement advances; criteria; amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office may make advances to pay all or part of the interest payable to the Bank or any other lender by an eligible cooperative applicant which the Office determines cannot pay a market rate of interest because it sells goods or services to, or provides facilities for the use of, persons of low income: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That such advances will not exceed an amount equal to 4 per centum of the principal amount of the indebtedness of such applicant to the Bank or such other lender for any year in which the net income of the cooperative is insufficient to meet scheduled interest payments."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcfd3b76-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3043/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest rate applicable to advances","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Capital investment advances made by the Office pursuant to subsection (a) and interest supplement advances made by the Office pursuant to subsection (b) shall bear interest at a rate determined by the Board of Directors of the Bank, and the Board of Directors may authorize an interest rate applicable to such advances lower than the rate applicable to loans by the Bank pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s3018"},"text":"section 3018 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcfd3b77-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/351/tII/s203"},"text":"Pub. L. 95–351, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-08-20"},"text":"Aug. 20, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/512"},"text":"92 Stat. 512","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tIII/s396/g"},"text":"Pub. L. 97–35, title III, § 396(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/440"},"text":"95 Stat. 440","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcfd3b78-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcfd3b79-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcfd3b7a-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1981—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":" struck out references to the Account wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcfd3b7b-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcfd3b7c-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1981 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":" effective on the day after the Final Government Equity Redemption Date ("},{"tag":"date","attrib":{"date":"1981-12-31"},"text":"Dec. 31, 1981","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/s396/i"},"text":"section 396(i) of Pub. L. 97–35","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s3011"},"text":"section 3011 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
