{"tag":"section","attrib":{"id":"iddd0b6c62-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423"},"text":null,"children":[{"tag":"num","attrib":{"value":"3423"},"text":"§ 3423.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Immunity from suit for disclosure of financial exploitation of senior citizens","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd0b6c63-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Immunity","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd0b6c64-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd0b6c65-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Bank Secrecy Act officer” means an individual responsible for ensuring compliance with the requirements mandated by subchapter II of chapter 53 of title 31 (commonly known as the “Bank Secrecy Act”);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd0b6c66-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “broker-dealer” means a broker and a dealer, as those terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78c/a"},"text":"section 78c(a) of title 15","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd0b6c67-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “covered agency” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd0b6c68-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State financial regulatory agency, including a State securities or law enforcement authority and a State insurance regulator;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd0b6c69-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each of the Federal agencies represented in the membership of the Financial Institutions Examination Council established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s3303"},"text":"section 3303 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd0b6c6a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/a/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a securities association registered under section 78","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":"–3 of title 15;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd0b6c6b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/a/1/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Securities and Exchange Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd0b6c6c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/a/1/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a law enforcement agency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd0b6c6d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/a/1/C/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State or local agency responsible for administering adult protective service laws;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd0b6c6e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “covered financial institution” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd0b6c6f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/a/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a credit union;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd0b6c70-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/a/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a depository institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd0b6c71-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/a/1/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an investment adviser;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd0b6c72-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/a/1/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a broker-dealer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd0b6c73-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/a/1/D/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an insurance company;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd0b6c74-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/a/1/D/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an insurance agency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd0b6c75-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/a/1/D/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a transfer agent;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd0b6c76-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “credit union” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"section 5301 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd0b6c77-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “depository institution” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813/c"},"text":"section 1813(c) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd0b6c78-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “exploitation” means the fraudulent or otherwise illegal, unauthorized, or improper act or process of an individual, including a caregiver or a fiduciary, that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd0b6c79-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/a/1/G/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uses the resources of a senior citizen for monetary or personal benefit, profit, or gain; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd0b6c7a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/a/1/G/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" results in depriving a senior citizen of rightful access to or use of benefits, resources, belongings, or assets;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd0b6c7b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/a/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “insurance agency” means any business entity that sells, solicits, or negotiates insurance coverage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd0b6c7c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/a/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “insurance company” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s80a–2/a"},"text":"section 80a–2(a) of title 15","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd0b6c7d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/a/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “insurance producer” means an individual who is required under State law to be licensed in order to sell, solicit, or negotiate insurance coverage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd0b6c7e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/a/1/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “investment adviser” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s80b–2/a"},"text":"section 80b–2(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd0b6c7f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/a/1/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “investment adviser representative” means an individual who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd0b6c80-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/a/1/L/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is employed by, or associated with, an investment adviser; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd0b6c81-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/a/1/L/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not perform solely clerical or ministerial acts;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd0b6c82-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/a/1/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “registered representative” means an individual who represents a broker-dealer in effecting or attempting to effect a purchase or sale of securities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd0b6c83-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/a/1/N"},"text":null,"children":[{"tag":"num","attrib":{"value":"N"},"text":"(N)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “senior citizen” means an individual who is not younger than 65 years of age;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd0b6c84-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/a/1/O"},"text":null,"children":[{"tag":"num","attrib":{"value":"O"},"text":"(O)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “State” means each of the several States, the District of Columbia, and any territory or possession of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd0b6c85-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/a/1/P"},"text":null,"children":[{"tag":"num","attrib":{"value":"P"},"text":"(P)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “State insurance regulator” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s6735"},"text":"section 6735 of title 15","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd0b6c86-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/a/1/Q"},"text":null,"children":[{"tag":"num","attrib":{"value":"Q"},"text":"(Q)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “State securities or law enforcement authority” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78x/f/4"},"text":"section 78x(f)(4) of title 15","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd0b6c87-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/a/1/R"},"text":null,"children":[{"tag":"num","attrib":{"value":"R"},"text":"(R)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “transfer agent” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78c/a"},"text":"section 78c(a) of title 15","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd0b6c88-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Immunity from suit","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd0b6c89-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Immunity for individuals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual who has received the training described in subsection (b) shall not be liable, including in any civil or administrative proceeding, for disclosing the suspected exploitation of a senior citizen to a covered agency if the individual, at the time of the disclosure—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd0b6c8a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" served as a supervisor or in a compliance or legal function (including as a Bank Secrecy Act officer) for, or, in the case of a registered representative, investment adviser representative, or insurance producer, was affiliated or associated with, a covered financial institution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd0b6c8b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" made the disclosure—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddd0b6c8c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/a/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in good faith; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddd0b6c8d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/a/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with reasonable care.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd0b6c8e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Immunity for covered financial institutions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A covered financial institution shall not be liable, including in any civil or administrative proceeding, for a disclosure made by an individual described in subparagraph (A) if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd0b6c8f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual was employed by, or, in the case of a registered representative, insurance producer, or investment adviser representative, affiliated or associated with, the covered financial institution at the time of the disclosure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd0b6c90-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before the time of the disclosure, each individual described in subsection (b)(1) received the training described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd0b6c91-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in subparagraph (A) or (B) shall be construed to limit the liability of an individual or a covered financial institution in a civil action for any act, omission, or fraud that is not a disclosure described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd0b6c92-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd0b6c93-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A covered financial institution or a third party selected by a covered financial institution may provide the training described in paragraph (2)(A) to each officer or employee of, or registered representative, insurance producer, or investment adviser representative affiliated or associated with, the covered financial institution who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd0b6c94-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is described in subsection (a)(2)(A)(i);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd0b6c95-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may come into contact with a senior citizen as a regular part of the professional duties of the individual; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd0b6c96-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may review or approve the financial documents, records, or transactions of a senior citizen in connection with providing financial services to a senior citizen.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd0b6c97-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd0b6c98-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The content of the training that a covered financial institution or a third party selected by the covered financial institution may provide under paragraph (1) shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd0b6c99-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be maintained by the covered financial institution and made available to a covered agency with examination authority over the covered financial institution, upon request, except that a covered financial institution shall not be required to maintain or make available such content with respect to any individual who is no longer employed by, or affiliated or associated with, the covered financial institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd0b6c9a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" instruct any individual attending the training on how to identify and report the suspected exploitation of a senior citizen internally and, as appropriate, to government officials or law enforcement authorities, including common signs that indicate the financial exploitation of a senior citizen;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd0b6c9b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" discuss the need to protect the privacy and respect the integrity of each individual customer of the covered financial institution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd0b6c9c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/b/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be appropriate to the job responsibilities of the individual attending the training.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd0b6c9d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The training under paragraph (1) shall be provided—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd0b6c9e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as soon as reasonably practicable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd0b6c9f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to an individual who begins employment, or becomes affiliated or associated, with a covered financial institution after ","children":[{"tag":"date","attrib":{"date":"2018-05-24"},"text":"May 24, 2018","children":[],"tail":", not later than 1 year after the date on which the individual becomes employed by, or affiliated or associated with, the covered financial institution in a position described in subparagraph (A), (B), or (C) of paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd0b6ca0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A covered financial institution shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd0b6ca1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" maintain a record of each individual who—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddd0b6ca2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/b/2/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is employed by, or affiliated or associated with, the covered financial institution in a position described in subparagraph (A), (B), or (C) of paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddd0b6ca3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/b/2/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has completed the training under paragraph (1), regardless of whether the training was—","children":[],"tail":null},{"tag":"item","attrib":{"id":"iddd0b6ca4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/b/2/C/i/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provided by the covered financial institution or a third party selected by the covered financial institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"iddd0b6ca5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/b/2/C/i/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" completed before the individual was employed by, or affiliated or associated with, the covered financial institution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"iddd0b6ca6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/b/2/C/i/II/cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"cc"},"text":"(cc)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" completed before, on, or after ","children":[{"tag":"date","attrib":{"date":"2018-05-24"},"text":"May 24, 2018","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd0b6ca7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon request, provide a record described in clause (i) to a covered agency with examination authority over the covered financial institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd0b6ca8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3423/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to State law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to preempt or limit any provision of State law, except only to the extent that subsection (a) provides a greater level of protection against liability to an individual described in subsection (a)(2)(A) or to a covered financial institution described in subsection (a)(2)(B) than is provided under State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd0b6ca9-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/174/tIII/s303"},"text":"Pub. L. 115–174, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-05-24"},"text":"May 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1335"},"text":"132 Stat. 1335","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd0b6caa-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd0b6cab-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd0b6cac-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For the Bank Secrecy Act, referred to in subsec. (a)(1)(A), (2)(A)(i), see Short Title note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1951"},"text":"section 1951 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd0b6cad-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Economic Growth, Regulatory Relief, and Consumer Protection Act, and not as part of the Right to Financial Privacy Act of 1978 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
