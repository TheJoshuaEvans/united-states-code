{"tag":"section","attrib":{"id":"iddc7546a6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1820a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1820a"},"text":"§ 1820a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Examination of investment companies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc7546a7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1820a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusive Commission authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (c), a Federal banking agency may not inspect or examine any registered investment company that is not a bank holding company or a savings and loan holding company.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc7546a8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1820a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Examination results and other information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall provide to any Federal banking agency, upon request, the results of any examination, reports, records, or other information with respect to any registered investment company to the extent necessary for the agency to carry out its statutory responsibilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc7546a9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1820a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain examinations authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall prevent the Corporation, if the Corporation finds it necessary to determine the condition of an insured depository institution for insurance purposes, from examining an affiliate of any insured depository institution, pursuant to its authority under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1820/b/4"},"text":"section 1820(b)(4) of this title","children":[],"tail":", as may be necessary to disclose fully the relationship between the insured depository institution and the affiliate, and the effect of such relationship on the insured depository institution."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc7546aa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1820a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the following definitions shall apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc7546ab-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1820a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bank holding company","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “bank holding company” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1841"},"text":"section 1841 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc7546ac-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1820a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Commission” means the Securities and Exchange Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc7546ad-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1820a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Corporation” means the Federal Deposit Insurance Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc7546ae-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1820a/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal banking agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Federal banking agency” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813/z"},"text":"section 1813(z) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc7546af-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1820a/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Insured depository institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “insured depository institution” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813/c"},"text":"section 1813(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc7546b0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1820a/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registered investment company","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “registered investment company” means an investment company that is registered with the Commission under the Investment Company Act of 1940 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s80a–1"},"text":"15 U.S.C. 80a–1","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc7546b1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1820a/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings and loan holding company","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “savings and loan holding company” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1467a/a/1/D"},"text":"section 1467a(a)(1)(D) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc7546b2-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/102/tI/s115"},"text":"Pub. L. 106–102, title I, § 115","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1371"},"text":"113 Stat. 1371","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc7546b3-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc7546b4-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddc7546b5-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Investment Company Act of 1940, referred to in subsec. (d)(6), is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-08-22/ch686"},"text":"act Aug. 22, 1940, ch. 686","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/789"},"text":"54 Stat. 789","children":[],"tail":", which is classified generally to subchapter I (§ 80a–1 et seq.) of chapter 2D of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s80a–51"},"text":"section 80a–51 of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddc7546b6-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Gramm-Leach-Bliley Act, and not as part of the Federal Deposit Insurance Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc7546b7-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddc7546b8-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 120 days after ","children":[{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/102/s161"},"text":"section 161 of Pub. L. 106–102","children":[],"tail":", set out as an Effective Date of 1999 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s24"},"text":"section 24 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
