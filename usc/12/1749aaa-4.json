{"tag":"section","attrib":{"id":"iddc3753a4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1749aaa–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"1749aaa–4"},"text":"§ 1749aaa–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc3753a5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1749aaa–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the request of individuals or organizations operating or contemplating the operation of group practice facilities or medical practice facility (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1749aaa–5"},"text":"section 1749aaa–5 of this title","children":[],"tail":"), the Secretary may provide or obtain technical assistance in the planning for and construction of such facilities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc3753a6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1749aaa–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Utilization of services and facilities of Federal agencies; payment; advances or reimbursement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With a view to avoiding unnecessary duplication of existing staffs and facilities of the Federal Government, the Secretary is authorized to utilize available services and facilities of any agency of the Federal Government in carrying out the provisions of this subchapter, and to pay for such services and facilities, either in advance or by way of reimbursement, in accordance with an agreement between the Secretary and the head of such agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc3753a7-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-27/ch847"},"text":"June 27, 1934, ch. 847","children":[],"tail":", title XI, § 1105, as added "},{"tag":"ref","attrib":{"href":"/us/pl/89/754/tV/s502/a"},"text":"Pub. L. 89–754, title V, § 502(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-03"},"text":"Nov. 3, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1276"},"text":"80 Stat. 1276","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/93/383/tIII/s312/a/5"},"text":"Pub. L. 93–383, title III, § 312(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-22"},"text":"Aug. 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/683"},"text":"88 Stat. 683","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc3753a8-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc3753a9-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc3753aa-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1974—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/383"},"text":"Pub. L. 93–383","children":[],"tail":" substituted “or medical practice facility (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1749aaa–5"},"text":"section 1749aaa–5 of this title","children":[],"tail":")” for “(as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1749aaa–5/1"},"text":"section 1749aaa–5(1) of this title","children":[],"tail":")”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
