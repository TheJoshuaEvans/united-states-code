{"tag":"section","attrib":{"id":"iddc3027a9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1747e"},"text":null,"children":[{"tag":"num","attrib":{"value":"1747e"},"text":"§ 1747e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial statements by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"With respect to each project insured under this subchapter, the Secretary shall provide that, after the close of each operating year, the investor shall submit to him for approval a financial and operating statement covering such operating year. If any such financial and operating statement shall not have been submitted or, for proper cause, shall not have been approved by the Secretary, payment of any claim submitted by the investor may, at the option of the Secretary, be withheld, in whole or in part, until such statement shall have been submitted and approved.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc3027aa-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-27/ch847"},"text":"June 27, 1934, ch. 847","children":[],"tail":", title VII, § 706, as added "},{"tag":"ref","attrib":{"href":"/us/act/1948-08-10/ch832"},"text":"Aug. 10, 1948, ch. 832","children":[],"tail":", title IV, § 401, "},{"tag":"ref","attrib":{"href":"/us/stat/62/1278"},"text":"62 Stat. 1278","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/act/1950-04-20/ch94"},"text":"Apr. 20, 1950, ch. 94","children":[],"tail":", title I, § 122, "},{"tag":"ref","attrib":{"href":"/us/stat/64/59"},"text":"64 Stat. 59","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/19/s1/a/3"},"text":"Pub. L. 90–19, § 1(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-05-25"},"text":"May 25, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/17"},"text":"81 Stat. 17","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc3027ab-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc3027ac-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc3027ad-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1967—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/19"},"text":"Pub. L. 90–19","children":[],"tail":" substituted “Secretary” for “Commissioner” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1950—Act ","children":[{"tag":"date","attrib":{"date":"1950-04-20"},"text":"Apr. 20, 1950","children":[],"tail":", substituted “Commissioner” for “Administrator” wherever appearing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
