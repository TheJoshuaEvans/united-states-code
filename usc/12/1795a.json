{"tag":"section","attrib":{"id":"iddc5b078a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1795a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1795a"},"text":"§ 1795a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this subchapter, the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc5b078b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1795a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “liquidity needs” means the needs of credit unions primarily serving natural persons for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc5b078c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1795a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" short-term adjustment credit available to assist in meeting temporary requirements for funds or to cushion more persist­ent outflows of funds pending an orderly adjustment of credit union assets and liabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc5b078d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1795a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seasonal credit available for longer periods to assist in meeting seasonal needs for funds arising from a combination of expected patterns of movement in share and deposit accounts and loans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc5b078e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1795a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protracted adjustment credit available in the event of unusual or emergency circumstances of a longer term nature resulting from national, regional or local difficulties.","children":[{"tag":"ref","attrib":{"idref":"fn002227"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002227"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The period probably should be a semicolon."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc5b078f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1795a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Central Liquidity Facility” or “Facility” means the National Credit Union Central Liquidity Facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc5b0790-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1795a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “paid-in and unimpaired capital and surplus” means the balance of the paid-in share accounts and deposits as of a given date, less any loss that may have been incurred for which there is no reserve or which has not been charged against undivided earnings, plus the credit balance (or less the debit balance) of the undivided earnings account as of a given date, after all losses have been provided for and net earnings or net losses have been added thereto or deducted therefrom. Reserves shall not be considered as part of surplus,","children":[{"tag":"ref","attrib":{"idref":"fn002228"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002228"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. The comma probably should be a semicolon."}],"tail":" and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc5b0791-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1795a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “member” means a Regular or an Agent member of the Facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc5b0792-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-26/ch750"},"text":"June 26, 1934, ch. 750","children":[],"tail":", title III, formerly subch. III, § 302, as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/630/tXVIII/s1802"},"text":"Pub. L. 95–630, title XVIII, § 1802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3719"},"text":"92 Stat. 3719","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/221/tIII/s309/b/1"},"text":"Pub. L. 96–221, title III, § 309(b)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"1980-03-31"},"text":"Mar. 31, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/149"},"text":"94 Stat. 149","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/136/dA/tIV/s4016/a/1"},"text":"Pub. L. 116–136, div. A, title IV, § 4016(a)(1)","children":[],"tail":", (b)(1)(A), "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/481"},"text":"134 Stat. 481","children":[],"tail":", 482.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc5b0793-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc5b0794-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading",