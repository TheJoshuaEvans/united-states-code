{"tag":"section","attrib":{"id":"iddc3c0e7d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1755"},"text":null,"children":[{"tag":"num","attrib":{"value":"1755"},"text":"§ 1755.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc3c0e7e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1755/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment by Federal credit union to Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with rules prescribed by the Board, each Federal credit union shall pay to the Administration an annual operating fee which may be composed of one or more charges identified as to the function or functions for which assessed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc3c0e7f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1755/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determinations of amount, assessment periods, and payment dates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The fee assessed under this section shall be determined according to a schedule, or schedules, or other method determined by the Board to be appropriate, which gives due consideration to the expenses of the Administration in carrying out its responsibilities under this chapter and to the ability of Federal credit unions to pay the fee. The Board shall, among other things, determine the periods for which the fee shall be assessed and the date or dates for the payment of the fee or increments thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc3c0e80-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1755/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supervision charge exception; waiver of payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the annual operating fee is composed of separate charges, no supervision charge shall be payable by a Federal credit union, and the Board may waive payment of any or all other charges comprising the fee, with respect to the year in which its charter is issued, or in which final distribution is made in its liquidation or the charter is canceled.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc3c0e81-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1755/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment into Treasury of United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All operating fees shall be deposited with the Treasurer of the United States for the account of the Administration and may be expended by the Board to defray the expenses incurred in carrying out the provisions of this chapter including the examination and supervision of Federal credit unions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc3c0e82-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1755/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment of annual operating fees not needed for current operations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc3c0e83-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1755/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon request of the Board, the Secretary of the Treasury shall invest and reinvest such portions of the annual operating fees deposited under subsection (d) as the Board determines are not needed for current operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc3e5774-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1755/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such investments may be made only in interest bearing securities of the United States with maturities requested by the Board bearing interest at rates determined by the Secretary of the Treasury, taking into consideration current market yields on outstanding marketable obligations of the United States of comparable maturities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc3e5775-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1755/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All income derived from such investments and reinvestments shall be deposited to the account of the Administration described in subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc3e5776-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-26/ch750"},"text":"June 26, 1934, ch. 750","children":[],"tail":", title I, § 105, formerly § 5, "},{"tag":"ref","attrib":{"href":"/us/stat/48/1217"},"text":"48 Stat. 1217","children":[],"tail":"; 1947 Reorg. Plan No. 1, § 401, eff. "},{"tag":"date","attrib":{"date":"1947-07-01"},"text":"July 1, 1947","children":[],"tail":", 12 F.R. 4534, "},{"tag":"ref","attrib":{"href":"/us/stat/61/952"},"text":"61 Stat. 952","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1948-06-29/ch711"},"text":"June 29, 1948, ch. 711","children":[],"tail":", §§ 1, 2, "},{"tag":"ref","attrib":{"href":"/us/stat/62/1091"},"text":"62 Stat. 1091","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1952-04-17/ch214/s1"},"text":"Apr. 17, 1952, ch. 214, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/63"},"text":"66 Stat. 63","children":[],"tail":"; renumbered § 6 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/86/354/s1"},"text":"Pub. L. 86–354, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-09-22"},"text":"Sept. 22, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/629"},"text":"73 Stat. 629","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/206/s2/1"},"text":"Pub. L. 91–206, § 2(1)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"1970-03-10"},"text":"Mar. 10, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/49"},"text":"84 Stat. 49","children":[],"tail":"; renumbered title I, § 105, "},{"tag":"ref","attrib":{"href":"/us/pl/91/468/s1/2"},"text":"Pub. L. 91–468, § 1(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-19"},"text":"Oct. 19, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/994"},"text":"84 Stat. 994","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/630/tV/s507"},"text":"Pub. L. 95–630, title V, § 507","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3682"},"text":"92 Stat. 3682","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/320/tV/s505"},"text":"Pub. L. 97–320, title V, § 505","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-15"},"text":"Oct. 15, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1528"},"text":"96 Stat. 1528","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc3e5777-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc3e5778-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc3e5779-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1982—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/320"},"text":"Pub. L. 97–320","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/630"},"text":"Pub. L. 95–630","children":[],"tail":" substituted provisions relating to the payment of an operating fee by each Federal credit union to the Board for provisions relating to the payment of costs incident to the ascertainment of whether an organization certificate should be approved and costs upon approval by the subscriber of such certificate to the Administration and payment of a supervision fee by each Federal credit union to the Administration."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/206"},"text":"Pub. L. 91–206","children":[],"tail":" substituted “Administrator” for “Director” and “Administration” for “Bureau”, wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1959—","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/354"},"text":"Pub. L. 86–354","children":[],"tail":" incorporated in last sentence subject matter formerly contained in a proviso clause following table and authorized fees to be expended for supervisory expenses."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1952—Act ","children":[{"tag":"date","attrib":{"date":"1952-04-17"},"text":"Apr. 17, 1952","children":[],"tail":", amended section, substituting a graduated scale of supervisory fees for the $10 a year supervisory fee."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc3e577a-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddc3e577b-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/630"},"text":"Pub. L. 95–630","children":[],"tail":" effective on expiration of 120 days after "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", and transitional provisions, see "},{"tag":"ref","attrib":{"href":"/us/pl/95/630/s509"},"text":"section 509 of Pub. L. 95–630","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1752"},"text":"section 1752 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddc3e577c-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1952 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1952-04-17/ch214/s2"},"text":"Act Apr. 17, 1952, ch. 214, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/63"},"text":"66 Stat. 63","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/act/1952-04-17/ch214/s2"},"text":"“The amendment by section 1 of this Act [amending this section] shall apply to supervision fees payable with respect to the calendar year 1952 and subsequent calendar years.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"iddc3e577d-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"iddc3e577e-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Transfer of functions of Farm Credit Administration and Governor thereof, generally, see notes set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1751"},"text":"section 1751 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of Governor of Farm Credit Administration under this section transferred to Federal Deposit Insurance Corporation by Reorg. Plan No. 1 of 1947.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
