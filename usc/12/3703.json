{"tag":"section","attrib":{"id":"iddd0ddd00-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3703"},"text":null,"children":[{"tag":"num","attrib":{"value":"3703"},"text":"§ 3703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Multifamily mortgages held by the Secretary encumbering real estate located in any State may be foreclosed by the Secretary in accordance with this chapter, or pursuant to other foreclosure procedures available, at the option of the Secretary. If the Secretary forecloses on any such mortgage pursuant to such other foreclosure procedures available, the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s3706/b"},"text":"section 3706(b) of this title","children":[],"tail":" may be applied at the discretion of the Secretary."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd0ddd01-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tIII/s364"},"text":"Pub. L. 97–35, title III, § 364","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/423"},"text":"95 Stat. 423","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/181/tI"},"text":"Pub. L. 98–181, title I","children":[],"tail":" [title IV, § 471], "},{"tag":"date","attrib":{"date":"1983-11-30"},"text":"Nov. 30, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1237"},"text":"97 Stat. 1237","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd0ddd02-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd0ddd03-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd0ddd04-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1983—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/181"},"text":"Pub. L. 98–181","children":[],"tail":" inserted provision relating to application of "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s3706/b"},"text":"section 3706(b) of this title","children":[],"tail":" in event of foreclosure under other foreclosure procedures."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
