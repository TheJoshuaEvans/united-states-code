{"tag":"section","attrib":{"id":"iddd06b176-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3348"},"text":null,"children":[{"tag":"num","attrib":{"value":"3348"},"text":"§ 3348.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recognition of State certified and licensed appraisers for purposes of this chapter","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd06b177-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3348/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date for use of certified or licensed appraisers only","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd06b178-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3348/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"1992-12-31"},"text":"December 31, 1992","children":[],"tail":", all appraisals performed in connection with federally related transactions shall be performed only by individuals certified or licensed in accordance with the requirements of this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd06b179-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3348/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension of effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the approval of the Council, the Appraisal Subcommittee may extend, until ","children":[{"tag":"date","attrib":{"date":"1991-12-31"},"text":"December 31, 1991","children":[],"tail":", the effective date for the use of certified or licensed appraisers if it makes a written finding that a State has made substantial progress in establishing a State certification and licensing system that appears to conform to the provisions of this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd06b17a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3348/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary waiver of appraiser certification or licensing requirements for State having scarcity of qualified appraisers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the approval of the Council, the Appraisal Subcommittee may waive any requirement relating to certification or licensing of a person to perform appraisals under this chapter if the Appraisal Subcommittee or a State agency whose certifications and licenses are in compliance with this chapter, makes a written determination that there is a scarcity of certified or licensed appraisers to perform appraisals in connection with federally related transactions in a State, or in any geographical political subdivision of a State, leading to significant delays in the performance of such appraisals. The waiver terminates when the Appraisal Subcommittee determines that such significant delays have been eliminated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd06b17b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3348/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to State certifying and licensing agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Appraisal Subcommittee, any other Federal agency or instrumentality, or any federally recognized entity shall report any action of a State certified or licensed appraiser that is contrary to the purposes of this chapter, to the appropriate State agency for a disposition of the subject of the referral. The State agency shall provide the Appraisal Subcommittee or the other Federal agency or instrumentality with a report on its disposition of the matter referred. Subsequent to such disposition, the subcommittee or the agency or instrumentality may take such further action, pursuant to written procedures, it deems necessary to carry out the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd06b17c-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/tXI/s1119"},"text":"Pub. L. 101–73, title XI, § 1119","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/516"},"text":"103 Stat. 516","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/233/tVII/s701/b"},"text":"Pub. L. 102–233, title VII, § 701(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-12"},"text":"Dec. 12, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1792"},"text":"105 Stat. 1792","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/242/tIV/s472/b"},"text":"Pub. L. 102–242, title IV, § 472(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2386"},"text":"105 Stat. 2386","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXVI/s1617/a"},"text":"Pub. L. 102–550, title XVI, § 1617(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4096"},"text":"106 Stat. 4096","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tXIV/s1473/t/1"},"text":"Pub. L. 111–203, title XIV, § 1473(t)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2199"},"text":"124 Stat. 2199","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd06b17d-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd06b17e-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd06b17f-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" substituted “Council,” for “council,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsecs. (a)(1), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/s1617/a"},"text":"Pub. L. 102–550, § 1617(a)","children":[],"tail":", repealed "},{"tag":"ref","attrib":{"href":"/us/pl/102/233/s701/b"},"text":"Pub. L. 102–233, § 701(b)","children":[],"tail":". See 1991 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/s472/b/1"},"text":"Pub. L. 102–242, § 472(b)(1)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"1992-12-31"},"text":"December 31, 1992","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1991-07-01"},"text":"July 1, 1991","children":[],"tail":"”. "},{"tag":"ref","attrib":{"href":"/us/pl/102/233/s701/b/1"},"text":"Pub. L. 102–233, § 701(b)(1)","children":[],"tail":", which made an identical amendment, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/s1617/a"},"text":"Pub. L. 102–550, § 1617(a)","children":[],"tail":". See Construction of 1991 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/s472/b/2"},"text":"Pub. L. 102–242, § 472(b)(2)","children":[],"tail":", substituted “, or in any geographical political subdivision of a State, leading to significant delays” for “leading to inordinate delays” in first sentence and “significant” for “inordinate” in second sentence. "},{"tag":"ref","attrib":{"href":"/us/pl/102/233/s701/b/2"},"text":"Pub. L. 102–233, § 701(b)(2)","children":[],"tail":", which made an identical amendment, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/s1617/a"},"text":"Pub. L. 102–550, § 1617(a)","children":[],"tail":". See Construction of 1991 Amendment note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd06b180-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd06b181-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective on the date on which final regulations implementing that amendment take effect, or on the date that is 18 months after the designated transfer date if such regulations have not been issued by that date, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1400/c"},"text":"section 1400(c) of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1601"},"text":"section 1601 of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd06b182-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction of 1991 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"No amendment to this section by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/233/s701"},"text":"section 701 of Pub. L. 102–233","children":[],"tail":" to be deemed to have taken effect before "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", and provisions of law amended by such section 701 to continue in effect as if no such amendment had been made, see "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/s1617/b"},"text":"section 1617(b) of Pub. L. 102–550","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s3345"},"text":"section 3345 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
