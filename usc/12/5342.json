{"tag":"section","attrib":{"id":"iddd556e15-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5342"},"text":null,"children":[{"tag":"num","attrib":{"value":"5342"},"text":"§ 5342.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Financial Research established","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd556e16-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5342/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established within the Department of the Treasury the Office of Financial Research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd556e17-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5342/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd556e18-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5342/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office shall be headed by a Director, who shall be appointed by the President, by and with the advice and consent of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd556e19-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5342/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall serve for a term of 6 years, except that, in the event that a successor is not nominated and confirmed by the end of the term of service of a Director, the Director may continue to serve until such time as the next Director is appointed and confirmed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd556e1a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5342/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Executive level","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall be compensated at Level III of the Executive Schedule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd556e1b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5342/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on dual service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The individual serving in the position of Director may not, during such service, also serve as the head of any financial regulatory agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd556e1c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5342/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities, duties, and authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall have sole discretion in the manner in which the Director fulfills the responsibilities and duties and exercises the authorities described in this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd556e1d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5342/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Budget","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director, in consultation with the Chairperson, shall establish the annual budget of the Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd556e1e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5342/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office personnel","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd556e1f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5342/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director, in consultation with the Chairperson, may fix the number of, and appoint and direct, all employees of the Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd556e20-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5342/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director, in consultation with the Chairperson, shall fix, adjust, and administer the pay for all employees of the Office, without regard to chapter 51 or subchapter III of chapter 53 of title 5, relating to classification of positions and General Schedule pay rates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd556e21-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5342/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":", (4) Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd556e22-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5342/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance from Federal agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any department or agency of the United States may provide to the Office and any special advisory, technical, or professional committees appointed by the Office, such services, funds, facilities, staff, and other support services as the Office may determine advisable. Any Federal Government employee may be detailed to the Office without reimbursement, and such detail shall be without interruption or loss of civil service status or privilege.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd556e23-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5342/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procurement of temporary and intermittent services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may procure temporary and intermittent services under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109/b"},"text":"section 3109(b) of title 5","children":[],"tail":" at rates for individuals which do not exceed the daily equivalent of the annual rate of basic pay prescribed for Level V of the Executive Schedule under section 5316 of such title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd556e24-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5342/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Post-employment prohibitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, with the concurrence of the Director of the Office of Government Ethics, shall issue regulations prohibiting the Director and any employee of the Office who has had access to the transaction or position data maintained by the Data Center or other business confidential information about financial entities required to report to the Office from being employed by or providing advice or consulting services to a financial company, for a period of 1 year after last having had access in the course of official duties to such transaction or position data or business confidential information, regardless of whether that entity is required to report to the Office. For employees whose access to business confidential information was limited, the regulations may provide, on a case-by-case basis, for a shorter period of post-employment prohibition, provided that the shorter period does not compromise business confidential information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd556e25-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5342/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical and professional advisory committees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office, in consultation with the Chairperson, may appoint such special advisory, technical, or professional committees as may be useful in carrying out the functions of the Office, and the members of such committees may be staff of the Office, or other persons, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd556e26-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5342/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fellowship program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office, in consultation with the Chairperson, may establish and maintain an academic and professional fellowship program, under which qualified academics and professionals shall be invited to spend not longer than 2 years at the Office, to perform research and to provide advanced training for Office personnel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd556e27-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tI/s152"},"text":"Pub. L. 111–203, title I, § 152","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1413"},"text":"124 Stat. 1413","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd556e28-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd556e29-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd556e2a-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Level III of the Executive Schedule, referred to in subsec. (b)(3), is set out in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5314"},"text":"section 5314 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd556e2b-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s152"},"text":"section 152 of Pub. L. 111–203","children":[],"tail":". Subsecs. (d)(3), (4) and (j) of section 152 amended "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1833b"},"text":"section 1833b of this title","children":[],"tail":" and sections 3132 and 5314 of Title 5, Government Organization and Employees, respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
