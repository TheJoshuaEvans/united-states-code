{"tag":"section","attrib":{"id":"iddb1df41e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s194"},"text":null,"children":[{"tag":"num","attrib":{"value":"194"},"text":"§ 194.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dividends on adjusted claims; distribution of assets","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"From time to time, the comptroller shall make a ratable dividend of the money so paid over to him by such receiver on all such claims as may have been proved to his satisfaction or adjudicated in a court of competent jurisdiction, and, as the proceeds of the assets of such association are paid over to him, shall make further dividends on all claims previously proved or adjudicated; and the remainder of the proceeds, if any, shall be paid over to the shareholders of such association, or their legal representatives, in proportion to the stock by them respectively held.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddb1df41f-3a6f-11f1-8fa0-c065796a7f06"},"text":"(R.S. § 5236; ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/tVI/s602/g/12"},"text":"Pub. L. 103–325, title VI, § 602(g)(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2294"},"text":"108 Stat. 2294","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb1df420-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb1df421-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddb1df422-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 5236 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1864-06-03/ch106/s50"},"text":"act June 3, 1864, ch. 106, § 50","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/13/114"},"text":"13 Stat. 114","children":[],"tail":", which was the National Bank Act. See "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s38"},"text":"section 38 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddb1df423-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325"},"text":"Pub. L. 103–325","children":[],"tail":" struck out “, after full provision has been first made for refunding to the United States any deficiency in redeeming the notes of such association” after “From time to time”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddb1df424-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddb1df425-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Application to District of Columbia","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions of this section were made applicable to banks, etc. in the District of Columbia by ","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-03-04/ch274/s4"},"text":"act Mar. 4, 1933, ch. 274, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/47/1567"},"text":"47 Stat. 1567","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"iddb1df426-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddb1df427-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Exception as to Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions vested by any provision of law in Comptroller of the Currency, referred to in this section, not included in transfer of functions to Secretary of the Treasury, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
