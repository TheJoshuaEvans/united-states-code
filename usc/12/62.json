{"tag":"section","attrib":{"id":"iddb0f9c13-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s62"},"text":null,"children":[{"tag":"num","attrib":{"value":"62"},"text":"§ 62.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" List of shareholders","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The president and cashier of every national banking association shall cause to be kept at all times a full and correct list of the names and residences of all the shareholders in the association, and the number of shares held by each, in the office where its business is transacted. Such list shall be subject to the inspection of all the shareholders and creditors of the association, and the officers authorized to assess taxes under State authority, during business hours of each day in which business may be legally transacted. A copy of such list, verified by the oath of such president or cashier, shall be transmitted to the Comptroller of the Currency within ten days of any demand therefor made by him.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddb0f9c14-3a6f-11f1-8fa0-c065796a7f06"},"text":"(R.S. § 5210; ","children":[{"tag":"ref","attrib":{"href":"/us/act/1953-05-18/ch59/s1"},"text":"May 18, 1953, ch. 59, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/67/27"},"text":"67 Stat. 27","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb0f9c15-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb0f9c16-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddb0f9c17-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 5210 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1864-06-03/ch106/s40"},"text":"act June 3, 1864, ch. 106, § 40","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/13/111"},"text":"13 Stat. 111","children":[],"tail":", which was the National Bank Act. See "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s38"},"text":"section 38 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddb0f9c18-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1953—Act ","children":[{"tag":"date","attrib":{"date":"1953-05-18"},"text":"May 18, 1953","children":[],"tail":", changed the requirement for annual transmission of a copy of the shareholders list to the Comptroller of the Currency by authorizing the Comptroller to acquire such copy at any time on 10 days’ notice."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddb0f9c19-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddb0f9c1a-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Application to District of Columbia","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions of this section were made applicable to banks, etc., in the District of Columbia by ","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-03-04/ch274/s4"},"text":"act Mar. 4, 1933, ch. 274, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/47/1567"},"text":"47 Stat. 1567","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"iddb0f9c1b-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddb0f9c1c-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Exception as to Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions vested by any provision of law in Comptroller of the Currency, referred to in this section, not included in transfer of functions to Secretary of the Treasury, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
