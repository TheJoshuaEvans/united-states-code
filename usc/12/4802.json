{"tag":"section","attrib":{"id":"iddd3fe9bb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4802"},"text":null,"children":[{"tag":"num","attrib":{"value":"4802"},"text":"§ 4802.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative consideration of burden with new regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd3fe9bc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4802/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining the effective date and administrative compliance requirements for new regulations that impose additional reporting, disclosure, or other requirements on insured depository institutions, each Federal banking agency shall consider, consistent with the principles of safety and soundness and the public interest—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd3fe9bd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4802/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any administrative burdens that such regulations would place on depository institutions, including small depository institutions and customers of depository institutions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3fe9be-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4802/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the benefits of such regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3fe9bf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4802/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adequate transition period for new regulations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd3fe9c0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4802/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"New regulations and amendments to regulations prescribed by a Federal banking agency which impose additional reporting, disclosures, or other new requirements on insured depository institutions shall take effect on the first day of a calendar quarter which begins on or after the date on which the regulations are published in final form, unless—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd3fe9c1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4802/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agency determines, for good cause published with the regulation, that the regulation should become effective before such time;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3fe9c2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4802/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the regulation is issued by the Board of Governors of the Federal Reserve System in connection with the implementation of monetary policy; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3fe9c3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4802/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the regulation is required to take effect on a date other than the date determined under this paragraph pursuant to any other Act of Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3fe9c4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4802/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Early compliance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who is subject to a regulation described in paragraph (1) may comply with the regulation before the effective date of the regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd3fe9c5-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/tIII/s302"},"text":"Pub. L. 103–325, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2214"},"text":"108 Stat. 2214","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
