{"tag":"section","attrib":{"id":"iddd129828-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3909"},"text":null,"children":[{"tag":"num","attrib":{"value":"3909"},"text":"§ 3909.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authorities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd129829-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3909/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and regulations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd12982a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3909/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The appropriate Federal banking agencies are authorized to interpret and define the terms used in this chapter, and each appropriate Federal banking agency shall prescribe rules or regulations or issue orders as necessary to effectuate the purposes of this chapter and to prevent evasions thereof.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd12982b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3909/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The appropriate Federal banking agency is authorized to apply the provisions of this chapter to any affiliate of an insured depository institution, but only to affiliates for which it is the appropriate Federal banking agency, in order to promote uniform application of this chapter or to prevent evasions thereof.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd12982c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3909/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this section, the term “affiliate” shall have the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s371c"},"text":"section 371c of this title","children":[],"tail":", except that the term “member bank” in such section shall be deemed to refer to an “insured depository institution”, as such term is defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813/c/2"},"text":"section 1813(c)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd12982d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3909/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Systems uniformity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The appropriate Federal banking agencies shall establish uniform systems to implement the authorities provided under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd12982e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3909/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing authorities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd12982f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3909/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The powers and authorities granted in this chapter shall be supplemental to and shall not be deemed in any manner to derogate from or restrict the authority of each appropriate Federal banking agency under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1818"},"text":"section 1818 of this title","children":[],"tail":" or any other law including the authority to require additional capital or reserves."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd129830-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3909/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any such authority may be used by any appropriate Federal banking agency to ensure compliance by a banking institution with the provisions of this chapter and all rules, regulations, or orders issued pursuant thereto.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd129831-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3909/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil penalties; assessment and collection","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd129832-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3909/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any banking institution which violates, or any officer, director, employee, agent, or other person participating in the conduct of the affairs of such banking institution, who violates any provision of this chapter, or any rule, regulation, or order, issued under this chapter, shall forfeit and pay a civil penalty of not more than $1,000 per day for each day during which such violation continues.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd129833-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3909/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such violations shall be deemed to be a violation of a final order under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1818/i/2"},"text":"section 1818(i)(2) of this title","children":[],"tail":" and the penalty shall be assessed and collected by the appropriate Federal banking agency under the procedures established by, and subject to the rights afforded to parties in, such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd129834-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/181/tI"},"text":"Pub. L. 98–181, title I","children":[],"tail":" [title IX, § 910], "},{"tag":"date","attrib":{"date":"1983-11-30"},"text":"Nov. 30, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1282"},"text":"97 Stat. 1282","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/351/tVII/s713/b"},"text":"Pub. L. 109–351, title VII, § 713(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-13"},"text":"Oct. 13, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1995"},"text":"120 Stat. 1995","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd129835-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd129836-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd129837-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/351/s713/b/1"},"text":"Pub. L. 109–351, § 713(b)(1)","children":[],"tail":", substituted “insured depository institution” for “insured bank”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/351/s713/b/2"},"text":"Pub. L. 109–351, § 713(b)(2)","children":[],"tail":", substituted “an ‘insured depository institution’, as such term is defined in section 1813(c)(2)” for “an ‘insured bank’, as such term is used in section 1813(h)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
