{"tag":"section","attrib":{"id":"iddcf39eee-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2705"},"text":null,"children":[{"tag":"num","attrib":{"value":"2705"},"text":"§ 2705.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency mortgage relief payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcf39eef-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2705/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direct payments to mortgagee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any mortgagee which would otherwise be eligible to participate in the program authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2704"},"text":"section 2704 of this title","children":[],"tail":" but does not qualify for an advance or advances as authorized by section 2712 "},{"tag":"ref","attrib":{"idref":"fn002314"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002314"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title or under section 1430, 1430b, or 1431 of this title or otherwise elects not to participate in the program authorized under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2704"},"text":"section 2704 of this title","children":[],"tail":", the Secretary is authorized to make repayable emergency mortgage relief payments directly to such mortgagee on behalf of homeowners whose mortgages are held by such financial institution and who are delinquent in their mortgage payments."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcf39ef0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2705/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mortgages eligible; terms and conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Emergency mortgage relief payments shall be made under this section only with respect to a mortgage which meets the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2702"},"text":"section 2702 of this title","children":[],"tail":" and only on such terms and conditions as the Secretary may prescribe, subject to the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2703"},"text":"section 2703 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcf39ef1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2705/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Processing of relief payments; power of Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make such delegations and accept such certifications with respect to the processing of mortgage relief payments provided under this section as he deems appropriate to facilitate the prompt and efficient implementation of the assistance authorized under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcf39ef2-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/50/tI/s106"},"text":"Pub. L. 94–50, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-07-02"},"text":"July 2, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/251"},"text":"89 Stat. 251","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcf39ef3-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcf39ef4-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddcf39ef5-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2712"},"text":"Section 2712 of this title","children":[],"tail":", referred to in subsec. (a), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tXIV/s1496/b/7"},"text":"Pub. L. 111–203, title XIV, § 1496(b)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2209"},"text":"124 Stat. 2209","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
