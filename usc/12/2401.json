{"tag":"section","attrib":{"id":"iddceee328-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2401"},"text":null,"children":[{"tag":"num","attrib":{"value":"2401"},"text":"§ 2401.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is established the National Commission on Electronic Fund Transfers (hereinafter referred to as the “Commission”) which shall be an independent instrumentality of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddceee329-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/495/tII/s201"},"text":"Pub. L. 93–495, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-28"},"text":"Oct. 28, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1508"},"text":"88 Stat. 1508","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
