{"tag":"section","attrib":{"id":"iddd1e7f08-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4207"},"text":null,"children":[{"tag":"num","attrib":{"value":"4207"},"text":"§ 4207.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unreviewed declarations; petition to pursue action as private contractor","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd1e7f09-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4207/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd1e7f0a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4207/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If, pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4206/d/2"},"text":"section 4206(d)(2) of this title","children":[],"tail":", the Attorney General notifies a declarant that the declarant’s allegations have not yet been addressed, the declarant may notify the Attorney General to award a contract pursuant to subchapter III to pursue the case."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1e7f0b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4207/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A declarant’s notification under paragraph (1) shall be filed with the Attorney General not later than 30 days after the date of service of notice under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4206/d/2"},"text":"section 4206(d)(2) of this title","children":[],"tail":", and the Attorney General shall respond to the notification not later than 30 days after receipt."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1e7f0c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4207/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of response","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In response to a notification under subsection (a)(1), the Attorney General shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd1e7f0d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4207/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grant a contract pursuant to subchapter III; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1e7f0e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4207/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proceed with an action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1e7f0f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4207/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant of contract","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Attorney General decides to grant a contract, the declarant, after consultation with the Attorney General, shall have the right to select counsel to prosecute an action, and the declarant and the declarant’s counsel shall act in accordance with subchapter III.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd1e7f10-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXV/s2567"},"text":"Pub. L. 101–647, title XXV, § 2567","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4898"},"text":"104 Stat. 4898","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
