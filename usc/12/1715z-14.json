null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddc1106b6-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Evaluation of Reinsurance Program; Report to Congress","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/181/tI"},"text":"Pub. L. 98–181, title I","children":[],"tail":" [title IV, § 428(b)], "},{"tag":"date","attrib":{"date":"1983-11-30"},"text":"Nov. 30, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1219"},"text":"97 Stat. 1219","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/181/tI"},"text":"“The Secretary of Housing and Urban Development shall evaluate the reinsurance program under section 249 of the National Housing Act [this section] and, not later than ","children":[{"tag":"date","attrib":{"date":"1985-03-01"},"text":"March 1, 1985","children":[],"tail":", submit to the Congress a report setting forth the results of such evaluation. Such report shall include an evaluation of the possible effect of a reinsurance program on the characteristics of the pool of mortgages remaining wholly under the applicable insurance funds and the actuarial soundness of such funds under such conditions.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
