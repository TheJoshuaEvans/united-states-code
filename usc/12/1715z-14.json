:", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2835"},"text":"122 Stat. 2835","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc1106b4-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tI/s143/1"},"text":"Pub. L. 106–554, § 1(a)(7) [title I, § 143(1)]","children":[],"tail":", substituted “Risk-sharing demonstration” for “Reinsurance contracts” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tI/s143/2"},"text":"Pub. L. 106–554, § 1(a)(7) [title I, § 143(2), (3)]","children":[],"tail":", in heading and first sentence substituted “risk-sharing” for “reinsurance” wherever appearing, in first sentence inserted “and with insured community development financial institutions” after “private mortgage insurers”, in second sentence substituted “four administrative regions” for “two administrative regions” and “the expiration of the 5-year period beginning on "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"December 21, 2000","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1988-03-15"},"text":"March 15, 1988","children":[],"tail":"”, and in last sentence substituted “mortgages for which risk of nonpayment is shared” for “mortgages insured” and “20 percent” for “10 percent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tI/s143/2"},"text":"Pub. L. 106–554, § 1(a)(7) [title I, § 143(2), (4)(A), (B)]","children":[],"tail":", in first sentence of introductory provisions, substituted “, in providing” for “to provide”, “, to enter into” for “through” and “risk-sharing” for “reinsurance” and inserted “and with insured community development financial institutions” before period at end and, in second sentence of introductory provisions, inserted “and insured community development financial institutions” after “private mortgage insurance companies”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tI/s143/4/C"},"text":"Pub. L. 106–554, § 1(a)(7) [title I, § 143(4)(C)]","children":[],"tail":", added par. (1) and struck out former par. (1) which read as follows: “assume a percentage of loss on any mortgage insured pursuant to section 1709(b), 1715y, or 1715z–10 of this title covering a one- to four-family dwelling, which percentage of loss shall be set forth in the risk-sharing contract; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tI/s143/2"},"text":"Pub. L. 106–554, § 1(a)(7) [title I, § 143(2)]","children":[],"tail":", substituted “risk-sharing” for “reinsurance”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tI/s143/4/D"},"text":"Pub. L. 106–554, § 1(a)(7) [title I, § 143(4)(D)]","children":[],"tail":", substituted “perform or delegate underwriting,” for “carry out (under appropriate delegation) such” and “functions as the Secretary” for “function as the Secretary pursuant to regulations,” and inserted before period at end “and shall set forth in the risk-sharing contract”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tI/s143/2"},"text":"Pub. L. 106–554, § 1(a)(7) [title I, § 143(2), (5)]","children":[],"tail":", in first sentence, substituted “contract for” for “contract of” and “risk-sharing” for “reinsurance”, inserted “received by the Secretary with a private mortgage insurer or insured community development financial institution” after “sharing of premiums”, substituted “loss reserves” for “insurance reserves”, “such risk-sharing contract” for “such insurance”, and “rights of assignees” for “right of assignees” and, in second sentence, inserted “or insured community development financial institution” after “private mortgage insurance company” and substituted “loans for risk-sharing” for “loans for insurance”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tI/s143/2"},"text":"Pub. L. 106–554, § 1(a)(7) [title I, § 143(2), (6)]","children":[],"tail":", inserted “or insured community development financial institution” after “private mortgage insurance company” and substituted “risk-sharing” for “reinsurance”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tI/s143/7"},"text":"Pub. L. 106–554, § 1(a)(7) [title I, § 143(7)]","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/200"},"text":"Pub. L. 100–200","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1988-03-15"},"text":"March 15, 1988","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1987-12-16"},"text":"December 16, 1987","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/179"},"text":"Pub. L. 100–179","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1987-12-16"},"text":"December 16, 1987","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1987-12-02"},"text":"December 2, 1987","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/170"},"text":"Pub. L. 100–170","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1987-12-02"},"text":"December 2, 1987","children":[],"tail":"” for “"},{"