{"tag":"section","attrib":{"id":"iddb22af0d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s215a–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"215a–3"},"text":"§ 215a–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mergers and consolidations with subsidiaries and nonbank affiliates","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddb22af0e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s215a–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon the approval of the Comptroller, a national bank may merge with one or more of its nonbank subsidiaries or affiliates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb22af0f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s215a–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section shall be construed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb22af10-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s215a–3/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to affect the applicability of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1828/c"},"text":"section 1828(c) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb22af11-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s215a–3/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to grant a national bank any power or authority that is not permissible for a national bank under other applicable provisions of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb22af12-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s215a–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Comptroller shall promulgate regulations to implement this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddb22af13-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1918-11-07/ch209/s6"},"text":"Nov. 7, 1918, ch. 209, § 6","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/tXII/s1206"},"text":"Pub. L. 106–569, title XII, § 1206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/3034"},"text":"114 Stat. 3034","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
