{"tag":"section","attrib":{"id":"iddc589690-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1790"},"text":null,"children":[{"tag":"num","attrib":{"value":"1790"},"text":"§ 1790.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nondiscriminatory provision","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It is not the purpose of this subchapter to discriminate in any manner against State-chartered credit unions and in favor of Federal credit unions, but it is the purpose of this subchapter to provide all credit unions with the same opportunity to obtain and enjoy the benefits of this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc589691-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-26/ch750"},"text":"June 26, 1934, ch. 750","children":[],"tail":", title II, § 211, formerly § 210, as added "},{"tag":"ref","attrib":{"href":"/us/pl/91/468/s1/3"},"text":"Pub. L. 91–468, § 1(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-19"},"text":"Oct. 19, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1015"},"text":"84 Stat. 1015","children":[],"tail":"; renumbered § 211, "},{"tag":"ref","attrib":{"href":"/us/pl/95/147/s2/c/2"},"text":"Pub. L. 95–147, § 2(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-10-28"},"text":"Oct. 28, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1228"},"text":"91 Stat. 1228","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
