{"tag":"section","attrib":{"id":"iddcbcd6c6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2013"},"text":null,"children":[{"tag":"num","attrib":{"value":"2013"},"text":"§ 2013.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General corporate powers","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Each Farm Credit Bank shall be a body corporate and, subject to regulation by the Farm Credit Administration, shall have power to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcbcd6c7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2013/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adopt and use a corporate seal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbcd6c8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2013/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have succession until dissolved under the provisions of this chapter or other Act of Congress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbcd6c9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2013/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make contracts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbcd6ca-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2013/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sue and be sued;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbcd6cb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2013/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquire, hold, dispose, and otherwise exercise all the usual incidents of ownership of real and personal property necessary or convenient to its business;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbcd6cc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2013/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make, participate in, and discount loans, make commitments for credit, accept advance payments, and provide services as authorized in this chapter, and charge fees for such;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbcd6cd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2013/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operate under the direction of its board of directors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbcd6ce-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2013/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide by its board of directors for a president, one or more vice presidents, a secretary, a treasurer, and provide for such other officers, employees, and agents as may be necessary, as provided in this chapter, define their duties, and require surety bonds or make other provision against losses occasioned by employees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbcd6cf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2013/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" prescribe, by its board of directors, its bylaws that shall be consistent with law, and that shall provide for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcbcd6d0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2013/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the classes of its stock and the manner in which such stock shall be issued, transferred, and retired; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcbcd6d1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2013/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the manner in which it is to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddcbcd6d2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2013/9/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" select officers, employees, and agents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcbcd6d3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2013/9/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquire, hold, and transfer property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcbcd6d4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2013/9/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make loans and discounts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcbcd6d5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2013/9/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct general business; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcbcd6d6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2013/9/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exercise and enjoy the privileges granted to it by law;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbcd6d7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2013/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" borrow money and issue notes, bonds, debentures, or other obligations individually, or in concert with one or more other banks of the System, of such character, terms, conditions, and rates of interest as may be determined as provided for in this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbcd6d8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2013/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchase nonvoting stock in, or pay in surplus to, and accept deposits of securities or funds from associations in its district, and pay interest on such funds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbcd6d9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2013/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" participate with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcbcd6da-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2013/12/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more other Farm Credit Banks in loans under this subchapter on such terms as may be agreed on among such banks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcbcd6db-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2013/12/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more other Farm Credit System institutions in loans made under this subchapter or other subchapters of this chapter on the basis prescribed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2206"},"text":"section 2206 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcbcd6dc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2013/12/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lenders that are not Farm Credit System institutions in loans that the bank is authorized to make under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbcd6dd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2013/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approve the salary scale of the officers and employees of the associations in its district and supervise the exercise by such associations of the functions vested in or delegated to them;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbcd6de-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2013/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" deposit the securities and current funds of the bank with any member bank of the Federal Reserve System or any insured State nonmember bank (within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"section 1813 of this title","children":[],"tail":") and pay fees and receive interest on such as may be agreed, and when designated for that purpose by the Secretary of the Treasury, such bank—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcbcd6df-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2013/14/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be a depository of public money, except receipts from customs, under such regulations as may be prescribed by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcbcd6e0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2013/14/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be employed as a fiscal agent of the Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcbcd6e1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2013/14/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall perform all such reasonable duties as a depository of public money or financial agent of the Government as may be required of such bank;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"except that no Government funds deposited under the provisions of this paragraph shall be invested in loans or bonds or other obligations of the bank;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbcd6e2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2013/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" buy and sell obligations of, or insured by, the United States or any agency thereof, or securities backed by the full faith and credit of any such agency, and make other investments as may be authorized under regulations issued by the Farm Credit Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbcd6e3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2013/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sell to lenders that are not Farm Credit System institutions interests in loans, and buy from and sell to Farm Credit System institutions interests in loans and other extensions of credit, and nonvoting stock as may be authorized under regulations issued by the Farm Credit Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbcd6e4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2013/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct studies and make and adopt standards for lending;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbcd6e5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2013/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" delegate to associations such functions as the bank determines appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbcd6e6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2013/19"},"text":null,"children":[{"tag":"num","attrib":{"value":"19"},"text":"(19)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amend and modify loan contracts, documents, and payment schedules, and release, subordinate, or substitute security for any of such items;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbcd6e7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2013/20"},"text":null,"children":[{"tag":"num","attrib":{"value":"20"},"text":"(20)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for loans made by the bank, require associations to endorse notes and other obligations of borrowers from the bank;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbcd6e8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2013/21"},"text":null,"children":[{"tag":"num","attrib":{"value":"21"},"text":"(21)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exercise through the board of directors or authorized officers, employees, or agents of the bank, all such incidental powers as may be necessary or expedient to carry on the business of the bank;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbcd6e9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2013/22"},"text":null,"children":[{"tag":"num","attrib":{"value":"22"},"text":"(22)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept contributions to the capital of the bank from associations and account for such in accordance with generally accepted accounting principles, except as may be authorized by the Farm Credit Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbcd6ea-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2013/23"},"text":null,"children":[{"tag":"num","attrib":{"value":"23"},"text":"(23)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as may be authorized by the board of directors of the bank, agree with other Farm Credit System institutions to share loan and other losses, whether to protect against capital impairment or for any other purpose; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbcd6eb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2013/24"},"text":null,"children":[{"tag":"num","attrib":{"value":"24"},"text":"(24)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operate as an originator and become certified as a certified facility under subchapter VIII.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcbcd6ec-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tI/s1"},"text":"Pub. L. 92–181, title I, § 1","children":[],"tail":".5, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tIV/s401"},"text":"Pub. L. 100–233, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1623"},"text":"101 Stat. 1623","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/tIV/s401/d"},"text":"Pub. L. 100–399, title IV, § 401(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-17"},"text":"Aug. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/995"},"text":"102 Stat. 995","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/105/tII/s201"},"text":"Pub. L. 104–105, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/172"},"text":"110 Stat. 172","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcbcd6ed-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcbcd6ee-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"iddcbcd6ef-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2013, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tI/s1"},"text":"Pub. L. 92–181, title I, § 1","children":[],"tail":".5, "},{"tag":"date","attrib":{"date":"1971-12-10"},"text":"Dec. 10, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/585"},"text":"85 Stat. 585","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/592/tI/s102"},"text":"Pub. L. 96–592, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-24"},"text":"Dec. 24, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3437"},"text":"94 Stat. 3437","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/205/tII/s205/d/2"},"text":"Pub. L. 99–205, title II, § 205(d)(2)","children":[],"tail":", (3), title VI, § 601, "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1703"},"text":"99 Stat. 1703","children":[],"tail":", 1711; "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tVIII/s802/c"},"text":"Pub. L. 100–233, title VIII, § 802(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1710"},"text":"101 Stat. 1710","children":[],"tail":", related to land bank stock, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/s401"},"text":"Pub. L. 100–233, § 401","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcbcd6f0-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Par. (13). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/105"},"text":"Pub. L. 104–105","children":[],"tail":" struck out “, and the appointment and compensation of the chief executive officer thereof,” after “in its district”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Par. (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s401/d/1"},"text":"Pub. L. 100–399, § 401(d)(1)","children":[],"tail":", amended par. (9) generally. Prior to amendment, par. (9) read as follows: “prescribe by its board of directors—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) the bylaws of such bank that shall not be inconsistent with law, providing for the classes of the stock of the bank and the manner in which such stock shall be issued, transferred, and retired;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) the officers, employees, and agents of the bank as provided for;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) the property of the bank acquired, held, and transferred;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(D) the loans and discounts made by the bank;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(E) the general business conducted by the bank; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(F) the privileges granted to the bank by law exercised and enjoyed;”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s401/d/2"},"text":"Pub. L. 100–399, § 401(d)(2)","children":[],"tail":", substituted “of securities or” for “or securities of”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (12)(B), (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s401/d/3"},"text":"Pub. L. 100–399, § 401(d)(3)","children":[],"tail":", struck out “participate with” before “