{"tag":"section","attrib":{"id":"iddcc64c48-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2147"},"text":null,"children":[{"tag":"num","attrib":{"value":"2147"},"text":"§ 2147.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Patronage pools","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Under such terms and conditions as may be determined by its board of directors, the consolidated bank may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcc64c49-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2147/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a period of at least 3 years following ","children":[{"tag":"date","attrib":{"date":"1988-01-06"},"text":"January 6, 1988","children":[],"tail":", establish separate patronage pools consisting of loans to eligible borrowers located in each constituent farm credit district (as such district existed on "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"January 6, 1988","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc64c4a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2147/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allocate revenues, expenses, and net savings among such pools on an equitable basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcc64c4b-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tIII/s3"},"text":"Pub. L. 92–181, title III, § 3","children":[],"tail":".26, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tIV/s415/2"},"text":"Pub. L. 100–233, title IV, § 415(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1644"},"text":"101 Stat. 1644","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
