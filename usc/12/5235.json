{"tag":"section","attrib":{"id":"iddd4e4293-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5235"},"text":null,"children":[{"tag":"num","attrib":{"value":"5235"},"text":"§ 5235.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosures on exercise of loan authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd4e4294-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5235/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 7 days after the date on which the Board exercises its authority under the third paragraph of section 13 of the Federal Reserve Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s343"},"text":"12 U.S.C. 343","children":[],"tail":"; relating to discounts for individuals, partnerships, and corporations) the Board shall provide to the Committee on Banking, Housing, and Urban Affairs of the Senate and the Committee on Financial Services of the House of Representatives a report which includes—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd4e4295-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5235/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the justification for exercising the authority; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4e4296-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5235/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the specific terms of the actions of the Board, including the size and duration of the lending, available information concerning the value of any collateral held with respect to such a loan, the recipient of warrants or any other potential equity in exchange for the loan, and any expected cost to the taxpayers for such exercise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd4e4297-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5235/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic updates","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall provide updates to the Committees specified in subsection (a) not less frequently than once every 60 days while the subject loan is outstanding, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd4e4298-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5235/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status of the loan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4e4299-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5235/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the value of the collateral held by the Federal reserve bank which initiated the loan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4e429a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5235/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the projected cost to the taxpayers of the loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd4e429b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5235/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The information submitted to the Congress under this section shall be kept confidential, upon the written request of the Chairman of the Board, in which case it shall be made available only to the Chairpersons and Ranking Members of the Committees described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd4e429c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5235/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of this section shall be in force for all uses of the authority provided under section 13 of the Federal Reserve Act occurring during the period beginning on ","children":[{"tag":"date","attrib":{"date":"2008-03-01"},"text":"March 1, 2008","children":[],"tail":" and ending on the after "},{"tag":"ref","attrib":{"idref":"fn002465"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002465"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" "},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"October 3, 2008","children":[],"tail":", and reports described in subsection (a) shall be required beginning not later than 30 days after "},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"October 3, 2008","children":[],"tail":", with respect to any such exercise of authority."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd4e429d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5235/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sharing of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any reports required under this section shall also be submitted to the Congressional Oversight Panel established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5233"},"text":"section 5233 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd4e429e-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/343/dA/tI/s129"},"text":"Pub. L. 110–343, div. A, title I, § 129","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3796"},"text":"122 Stat. 3796","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd4e429f-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd4e42a0-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd4e42a1-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 13 of the Federal Reserve Act, referred to in subsecs. (a) and (d), is classified to sections 92, 342 to 347, 347c, 347d, 361, 372, and 373 of this title. The third paragraph (now designated par. (3)) of section 13 of the Act is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s343/3"},"text":"section 343(3) of this title","children":[],"tail":". For further details, see Codification notes under sections 342 and 343 of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
