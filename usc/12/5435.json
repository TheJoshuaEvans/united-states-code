{"tag":"section","attrib":{"id":"iddd660fef-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5435"},"text":null,"children":[{"tag":"num","attrib":{"value":"5435"},"text":"§ 5435.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of affairs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd660ff0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5435/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Director","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During the 90-day period beginning on the transfer date, the Director of the Office of Thrift Supervision—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd660ff1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5435/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall, solely for the purpose of winding up the affairs of the Office of Thrift Supervision relating to any function transferred to the Office of the Comptroller of the Currency, the Corporation, or the Board of Governors under this title— ","children":[{"tag":"ref","attrib":{"idref":"fn002492"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002492"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd660ff2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5435/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" manage the employees of the Office of Thrift Supervision who have not yet been transferred and provide for the payment of the compensation and benefits of the employees that accrue before the date on which the employees are transferred under this title; ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd660ff3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5435/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" manage any property of the Office of Thrift Supervision, until the date on which the property is transferred under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5433"},"text":"section 5433 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd660ff4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5435/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may take any other action necessary to wind up the affairs of the Office of Thrift Supervision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd660ff5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5435/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status of Director","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd660ff6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5435/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding the transfer of functions under this part, during the 90-day period beginning on the transfer date, the Director of the Office of Thrift Supervision shall retain and may exercise any authority vested in the Director of the Office of Thrift Supervision on the day before the transfer date, only to the extent necessary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd660ff7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5435/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to wind up the Office of Thrift Supervision; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd660ff8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5435/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out the transfer under this part during such 90-day period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd660ff9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5435/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other provisions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1), the Director of the Office of Thrift Supervision shall, during the 90-day period beginning on the transfer date, continue to be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd687ffa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5435/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" treated as an officer of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd687ffb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5435/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entitled to receive compensation at the same annual rate of basic pay that the Director of the Office of Thrift Supervision received on the day before the transfer date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd687ffc-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tIII/s325"},"text":"Pub. L. 111–203, title III, § 325","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1536"},"text":"124 Stat. 1536","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd687ffd-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd687ffe-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd687fff-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This title, where footnoted in subsec. (a)(1), is title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1520"},"text":"124 Stat. 1520","children":[],"tail":", known as the Enhancing Financial Institution Safety and Soundness Act of 2010, which enacted this subchapter and sections 4b and 16 of this title, amended sections 1, 11, 248, 461, 481, 482, 1438, 1462, 1462a, 1463, to 1464, 1466a, 1467, 1467a, 1468, 1468a, to 1468b, 1470, 1701c, 1701p–1, 1708, 1757, 1785, 1786, 1787, 1812, 1813, 1817, 1818, 1820, 1821, 1823, 1828, 1829, 1831e, 1831j, 1833b, 1833e, 1834, 1841, 1843, 1844, 1861, 1867, 1881, 1882, 1884, 1972, 2709, 2902, 2905, 3206 to 3208, 3332, 4515, and 4517 of this title, "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s906"},"text":"section 906 of Title 2","children":[],"tail":", The Congress, sections 78c, 78"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":", 78"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"–5, and 78w of Title 15, Commerce and Trade, sections 212, 657, 981, 982, 1006, 1014, and 1032 of Title 18, Crimes and Criminal Procedure, sections 321 and 714 of Title 31, Money and Finance, "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s41501"},"text":"section 41501 of Title 34","children":[],"tail":", Crime Control and Law Enforcement, sections 4003 and 8105 of Title 42, The Public Health and Welfare, and "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s3502"},"text":"section 3502 of Title 44","children":[],"tail":", Public Printing and Documents, repealed "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1441a"},"text":"section 1441a of this title","children":[],"tail":", enacted provisions set out as notes under sections 1, 16, 1438, 1787, 1812, 1817, and 1821 of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s906"},"text":"section 906 of Title 2","children":[],"tail":", and amended provisions set out as notes under sections 1437, 1463, 1464, 1467a, 1707, 1812, and 1818 of this title. For complete classification of title III to the Code, see Short title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd688000-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd688001-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 1 day after ","children":[{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s4"},"text":"section 4 of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"section 5301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
