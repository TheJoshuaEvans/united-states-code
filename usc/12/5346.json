}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd556e93-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5346/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" steps taken to foster innovation and creativity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd556e94-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5346/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leadership development and succession planning; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd556e95-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5346/b/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" effective use of technology by employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd556e96-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5346/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Workplace flexibility plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Office shall submit a workforce flexibility plan that includes, to the extent practicable—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd556e97-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5346/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" telework;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd556e98-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5346/b/2/B/ii"},"text":null,"children":[{"tag":"num","attri