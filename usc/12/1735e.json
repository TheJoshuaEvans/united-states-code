{"tag":"section","attrib":{"id":"iddc268a93-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1735e"},"text":null,"children":[{"tag":"num","attrib":{"value":"1735e"},"text":"§ 1735e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance of materials or products used in structures","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall adopt a uniform procedure for the acceptance of materials and products to be used in structures approved for mortgages or loans insured under this chapter. Under such procedure any material or product which the Secretary finds is technically suitable for the use proposed shall be accepted. Acceptance of a material or product as technically suitable shall not be deemed to restrict the discretion of the Secretary to determine that a structure, with respect to which a mortgage is executed, is economically sound or an acceptable risk.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc268a94-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-27/ch847"},"text":"June 27, 1934, ch. 847","children":[],"tail":", title V, § 521, as added "},{"tag":"ref","attrib":{"href":"/us/pl/89/117/tII/s216"},"text":"Pub. L. 89–117, title II, § 216","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-08-10"},"text":"Aug. 10, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/473"},"text":"79 Stat. 473","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/90/19/s1/a/3"},"text":"Pub. L. 90–19, § 1(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-05-25"},"text":"May 25, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/17"},"text":"81 Stat. 17","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc268a95-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc268a96-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc268a97-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1967—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/19"},"text":"Pub. L. 90–19","children":[],"tail":" substituted “Secretary” for “Commissioner” wherever appearing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
