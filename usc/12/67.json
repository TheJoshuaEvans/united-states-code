{"tag":"section","attrib":{"id":"iddb11e622-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s67"},"text":null,"children":[{"tag":"num","attrib":{"value":"67"},"text":"§ 67.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Individual liability of shareholders; compromises; authority of receiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any receiver of a national banking association is authorized, with the approval of the Comptroller of the Currency and upon the order of a court of record of competent jurisdiction, to compromise, either before or after judgment, the individual liability of any shareholder of such association.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddb11e623-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-02-25/ch58"},"text":"Feb. 25, 1930, ch. 58","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/74"},"text":"46 Stat. 74","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb11e624-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddb11e625-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddb11e626-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Application to District of Columbia","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions of this section were made applicable to banks, etc., in the District of Columbia by ","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-03-04/ch274/s4"},"text":"act Mar. 4, 1933, ch. 274, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/47/1567"},"text":"47 Stat. 1567","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"iddb11e627-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddb11e628-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Exception as to Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions vested by any provision of law in Comptroller of the Currency, referred to in this section, not included in transfer to Secretary of the Treasury, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
