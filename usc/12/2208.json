{"tag":"section","attrib":{"id":"iddccb0808-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2208"},"text":null,"children":[{"tag":"num","attrib":{"value":"2208"},"text":"§ 2208.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition against use of signed ballots","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In any election or merger vote, or other proceeding subject to a vote of the stockholders (or subscribers to the guaranty fund of a bank for cooperatives), conducted by a lending institution of the Farm Credit System, the institution—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddccb0809-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2208/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not use signed ballots; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddccb080a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2208/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall implement measures to safeguard the voting process for the protection of the right of stockholders (or subscribers) to a secret ballot.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddccb080b-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tIV/s4"},"text":"Pub. L. 92–181, title IV, § 4","children":[],"tail":".20, as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/592/tIV/s403"},"text":"Pub. L. 96–592, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-24"},"text":"Dec. 24, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3447"},"text":"94 Stat. 3447","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tIV/s425"},"text":"Pub. L. 100–233, title IV, § 425","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1657"},"text":"101 Stat. 1657","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddccb080c-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddccb080d-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddccb080e-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/233"},"text":"Pub. L. 100–233","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “The provisions of (1) "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2074"},"text":"section 2074 of this title","children":[],"tail":" authorizing the Federal intermediate credit banks to lend to or discount paper for other financial institutions, and (2) "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2128/b"},"text":"section 2128(b) of this title","children":[],"tail":" authorizing the financing of certain domestic or foreign entities in connection with the import or export activities of cooperatives which are borrowers from the banks for cooperatives, shall expire on "},{"tag":"date","attrib":{"date":"1990-09-30"},"text":"September 30, 1990","children":[],"tail":", unless extended by Act of Congress prior to that date. Any contract or agreement entered into under the authority of either provision prior to its expiration shall remain in full force and effect notwithstanding such expiration.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
