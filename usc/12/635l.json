{"tag":"section","attrib":{"id":"iddb63136d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635l"},"text":null,"children":[{"tag":"num","attrib":{"value":"635l"},"text":"§ 635l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization for appropriation of funds for losses","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are hereby authorized to be appropriated to the Secretary of the Treasury without fiscal year limitation $100,000,000 to cover the amount of any losses which are to be borne by the Secretary of the Treasury as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s635k"},"text":"section 635k of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddb63136e-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/390/s3"},"text":"Pub. L. 90–390, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-07-07"},"text":"July 7, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/297"},"text":"82 Stat. 297","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
