{"tag":"section","attrib":{"id":"iddd06b213-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3401"},"text":null,"children":[{"tag":"num","attrib":{"value":"3401"},"text":"§ 3401.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purpose of this chapter, the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd06b214-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3401/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “financial institution”, except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s3414"},"text":"section 3414 of this title","children":[],"tail":", means any office of a bank, savings bank, card issuer as defined in section 1602(n) "},{"tag":"ref","attrib":{"idref":"fn002347"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002347"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 15, industrial loan company, trust company, savings association, building and loan, or homestead association (including cooperative banks), credit union, or consumer finance institution, located in any State or territory of the United States, the District of Columbia, Puerto Rico, Guam, American Samoa, or the Virgin Islands;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd06b215-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3401/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “financial record” means an original of, a copy of, or information known to have been derived from, any record held by a financial institution pertaining to a customer’s relationship with the financial institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd06b216-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3401/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Government authority” means any agency or department of the United States, or any officer, employee, or agent thereof;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd06b217-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3401/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “person” means an individual or a partnership of five or fewer individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd06b218-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3401/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “customer” means any person or authorized representative of that person who utilized or is utilizing any service of a financial institution, or for whom a financial institution is acting or has acted as a fiduciary, in relation to an account maintained in the person’s name;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd06b219-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3401/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “holding company” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd06b21a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3401/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any bank holding company (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1841"},"text":"section 1841 of this title","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd06b21b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3401/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any company described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1843/f/1"},"text":"section 1843(f)(1) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd06b21c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3401/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “supervisory agency” means with respect to any particular financial institution, holding company, or any subsidiary of a financial institution or holding company, any of the following which has statutory authority to examine the financial condition, business operations, or records or transactions of that institution, holding company, or subsidiary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd06b21d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3401/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Deposit Insurance Corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd06b21e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3401/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Bureau of Consumer Financial Protection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd06b21f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3401/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Credit Union Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd06b220-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3401/7/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Board of Governors of the Federal Reserve System;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd06b221-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3401/7/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Comptroller of the Currency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd06b222-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3401/7/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Securities and Exchange Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd06b223-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3401/7/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commodity Futures Trading Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd06b224-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3401/7/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Treasury, with respect to the Bank Secrecy Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/508/tI"},"text":"Public Law 91–508, title I","children":[],"tail":") ["},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1951"},"text":"12 U.S.C. 1951","children":[],"tail":" et seq.] and subchapter II of chapter 53 of title 31; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd06b225-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3401/7/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any State banking or securities department or agency; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd06b226-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3401/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “law enforcement inquiry” means a lawful investigation or official proceeding inquiring into a violation of, or failure to comply with, any criminal or civil statute or any regulation, rule, or order issued pursuant thereto.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd06b227-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/630/tXI/s1101"},"text":"Pub. L. 95–630, title XI, § 1101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3697"},"text":"92 Stat. 3697","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/73/tVII/s744/b"},"text":"Pub. L. 101–73, title VII, § 744(b)","children":[],"tail":", title IX, § 941, "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/438"},"text":"103 Stat. 438","children":[],"tail":", 496; "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXV/s2596/c"},"text":"Pub. L. 101–647, title XXV, § 2596(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4908"},"text":"104 Stat. 4908","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/102/tVII/s727/b/1"},"text":"Pub. L. 106–102, title VII, § 727(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1475"},"text":"113 Stat. 1475","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/177/tIII/s374/b"},"text":"Pub. L. 108–177, title III, § 374(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-13"},"text":"Dec. 13, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2628"},"text":"117 Stat. 2628","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1099/1"},"text":"Pub. L. 111–203, title X, § 1099(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2105"},"text":"124 Stat. 2105","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd06b228-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd06b229-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd06b22a-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1602/n"},"text":"Section 1602(n) of title 15","children":[],"tail":", referred to in par. (1), was redesignated section 1602("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":") of title 15 by "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1100A/1/A"},"text":"Pub. L. 111–203, title X, § 1100A(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2107"},"text":"124 Stat. 2107","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Bank Secrecy Act, referred to in par. (7)(H), is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/508"},"text":"Pub. L. 91–508","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-26"},"text":"Oct. 26, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1114"},"text":"84 Stat. 1114","children":[],"tail":", which is classified principally to chapter 21 (§ 1951 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1951"},"text":"section 1951 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd06b22b-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In par. (7)(H), “the Bank Secrecy Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/508/tI"},"text":"Public Law 91–508, title I","children":[],"tail":") ["},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1951"},"text":"12 U.S.C. 1951","children":[],"tail":" et seq.] and subchapter II of chapter 53 of title 31” substituted for “the Bank Secrecy Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1951"},"text":"12 U.S.C. 1951","children":[],"tail":" et seq.] and the Currency and Foreign Transactions Reporting Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1051"},"text":"31 U.S.C. 1051","children":[],"tail":" et seq.] ("},{"tag":"ref","attrib":{"href":"/us/pl/91/508/tI"},"text":"Public Law 91–508, title I","children":[],"tail":" and II)”, on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s4/b"},"text":"Pub. L. 97–258, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1067"},"text":"96 Stat. 1067","children":[],"tail":", the first section of which enacted Title 31, Money and Finance."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd06b22c-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Par. (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1099/1/A"},"text":"Pub. L. 111–203, § 1099(1)(A)","children":[],"tail":", inserted “and” at end of subpar. (A), struck out “and” at end of subpar. (B), and struck out subpar. (C) which read as follows: “any savings and loan holding company (as defined in the Home Owners’ Loan Act);”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (7)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1099/1/B"},"text":"Pub. L. 111–203, § 1099(1)(B)","children":[],"tail":", added subpar. (B) and struck out former subpar. (B) which read as follows: “Director, Office of Thrift Supervision;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/177"},"text":"Pub. L. 108–177","children":[],"tail":" inserted “, except as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s3414"},"text":"section 3414 of this title","children":[],"tail":",” before “means any office”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Par. (7)(G) to (I). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/102"},"text":"Pub. L. 106–102","children":[],"tail":" added subpar. (G) and redesignated former subpars. (G) and (H) as (H) and (I), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Par. (6)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647"},"text":"Pub. L. 101–647","children":[],"tail":" substituted “section 1843(f)(1)” for “section 1842(f)(1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/s744/b/1"},"text":"Pub. L. 101–73, § 744(b)(1)","children":[],"tail":", substituted “savings association” for “savings and loan”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/s941/3"},"text":"Pub. L. 101–73, § 941(3)","children":[],"tail":", added par. (6). Former par. (6) redesignated (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/s941/1"},"text":"Pub. L. 101–73, § 941(1)","children":[],"tail":", (2), redesignated former par. (6) as (7) and substituted new introductory provisions for former introductory provisions which read as follows: “ ‘supervisory agency’ means, with respect to any particular financial institution any of the following which has statutory authority to examine the financial condition or business operations of that institution—”. Former par. (7) redesignated (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/s744/b/2"},"text":"Pub. L. 101–73, § 744(b)(2)","children":[],"tail":", (3), redesignated subpars. (C) to (I) as (B) to (H), respectively, substituted “Director, Office of Thrift Supervision” for “the Federal Home Loan Bank Board” in subpar. (B), and struck out former subpar. (B) which read as follows: “the Federal Savings and Loan Insurance Corporation;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/s941/1"},"text":"Pub. L. 101–73, § 941(1)","children":[],"tail":", redesignated par. (7) as (8)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd06b22d-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd06b22e-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective on the designated transfer date, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1100H"},"text":"section 1100H of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd06b22f-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective upon the expiration of 120 days after ","children":[{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/630/s2101"},"text":"section 2101 of Pub. L. 95–630","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s375b"},"text":"section 375b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"iddd06b230-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/630/tXI/s1100"},"text":"Pub. L. 95–630, title XI, § 1100","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3697"},"text":"92 Stat. 3697","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/630/tXI/s1100"},"text":"“This title [enacting this chapter] may be cited as the ‘Right to Financial Privacy Act of 1978’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
