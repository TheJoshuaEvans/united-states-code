{"tag":"section","attrib":{"id":"iddce08b7e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2277a–10b"},"text":"§ 2277a–10b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to regulate golden parachute and indemnification payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddce08b7f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce08b80-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Golden parachute payment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “golden parachute payment”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddce08b81-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10b/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means a payment (or any agreement to make a payment) in the nature of compensation for the benefit of any institution-related party under an obligation of any Farm Credit System institution that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddce08b82-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10b/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is contingent on the termination of the party’s relationship with the institution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddce08b83-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10b/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is received on or after the date on which—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddce08b84-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10b/a/1/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the institution is insolvent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddce08b85-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10b/a/1/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a conservator or receiver is appointed for the institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddce08b86-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10b/a/1/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the institution has been assigned by the Farm Credit Administration a composite CAMEL rating of 4 or 5 under the Farm Credit Administration Rating System, or an equivalent rating; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddce08b87-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10b/a/1/A/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Corporation otherwise determines that the institution is in a troubled condition (as defined in regulations issued by the Corporation); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce08b88-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10b/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes a payment that would be a golden parachute payment but for the fact that the payment was made before the date referred to in subparagraph (A)(ii) if the payment was made in contemplation of the occurrence of an event described in any subclause of subparagraph (A); but","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce08b89-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10b/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" does not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddce08b8a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10b/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a payment made under a retirement plan that is qualified (or is intended to be qualified) under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s401"},"text":"section 401 of title 26","children":[],"tail":" or other nondiscriminatory benefit plan;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddce08b8b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10b/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a payment made under a bona fide supplemental executive retirement plan, deferred compensation plan, or other arrangement that the Corporation determines, by regulation or order, to be permissible; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddce08b8c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10b/a/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a payment made by reason of the death or disability of an institution-related party.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce08b8d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indemnification payment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “indemnification payment” means a payment (or any agreement to make a payment) by any Farm Credit System institution for the benefit of any person who is or was an institution-related party, to pay or reimburse the person for any liability or legal expense with regard to any administrative proceeding or civil action instituted by the Farm Credit Administration that results in a final order under which the person—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddce08b8e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10b/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is assessed a civil money penalty; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce08b8f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10b/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is removed or prohibited from participating in the conduct of the affairs of the institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce08b90-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institution-related party","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “institution-related party” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddce08b91-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10b/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a director, officer, employee, or agent for a Farm Credit System institution or any conservator or receiver of such an institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce08b92-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10b/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a stockholder (other than another Farm Credit System institution), consultant, joint venture partner, or any other person determined by the Farm Credit Administration to be a participant in the conduct of the affairs of a Farm Credit System institution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce08b93-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10b/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an independent contractor (including any attorney, appraiser, or accountant) that knowingly or recklessly participates in any violation of any law or regulation, any breach of fiduciary duty, or any unsafe or unsound practice that caused or is likely to cause more than a minimal financial loss to, or a significant adverse effect on, the Farm Credit System institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce08b94-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10b/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability or legal expense","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “liability or legal expense” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddce08b95-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10b/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a legal or other professional expense incurred in connection with any claim, proceeding, or action;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce08b96-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10b/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of, and any cost incurred in connection with, any settlement of any claim, proceeding, or action; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce08b97-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10b/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of, and any cost incurred in connection with, any judgment or penalty imposed with respect to any claim, proceeding, or action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce08b98-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10b/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “payment” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddce08b99-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10b/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a direct or indirect transfer of any funds or any asset; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce08b9a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10b/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any segregation of any funds or assets for the purpose of making, or under an agreement to make, any payment after the date on which the funds or assets are segregated, without regard to whether the obligation to make the payment is contingent on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddce08b9b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10b/a/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the determination, after that date, of the liability for the payment of the amount; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddce08b9c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10b/a/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the liquidation, after that date, of the amount of the payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce08b9d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation may prohibit or limit, by regulation or order, any golden parachute payment or indemnification payment by a Farm Credit System institution (including any conservator or receiver of the Federal Agricultural Mortgage Corporation) in troubled condition (as defined in regulations issued by the Corporation).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce08b9e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors to be taken into account","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Corporation shall prescribe, by regulation, the factors to be considered by the Corporation in taking any action under subsection (b). The factors may include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce08b9f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether there is a reasonable basis to believe that an institution-related party has committed any fraudulent act or omission, breach of trust or fiduciary duty, or insider abuse with regard to the Farm Credit System institution involved that has had a material effect on the financial condition of the institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce08ba0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether there is a reasonable basis to believe that the institution-related party is substantially responsible for the insolvency of the Farm Credit System institution, the appointment of a conservator or receiver for the institution, or the institution’s troubled condition (as defined in regulations prescribed by the Corporation);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce08ba1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10b/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether there is a reasonable basis to believe that the institution-related party has materially violated any applicable law or regulation that has had a material effect on the financial condition of the institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce08ba2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10b/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" whether there is a reasonable basis to believe that the institution-related party has violated or conspired to violate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddce08ba3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10b/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 215, 657, 1006, 1014, or 1344 of title 18; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce08ba4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10b/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 1341 or 1343 of title 18, affecting a Farm Credit System institution;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce08ba5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10b/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the institution-related party was in a position of managerial or fiduciary responsibility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce08ba6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10b/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the length of time that the party was related to the Farm Credit System institution and the degree to which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddce08ba7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10b/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the payment reasonably reflects compensation earned over the period of employment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce08ba8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10b/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the compensation represents a reasonable payment for services rendered.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce08ba9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain payments prohibited","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No Farm Credit System institution may prepay the salary or any liability or legal expense of any institution-related party if the payment is made—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce08baa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in contemplation of the insolvency of the institution or after the commission of an act of insolvency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce08bab-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with a view to, or with the result of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddce08bac-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10b/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preventing the proper application of the assets of the institution to creditors; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce08bad-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10b/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preferring 1 creditor over another creditor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce08bae-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce08baf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prohibits any Farm Credit System institution from purchasing any commercial insurance policy or fidelity bond, so long as the insurance policy or bond does not cover any legal or liability expense of an institution described in subsection (a)(2); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce08bb0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limits the powers, functions, or responsibilities of the Farm Credit Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddce08bb1-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tV/s5"},"text":"Pub. L. 92–181, title V, § 5","children":[],"tail":".61B, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/105/tII/s218"},"text":"Pub. L. 104–105, title II, § 218","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/181"},"text":"110 Stat. 181","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
