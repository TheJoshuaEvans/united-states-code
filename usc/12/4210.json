{"tag":"section","attrib":{"id":"iddd1e7f16-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4210"},"text":null,"children":[{"tag":"num","attrib":{"value":"4210"},"text":"§ 4210.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sources of payments to declarants","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other law, an award under this chapter ","children":[{"tag":"ref","attrib":{"idref":"fn002386"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002386"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" may be paid to a declarant, or to an individual providing information, from the amounts recovered through civil actions based in whole or in part on the information provided in a valid declaration under this chapter."},{"tag":"ref","attrib":{"idref":"fn002386"},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd1e7f17-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXV/s2570"},"text":"Pub. L. 101–647, title XXV, § 2570","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4899"},"text":"104 Stat. 4899","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd1e7f18-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd1e7f19-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd1e7f1a-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this title”, and was translated as reading “this subtitle”, meaning subtitle H of title XXV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647"},"text":"Pub. L. 101–647","children":[],"tail":", known as the Financial Institutions Anti-Fraud Enforcement Act of 1990, which is classified principally to this chapter, as the probable intent of Congress. For complete classification of subtitle H to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4201"},"text":"section 4201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
