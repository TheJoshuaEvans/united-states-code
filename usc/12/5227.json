{"tag":"section","attrib":{"id":"iddd4e41c8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5227"},"text":null,"children":[{"tag":"num","attrib":{"value":"5227"},"text":"§ 5227.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study and report on margin authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd4e41c9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5227/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Comptroller General shall undertake a study to determine the extent to which leverage and sudden deleveraging of financial institutions was a factor behind the current financial crisis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd4e41ca-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5227/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The study required by this section shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd4e41cb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5227/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of the roles and responsibilities of the Board, the Securities and Exchange Commission, the Secretary, and other Federal banking agencies with respect to monitoring leverage and acting to curtail excessive leveraging;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4e41cc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5227/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of the authority of the Board to regulate leverage, including by setting margin requirements, and what process the Board used to decide whether or not to use its authority;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4e41cd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5227/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of any usage of the margin authority by the Board; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4e41ce-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5227/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for the Board and appropriate committees of Congress with respect to the existing authority of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd4e41cf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5227/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2009-06-01"},"text":"June 1, 2009","children":[],"tail":", the Comptroller General shall complete and submit a report on the study required by this section to the Committee on Banking, Housing, and Urban Affairs of the Senate and the Committee on Financial Services of the House of Representatives."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd4e41d0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5227/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sharing of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any reports required under this section shall also be submitted to the Congressional Oversight Panel established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5233"},"text":"section 5233 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd4e41d1-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/343/dA/tI/s117"},"text":"Pub. L. 110–343, div. A, title I, § 117","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3786"},"text":"122 Stat. 3786","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
