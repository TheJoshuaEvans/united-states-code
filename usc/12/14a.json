{"tag":"section","attrib":{"id":"iddafed325-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s14a"},"text":null,"children":[{"tag":"num","attrib":{"value":"14a"},"text":"§ 14a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data standards; open data publication","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddafed326-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s14a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data standards","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddafed327-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s14a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Comptroller of the Currency shall, by rule, adopt data standards for all collections of information that are regularly filed with or submitted to the Comptroller of the Currency by any entity with respect to which the Office of the Comptroller of the Currency is the appropriate Federal banking agency (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"section 1813 of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddafed328-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s14a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consistency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The data standards required under paragraph (1) shall incorporate, and ensure compatibility with (to the extent feasible), all applicable data standards established in the rules promulgated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5334"},"text":"section 5334 of this title","children":[],"tail":", including, to the extent practicable, by having the characteristics described in clauses (i) through (vi) of subsection (c)(1)(B) of such section 5334."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddafed329-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s14a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Open data publication","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"All public data assets published by the Comptroller of the Currency under title LXII or the Dodd-Frank Wall Street Reform and Consumer Protection Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Public Law 111–203","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/124/1376"},"text":"124 Stat. 1376","children":[],"tail":") shall be—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddafed32a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s14a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made available as an open Government data asset (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s3502"},"text":"section 3502 of title 44","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddafed32b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s14a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" freely available for download;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddafed32c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s14a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rendered in a human-readable format; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddafed32d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s14a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accessible via application programming interface where appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddafed32e-3a6f-11f1-8fa0-c065796a7f06"},"text":"(R.S. § 333, as added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLVIII/s5841"},"text":"Pub. L. 117–263, div. E, title LVIII, § 5841","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3431"},"text":"136 Stat. 3431","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddafed32f-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddafed330-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddafed331-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Title LXII, referred to in subsec. (b), probably means title LXII of the Revised Statutes, consisting of R.S. §§ 5133 to 5244, which are classified to sections 16, 21, 22 to 24a, 25a, 25b, 26, 27, 29, 35 to 37, 39, 43, 52, 53, 55 to 57, 59 to 62, 66, 71, 72 to 76, 81, 83 to 86, 90, 91, 93, 93a, 94, 141 to 144, 161, 164, 181, 182, 192 to 194, 196, 215c, 481 to 485, 501, 541, 548, and 582 of this title. See, also, sections 8, 333, 334, 475, 656, 709, 1004, and 1005 of Title 18, Crimes and Criminal Procedure. For complete classification of R.S. §§ 5133 to 5244 to the Code, see Tables.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Dodd-Frank Wall Street Reform and Consumer Protection Act, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1376"},"text":"124 Stat. 1376","children":[],"tail":", which enacted chapter 53 (§ 5301 et seq.) of this title and chapters 108 (§ 8201 et seq.) and 109 (§ 8301 et seq.) of Title 15, Commerce and Trade, and enacted, amended, and repealed numerous other sections and notes in the Code. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddb014432-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another R.S. § 333 is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s14"},"text":"section 14 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddb014433-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddb014434-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rulemaking","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLVIII/s5842"},"text":"Pub. L. 117–263, div. E, title LVIII, § 5842","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3432"},"text":"136 Stat. 3432","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dE/tLVIII/s5842"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Comptroller of the Currency shall issue rules to carry out the amendments made by section 5841 [enacting this section], which shall take effect not later than 2 years after the date on which final rules are promulgated under section 124(b)(2) of the Financial Stability Act of 2010 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5334/b/2"},"text":"12 U.S.C. 5334(b)(2)","children":[],"tail":"], as added by "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5811/a"},"text":"section 5811(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Scaling of Regulatory Requirements; Minimizing Disruption","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In issuing the rules required under subsection (a), the Comptroller of the Currency—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may scale data reporting requirements in order to reduce any unjustified burden on smaller regulated entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall seek to minimize disruptive changes to the persons affected by those regulations.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddb014435-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rule of Construction Regarding No New Disclosure Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLVIII/s5843"},"text":"Pub. L. 117–263, div. E, title LVIII, § 5843","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3432"},"text":"136 Stat. 3432","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dE/tLVIII/s5843"},"text":"“Nothing in this subtitle [subtitle D (§§ 5841–5843) of title LVIII of div. E of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":", enacting this section and provisions set out as a note under this section], or the amendments made by this subtitle, shall be construed to require the Comptroller of the Currency to collect or make publicly available additional information under the Revised Statutes of the United States (or under any other provision of law referenced in an amendment made by this subtitle), beyond information that was collected or made publicly available under any such provision of law, as of the day before the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
