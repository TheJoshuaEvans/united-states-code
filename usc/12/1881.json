{"tag":"section","attrib":{"id":"iddcb7f4a9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1881"},"text":null,"children":[{"tag":"num","attrib":{"value":"1881"},"text":"§ 1881.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Federal supervisory agency” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"As used in this chapter the term “Federal supervisory agency” means the appropriate Federal banking agency, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813/q"},"text":"section 1813(q) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddcb7f4aa-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/389/s2"},"text":"Pub. L. 90–389, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-07-07"},"text":"July 7, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/294"},"text":"82 Stat. 294","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/73/tVII/s744/h"},"text":"Pub. L. 101–73, title VII, § 744(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/439"},"text":"103 Stat. 439","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/386/s8/d"},"text":"Pub. L. 108–386, § 8(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2232"},"text":"118 Stat. 2232","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tIII/s356/1"},"text":"Pub. L. 111–203, title III, § 356(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1547"},"text":"124 Stat. 1547","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcb7f4ab-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcb7f4ac-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcb7f4ad-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" substituted “the term ‘Federal supervisory agency’ means the appropriate Federal banking agency, as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813/q"},"text":"section 1813(q) of this title","children":[],"tail":".” for “the term ‘Federal supervisory agency’ means—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) The Comptroller of the Currency with respect to national banks,","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) The Board of Governors of the Federal Reserve System with respect to Federal Reserve banks and State banks which are members of the Federal Reserve System,","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) The Federal Deposit Insurance Corporation with respect to State banks which are not members of the Federal Reserve System but the deposits of which are insured by the Federal Deposit Insurance Corporation and State savings associations, and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) The Director of the Office of Thrift Supervision with respect to Federal savings.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/386"},"text":"Pub. L. 108–386","children":[],"tail":" struck out “and district banks” after “national banks”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/s744/h/2"},"text":"Pub. L. 101–73, § 744(h)(2)","children":[],"tail":", inserted reference to State savings associations."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/s744/h/1"},"text":"Pub. L. 101–73, § 744(h)(1)","children":[],"tail":", substituted “Director of the Office of Thrift Supervision” for “Federal Home Loan Bank Board”, struck out “and loan” after “Federal savings”, and struck out “associations, and institutions the accounts of which are insured by the Federal Savings and Loan Insurance Corporation” before period at end."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcb7f4ae-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcb7f4af-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective on the transfer date, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s351"},"text":"section 351 of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s906"},"text":"section 906 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcb7f4b0-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/386"},"text":"Pub. L. 108–386","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", and, except as otherwise provided, applicable with respect to fiscal year 2005 and each succeeding fiscal year, see sections 8(i) and 9 of "},{"tag":"ref","attrib":{"href":"/us/pl/108/386"},"text":"Pub. L. 108–386","children":[],"tail":", set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s321"},"text":"section 321 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"iddcb7f4b1-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/90/389/s1"},"text":"Pub. L. 90–389, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-07-07"},"text":"July 7, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/294"},"text":"82 Stat. 294","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/90/389/s1"},"text":"“That this Act [enacting this chapter and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1729"},"text":"section 1729 of this title","children":[],"tail":"] may be cited as the ‘Bank Protection Act of 1968’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
