3"},"text":"May 19, 1956, ch. 313","children":[],"tail":", Ch. V, "},{"tag":"ref","attrib":{"href":"/us/stat/70/166"},"text":"70 Stat. 166","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1955-06-30/ch244"},"text":"June 30, 1955, ch. 244","children":[],"tail":", title II, "},{"tag":"ref","attrib":{"href":"/us/stat/69/213"},"text":"69 Stat. 213","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddba10665-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"iddba10666-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of Housing and Home Finance Agency and Administrator thereof transferred to Secretary of Housing and Urban Development by section 5(a) of Department of Housing and Urban Development Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/174"},"text":"Pub. L. 89–174","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-09-09"},"text":"Sept. 9, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/669"},"text":"79 Stat. 669","children":[],"tail":") which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3534/a"},"text":"section 3534(a) of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
