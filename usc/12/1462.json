{"tag":"section","attrib":{"id":"iddb86c787-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1462"},"text":null,"children":[{"tag":"num","attrib":{"value":"1462"},"text":"§ 1462.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb86c788-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1462/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Corporation” means the Federal Deposit Insurance Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb86c789-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1462/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings association","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “savings association” means a savings association, as defined in section 3 of the Federal Deposit Insurance Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"12 U.S.C. 1813","children":[],"tail":"], the deposits of which are insured by the Corporation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb86c78a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1462/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal savings association","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Federal savings association” means a Federal savings association or a Federal savings bank chartered under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1464"},"text":"section 1464 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb86c78b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1462/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National bank","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “national bank” has the same meaning as in section 3 of the Federal Deposit Insurance Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"12 U.S.C. 1813","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb86c78c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1462/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal banking agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Federal banking agencies” means the Office of the Comptroller of the Currency, the Board of Governors of the Federal Reserve System, and the Federal Deposit Insurance Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb86c78d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1462/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” has the same meaning as in section 3 of the Federal Deposit Insurance Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"12 U.S.C. 1813","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb86c78e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1462/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Affiliate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “affiliate” means any person that controls, is controlled by, or is under common control with, a savings association, except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1467a"},"text":"section 1467a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb86c78f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1462/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Board”, other than in the context of the Board of Directors of the Corporation, means the Board of Governors of the Federal Reserve System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb86c790-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1462/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comptroller","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Comptroller” means the Comptroller of the Currency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb86c791-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1462/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate Federal banking agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “appropriate Federal banking agency” has the same meaning as in section 3(q) of the Federal Deposit Insurance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813/q"},"text":"12 U.S.C. 1813(q)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb86c792-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1462/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functionally regulated subsidiary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “functionally regulated subsidiary” has the same meaning as in section 5(c)(5) of the Bank Holding Company Act of 1956 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1844/c/5"},"text":"12 U.S.C. 1844(c)(5)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddb86c793-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-06-13/ch64/s2"},"text":"June 13, 1933, ch. 64, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/128"},"text":"48 Stat. 128","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1934-06-27/ch847"},"text":"June 27, 1934, ch. 847","children":[],"tail":", title V, § 508(a), "},{"tag":"ref","attrib":{"href":"/us/stat/48/1264"},"text":"48 Stat. 1264","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1935-05-28/ch150/s10"},"text":"May 28, 1935, ch. 150, § 10","children":[],"tail":", "},{"tag":"ref","attri