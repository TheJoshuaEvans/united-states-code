":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb86c795-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddb86c796-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Pars. (1) to (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s369/2"},"text":"Pub. L. 111–203, § 369(2)","children":[],"tail":", redesignated pars. (2) and (4) to (9) as (1) and (2) to (7), respectively, added pars. (8) and (9), and struck out former pars. (1) and (3) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) ","children":[{"tag":"inline","attrib":{},"text":"Director","children":[],"tail":".—The term ‘Director’ means the Director of the Office of Thrift Supervision."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) ","children":[{"tag":"inline","attrib":{},"text":"Office","children":[],"tail":".—The term ‘Office’ means the Office of Thrift Supervision.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (10), (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s604/h/1"},"text":"Pub. L. 111–203, § 604(h)(1)","children":[],"tail":", added pars. (10) and (11)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73"},"text":"Pub. L. 101–73","children":[],"tail":" amended section generally, substituting definition of “Director”, “Corporation”, “Office”, “savings association”, “Federal savings association”, “national bank”, “Federal banking agencies”, “State”, and “affiliate”, designated as pars. (1) to (9), for definition of “Board”, “Corporation”, “home mortgage”, “first mortgage”, and “association”, designated as subsecs. (a) to (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/320"},"text":"Pub. L. 97–320","children":[],"tail":" substituted reference to Federal savings bank or Federal savings banks for reference to Federal mutual savings bank wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/630"},"text":"Pub. L. 95–630","children":[],"tail":" included a Federal mutual savings bank chartered by the Board within definition of “association”, and inserted provisions that a reference to a Federal savings and loan association shall be deemed also a reference to a Federal mutual savings bank."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1935—Subsec. (c). Act ","children":[{"tag":"date","attrib":{"date":"1935-05-28"},"text":"May 28, 1935","children":[],"tail":", inserted “or dwellings” and “in whole or in part” in cl. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1934—Subsec. (c). Act ","children":[{"tag":"date","attrib":{"date":"1934-06-27"},"text":"June 27, 1934","children":[],"tail":", substituted “(1) under a lease for not less than ninety-nine years which is renewable, or (2) under a lease having a period of not less than fifty years to run from the date the mortgage was executed” for “under a lease renewable for not less than ninety nine years”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddb86c797-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"iddb86c798-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Home Loan Bank Board” changed to “Federal Home Loan Bank Board” by ","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-08-11/ch783/s109/a/3"},"text":"act Aug. 11, 1955, ch. 783, § 109(a)(3)","children":[],"tail":", which was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1437/b"},"text":"section 1437(b) of this title","children":[],"tail":" prior to the repeal of section 1437 by "},{"tag":"ref","attrib":{"href":"/us/pl/101/73/tVII/s703/a"},"text":"Pub. L. 101–73, title VII, § 703(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/415"},"text":"103 Stat. 415","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddb86c799-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s369/2"},"text":"section 369(2) of Pub. L. 111–203","children":[],"tail":" effective on the transfer date, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s351"},"text":"section 351 of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s906"},"text":"section 906 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tVI/s604/j"},"text":"Pub. L. 111–203, title VI, § 604(j)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1604"},"text":"124 Stat. 1604","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/203/tVI/s604/j"},"text":"“The amendments made by this section [amending thi