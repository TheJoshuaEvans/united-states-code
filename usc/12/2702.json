{"tag":"section","attrib":{"id":"iddcf39ec8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2702"},"text":null,"children":[{"tag":"num","attrib":{"value":"2702"},"text":"§ 2702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mortgages eligible for assistance","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"No assistance shall be extended with respect to any mortgage under this chapter unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcf39ec9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2702/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the holder of the mortgage has indicated to the mortgagor its intention to foreclose;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf39eca-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2702/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the mortgagor and holder of the mortgage have certified that circumstances make it probable that there will be a foreclosure and that the mortgagor is in need of emergency mortgage relief as authorized by this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf39ecb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2702/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payments under the mortgage have been delinquent for at least three months;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf39ecc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2702/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the mortgagor has incurred a substantial reduction in income as a result of involuntary unemployment or underemployment due to adverse economic conditions or medical conditions and is financially unable to make full mortgage payments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf39ecd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2702/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a reasonable prospect that the mortgagor will be able to make the adjustments necessary for a full resumption of mortgage payments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf39ece-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2702/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the mortgaged property is the principal residence of the mortgagor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcf39ecf-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/50/tI/s103"},"text":"Pub. L. 94–50, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-07-02"},"text":"July 2, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/249"},"text":"89 Stat. 249","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tXIV/s1496/b/1"},"text":"Pub. L. 111–203, title XIV, § 1496(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2207"},"text":"124 Stat. 2207","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcf39ed0-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcf39ed1-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcf39ed2-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1496/b/1/A"},"text":"Pub. L. 111–203, § 1496(b)(1)(A)","children":[],"tail":", substituted “have certified” for “have indicated in writing to the Secretary of Housing and Urban Development (hereinafter referred to as the ‘Secretary’) and to any agency or department of the Federal Government responsible for the regulation of the holder” and struck out “(such as the volume of delinquent loans in its portfolio)” after “circumstances” and “, except that such statement by the holder of the mortgage may be waived by the Secretary if in his judgment such waiver would further the purposes of this chapter” after “by this chapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1496/b/1/B"},"text":"Pub. L. 111–203, § 1496(b)(1)(B)","children":[],"tail":", inserted “or medical conditions” after “adverse economic conditions”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcf39ed3-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcf39ed4-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective on the date on which final regulations implementing that amendment take effect, or on the date that is 18 months after the designated transfer date if such regulations have not been issued by that date, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1400/c"},"text":"section 1400(c) of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1601"},"text":"section 1601 of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
