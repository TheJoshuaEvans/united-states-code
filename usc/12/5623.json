{"tag":"section","attrib":{"id":"iddd7b93a4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5623"},"text":null,"children":[{"tag":"num","attrib":{"value":"5623"},"text":"§ 5623.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expanded access to mainstream financial institutions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd7b93a5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5623/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary is authorized to establish a multiyear program of grants, cooperative agreements, financial agency agreements, and similar contracts or undertakings to promote initiatives designed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd7b93a6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5623/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enable low- and moderate-income individuals to establish one or more accounts in a federally insured depository institution that are appropriate to meet the financial needs of such individuals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7b93a7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5623/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve access to the provision of accounts, on reasonable terms, for low- and moderate-income individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd7b93a8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5623/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program eligibility and activities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd7b93a9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5623/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall restrict participation in any program established under subsection (a) to an eligible entity. Subject to regulations prescribed by the Secretary under this subchapter, 1 or more eligible entities may participate in 1 or several programs established under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7b93aa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5623/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Account activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to regulations prescribed by the Secretary, an eligible entity may, in participating in a program established under subsection (a), offer or provide to low- and moderate-income individuals products and services relating to accounts, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd7b93ab-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5623/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" small-dollar value loans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7b93ac-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5623/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" financial education and counseling relating to conducting transactions in and managing accounts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd7b93ad-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tXII/s1204"},"text":"Pub. L. 111–203, title XII, § 1204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2130"},"text":"124 Stat. 2130","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd7b93ae-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd7b93af-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd7b93b0-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in subsec. (b)(1), was in the original “this title”, meaning title XII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2129"},"text":"124 Stat. 2129","children":[],"tail":", known as the Improving Access to Mainstream Financial Institutions Act of 2010, which is classified principally to this subchapter. For complete classification of title XII to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
