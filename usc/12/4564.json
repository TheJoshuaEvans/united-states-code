{"tag":"section","attrib":{"id":"iddd2a8ce2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4564"},"text":null,"children":[{"tag":"num","attrib":{"value":"4564"},"text":"§ 4564.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discretionary adjustment of housing goals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd2a8ce3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4564/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An enterprise may petition the Director in writing at any time during a year to reduce the level of any goal or subgoal for such year established pursuant to this subpart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2a8ce4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4564/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standard for reduction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director may reduce the level for a goal or subgoal pursuant to such a petition only if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2a8ce5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4564/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" market and economic conditions or the financial condition of the enterprise require such action; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2a8ce6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4564/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" efforts to meet the goal or subgoal would result in the constraint of liquidity, over-investment in certain market segments, or other consequences contrary to the intent of this subpart, or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1716/3"},"text":"section 1716(3) of this title","children":[],"tail":" or section 301(b)(3) of the Federal Home Loan Mortgage Corporation Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1451"},"text":"12 U.S.C. 1451","children":[],"tail":" note), as applicable."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2a8ce7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4564/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall, promptly upon receipt of a petition regarding a reduction, seek public comment on the reduction for a period of 30 days. The Director shall make a determination regarding any proposed reduction within 30 days after the expiration of such public comment period. The Director may extend such determination period for a single additional 15-day period, but only if the Director requests additional information from the enterprise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd2a8ce8-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXIII/s1334"},"text":"Pub. L. 102–550, title XIII, § 1334","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tI/s1128/b"},"text":"Pub. L. 110–289, div. A, title I, § 1128(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2701"},"text":"122 Stat. 2701","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd2a8ce9-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd2a8cea-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd2a8ceb-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 301(b)(3) of the Federal Home Loan Mortgage Corporation Act, referred to in subsec. (b)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/351/s301/b/3"},"text":"section 301(b)(3) of Pub. L. 91–351","children":[],"tail":", which is set out as a Short Title and Statement of Purpose note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1451"},"text":"section 1451 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"iddd2a8cec-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 4564, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXIII/s1334"},"text":"Pub. L. 102–550, title XIII, § 1334","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3960"},"text":"106 Stat. 3960","children":[],"tail":", related to central cities, rural areas, and other underserved areas housing goal, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tI/s1128/a"},"text":"Pub. L. 110–289, div. A, title I, § 1128(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2696"},"text":"122 Stat. 2696","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
