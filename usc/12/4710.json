{"tag":"section","attrib":{"id":"iddd3b2ee2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4710"},"text":null,"children":[{"tag":"num","attrib":{"value":"4710"},"text":"§ 4710.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection and compilation of information","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Fund shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd3b2ee3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4710/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect and compile information pertinent to community development financial institutions that will assist in creating, developing, expanding, and preserving such institutions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3b2ee4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4710/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make such information available to promote the purposes of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd3b2ee5-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/tI/s111"},"text":"Pub. L. 103–325, title I, § 111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2177"},"text":"108 Stat. 2177","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
