{"tag":"section","attrib":{"id":"iddd3b2eeb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4712"},"text":null,"children":[{"tag":"num","attrib":{"value":"4712"},"text":"§ 4712.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capitalization assistance to enhance liquidity","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd3b2eec-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4712/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd3b2eed-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4712/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Fund may provide assistance for the purpose of providing capital to organizations to purchase loans or otherwise enhance the liquidity of community development financial institutions, if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd3b2eee-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4712/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the primary purpose of such organizations is to promote community development; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3b2eef-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4712/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any assistance received is matched with funds—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd3b2ef0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4712/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from sources other than the Federal Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd3b2ef1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4712/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the basis of not less than one dollar for each dollar provided by the Fund; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd3b2ef2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4712/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that are comparable in form and value to the assistance provided by the Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3b2ef3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4712/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on other assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An organization that receives assistance under this section may not receive other financial or technical assistance under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3b2ef4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4712/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction of Federal Government funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, notwithstanding section 105(a)(9) of the Housing and Community Development Act of 1974 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5305/a/9"},"text":"42 U.S.C. 5305(a)(9)","children":[],"tail":"], funds provided pursuant to such Act shall be considered to be Federal Government funds."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3b2ef5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4712/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The selection of organizations to receive assistance under this section shall be at the discretion of the Fund and in accordance with criteria established by the Fund. In establishing such criteria, the Fund shall take into account the criteria contained in sections 4704(b) and 4706 of this title, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3b2ef6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4712/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Fund may provide a total of not more than $5,000,000 of assistance to an organization or its subsidiaries or affiliates under this section during any 3-year period. Assistance may be provided in a lump sum or over a period of time, as determined by the Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3b2ef7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4712/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audit and report requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Organizations that receive assistance from the Fund in accordance with this section shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd3b2ef8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4712/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Fund, not less than once in every 18-month period, financial statements audited by an independent certified public accountant, as part of the report required by paragraph (2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3b2ef9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4712/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit an annual report on its activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3b2efa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4712/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" keep such records as may be necessary to disclose the manner in which any assistance under this section is used.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3b2efb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4712/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on liability","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd3b2efc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4712/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability of Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The liability of the Fund and the United States Government arising out of the provision of assistance to any organization in accordance with this section shall be limited to the amount of such assistance. The Fund shall be exempt from any assessments and any other liabilities that may be imposed on controlling or principal shareholders by any Federal law or the law of any State, or territory. Nothing in this paragraph shall affect the application of Federal tax law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3b2efd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4712/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability of Government","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section does not oblige the Federal Government, either directly or indirectly, to provide any funds to any organization assisted pursuant to this section, or to honor, reimburse, or otherwise guarantee any obligation or liability of such an organization. This section shall not be construed to imply that any such organization or any obligations or securities of any such organization are backed by the full faith and credit of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3b2efe-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4712/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of proceeds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any proceeds from the sale of loans by an organization assisted under this section shall be used by the seller for community development purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd3b2eff-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/tI/s113"},"text":"Pub. L. 103–325, title I, § 113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2178"},"text":"108 Stat. 2178","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd3b2f00-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd3b2f01-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd3b2f02-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Housing and Community Development Act of 1974, referred to in subsec. (a)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/383"},"text":"Pub. L. 93–383","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-22"},"text":"Aug. 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/633"},"text":"88 Stat. 633","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5301"},"text":"section 5301 of Title 42","children":[],"tail":", The Public Health and Welfare, and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
