{"tag":"section","attrib":{"id":"iddd63c5f0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5393"},"text":null,"children":[{"tag":"num","attrib":{"value":"5393"},"text":"§ 5393.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ban on certain activities by senior executives and directors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd63c5f1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5393/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board of Governors or, if the covered financial company was not supervised by the Board of Governors, the Corporation, may exercise the authority provided by this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd63c5f2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5393/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to issue order","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The appropriate agency described in subsection (a) may take any action authorized by subsection (c), if the agency determines that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd63c5f3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5393/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a senior executive or a director of the covered financial company, prior to the appointment of the Corporation as receiver, has, directly or indirectly—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd63c5f4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5393/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" violated—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd63c5f5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5393/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any law or regulation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd63c5f6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5393/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any cease-and-desist order which has become final;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd63c5f7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5393/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any condition imposed in writing by a Federal agency in connection with any action on any application, notice, or request by such company or senior executive; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd63c5f8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5393/b/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any written agreement between such company and such agency;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd63c5f9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5393/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engaged or participated in any unsafe or unsound practice in connection with any financial company; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd63c5fa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5393/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" committed or engaged in any act, omission, or practice which constitutes a breach of the fiduciary duty of such senior executive or director;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd63c5fb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5393/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by reason of the violation, practice, or breach described in any subparagraph of paragraph (1), such senior executive or director has received financial gain or other benefit by reason of such violation, practice, or breach and such violation, practice, or breach contributed to the failure of the company; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd63c5fc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5393/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such violation, practice, or breach—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd63c5fd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5393/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involves personal dishonesty on the part of such senior executive or director; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd63c5fe-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5393/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrates willful or continuing disregard by such senior executive or director for the safety or soundness of such company.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd63c5ff-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5393/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized actions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd63c600-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5393/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The appropriate agency for a financial company, as described in subsection (a), may serve upon a senior executive or director described in subsection (b) a written notice of the intention of the agency to prohibit any further participation by such person, in any manner, in the conduct of the affairs of any financial company for a period of time determined by the appropriate agency to be commensurate with such violation, practice, or breach, provided such period shall be not less than 2 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd63c601-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5393/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The due process requirements and other procedures under section 8(e) of the Federal Deposit Insurance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1818/e"},"text":"12 U.S.C. 1818(e)","children":[],"tail":") shall apply to actions under this section as if the covered financial company were an insured depository institution and the senior executive or director were an institution-affiliated party, as those terms are defined in that Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1811"},"text":"12 U.S.C. 1811","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd63c602-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5393/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation and the Board of Governors, in consultation with the Council, shall jointly prescribe rules or regulations to administer and carry out this section, including rules, regulations, or guidelines to further define the term senior executive for the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd63c603-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tII/s213"},"text":"Pub. L. 111–203, title II, § 213","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1517"},"text":"124 Stat. 1517","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd63c604-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd63c605-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd63c606-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Deposit Insurance Act, referred to in subsec. (c)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-21/ch967/s2"},"text":"act Sept. 21, 1950, ch. 967, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/873"},"text":"64 Stat. 873","children":[],"tail":", which is classified generally to chapter 16 (§ 1811 et seq.) of this title. The terms “insured depository institution” and “institution-affiliated party” are defined in section 3 of the Act, which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"section 1813 of this title","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1811"},"text":"section 1811 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd63c607-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd63c608-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 1 day after ","children":[{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s4"},"text":"section 4 of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"section 5301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
