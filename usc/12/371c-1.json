{"tag":"section","attrib":{"id":"iddb3ceced-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371c–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"371c–1"},"text":"§ 371c–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions on transactions with affiliates","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddb3cecee-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371c–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb3cecef-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371c–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A member bank and its subsidiaries may engage in any of the transactions described in paragraph (2) only—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddb3cecf0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371c–1/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on terms and under circumstances, including credit standards, that are substantially the same, or at least as favorable to such bank or its subsidiary, as those prevailing at the time for comparable transactions with or involving other nonaffiliated companies, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb3cecf1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371c–1/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the absence of comparable transactions, on terms and under circumstances, including credit standards, that in good faith would be offered to, or would apply to, nonaffiliated companies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb3cecf2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371c–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transactions covered","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) applies to the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddb3cecf3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371c–1/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any covered transaction with an affiliate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb3cecf4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371c–1/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The sale of securities or other assets to an affiliate, including assets subject to an agreement to repurchase.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb3cecf5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371c–1/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The payment of money or the furnishing of services to an affiliate under contract, lease, or otherwise.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb3cecf6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371c–1/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any transaction in which an affiliate acts as an agent or broker or receives a fee for its services to the bank or to any other person.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb3cecf7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371c–1/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any transaction or series of transactions with a third party—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddb3cecf8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371c–1/a/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if an affiliate has a financial interest in the third party, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddb3cecf9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371c–1/a/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if an affiliate is a participant in such transaction or series of transactions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb3cecfa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371c–1/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transactions that benefit affiliate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of this subsection, any transaction by a member bank or its subsidiary with any person shall be deemed to be a transaction with an affiliate of such bank if any of the proceeds of the transaction are used for the benefit of, or transferred to, such affiliate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb3cecfb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371c–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited transactions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb3cecfc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371c–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A member bank or its subsidiary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddb3cecfd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371c–1/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall not purchase as fiduciary any securities or other assets from any affiliate unless such purchase is permitted—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddb3cecfe-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371c–1/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under the instrument creating the fiduciary relationship,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddb3cecff-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371c–1/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by court order, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddb3ced00-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371c–1/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by law of the jurisdiction governing the fiduciary relationship; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb3ced01-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371c–1/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether acting as principal or fiduciary, shall not knowingly purchase or otherwise acquire, during the existence of any underwriting or selling syndicate, any security if a principal underwriter of that security is an affiliate of such bank.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb3ced02-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371c–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subparagraph (B) of paragraph (1) shall not apply if the purchase or acquisition of such securities has been approved, before such securities are initially offered for sale to the public, by a majority of the directors of the bank based on a determination that the purchase is a sound investment for the bank irrespective of the fact that an affiliate of the bank is a principal underwriter of the securities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb3ced03-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371c–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddb3ced04-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371c–1/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “security” has the meaning given to such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78c/a/10"},"text":"section 78c(a)(10) of title 15","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb3ced05-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371c–1/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “principal underwriter” means any underwriter who, in connection with a primary distribution of securities—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddb3ced06-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371c–1/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in privity of contract with the issuer or an affiliated person of the issuer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddb3ced07-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371c–1/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acting alone or in concert with one or more other persons, initiates or directs the formation of an underwriting syndicate; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddb3ced08-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371c–1/b/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is allowed a rate of gross commission, spread, or other profit greater than the rate allowed another underwriter participating in the distribution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb3ced09-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371c–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advertising restriction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member bank or any subsidiary or affiliate of a member bank shall not publish any advertisement or enter into any agreement stating or suggesting that the bank shall in any way be responsible for the obligations of its affiliates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb3ced0a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371c–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb3ced0b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371c–1/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “affiliate” has the meaning given to such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s371c"},"text":"section 371c of this title","children":[],"tail":" (but does not include any company described in section "},{"tag":"ref","attrib":{"idref":"fn002043"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002043"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “subsection”."}],"tail":" (b)(2) of such section or any bank);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb3ced0c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371c–1/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms “bank”, “subsidiary”, “person”, and “security” (other than security as used in subsection (b)) have the meanings given to such terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s371c"},"text":"section 371c of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb3ced0d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371c–1/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “covered transaction” has the meaning given to such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s371c"},"text":"section 371c of this title","children":[],"tail":" (but does not include any transaction which is exempt from such definition under subsection (d) of such section)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb3ced0e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371c–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb3ced0f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371c–1/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board may prescribe regulations to administer and carry out the purposes of this section, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddb3ced10-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371c–1/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regulations to further define terms used in this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb3ced11-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371c–1/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" subject to paragraph (2), if the Board finds that an exemption or exclusion is in the public interest and is consistent with the purposes of this section, and notifies the Federal Deposit Insurance Corporation of such finding, regulations to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddb3ced12-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371c–1/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exempt transactions or relationships from the requirements of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddb3ced13-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371c–1/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exclude any subsidiary of a bank holding company from the definition of affiliate for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb3ced14-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371c–1/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board may grant an exemption or exclusion under this subsection only if, during the 60-day period beginning on the date of receipt of notice of the finding from the Board under paragraph (1)(B), the Federal Deposit Insurance Corporation does not object, in writing, to such exemption or exclusion, based on a determination that the exemption presents an unacceptable risk to the Deposit Insurance Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddb3ced15-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1913-12-23/ch6/s23B"},"text":"Dec. 23, 1913, ch. 6, § 23B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/86/tI/s102/a"},"text":"Pub. L. 100–86, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-08-10"},"text":"Aug. 10, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/564"},"text":"101 Stat. 564","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/102/tVII/s738"},"text":"Pub. L. 106–102, title VII, § 738","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1480"},"text":"113 Stat. 1480","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tVI/s608/b"},"text":"Pub. L. 111–203, title VI, § 608(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1610"},"text":"124 Stat. 1610","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb3ced16-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb3ced17-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddb3ced18-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s608/b/1"},"text":"Pub. L. 111–203, § 608(b)(1)","children":[],"tail":"–(4), designated existing provisions as par. (1) and inserted heading, redesignated former pars. (1) and (2) as subpars. (A) and (B), respectively, of par. (1), redesignated former subpars. (A) and (B) of par. (2) as cls. (i) and (ii), respectively, of par. (1)(B), realigned margins, and struck out concluding provisions which read as follows: “if the Board finds such exemptions or exclusions are in the public interest and are consistent with the purposes of this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s608/b/5/A"},"text":"Pub. L. 111–203, § 608(b)(5)(A)","children":[],"tail":", inserted “subject to paragraph (2), if the Board finds that an exemption or exclusion is in the public interest and is consistent with the purposes of this section, and notifies the Federal Deposit Insurance Corporation of such finding,” before “regulations” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s608/b/5/B"},"text":"Pub. L. 111–203, § 608(b)(5)(B)","children":[],"tail":", substituted period for comma at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s608/b/6"},"text":"Pub. L. 111–203, § 608(b)(6)","children":[],"tail":", added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/102"},"text":"Pub. L. 106–102","children":[],"tail":" amended text of par. (2) generally. Prior to amendment, text read as follows: “Subparagraph (B) of paragraph (1) shall not apply if the purchase or acquisition of such securities has been approved, before such securities are initially offered for sale to the public, by a majority of the directors of the bank who are not officers or employees of the bank or any affiliate thereof.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddb3ced19-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddb3ced1a-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective 1 year after the transfer date, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s608/d"},"text":"section 608(d) of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s371c"},"text":"section 371c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
