{"tag":"section","attrib":{"id":"iddcea2829-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"2279aa–4"},"text":"§ 2279aa–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stock issuance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcea282a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voting common stock","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcea282b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–4/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issue","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcea282c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–4/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation shall issue voting common stock having such par value as may be fixed by the Board from time to time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcea282d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–4/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Number of votes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each share of voting common stock shall be entitled to one vote with rights of cumulative voting at all elections of directors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcea282e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–4/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offers","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddcea282f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–4/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall offer the voting common stock to banks, other financial institutions, insurance companies, and System institutions under such terms and conditions as the Board may adopt.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcea2830-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–4/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The voting common stock shall be fairly and broadly offered to ensure that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddcea2831-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–4/a/1/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no institution or institutions acquire a disproportionate share of the total quantity of the voting common stock outstanding of a class of stock; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddcea2832-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–4/a/1/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" capital contributions and issuances of voting common stock for the contributions are fairly distributed between entities eligible to hold class A stock and class B stock.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcea2833-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–4/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Classes of stock","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddcea2834-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–4/a/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The stock shall be divided into two classes with the same par value per share.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcea2835-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–4/a/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Class A stock","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Class A stock may be held only by entities that are not Farm Credit System institutions and that are entitled to vote for directors specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2279aa–2/a/2/A"},"text":"section 2279aa–2(a)(2)(A) of this title","children":[],"tail":", including national banking associations (which shall be allowed to purchase and hold such stock)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcea2836-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–4/a/1/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Class B stock","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Class B stock may be held only by Farm Credit System institutions that are entitled to vote for directors specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2279aa–2/a/2/B"},"text":"section 2279aa–2(a)(2)(B) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcea2837-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–4/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on issue","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After the date the permanent board first meets with a quorum of its members present, voting common stock of the Corporation may be issued only to originators and certified facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcea2838-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–4/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Board to establish terms and procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall adopt such terms, conditions, and procedures with regard to the issue of stock under this section as may be necessary, including the establishment of a maximum amount limitation on the number of shares of voting common stock that may be outstanding at any time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcea2839-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–4/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transferability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to such limitations as the Board may impose, any share of any class of voting common stock issued under this section shall be transferable among the institutions or entities to which shares of such class of common stock may be offered under paragraph (1), except that, as to the Corporation, such shares shall be transferable only on the books of the Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcea283a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–4/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum number of shares","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No stockholder, other than a holder of class B stock, may own, directly or indirectly, more than 33 percent of the outstanding shares of such class of the voting common stock of the Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcea283b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required capital contributions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcea283c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–4/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation may require each originator and each certified facility to make, or commit to make, such nonrefundable capital contributions to the Corporation as are reasonable and necessary to meet the administrative expenses of the Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcea283d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–4/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stock issued as consideration for contribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation, from time to time, shall issue to each originator or certified facility voting common stock evidencing any capital contributions made pursuant to this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcea283e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–4/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dividends","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcea283f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–4/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such dividends as may be declared by the Board, in the discretion of the Board, shall be paid by the Corporation to the holders of the voting common stock of the Corporation pro rata based on the total number of shares of both classes of stock outstanding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcea2840-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–4/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reserves requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No dividend may be declared or paid by the Board under this section unless the Board determines that adequate provision has been made for the reserve required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2279aa–10/c/1"},"text":"section 2279aa–10(c)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcea2841-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–4/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dividends prohibited while obligations are outstanding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No dividend may be declared or paid by the Board under this section while any obligation issued by the Corporation to the Secretary of the Treasury under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2279aa–13"},"text":"section 2279aa–13 of this title","children":[],"tail":" remains outstanding."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcea2842-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–4/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonvoting common stock","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation is authorized to issue nonvoting common stock having such par value as may be fixed by the Board from time to time. Such nonvoting common stock shall be freely transferable, except that, as to the Corporation, such stock shall be transferable only on the books of the Corporation. Such dividends as may be declared by the Board, in the discretion of the Board, may be paid by the Corporation to the holders of the nonvoting common stock of the Corporation, subject to paragraphs (2) and (3) of subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcea2843-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–4/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preferred stock","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcea2844-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–4/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation is authorized to issue nonvoting preferred stock having such par value as may be fixed by the Board from time to time. Such preferred stock issued shall be freely transferable, except that, as to the Corporation, such stock shall be transferred only on the books of the Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcea2845-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–4/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights of preferred stock","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraphs (2) and (3) of subsection (c), the holders of the preferred stock shall be entitled to such rate of cumulative dividends, and such holders shall be subject to such redemption or other conversion provisions, as may be provided for at the time of issuance. No dividends shall be payable on any share of common stock at any time when any dividend is due on any share of preferred stock and has not been paid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcea2846-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–4/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference on termination of business","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the event of any liquidation, dissolution, or winding up of the business of the Corporation, the holders of the preferred shares of stock shall be paid in full at the par value thereof, plus all accrued dividends, before the holders of the common shares receive any payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcea2847-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tVIII/s8"},"text":"Pub. L. 92–181, title VIII, § 8","children":[],"tail":".4, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tVII/s702"},"text":"Pub. L. 100–233, title VII, § 702","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1692"},"text":"101 Stat. 1692","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/tVI/s601/d"},"text":"Pub. L. 100–399, title VI, § 601(d)","children":[],"tail":", (e), "},{"tag":"date","attrib":{"date":"1988-08-17"},"text":"Aug. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1005"},"text":"102 Stat. 1005","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tV/s5411/44"},"text":"Pub. L. 115–334, title V, § 5411(44)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4684"},"text":"132 Stat. 4684","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcea2848-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcea2849-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcea284a-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":", within existing provisions, designated first and second sentences as subpars. (A) and (B), respectively, added subpar. (C) and struck out former third sentence which read “Voting shall be by classes as described in "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2279aa–2/a/9"},"text":"section 2279aa–2(a)(9) of this title","children":[],"tail":".”, designated fourth to sixth sentences collectively as subpar. (D) and individually as cls. (i) to (iii), respectively, thereof, substituted “2279aa–2(a)(2)(A)” for “2279aa–2(b)(2)(A)” in subpar. (D)(ii) and “2279aa–2(a)(2)(B)” for “2279aa–2(b)(2)(B)” in subpar. (D)(iii), and inserted subpar. and cl. headings."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s601/d"},"text":"Pub. L. 100–399, § 601(d)","children":[],"tail":", in penultimate sentence, inserted “and” after “institutions” and inserted “, including national banking associations (which shall be allowed to purchase and hold such stock)” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s601/e"},"text":"Pub. L. 100–399, § 601(e)","children":[],"tail":", substituted “books of the Corporation” for “books of the Association”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcea284b-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcea284c-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399"},"text":"Pub. L. 100–399","children":[],"tail":" effective as if enacted immediately after enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/100/233"},"text":"Pub. L. 100–233","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/s1001/a"},"text":"section 1001(a) of Pub. L. 100–399","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2002"},"text":"section 2002 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
