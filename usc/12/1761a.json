ull,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those comprising this section were contained in section 11(b) of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-26/ch750"},"text":"act June 26, 1934, ch. 750","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/1219"},"text":"48 Stat. 1219","children":[],"tail":" (formerly classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1761/b"},"text":"section 1761(b) of this title","children":[],"tail":"), prior to the amendment and renumbering of act "},{"tag":"date","attrib":{"date":"1934-06-26"},"text":"June 26, 1934","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/pl/86/354"},"text":"Pub. L. 86–354","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc40c93d-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1987—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/86"},"text":"Pub. L. 100–86","children":[],"tail":" inserted third sentence and struck out former third sentence which read as follows: “The board shall elect from their number a financial officer who shall give bond with good and sufficient surety, in an amount and character to be determined by the board of directors in compliance with regulations prescribed from time to time by the Board conditioned upon the faithful performance of the officer’s trust.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/320"},"text":"Pub. L. 97–320","children":[],"tail":" substituted provisions relating to the officers of the board for provisions which read: “At their first meeting after the annual meeting of the members, the directors shall elect from their number a president, one or more vice presidents, a secretary, and a treasurer, who shall be the executive officers of the corporation. No executive officer, except the treasurer, shall be compensated as such. The offices of secretary and treasurer may be held by the same person. The duties of the officers shall be as determined by the bylaws. Before the treasurer shall enter upon his duties he shall give bond with good and sufficient surety, in an amount and character to be determined by the board of directors in compliance with regulations prescribed from time to time by the Board, conditioned upon the faithful performance of his trust.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/630"},"text":"Pub. L. 95–630","children":[],"tail":" substituted “Board” for “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/206"},"text":"Pub. L. 91–206","children":[],"tail":" substituted “Administrator” for “Director”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1963—","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/150"},"text":"Pub. L. 88–150","children":[],"tail":" struck out “, except that the treasurer shall be the general manager of the corporation” after “bylaws” in fourth sentence."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc40c93e-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddc40c93f-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/630"},"text":"Pub. L. 95–630","children":[],"tail":" effective on expiration of 120 days after "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", and transitional provisions, see "},{"tag":"ref","attrib":{"href":"/us/pl/95/630/s509"},"text":"section 509 of Pub. L. 95–630","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1752"},"text":"section 1752 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
