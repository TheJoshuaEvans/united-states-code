{"tag":"section","attrib":{"id":"iddcc191f6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2077"},"text":null,"children":[{"tag":"num","attrib":{"value":"2077"},"text":"§ 2077.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Each production credit association and its obligations are instrumentalities of the United States and as such any and all notes, debentures, and other obligations issued by such associations shall be exempt, both as to principal and interest, from all taxation (except surtaxes, estate, inheritance, and gift taxes) now or hereafter imposed by the United States or any State, territorial, or local taxing authority, except that interest on such obligations shall be subject to Federal income taxation in the hands of the holder.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddcc191f7-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tII/s2"},"text":"Pub. L. 92–181, title II, § 2","children":[],"tail":".7, formerly § 2.6, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tIV/s401"},"text":"Pub. L. 100–233, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1633"},"text":"101 Stat. 1633","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/tIV/s401/r"},"text":"Pub. L. 100–399, title IV, § 401(r)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-17"},"text":"Aug. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/998"},"text":"102 Stat. 998","children":[],"tail":"; renumbered § 2.7, "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXVIII/s1833/1"},"text":"Pub. L. 101–624, title XVIII, § 1833(1)","children":[],"tail":