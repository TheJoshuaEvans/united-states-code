{"tag":"section","attrib":{"id":"iddd2361b0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4513b"},"text":null,"children":[{"tag":"num","attrib":{"value":"4513b"},"text":"§ 4513b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prudential management and operations standards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd2361b1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4513b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall establish standards, by regulation or guideline, for each regulated entity relating to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2361b2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4513b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adequacy of internal controls and information systems taking into account the nature and scale of business operations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2361b3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4513b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" independence and adequacy of internal audit systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2361b4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4513b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" management of interest rate risk exposure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2361b5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4513b/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" management of market risk, including standards that provide for systems that accurately measure, monitor, and control market risks and, as warranted, that establish limitations on market risk;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2361b6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4513b/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adequacy and maintenance of liquidity and reserves;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2361b7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4513b/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" management of asset and investment portfolio growth;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2361b8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4513b/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" investments and acquisitions of assets by a regulated entity, to ensure that they are consistent with the purposes of this chapter and the authorizing statutes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2361b9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4513b/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" overall risk management processes, including adequacy of oversight by senior management and the board of directors and of processes and policies to identify, measure, monitor, and control material risks, including reputational risks, and for adequate, well-tested business resumption plans for all major systems with remote site facilities to protect against disruptive events;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2361ba-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4513b/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" management of credit and counterparty risk, including systems to identify concentrations of credit risk and prudential limits to restrict exposure of the regulated entity to a single counterparty or groups of related counterparties;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2361bb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4513b/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintenance of adequate records, in accordance with consistent accounting policies and practices that enable the Director to evaluate the financial condition of the regulated entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2361bc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4513b/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other operational and management standards as the Director determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2361bd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4513b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to meet standards","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2361be-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4513b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan requirement","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd2361bf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4513b/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Director determines that a regulated entity fails to meet any standard established under subsection (a)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd2361c0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4513b/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if such standard is established by regulation, the Director shall require the regulated entity to submit an acceptable plan to the Director within the time allowed under subparagraph (C); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd2361c1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4513b/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if such standard is established by guideline, the Director may require the regulated entity to submit a plan described in clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd2361c2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4513b/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any plan required under subparagraph (A) shall specify the actions that the regulated entity will take to correct the deficiency. If the regulated entity is undercapitalized, the plan may be a part of the capital restoration plan for the regulated entity under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4622"},"text":"section 4622 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd2361c3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4513b/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadlines for submission and review","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall by regulation establish deadlines that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd2361c4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4513b/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the regulated entities with reasonable time to submit plans required under subparagraph (A), and generally require a regulated entity to submit a plan not later than 30 days after the Director determines that the entity fails to meet any standard established under subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd2361c5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4513b/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require the Director to act on plans expeditiously, and generally not later than 30 days after the plan is submitted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2361c6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4513b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required order upon failure to submit or implement plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a regulated entity fails to submit an acceptable plan within the time allowed under paragraph (1)(C), or fails in any material respect to implement a plan accepted by the Director, the following shall apply:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd2361c7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4513b/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required correction of deficiency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall, by order, require the regulated entity to correct the deficiency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd2361c8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4513b/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director may, by order, take one or more of the following actions until the deficiency is corrected:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd25aab9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4513b/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Prohibit the regulated entity from permitting its average total assets (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4516/b"},"text":"section 4516(b) of this title","children":[],"tail":") during any calendar quarter to exceed its average total assets during the preceding calendar quarter, or restrict the rate at which the average total assets of the entity may increase from one calendar quarter to another."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd25aaba-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4513b/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Require the regulated entity—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddd25aabb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4513b/b/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an enterprise, to increase its ratio of core capital to assets.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddd25aabc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4513b/b/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a Federal Home Loan Bank, to increase its ratio of total capital (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1426/a/5"},"text":"section 1426(a)(5) of this title","children":[],"tail":") to assets."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd25aabd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4513b/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Require the regulated entity to take any other action that the Director determines will better carry out the purposes of this section than any of the actions described in this subparagraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd25aabe-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4513b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory restrictions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In complying with paragraph (2), the Director shall take one or more of the actions described in clauses (i) through (iii) of paragraph (2)(B) if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd25aabf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4513b/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director determines that the regulated entity fails to meet any standard prescribed under subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd25aac0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4513b/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the regulated entity has not corrected the deficiency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd25aac1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4513b/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the 18-month period before the date on which the regulated entity first failed to meet the standard, the entity underwent extraordinary growth, as defined by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd25aac2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4513b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other enforcement authority not affected","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority of the Director under this section is in addition to any other authority of the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd25aac3-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXIII/s1313B"},"text":"Pub. L. 102–550, title XIII, § 1313B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tI/s1108"},"text":"Pub. L. 110–289, div. A, title I, § 1108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2672"},"text":"122 Stat. 2672","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd25aac4-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd25aac5-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd25aac6-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a)(7), was in the original “this title”, meaning title XIII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550"},"text":"Pub. L. 102–550","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3941"},"text":"106 Stat. 3941","children":[],"tail":", which is classified principally to this chapter. For complete classification of title XIII to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4501"},"text":"section 4501 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
