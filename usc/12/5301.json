{"tag":"section","attrib":{"id":"iddd50b30c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5301"},"text":null,"children":[{"tag":"num","attrib":{"value":"5301"},"text":"§ 5301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this Act, the following definitions shall apply, except as the context otherwise requires or as otherwise specifically provided in this Act:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd50b30d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5301/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Affiliate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “affiliate” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"section 1813 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd50b30e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5301/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate Federal banking agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On and after the transfer date, the term “appropriate Federal banking agency” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813/q"},"text":"section 1813(q) of this title","children":[],"tail":", as amended by title III."},{"tag":"ref","attrib":{"idref":"fn002469"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002469"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd50b30f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5301/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board of Governors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Board of Governors” means the Board of Governors of the Federal Reserve System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd50b310-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5301/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bureau","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Bureau” means the Bureau of Consumer Financial Protection established under title X.","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd50b311-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5301/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Commission” means the Securities and Exchange Commission, except in the context of the Commodity Futures Trading Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd50b312-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5301/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commodity futures terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “futures commission merchant”, “swap”, “swap dealer”, “swap execution facility”, “derivatives clearing organization”, “board of trade”, “commodity trading advisor”, “commodity pool”, and “commodity pool operator” have the same meanings as given the terms in section 1a of the Commodity Exchange Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1"},"text":"7 U.S.C. 1","children":[],"tail":" et seq.) ["},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1a"},"text":"7 U.S.C. 1a","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd50b313-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5301/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Corporation” means the Federal Deposit Insurance Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd50b314-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5301/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Council","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Council” means the Financial Stability Oversight Council established under subchapter I.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd50b315-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5301/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit union","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “credit union” means a Federal credit union, State credit union, or State-chartered credit union, as those terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1752"},"text":"section 1752 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd50b316-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5301/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal banking agency","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd50b317-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5301/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Federal banking agency” means, individually, the Board of Governors, the Office of the Comptroller of the Currency, and the Corporation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd50b318-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5301/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Federal banking agencies” means all of the agencies referred to in subparagraph (A), collectively.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd50b319-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5301/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functionally regulated subsidiary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “functionally regulated subsidiary” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1844/c/5"},"text":"section 1844(c)(5) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd50b31a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5301/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Primary financial regulatory agency","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “primary financial regulatory agency” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd50b31b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5301/12/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriate Federal banking agency, with respect to institutions described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813/q"},"text":"section 1813(q) of this title","children":[],"tail":", except to the extent that an institution is or the activities of an institution are otherwise described in subparagraph (B), (C), (D), or (E);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd50b31c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5301/12/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Securities and Exchange Commission, with respect to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd50b31d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5301/12/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any broker or dealer that is registered with the Commission under the Securities Exchange Act of 1934 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78a"},"text":"15 U.S.C. 78a","children":[],"tail":" et seq.], with respect to the activities of the broker or dealer that require the broker or dealer to be registered under that Act;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd50b31e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5301/12/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any investment company that is registered with the Commission under the Investment Company Act of 1940 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s80a–1"},"text":"15 U.S.C. 80a–1","children":[],"tail":" et seq.], with respect to the activities of the investment company that require the investment company to be registered under that Act;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd50b31f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5301/12/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any investment adviser that is registered with the Commission under the Investment Advisers Act of 1940 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s80b–1"},"text":"15 U.S.C. 80b–1","children":[],"tail":" et seq.], with respect to the investment advisory activities of such company and activities that are incidental to such advisory activities;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd50b320-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5301/12/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any clearing agency registered with the Commission under the Securities Exchange Act of 1934, with respect to the activities of the clearing agency that require the agency to be registered under such Act;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd50b321-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5301/12/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any nationally recognized statistical rating organization registered with the Commission under the Securities Exchange Act of 1934;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd50b322-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5301/12/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any transfer agent registered with the Commission under the Securities Exchange Act of 1934;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd50b323-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5301/12/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any exchange registered as a national securities exchange with the Commission under the Securities Exchange Act of 1934;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd50b324-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5301/12/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any national securities association registered with the Commission under the Securities Exchange Act of 1934;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd50b325-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5301/12/B/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any securities information processor registered with the Commission under the Securities Exchange Act of 1934;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd50b326-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5301/12/B/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Municipal Securities Rulemaking Board established under the Securities Exchange Act of 1934;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd50b327-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5301/12/B/xi"},"text":null,"children":[{"tag":"num","attrib":{"value":"xi"},"text":"(xi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Public Company Accounting Oversight Board established under the Sarbanes-Oxley Act of 2002 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s7211"},"text":"15 U.S.C. 7211","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd50b328-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5301/12/B/xii"},"text":null,"children":[{"tag":"num","attrib":{"value":"xii"},"text":"(xii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Securities Investor Protection Corporation established under the Securities Investor Protection Act of 1970 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78aaa"},"text":"15 U.S.C. 78aaa","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd50b329-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5301/12/B/xiii"},"text":null,"children":[{"tag":"num","attrib":{"value":"xiii"},"text":"(xiii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any security-based swap execution facility, security-based swap data repository, security-based swap dealer or major security-based swap participant registered with the Commission under the Securities Exchange Act of 1934, with respect to the security-based swap activities of the person that require such person to be registered under such Act;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd50b32a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5301/12/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Commodity Futures Trading Commission, with respect to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd50b32b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5301/12/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any futures commission merchant registered with the Commodity Futures Trading Commission under the Commodity Exchange Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1"},"text":"7 U.S.C. 1","children":[],"tail":" et seq.), with respect to the activities of the futures commission merchant that require the futures commission merchant to be registered under that Act;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd50b32c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5301/12/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any commodity pool operator registered with the Commodity Futures Trading Commission under the Commodity Exchange Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1"},"text":"7 U.S.C. 1","children":[],"tail":" et seq.), with respect to the activities of the commodity pool operator that require the commodity pool operator to be registered under that Act, or a commodity pool, as defined in that Act;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd50b32d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5301/12/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any commodity trading advisor or introducing broker registered with the Commodity Futures Trading Commission under the Commodity Exchange Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1"},"text":"7 U.S.C. 1","children":[],"tail":" et seq.), with respect to the activities of the commodity trading advisor or introducing broker that require the commodity trading adviser or introducing broker to be registered under that Act;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd50b32e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5301/12/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any derivatives clearing organization registered with the Commodity Futures Trading Commission under the Commodity Exchange Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1"},"text":"7 U.S.C. 1","children":[],"tail":" et seq.), with respect to the activities of the derivatives clearing organization that require the derivatives clearing organization to be registered under that Act;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd50b32f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5301/12/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any board of trade designated as a contract market by the Commodity Futures Trading Commission under the Commodity Exchange Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1"},"text":"7 U.S.C. 1","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd50b330-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5301/12/C/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any futures association registered with the Commodity Futures Trading Commission under the Commodity Exchange Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1"},"text":"7 U.S.C. 1","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd50b331-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5301/12/C/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any retail foreign exchange dealer registered with the Commodity Futures Trading Commission under the Commodity Exchange Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1"},"text":"7 U.S.C. 1","children":[],"tail":" et seq.), with respect to the activities of the retail foreign exchange dealer that require the retail foreign exchange dealer to be registered under that Act;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd50b332-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5301/12/C/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any swap execution facility, swap data repository, swap dealer, or major swap participant registered with the Commodity Futures Trading Commission under the Commodity Exchange Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1"},"text":"7 U.S.C. 1","children":[],"tail":" et seq.) with respect to the swap activities of the person that require such person to be registered under that Act; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd50b333-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5301/12/C/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":