{"tag":"section","attrib":{"id":"iddd71f6d8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5532"},"text":null,"children":[{"tag":"num","attrib":{"value":"5532"},"text":"§ 5532.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd71f6d9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5532/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Bureau may prescribe rules to ensure that the features of any consumer financial product or service, both initially and over the term of the product or service, are fully, accurately, and effectively disclosed to consumers in a manner that permits consumers to understand the costs, benefits, and risks associated with the product or service, in light of the facts and circumstances.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd71f6da-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5532/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Model disclosures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd71f6db-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5532/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any final rule prescribed by the Bureau under this section requiring disclosures may include a model form that may be used at the option of the covered person for provision of the required disclosures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd71f6dc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5532/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Format","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A model form issued pursuant to paragraph (1) shall contain a clear and conspicuous disclosure that, at a minimum—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd71f6dd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5532/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uses plain language comprehensible to consumers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd71f6de-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5532/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains a clear format and design, such as an easily readable type font; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd71f6df-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5532/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" succinctly explains the information that must be communicated to the consumer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd71f6e0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5532/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consumer testing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any model form issued pursuant to this subsection shall be validated through consumer testing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd71f6e1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5532/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis for rulemaking","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In prescribing rules under this section, the Bureau shall consider available evidence about consumer awareness, understanding of, and responses to disclosures or communications about the risks, costs, and benefits of consumer financial products or services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd71f6e2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5532/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Safe harbor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any covered person that uses a model form included with a rule issued under this section shall be deemed to be in compliance with the disclosure requirements of this section with respect to such model form.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd7466e3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5532/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trial disclosure programs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd7466e4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5532/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Bureau may permit a covered person to conduct a trial program that is limited in time and scope, subject to specified standards and procedures, for the purpose of providing trial disclosures to consumers that are designed to improve upon any model form issued pursuant to subsection (b)(1), or any other model form issued to implement an enumerated statute, as applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7466e5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5532/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Safe harbor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The standards and procedures issued by the Bureau shall be designed to encourage covered persons to conduct trial disclosure programs. For the purposes of administering this subsection, the Bureau may establish a limited period during which a covered person conducting a trial disclosure program shall be deemed to be in compliance with, or may be exempted from, a requirement of a rule or an enumerated consumer law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7466e6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5532/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public disclosure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The rules of the Bureau shall provide for public disclosure of trial disclosure programs, which public disclosure may be limited, to the extent necessary to encourage covered persons to conduct effective trials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd7466e7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5532/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Combined mortgage loan disclosure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after the designated transfer date, the Bureau shall propose for public comment rules and model disclosures that combine the disclosures required under the Truth in Lending Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1601"},"text":"15 U.S.C. 1601","children":[],"tail":" et seq.] and sections 2603 and 2604 of this title, into a single, integrated disclosure for mortgage loan transactions covered by those laws, unless the Bureau determines that any proposal issued by the Board of Governors and the Secretary of Housing and Urban Development carries out the same purpose."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd7466e8-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1032"},"text":"Pub. L. 111–203, title X, § 1032","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2006"},"text":"124 Stat. 2006","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd7466e9-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd7466ea-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd7466eb-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Truth in Lending Act, referred to in subsec. (f), is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321"},"text":"Pub. L. 90–321","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-05-29"},"text":"May 29, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/146"},"text":"82 Stat. 146","children":[],"tail":", which is classified generally to subchapter I (§ 1601 et seq.) of chapter 41 of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1601"},"text":"section 1601 of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd7466ec-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd7466ed-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the designated transfer date, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1037"},"text":"section 1037 of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5531"},"text":"section 5531 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
