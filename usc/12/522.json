{"tag":"section","attrib":{"id":"iddb48d47e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s522"},"text":null,"children":[{"tag":"num","attrib":{"value":"522"},"text":"§ 522.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Reserve branch bank buildings","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No Federal Reserve bank may authorize the acquisition or construction of any branch building, or enter into any contract or other obligation for the acquisition or construction of any branch building, without the approval of the Board.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddb48d47f-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1913-12-23/ch6/s10"},"text":"Dec. 23, 1913, ch. 6, § 10","children":[],"tail":" (par.), as added "},{"tag":"ref","attrib":{"href":"/us/act/1922-06-03/ch205"},"text":"June 3, 1922, ch. 205","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/622"},"text":"42 Stat. 622","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/act/1923-02-06/ch60"},"text":"Feb. 6, 1923, ch. 60","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/1223"},"text":"42 Stat. 1223","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1947-07-30/ch352"},"text":"July 30, 1947, ch. 352","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/520"},"text":"61 Stat. 520","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1953-05-29/ch87"},"text":"May 29, 1953, ch. 87","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/67/41"},"text":"67 Stat. 41","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/622/s1"},"text":"Pub. L. 87–622, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-08-31"},"text":"Aug. 31, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/418"},"text":"76 Stat. 418","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/495/tI/s108"},"text":"Pub. L. 93–495, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-28"},"text":"Oct. 28, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1505"},"text":"88 Stat. 1505","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/491/s2"},"text":"Pub. L. 102–491, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3144"},"text":"106 Stat. 3144","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb48d480-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb48d481-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddb48d482-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ninth paragraph of act ","children":[{"tag":"date","attrib":{"date":"1913-12-23"},"text":"Dec. 23, 1913","children":[],"tail":", § 10, as added "},{"tag":"date","attrib":{"date":"1922-06-03"},"text":"June 3, 1922","children":[],"tail":". For classification to this title of other pars. of section 10, see Codification note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s241"},"text":"section 241 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddb48d483-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/491"},"text":"Pub. L. 102–491","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “No Federal reserve bank shall have authority hereafter to enter into any contract or contracts for the erection of any branch bank building of any kind or character, or to authorize the erection of any such building, if the cost of the building proper, exclusive of the cost of the vaults, permanent equipment, furnishings, and fixtures, is in excess of $250,000: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That nothing herein shall apply to any building under construction prior to "},{"tag":"date","attrib":{"date":"1922-06-03"},"text":"June 3, 1922","children":[],"tail":": "},{"tag":"i","attrib":{},"text":"Provided further","children":[],"tail":", That the cost as above specified shall not be so limited as long as the aggregate of such costs which are incurred by all Federal Reserve banks for branch bank buildings with the approval of the Board of Governors after "},{"tag":"date","attrib":{"date":"1947-07-30"},"text":"July 30, 1947","children":[],"tail":" does not exceed $140,000,000.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/495"},"text":"Pub. L. 93–495","children":[],"tail":" increased from $60,000,000 to $140,000,000 the limitation on aggregate costs of constructing branch bank buildings."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1962—","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/622"},"text":"Pub. L. 87–622","children":[],"tail":" increased from $30,000,000 to $60,000,000 the limitation on aggregate costs of constructing branch bank buildings."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1953—Act ","children":[{"tag":"date","attrib":{"date":"1953-05-29"},"text":"May 29, 1953","children":[],"tail":", increased from $10,000,000 to $30,000,000 the limitation on aggregate cost of constructing branch bank buildings."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1947—Act ","children":[{"tag":"date","attrib":{"date":"1947-07-30"},"text":"July 30, 1947","children":[],"tail":", inserted proviso exempting limitation on cost of construction where aggregate costs do not exceed $10,000,000."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
