{"tag":"section","attrib":{"id":"iddb63133d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635i–8"},"text":null,"children":[{"tag":"num","attrib":{"value":"635i–8"},"text":"§ 635i–8.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special debt relief for poorest, most heavily indebted countries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddb63133e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635i–8/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Debt reduction authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President may reduce amounts of principal and interest owed by any eligible country to the Bank as a result of loans or guarantees made under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb63133f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635i–8/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb631340-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635i–8/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Types of debt reduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority provided by subsection (a) may be exercised only to implement multilateral agreements to reduce the burden of official bilateral debt as set forth in the minutes of the so-called “Paris Club” (also known as “Paris Club Agreed Minutes”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb631341-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635i–8/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible countries","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddb631342-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635i–8/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Eligible country” defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in subsection (a), the term “eligible country” means any country that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddb631343-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635i–8/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has excessively burdensome external debt;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddb631344-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635i–8/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is eligible to borrow from the International Development Association; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddb631345-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635i–8/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not eligible to borrow from the International Bank for Reconstruction and Development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb631346-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635i–8/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determinations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraph (A), the President may determine whether a country is an eligible country for purposes of subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb631347-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635i–8/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The authority provided by this section may be exercised only with respect to a country whose government—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb631348-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635i–8/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not have an excessive level of military expenditures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb631349-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635i–8/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not repeatedly provided support for acts of international terrorism;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb63134a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635i–8/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not failing to cooperate on international narcotics control matters; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb63134b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635i–8/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" (including its military or other security forces) does not engage in a consistent pattern of gross violations of internationally recognized human rights.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb63134c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635i–8/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority provided by subsection (a) may be exercised only in such amounts or to such extent as is provided in advance in appropriations Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddb63134d-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-07-31/ch341/s14"},"text":"July 31, 1945, ch. 341, § 14","children":[],"tail":", formerly § 11, as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/87/tV/s570/b"},"text":"Pub. L. 103–87, title V, § 570(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-09-30"},"text":"Sept. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/970"},"text":"107 Stat. 970","children":[],"tail":"; renumbered § 14, "},{"tag":"ref","attrib":{"href":"/us/pl/103/428/s2/b"},"text":"Pub. L. 103–428, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4376"},"text":"108 Stat. 4376","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/189/s24/b/6"},"text":"Pub. L. 107–189, § 24(b)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-06-14"},"text":"June 14, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/709"},"text":"116 Stat. 709","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb63134e-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb63134f-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddb631350-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/189"},"text":"Pub. L. 107–189","children":[],"tail":" substituted “principal” for “principle”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"iddb631351-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddb631352-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Authority With Respect to Debt Reduction for Poorest Countries","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"1994-06-20"},"text":"June 20, 1994","children":[],"tail":", 59 F.R. 33413, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum for the Secretary of the Treasury","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"By the authority vested in me as President by the Constitution and the laws of the United States of America, including section 570 of the Foreign Operations, Export Financing, and Related Programs Appropriations Act, 1994 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/87"},"text":"Public Law 103–87","children":[],"tail":") (the “Act”) [enacting "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s635i–8"},"text":"12 U.S.C. 635i–8","children":[],"tail":"], section 14 of the Export-Import Bank Act of 1945 ("},{"tag":"ref","attrib":{"href":"/us/usc/t12/s635"},"text":"12 U.S.C. 635","children":[],"tail":"—635i–8) [probably means "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s635i–8"},"text":"12 U.S.C. 635i–8","children":[],"tail":"], and "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"section 301 of title 3","children":[],"tail":" of the United States Code, it is hereby ordered as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1. There are delegated to the Secretary of the Treasury, in consultation with the Secretary of State and the Secretary of Defense, the functions, authorities, and duties conferred upon the President by section 570(a) of the Act [","children":[{"tag":"ref","attrib":{"href":"/us/stat/107/970"},"text":"107 Stat. 970","children":[],"tail":"]."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2. There are delegated to the Secretary of the Treasury, in consultation with the Secretary of State and the President of the Export-Import Bank, the functions, authorities, and duties conferred upon the President by section 570(b) of the Act and section 14(a) of the Export-Import Bank Act of 1945 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s635"},"text":"12 U.S.C. 635","children":[],"tail":"—635i–8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Secretary of the Treasury is authorized and directed to publish this memorandum in the Federal Register.","children":[],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"text":"William J. Clinton.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
