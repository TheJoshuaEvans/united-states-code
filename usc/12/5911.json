{"tag":"section","attrib":{"id":"iddd8508f6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5911"},"text":null,"children":[{"tag":"num","attrib":{"value":"5911"},"text":"§ 5911.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of existing insolvency law","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In accordance with otherwise applicable law, an insolvency proceeding with respect to a permitted payment stablecoin issuer shall occur as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd8508f7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5911/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A depository institution (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"section 1813 of this title","children":[],"tail":") shall be resolved by the Federal Deposit Insurance Corporation, National Credit Union Administration, or State payment stablecoin regulator, as applicable."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd8508f8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5911/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A subsidiary of a depository institution (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"section 1813 of this title","children":[],"tail":") or a nonbank entity may be considered a debtor under title 11."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd8508f9-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/27/s11/g"},"text":"Pub. L. 119–27, § 11(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-18"},"text":"July 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/458"},"text":"139 Stat. 458","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd8508fa-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"iddd8508fb-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Delayed Effective Date of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For delayed effective date of section, see Effective Date note below.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd8508fc-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd8508fd-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the earlier of the date that is 18 months after ","children":[{"tag":"date","attrib":{"date":"2025-07-18"},"text":"July 18, 2025","children":[],"tail":", or the date that is 120 days after the date on which the primary Federal payment stablecoin regulators issue any final regulations implementing "},{"tag":"ref","attrib":{"href":"/us/pl/119/27"},"text":"Pub. L. 119–27","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/119/27/s20"},"text":"section 20 of Pub. L. 119–27","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5901"},"text":"section 5901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
