{"tag":"section","attrib":{"id":"iddd5a27ec-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5381"},"text":null,"children":[{"tag":"num","attrib":{"value":"5381"},"text":"§ 5381.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd5a27ed-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5381/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subchapter, the following definitions shall apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd5a27ee-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5381/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative expenses of the receiver","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “administrative expenses of the receiver” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd5a27ef-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5381/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the actual, necessary costs and expenses incurred by the Corporation as receiver for a covered financial company in liquidating a covered financial company; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd5a27f0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5381/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any obligations that the Corporation as receiver for a covered financial company determines are necessary and appropriate to facilitate the smooth and orderly liquidation of the covered financial company.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd5a27f1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5381/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bankruptcy Code","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Bankruptcy Code” means title 11.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd5a27f2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5381/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bridge financial company","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “bridge financial company” means a new financial company organized by the Corporation in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5390/h"},"text":"section 5390(h) of this title","children":[],"tail":" for the purpose of resolving a covered financial company."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd5a27f3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5381/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Claim","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “claim” means any right to payment, whether or not such right is reduced to judgment, liquidated, unliquidated, fixed, contingent, matured, unmatured, disputed, undisputed, legal, equitable, secured, or unsecured.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd5a27f4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5381/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Company","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “company” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1841/b"},"text":"section 1841(b) of this title","children":[],"tail":", except that such term includes any company described in paragraph (11), the majority of the securities of which are owned by the United States or any State."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd5a27f5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5381/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Court","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Court” means the United States District Court for the District of Columbia, unless the context otherwise requires.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd5a27f6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5381/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered broker or dealer","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered broker or dealer” means a covered financial company that is a broker or dealer that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd5a27f7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5381/a/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is registered with the Commission under section 78","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":"(b) of title 15; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd5a27f8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5381/a/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a member of SIPC.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd5a27f9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5381/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered financial company","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered financial company”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd5a27fa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5381/a/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means a financial company for which a determination has been made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5383/b"},"text":"section 5383(b) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd5a27fb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5381/a/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include an insured depository institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd5a27fc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5381/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered subsidiary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered subsidiary” means a subsidiary of a covered financial company, other than—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd5a27fd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5381/a/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an insured depository institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd5a27fe-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5381/a/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an insurance company; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd5a27ff-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5381/a/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a covered broker or dealer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd5a2800-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5381/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions relating to covered brokers and dealers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “customer”, “customer name securities”, “customer property”, and “net equity” in the context of a covered broker or dealer, have the same meanings as in section 78","children":[{"tag":"i","attrib":{},"text":"lll","children":[],"tail":" of title 15."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd5a2801-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5381/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial company","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “financial company” means any company that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd5a2802-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5381/a/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is incorporated or organized under any provision of Federal law or the laws of any State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd5a2803-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5381/a/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd5a2804-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5381/a/11/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a bank holding company, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1841/a"},"text":"section 1841(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd5a2805-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5381/a/11/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonbank financial company supervised by the Board of Governors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd5a2806-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5381/a/11/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any company that is predominantly engaged in activities that the Board of Governors has determined are financial in nature or incidental thereto for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1843/k"},"text":"section 1843(k) of this title","children":[],"tail":" other than a company described in clause (i) or (ii); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd5a2807-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5381/a/11/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any subsidiary of any company described in any of clauses (i) through (iii) that is predominantly engaged in activities that the Board of Governors has determined are financial in nature or incidental thereto for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1843/k"},"text":"section 1843(k) of this title","children":[],"tail":" (other than a subsidiary that is an insured depository institution or an insurance company); and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd5a2808-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5381/a/11/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not a Farm Credit System institution chartered under and subject to the provisions of the Farm Credit Act of 1971, as amended (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2001"},"text":"12 U.S.C. 2001","children":[],"tail":" et seq.), a governmental entity, or a regulated entity, as defined under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4502/20"},"text":"section 4502(20) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd5a2809-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5381/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Fund” means the Orderly Liquidation Fund established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5390/n"},"text":"section 5390(n) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd5a280a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5381/a/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Insurance company","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “insurance company” means any entity that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd5a280b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5381/a/13/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engaged in the business of insurance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd5a280c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5381/a/13/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to regulation by a State insurance regulator; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd5a280d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5381/a/13/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" covered by a State law that is designed to specifically deal with the rehabilitation, liquidation, or insolvency of an insurance company.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd5a280e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5381/a/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonbank financial company","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “nonbank financial company” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5311/a/4/C"},"text":"section 5311(a)(4)(C) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd5a280f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5381/a/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonbank financial company supervised by the Board of Governors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “nonbank financial company supervised by the Board of Governors” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5311/a/4/D"},"text":"section 5311(a)(4)(D) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd5a2810-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5381/a/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" SIPC","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “SIPC” means the Securities Investor Protection Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd5a2811-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5381/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitional criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purpose of the definition of the term “financial company” under subsection (a)(11), no company shall be deemed to be predominantly engaged in activities that the Board of Governors has determined are financial in nature or incidental thereto for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1843/k"},"text":"section 1843(k) of this title","children":[],"tail":", if the consolidated revenues of such company from such activities constitute less than 85 percent of the total consolidated revenues of such company, as the Corporation, in consultation with the Secretary, shall establish by regulation. In determining whether a company is a financial company under this subchapter, the consolidated revenues derived from the ownership or control of a depository institution shall be included."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd5a2812-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tII/s201"},"text":"Pub. L. 111–203, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1442"},"text":"124 Stat. 1442","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd5a2813-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd5a2814-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd5a2815-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in text, was in the original “this title”, meaning title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1442"},"text":"124 Stat. 1442","children":[],"tail":", which is classified principally to this subchapter. For complete classification of title II to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Farm Credit Act of 1971, referred to in subsec. (a)(11)(C), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181"},"text":"Pub. L. 92–181","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-12-10"},"text":"Dec. 10, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/583"},"text":"85 Stat. 583","children":[],"tail":", which is classified principally to chapter 23 (§ 2001 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2001"},"text":"section 2001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd5a2816-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd5a2817-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 1 day after ","children":[{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s4"},"text":"section 4 of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"section 5301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
