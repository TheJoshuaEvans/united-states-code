{"tag":"section","attrib":{"id":"iddb631312-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635i–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"635i–6"},"text":"§ 635i–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Debt reduction; Enterprise for the Americas Initiative","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddb631313-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635i–6/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb631314-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635i–6/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “eligible country” means a country designated by the President in accordance with subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb631315-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635i–6/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Facility” means the entity established in the Department of the Treasury by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1738"},"text":"section 1738 of title 7","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb631316-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635i–6/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “IMF” means the International Monetary Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb631317-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635i–6/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility for benefits under the Facility","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb631318-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635i–6/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible for benefits from the Facility under this section, a country must—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddb631319-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635i–6/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be a Latin American or Caribbean country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb63131a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635i–6/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" have in effect, have received approval for, or, as appropriate in exceptional circumstances, be making significant progress toward—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddb63131b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635i–6/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an IMF standby arrangement, extended IMF arrangement, or an arrangement under the structural adjustment facility or enhanced structural adjustment facility or, in exceptional circumstances, an IMF monitored program or its equivalent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddb63131c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635i–6/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as appropriate, structural or sectoral adjustment loans from the International Bank for Reconstruction and Development or the International Development Association;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb63131d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635i–6/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have put in place major investment reforms in conjunction with an Inter-American Development Bank loan or otherwise be implementing, or making significant progress toward, an open investment regime; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb63131e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635i–6/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if appropriate, have agreed with its commercial bank lenders on a satisfactory financing program, including, as appropriate, debt or debt service reduction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb63131f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635i–6/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility determinations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall determine whether a country is an eligible country for purposes of paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb631320-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635i–6/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loans eligible for sale, reduction, or cancellation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb631321-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635i–6/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to sell, reduce, or cancel certain loans","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, the President may, in accordance with this section, sell to any eligible purchaser any loan or portion thereof made before ","children":[{"tag":"date","attrib":{"date":"1992-01-01"},"text":"January 1, 1992","children":[],"tail":", to any eligible country or any agency thereof pursuant to this subchapter, or, on receipt of payment from an eligible purchaser, reduce or cancel such loan or portion thereof, only for the purpose of facilitating—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddb631322-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635i–6/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" debt-for-equity swaps, debt-for-development swaps, or debt-for-nature swaps; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb631323-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635i–6/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a debt buy-back by an eligible country of its own qualified debt, only if the eligible country uses an additional amount of the local currency of the eligible country, equal to not less than 40 percent of the price paid for such debt by such eligible country, or the difference between the price paid for such debt and the face value of such debt, to support activities that link conservation and sustainable use of natural resources with local community development, and child survival and other child development activities, in a manner consistent with sections 1738f through 1738k of title 7,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"if the sale, reduction, or cancellation would not contravene any term or condition of any prior agreement relating to such loan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb631324-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635i–6/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the President shall, in accordance with this section, establish the terms and conditions under which loans may be sold, reduced, or canceled pursuant to this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb631325-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635i–6/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment under securities laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The filing of a registration statement under the Securities Act of 1933 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s77a"},"text":"15 U.S.C. 77a","children":[],"tail":" et seq.] shall not be required with respect to the sale or offer for sale by the Bank of a loan or any interest therein pursuant to this section. For purposes of the Securities Act of 1933, the Bank shall not be deemed to be an issuer or underwriter with respect to any subsequent sale or other disposition of such loan (or any interest therein) or any security received by an eligible purchaser pursuant to any debt-for-equity swap, debt-for-development swap, or debt-for-nature swap."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb631326-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635i–6/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Facility shall notify the Bank of purchasers that the President has determined to be eligible, and shall direct the Bank to carry out the sale, reduction, or cancellation of a loan pursuant to this section. The Bank shall make an adjustment in its accounts to reflect the sale, reduction, or cancellation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb631327-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635i–6/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authorities of this subsection may be exercised only to such extent as provided for in advance in appropriations Acts, as necessary to implement the Federal Credit Reform Act of 1990 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s661"},"text":"2 U.S.C. 661","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb631328-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635i–6/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit of proceeds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The proceeds from the sale, reduction, or cancellation of any loan sold, reduced, or canceled pursuant to this section shall be deposited in the United States Government account or accounts established for the repayment of such loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb631329-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635i–6/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible purchasers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A loan may be sold pursuant to subsection (c)(1)(A) only to a purchaser who presents plans satisfactory to the President for using the loan for the purpose of engaging in debt-for-equity swaps, debt-for-development swaps, or debt-for-nature swaps.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb63132a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635i–6/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Debtor consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before the sale to any eligible purchaser, or any reduction or cancellation pursuant to this section, of any loan made to an eligible country, the President shall consult with the country concerning the amount of loans to be sold, reduced, or canceled and their uses for debt-for-equity swaps, debt-for-development swaps, or debt-for-nature swaps.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb63132b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635i–6/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the sale, reduction, and cancellation of loans or portions thereof pursuant to this section, there are authorized to be appropriated to the President such sums as may be necessary, which are authorized to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddb63132c-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-07-31/ch341/s12"},"text":"July 31, 1945, ch. 341, § 12","children":[],"tail":", formerly § 18, as added and renumbered § 12, "},{"tag":"ref","attrib":{"href":"/us/pl/102/429/tI"},"text":"Pub. L. 102–429, title I","children":[],"tail":", §§ 108, 121(c)(6), "},{"tag":"date","attrib":{"date":"1992-10-21"},"text":"Oct. 21, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2191"},"text":"106 Stat. 2191","children":[],"tail":", 2199; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/189/s24/b/5"},"text":"Pub. L. 107–189, § 24(b)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-06-14"},"text":"June 14, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/709"},"text":"116 Stat. 709","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/tIII/s3001/b/1/A"},"text":"Pub. L. 110–246, title III, § 3001(b)(1)(A)","children":[],"tail":", (2)(L), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1820"},"text":"122 Stat. 1820","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb63132d-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb63132e-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddb63132f-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Securities Act of 1933, referred to in subsec. (c)(3), is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-05-27/ch38"},"text":"act May 27, 1933, ch. 38","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/74"},"text":"48 Stat. 74","children":[],"tail":", which is classified generally to subchapter I (§ 77a et seq.) of chapter 2A of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s77a"},"text":"section 77a of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Federal Credit Reform Act of 1990, referred to in subsec. (c)(5), is title V of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/344"},"text":"Pub. L. 93–344","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXIII/s13201/a"},"text":"Pub. L. 101–508, title XIII, § 13201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-609"},"text":"104 Stat. 1388–609","children":[],"tail":", which is classified generally to subchapter III (§ 661 et seq.) of chapter 17A of Title 2, The Congress. For complete classification of this Act to the Code, see Short Title of 1990 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s621"},"text":"section 621 of Title 2","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"iddb631330-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 12 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-07-31/ch341"},"text":"act July 31, 1945, ch. 341","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s635i"},"text":"section 635i of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/429/s121/c/1"},"text":"Pub. L. 102–429, § 121(c)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddb631331-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1738"},"text":"section 1738 of title 7","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made technical amendment to reference in original act which appears in text as reference to sections 1738f through 1738k of title 7."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/189"},"text":"Pub. L. 107–189","children":[],"tail":" substituted “subsection (b) of this section” for “section (b) of this section”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddb631332-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddb631333-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/b"},"text":"section 4(b) of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of Title 7","children":[],"tail":", Agriculture."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
