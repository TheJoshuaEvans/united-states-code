{"tag":"section","attrib":{"id":"iddc37539d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1749aaa–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"1749aaa–2"},"text":"§ 1749aaa–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of insurance benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The mortgagee shall be entitled to receive the benefits of the insurance under this subchapter in the manner provided in subsection (g) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1713"},"text":"section 1713 of this title","children":[],"tail":" with respect to mortgages insured under that section. For such purpose the provisions of subsections (g), (h), (i), (j), (k), ("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), and (n) of such section 1713 shall apply to mortgages insured under this subchapter and all references in such subsections to such section 1713 shall be deemed to refer to this subchapter."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc37539e-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-27/ch847"},"text":"June 27, 1934, ch. 847","children":[],"tail":", title XI, § 1103, as added "},{"tag":"ref","attrib":{"href":"/us/pl/89/754/tV/s502/a"},"text":"Pub. L. 89–754, title V, § 502(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-03"},"text":"Nov. 3, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1275"},"text":"80 Stat. 1275","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
