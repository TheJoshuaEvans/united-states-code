{"tag":"section","attrib":{"id":"iddceee32a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2402"},"text":null,"children":[{"tag":"num","attrib":{"value":"2402"},"text":"§ 2402.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership of Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddceee32b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2402/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall be composed of twenty-six members as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddceee32c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2402/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chairman of the Board of Governors of the Federal Reserve System or his delegate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddceee32d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2402/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Attorney General or his delegate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddceee32e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2402/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Comptroller of the Currency or his delegate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddceee32f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2402/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chairman of the Federal Home Loan Bank Board or his delegate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddceee330-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2402/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator of the National Credit Union Administration or his delegate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddceee331-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2402/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chairman of the Board of Directors of the Federal Deposit Insurance Corporation or his delegate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddceee332-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2402/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chairman of the Federal Communications Commission or his delegate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddceee333-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2402/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Postmaster General or his delegate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddceee334-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2402/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Treasury or his delegate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddceee335-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2402/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chairman of the Federal Trade Commission or his delegate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddceee336-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2402/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two individuals, appointed by the President, one of whom is an official of a State agency which regulates banking, or similar financial institutions, and one of whom is an official of a State agency which regulates thrift or similar financial institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddceee337-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2402/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seven individuals, appointed by the President, who are officers or employees of, or who otherwise represent banking, thrift, or other business entities, including one representative each of commercial banks, mutual savings banks, savings and loan associations, credit unions, retailers, nonbanking institutions offering credit card services, and organizations providing interchange services for credit cards issued by banks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddceee338-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2402/a/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" five individuals, appointed by the President, from private life who are not affiliated with, do not represent and have no substantial interest in any banking, thrift, or other financial institution, including but not limited to credit unions, retailers, and insurance companies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddceee339-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2402/a/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Comptroller General of the United States or his delegate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddceee33a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2402/a/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the Office of Technology Assessment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddceee33b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2402/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of Chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chairperson shall be designated by the President at the time of his appointment from among the members of the Commission and such selection shall be by and with the advice and consent of the Senate unless the appointee holds an office to which he was appointed by and with the advice and consent of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddceee33c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2402/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A vacancy in the Commission shall be filled in the manner in which the original appointment was made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddceee33d-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/495/tII/s202"},"text":"Pub. L. 93–495, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-28"},"text":"Oct. 28, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1508"},"text":"88 Stat. 1508","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddceee33e-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddceee33f-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"iddceee340-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions vested in Administrator of National Credit Union Administration transferred and vested in National Credit Union Administration Board pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1752a"},"text":"section 1752a of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Federal Home Loan Bank Board abolished and functions transferred, see sections 401 to 406 of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73"},"text":"Pub. L. 101–73","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1437"},"text":"section 1437 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
