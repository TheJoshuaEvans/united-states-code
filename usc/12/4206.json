{"tag":"section","attrib":{"id":"iddd1e7ef6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4206"},"text":null,"children":[{"tag":"num","attrib":{"value":"4206"},"text":"§ 4206.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights of declarants; notifications; Government accountability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd1e7ef7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4206/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person who has filed a declaration that meets the requirements of sections 4201 through 4204 of this title shall have the rights stated in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1e7ef8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4206/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of decision not to pursue","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If, after review, the Attorney General concludes that the information contained in a declaration should not be pursued in a civil or criminal proceeding, the Attorney General shall so notify the declarant in writing and shall provide a brief statement of the reasons that the declaration will not be pursued.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1e7ef9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4206/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judgment, order, or settlement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd1e7efa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4206/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When the United States obtains a judgment, order, or settlement based in whole or in part on a valid declaration filed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4201"},"text":"section 4201 of this title","children":[],"tail":", the Attorney General shall notify the declarant in writing of such fact."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1e7efb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4206/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A notice described in paragraph (1) shall contain—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd1e7efc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4206/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Attorney General’s determination of the amount of the award due the declarant under subsection (c) or (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4205"},"text":"section 4205 of this title","children":[],"tail":" upon recovery by the United States; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd1e7efd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4206/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a short statement of reasons for the amount of the award.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1e7efe-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4206/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of pendency of investigation or proceeding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Attorney General has not provided the declarant with notice under subsection (b) or a notice of invalidity pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4204"},"text":"section 4204 of this title","children":[],"tail":" within the time period set forth in subsection (e), the Attorney General shall notify the declarant in writing that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd1e7eff-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4206/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a pending investigation or proceeding in the course of which the declarant’s allegations are being addressed; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1e7f00-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4206/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the declarant’s allegations have not yet been addressed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1e7f01-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4206/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for notices","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd1e7f02-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4206/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a valid declaration filed not more than 3 years after ","children":[{"tag":"date","attrib":{"date":"1990-11-29"},"text":"November 29, 1990","children":[],"tail":", the Attorney General shall send notification to a declarant pursuant to subsection (d) not later than 3 years after the date of filing of the declaration."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1e7f03-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4206/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd1e7f04-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4206/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to subparagraph (B), in the case of a declaration filed more than 3 years after ","children":[{"tag":"date","attrib":{"date":"1990-11-29"},"text":"November 29, 1990","children":[],"tail":", the Attorney General shall send notification not later than 1 year after the date of filing of the declaration."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd1e7f05-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4206/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Attorney General certifies that it is in the interest of the United States to give further consideration to the information provided in the declaration for an additional 90-day period, the Attorney General shall so notify the declarant in writing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1e7f06-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4206/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality of notices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All notices provided to a declarant under this section shall be kept confidential by the declarant in the same manner, and subject to the same penalties, as the declaration under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4203"},"text":"section 4203 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd1e7f07-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXV/s2566"},"text":"Pub. L. 101–647, title XXV, § 2566","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4897"},"text":"104 Stat. 4897","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
