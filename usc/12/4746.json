{"tag":"section","attrib":{"id":"iddd3fe97c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4746"},"text":null,"children":[{"tag":"num","attrib":{"value":"4746"},"text":"§ 4746.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd3fe97d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4746/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reserve funds report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On or before the last day of each calendar quarter, a participating State shall submit to the Fund a report of contributions to reserve funds made by the participating State during the previous calendar quarter. If the participating State has made contributions to one or more reserve funds during the previous quarter, the report shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd3fe97e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4746/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" indicate the total amount of such contributions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3fe97f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4746/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" indicate the amount of contributions which is subject to reimbursement, which shall be equal to the total amount of contributions, unless one of the limitations contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4747"},"text":"section 4747 of this title","children":[],"tail":" is applicable;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3fe980-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4746/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if one of the limitations in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4747"},"text":"section 4747 of this title","children":[],"tail":" is applicable, provide documentation of the applicability of such limitation for each loan for which the limitation applies; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3fe981-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4746/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include a certification by the participating State that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd3fe982-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4746/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information provided in accordance with paragraphs (1), (2), and (3) is accurate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3fe983-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4746/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funds in an amount meeting the minimum requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4743/b/3"},"text":"section 4743(b)(3) of this title","children":[],"tail":" continue to be available and legally committed to contributions by the State to reserve funds, less any amount that has been contributed by the State to reserve funds subsequent to the State being approved for participation in the Program;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3fe984-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4746/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there has been no unapproved amendment to any participation agreement or the form of participation agreements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3fe985-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4746/a/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the participating State is otherwise implementing the Program in accordance with this subchapter and regulations issued pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4749"},"text":"section 4749 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3fe986-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4746/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual data","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than March 31 of each year, each participating State shall submit to the Fund annual data indicating the number of borrowers financed under the Program, the total amount of covered loans, and breakdowns by industry type, loan size, annual sales, and number of employees of the borrowers financed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3fe987-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4746/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The reports and data filed pursuant to subsections (a) and (b) shall be in such form as the Fund may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd3fe988-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/tII/s256"},"text":"Pub. L. 103–325, title II, § 256","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2212"},"text":"108 Stat. 2212","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
