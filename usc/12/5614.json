{"tag":"section","attrib":{"id":"iddd7b9386-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5614"},"text":null,"children":[{"tag":"num","attrib":{"value":"5614"},"text":"§ 5614.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exercise of Federal Reserve authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd7b9387-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5614/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No decisions by Federal reserve bank presidents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No provision of subchapter I relating to the authority of the Board of Governors shall be construed as conferring any decision-making authority on presidents of Federal reserve banks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7b9388-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5614/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voting decisions by Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board of Governors shall not delegate the authority to make any voting decision that the Board of Governors is authorized or required to make under subchapter I of this chapter in contravention of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s248/k"},"text":"section 248(k) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd7b9389-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tXI/s1108/d"},"text":"Pub. L. 111–203, title XI, § 1108(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2127"},"text":"124 Stat. 2127","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd7b938a-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd7b938b-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd7b938c-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subchapter I, referred to in text, was in the original “title I”, meaning title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1391"},"text":"124 Stat. 1391","children":[],"tail":", known as the Financial Stability Act of 2010, which is classified principally to subchapter I (§ 5311 et seq.) of this chapter. For complete classification of title I to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
