{"tag":"section","attrib":{"id":"iddd425ae8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4907"},"text":null,"children":[{"tag":"num","attrib":{"value":"4907"},"text":"§ 4907.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil liability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd425ae9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4907/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any servicer, mortgagee, or mortgage insurer that violates a provision of this chapter shall be liable to each mortgagor to whom the violation relates for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd425aea-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4907/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an action by an individual, or a class action in which the liable party is not subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4909"},"text":"section 4909 of this title","children":[],"tail":", any actual damages sustained by the mortgagor as a result of the violation, including interest (at a rate determined by the court) on the amount of actual damages, accruing from the date on which the violation commences;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd425aeb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4907/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd425aec-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4907/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an action by an individual, such statutory damages as the court may allow, not to exceed $2,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd425aed-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4907/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a class action—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd425aee-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4907/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in which the liable party is subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4909"},"text":"section 4909 of this title","children":[],"tail":", such amount as the court may allow, except that the total recovery under this subparagraph in any class action or series of class actions arising out of the same violation by the same liable party shall not exceed the lesser of $500,000 or 1 percent of the net worth of the liable party, as determined by the court; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd425aef-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4907/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in which the liable party is not subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4909"},"text":"section 4909 of this title","children":[],"tail":", such amount as the court may allow, not to exceed $1,000 as to each member of the class, except that the total recovery under this subparagraph in any class action or series of class actions arising out of the same violation by the same liable party shall not exceed the lesser of $500,000 or 1 percent of the gross revenues of the liable party, as determined by the court;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd425af0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4907/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" costs of the action; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd425af1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4907/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reasonable attorney fees, as determined by the court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd425af2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4907/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing of actions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No action may be brought by a mortgagor under subsection (a) later than 2 years after the date of the discovery of the violation that is the subject of the action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd425af3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4907/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on liability","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd425af4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4907/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to a residential mortgage transaction, the failure of a servicer to comply with the requirements of this chapter due to the failure of a mortgage insurer or a mortgagee to comply with the requirements of this chapter, shall not be construed to be a violation of this chapter by the servicer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd425af5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4907/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in paragraph (1) shall be construed to impose any additional requirement or liability on a mortgage insurer, a mortgagee, or a holder of a residential mortgage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd425af6-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/216/s8"},"text":"Pub. L. 105–216, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-29"},"text":"July 29, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/905"},"text":"112 Stat. 905","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd425af7-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd425af8-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd425af9-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 1 year after ","children":[{"tag":"date","attrib":{"date":"1998-07-29"},"text":"July 29, 1998","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/216/s13"},"text":"section 13 of Pub. L. 105–216","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4901"},"text":"section 4901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
