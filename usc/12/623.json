{"tag":"section","attrib":{"id":"iddb4d8f5f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s623"},"text":null,"children":[{"tag":"num","attrib":{"value":"623"},"text":"§ 623.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary liquidation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any corporation organized under this subchapter may go into voluntary liquidation and be closed by a vote of its shareholders owning two-thirds of its stock.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddb4d8f60-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1913-12-23/ch6/s25A"},"text":"Dec. 23, 1913, ch. 6, § 25A","children":[],"tail":" (par.), formerly § 25(a), as added "},{"tag":"ref","attrib":{"href":"/us/act/1919-12-24/ch18"},"text":"Dec. 24, 1919, ch. 18","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/378"},"text":"41 Stat. 378","children":[],"tail":"; renumbered § 25A, "},{"tag":"ref","attrib":{"href":"/us/pl/102/242/tI/s142/e/2"},"text":"Pub. L. 102–242, title I, § 142(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2281"},"text":"105 Stat. 2281","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb4d8f61-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb4d8f62-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddb4d8f63-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Any corporation organized under this subchapter, referred to in text, was in the original “Any such corporation”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddb4d8f64-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of par. 15 (undesignated) of section 25A of act ","children":[{"tag":"date","attrib":{"date":"1913-12-23"},"text":"Dec. 23, 1913","children":[],"tail":", which comprises this subchapter. For complete classification of section 25A of this Act, see Codification note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s611"},"text":"section 611 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
