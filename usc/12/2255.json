{"tag":"section","attrib":{"id":"iddccfe9c5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2255"},"text":null,"children":[{"tag":"num","attrib":{"value":"2255"},"text":"§ 2255.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions of other banks and lending institutions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Comptroller of the Currency is authorized and directed, upon request of the Farm Credit Administration to furnish for confidential use of an institution of the System such reports, records, and other information as he may have available relating to the financial condition of national banks through, for, or with which such institution of the System has made or contemplates making discounts or loans and to make such further examination, as may be agreed, of organizations through, for, or with which such institution of the Farm Credit System has made or contemplates making discounts or loans.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddccfe9c6-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tV/s5"},"text":"Pub. L. 92–181, title V, § 5","children":[],"tail":".20, formerly § 5.21, "},{"tag":"date","attrib":{"date":"1971-12-10"},"text":"Dec. 10, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/623"},"text":"85 Stat. 623","children":[],"tail":"; renumbered § 5.20, "},{"tag":"ref","attrib":{"href":"/us/pl/99/205/tII/s203/b"},"text":"Pub. L. 99–205, title II, § 203(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1694"},"text":"99 Stat. 1694","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddccfe9c7-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddccfe9c8-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"iddccfe9c9-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5.20 of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181"},"text":"Pub. L. 92–181","children":[],"tail":" was renumbered section 5.19 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2254"},"text":"section 2254 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
