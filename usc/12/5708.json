{"tag":"section","attrib":{"id":"iddd7e04f0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5708"},"text":null,"children":[{"tag":"num","attrib":{"value":"5708"},"text":"§ 5708.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation and administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd7e04f1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5708/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authorities and duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd7e04f2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5708/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with the Administrator of the Small Business Administration and the appropriate Federal banking agencies on the administration of the Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e04f3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5708/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish minimum national standards for approved State programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e04f4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5708/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance to States for starting State programs and generally disseminate best practices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e04f5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5708/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" manage, administer, and perform necessary program integrity functions for the Program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e04f6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5708/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure adequate oversight of the approved State programs, including oversight of the cash flows, performance, and compliance of each approved State program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd7e04f7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5708/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby appropriated to the Secretary, out of funds in the Treasury not otherwise appropriated, $1,500,000,000 to carry out the Program, including to pay reasonable costs of administering the Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd7e04f8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5708/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of Secretary’s Program administration functions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authorities and duties of the Secretary to implement and administer the Program shall terminate at the end of the 7-year period beginning on ","children":[{"tag":"date","attrib":{"date":"2021-03-11"},"text":"March 11, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd7e04f9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5708/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expedited contracting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"During the 1-year period beginning on ","children":[{"tag":"date","attrib":{"date":"2021-03-11"},"text":"March 11, 2021","children":[],"tail":", the Secretary may enter into contracts without regard to any other provision of law regarding public contracts, for purposes of carrying out this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd7e04fa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5708/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the amounts appropriated for fiscal year 2021 to carry out the Program, $500,000,000 may be used by the Secretary to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd7e04fb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5708/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide funds to States to carry out a technical assistance plan under which a State will provide legal, accounting, and financial advisory services, either directly or contracted with legal, accounting, and financial advisory firms, with priority given to business enterprises owned and controlled by socially and economically disadvantaged individuals, to very small businesses and business enterprises owned and controlled by socially and economically disadvantaged individuals applying for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd7e04fc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5708/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State programs under the Program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7e04fd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5708/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other State or Federal programs that support small businesses;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e04fe-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5708/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" transfer amounts to the Minority Business Development Agency, so that the Agency may use such amounts in a manner the Agency determines appropriate, including through contracting with third parties, to provide technical assistance to business enterprises owned and controlled by socially and economically disadvantaged individuals applying to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd7e04ff-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5708/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State programs under the Program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7e0500-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5708/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other State or Federal programs that support small businesses; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e0501-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5708/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" contract with legal, accounting, and financial advisory firms (with priority given to business enterprises owned and controlled by socially and economically disadvantaged individuals), to provide technical assistance to business enterprises owned and controlled by socially and economically disadvantaged individuals applying to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd7e0502-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5708/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State programs under the Program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7e0503-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5708/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other State or Federal programs that support small businesses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd7e0504-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/240/tIII/s3009"},"text":"Pub. L. 111–240, title III, § 3009","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-09-27"},"text":"Sept. 27, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2580"},"text":"124 Stat. 2580","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/2/tIII/s3301/a/1/F"},"text":"Pub. L. 117–2, title III, § 3301(a)(1)(F)","children":[],"tail":", (d), "},{"tag":"date","attrib":{"date":"2021-03-11"},"text":"Mar. 11, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/69"},"text":"135 Stat. 69","children":[],"tail":", 70.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd7e0505-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"amendments","id":"iddd7e0506-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2/s3301/a/1/F"},"text":"Pub. L. 117–2, § 3301(a)(1)(F)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2021-03-11"},"text":"March 11, 2021","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2010-09-27"},"text":"September 27, 2010","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2/s3301/d"},"text":"Pub. L. 117–2, § 3301(d)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd7e0507-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd804df8-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2"},"text":"Pub. L. 117–2","children":[],"tail":" applicable with respect to funds appropriated under "},{"tag":"ref","attrib":{"href":"/us/pl/117/2/s3301"},"text":"section 3301 of Pub. L. 117–2","children":[],"tail":" and funds appropriated on and after "},{"tag":"date","attrib":{"date":"2021-03-11"},"text":"Mar. 11, 2021","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/2/s3301/g"},"text":"section 3301(g) of Pub. L. 117–2","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5701"},"text":"section 5701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
