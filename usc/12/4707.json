{"tag":"section","attrib":{"id":"iddd38be8a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707"},"text":null,"children":[{"tag":"num","attrib":{"value":"4707"},"text":"§ 4707.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance provided by Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd38be8b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forms of assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd38be8c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Fund may provide—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd38be8d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" financial assistance through equity investments, deposits, credit union shares, loans, and grants; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd38be8e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" technical assistance—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd38be8f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" directly;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd38be90-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through grants; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd38be91-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by contracting with organizations that possess expertise in community development finance, without regard to whether the organizations receive or are eligible to receive assistance under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd38be92-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equity investments","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd38be93-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on equity investments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Fund shall not own more than 50 percent of the equity of a community development financial institution and may not control the operations of such institution. The Fund may hold only transferable, nonvoting equity investments in the institution. Such equity investments may provide for convertibility to voting stock upon transfer by the Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd38be94-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fund deemed not to control","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the Fund shall not be deemed to control a community development financial institution by reason of any assistance provided under this subchapter for the purpose of any other applicable law to the extent that the Fund complies with subparagraph (A). Nothing in this subparagraph shall affect the application of any Federal tax law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd38be95-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Deposits made pursuant to this section in an insured community development financial institution shall not be subject to any requirement for collateral or security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd38be96-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on obligations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Direct loan obligations may be incurred by the Fund only to the extent that appropriations of budget authority to cover their cost, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s661a/5"},"text":"section 661a(5) of title 2","children":[],"tail":", are made in advance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd38be97-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses of financial assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd38be98-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Financial assistance made available under this subchapter may be used by assisted community development financial institutions to serve investment areas or targeted populations by developing or supporting—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd38be99-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commercial facilities that promote revitalization, community stability, or job creation or retention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd38be9a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" businesses that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd38be9b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide jobs for low-income people or are owned by low-income people; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd38be9c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance the availability of products and services to low-income people;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd38be9d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd38be9e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of basic financial services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd38be9f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" housing that is principally affordable to low-income people, except that assistance used to facilitate homeownership shall only be used for services and lending products—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd38bea0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/b/1/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that serve low-income people; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd38bea1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/b/1/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddd38bea2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/b/1/E/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are not provided by other lenders in the area; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddd38bea3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/b/1/E/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complement the services and lending products provided by other lenders that serve the investment area or targeted population; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd38bea4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other businesses and activities deemed appropriate by the Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd38bea5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No assistance made available under this subchapter may be expended by a community development financial institution (or an organization receiving assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4712"},"text":"section 4712 of this title","children":[],"tail":") to pay any person to influence or attempt to influence any agency, elected official, officer, or employee of a State or local government in connection with the making, award, extension, continuation, renewal, amendment, or modification of any State or local government contract, grant, loan, or cooperative agreement (as such terms are defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1352"},"text":"section 1352 of title 31","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd38bea6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses of technical assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd38bea7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Types of activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Technical assistance may be used for activities that enhance the capacity of a community development financial institution, such as training of management and other personnel and development of programs and investment or loan products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd38bea8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Fund may provide technical assistance, regardless of whether or not the recipient also receives financial assistance under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd38bea9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd38beaa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), the Fund may provide not more than $5,000,000 of assistance, in the aggregate, during any 3-year period to any 1 community development financial institution and its subsidiaries and affiliates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd38beab-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Fund may provide not more than $3,750,000 of assistance in addition to the amount specified in paragraph (1) during the same 3-year period to an existing community development financial institution that proposes to establish a subsidiary or affiliate for the purpose of serving an investment area or targeted population outside of any State and outside of any metropolitan area presently served by the institution, if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd38beac-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the subsidiary or affiliate—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd38bead-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would be a community development financial institution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd38beae-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" independently—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddd38beaf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/d/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets the selection criteria described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4704"},"text":"section 4704 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddd38beb0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/d/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" satisfies the selection criteria of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4706"},"text":"section 4706 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd38beb1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no other application for assistance to serve the investment area or targeted population has been submitted to the Administrator within a reasonable period of time preceding the date of receipt of the application at issue.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd38beb2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing of assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Assistance may be provided as described in paragraphs (1) and (2) in a lump sum or over a period of time, as determined by the Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd38beb3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd38beb4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Assistance other than technical assistance shall be matched with funds from sources other than the Federal Government on the basis of not less than one dollar for each dollar provided by the Fund. Such matching funds shall be at least comparable in form and value to assistance provided by the Fund. The Fund shall provide no assistance (other than technical assistance) until a community development financial institution has secured firm commitments for the matching funds required.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd38beb5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of an applicant with severe constraints on available sources of matching funds, the Fund may permit an applicant to comply with the matching requirements of paragraph (1) by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd38beb6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reducing such matching requirement by 50 percent; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd38beb7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" permitting an applicant to provide matching funds in a form to be determined at the discretion of the Fund, if such applicant—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd38beb8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has total assets of less than $100,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd38beb9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serves nonmetropolitan or rural areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd38beba-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/e/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not requesting more than $25,000 in assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd38bebb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 25 percent of the total funds disbursed in any fiscal year by the Fund may be matched as authorized under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd38bebc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction of “Federal Government funds”","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, notwithstanding section 105(a)(9) of the Housing and Community Development Act of 1974 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5305/a/9"},"text":"42 U.S.C. 5305(a)(9)","children":[],"tail":"], funds provided pursuant to such Act shall be considered to be Federal Government funds."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd38bebd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and conditions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd38bebe-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Soundness of unregulated institutions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Fund shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd38bebf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure, to the maximum extent practicable, that each community development financial institution (other than an insured community development financial institution or depository institution holding company) assisted under this subchapter is financially and managerially sound and maintains appropriate internal controls;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd38bec0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require such institution to submit, not less than once during each 18-month period, a statement of financial condition audited by an independent certified public accountant as part of the report required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4714/e/1"},"text":"section 4714(e)(1) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd38bec1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require that all assistance granted under this section is used by the community development financial institution or community development partnership in a manner consistent with the purposes of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd38bec2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance agreement","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd38bec3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before providing any assistance under this subchapter, the Fund and each community development financial institution to be assisted shall enter into an agreement that requires the institution to comply with performance goals and abide by other terms and conditions pertinent to assistance received under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd38bec4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance goals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Performance goals shall be negotiated between the Fund and each community development financial institution receiving assistance based upon the strategic plan submitted pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4704/b/2"},"text":"section 4704(b)(2) of this title","children":[],"tail":". Such goals may be modified with the consent of the parties, or as provided in subparagraph (C). Performance goals for insured community development financial institutions shall be determined in consultation with the appropriate Federal banking agency."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd38bec5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sanctions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The agreement shall provide that, in the event of fraud, mismanagement, noncompliance with this subchapter, or noncompliance with the terms of the agreement, the Fund, in its discretion, may—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd38bec6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/f/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require changes to the performance goals imposed pursuant to subparagraph (B);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd38bec7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/f/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require changes to the strategic plan submitted pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4704/b/2"},"text":"section 4704(b)(2) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd38bec8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/f/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" revoke approval of the application;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd38bec9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/f/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce or terminate assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd38beca-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/f/2/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require repayment of assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd38becb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/f/2/C/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bar an applicant from reapplying for assistance from the Fund; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd38becc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/f/2/C/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take such other actions as the Fund deems appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd38becd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with tribal governments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In reviewing the performance of any assisted community development financial institution, the investment area of which includes an Indian reservation, or the targeted population of which includes an Indian tribe, the Fund shall consult with, and seek input from, any appropriate tribal government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd38bece-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to sell equity investments and loans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Fund may, at any time, sell its equity investments and loans, but the Fund shall retain the power to enforce limitations on assistance entered into in accordance with the requirements of this subchapter until the performance goals related to the investment or loan have been met.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd38becf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4707/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No authority to limit supervision and regulation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall affect any authority of the appropriate Federal banking agency to supervise and regulate any institution or company.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd38bed0-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/tI/s108"},"text":"Pub. L. 103–325, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2172"},"text":"108 Stat. 2172","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd38bed1-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd38bed2-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd38bed3-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Housing and Community Development Act of 1974, referred to in subsec. (e)(4), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/383"},"text":"Pub. L. 93–383","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-22"},"text":"Aug. 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/633"},"text":"88 Stat. 633","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5301"},"text":"section 5301 of Title 42","children":[],"tail":", The Public Health and Welfare, and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
