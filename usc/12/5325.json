{"tag":"section","attrib":{"id":"iddd52fd15-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5325"},"text":null,"children":[{"tag":"num","attrib":{"value":"5325"},"text":"§ 5325.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enhanced supervision and prudential standards for nonbank financial companies supervised by the Board of Governors and certain bank holding companies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd52fd16-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5325/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd52fd17-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5325/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to prevent or mitigate risks to the financial stability of the United States that could arise from the material financial distress, failure, or ongoing activities of large, interconnected financial institutions, the Council may make recommendations to the Board of Governors concerning the establishment and refinement of prudential standards and reporting and disclosure requirements applicable to nonbank financial companies supervised by the Board of Governors and large, interconnected bank holding companies, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd52fd18-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5325/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are more stringent than those applicable to other nonbank financial companies and bank holding companies that do not present similar risks to the financial stability of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd52fd19-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5325/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase in stringency, based on the considerations identified in subsection (b)(3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd52fd1a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5325/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommended application of required standards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making recommendations under this section, the Council may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd52fd1b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5325/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" differentiate among companies that are subject to heightened standards on an individual basis or by category, taking into consideration their capital structure, riskiness, complexity, financial activities (including the financial activities of their subsidiaries), size, and any other risk-related factors that the Council deems appropriate; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd52fd1c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5325/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommend an asset threshold that is higher than the applicable threshold for the application of any standard described in subsections (c) through (g).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd52fd1d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5325/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development of prudential standards","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd52fd1e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5325/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The recommendations of the Council under subsection (a) may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd52fd1f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5325/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" risk-based capital requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd52fd20-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5325/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leverage limits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd52fd21-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5325/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" liquidity requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd52fd22-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5325/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resolution plan and credit exposure report requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd52fd23-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5325/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" concentration limits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd52fd24-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5325/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a contingent capital requirement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd52fd25-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5325/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhanced public disclosures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd52fd26-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5325/b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" short-term debt limits; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd52fd27-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5325/b/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" overall risk management requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd52fd28-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5325/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prudential standards for foreign financial companies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making recommendations concerning the standards set forth in paragraph (1) that would apply to foreign nonbank financial companies supervised by the Board of Governors or foreign-based bank holding companies, the Council shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd52fd29-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5325/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" give due regard to the principle of national treatment and equality of competitive opportunity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd52fd2a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5325/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take into account the extent to which the foreign nonbank financial company or foreign-based bank holding company is subject on a consolidated basis to home country standards that are comparable to those applied to financial companies in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd52fd2b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5325/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making recommendations concerning prudential standards under paragraph (1), the Council shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd52fd2c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5325/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" take into account differences among nonbank financial companies supervised by the Board of Governors and bank holding companies described in subsection (a), based on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd52fd2d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5325/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the factors described in subsections (a) and (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5323"},"text":"section 5323 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd52fd2e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5325/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the company owns an insured depository institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd52fd2f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5325/b/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nonfinancial activities and affiliations of the company; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd52fd30-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5325/b/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other factors that the Council determines appropriate;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd52fd31-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5325/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent possible, ensure that small changes in the factors listed in subsections (a) and (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5323"},"text":"section 5323 of this title","children":[],"tail":" would not result in sharp, discontinuous changes in the prudential standards established under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5365"},"text":"section 5365 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd52fd32-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5325/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adapt its recommendations as appropriate in light of any predominant line of business of such company, including assets under management or other activities for which particular standards may not be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd52fd33-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5325/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contingent capital","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd52fd34-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5325/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall conduct a study of the feasibility, benefits, costs, and structure of a contingent capital requirement for nonbank financial companies supervised by the Board of Governors and bank holding companies described in subsection (a), which study shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd52fd35-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5325/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of the degree to which such requirement would enhance the safety and soundness of companies subject to the requirement, promote the financial stability of the United States, and reduce risks to United States taxpayers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd52fd36-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5325/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of the characteristics and amounts of contingent capital that should be required;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd52fd37-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5325/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of potential prudential standards that should be used to determine whether the contingent capital of a company would be converted to equity in times of financial stress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd52fd38-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5325/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of the costs to companies, the effects on the structure and operation of credit and other financial markets, and other economic effects of requiring contingent capital;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd52fd39-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5325/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of the effects of such requirement on the international competitiveness of companies subject to the requirement and the prospects for international coordination in establishing such requirement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd52fd3a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5325/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for implementing regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd52fd3b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5325/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall submit a report to Congress regarding the study required by paragraph (1) not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd52fd3c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5325/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd52fd3d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5325/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsequent to submitting a report to Congress under paragraph (2), the Council may make recommendations to the Board of Governors to require any nonbank financial company supervised by the Board of Governors and any bank holding company described in subsection (a) to maintain a minimum amount of contingent capital that is convertible to equity in times of financial stress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd52fd3e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5325/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors to consider","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making recommendations under this subsection, the Council shall consider—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd52fd3f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5325/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an appropriate transition period for implementation of a conversion under this subsection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd52fd40-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5325/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the factors described in subsection (b)(3);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd52fd41-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5325/c/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" capital requirements applicable to a nonbank financial company supervised by the Board of Governors or a bank holding company described in subsection (a), and subsidiaries thereof;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd52fd42-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5325/c/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" results of the study required by paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd52fd43-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5325/c/3/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other factor that the Council deems appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd52fd44-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5325/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Resolution plan and credit exposure reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd52fd45-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5325/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Resolution plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council may make recommendations to the Board of Governors concerning the requirement that each nonbank financial company supervised by the Board of Governors and each bank holding company described in subsection (a) report periodically to the Council, the Board of Governors, and the Corporation, the plan of such company for rapid and orderly resolution in the event of material financial distress or failure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd52fd46-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5325/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit exposure report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council may make recommendations to the Board of Governors concerning the advisability of requiring each nonbank financial company supervised by the Board of Governors and bank holding company described in subsection (a) to report periodically to the Council, the Board of Governors, and the Corporation on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd52fd47-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5325/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature and extent to which the company has credit exposure to other significant nonbank financial companies and significant bank holding companies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd52fd48-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5325/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature and extent to which other such significant nonbank financial companies and significant bank holding companies have credit exposure to that company.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd52fd49-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5325/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Concentration limits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to limit the risks that the failure of any individual company could pose to nonbank financial companies supervised by the Board of Governors or bank holding companies described in subsection (a), the Council may make recommendations to the Board of Governors to prescribe standards to limit such risks, as set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5365"},"text":"section 5365 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd52fd4a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5325/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enhanced public disclosures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council may make recommendations to the Board of Governors to require periodic public disclosures by bank holding companies described in subsection (a) and by nonbank financial companies supervised by the Board of Governors, in order to support market evaluation of the risk profile, capital adequacy, and risk management capabilities thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd52fd4b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5325/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short-term debt limits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council may make recommendations to the Board of Governors to require short-term debt limits to mitigate the risks that an over-accumulation of such debt could pose to bank holding companies described in subsection (a), nonbank financial companies supervised by the Board of Governors, or the financial system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd52fd4c-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tI/s115"},"text":"Pub. L. 111–203, title I, § 115","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1403"},"text":"124 Stat. 1403","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/174/tIV/s401/c/1/A"},"text":"Pub. L. 115–174, title IV, § 401(c)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-05-24"},"text":"May 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1358"},"text":"132 Stat. 1358","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd52fd4d-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd52fd4e-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd52fd4f-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/174"},"text":"Pub. L. 115–174","children":[],"tail":" substituted “the applicable threshold” for “$50,000,000,000”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd52fd50-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd52fd51-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Except as otherwise provided, amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/174"},"text":"Pub. L. 115–174","children":[],"tail":" effective 18 months after "},{"tag":"date","attrib":{"date":"2018-05-24"},"text":"May 24, 2018","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/174/s401/d"},"text":"section 401(d) of Pub. L. 115–174","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5365"},"text":"section 5365 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd52fd52-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For construction of amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/174"},"text":"Pub. L. 115–174","children":[],"tail":" as applied to certain foreign banking organizations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/174/s401/g"},"text":"section 401(g) of Pub. L. 115–174","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5365"},"text":"section 5365 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
