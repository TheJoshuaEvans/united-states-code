{"tag":"section","attrib":{"id":"iddb086fc5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s25a"},"text":null,"children":[{"tag":"num","attrib":{"value":"25a"},"text":"§ 25a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation by national banks in lotteries and related activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddb086fc6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s25a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A national bank may not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb086fc7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s25a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deal in lottery tickets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb086fc8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s25a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deal in bets used as a means or substitute for participation in a lottery;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb086fc9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s25a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" announce, advertise, or publicize the existence of any lottery; ","children":[{"tag":"ref","attrib":{"idref":"fn002007"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002007"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The word “or” probably should appear."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb086fca-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s25a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" announce, advertise, or publicize the existence or identity of any participant or winner, as such, in a lottery.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb086fcb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s25a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of banking premises prohibited","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A national bank may not permit—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb086fcc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s25a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of any part of any of its banking offices by any person for any purpose forbidden to the bank under subsection (a), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb086fcd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s25a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct access by the public from any of its banking offices to any premises used by any person for any purpose forbidden to the bank under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb086fce-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s25a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb086fcf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s25a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “deal in” includes making, taking, buying, selling, redeeming, or collecting.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb086fd0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s25a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “lottery” includes any arrangement, other than a savings promotion raffle, whereby three or more persons (the “participants”) advance money or credit to another in exchange for the possibility or expectation that one or more but not all of the participants (the “winners”) will receive by reason of their advances more than the amounts they have advanced, the identity of the winners being determined by any means which includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddb086fd1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s25a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a random selection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb086fd2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s25a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a game, race, or contest; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb086fd3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s25a/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any record or tabulation of the result of one or more events in which any participant has no interest except for its bearing upon the possibility that he may become a winner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb086fd4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s25a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “lottery ticket” includes any right, privilege, or possibility (and any ticket, receipt, record, or other evidence of any such right, privilege, or possibility) of becoming a winner in a lottery.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb086fd5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s25a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “savings promotion raffle” means a contest in which the sole consideration required for a chance of winning designated prizes is obtained by the deposit of a specified amount of money in a savings account or other savings program, where each ticket or entry has an equal chance of being drawn, such contest being subject to regulations that may from time to time be promulgated by the appropriate prudential regulator (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5481"},"text":"section 5481 of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb086fd6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s25a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lawful banking services connected with operation of lotteries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing contained in this section prohibits a national bank from accepting deposits or cashing or otherwise handling checks or other negotiable instruments, or performing other lawful banking services for a State operating a lottery, or for an officer or employee of that State who is charged with the administration of the lottery.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb086fd7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s25a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations; enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Comptroller of the Currency shall issue such regulations as may be necessary to the strict enforcement of this section and the prevention of evasions thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddb086fd8-3a6f-11f1-8fa0-c065796a7f06"},"text":"(R.S. § 5136B, formerly § 5136A, as added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/203/s1/a"},"text":"Pub. L. 90–203, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-12-15"},"text":"Dec. 15, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/608"},"text":"81 Stat. 608","children":[],"tail":"; renumbered R.S. § 5136B, "},{"tag":"ref","attrib":{"href":"/us/pl/106/102/tI/s121/a/1"},"text":"Pub. L. 106–102, title I, § 121(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1373"},"text":"113 Stat. 1373","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/251/s3/a"},"text":"Pub. L. 113–251, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2889"},"text":"128 Stat. 2889","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb086fd9-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb086fda-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddb086fdb-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/251/s3/a/1"},"text":"Pub. L. 113–251, § 3(a)(1)","children":[],"tail":", inserted “, other than a savings promotion raffle,” before “whereby” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/251/s3/a/2"},"text":"Pub. L. 113–251, § 3(a)(2)","children":[],"tail":", added par. (4)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddb086fdc-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddb086fdd-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/90/203/s6"},"text":"Pub. L. 90–203, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-12-15"},"text":"Dec. 15, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/611"},"text":"81 Stat. 611","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/90/203/s6"},"text":"“The amendments made by this Act [adding this section, sections 339, 1730c, and 1829a of this title, and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1306"},"text":"section 1306 of Title 18","children":[],"tail":", Crimes and Criminal Procedure] shall take effect on "},{"tag":"date","attrib":{"date":"1968-04-01"},"text":"April 1, 1968","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddb086fde-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/251/s2"},"text":"Pub. L. 113–251, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2888"},"text":"128 Stat. 2888","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/251/s2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Congress finds that—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the annual savings rate in the United States was 4.1 percent in 2012;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" more than 40 percent of American households lack the savings to cover basic expenses for 3 months, if an unexpected event leads to a loss of stable income;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" personal savings provide Americans with the financial resources to meet future needs, including higher education and homeownership, while also providing a safety net to weather unexpected financial shocks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prize-linked savings products are typical savings products offered by financial institutions, like savings accounts, certificates of deposit, and savings bonds, with the added feature of offering chances to win prizes based on deposit activity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State of Michigan was the first State to allow credit unions to offer prize-linked savings products, and in 2009 launched the first large-scale prize-linked savings product in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the States of Connecticut, Michigan, Maine, Maryland, Nebraska, North Carolina, Rhode Island, and Washington all have laws that allow financial institutions to offer prize-linked savings products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the States of Michigan and Nebraska, more than 42,000 individuals have opened prize-linked savings accounts and saved more than $72,000,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"“(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prize-linked savings products have been shown to successfully attract non-savers, the asset poor, and low-to-moderate income groups, providing individuals with a new tool to build personal savings; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"“(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encouraging personal savings is in the national interest of the United States.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
