{"tag":"section","attrib":{"id":"iddd1e7f23-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4213"},"text":null,"children":[{"tag":"num","attrib":{"value":"4213"},"text":"§ 4213.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promulgation of regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Attorney General may promulgate any rules, regulations, or guidelines that, in the Attorney General’s judgment, are necessary and appropriate to the effective administration of this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd1e7f24-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXV/s2573"},"text":"Pub. L. 101–647, title XXV, § 2573","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4899"},"text":"104 Stat. 4899","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
