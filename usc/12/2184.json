{"tag":"section","attrib":{"id":"iddcc8be2d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2184"},"text":null,"children":[{"tag":"num","attrib":{"value":"2184"},"text":"§ 2184.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Communications with stockholders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcc8be2e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2184/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of stockholder lists","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcc8be2f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2184/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Farm Credit System bank or association shall provide to a stockholder of the bank or association a current list of stockholders of the bank or association not later than 7 calendar days after the date on which the bank or association receives a written request for the stockholder list from the stockholder.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc8be30-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2184/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As a condition of providing a stockholder list under paragraph (1), the bank or association may require that the stockholder agree and certify in writing that the stockholder will—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcc8be31-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2184/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use the list exclusively for communicating with stockholders for permissible purposes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcc8be32-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2184/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not make the list available to any person, other than the stockholder’s attorney or accountant, without first obtaining the written consent of the institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcc8be33-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2184/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternative communications","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcc8be34-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2184/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Request to issue","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As an alternative to receiving a list of stockholders, a stockholder may request the institution to mail or otherwise furnish to each stockholder a communication for a permissible purpose on behalf of the requesting stockholder.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc8be35-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2184/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" When permissible","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Alternative communications may be used, at the discretion of the requesting stockholder, if the requester agrees to defray the reasonable costs of the communication. If the requester decides to exercise this option, the institution shall provide the requester with a written estimate of the costs of handling and mailing the communication as soon as is practicable after receipt of the stockholder’s request to furnish the communication.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcc8be36-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tIV/s4"},"text":"Pub. L. 92–181, title IV, § 4","children":[],"tail":".12A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tIV/s420"},"text":"Pub. L. 100–233, title IV, § 420","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1653"},"text":"101 Stat. 1653","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tV/s5411/21"},"text":"Pub. L. 115–334, title V, § 5411(21)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4681"},"text":"132 Stat. 4681","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcc8be37-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcc8be38-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcc8be39-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" added par. (1) and struck out former par. (1). Prior to amendment, text read as follows: “Within 7 days after receipt of a written request by a stockholder, a bank for cooperatives, Federal land bank association, or production credit association shall provide a current list of its stockholders to such requesting stockholder.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
