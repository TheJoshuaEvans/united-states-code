{"tag":"section","attrib":{"id":"iddc9b6bae-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831o–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1831o–1"},"text":"§ 1831o–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Source of strength","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc9b6baf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831o–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Holding companies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The appropriate Federal banking agency for a bank holding company or savings and loan holding company shall require the bank holding company or savings and loan holding company to serve as a source of financial strength for any subsidiary of the bank holding company or savings and loan holding company that is a depository institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc9b6bb0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831o–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other companies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an insured depository institution is not the subsidiary of a bank holding company or savings and loan holding company, the appropriate Federal banking agency for the insured depository institution shall require any company that directly or indirectly controls the insured depository institution to serve as a source of financial strength for such institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc9b6bb1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831o–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of State insurance regulator","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc9b6bb2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831o–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1844/g"},"text":"section 1844(g) of this title","children":[],"tail":" shall apply to a savings and loan holding company that is an insurance company, an affiliate of an insured depository institution that is an insurance company, and to any other company that is an insurance company and that directly or indirectly controls an insured depository institution, to the same extent as the provisions of that section apply to a bank holding company that is an insurance company."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc9b6bb3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831o–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Requiring a bank holding company that is an insurance company, a savings and loan holding company that is an insurance company, an affiliate of an insured depository institution that is an insurance company, or any other company that is an insurance company and that directly or indirectly controls an insured depository institution to serve as a source of financial strength under this section shall be deemed an action of the Board that requires a bank holding company to provide funds or other assets to a subsidiary depository institution for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1844/g"},"text":"section 1844(g) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc9b6bb4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831o–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The appropriate Federal banking agency for an insured depository institution described in subsection (b) may, from time to time, require the company, or a company that directly or indirectly controls the insured depository institution, to submit a report, under oath, for the purposes of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc9b6bb5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831o–1/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessing the ability of such company to comply with the requirement under subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc9b6bb6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831o–1/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enforcing the compliance of such company with the requirement under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc9b6bb7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831o–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after the transfer date, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5411"},"text":"section 5411 of this title","children":[],"tail":", the appropriate Federal banking agencies shall jointly issue final rules to carry out this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc9b6bb8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831o–1/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “source of financial strength” means the ability of a company that directly or indirectly owns or controls an insured depository institution to provide financial assistance to such insured depository institution in the event of the financial distress of the insured depository institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc9b6bb9-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-21/ch967/s2"},"text":"Sept. 21, 1950, ch. 967, § 2","children":[],"tail":"[38A], as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tVI/s616/d"},"text":"Pub. L. 111–203, title VI, § 616(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1616"},"text":"124 Stat. 1616","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/113/dO/tVII/s706/a"},"text":"Pub. L. 114–113, div. O, title VII, § 706(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/3029"},"text":"129 Stat. 3029","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc9b6bba-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc9b6bbb-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc9b6bbc-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsecs. (c) to (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113"},"text":"Pub. L. 114–113","children":[],"tail":" added subsec. (c) and redesignated former subsecs. (c) to (e) as (d) to (f), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc9b6bbd-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddc9b6bbe-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the transfer date, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s616/e"},"text":"section 616(e) of Pub. L. 111–203","children":[],"tail":", set out as an Effective Date of 2010 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1467a"},"text":"section 1467a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
