{"tag":"section","attrib":{"id":"iddd06b18a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3350"},"text":null,"children":[{"tag":"num","attrib":{"value":"3350"},"text":"§ 3350.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd06b18b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3350/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State appraiser certifying and licensing agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State appraiser certifying and licensing agency” means a State agency established in compliance with this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd06b18c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3350/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appraisal Subcommittee; subcommittee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “Appraisal Subcommittee” and “subcommittee” mean the Appraisal Subcommittee of the Federal Financial Institutions Examination Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd06b18d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3350/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Council","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Council” means the Federal Financial Institutions Examinations Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd06b18e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3350/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federally related transaction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “federally related transaction” means any real estate-related financial transaction which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd06b18f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3350/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a federal financial institutions regulatory agency or the Resolution Trust Corporation engages in, contracts for, or regulates; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd06b190-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3350/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requires the services of an appraiser.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd06b191-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3350/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Real estate related financial transaction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “real estate-related financial transaction” means any transaction involving—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd06b192-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3350/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sale, lease, purchase, investment in or exchange of real property, including interests in property, or the financing thereof;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd06b193-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3350/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the refinancing of real property or interests in real property; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd06b194-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3350/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of real property or interests in property as security for a loan or investment, including mortgage-backed securities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd06b195-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3350/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal financial institutions regulatory agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Federal financial institutions regulatory agencies” means the Board of Governors of the Federal Reserve System, the Federal Deposit Insurance Corporation, the Office of the Comptroller of the Currency, the Office of Thrift Supervision, and the National Credit Union Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd06b196-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3350/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “financial institution” means an insured depository institution as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"section 1813 of this title","children":[],"tail":" or an insured credit union as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1752"},"text":"section 1752 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd06b197-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3350/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Chairperson” means the Chairperson of the Appraisal Subcommittee selected by the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd06b198-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3350/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foundation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “Appraisal Foundation” and “Foundation” means the Appraisal Foundation established on ","children":[{"tag":"date","attrib":{"date":"1987-11-30"},"text":"November 30, 1987","children":[],"tail":", as a not for profit corporation under the laws of Illinois."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd06b199-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3350/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Written appraisal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “written appraisal” means a written statement used in connection with a federally related transaction that is independently and impartially prepared by a licensed or certified appraiser setting forth an opinion of defined value of an adequately described property as of a specific date, supported by presentation and analysis of relevant market information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd06b19a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3350/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appraisal management company","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “appraisal management company” means, in connection with valuing properties collateralizing mortgage loans or mortgages incorporated into a securitization, any external third party authorized either by a creditor of a consumer credit transaction secured by a consumer’s principal dwelling or by an underwriter of or other principal in the secondary mortgage markets, that oversees a network or panel of more than 15 certified or licensed appraisers in a State or 25 or more nationally within a given year—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd06b19b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3350/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to recruit, select, and retain appraisers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd06b19c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3350/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to contract with licensed and certified appraisers to perform appraisal assignments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd06b19d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3350/11/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to manage the process of having an appraisal performed, including providing administrative duties such as receiving appraisal orders and appraisal reports, submitting completed appraisal reports to creditors and underwriters, collecting fees from creditors and underwriters for services provided, and reimbursing appraisers for services performed; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd06b19e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3350/11/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to review and verify the work of appraisers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd06b19f-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/tXI/s1121"},"text":"Pub. L. 101–73, title XI, § 1121","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/517"},"text":"103 Stat. 517","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tXIV/s1473/f/4"},"text":"Pub. L. 111–203, title XIV, § 1473(f)(4)","children":[],"tail":", (t)(2), (3), "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2193"},"text":"124 Stat. 2193","children":[],"tail":", 2199.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd06b1a0-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd06b1a1-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd06b1a2-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Par. (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1473/t/2"},"text":"Pub. L. 111–203, § 1473(t)(2)","children":[],"tail":", substituted “Corporation,” for “Corporations,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1473/t/3"},"text":"Pub. L. 111–203, § 1473(t)(3)","children":[],"tail":", substituted “Council” for “council”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1473/f/4"},"text":"Pub. L. 111–203, § 1473(f)(4)","children":[],"tail":", added par. (11)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd06b1a3-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd06b1a4-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective on the date on which final regulations implementing that amendment take effect, or on the date that is 18 months after the designated transfer date if such regulations have not been issued by that date, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1400/c"},"text":"section 1400(c) of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1601"},"text":"section 1601 of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
