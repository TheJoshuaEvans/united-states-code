{"tag":"section","attrib":{"id":"iddccd793a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2250"},"text":null,"children":[{"tag":"num","attrib":{"value":"2250"},"text":"§ 2250.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Farm Credit Administration operating expenses fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddccd793b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2250/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determinations required","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddccd793c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2250/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Generally","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Prior to the first day of each fiscal year, the Farm Credit Administration shall determine—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddccd793d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2250/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of administering this chapter for the subsequent fiscal year, including expenses for official functions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddccd793e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2250/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of assessments that will be required to pay such administrative expenses, taking into consideration the funds contained in the Administrative Expense Account, and maintain a necessary reserve; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddccd793f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2250/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of assessments that will be required to pay the costs of supervising and examining the Mortgage Corporation established under subchapter VIII.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddccd7940-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2250/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Apportionments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On the basis of the determinations made under paragraph (1), the Farm Credit Administration shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddccd7941-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2250/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" apportion the amount of the assessment described in paragraph (1)(B) among the System institutions on a basis that is determined to be equitable by the Farm Credit Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddccd7942-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2250/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess and collect such apportioned amounts from time to time during the fiscal year as determined necessary by the Farm Credit Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddccd7943-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2250/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess and collect from the Mortgage Corporation, from time to time during the fiscal year, the amount described in paragraph (1)(C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddccd7944-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2250/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposits into fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddccd7945-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2250/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treasury fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amounts collected under subsection (a) shall be deposited in the Farm Credit Administration Administrative Expense Account. The Expense Account shall be maintained in the Treasury of the United States and shall be available, without regard, for purposes of sequestration, to the Balanced Budget and Emergency Deficit Control Act of 1985 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s900"},"text":"2 U.S.C. 900","children":[],"tail":" et seq.], to pay the expenses of the Farm Credit Administration."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddccd7946-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2250/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nongovernment funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The funds contained in the Expense Account shall not be construed to be Federal Government funds or appropriated moneys.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddccd7947-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2250/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddccd7948-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2250/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On request of the Farm Credit Administration, the Secretary of the Treasury shall invest and reinvest such amounts contained in the Expense Account as, in the determination of the Farm Credit Administration, are in excess of the amounts necessary for current expenses of the Farm Credit Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddccd7949-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2250/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Returns","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All income earned from such investments and reinvestments shall be deposited in the Expense Account.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddccd794a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2250/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Type","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such investments shall be made in public debt securities with maturities suitable to the needs of the Expense Account, as determined by the Farm Credit Administration, and bearing interest at rates determined by the Secretary of the Treasury, taking into consideration current market yields on outstanding marketable obligations of the United States of comparable maturities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddccd794b-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tV/s5"},"text":"Pub. L. 92–181, title V, § 5","children":[],"tail":".15, formerly § 5.16, "},{"tag":"date","attrib":{"date":"1971-12-10"},"text":"Dec. 10, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/620"},"text":"85 Stat. 620","children":[],"tail":"; renumbered § 5.15 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/205/tII"},"text":"Pub. L. 99–205, title II","children":[],"tail":", §§ 201(5), 205(g)(6), "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1690"},"text":"99 Stat. 1690","children":[],"tail":", 1707; "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tIV/s432/a"},"text":"Pub. L. 100–233, title IV, § 432(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1660"},"text":"101 Stat. 1660","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/tIV/s416/a"},"text":"Pub. L. 100–399, title IV, § 416(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1988-08-17"},"text":"Aug. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1004"},"text":"102 Stat. 1004","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/552/tV/s510"},"text":"Pub. L. 102–552, title V, § 510","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4132"},"text":"106 Stat. 4132","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddccd794c-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddccd794d-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddccd794e-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Balanced Budget and Emergency Deficit Control Act of 1985, referred to in subsec. (b)(1), is title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/177"},"text":"Pub. L. 99–177","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-12"},"text":"Dec. 12, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1038"},"text":"99 Stat. 1038","children":[],"tail":", which enacted chapter 20 (§ 900 et seq.) and sections 654 to 656 of Title 2, The Congress, amended sections 602, 622, 631 to 642, and 651 to 653 of Title 2, sections 1104 to 1106, and 1109 of Title 31, Money and Finance, and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s911"},"text":"section 911 of Title 42","children":[],"tail":", The Public Health and Welfare, repealed "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s661"},"text":"section 661 of Title 2","children":[],"tail":", enacted provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s900"},"text":"section 900 of Title 2","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s911"},"text":"section 911 of Title 42","children":[],"tail":", and amended provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s621"},"text":"section 621 of Title 2","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s900"},"text":"section 900 of Title 2","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"iddccd794f-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5.15 of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181"},"text":"Pub. L. 92–181","children":[],"tail":" was renumbered section 5.14 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2249"},"text":"section 2249 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddccd7950-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/552"},"text":"Pub. L. 102–552","children":[],"tail":" inserted “, for purposes of sequestration,” after “regard” and struck out “or any other law” before “, to pay the expenses”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/233"},"text":"Pub. L. 100–233","children":[],"tail":" amended section generally. Prior to amendment, section read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) The Farm Credit Administration shall prior to the first day of each fiscal year estimate the cost of administrative expenses for the ensuing fiscal year in administering this chapter, including official functions, and shall apportion the amount so determined among the institutions of the System on such equitable basis as the Farm Credit Administration shall determine, and shall assess against and collect in advance the amounts so apportioned from the institutions among which the apportionment is made.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) The amounts collected pursuant to subsection (a) of this section shall be covered into the Treasury, and credited to a special fund and, without regard to other law, shall be available to the Farm Credit Administration for expenditure during each fiscal year for salaries and expenses of the Farm Credit Administration. As soon as practicable after the end of each such fiscal year, the Farm Credit Administration shall determine, on a fair and reasonable basis, the cost of operation of the Farm Credit Administration and the part thereof which fairly and equitably should be allocated to each bank and association as its share of the cost during the fiscal year of the Farm Credit Administration. If the amount so allocated is greater than the amount collected from the bank or other institutions, the difference shall be collected from such bank or other institutions, and, if less, shall be refunded from the special fund to the bank or other institutions entitled thereto or credited in the special fund to such bank or other institutions for use for the same purposes in future fiscal years.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s416/a"},"text":"Pub. L. 100–399, § 416(a)","children":[],"tail":", substituted “the assessment described in paragraph (1)(B)” for “such assessment”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s416/b"},"text":"Pub. L. 100–399, § 416(b)","children":[],"tail":", substituted “described” for “specified”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/205/s205/g/6"},"text":"Pub. L. 99–205, § 205(g)(6)","children":[],"tail":", substituted “the Farm Credit Administration” for “said Administration” twice in first sentence, and for “the Administration” and “such Administration” in second sentence."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddccd7951-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddccd7952-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399"},"text":"Pub. L. 100–399","children":[],"tail":" effective as if enacted immediately after enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/100/233"},"text":"Pub. L. 100–233","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/s1001/a"},"text":"section 1001(a) of Pub. L. 100–399","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2002"},"text":"section 2002 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddccd7953-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1985 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/205"},"text":"Pub. L. 99–205","children":[],"tail":" effective thirty days after "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/205/s401"},"text":"section 401 of Pub. L. 99–205","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2001"},"text":"section 2001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
