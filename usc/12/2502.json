{"tag":"section","attrib":{"id":"iddceee37e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2502"},"text":null,"children":[{"tag":"num","attrib":{"value":"2502"},"text":"§ 2502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddceee37f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2502/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “banking organization” means any bank, trust company, savings bank, safe deposit company, or a private banker engaged in business in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddceee380-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2502/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “business association” means any corporation (other than a public corporation), joint stock company, business trust, partnership, or any association for business purposes of two or more individuals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddceee381-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2502/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “financial organization” means any savings and loan association, building and loan association, credit union, or investment company engaged in business in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddceee382-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/495/tVI/s602"},"text":"Pub. L. 93–495, title VI, § 602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-28"},"text":"Oct. 28, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1525"},"text":"88 Stat. 1525","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
