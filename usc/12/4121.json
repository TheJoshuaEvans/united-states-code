{"tag":"section","attrib":{"id":"iddd1c3549-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4121"},"text":null,"children":[{"tag":"num","attrib":{"value":"4121"},"text":"§ 4121.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions of qualified and priority purchaser and related party rule","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd1c354a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4121/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority purchaser","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “priority purchaser” means (A) a resident council organized to acquire the housing in accordance with a resident homeownership program that meets the requirements of section 4121 ","children":[{"tag":"ref","attrib":{"idref":"fn002375"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002375"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be section “4116”."}],"tail":" of this title; and (B) any nonprofit organization or State or local agency that agrees to maintain low-income affordability restrictions for the remaining useful life of the housing (as determined under section 4112(d) "},{"tag":"ref","attrib":{"idref":"fn002376"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002376"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be section “4112(c)”."}],"tail":" of this title)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1c354b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4121/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified purchaser","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “qualified purchaser” means any entity that agrees to maintain low-income affordability restrictions for the remaining useful life of the housing (as determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4112/c"},"text":"section 4112(c) of this title","children":[],"tail":"), and includes for-profit entities and priority purchasers."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1c354c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4121/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Related parties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (d), the terms “qualified purchaser” and “priority purchaser” do not include any entity that, either directly or indirectly, is wholly or partially owned or controlled by the owner of the housing being transferred under this subchapter, is under whole or partial common control with such owner, or has any financial interest in such owner or in which such owner has any financial interest. The Secretary shall issue any regulations appropriate to implement the preceding sentence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1c354d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4121/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A qualified purchaser shall not be precluded from retaining as a property management entity a company that is owned or controlled by the selling owner or a principal thereof if retention of the management company is neither a condition of sale nor part of consideration paid for sale and the property management contract is negotiated by the qualified purchaser on an arm’s length basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd1c354e-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/242/tII/s231"},"text":"Pub. L. 100–242, title II, § 231","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/625/tVI/s601/a"},"text":"Pub. L. 101–625, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4273"},"text":"104 Stat. 4273","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tIII/s317/a/6"},"text":"Pub. L. 102–550, title III, § 317(a)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3772"},"text":"106 Stat. 3772","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd1c354f-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd1c3550-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd1c3551-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550"},"text":"Pub. L. 102–550","children":[],"tail":" substituted “4112(c)” for “4112(d)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
