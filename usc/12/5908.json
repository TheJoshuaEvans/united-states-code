{"tag":"section","attrib":{"id":"iddd8508a7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5908"},"text":null,"children":[{"tag":"num","attrib":{"value":"5908"},"text":"§ 5908.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Anti-money laundering innovation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd8508a8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5908/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public comment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Beginning on the date that is 30 days after ","children":[{"tag":"date","attrib":{"date":"2025-07-18"},"text":"July 18, 2025","children":[],"tail":", and for a period of 60 days thereafter, the Secretary of the Treasury shall seek public comment to identify innovative or novel methods, techniques, or strategies that regulated financial institutions use, or have the potential to use, to detect illicit activity, such as money laundering, involving digital assets, including comments with respect to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd8508a9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5908/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" application program interfaces;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd8508aa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5908/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" artificial intelligence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd8508ab-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5908/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" digital identify verification; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd8508ac-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5908/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use of blockchain technology and monitoring.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd8508ad-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5908/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treasury research","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd8508ae-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5908/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon completion of the public comment period described in subsection (a), the Secretary of the Treasury shall conduct research on the innovative or novel methods, techniques, or strategies that regulated financial institutions use, or have the potential to use, to detect illicit activity, such as money laundering, involving digital assets that were identified in such public comment period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd8508af-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5908/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research factors","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to each innovative or novel method, technique, or strategy described in paragraph (1), the Financial Crimes Enforcement Network shall evaluate and consider the following factors against existing methods, techniques, or strategies:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd8508b0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5908/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Improvements in the ability of financial institutions to detect illicit activity involving digital assets.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd8508b1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5908/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Costs to regulated financial institutions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd8508b2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5908/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount and sensitivity of information that is collected or reviewed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd8508b3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5908/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Privacy risks associated with the information that is collected or reviewed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd8508b4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5908/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Operational challenges and efficiency considerations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd8508b5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5908/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Cybersecurity risks.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd8508b6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5908/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Effectiveness of methods, techniques, or strategies at mitigating illicit finance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd8508b7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5908/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treasury risk assessment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As part of the national strategy for combating terrorist and other illicit financing required under sections 261 and 262 of the Countering America’s Adversaries Through Sanctions Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/44"},"text":"Public Law 115–44","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/131/934"},"text":"131 Stat. 934","children":[],"tail":"), the Secretary of the Treasury shall consider—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd8508b8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5908/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the source of illicit activity, such as money laundering and sanctions evasion involving digital assets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd8508b9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5908/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effectiveness of and gaps in existing methods, techniques, and strategies used by regulated financial institutions in detecting illicit activity, such as money laundering, involving digital assets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd8508ba-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5908/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact of existing regulatory frameworks on the use and development of innovative methods, techniques, or strategies by regulated financial institutions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd8508bb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5908/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any foreign jurisdictions that pose a high risk of facilitating illicit activity through the use of digital assets to obtain fiat currency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd8508bc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5908/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" FinCEN guidance or rulemaking","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"2025-07-18"},"text":"July 18, 2025","children":[],"tail":", the Financial Crimes Enforcement Network shall issue public guidance and notice and comment rulemaking, based on the results of the research and risk assessments required under this section, relating to the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd8508bd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5908/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The implementation of innovative or novel methods, techniques, or strategies by regulated financial institutions to detect illicit activity involving digital assets.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd8508be-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5908/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Standards for payment stablecoin issuers to identify and report illicit activity involving the payment stablecoin of a permitted payment stablecoin issuer, including, fraud, cybercrime, money laundering, financing of terrorism, sanctions evasion, or insider trading.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd8508bf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5908/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Standards for payment stablecoin issuers’ systems and practices to monitor transactions on blockchains, digital asset mixing services, tumblers, or other similar services that mix payment stablecoins in such a way as to make such transaction or the identity of the transaction parties less identifiable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd8508c0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5908/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Tailored risk management standards for financial institutions interacting with decentralized finance protocols.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd8508c1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5908/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendations and report to Congress","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd8508c2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5908/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2025-07-18"},"text":"July 18, 2025","children":[],"tail":", the Secretary of the Treasury shall submit to the chairs and ranking members of the Committee on Banking, Housing, and Urban Affairs of the Senate and the Committee on Financial Services of the House of Representatives a report on—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd8508c3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5908/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" legislative and regulatory proposals to allow regulated financial institutions to develop and implement novel and innovative methods, techniques, or strategies to detect illicit activity, such as money laundering and sanctions evasion, involving digital assets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd8508c4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5908/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the results of the research and risk assessments conducted pursuant to this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd8508c5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5908/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" efforts to support the ability of financial institutions to implement novel and innovative methods, techniques, or strategies to detect illicit activity, such as money laundering and sanctions evasion, involving digital assets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd8508c6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5908/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which transactions on distributed ledgers, digital asset mixing services, tumblers, or other similar services that mix payment stablecoins in such a way as to make such transaction or the identity of the transaction parties less identifiable may facilitate illicit activity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd8508c7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5908/e/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" legislative recommendations relating to the scope of the term “digital asset service provider” and the application of that term to decentralized finance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd8508c8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5908/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Classified annex","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A report under this section may include a classified annex, if applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd8508c9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5908/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to limit the existing authority of the Secretary of the Treasury or the primary Federal payment stablecoin regulators to, prior to the submission of a report required under this section, use existing exemptive authorities, the no-action letter process, or rulemaking authorities in a manner that encourages regulated financial institutions to adopt novel or innovative methods, techniques, or strategies to detect illicit activity, such as money laundering, involving digital assets.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd8508ca-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/27/s9"},"text":"Pub. L. 119–27, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-18"},"text":"July 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/453"},"text":"139 Stat. 453","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd8508cb-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"iddd8508cc-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Delayed Effective Date of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For delayed effective date of section, see Effective Date note below.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd8508cd-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd8508ce-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 261 and 262 of the Countering America’s Adversaries Through Sanctions Act, referred in subsec. (c), are sections 261 and 262 of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/44/tII"},"text":"Pub. L. 115–44, title II","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-02"},"text":"Aug. 2, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/934"},"text":"131 Stat. 934","children":[],"tail":", which are not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd8508cf-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd8508d0-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the earlier of the date that is 18 months after ","children":[{"tag":"date","attrib":{"date":"2025-07-18"},"text":"July 18, 2025","children":[],"tail":", or the date that is 120 days after the date on which the primary Federal payment stablecoin regulators issue any final regulations implementing "},{"tag":"ref","attrib":{"href":"/us/pl/119/27"},"text":"Pub. L. 119–27","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/119/27/s20"},"text":"section 20 of Pub. L. 119–27","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5901"},"text":"section 5901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
