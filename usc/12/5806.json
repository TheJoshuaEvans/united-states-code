{"tag":"section","attrib":{"id":"iddd804e89-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5806"},"text":null,"children":[{"tag":"num","attrib":{"value":"5806"},"text":"§ 5806.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preemption","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"This chapter, and regulations promulgated under this chapter, shall supersede any provision of any State or local law, statute, rule, regulation, or standard—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd804e8a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5806/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relating to the selection or use of a benchmark replacement or related conforming changes; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd804e8b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5806/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expressly limiting the manner of calculating interest, including the compounding of interest, as that provision applies to the selection or use of a Board-selected benchmark replacement or benchmark replacement conforming changes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd804e8c-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/dU/s107"},"text":"Pub. L. 117–103, div. U, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/832"},"text":"136 Stat. 832","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd804e8d-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd804e8e-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd804e8f-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this division”, meaning div. U of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103"},"text":"Pub. L. 117–103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/825"},"text":"136 Stat. 825","children":[],"tail":", known as the Adjustable Interest Rate (LIBOR) Act, which is classified principally to this chapter. For complete classification of div. U to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5801"},"text":"section 5801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
