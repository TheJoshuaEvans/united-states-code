{"tag":"section","attrib":{"id":"iddd1c35e9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4205"},"text":null,"children":[{"tag":"num","attrib":{"value":"4205"},"text":"§ 4205.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights of declarants; participation in actions, awards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd1c35ea-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4205/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person who has filed a declaration that meets the requirements of sections 4201 through 4204 of this title shall have the rights stated in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1c35eb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4205/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Attorney General determines that a cause of action referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4201"},"text":"section 4201 of this title","children":[],"tail":" based on the declaration should be referred to private counsel pursuant to subchapter III, the declarant, after consultation with the Attorney General, shall have the right to select counsel to prosecute the action, and the declarant and the declarant’s counsel shall act in accordance with subchapter III."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1c35ec-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4205/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal conviction","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd1c35ed-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4205/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When the United States obtains a criminal conviction and the Attorney General determines that the conviction was based in whole or in part on the information contained in a valid declaration filed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4201"},"text":"section 4201 of this title","children":[],"tail":" the Attorney General may, in his discretion, pay a reward to the declarant "},{"tag":"ref","attrib":{"idref":"fn002385"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002385"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a period."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1c35ee-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4205/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In determining the size of any award under paragraph (1), the Attorney General may, in the Attorney General’s discretion, consider any appropriate factor, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd1c35ef-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4205/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the seriousness of the offense for which the conviction was obtained;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd1c35f0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4205/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the facts alleged in the declaration contributed to the conviction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd1c35f1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4205/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of offenders apprehended pursuant to information provided by the declarant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd1c35f2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4205/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether or not the offender was previously under investigation by any law enforcement agency when the declaration was filed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd1c35f3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4205/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the declarant cooperated in the development of the Government’s case and its presentation at trial;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd1c35f4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4205/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sentences and fines imposed on the offender and other offenders in related cases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd1c35f5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4205/c/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which other sources of private information were relied upon; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd1c35f6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4205/c/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the hardship to the declarant and any expenses the declarant incurred in preparing the declaration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1c35f7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4205/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Share of funds and assets","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd1c35f8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4205/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" When the United States acquires funds or assets pursuant to the execution of a judgment, order, or settlement and the Attorney General determines that the judgment, order, or settlement was based in whole or in part on the information contained in a valid declaration filed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4201"},"text":"section 4201 of this title","children":[],"tail":", the declarant shall have the right to share in the recovery as follows:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd1c35f9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4205/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd1c35fa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4205/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The declarant shall be entitled to 20 percent to 30 percent of any recovery up to the first $1,000,000 recovered, 10 percent to 20 percent of the next $4,000,000 recovered, and 5 percent to 10 percent of the next $5,000,000 recovered.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd1c35fb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4205/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In calculating an award under clause (i), the Attorney General may consider the size of the overall recovery and the usefulness of the information provided by the declarant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd1c35fc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4205/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When a declarant has received an award under subsection (c), the Attorney General may subtract the amount of that reward from any recovery under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1c35fd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4205/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd1c35fe-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4205/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When more than 1 declarant has provided information leading to a recovery under this subsection, the Attorney General shall first calculate the size of the total award under paragraph (1)(A) and then distribute that amount according to the contribution made by each declarant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd1c35ff-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4205/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In distributing any such award between 2 or more declarants, the Attorney General may, in the Attorney General’s discretion, consider any appropriate factor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1c3600-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4205/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273/dA/tIII/s301/c/3"},"text":"Pub. L. 107–273, div. A, title III, § 301(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1781"},"text":"116 Stat. 1781","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1e7ef1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4205/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate Federal banking agency exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, funds or assets acquired by the United States shall not include any funds or assets acquired by any appropriate Federal banking agency acting in any capacity or the Resolution Trust Corporation acting in any capacity, except for any civil money penalties recovered by a Federal banking agency through a final judgment, order or settlement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd1e7ef2-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXV/s2565"},"text":"Pub. L. 101–647, title XXV, § 2565","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4896"},"text":"104 Stat. 4896","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dA/tIII/s301/c/3"},"text":"Pub. L. 107–273, div. A, title III, § 301(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1781"},"text":"116 Stat. 1781","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd1e7ef3-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd1e7ef4-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd1e7ef5-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273"},"text":"Pub. L. 107–273","children":[],"tail":" substituted “the Attorney General may, in his discretion, pay a reward to the declarant” for “, the declarant shall have the right to receive not less than $5,000 and not more than $100,000, any such award to be paid from the Financial Institution Information Award Fund established under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4209"},"text":"section 4209 of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273"},"text":"Pub. L. 107–273","children":[],"tail":" struck out heading and text of subsec. (e). Text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) No person shall receive both an award under this section and a reward under either ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1831k"},"text":"section 1831k of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3509A"},"text":"section 3509A of title 18","children":[],"tail":" for providing the same or substantially similar information."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) When a person qualifies for both an award under this section and a reward under either ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1831k"},"text":"section 1831k of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3509A"},"text":"section 3509A of title 18","children":[],"tail":" for providing the same or substantially similar information, the person may notify the Attorney General in writing of the person’s election to seek an award under this section or a reward under such other section.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
