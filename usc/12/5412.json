{"tag":"section","attrib":{"id":"iddd660f26-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5412"},"text":null,"children":[{"tag":"num","attrib":{"value":"5412"},"text":"§ 5412.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers and duties transferred","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd660f27-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5412/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section, and the amendments made by this section, shall take effect on the transfer date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd660f28-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5412/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions of the Office of Thrift Supervision","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd660f29-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5412/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings and loan holding company functions transferred","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd660f2a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5412/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are transferred to the Board of Governors all functions of the Office of Thrift Supervision and the Director of the Office of Thrift Supervision (including the authority to issue orders) relating to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd660f2b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5412/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the supervision of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddd660f2c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5412/b/1/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any savings and loan holding company; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddd660f2d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5412/b/1/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any subsidiary (other than a depository institution) of a savings and loan holding company; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd660f2e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5412/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all rulemaking authority of the Office of Thrift Supervision and the Director of the Office of Thrift Supervision relating to savings and loan holding companies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd660f2f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5412/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers, authorities, rights, and duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board of Governors shall succeed to all powers, authorities, rights, and duties that were vested in the Office of Thrift Supervision and the Director of the Office of Thrift Supervision on the day before the transfer date relating to the functions and authority transferred under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd660f30-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5412/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" All other functions transferred","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd660f31-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5412/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board of Governors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All rulemaking authority of the Office of Thrift Supervision and the Director of the Office of Thrift Supervision under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1468"},"text":"section 1468 of this title","children":[],"tail":" relating to transactions with affiliates and extensions of credit to executive officers, directors, and principal shareholders and under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1464/q"},"text":"section 1464(q) of this title","children":[],"tail":" relating to tying arrangements is transferred to the Board of Governors."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd660f32-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5412/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comptroller of the Currency","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (1) and subparagraph (A)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd660f33-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5412/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" there are transferred to the Office of the Comptroller of the Currency and the Comptroller of the Currency—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddd660f34-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5412/b/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all functions of the Office of Thrift Supervision and the Director of the Office of Thrift Supervision, respectively, relating to Federal savings associations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddd660f35-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5412/b/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all rulemaking authority of the Office of Thrift Supervision and the Director of the Office of Thrift Supervision, respectively, relating to savings associations; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd660f36-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5412/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of the Comptroller of the Currency and the Comptroller of the Currency shall succeed to all powers, authorities, rights, and duties that were vested in the Office of Thrift Supervision and the Director of the Office of Thrift Supervision, respectively, on the day before the transfer date relating to the functions and authority transferred under clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd660f37-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5412/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corporation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (1) and subparagraphs (A) and (B)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd660f38-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5412/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all functions of the Office of Thrift Supervision and the Director of the Office of Thrift Supervision relating to State savings associations are transferred to the Corporation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd660f39-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5412/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Corporation shall succeed to all powers, authorities, rights, and duties that were vested in the Office of Thrift Supervision and the Director of the Office of Thrift Supervision on the day before the transfer date relating to the functions transferred under clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd660f3a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5412/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd660f3b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5412/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consumer protection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section may be construed to limit or otherwise affect the transfer of powers under title X.","children":[{"tag":"ref","attrib":{"idref":"fn002487"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002487"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd660f3c-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tIII/s312"},"text":"Pub. L. 111–203, title III, § 312","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1521"},"text":"124 Stat. 1521","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd660f3d-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd660f3e-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd660f3f-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Title X, referred to in subsec. (d), is title X of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1955"},"text":"124 Stat. 1955","children":[],"tail":", known as the Consumer Financial Protection Act of 2010, which enacted subchapter V (§ 5481 et seq.) of this chapter and enacted, amended, and repealed numerous other sections and notes in the Code. For complete classification of title X to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd660f40-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s312"},"text":"section 312 of Pub. L. 111–203","children":[],"tail":". Subsec. (c) of "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s312"},"text":"section 312 of Pub. L. 111–203","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"section 1813 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
