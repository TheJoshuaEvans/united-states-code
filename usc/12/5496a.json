{"tag":"section","attrib":{"id":"iddd6d3bdb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5496a"},"text":null,"children":[{"tag":"num","attrib":{"value":"5496a"},"text":"§ 5496a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual audits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd6d3bdc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5496a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual independent audit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Bureau shall order an annual independent audit of the operations and budget of the Bureau.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd6d3bdd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5496a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual GAO audit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Comptroller General of the United States shall conduct an annual audit of the Bureau’s financial statements in accordance with generally accepted government accounting standards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd6d3bde-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1016A"},"text":"Pub. L. 111–203, title X, § 1016A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/112/10/dB/tV/s1573/a"},"text":"Pub. L. 112–10, div. B, title V, § 1573(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-04-15"},"text":"Apr. 15, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/138"},"text":"125 Stat. 138","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd6d3bdf-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd6d3be0-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd6d3be1-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Initial Audits","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/10/dB/tV/s1573/c"},"text":"Pub. L. 112–10, div. B, title V, § 1573(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-04-15"},"text":"Apr. 15, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/139"},"text":"125 Stat. 139","children":[],"tail":", provided that the initial audits under this section were to be completed not later than the end of the 180-day period beginning on "},{"tag":"date","attrib":{"date":"2011-04-15"},"text":"Apr. 15, 2011","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
