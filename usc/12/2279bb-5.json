{"tag":"section","attrib":{"id":"iddcec7371-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"2279bb–5"},"text":"§ 2279bb–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory actions applicable to level II","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcec7372-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–5/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capital restoration plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Corporation is classified as within level II, the Corporation shall, within the time period determined by the Director, submit to the Director a capital restoration plan and, after approval, carry out the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcec7373-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–5/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction on dividends","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Corporation is classified as within level II, the Corporation may not make any payment of dividends that would result in the Corporation being reclassified as within level III or IV.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcec7374-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–5/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reclassification from level II to level III","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall immediately reclassify the Corporation as within level III (and the Corporation shall be subject to the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2279bb–6"},"text":"section 2279bb–6 of this title","children":[],"tail":"), if—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcec7375-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–5/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Corporation is within level II; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcec7376-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–5/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcec7377-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–5/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Corporation does not submit a capital restoration plan that is approved by the Director; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcec7378-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–5/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director determines that the Corporation has failed to make, in good faith, reasonable efforts necessary to comply with such a capital restoration plan and fulfill the schedule for the plan approved by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcec7379-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–5/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall take effect upon the expiration of the 30-month period beginning on ","children":[{"tag":"date","attrib":{"date":"1991-12-13"},"text":"December 13, 1991","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcec737a-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tVIII/s8"},"text":"Pub. L. 92–181, title VIII, § 8","children":[],"tail":".36, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tV/s503/b/2"},"text":"Pub. L. 102–237, title V, § 503(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1876"},"text":"105 Stat. 1876","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
