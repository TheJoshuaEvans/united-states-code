{"tag":"section","attrib":{"id":"iddcf858c1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2806"},"text":null,"children":[{"tag":"num","attrib":{"value":"2806"},"text":"§ 2806.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance improvement methods","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcf858c2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2806/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcf858c3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2806/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Bureau of Consumer Financial Protection, with the assistance of the Secretary, the Director of the Bureau of the Census, the Board of Governors of the Federal Reserve System, the Federal Deposit Insurance Corporation, and such other persons as the Bureau deems appropriate, shall develop or assist in the improvement of, methods of matching addresses and census tracts to facilitate compliance by depository institutions in as economical a manner as possible with the requirements of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf858c4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2806/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated, such sums as may be necessary to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf858c5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2806/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracting authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Bureau of Consumer Financial Protection is authorized to utilize, contract with, act through, or compensate any person or agency in order to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcf858c6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2806/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendations to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Bureau of Consumer Financial Protection shall recommend to the Committee on Banking, Housing, and Urban Affairs of the Senate and the Committee on Financial Services of the House of Representatives, such additional legislation as the Director of the Bureau of Consumer Financial Protection deems appropriate to carry out the purpose of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcf858c7-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/200/tIII/s307"},"text":"Pub. L. 94–200, title III, § 307","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1094/6"},"text":"Pub. L. 111–203, title X, § 1094(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2101"},"text":"124 Stat. 2101","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcf858c8-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcf858c9-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"iddcf858ca-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2806, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/200/tIII/s307"},"text":"Pub. L. 94–200, title III, § 307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-31"},"text":"Dec. 31, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/1127"},"text":"89 Stat. 1127","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/628/tX/s1087/c"},"text":"Pub. L. 100–628, title X, § 1087(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-07"},"text":"Nov. 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3280"},"text":"102 Stat. 3280","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/73/tVII/s744/p/3"},"text":"Pub. L. 101–73, title VII, § 744(p)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/440"},"text":"103 Stat. 440","children":[],"tail":", which related to research and improved methods; authorization of appropriations; recommendations to congressional committees, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s