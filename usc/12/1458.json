{"tag":"section","attrib":{"id":"iddb86c773-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1458"},"text":null,"children":[{"tag":"num","attrib":{"value":"1458"},"text":"§ 1458.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Territorial applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other law, this chapter shall be applicable to the several States, the District of Columbia, the Commonwealth of Puerto Rico, and the territories and possessions of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddb86c774-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/351/tIII/s309"},"text":"Pub. L. 91–351, title III, § 309","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-07-24"},"text":"July 24, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/457"},"text":"84 Stat. 457","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
