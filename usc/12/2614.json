{"tag":"section","attrib":{"id":"iddcf39e91-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2614"},"text":null,"children":[{"tag":"num","attrib":{"value":"2614"},"text":"§ 2614.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction of courts; limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any action pursuant to the provisions of section 2605, 2607, or 2608 of this title may be brought in the United States district court or in any other court of competent jurisdiction, for the district in which the property involved is located, or where the violation is alleged to have occurred, within 3 years in the case of a violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2605"},"text":"section 2605 of this title","children":[],"tail":" and 1 year in the case of a violation of section 2607 or 2608 of this title from the date of the occurrence of the violation, except that actions brought by the Bureau, the Secretary, the Attorney General of any State, or the insurance commissioner of any State may be brought within 3 years from the date of the occurrence of the violation."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddcf39e92-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/533/s16"},"text":"Pub. L. 93–533, § 16","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-12-22"},"text":"Dec. 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1731"},"text":"88 Stat. 1731","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/181/tI"},"text":"Pub. L. 98–181, title I","children":[],"tail":" [title IV, § 461(d)], "},{"tag":"date","attrib":{"date":"1983-11-30"},"text":"Nov. 30, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1232"},"text":"97 Stat. 1232","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tII/s2103/e"},"text":"Pub. L. 104–208, div. A, title II, § 2103(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-400"},"text":"110 Stat. 3009–400","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1098/9"},"text":"Pub. L. 111–203, title X, § 1098(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2104"},"text":"124 Stat. 2104","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcf39e93-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcf39e94-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcf39e95-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" inserted “the Bureau,” before “the Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" substituted “section 2605, 2607, or 2608 of this title” for “section 2607 or 2608 of this title” and “within 3 years in the case of a violation of "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2605"},"text":"section 2605 of this title","children":[],"tail":" and 1 year in the case of a violation of section 2607 or 2608 of this title” for “within one year”."}],"tail":"\n"},{"tag":