{"tag":"section","attrib":{"id":"iddd804e7c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5805"},"text":null,"children":[{"tag":"num","attrib":{"value":"5805"},"text":"§ 5805.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benchmark for loans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd804e7d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5805/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd804e7e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5805/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bank","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “bank” means an institution subject to examination by a Federal financial institutions regulatory agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd804e7f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5805/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered action","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered action” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd804e80-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5805/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the initiation by a Federal supervisory agency of an enforcement action, including the issuance of a cease-and-desist order; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd804e81-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5805/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the issuance by a Federal supervisory agency of a matter requiring attention, a matter requiring immediate attention; or a matter requiring board attention resulting from a supervisory activity conducted by the Federal supervisory agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd804e82-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5805/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal financial institutions regulatory agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Federal financial institutions regulatory agencies” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s3302"},"text":"section 3302 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd804e83-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5805/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal supervisory agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Federal supervisory agency” means an agency listed in subparagraphs (A) through (H) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s3401/7"},"text":"section 3401(7) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd804e84-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5805/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-IBOR loan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “non-IBOR loan” means any loan that, by its terms, does not use in any way LIBOR, any tenor of non-U.S. dollar currency rates formerly known as the London interbank offered rate as administered by ICE Benchmark Administration Limited (or any predecessor or successor administrator thereof), and any other interbank offered rates that are expected to cease, as a benchmark.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd804e85-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5805/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benchmarks used by banks","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to a benchmark used by a bank—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd804e86-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5805/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the bank, in any non-IBOR loan made before, on, or after ","children":[{"tag":"date","attrib":{"date":"2022-03-15"},"text":"March 15, 2022","children":[],"tail":", may use any benchmark, including a benchmark that is not SOFR, that the bank determines to be appropriate for the funding model of the bank; the needs of the customers of the bank; and the products, risk profile, risk management capabilities, and operational capabilities of the bank; provided, however, that the use of any benchmark shall remain subject to the terms of the non-IBOR loan, and applicable law; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd804e87-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5805/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no Federal supervisory agency may take any covered action against the bank solely because that benchmark is not SOFR.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd804e88-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/dU/s106"},"text":"Pub. L. 117–103, div. U, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/831"},"text":"136 Stat. 831","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
