{"tag":"section","attrib":{"id":"iddd3d9f47-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4744"},"text":null,"children":[{"tag":"num","attrib":{"value":"4744"},"text":"§ 4744.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd3d9f48-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4744/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A participating State may enter into a participation agreement with any financial institution determined by the participating State, after consultation with the appropriate Federal banking agency, to have sufficient commercial lending experience and financial and managerial capacity to participate in the Program. The determination by the State shall not be reviewable by the Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3d9f49-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4744/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participating financial institutions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon entering into the participation agreement with the participating State, the financial institution shall become a participating financial institution eligible to enroll loans under the Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd3d9f4a-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/tII/s254"},"text":"Pub. L. 103–325, title II, § 254","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2207"},"text":"108 Stat. 2207","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
