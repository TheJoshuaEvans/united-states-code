{"tag":"section","attrib":{"id":"iddd3b2f03-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4713"},"text":null,"children":[{"tag":"num","attrib":{"value":"4713"},"text":"§ 4713.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incentives for depository institution participation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd3b2f04-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4713/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Function of Administrator","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd3b2f05-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4713/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of any funds appropriated pursuant to the authorization in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4718/a"},"text":"section 4718(a) of this title","children":[],"tail":", the funds made available for use in carrying out this section in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4718/a/4"},"text":"section 4718(a)(4) of this title","children":[],"tail":" shall be administered by the Administrator of the Fund, in consultation with—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd3b2f06-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4713/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal banking agencies (as defined in section 3 of the Federal Deposit Insurance Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"12 U.S.C. 1813","children":[],"tail":"]) and the National Credit Union Administration;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3b2f07-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4713/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individuals named pursuant to clauses (ii) and (iv) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4703/d/2/G"},"text":"section 4703(d)(2)(G) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3b2f08-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4713/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other representatives of insured depository institutions or other persons as the Administrator may determine to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3b2f09-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4713/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of Bank Enterprise Act of 1991","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (b) and the consultation requirement of paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd3b2f0a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4713/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 233 of the Bank Enterprise Act of 1991 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1834a"},"text":"12 U.S.C. 1834a","children":[],"tail":"] shall be applicable to the Administrator, for purposes of this section, in the same manner and to the same extent that such section is applicable to the Community Enterprise Assessment Credit Board;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3b2f0b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4713/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Administrator shall, for purposes of carrying out this section and section 233 of the Bank Enterprise Act of 1991 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1834a"},"text":"12 U.S.C. 1834a","children":[],"tail":"]—"}],"tail":null},{"tag":"clause","attrib":{"id":"iddd3b2f0c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4713/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have all powers and rights of the Community Enterprise Assessment Credit Board under section 233 of the Bank Enterprise Act of 1991 to administer and enforce any provision of such section 233 which is applicable to the Administrator under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd3b2f0d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4713/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be subject to the same duties and restrictions imposed on the Community Enterprise Assessment Credit Board; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3b2f0e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4713/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Administrator shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd3b2f0f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4713/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have all powers and rights of an appropriate Federal banking agency under section 233(b)(2) of the Bank Enterprise Act of 1991 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1834a/b/2"},"text":"12 U.S.C. 1834a(b)(2)","children":[],"tail":"] to approve or disapprove the designation of qualified distressed communities for purposes of this section and provide information and assistance with respect to any such designation; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd3b2f10-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4713/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be subject to the same duties imposed on the appropriate Federal banking agencies under such section 233(b)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3b2f11-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4713/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Awards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall determine the amount of assessment credits, and shall make awards of those credits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3b2f12-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4713/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations and guidelines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may prescribe such regulations and issue such guidelines as the Administrator determines to be appropriate to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3b2f13-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4713/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions to applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraphs (1) through (4) of this subsection, subsections (a)(1) and (e)(2) of section 233 of the Bank Enterprise Act of 1991 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1834a/a/1"},"text":"12 U.S.C. 1834a(a)(1)","children":[],"tail":", (e)(2)], and any other provision of the Federal Deposit Insurance Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1811"},"text":"12 U.S.C. 1811","children":[],"tail":" et seq.] relating to the Bank Enterprise Act of 1991, do not apply to the Administrator for purposes of this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3b2f14-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4713/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provisions relating to administration of this section","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd3b2f15-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4713/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New lifeline accounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In applying section 233 of the Bank Enterprise Act of 1991 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1834a"},"text":"12 U.S.C. 1834a","children":[],"tail":"] for purposes of this section, the Administrator shall treat the provision of new lifeline accounts by an insured depository institution as an activity which is qualified to be taken into account under section 233(a)(2)(A) of such Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3b2f16-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4713/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of assessment credit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of this subchapter, section 233(a)(3) of the Bank Enterprise Act of 1991 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1834a/a/3"},"text":"12 U.S.C. 1834a(a)(3)","children":[],"tail":") shall be applied by substituting the following text:"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3b2f17-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4713/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of assessment credit","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"“The amount of an assessment credit which may be awarded to an insured depository institution to carry out the qualified activities of the institution or of the subsidiaries of the institution pursuant to this section for any semiannual period shall be equal to the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd3b2f18-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4713/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to qualifying activities described in paragraph (2)(A), the amount which is equal to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd3b2f19-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4713/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 5 percent of the sum of the amounts determined under such subparagraph, in the case of an institution which is not a community development financial institution; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd3b2f1a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4713/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 15 percent of the sum of the amounts determined under such subparagraph, in the case of an institution which is a community development financial institution; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3b2f1b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4713/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to qualifying activities described in paragraph (2)(C), 15 percent of the amounts determined under such subparagraph.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3b2f1c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4713/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment of percentage","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Section 233(a)(5) of the Bank Enterprise Act of 1991 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1834a/a/5"},"text":"12 U.S.C. 1834a(a)(5)","children":[],"tail":"] shall be applied for purposes of this section by—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd3b2f1d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4713/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substituting “institutions which are community development financial institutions” for “institutions which meet the community development organization requirements under section 234 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1834b"},"text":"12 U.S.C. 1834b","children":[],"tail":"]”; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3b2f1e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4713/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substituting “institutions which are not community development financial institutions” for “institutions which do not meet such requirements”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3b2f1f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4713/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of QDC","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Section 233(b)(2) of the Bank Enterprise Act of 1991 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1834a/b/2"},"text":"12 U.S.C. 1834a(b)(2)","children":[],"tail":"] shall be applied for purposes of this section without regard to subparagraph (A)(ii) of such section 233(b)(2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3b2f20-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4713/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operation on annual basis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may, in the Administrator’s discretion, apply section 233 of the Bank Enterprise Act of 1991 for purposes of this section by providing community enterprise assessment credits with respect to annual periods rather than semiannual periods.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3b2f21-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4713/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outreach","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall ensure that information about the Bank Enterprise Act of 1991 under this section is widely disseminated to all interested parties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3b2f22-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4713/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of this subchapter, section 233(a)(2)(A) of the Bank Enterprise Act of 1991 shall be applied by inserting “of the increase” after “the amount”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd3b2f23-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/tI/s114"},"text":"Pub. L. 103–325, title I, § 114","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2179"},"text":"108 Stat. 2179","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd3b2f24-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd3b2f25-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd3b2f26-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Bank Enterprise Act of 1991, referred to in subsecs. (a)(2), (5) and (b)(6), is subtitle C (§§ 231–234) of title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242"},"text":"Pub. L. 102–242","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2308-2315"},"text":"105 Stat. 2308–2315","children":[],"tail":", which enacted sections 1834 to 1834b of this title, amended "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1817"},"text":"section 1817 of this title","children":[],"tail":", and enacted provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1811"},"text":"section 1811 of this title","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 1991 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1811"},"text":"section 1811 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Federal Deposit Insurance Act, referred to in subsec. (a)(5), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-21/ch967/s2"},"text":"act Sept. 21, 1950, ch. 967, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/873"},"text":"64 Stat. 873","children":[],"tail":", which is classified generally to chapter 16 (§ 1811 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1811"},"text":"section 1811 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd3b2f27-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/s114"},"text":"section 114 of Pub. L. 103–325","children":[],"tail":". Subsec. (c) of "},{"tag":"ref","attrib":{"href":"/us/pl/103/325/s114"},"text":"section 114 of Pub. L. 103–325","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1834a"},"text":"section 1834a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
