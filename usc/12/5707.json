{"tag":"section","attrib":{"id":"iddd7e04e5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5707"},"text":null,"children":[{"tag":"num","attrib":{"value":"5707"},"text":"§ 5707.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remedies for State program termination or failures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd7e04e6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5707/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remedies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd7e04e7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5707/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If any of the events listed in paragraph (2) occur, the Secretary, in the Secretary’s discretion, may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd7e04e8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5707/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce the amount of Federal funds allocated to the State under the Program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7e04e9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5707/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" terminate any further transfers of allocated amounts that have not yet been transferred to the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e04ea-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5707/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Causal events","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The events referred to in paragraph (1) are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd7e04eb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5707/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" termination by a participating State of its participation in the Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7e04ec-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5707/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" failure on the part of a participating State to submit complete reports under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5706"},"text":"section 5706 of this title","children":[],"tail":" on a timely basis; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7e04ed-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5707/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" noncompliance by the State with the terms of the allocation agreement between the Secretary and the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd7e04ee-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5707/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deallocated amounts to be reallocated","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If, after 13 months, any portion of the amount of Federal funds allocated to a participating State is deemed by the Secretary to be no longer allocated to the State after actions taken by the Secretary under subsection (a)(1), the Secretary shall reallocate that portion among the participating States, excluding the State whose allocated funds were deemed to be no longer allocated, as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5702/b"},"text":"section 5702(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd7e04ef-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/240/tIII/s3008"},"text":"Pub. L. 111–240, title III, § 3008","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-09-27"},"text":"Sept. 27, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2580"},"text":"124 Stat. 2580","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
