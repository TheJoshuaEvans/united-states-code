{"tag":"section","attrib":{"id":"iddbaceda0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701u"},"text":null,"children":[{"tag":"num","attrib":{"value":"1701u"},"text":"§ 1701u.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Economic opportunities for low- and very low-income persons","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddbaceda1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701u/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddbaceda2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701u/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal housing and community development programs provide State and local governments and other recipients of Federal financial assistance with substantial funds for projects and activities that produce significant employment and other economic opportunities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddbaceda3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701u/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" low- and very low-income persons, especially recipients of government assistance for housing, often have restricted access to employment and other economic opportunities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddbaceda4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701u/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employment and other economic opportunities generated by projects and activities that receive Federal housing and community development assistance offer an effective means of empowering low- and very low-income persons, particularly persons who are recipients of government assistance for housing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddbaceda5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701u/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prior Federal efforts to direct employment and other economic opportunities generated by Federal housing and community development programs to low- and very low-income persons have not been fully effective and should be intensified.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddbaceda6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701u/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the policy of the Congress and the purpose of this section to ensure that the employment and other economic opportunities generated by Federal financial assistance for housing and community development programs shall, to the greatest extent feasible, be directed toward low- and very low-income persons, particularly those who are recipients of government assistance for housing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddbaceda7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701u/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddbaceda8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701u/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public and Indian housing program","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddbaceda9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701u/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall require that public and Indian housing agencies, and their contractors and subcontractors, make their best efforts, consistent with existing Federal, State, and local laws and regulations, to give to low- and very low-income persons the training and employment opportunities generated by development assistance provided pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437c"},"text":"section 1437c of title 42","children":[],"tail":", operating assistance provided pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437g"},"text":"section 1437g of title 42","children":[],"tail":", and modernization grants provided pursuant to section 1437"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of title 42."},{"tag":"ref","attrib":{"idref":"fn002114"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002114"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddbacedaa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701u/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The efforts required under subparagraph (A) shall be directed in the following order of priority:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddbacedab-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701u/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To residents of the housing developments for which the assistance is expended.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddbacedac-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701u/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To residents of other developments managed by the public or Indian housing agency that is expending the assistance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddbacedad-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701u/c/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To participants in YouthBuild programs receiving assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3226"},"text":"section 3226 of title 29","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddbacedae-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701u/c/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To other low- and very low-income persons residing within the metropolitan area (or nonmetropolitan county) in which the assistance is expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddbacedaf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701u/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other programs","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddbacedb0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701u/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In other programs that provide housing and community development assistance, the Secretary shall ensure that, to the greatest extent feasible, and consistent with existing Federal, State, and local laws and regulations, opportunities for training and employment arising in connection with a housing rehabilitation (including reduction and abatement of lead-based paint hazards), housing construction, or other public construction project are given to low- and very low-income persons residing within the metropolitan area (or nonmetropolitan county) in which the project is located.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddbacedb1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701u/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Where feasible, priority should be given to low- and very low-income persons residing within the service area of the project or the neighborhood in which the project is located and to participants in YouthBuild programs receiving assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3226"},"text":"section 3226 of title 29","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddbacedb2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701u/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracting","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddbacedb3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701u/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public and Indian housing program","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddbacedb4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701u/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall require that public and Indian housing agencies, and their contractors and subcontractors, make their best efforts, consistent with existing Federal, State, and local laws and regulations, to award contracts for work to be performed in connection with development assistance provided pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437c"},"text":"section 1437c of title 42","children":[],"tail":", operating assistance provided pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437g"},"text":"section 1437g of title 42","children":[],"tail":", and modernization grants provided pursuant to section 1437"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of title 42,"},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" to business concerns that provide economic opportunities for low- and very low-income persons."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddbacedb5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701u/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The efforts required under subparagraph (A) shall be directed in the following order of priority:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddbacedb6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701u/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To business concerns that provide economic opportunities for residents of the housing development for which the assistance is provided.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddbacedb7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701u/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To business concerns that provide economic opportunities for residents of other housing developments operated by the public and Indian housing agency that is providing the assistance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddbacedb8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701u/d/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To YouthBuild programs receiving assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3226"},"text":"section 3226 of title 29","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddbacedb9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701u/d/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To business concerns that provide economic opportunities for low- and very low-income persons residing within the metropolitan area (or nonmetropolitan county) in which the assistance is provided.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddbacedba-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701u/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other programs","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddbacedbb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701u/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In providing housing and community development assistance pursuant to other programs, the Secretary shall ensure that, to the greatest extent feasible, and consistent with existing Federal, State, and local laws and regulations, contracts awarded for work to be performed in connection with a housing rehabilitation (including reduction and abatement of lead-based paint hazards), housing construction, or other public construction project are given to business concerns that provide economic opportunities for low- and very low-income persons residing within the metropolitan area (or nonmetropolitan county) in which the assistance is expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddbacedbc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701u/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Where feasible, priority should be given to business concerns which provide economic opportunities for low- and very low-income persons residing within the service area of the project or the neighborhood in which the project is located and to YouthBuild programs receiving assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3226"},"text":"section 3226 of title 29","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddbacedbd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701u/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of this section the following definitions shall apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddbacedbe-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701u/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Low- and very low-income persons","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “low-income persons” and “very low-income persons” have the same meanings given the terms “low-income families” and “very low-income families”, respectively, in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437a/b/2"},"text":"section 1437a(b)(2) of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddbacedbf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701u/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Business concern that provides economic opportunities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “a business concern that provides economic opportunities” means a business concern that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddbacedc0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701u/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides economic opportunities for a class of persons that has a majority controlling interest in the business;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddbacedc1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701u/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employs a substantial number of such persons; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddbacedc2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701u/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets such other criteria as the Secretary may establish.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddbacedc3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701u/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with other Federal agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall consult with the Secretary of Labor, the Secretary of Health and Human Services, the Secretary of Commerce, the Administrator of the Small Business Administration, and such other Federal agencies as the Secretary determines are necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddbacedc4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701u/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"1992-10-28"},"text":"October 28, 1992","children":[],"tail":", the Secretary shall promulgate regulations to implement this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddbacedc5-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/448/s3"},"text":"Pub. L. 90–448, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-08-01"},"text":"Aug. 1, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/476"},"text":"82 Stat. 476","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/152/tIV/s404"},"text":"Pub. L. 91–152, title IV, § 404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-24"},"text":"Dec. 24, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/395"},"text":"83 Stat. 395","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/383/tI/s118"},"text":"Pub. L. 93–383, title I, § 118","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-22"},"text":"Aug. 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/653"},"text":"88 Stat. 653","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/399/tIII/s329"},"text":"Pub. L. 96–399, title III, § 329","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-08"},"text":"Oct. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1651"},"text":"94 Stat. 1651","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tIX/s915"},"text":"Pub. L. 102–550, title IX, § 915","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3878"},"text":"106 Stat. 3878","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/281/s2/d/1"},"text":"Pub. L. 109–281, § 2(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-09-22"},"text":"Sept. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1181"},"text":"120 Stat. 1181","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/tV/s512/p"},"text":"Pub. L. 113–128, title V, § 512(p)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1711"},"text":"128 Stat. 1711","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddbacedc6-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddbacedc7-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddbacedc8-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 1437","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of title 42, referred to in subsecs. (c)(1)(A) and (d)(1)(A), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/105/276/tV/s522/a"},"text":"Pub. L. 105–276, title V, § 522(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2564"},"text":"112 Stat. 2564","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddbacedc9-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Housing and Urban Development Act of 1968, and not as part of the National Housing Act which comprises this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"date","attrib":{"date":"1992-10-28"},"text":"October 28, 1992","children":[],"tail":", referred to in subsec. (g), was in the original “the date of enactment of the National Affordable Housing Act Amendments of 1992”, and was translated as meaning the date of enactment of the Housing and Community Development Act of 1992, "},{"tag":"ref","attrib":{"href":"/us/pl/102/550"},"text":"Pub. L. 102–550","children":[],"tail":", which amended this section generally, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddbacedca-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (c)(1)(B)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s512/p/1/A"},"text":"Pub. L. 113–128, § 512(p)(1)(A)","children":[],"tail":", substituted “participants in YouthBuild programs receiving assistance under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3226"},"text":"section 3226 of title 29","children":[],"tail":"” for “participants in YouthBuild programs receiving assistance under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2918a"},"text":"section 2918a of title 29","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s512/p/1/B"},"text":"Pub. L. 113–128, § 512(p)(1)(B)","children":[],"tail":", substituted “participants in YouthBuild programs receiving assistance under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3226"},"text":"section 3226 of title 29","children":[],"tail":"” for “participants in YouthBuild programs receiving assistance under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2918a"},"text":"section 2918a of title 29","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(B)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s512/p/2/A"},"text":"Pub. L. 113–128, § 512(p)(2)(A)","children":[],"tail":", substituted “To YouthBuild programs receiving assistance under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3226"},"text":"section 3226 of title 29","children":[],"tail":"” for “To YouthBuild programs receiving assistance under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2918a"},"text":"section 2918a of title 29","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s512/p/2/B"},"text":"Pub. L. 113–128, § 512(p)(2)(B)","children":[],"tail":", substituted “to YouthBuild programs receiving assistance under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3226"},"text":"section 3226 of title 29","children":[],"tail":"” for “to YouthBuild programs receiving assistance under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2918a"},"text":"section 2918a of title 29","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsecs. (c)(1)(B)(iii), (2)(B), (d)(1)(B)(iii), (2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/281"},"text":"Pub. L. 109–281","children":[],"tail":" substituted “YouthBuild programs receiving assistance under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2918a"},"text":"section 2918a of title 29","children":[],"tail":"” for “Youthbuild programs receiving assistance under subtitle D of title IV of the Cranston-Gonzalez National Affordable Housing Act”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550"},"text":"Pub. L. 102–550","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “In the administration by the Secretary of Housing and Urban Development of programs providing direct financial assistance, including community development block grants under title I of the Housing and Community Development Act of 1974, in aid of housing, urban planning, development, redevelopment, or renewal, public or community facilities, and new community development, the Secretary shall—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) require, in consultation with the Secretary of Labor, that to the greatest extent feasible opportunities for training and employment arising in connection with the planning and carrying out of any project assisted under any such program be given to lower income persons residing within the unit of local government or the metropolitan area (or non­metropolitan county), as determined by the Secretary, in which the project is located; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) require, in consultation with the Administrator of the Small Business Administration, that to the greatest extent feasible contracts for work to be performed in connection with any such project be awarded to business concerns, including but not limited to individuals or firms doing business in the field of planning, consulting, design, architecture, building construction, rehabilitation, maintenance or repair, which are located in or owned in substantial part by persons residing in the same metropolitan area (or nonmetropolitan county) as the project.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/399/s329/1"},"text":"Pub. L. 96–399, § 329(1)","children":[],"tail":", substituted “residing within the unit of local government or the metropolitan area (or nonmetropolitan county), as determined by the Secretary, in which the project is located” for “residing in the area of such project”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/399/s329/2"},"text":"Pub. L. 96–399, § 329(2)","children":[],"tail":", substituted “residing in the same metropolitan area (or nonmetropolitan county) as the project” for “residing in the area of such project”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/383"},"text":"Pub. L. 93–383","children":[],"tail":" inserted reference to community development block grants under title I of the Housing and Community Development Act of 1974."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1969—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/152"},"text":"Pub. L. 91–152","children":[],"tail":" substituted provisions making applicable programs providing direct financial assistance in aid of housing, urban planning, development, redevelopment, or renewal, public or community facilities, and new community development, for provisions making applicable programs authorized by sections 1715"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"(d)(3), 1715z, and 1715z–1 of this title, the low-rent public housing program under the United States Housing Act of 1937, and the rent supplement program under section 101 of the Housing and Urban Development Act of 1965."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddbacedcb-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddbacedcc-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2014 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128"},"text":"Pub. L. 113–128","children":[],"tail":" effective on the first day of the first full program year after "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"2015-07-01"},"text":"July 1, 2015","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/s506"},"text":"section 506 of Pub. L. 113–128","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3101"},"text":"section 3101 of Title 29","children":[],"tail":", Labor."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddbacedcd-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/281/s2/f"},"text":"Pub. L. 109–281, § 2(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-09-22"},"text":"Sept. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1182"},"text":"120 Stat. 1182","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/281/s2/f"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“This section [enacting former ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2918a"},"text":"section 2918a of Title 29","children":[],"tail":", Labor, amending this section, "},{"tag":"ref","attrib":{"hr