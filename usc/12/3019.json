{"tag":"section","attrib":{"id":"iddcfaca20-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3019"},"text":null,"children":[{"tag":"num","attrib":{"value":"3019"},"text":"§ 3019.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxation by State, county, etc., taxing authority; Federal tax status","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcfaca21-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3019/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Bank, including its franchise, capital, reserves, surplus, mortgages, or other security holdings and income shall be exempt from taxation now or hereafter imposed by any State, county, municipality, or local taxing authority, but any real property held by the Bank shall be subject to any State, county, municipal, or local taxation to the same extent according to its value as other real property is taxed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcfaca22-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3019/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding any other provision of law, for purposes of subchapter T of chapter 1 of title 26—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcfaca23-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3019/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Bank shall be treated as a corporation operating on the cooperative basis within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s1381/a/2"},"text":"section 1381(a)(2) of title 26","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcfaca24-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3019/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “patronage dividend”, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s1388/a"},"text":"section 1388(a) of title 26","children":[],"tail":" includes, only as such section applies to the Bank, any patronage refunds in the form of class B or class C stock or allocated surplus that are distributed or set aside by the Bank pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s3014/i"},"text":"section 3014(i) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcfaca25-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3019/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms “written notice of allocation” and “qualified written notices of allocation”, as defined in sections 1388(b) and (c) of title 26, include (to the extent of par value), only as such sections apply to the Bank, any class B or class C stock distributed by the Bank pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s3014/i"},"text":"section 3014(i) of this title","children":[],"tail":" and shall also include any allocated surplus set aside by the Bank pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s3014/i"},"text":"section 3014(i) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcfaca26-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3019/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" patrons of the Bank shall be deemed to have consented under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s1388/c/2"},"text":"section 1388(c)(2) of title 26","children":[],"tail":" to the inclusion in their incomes of any qualified written notices of allocation received by such patrons from the Bank; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcfaca27-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3019/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amounts required to be included in the incomes of patrons of the Bank with respect to class B or class C stock or allocated surplus shall be treated as earnings from business done by such patrons of the Bank with or for their own patrons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcfaca28-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/351/tI/s109"},"text":"Pub. L. 95–351, title I, § 109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-08-20"},"text":"Aug. 20, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/509"},"text":"92 Stat. 509","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tIII/s392/a"},"text":"Pub. L. 97–35, title III, § 392(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/434"},"text":"95 Stat. 434","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcfaca29-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcfaca2a-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddcfaca2b-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subchapter T of chapter 1 of title 26, referred to in subsec. (b), is set out as section 1381 et seq. of Title 26, Internal Revenue Code.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcfaca2c-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" substituted “Internal Revenue Code of 1986” for “Internal Revenue Code of 1954”, which for purposes of codification was translated as “title 26” thus requiring no change in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":" designated existing provisions as subsec. (a), struck out applicability of Final Government Equity Redemption Date to provisions, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcfaca2d-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcfaca2e-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1981 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tIII/s392/b"},"text":"Pub. L. 97–35, title III, § 392(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/435"},"text":"95 Stat. 435","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/35/tIII/s392/b"},"text":"“The amendments made by subsection (a) [amending this section] shall take effect on the day after the Final Government Equity Redemption Date [","children":[{"tag":"date","attrib":{"date":"1981-12-31"},"text":"Dec. 31, 1981","children":[],"tail":"].”"}],"tail":"\n For definition of “Final Government Equity Redemption Date”, see "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/s396/a"},"text":"section 396(a) of Pub. L. 97–35","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s3012"},"text":"section 3012 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
