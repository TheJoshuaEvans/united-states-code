{"tag":"section","attrib":{"id":"iddd44a59c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5101"},"text":null,"children":[{"tag":"num","attrib":{"value":"5101"},"text":"§ 5101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes and methods for establishing a mortgage licensing system and registry","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In order to increase uniformity, reduce regulatory burden, enhance consumer protection, and reduce fraud, the States, through the Conference of State Bank Supervisors and the American Association of Residential Mortgage Regulators, are hereby encouraged to establish a Nationwide Mortgage Licensing System and Registry for the residential mortgage industry that accomplishes all of the following objectives:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd44a59d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5101/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Provides uniform license applications and reporting requirements for State-licensed loan originators.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd44a59e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5101/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Provides a comprehensive licensing and supervisory database.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd44a59f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5101/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Aggregates and improves the flow of information to and between regulators.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd44a5a0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5101/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Provides increased accountability and tracking of loan originators.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd44a5a1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5101/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Streamlines the licensing process and reduces the regulatory burden.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd44a5a2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5101/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Enhances consumer protections and supports anti-fraud measures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd44a5a3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5101/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Provides consumers with easily accessible information, offered at no charge, utilizing electronic media, including the Internet, regarding the employment history of, and publicly adjudicated disciplinary and enforcement actions against, loan originators.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd44a5a4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5101/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Establishes a means by which residential mortgage loan originators would, to the greatest extent possible, be required to act in the best interests of the consumer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd44a5a5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5101/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Facilitates responsible behavior in the subprime mortgage market place and provides comprehensive training and examination requirements related to subprime mortgage lending.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd44a5a6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5101/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Facilitates the collection and disbursement of consumer complaints on behalf of State and Federal mortgage regulators.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd44a5a7-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tV/s1502"},"text":"Pub. L. 110–289, div. A, title V, § 1502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2810"},"text":"122 Stat. 2810","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd44a5a8-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd44a5a9-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"iddd44a5aa-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dG/tLXXXVIII/s88001"},"text":"Pub. L. 114–94, div. G, title LXXXVIII, § 88001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1799"},"text":"129 Stat. 1799","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/94/dG/tLXXXVIII/s88001"},"text":"“This title [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5110"},"text":"section 5110 of this title","children":[],"tail":"] may be cited as the ‘State Licensing Efficiency Act of 2015’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"iddd44a5ab-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tV/s1501"},"text":"Pub. L. 110–289, div. A, title V, § 1501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2810"},"text":"122 Stat. 2810","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/289/dA/tV/s1501"},"text":"“This title [enacting this chapter] may be cited as the ‘Secure and Fair Enforcement for Mortgage Licensing Act of 2008’ or ‘S.A.F.E. Mortgage Licensing Act of 2008’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
