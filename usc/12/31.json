{"tag":"section","attrib":{"id":"iddb0ae13a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s31"},"text":null,"children":[{"tag":"num","attrib":{"value":"31"},"text":"§ 31.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights and liabilities as affected by change of name","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All debts, liabilities, rights, provisions, and powers of the association under its old name shall devolve upon and inure to the association under its new name.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddb0ae13b-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1886-05-01/ch73/s3"},"text":"May 1, 1886, ch. 73, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/24/19"},"text":"24 Stat. 19","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
