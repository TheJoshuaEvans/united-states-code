{"tag":"section","attrib":{"id":"iddb310737-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s339a"},"text":null,"children":[{"tag":"num","attrib":{"value":"339a"},"text":"§ 339a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Resolution of clearing banks","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddb310738-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s339a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conservatorship or receivership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb310739-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s339a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board may appoint a conservator or receiver to take possession and control of any uninsured State member bank which operates, or operates as, a multilateral clearing organization pursuant to section 4422 ","children":[{"tag":"ref","attrib":{"idref":"fn002036"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002036"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title to the same extent and in the same manner as the Comptroller of the Currency may appoint a conservator or receiver for a national bank."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb31073a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s339a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The conservator or receiver for an uninsured State member bank referred to in paragraph (1) shall exercise the same powers, functions, and duties, subject to the same limitations, as a conservator or receiver for a national bank.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb31073b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s339a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall have the same authority with respect to any conservator or receiver appointed under subsection (a), and the uninsured State member bank for which the conservator or receiver has been appointed, as the Comptroller of the Currency has with respect to a conservator or receiver for a national bank and the national bank for which the conservator or receiver has been appointed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb31073c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s339a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bankruptcy proceedings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board (in the case of an uninsured State member bank which operates, or operates as, such a multilateral clearing organization) may direct a conservator or receiver appointed for the bank to file a petition pursuant to title 11, in which case, title 11 shall apply to the bank in lieu of otherwise applicable Federal or State insolvency law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddb31073d-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1913-12-13/ch6/s9B"},"text":"Dec. 13, 1913, ch. 6, § 9B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/5/tI/s112/b"},"text":"Pub. L. 106–554, § 1(a)(5) [title I, § 112(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–392.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb31073e-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb31073f-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddb310740-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4422"},"text":"Section 4422 of this title","children":[],"tail":", referred to in subsec. (a)(1), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tVII/s740"},"text":"Pub. L. 111–203, title VII, § 740","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1729"},"text":"124 Stat. 1729","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddb310741-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as section 9B of act ","children":[{"tag":"date","attrib":{"date":"1913-12-13"},"text":"Dec. 13, 1913","children":[],"tail":", and not as part of section 9 of such act which comprises this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
