{"tag":"section","attrib":{"id":"iddcfd3b61-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3041"},"text":null,"children":[{"tag":"num","attrib":{"value":"3041"},"text":"§ 3041.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment; appointment, etc., of Director","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcfd3b62-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3041/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is hereby established within the Bank an Office of Self-Help Development and Technical Assistance (hereinafter the “Office”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcfd3b63-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3041/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office shall have a Director who shall be appointed by the President, with the advice and consent of the Senate, and who shall not be a member of the Board. Subject to review by the Board, the Director shall promulgate and publish in the Federal Register policies and procedures governing the operation of the Office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcfd3b64-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/351/tII/s201"},"text":"Pub. L. 95–351, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-08-20"},"text":"Aug. 20, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/511"},"text":"92 Stat. 511","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcfd3b65-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcfd3b66-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddcfd3b67-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of Office and Performance of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For abolition of the Office of Self-Help Development and Technical Assistance and performance of the functions by a nonprofit corporation upon the incorporation of the nonprofit corporation, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s3051"},"text":"section 3051 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
