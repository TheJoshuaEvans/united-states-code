{"tag":"section","attrib":{"id":"iddb4419bd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s465"},"text":null,"children":[{"tag":"num","attrib":{"value":"465"},"text":"§ 465.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis for ascertaining deposits against which required balance is determined","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In estimating the reserve balances required by this chapter, member banks may deduct from the amount of their gross demand deposits the amounts of balances due from other banks (except Federal Reserve banks and foreign banks) and cash items in process of collection payable immediately upon presentation in the United States, within the meaning of these terms as defined by the Board of Governors of the Federal Reserve System.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddb4419be-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1913-12-23/ch6/s19/g"},"text":"Dec. 23, 1913, ch. 6, § 19(g)","children":[],"tail":", formerly § 19 (par. 10), "},{"tag":"ref","attrib":{"href":"/us/stat/38/270"},"text":"38 Stat. 270","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1914-08-15/ch252"},"text":"Aug. 15, 1914, ch. 252","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/692"},"text":"38 Stat. 692","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1917-06-21/ch32/s10"},"text":"June 21, 1917, ch. 32, § 10","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/40/240"},"text":"40 Stat. 240","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1935-08-23/ch614"},"text":"Aug. 23, 1935, ch. 614","children":[],"tail":", title III, § 324(b), "},{"tag":"ref","attrib":{"href":"/us/stat/49/714"},"text":"49 Stat. 714","children":[],"tail":"; renumbered § 19(g), "},{"tag":"ref","attrib":{"href":"/us/pl/89/597/s2/b"},"text":"Pub. L. 89–597, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-21"},"text":"Sept. 21, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/824"},"text":"80 Stat. 824","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb4419bf-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb4419c0-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddb4419c1-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/act/1913-12-23/ch6"},"text":"act Dec. 23, 1913, ch. 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/251"},"text":"38 Stat. 251","children":[],"tail":", known as the Federal Reserve Act. For complete classification of this Act to the Code, see References in Text note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s226"},"text":"section 226 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddb4419c2-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of subsec. (g), formerly tenth par., of section 19 of act ","children":[{"tag":"date","attrib":{"date":"1913-12-23"},"text":"Dec. 23, 1913","children":[],"tail":", as redesignated by "},{"tag":"ref","attrib":{"href":"/us/pl/89/597"},"text":"Pub. L. 89–597","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddb4419c3-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1935—Act ","children":[{"tag":"date","attrib":{"date":"1935-08-23"},"text":"Aug. 23, 1935","children":[],"tail":", changed method of estimating reserve balances."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
