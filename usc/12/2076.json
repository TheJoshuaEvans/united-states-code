{"tag":"section","attrib":{"id":"iddcc191e8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2076"},"text":null,"children":[{"tag":"num","attrib":{"value":"2076"},"text":"§ 2076.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other services","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Each production credit association may provide technical assistance to borrowers, applicants, and members and may make available to them at their option such financial related services appropriate to their on-farm and aquatic operations as is determined feasible by the board of directors of each Farm Credit Bank, under regulations prescribed by the Farm Credit Administration.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddcc191e9-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tII/s2"},"text":"Pub. L. 92–181, title II, § 2","children":[],"tail":".5, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tIV/s401"},"text":"Pub. L. 100–233, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1633"},"text":"101 Stat. 1633","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcc191ea-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcc191eb-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"iddcc191ec-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attri