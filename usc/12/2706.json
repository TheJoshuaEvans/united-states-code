{"tag":"section","attrib":{"id":"iddcf39ef6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2706"},"text":null,"children":[{"tag":"num","attrib":{"value":"2706"},"text":"§ 2706.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency Homeowners’ Relief Fund","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"To carry out the purposes of this chapter, the Secretary is authorized to establish in the Treasury of the United States an Emergency Homeowners’ Relief Fund (hereinafter in this chapter referred to as the “fund”) which shall be available to the Secretary without fiscal year limitation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcf39ef7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2706/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for making payments in connection with defaulted loans or advances of credit insured under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2704"},"text":"section 2704 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf39ef8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2706/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for making emergency mortgage relief payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2705"},"text":"section 2705 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf39ef9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2706/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to pay such administrative expenses (or portion of such expenses) of carrying out the provisions of this chapter as the Secretary may deem necessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcf39efa-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/50/tI/s107"},"text":"Pub. L. 94–50, title I, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-07-02"},"text":"July 2, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/252"},"text":"89 Stat. 252","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/479/tII/s204/m/1"},"text":"Pub. L. 98–479, title II, § 204(m)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-17"},"text":"Oct. 17, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2234"},"text":"98 Stat. 2234","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tXIV/s1496/b/4"},"text":"Pub. L. 111–203, title XIV, § 1496(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2208"},"text":"124 Stat. 2208","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcf39efb-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcf39efc-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcf39efd-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" struck out subsec. (a) designation before “To carry out” and subsec. (b) which read as follows: “The fund shall be credited with—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) all amounts received by the Secretary as premium charges for insurance or as repayment for emergency mortgage relief payments under this chapter and all receipts, earnings, collections, or proceeds derived from any claim or other assets acquired by the Secretary under this Act; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) such amounts as may be appropriated for the purposes of this chapter.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/479/s204/m/1/A"},"text":"Pub. L. 98–479, § 204(m)(1)(A)","children":[],"tail":", (B), redesignated subsec. (a)(1) as subsec. (a) and subpars. (A), (B), and (C) as pars. (1), (2), and (3), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/479/s204/m/1/C"},"text":"Pub. L. 98–479, § 204(m)(1)(C)","children":[],"tail":", (D), redesignated subsec. (a)(2) as subsec. (b) and subpars. (A) and (B) as pars. (1) and (2), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcf39efe-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcf39eff-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective on the date on which final regulations implementing that amendment take effect, or on the date that is 18 months after the designated transfer date if such regulations have not been issued by that date, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1400/c"},"text":"section 1400(c) of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1601"},"text":"section 1601 of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddcf60f00-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Emergency Mortgage Relief","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tXIV/s1496/a"},"text":"Pub. L. 111–203, title XIV, § 1496(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2207"},"text":"124 Stat. 2207","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/203/tXIV/s1496/a"},"text":"“Effective ","children":[{"tag":"date","attrib":{"date":"2010-10-01"},"text":"October 1, 2010","children":[],"tail":", and notwithstanding any other provision of law, there is hereby made available to the Secretary of Housing and Urban Development such sums as are necessary to provide $1,000,000,000 in assistance through the Emergency Homeowners’ Relief Fund, which such Secretary shall establish pursuant to section 107 of the Emergency Housing Act of 1975 ("},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2706"},"text":"12 U.S.C. 2706","children":[],"tail":"), as such Act is amended by this section, for use for emergency mortgage assistance in accordance with title I of such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2701"},"text":"12 U.S.C. 2701","children":[],"tail":" et seq.].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
