{"tag":"section","attrib":{"id":"iddd688064-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5461"},"text":null,"children":[{"tag":"num","attrib":{"value":"5461"},"text":"§ 5461.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings and purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd688065-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5461/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd688066-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5461/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The proper functioning of the financial markets is dependent upon safe and efficient arrangements for the clearing and settlement of payment, securities, and other financial transactions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd688067-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5461/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Financial market utilities that conduct or support multilateral payment, clearing, or settlement activities may reduce risks for their participants and the broader financial system, but such utilities may also concentrate and create new risks and thus must be well designed and operated in a safe and sound manner.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd688068-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5461/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Payment, clearing, and settlement activities conducted by financial institutions also present important risks to the participating financial institutions and to the financial system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd688069-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5461/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Enhancements to the regulation and supervision of systemically important financial market utilities and the conduct of systemically important payment, clearing, and settlement activities by financial institutions are necessary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd68806a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5461/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide consistency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd68806b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5461/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote robust risk management and safety and soundness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd68806c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5461/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce systemic risks; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd68806d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5461/a/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support the stability of the broader financial system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd68806e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5461/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purpose of this subchapter is to mitigate systemic risk in the financial system and promote financial stability by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd68806f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5461/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" authorizing the Board of Governors to promote uniform standards for the—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd688070-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5461/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" management of risks by systemically important financial market utilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd688071-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5461/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct of systemically important payment, clearing, and settlement activities by financial institutions;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd688072-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5461/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing the Board of Governors an enhanced role in the supervision of risk management standards for systemically important financial market utilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd688073-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5461/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strengthening the liquidity of systemically important financial market utilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd688074-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5461/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing the Board of Governors an enhanced role in the supervision of risk management standards for systemically important payment, clearing, and settlement activities by financial institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd688075-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tVIII/s802"},"text":"Pub. L. 111–203, title VIII, § 802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1802"},"text":"124 Stat. 1802","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd688076-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd688077-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd688078-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tVIII/s814"},"text":"Pub. L. 111–203, title VIII, § 814","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1822"},"text":"124 Stat. 1822","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/203/tVIII/s814"},"text":"“This title [enacting this subchapter] is effective as of the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"iddd688079-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter known as the “Payment, Clearing, and Settlement Supervision Act of 2010”, see Short Title note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"section 5301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
