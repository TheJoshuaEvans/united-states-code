{"tag":"section","attrib":{"id":"iddd7b92f1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5601"},"text":null,"children":[{"tag":"num","attrib":{"value":"5601"},"text":"§ 5601.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remittance transfers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd7b92f2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5601/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd7b92f3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5601/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Automated clearinghouse system","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd7b92f4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5601/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expansion of system","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board of Governors shall work with the Federal reserve banks and the Department of the Treasury to expand the use of the automated clearinghouse system and other payment mechanisms for remittance transfers to foreign countries, with a focus on countries that receive significant remittance transfers from the United States, based on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd7b92f5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5601/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number, volume, and size of such transfers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7b92f6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5601/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the significance of the volume of such transfers relative to the external financial flows of the receiving country, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd7b92f7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5601/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount transferred; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd7b92f8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5601/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total volume of payments made by United States Government agencies to beneficiaries and retirees living abroad;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7b92f9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5601/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the feasibility of such an expansion; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7b92fa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5601/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability of the Federal Reserve System to establish payment gateways in different geographic regions and currency zones to receive remittance transfers and route them through the payments systems in the destination countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7b92fb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5601/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than one calendar year after ","children":[{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", and on April 30 biennially thereafter during the 10-year period beginning on "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", the Board of Governors shall submit a report to the Committee on Banking, Housing, and Urban Affairs of the Senate and the Committee on Financial Services of the House of Representatives on the status of the automated clearinghouse system and its progress in complying with the requirements of this subsection. The report shall include an analysis of adoption rates of International ACH Transactions rules and formats, the efficacy of increasing adoption rates, and potential recommendations to increase adoption."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd7b92fc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5601/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expansion of financial institution provision of remittance transfers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd7b92fd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5601/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of guidelines to institutions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each of the Federal banking agencies and the National Credit Union Administration shall provide guidelines to financial institutions under the jurisdiction of the agency regarding the offering of low-cost remittance transfers and no-cost or low-cost basic consumer accounts, as well as agency services to remittance transfer providers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7b92fe-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5601/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance to Financial Literacy Commission ","children":[{"tag":"ref","attrib":{"idref":"fn002537"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002537"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Financial Literacy and Education Commission”."}],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As part of its ","children":[{"tag":"ref","attrib":{"idref":"fn002538"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002538"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “their”."}],"tail":" duties as members of the Financial Literacy and Education Commission, the Bureau, the Federal banking agencies, and the National Credit Union Administration shall assist the Financial Literacy and Education Commission in executing the Strategy for Assuring Financial Empowerment (or the “SAFE Strategy”), as it relates to remittances."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd7b92ff-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5601/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd7b9300-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5601/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on feasibility of and impediments to use of remittance history in calculation of credit score","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before the end of the 365-day period beginning on ","children":[{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", the Director shall submit a report to the President, the Committee on Banking, Housing, and Urban Affairs of the Senate, and the Committee on Financial Services of the House of Representatives regarding—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd7b9301-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5601/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the manner in which the remittance history of a consumer could be used to enhance the credit score of the consumer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7b9302-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5601/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the current legal and business model barriers and impediments that impede the use of the remittance history of the consumer to enhance the credit score of the consumer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7b9303-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5601/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations on the manner in which maximum transparency and disclosure to consumers of exchange rates for remittance transfers subject to this title ","children":[{"tag":"ref","attrib":{"idref":"fn002539"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002539"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" See References in Text note below."}],"tail":" and the amendments made by this title "},{"tag":"ref","attrib":{"idref":"fn002539"},"text":"3","children":[],"tail":" may be accomplished, whether or not such exchange rates are known at the time of origination or payment by the consumer for the remittance transfer, including disclosure to the sender of the actual exchange rate used and the amount of currency that the recipient of the remittance transfer received, using the values of the currency into which the funds were exchanged, as contained in sections 1693"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"–1(a)(2)(D) "},{"tag":"ref","attrib":{"idref":"fn002539"},"text":"3","children":[],"tail":" and 1693"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"–1(a)(3) of title 15 (as amended by this section)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd7b9304-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1073"},"text":"Pub. L. 111–203, title X, § 1073","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2060"},"text":"124 Stat. 2060","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd7b9305-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd7b9306-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd7b9307-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This title, where footnoted in subsec. (e)(3), is title X of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1955"},"text":"124 Stat. 1955","children":[],"tail":", known as the Consumer Financial Protection Act of 2010, which enacted this subchapter and enacted, amended, and repealed numerous other sections and notes in the Code. For complete classification of title X to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 1693","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":"–1(a)(2) of title 15, referred to in subsec. (e)(3), does not contain a subpar. (D)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd7b9308-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1073"},"text":"section 1073 of Pub. L. 111–203","children":[],"tail":". Subsecs. (a) and (d) of "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1073"},"text":"section 1073 of Pub. L. 111–203","children":[],"tail":" enacted section 1693"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"–1 of Title 15, Commerce and Trade, amended "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1757"},"text":"section 1757 of this title","children":[],"tail":" and sections 1693, 1693b, 1693p, 1693q, and 1693r of Title 15, and amended provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1693"},"text":"section 1693 of Title 15","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd7b9309-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd7b930a-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Part effective 1 day after ","children":[{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s4"},"text":"section 4 of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"section 5301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
