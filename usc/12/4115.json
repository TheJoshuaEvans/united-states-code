{"tag":"section","attrib":{"id":"iddd19c3d7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4115"},"text":null,"children":[{"tag":"num","attrib":{"value":"4115"},"text":"§ 4115.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timetable for approval of plan of action","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd19c3d8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4115/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of deficiencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 60 days after receipt of a plan of action, the Secretary shall notify the owner in writing of any deficiencies that prevent the plan of action from being approved. If deficiencies are found, such notice shall describe alternative ways in which the plan may be revised to meet the criteria for approval.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd19c3d9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4115/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of approval","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd19c3da-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4115/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after receipt of a plan of action, or such longer period as the owner requests, the Secretary shall notify the owner in writing whether the plan of action, including any revisions, is approved. If approval is withheld, the notice shall describe—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd19c3db-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4115/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reasons for withholding approval; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd19c3dc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4115/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the actions that could be taken to meet the criteria for approval.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd19c3dd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4115/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Opportunity to revise","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall subsequently give the owner a reasonable opportunity to revise the plan of action and seek approval.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd19c3de-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4115/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delayed approval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary does not approve a plan of action within the period under subsection (b), the Secretary shall provide incentives and assistance under this subchapter in the amount that the owner would have received if the Secretary had complied with such time limitations. The preceding sentence shall not apply if the plan of action was not approved because of deficiencies. An owner may bring an action in the appropriate Federal district court to enforce this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd19c3df-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/242/tII/s225"},"text":"Pub. L. 100–242, title II, § 225","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/625/tVI/s601/a"},"text":"Pub. L. 101–625, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4266"},"text":"104 Stat. 4266","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
