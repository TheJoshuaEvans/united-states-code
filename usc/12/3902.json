{"tag":"section","attrib":{"id":"iddd1297c5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3902"},"text":null,"children":[{"tag":"num","attrib":{"value":"3902"},"text":"§ 3902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd1297c6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3902/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “appropriate Federal banking agency” has the same meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813/q"},"text":"section 1813(q) of this title","children":[],"tail":", except that for purposes of this chapter such term means the Board of Governors of the Federal Reserve System for—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd1297c7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3902/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bank holding companies and any nonbank subsidiary thereof;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd1297c8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3902/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Edge Act corporations organized under section 25(a) ","children":[{"tag":"ref","attrib":{"idref":"fn002358"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002358"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of the Federal Reserve Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t12/s611"},"text":"12 U.S.C. 611","children":[],"tail":" et seq.]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd1297c9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3902/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Agreement Corporations operating under section 25 of the Federal Reserve Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s601"},"text":"12 U.S.C. 601","children":[],"tail":" et seq.]; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1297ca-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3902/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “banking institution” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd1297cb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3902/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd1297cc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3902/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an insured bank as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813/h"},"text":"section 1813(h) of this title","children":[],"tail":" or any subsidiary of an insured bank;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd1297cd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3902/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Edge Act corporation organized under section 25(a) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of the Federal Reserve Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t12/s611"},"text":"12 U.S.C. 611","children":[],"tail":" et seq.]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd1297ce-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3902/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Agreement Corporation operating under section 25 of the Federal Reserve Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s601"},"text":"12 U.S.C. 601","children":[],"tail":" et seq.]; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd1297cf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3902/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent determined by the appropriate Federal banking agency, any agency or branch of a foreign bank, and any commercial lending company owned or controlled by one or more foreign banks or companies that control a foreign bank as those terms are defined in the International Banking Act of 1978 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s3101"},"text":"12 U.S.C. 3101","children":[],"tail":" et seq.]. The term “banking institution” shall not include a foreign bank."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd1297d0-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/181/tI"},"text":"Pub. L. 98–181, title I","children":[],"tail":" [title IX, § 903], "},{"tag":"date","attrib":{"date":"1983-11-30"},"text":"Nov. 30, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1278"},"text":"97 Stat. 1278","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd1297d1-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":