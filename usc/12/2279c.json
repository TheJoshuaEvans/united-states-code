{"tag":"section","attrib":{"id":"iddce7b81e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279c"},"text":null,"children":[{"tag":"num","attrib":{"value":"2279c"},"text":"§ 2279c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equalization of loan-making powers of certain district associations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddce7b81f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equalization of loan-making powers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce7b820-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddce7b821-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279c/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal land bank associations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), any association that owns a Federal land bank association authorized as of ","children":[{"tag":"date","attrib":{"date":"2007-01-01"},"text":"January 1, 2007","children":[],"tail":", to make long-term loans under subchapter I in its chartered territory within the geographic area described in subsection (b) may make short- and intermediate-term loans and otherwise operate as a production credit association under subchapter II within that same chartered territory."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce7b822-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279c/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Production credit associations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), any association that under its charter has subchapter I lending authority and that owns a production credit association authorized as of ","children":[{"tag":"date","attrib":{"date":"2007-01-01"},"text":"January 1, 2007","children":[],"tail":", to make short- and intermediate-term loans under subchapter II in the geographic area described in subsection (b) may make long-term loans and otherwise operate, directly or through a subsidiary association, as a Federal land bank association or Federal land credit association under subchapter I in the geographic area."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce7b823-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279c/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Farm Credit Bank","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2252/a"},"text":"section 2252(a) of this title","children":[],"tail":", the Farm Credit Bank with which any association had a written financing agreement as of "},{"tag":"date","attrib":{"date":"2007-01-01"},"text":"January 1, 2007","children":[],"tail":", may make loans and extend other comparable financial assistance with respect to, and may purchase, any loans made under the new authority provided under subparagraph (A) or (B) by an association exercising such authority."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce7b824-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required approvals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An association may exercise the additional authority provided for in paragraph (1) only after the exercise of the authority is approved by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddce7b825-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279c/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the board of directors of the association; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce7b826-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279c/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a majority of the voting stockholders of the association (or, if the association is a subsidiary of another association, the voting stockholders of the parent association) voting, in person or by proxy, at a duly authorized meeting of stockholders in accordance with the process described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2279e"},"text":"section 2279e of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce7b827-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section applies only to associations the chartered territory of which was within the geographic area served 