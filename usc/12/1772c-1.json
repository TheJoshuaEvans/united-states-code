{"tag":"section","attrib":{"id":"iddc433a07-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1772c–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1772c–1"},"text":"§ 1772c–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community development revolving loan fund for credit unions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc433a08-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1772c–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board may exercise the authority granted to it by the Community Development Credit Union Revolving Loan Fund Transfer Act, including any additional appropriation made or earnings accrued, subject only to this section and to regulations prescribed by the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc433a09-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1772c–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board may invest any idle Fund moneys in United States Treasury securities. Any interest accrued on such securities shall become a part of the Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc433a0a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1772c–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board may require that any loans made from the Fund be matched by increased shares in the borrower credit union.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc433a0b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1772c–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Interest earned by the Fund may be allocated by the Board for technical assistance to community development credit unions, subject to an appropriations Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc433a0c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1772c–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Fund” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As used in this section, the term “Fund” means the Community Development Credit Union Revolving Loan Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc433a0d-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-26/ch750"},"text":"June 26, 1934, ch. 750","children":[],"tail":", title I, § 130, as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/325/tI/s120/b"},"text":"Pub. L. 103–325, title I, § 120(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2188"},"text":"108 Stat. 2188","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc433a0e-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc433a0f-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddc433a10-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Community Development Credit Union Revolving Loan Fund Transfer Act, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/609"},"text":"Pub. L. 99–609","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-06"},"text":"Nov. 6, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3475"},"text":"100 Stat. 3475","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9822"},"text":"section 9822 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
