{"tag":"section","attrib":{"id":"iddb2769ef-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s245"},"text":null,"children":[{"tag":"num","attrib":{"value":"245"},"text":"§ 245.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies during recess of Senate","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President shall have power to fill all vacancies that may happen on the Board of Governors of the Federal Reserve System during the recess of the Senate by granting commissions which shall expire with the next session of the Senate.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddb2769f0-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1913-12-23/ch6/s10"},"text":"Dec. 23, 1913, ch. 6, § 10","children":[],"tail":" (par.), "},{"tag":"ref","attrib":{"href":"/us/stat/38/260"},"text":"38 Stat. 260","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1922-06-03/ch205"},"text":"June 3, 1922, ch. 205","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/620"},"text":"42 Stat. 620","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1935-08-23/ch614"},"text":"Aug. 23, 1935, ch. 614","children":[],"tail":", title II, § 203(a), 49, Stat. 704.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb2769f1-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb2769f2-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddb2769f3-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of fifth par. of section 10 of act ","children":[{"tag":"date","attrib":{"date":"1913-12-23"},"text":"Dec. 23, 1913","children":[],"tail":". For classification to this title of other pars. of section 10, see Codification note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s241"},"text":"section 241 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddb2769f4-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"iddb2769f5-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 203(a) of act ","children":[{"tag":"date","attrib":{"date":"1935-08-23"},"text":"Aug. 23, 1935","children":[],"tail":", changed name of Federal Reserve Board to Board of Governors of the Federal Reserve System."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
