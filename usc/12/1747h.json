{"tag":"section","attrib":{"id":"iddc3270b3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1747h"},"text":null,"children":[{"tag":"num","attrib":{"value":"1747h"},"text":"§ 1747h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of insurance contract by investor","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The investor, after written notice to the Secretary of his intention so to do, may terminate, as of the close of any operating year, any insurance contract made pursuant to this subchapter. The Secretary shall prescribe the events and conditions under which said Secretary shall have the option to terminate any insurance contract made pursuant to this subchapter, and the events and conditions under which said Secretary may reinstate any insurance contract terminated pursuant to this section or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1747g/a"},"text":"section 1747g(a) of this title","children":[],"tail":". If any insurance contract is terminated pursuant to this section, the Secretary may require the investor to pay an adjusted premium charge in such amount as the Secretary determines to be equitable, but not in excess of the aggregate amount of the premium charges which such investor otherwise would have been required to pay if such insurance contract had not been so terminated."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc3270b4-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-27/ch847"},"text":"June 27, 1934, ch. 847","children":[],"tail":", title VII, § 709, as added "},{"tag":"ref","attrib":{"href":"/us/act/1948-08-10/ch832"},"text":"Aug. 10, 1948, ch. 832","children":[],"tail":", title IV, § 401, "},{"tag":"ref","attrib":{"href":"/us/stat/62/1280"},"text":"62 Stat. 1280","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/act/1950-04-20/ch94"},"text":"Apr. 20, 1950, ch. 94","children":[],"tail":", title I, § 122, "},{"tag":"ref","attrib":{"href":"/us/stat/64/59"},"text":"64 Stat. 59","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/19/s1/a/3"},"text":"Pub. L. 90–19, § 1(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-05-25"},"text":"May 25, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/17"},"text":"81 Stat. 17","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc3270b5-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc3270b6-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc3270b7-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1967—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/19"},"text":"Pub. L. 90–19","children":[],"tail":" substituted “Secretary” for “Commissioner” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1950—Act ","children":[{"tag":"date","attrib":{"date":"1950-04-20"},"text":"Apr. 20, 1950","children":[],"tail":", substituted “Commissioner” for “Administrator” wherever appearing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
