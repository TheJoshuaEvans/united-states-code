{"tag":"section","attrib":{"id":"iddcbf2147-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2020"},"text":null,"children":[{"tag":"num","attrib":{"value":"2020"},"text":"§ 2020.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Related services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcbf2148-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2020/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Farm Credit Banks may provide technical assistance to borrowers, members, and applicants from the bank and associations in the district, including persons obligated on paper discounted by the bank, and may make available to them at their option such financial related services appropriate to their on-farm and aquatic operations as determined to be feasible by the board of directors of the bank, under regulations of the Farm Credit Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcbf2149-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2020/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to pass along cost of insurance premiums","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcbf214a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2020/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Farm Credit Bank may assess each production credit association, other association making direct loans under the authority provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2279b"},"text":"section 2279b of this title","children":[],"tail":", and other financing institution described in "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2015/b/1/B"},"text":"section 2015(b)(1)(B) of this title","children":[],"tail":" in the district in which the bank is located to cover the costs of making premium payments under part E of subchapter V."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbf214b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2020/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The assessment on any association or other financing institution described in paragraph (1) for any period shall be computed in an equitable manner, as determined by the Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcbf214c-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tI/s1"},"text":"Pub. L. 92–181, title I, § 1","children":[],"tail":".12, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tIV/s401"},"text":"Pub. L. 100–233, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1628"},"text":"101 Stat. 1628","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/tIV/s401/k"},"text":"Pub. L. 100–399, title IV, § 401(k)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-17"},"text":"Aug. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/996"},"text":"102 Stat. 996","children":[],"tail":