{"tag":"section","attrib":{"id":"iddcf39e9f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2616"},"text":null,"children":[{"tag":"num","attrib":{"value":"2616"},"text":"§ 2616.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State laws unaffected; inconsistent Federal and State provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"This chapter does not annul, alter, or affect, or exempt any person subject to the provisions of this chapter from complying with, the laws of any State with respect to settlement practices, except to the extent that those laws are inconsistent with any provision of this chapter, and then only to the extent of the inconsistency. The Bureau is authorized to determine whether such inconsistencies exist. The Bureau may not determine that any State law is inconsistent with any provision of this chapter if the Bureau determines that such law gives greater protection to the consumer. In making these determinations the Bureau shall consult with the appropriate Federal agencies.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddcf39ea0-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/533/s18"},"text":"Pub. L. 93–533, § 18","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-12-22"},"text":"Dec. 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1731"},"text":"88 Stat. 1731","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/205/s9"},"text":"Pub. L. 94–205, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-01-02"},"text":"Jan. 2, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/1159"},"text":"89 Stat. 1159","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1098/10"},"text":"Pub. L. 111–203, title X, § 1098(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2104"},"text":"124 Stat. 2104","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcf39ea1-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcf39ea2-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcf39ea3-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" substituted “Bureau” for “Secretary” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/205"},"text":"Pub. L. 94–205","children":[],"tail":" struck out “(a)” before “This chapter” and struck out subsec. (b) which provided for Federal protection against liability for acts done or omitted in good faith in accordance with the rules, regulations, or interpretations issued by the Secretary. See section 2617 (b) of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcf39ea4-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcf39ea5-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendme