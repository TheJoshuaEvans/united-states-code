{"tag":"section","attrib":{"id":"iddca75386-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1835"},"text":null,"children":[{"tag":"num","attrib":{"value":"1835"},"text":"§ 1835.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Insured depository institution capital requirements for transfers of small business obligations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddca75387-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1835/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accounting principles","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The accounting principles applicable to the transfer of a small business loan or a lease of personal property with recourse contained in reports or statements required to be filed with Federal banking agencies by a qualified insured depository institution shall be consistent with generally accepted accounting principles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca75388-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1835/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capital and reserve requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to the transfer of a small business loan or lease of personal property with recourse that is a sale under generally accepted accounting principles, each qualified insured depository institution shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddca75389-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1835/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish and maintain a reserve equal to an amount sufficient to meet the reasonable estimated liability of the institution under the recourse arrangement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca7538a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1835/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include, for purposes of applicable capital standards and other capital measures, only the amount of the retained recourse in the risk-weighted assets of the institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca7538b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1835/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified institutions criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An insured depository institution is a qualified insured depository institution for purposes of this section if, without regard to the accounting principles or capital requirements referred to in subsections (a) and (b), the institution is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddca7538c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1835/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" well capitalized; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca7538d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1835/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with the approval, by regulation or order, of the appropriate Federal banking agency, adequately capitalized.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca7538e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1835/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aggregate amount of recourse","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The total outstanding amount of recourse retained by a qualified insured depository institution with respect to transfers of small business loans and leases of personal property under subsections (a) and (b) shall not exceed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddca7538f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1835/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 15 percent of the risk-based capital of the institution; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca75390-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1835/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such greater amount, as established by the appropriate Federal banking agency by regulation or order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca75391-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1835/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institutions that cease to be qualified or exceed aggregate limits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an insured depository institution ceases to be a qualified insured depository institution or exceeds the limits under subsection (d), this section shall remain applicable to any transfers of small business loans or leases of personal property that occurred during the time that the institution was qualified and did not exceed such limit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca75392-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1835/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prompt corrective action not affected","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The capital of an insured depository institution shall be computed without regard to this section in determining whether the institution is adequately capitalized, undercapitalized, significantly undercapitalized, or critically undercapitalized under section 1831","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca75393-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1835/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"1994-09-23"},"text":"September 23, 1994","children":[],"tail":", each appropriate Federal banking agency shall promulgate final regulations implementing this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca75394-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1835/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternative system permitted","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddca75395-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1835/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the discretion of the appropriate Federal banking agency, this section shall not apply if the regulations of the agency provide that the aggregate amount of capital and reserves required with respect to the transfer of small business loans and leases of personal property with recourse does not exceed the aggregate amount of capital and reserves that would be required under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca75396-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1835/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing transactions not affected","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraph (1), this section shall remain in effect with respect to transfers of small business loans and leases of personal property with recourse by qualified insured depository institutions occurring before the effective date of regulations referred to in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca75397-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1835/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddca75398-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1835/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “adequately capitalized” has the same meaning as in section 1831","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":"(b) of this title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca75399-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1835/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “appropriate Federal banking agency” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"section 1813 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca7539a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1835/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “capital standards” has the same meaning as in section 1831","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":"(c) of this title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca7539b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1835/i/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Federal banking agencies” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"section 1813 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca7539c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1835/i/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “insured depository institution” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"section 1813 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca7539d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1835/i/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “other capital measures” has the meaning as in section 1831","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":"(c) of this title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca7539e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1835/i/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “recourse” has the meaning given to such term under generally accepted accounting principles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca7539f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1835/i/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “small business” means a business that meets the criteria for a small business concern established by the Small Business Administration under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s632/a"},"text":"section 632(a) of title 15","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca753a0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1835/i/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “well capitalized” has the same meaning as in section 1831","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":"(b) of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddca753a1-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/tII/s208"},"text":"Pub. L. 103–325, title II, § 208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2201"},"text":"108 Stat. 2201","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddca753a2-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddca753a3-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddca753a4-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Small Business Loan Securitization and Secondary Market Enhancement Act of 1994 and as part of the Riegle Community Development and Regulatory Improvement Act of 1994, and not as part of the Federal Deposit Insurance Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
