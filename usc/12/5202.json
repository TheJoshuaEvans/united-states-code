{"tag":"section","attrib":{"id":"iddd4985f1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5202"},"text":null,"children":[{"tag":"num","attrib":{"value":"5202"},"text":"§ 5202.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter, the following definitions shall apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd4985f2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5202/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate committees of Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “appropriate committees of Congress” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd4985f3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5202/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Banking, Housing, and Urban Affairs, the Committee on Finance, the Committee on the Budget, and the Committee on Appropriations of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd4985f4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5202/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Financial Services, the Committee on Ways and Means, the Committee on the Budget, and the Committee on Appropriations of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4985f5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5202/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Board” means the Board of Governors of the Federal Reserve System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4985f6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5202/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional support agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “congressional support agencies” means the Congressional Budget Office and the Joint Committee on Taxation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4985f7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5202/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Corporation” means the Federal Deposit Insurance Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4985f8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5202/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “financial institution” means any institution, including, but not limited to, any bank, savings association, credit union, security broker or dealer, or insurance company, established and regulated under the laws of the United States or any State, territory, or possession of the United States, the District of Columbia, Commonwealth of Puerto Rico, Commonwealth of Northern Mariana Islands, Guam, American Samoa, or the United States Virgin Islands, and having significant operations in the United States, but excluding any central bank of, or institution owned by, a foreign government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4985f9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5202/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Fund” means the Troubled Assets Insurance Financing Fund established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5212"},"text":"section 5212 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4985fa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5202/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4985fb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5202/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" TARP","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “TARP” means the Troubled Asset Relief Program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5211"},"text":"section 5211 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4985fc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5202/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Troubled assets","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “troubled assets” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd4985fd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5202/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" residential or commercial mortgages and any securities, obligations, or other instruments that are based on or related to such mortgages, that in each case was originated or issued on or before ","children":[{"tag":"date","attrib":{"date":"2008-03-14"},"text":"March 14, 2008","children":[],"tail":", the purchase of which the Secretary determines promotes financial market stability; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd4985fe-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5202/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other financial instrument that the Secretary, after consultation with the Chairman of the Board of Governors of the Federal Reserve System, determines the purchase of which is necessary to promote financial market stability, but only upon transmittal of such determination, in writing, to the appropriate committees of Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd4985ff-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/343/dA/s3"},"text":"Pub. L. 110–343, div. A, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3766"},"text":"122 Stat. 3766","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd498600-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd498601-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd498602-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act” and was translated as reading “this division”, meaning div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/343"},"text":"Pub. L. 110–343","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3765"},"text":"122 Stat. 3765","children":[],"tail":", known as the Emergency Economic Stabilization Act of 2008, to reflect the probable intent of Congress. For complete classification of division A to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5201"},"text":"section 5201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
