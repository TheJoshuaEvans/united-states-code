{"tag":"section","attrib":{"id":"iddd150953-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4008"},"text":null,"children":[{"tag":"num","attrib":{"value":"4008"},"text":"§ 4008.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations and reports by Board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd150954-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4008/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"After notice and opportunity to submit comment in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s553/c"},"text":"section 553(c) of title 5","children":[],"tail":", the Board, jointly with the Director of the Bureau of Consumer Financial Protection, shall prescribe regulations—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd150955-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4008/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out the provisions of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd150956-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4008/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prevent the circumvention or evasion of such provisions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd150957-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4008/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to facilitate compliance with such provisions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd150958-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4008/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations relating to improvement of check processing system","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to improve the check processing system, the Board shall consider (among other proposals) requiring, by regulation, that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd150959-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4008/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" depository institutions be charged based upon notification that a check or similar instrument will be presented for payment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd15095a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4008/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Reserve banks and depository institutions provide for check truncation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd15095b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4008/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" depository institutions be provided incentives to return items promptly to the depository institution of first deposit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd15095c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4008/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Reserve banks and depository institutions take such actions as are necessary to automate the process of returning unpaid checks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd15095d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4008/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" each depository institution and Federal Reserve bank—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd15095e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4008/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" place its endorsement, and other notations specified in regulations of the Board, on checks in the positions specified in such regulations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd15095f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4008/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" take such actions as are necessary to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd150960-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4008/b/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" automate the process of reading endorsements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd150961-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4008/b/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eliminate unnecessary endorsements;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd150962-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4008/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" within one business day after an originating depository institution is presented a check (for more than such minimum amount as the Board may prescribe)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd150963-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4008/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such originating depository institution determines whether it will pay such check; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd150964-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4008/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if such originating depository institution determines that it will not pay such check, such originating depository institution directly notify the receiving depository institution of such determination;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd150965-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4008/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regardless of where a check is cleared initially, all returned checks be eligible to be returned through the Federal Reserve System;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd150966-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4008/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal Reserve banks and depository institutions participate in the development and implementation of an electronic clearinghouse process to the extent the Board determines, pursuant to the study under subsection (f), that such a process is feasible; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd150967-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4008/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" originating depository institutions be permitted to return unpaid checks directly to, and obtain reimbursement for such checks directly from, the receiving depository institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd150968-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4008/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulatory responsibility of Board for payment system","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd150969-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4008/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibility for payment system","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to carry out the provisions of this chapter, the Board of Governors of the Federal Reserve System shall have the responsibility to regulate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd15096a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4008/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any aspect of the payment system, including the receipt, payment, collection, or clearing of checks; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd15096b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4008/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any related function of the payment system with respect to checks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd15096c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4008/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall prescribe such regulations as it may determine to be appropriate to carry out its responsibility under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd15096d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4008/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd15096e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4008/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation progress reports","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd15096f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4008/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall transmit a report to both Houses of the Congress not later than 18, 30, and 48 months after ","children":[{"tag":"date","attrib":{"date":"1987-08-10"},"text":"August 10, 1987","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd150970-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4008/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each such report shall describe—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd150971-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4008/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the actions taken and progress made by the Board to implement the schedules established in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4002"},"text":"section 4002 of this title","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd150972-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4008/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact of this chapter on consumers and depository institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd150973-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4008/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation of temporary schedule report","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd150974-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4008/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall transmit a report to both Houses of the Congress not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"1987-08-10"},"text":"August 10, 1987","children":[],"tail":", regarding the effects the temporary schedule established under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4002/c"},"text":"section 4002(c) of this title","children":[],"tail":" have had on depository institutions and the public."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd150975-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4008/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such report shall also assess the potential impact the implementation of the schedule established in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4002/b"},"text":"section 4002(b) of this title","children":[],"tail":" will have on depository institutions and the public, including an estimate of the risks to and losses of depository institutions and the benefits to consumers. Such report shall also contain such recommendations for legislative or administrative action as the Board may determine to be necessary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd150976-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4008/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comptroller General evaluation report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 6 months after ","children":[{"tag":"date","attrib":{"date":"1988-09-01"},"text":"September 1, 1988","children":[],"tail":", the Comptroller General of the United States shall transmit a report to the Congress evaluating the implementation and administration of this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd150977-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4008/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In prescribing regulations under subsections (a) and (b), the Board and the Director of the Bureau of Consumer Financial Protection, in the case of subsection (a), and the Board, in the case of subsection (b), shall consult with the Comptroller of the Currency, the Board of Directors of the Federal Deposit Insurance Corporation, and the National Credit Union Administration Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd150978-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4008/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electronic clearinghouse study","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd150979-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4008/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall study the feasibility of modernizing and accelerating the check payment system through the development of an electronic clearinghouse process utilizing existing telecommunications technology to avoid the necessity of actual presentment of the paper instrument to a payor institution before such institution is charged for the item.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd15097a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4008/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation; factors to be studied","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In connection with the study required under paragraph (1), the Board shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd15097b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4008/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with appropriate experts in telecommunications technology; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd15097c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4008/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider all practical and legal impediments to the development of an electronic clearinghouse process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd15097d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4008/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall report its conclusions to the Congress within 9 months of ","children":[{"tag":"date","attrib":{"date":"1987-08-10"},"text":"August 10, 1987","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd15097e-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/86/tVI/s609"},"text":"Pub. L. 100–86, title VI, § 609","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-08-10"},"text":"Aug. 10, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/647"},"text":"101 Stat. 647","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1086/d"},"text":"Pub. L. 111–203, title X, § 1086(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2086"},"text":"124 Stat. 2086","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd15097f-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd150980-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd150981-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (d)(3), “","children":[{"tag":"date","attrib":{"date":"1988-09-01"},"text":"September 1, 1988","children":[],"tail":"” substituted for “section 603(b) takes effect” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/100/86/s613/b"},"text":"section 613(b) of Pub. L. 100–86","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4001"},"text":"section 4001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd150982-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1086/d/1"},"text":"Pub. L. 111–203, § 1086(d)(1)","children":[],"tail":", inserted “, jointly with the Director of the Bureau of Consumer Financial Protection,” after “Board” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1086/d/2"},"text":"Pub. L. 111–203, § 1086(d)(2)","children":[],"tail":", added subsec. (e) and struck out former subsec. (e). Prior to amendment, text read as follows: “In prescribing regulations under subsections (a) and (b) of this section, the Board shall consult with the Comptroller of the Currency, the Board of Directors of the Federal Deposit Insurance Corporation, the Federal Home Loan Bank Board, and the National Credit Union Administration Board.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd150983-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd150984-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective on the designated transfer date, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1100H"},"text":"section 1100H of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd150985-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Exceptions in Areas Where Major Disaster Exists","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/18/tV/s50002"},"text":"Pub. L. 105–18, title V, § 50002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-06-12"},"text":"June 12, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/211"},"text":"111 Stat. 211","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/18/tV/s50002"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Truth in Lending Act","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"During the 240-day period beginning on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1997-06-12"},"text":"June 12, 1997","children":[],"tail":"], the Board of Governors of the Federal Reserve System may make exceptions to the Truth in Lending Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1601"},"text":"15 U.S.C. 1601","children":[],"tail":" et seq.] for transactions within an area in which the President, pursuant to section 401 of the Robert T. Stafford Disaster Relief and Emergency Assistance Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5170"},"text":"42 U.S.C. 5170","children":[],"tail":"], has determined, on or after "},{"tag":"date","attrib":{"date":"1997-02-28"},"text":"February 28, 1997","children":[],"tail":", that a major disaster exists, or within an area determined to be eligible for disaster relief under other Federal law by reason of damage related to the 1997 flooding of the Red River of the North, the Minnesota River, and the tributaries of such rivers, if the Board determines that the exception can reasonably be expected to alleviate hardships to the public resulting from such disaster that outweigh possible adverse effects."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expedited Funds Availability Act","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"During the 240-day period beginning on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1997-06-12"},"text":"June 12, 1997","children":[],"tail":"], the Board of Governors of the Federal Reserve System may make exceptions to the Expedited Funds Availability Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4001"},"text":"12 U.S.C. 4001","children":[],"tail":" et seq.] for depository institution offices located within any area referred to in subsection (a) of this section if the Board determines that the exception can reasonably be expected to alleviate hardships to the public resulting from such disaster that outweigh possible adverse effects."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Time Limit on Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any exception made under this section shall expire not later than ","children":[{"tag":"date","attrib":{"date":"1998-09-01"},"text":"September 1, 1998","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Publication Required","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board of Governors of the Federal Reserve System shall publish in the Federal Register a statement that—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes any exception made under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" explains how the exception can reasonably be expected to produce benefits to the public that outweigh possible adverse effects.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following prior acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/76/s2"},"text":"Pub. L. 103–76, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-12"},"text":"Aug. 12, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/752"},"text":"107 Stat. 752","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/485/s3"},"text":"Pub. L. 102–485, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2772"},"text":"106 Stat. 2772","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
