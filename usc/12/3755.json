{"tag":"section","attrib":{"id":"iddd104daa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3755"},"text":null,"children":[{"tag":"num","attrib":{"value":"3755"},"text":"§ 3755.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prerequisites to foreclosure","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd104dab-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3755/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd104dac-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3755/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Upon breach of covenant or condition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to foreclose a mortgage under this chapter upon the breach of a covenant or condition in the mortgage agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd104dad-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3755/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No other pending proceedings","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd104dae-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3755/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prior to commencement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No foreclosure may be commenced under this chapter unless any previously pending judicial or nonjudicial proceeding that has been separately instituted by the Secretary to foreclose the mortgage (other than under this chapter), has been withdrawn, dismissed, or otherwise terminated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd104daf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3755/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" After commencement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No separately instituted foreclosure proceeding on a mortgage which is the subject of a foreclosure proceeding under this chapter shall be instituted by the Secretary during the pendency of foreclosure pursuant to this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd104db0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3755/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other rights unaffected","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this chapter shall preclude the Secretary from—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd104db1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3755/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enforcing any right, other than foreclosure, under applicable Federal or State law, including any right to obtain a monetary judgment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd104db2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3755/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foreclosing under this chapter if the Secretary has obtained or is seeking any other remedy available pursuant to Federal or State law, or under the mortgage agreement, including the appointment of a receiver, mortgagee-in-possession status, or relief under an assignment of rents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd104db3-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/327/tII"},"text":"Pub. L. 103–327, title II","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-28"},"text":"Sept. 28, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2316"},"text":"108 Stat. 2316","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd104db4-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd104db5-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd104db6-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is based on section 806 of title VIII of S. 2281, One Hundred Third Congress, as reported ","children":[{"tag":"date","attrib":{"date":"1994-07-13"},"text":"July 13, 1994","children":[],"tail":", which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/103/327"},"text":"Pub. L. 103–327","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
