{"tag":"section","attrib":{"id":"iddd498698-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5218"},"text":null,"children":[{"tag":"num","attrib":{"value":"5218"},"text":"§ 5218.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conflicts of interest","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd498699-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5218/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall issue regulations or guidelines necessary to address and manage or to prohibit conflicts of interest that may arise in connection with the administration and execution of the authorities provided under this chapter, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd49869a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5218/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conflicts arising in the selection or hiring of contractors or advisors, including asset managers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd49869b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5218/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purchase of troubled assets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd49869c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5218/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the management of the troubled assets held;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd49869d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5218/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" post-employment restrictions on employees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd49869e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5218/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other potential conflict of interest, as the Secretary deems necessary or appropriate in the public interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd49869f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5218/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Regulations or guidelines required by this section shall be issued as soon as practicable after ","children":[{"tag":"date","attrib":{"date":"2008-10-03"},"text":"October 3, 2008","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd4986a0-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/343/dA/tI/s108"},"text":"Pub. L. 110–343, div. A, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3774"},"text":"122 Stat. 3774","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd4986a1-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd4986a2-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd4986a3-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a), was in the original “this Act” and was translated as reading “this division”, meaning div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/343"},"text":"Pub. L. 110–343","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3765"},"text":"122 Stat. 3765","children":[],"tail":", known as the Emergency Economic Stabilization Act of 2008, to reflect the probable intent of Congress. For complete classification of division A to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5201"},"text":"section 5201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
