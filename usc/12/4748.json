{"tag":"section","attrib":{"id":"iddd3fe997-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4748"},"text":null,"children":[{"tag":"num","attrib":{"value":"4748"},"text":"§ 4748.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement to Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd3fe998-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4748/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a participating State withdraws funds from a reserve fund pursuant to terms of the participation agreement permitted by subsection (d) or (r) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4745"},"text":"section 4745 of this title","children":[],"tail":", such participating State shall, not later than 15 calendar days after such withdrawal, submit to the Fund an amount computed by multiplying the amount withdrawn by the appropriate factor, as determined under subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3fe999-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4748/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factor","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The appropriate factor shall be obtained by dividing the total amount of contributions that have been made by the participating State to all reserve funds which were subject to reimbursement—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd3fe99a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4748/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by 2; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3fe99b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4748/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the total amount of contributions made by the participating State to all reserve funds, including if applicable, contributions that have been made by the State prior to becoming a participating State if the State continued its own capital access program in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4743/b"},"text":"section 4743(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3fe99c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4748/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of reimbursements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Fund may use funds reimbursed pursuant to this section to make reimbursements under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4747"},"text":"section 4747 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd3fe99d-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/tII/s258"},"text":"Pub. L. 103–325, title II, § 258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2213"},"text":"108 Stat. 2213","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
