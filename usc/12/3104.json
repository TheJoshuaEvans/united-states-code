{"tag":"section","attrib":{"id":"iddcff84ff-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3104"},"text":null,"children":[{"tag":"num","attrib":{"value":"3104"},"text":"§ 3104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Insurance of deposits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcff8500-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Objective","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In implementing this section, the Comptroller and the Federal Deposit Insurance Corporation shall each, by affording equal competitive opportunities to foreign and United States banking organizations in their United States operations, ensure that foreign banking organizations do not receive an unfair competitive advantage over United States banking organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcff8501-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposits of less than amount equal to the standard maximum deposit insurance amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No foreign bank may establish or operate a Federal branch which receives deposits of less than an amount equal to the standard maximum deposit insurance amount unless the branch is an insured branch as defined in section 3(s) of the Federal Deposit Insurance Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813/s"},"text":"12 U.S.C. 1813(s)","children":[],"tail":"], or unless the Comptroller determines by order or regulation that the branch is not engaged in domestic retail deposit activities requiring deposit insurance protection, taking account of the size and nature of depositors and deposit accounts."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcff8502-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3104/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposits required to be insured under State law","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcff8503-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3104/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" After ","children":[{"tag":"date","attrib":{"date":"1978-09-17"},"text":"September 17, 1978","children":[],"tail":", no foreign bank may establish a branch, and after one year following such date no foreign bank may operate a branch, in any State in which the deposits of a bank organized and existing under the laws of that State would be required to be insured, unless the branch is an insured branch as defined in section 3(s) of the Federal Deposit Insurance Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813/s"},"text":"12 U.S.C. 1813(s)","children":[],"tail":"], or unless the branch will not thereafter accept deposits of less than an amount equal to the standard maximum deposit insurance amount, or unless the Federal Deposit Insurance Corporation determines by order or regulation that the branch is not engaged in domestic retail deposit activities requiring deposit insurance protection, taking account of the size and nature of depositors and deposit accounts."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcff8504-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3104/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding the previous paragraph, a branch of a foreign bank in operation on ","children":[{"tag":"date","attrib":{"date":"1978-09-17"},"text":"September 17, 1978","children":[],"tail":", which has applied for Federal deposit insurance pursuant to section 5 of the Federal Deposit Insurance Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1815"},"text":"12 U.S.C. 1815","children":[],"tail":"] by "},{"tag":"date","attrib":{"date":"1979-09-17"},"text":"September 17, 1979","children":[],"tail":", and has not had such application denied, may continue to accept domestic retail deposits until "},{"tag":"date","attrib":{"date":"1980-01-31"},"text":"January 31, 1980","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcff8505-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3104/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retail deposit-taking by foreign banks","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcff8506-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3104/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"After ","children":[{"tag":"date","attrib":{"date":"1991-12-19"},"text":"December 19, 1991","children":[],"tail":", notwithstanding any other provision of this chapter or any provision of the Federal Deposit Insurance Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1811"},"text":"12 U.S.C. 1811","children":[],"tail":" et seq.], in order to accept or maintain domestic retail deposit accounts having balances of less than an amount equal to the standard maximum deposit insurance amount, and requiring deposit insurance protection, a foreign bank shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcff8507-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3104/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish 1 or more banking subsidiaries in the United States for that purpose; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcff8508-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3104/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtain Federal deposit insurance for any such subsidiary in accordance with the Federal Deposit Insurance Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcff8509-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3104/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Domestic retail deposit accounts with balances of less than an amount equal to the standard maximum deposit insurance amount that require deposit insurance protection may be accepted or maintained in a branch of a foreign bank only if such branch was an insured branch on ","children":[{"tag":"date","attrib":{"date":"1991-12-19"},"text":"December 19, 1991","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcff850a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3104/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Insured banks in U.S. territories","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, the term “foreign bank” does not include any bank organized under the laws of any territory of the United States, Puerto Rico, Guam, American Samoa, or the Virgin Islands the deposits of which are insured by the Federal Deposit Insurance Corporation pursuant to the Federal Deposit Insurance Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1811"},"text":"12 U.S.C. 1811","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcff850b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3104/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standard maximum deposit insurance amount defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “standard maximum deposit insurance amount” means the amount of the maximum amount of deposit insurance as determined under section 11(a)(1) of the Federal Deposit Insurance Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1821/a/1"},"text":"12 U.S.C. 1821(a)(1)","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcff850c-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/369/s6"},"text":"Pub. L. 95–369, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-09-17"},"text":"Sept. 17, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/614"},"text":"92 Stat. 614","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/64"},"text":"Pub. L. 96–64","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-09-14"},"text":"Sept. 14, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/412"},"text":"93 Stat. 412","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/242/tII/s214/a"},"text":"Pub. L. 102–242, title II, § 214(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2303"},"text":"105 Stat. 2303","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXVI/s1604/a/10"},"text":"Pub. L. 102–550, title XVI, § 1604(a)(10)","children":[],"tail":", (11), "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4082"},"text":"106 Stat. 4082","children":[],"tail":", 4083; "},{"tag":"ref","attrib":{"href":"/us/pl/102/558/tIII"},"text":"Pub. L. 102–558, title III","children":[],"tail":", §§ 302(a), 305, "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4224"},"text":"106 Stat. 4224","children":[],"tail":", 4226; "},{"tag":"ref","attrib":{"href":"/us/pl/103/328/tI/s107/a"},"text":"Pub. L. 103–328, title I, § 107(a)","children":[],"tail":", (d), "},{"tag":"date","attrib":{"date":"1994-09-29"},"text":"Sept. 29, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2358"},"text":"108 Stat. 2358","children":[],"tail":", 2360; "},{"tag":"ref","attrib":{"href":"/us/pl/109/173/s2/c/4"},"text":"Pub. L. 109–173, § 2(c)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-02-15"},"text":"Feb. 15, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3602"},"text":"119 Stat. 3602","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcff850d-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcff850e-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddcff850f-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For definition of “this chapter”, referred to in subsec. (d)(1), see References in Text note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s3101"},"text":"section 3101 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Federal Deposit Insurance Act, referred to in subsec. (d)(1), (3), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-21/ch967/s2"},"text":"act Sept. 21, 1950, ch. 967, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/873"},"text":"64 Stat. 873","children":[],"tail":", which is classified generally to chapter 16 (§ 1811 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1811"},"text":"section 1811 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcff8510-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsecs. (b), (c)(1), (d)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/173/s2/c/4/A"},"text":"Pub. L. 109–173, § 2(c)(4)(A)","children":[],"tail":", substituted “an amount equal to the standard maximum deposit insurance amount” for “$100,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/173/s2/c/4/B"},"text":"Pub. L. 109–173, § 2(c)(4)(B)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsecs. (a) to (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/328/s107/a"},"text":"Pub. L. 103–328, § 107(a)","children":[],"tail":", added subsec. (a) and redesignated former subsecs. (a) to (c) as (b) to (d), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/328/s107/d"},"text":"Pub. L. 103–328, § 107(d)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/s1604/a/10"},"text":"Pub. L. 102–550, § 1604(a)(10)","children":[],"tail":", struck out the subsec. (c) which was in effect before the subsec. (c) added by "},{"tag":"ref","attrib":{"href":"/us/pl/102/242/s214/a/3"},"text":"Pub. L. 102–242, § 214(a)(3)","children":[],"tail":", and which amended various other sections of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/558/s302/a/1"},"text":"Pub. L. 102–558, § 302(a)(1)","children":[],"tail":", inserted “domestic retail” before “deposit accounts” and “and requiring deposit insurance protection,” after “$100,000,” in introductory provisions. "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/s1604/a/11/A"},"text":"Pub. L. 102–550, § 1604(a)(11)(A)","children":[],"tail":", which made an identical amendment, was repealed, effective "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/pl/102/558/s305"},"text":"Pub. L. 102–558, § 305","children":[],"tail":", set out as a Repeal of Duplicative Provisions note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1815"},"text":"section 1815 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/558/s302/a/2"},"text":"Pub. L. 102–558, § 302(a)(2)","children":[],"tail":", substituted “Domestic retail deposit” for “Deposit” and inserted “that require deposit insurance protection” after “$100,000”. "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/s1604/a/11/B"},"text":"Pub. L. 102–550, § 1604(a)(11)(B)","children":[],"tail":", which made an identical amendment, was repealed, effective "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/pl/102/558/s305"},"text":"Pub. L. 102–558, § 305","children":[],"tail":", set out as a Repeal of Duplicative Provisions note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1815"},"text":"section 1815 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/s214/a/1"},"text":"Pub. L. 102–242, § 214(a)(1)","children":[],"tail":", (2), redesignated subsec. (b) as (b)(1) and designated last undesignated par. as par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/s214/a/3"},"text":"Pub. L. 102–242, § 214(a)(3)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/64"},"text":"Pub. L. 96–64","children":[],"tail":" inserted second par. which extended time for foreign banks to obtain required deposit insurance with respect to domestic existing branches."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcff8511-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcff8512-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/173"},"text":"Pub. L. 109–173","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2006-04-01"},"text":"Apr. 1, 2006","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/173/s2/e"},"text":"section 2(e) of Pub. L. 109–173","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1785"},"text":"section 1785 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcff8513-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/558/tIII/s302/b"},"text":"Pub. L. 102–558, title III, § 302(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4224"},"text":"106 Stat. 4224","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/558/tIII/s302/b"},"text":"“This section, and the amendments made by this section [amending this section], shall have the same effective date as the Federal Deposit Insurance Corporation Improvement Act of 1991 [","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242"},"text":"Pub. L. 102–242","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550"},"text":"Pub. L. 102–550","children":[],"tail":" effective as if included in the Federal Deposit Insurance Corporation Improvement Act of 1991, "},{"tag":"ref","attrib":{"href":"/us/pl/102/242"},"text":"Pub. L. 102–242","children":[],"tail":", as of "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/s1609/a"},"text":"section 1609(a) of Pub. L. 102–550","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s191"},"text":"section 191 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddcff8514-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/328/tI/s107/b"},"text":"Pub. L. 103–328, title I, § 107(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-29"},"text":"Sept. 29, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2359"},"text":"108 Stat. 2359","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/328/tI/s107/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each Federal banking agency, after consultation with the other Federal banking agencies to assure uniformity, shall revise the regulations adopted by such agency under section 6 of the International Banking Act of 1978 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s3104"},"text":"12 U.S.C. 3104","children":[],"tail":"] to ensure that the regulations are consistent with the objective set forth in section 6(a) of the International Banking Act of 1978."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Specific factors","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out paragraph (1), each Federal banking agency shall consider whether to permit an uninsured branch of a foreign bank to accept initial deposits of less than $100,000 only from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals who are not citizens or residents of the United States at the time of the initial deposit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" individuals who—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are not citizens of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are residents of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are employed by a foreign bank, foreign business, foreign government, or recognized international organization;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" persons to whom the branch or foreign bank has extended credit or provided other nondeposit banking services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foreign businesses and large United States businesses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"“(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foreign governmental units and recognized international organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"“(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" persons who are depositing funds in connection with the issuance of a financial instrument by the branch for the transmission of funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reduction in regulatory de minimis exemption","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out paragraph (1), each Federal banking agency shall limit any exemption which is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" available under any regulation prescribed pursuant to section 6(d) of the International Banking Act of 1978 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s3104/d"},"text":"12 U.S.C. 3104(d)","children":[],"tail":"] providing for the acceptance of initial deposits of less than $100,000 by an uninsured branch of a foreign bank; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" based on a percentage of the average deposits at such branch;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"to not more than 1 percent of the average deposits at such branch.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional relevant considerations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out paragraph (1), each Federal banking agency shall also consider the importance of maintaining and improving the availability of credit to all sectors of the United States economy, including the international trade finance sector of the United State [sic] economy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deadline for prescribing revised regulations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each Federal banking agency—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall publish final regulations under paragraph (1) in the Federal Register not later than 12 months after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1994-09-29"},"text":"Sept. 29, 1994","children":[],"tail":"]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may establish reasonable transition rules to facilitate any termination of any deposit-taking activities that were permissible under regulations that were in effect before the date of enactment of this Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term ‘Federal banking agency’ means—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Comptroller of the Currency with respect to Federal branches of foreign banks; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Deposit Insurance Corporation with respect to State branches of foreign banks; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘uninsured branch’ means a branch of a foreign bank that is not an insured branch, as defined in section 3(s)(3) of the Federal Deposit Insurance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813/s/3"},"text":"12 U.S.C. 1813(s)(3)","children":[],"tail":").”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
