{"tag":"section","attrib":{"id":"iddb631374-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635o"},"text":null,"children":[{"tag":"num","attrib":{"value":"635o"},"text":"§ 635o.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional statement of purpose","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purpose of this subchapter is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb631375-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635o/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to expand employment and economic growth in the United States by expanding United States exports to the markets of the developing world;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb631376-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635o/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to stimulate the economic development of countries in the developing world by improving their access to credit for the importation of United States products and services for developmental purposes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb631377-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635o/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to neutralize the predatory financing engaged in by many nations whose exports compete with United States exports, and thereby restore export competition to a market basis; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb631378-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635o/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage foreign governments to enter into effective and comprehensive agreements with the United States to end the use of tied aid credits for exports, and to limit and govern the use of export credit subsidies generally.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddb631379-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/181/tI"},"text":"Pub. L. 98–181, title I","children":[],"tail":" [title VI, § 642], "},{"tag":"date","attrib":{"date":"1983-11-30"},"text":"Nov. 30, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1263"},"text":"97 Stat. 1263","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb63137a-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb63137b-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddb63137c-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in text, was in the original “this part”, meaning part C (§§ 641–647, 650) of title VI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/181/tI"},"text":"Pub. L. 98–181, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-11-30"},"text":"Nov. 30, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1263"},"text":"97 Stat. 1263","children":[],"tail":", known as the Trade and Development Enhancement Act of 1983, which enacted this subchapter and "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1671g"},"text":"section 1671g of Title 19","children":[],"tail":", Customs Duties, and amended sections 1671a and 1671b of Title 19. For complete classification of this Act to the Code, see Short Title note below and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddb63137d-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"iddb63137e-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/181/tI"},"text":"Pub. L. 98–181, title I","children":[],"tail":" [title VI, § 641], "},{"tag":"date","attrib":{"date":"1983-11-30"},"text":"Nov. 30, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1263"},"text":"97 Stat. 1263","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/181/tI"},"text":"“This part [part C (§§ 641–647, 650) of title VI, enacting this subchapter and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1671g"},"text":"section 1671g of Title 19","children":[],"tail":", Customs Duties, and amending sections 1671a and 1671b of Title 19] may be referred to as the ‘Trade and Development Enhancement Act of 1983’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
