hildren":[],"tail":". Subsec. (b) of "},{"tag":"ref","attrib":{"href":"/us/pl/102/242/s232"},"text":"section 232 of Pub. L. 102–242","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1817"},"text":"section 1817 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddca4e2eb-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s353/1"},"text":"Pub. L. 111–203, § 353(1)","children":[],"tail":", struck out “by Federal Reserve Board” at end of heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s353/2"},"text":"Pub. L. 111–203, § 353(2)","children":[],"tail":", substituted “The Comptroller of the Currency” for “The Board of Governors of the Federal Reserve System,” and “section 1817(b)(2)(E)” for “section 1817(b)(2)(H)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s353/3"},"text":"Pub. L. 111–203, § 353(3)","children":[],"tail":", substituted “Comptroller” for “Board”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s353/4"},"text":"Pub. L. 111–203, § 353(4)","children":[],"tail":", added subpar. (A) and redesignated former subpars. (A) to (C) as (B) to (D), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/171"},"text":"Pub. L. 109–171","children":[],"tail":" repealed "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/s2704/d/16"},"text":"Pub. L. 104–208, § 2704(d)(16)","children":[],"tail":". See 1996 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/173/s3/a/9/A"},"text":"Pub. L. 109–173, § 3(a)(9)(A)","children":[],"tail":", struck out “the Board and” before “the Corporation” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(J). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/173/s3/a/9/B"},"text":"Pub. L. 109–173, § 3(a)(9)(B)","children":[],"tail":", substituted “the Corporation” for “the Board”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/173/s3/a/9/C"},"text":"Pub. L. 109–173, § 3(a)(9)(C)","children":[],"tail":", added subpar. (A) and struck out heading and text of former subpar. (A). Text read as follows: “The term ‘Board’ means the Board of Governors of the Federal Reserve System.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/173/s3/a/9/D"},"text":"Pub. L. 109–173, § 3(a)(9)(D)","children":[],"tail":", substituted “Corporation” for “Board”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s2704/d/16"},"text":"Pub. L. 104–208, § 2704(d)(16)","children":[],"tail":", which directed substitution of “"},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1817/b/2/G"},"text":"section 1817(b)(2)(G) of this title","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1817/b/2/H"},"text":"section 1817(b)(2)(H) of this title","children":[],"tail":"”, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/109/171"},"text":"Pub. L. 109–171","children":[],"tail":". See Effective Date of 1996 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/558/s303/b/4"},"text":"Pub. L. 102–558, § 303(b)(4)","children":[],"tail":", substituted “section 1817(b)(2)(H)” for “section 