{"tag":"section","attrib":{"id":"iddd44a499-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006"},"text":null,"children":[{"tag":"num","attrib":{"value":"5006"},"text":"§ 5006.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expedited recredit for consumers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd44a49a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recredit claims","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd44a49b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A consumer may make a claim for expedited recredit from the bank that holds the account of the consumer with respect to a substitute check, if the consumer asserts in good faith that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd44a49c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the bank charged the consumer’s account for a substitute check that was provided to the consumer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd44a49d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" either—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd44a49e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the check was not properly charged to the consumer’s account; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd44a49f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the consumer has a warranty claim with respect to such substitute check;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd44a4a0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the consumer suffered a resulting loss; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd44a4a1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the production of the original check or a better copy of the original check is necessary to determine the validity of any claim described in subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd44a4a2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 40-day period","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any claim under paragraph (1) with respect to a consumer account may be submitted by a consumer before the end of the 40-day period beginning on the later of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd44a4a3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the financial institution mails or delivers, by a means agreed to by the consumer, the periodic statement of account for such account which contains information concerning the transaction giving rise to the claim; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd44a4a4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the substitute check is made available to the consumer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd44a4a5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension under extenuating circumstances","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the ability of the consumer to submit the claim within the 40-day period under paragraph (2) is delayed due to extenuating circumstances, including extended travel or the illness of the consumer, the 40-day period shall be extended by a reasonable amount of time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd44a4a6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures for claims","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd44a4a7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To make a claim for an expedited recredit under subsection (a) with respect to a substitute check, the consumer shall provide to the bank that holds the account of such consumer—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd44a4a8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of the claim, including an explanation of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd44a4a9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" why the substitute check was not properly charged to the consumer’s account; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd44a4aa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the warranty claim with respect to such check;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd44a4ab-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement that the consumer suffered a loss and an estimate of the amount of the loss;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd44a4ac-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reason why production of the original check or a better copy of the original check is necessary to determine the validity of the charge to the consumer’s account or the warranty claim; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd44a4ad-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sufficient information to identify the substitute check and to investigate the claim.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd44a4ae-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Claim in writing","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd44a4af-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The bank holding the consumer account that is the subject of a claim by the consumer under subsection (a) may, in the discretion of the bank, require the consumer to submit the information required under paragraph (1) in writing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd44a4b0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Means of submission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A bank that requires a submission of information under subparagraph (A) may permit the consumer to make the submission electronically, if the consumer has agreed to communicate with the bank in that manner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd44a4b1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recredit to consumer","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd44a4b2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions for recredit","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The bank shall recredit a consumer account in accordance with paragraph (2) for the amount of a substitute check that was charged against the consumer account if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd44a4b3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a consumer submits a claim to the bank with respect to that substitute check that meets the requirement of subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd44a4b4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the bank has not—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd44a4b5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provided to the consumer—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddd44a4b6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/c/1/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the original check; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddd44a4b7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/c/1/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a copy of the original check (including an image or a substitute check) that accurately represents all of the information on the front and back of the original check, as of the time at which the original check was truncated; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd44a4b8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrated to the consumer that the substitute check was properly charged to the consumer account.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd44a4b9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing of recredit","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd44a4ba-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The bank shall recredit the consumer’s account for the amount described in paragraph (1) no later than the end of the business day following the business day on which the bank determines the consumer’s claim is valid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd44a4bb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recredit pending investigation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the bank has not yet determined that the consumer’s claim is valid before the end of the 10th business day after the business day on which the consumer submitted the claim, the bank shall recredit the consumer’s account for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd44a4bc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the lesser of the amount of the substitute check that was charged against the consumer account, or $2,500, together with interest if the account is an interest-bearing account, no later than the end of such 10th business day; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd44a4bd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the remaining amount of the substitute check that was charged against the consumer account, if any, together with interest if the account is an interest-bearing account, not later than the 45th calendar day following the business day on which the consumer submits the claim.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd44a4be-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of recredit","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd44a4bf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Next business day availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), a bank that provides a recredit to a consumer account under subsection (c) shall make the recredited funds available for withdrawal by the consumer by the start of the next business day after the business day on which the bank recredits the consumer’s account under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd44a4c0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Safeguard exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A bank may delay availability to a consumer of a recredit provided under subsection (c)(2)(B)(i) until the start of either the business day following the business day on which the bank determines that the consumer’s claim is valid or the 45th calendar day following the business day on which the consumer submits a claim for such recredit in accordance with subsection (b), whichever is earlier, in any of the following circumstances:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd44a4c1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New accounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The claim is made during the 30-day period beginning on the business day the consumer account was established.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd44a4c2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repeated overdrafts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Without regard to the charge that is the subject of the claim for which the recredit was made—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd44a4c3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on 6 or more business days during the 6-month period ending on the date on which the consumer submits the claim, the balance in the consumer account was negative or would have become negative if checks or other charges to the account had been paid; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd44a4c4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on 2 or more business days during such 6-month period, the balance in the consumer account was negative or would have become negative in the amount of $5,000 or more if checks or other charges to the account had been paid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd44a4c5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prevention of fraud losses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The bank has reasonable cause to believe that the claim is fraudulent, based on facts (other than the fact that the check in question or the consumer is of a particular class) that would cause a well-grounded belief in the mind of a reasonable person that the claim is fraudulent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd44a4c6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Overdraft fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No bank that, in accordance with paragraph (2), delays the availability of a recredit under subsection (c) to any consumer account may impose any overdraft fees with respect to drafts drawn by the consumer on such recredited amount before the end of the 5-day period beginning on the date notice of the delay in the availability of such amount is sent by the bank to the consumer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd44a4c7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reversal of recredit","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A bank may reverse a recredit to a consumer account if the bank—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd44a4c8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determines that a substitute check for which the bank recredited a consumer account under subsection (c) was in fact properly charged to the consumer account; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd44a4c9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notifies the consumer in accordance with subsection (f)(3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd44a4ca-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice to consumer","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd44a4cb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice if consumer claim not valid","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a bank determines that a substitute check subject to the consumer’s claim was in fact properly charged to the consumer’s account, the bank shall send to the consumer, no later than the business day following the business day on which the bank makes a determination—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd44a4cc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the original check or a copy of the original check (including an image or a substitute check) that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd44a4cd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/f/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accurately represents all of the information on the front and back of the original check (as of the time the original check was truncated); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd44a4ce-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/f/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is otherwise sufficient to determine whether or not the consumer’s claim is valid; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd44a4cf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an explanation of the basis for the determination by the bank that the substitute check was properly charged, including a statement that the consumer may request copies of any information or documents on which the bank relied in making the determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd44a4d0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of recredit","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a bank recredits a consumer account under subsection (c), the bank shall send to the consumer, no later than the business day following the business day on which the bank makes the recredit, a notice of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd44a4d1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the recredit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd44a4d2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date the recredited funds will be available for withdrawal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd44a4d3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of reversal of recredit","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to the notice required under paragraph (1), if a bank reverses a recredited amount under subsection (e), the bank shall send to the consumer, no later than the business day following the business day on which the bank reverses the recredit, a notice of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd44a4d4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the reversal; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd44a4d5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date the recredit was reversed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd44a4d6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mode of delivery","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A notice described in this subsection shall be delivered by United States mail or by any other means through which the consumer has agreed to receive account information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd44a4d7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other claims not affected","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Providing a recredit in accordance with this section shall not absolve the bank from liability for a claim made under any other law, such as a claim for wrongful dishonor under the Uniform Commercial Code, or from liability for additional damages under section 5005 or 5009 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd44a4d8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clarification concerning consumer possession","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A consumer who was provided a substitute check may make a claim for an expedited recredit under this section with regard to a transaction involving the substitute check whether or not the consumer is in possession of the substitute check.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd44a4d9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5006/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope of application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall only apply to customers who are consumers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd44a4da-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/100/s7"},"text":"Pub. L. 108–100, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-10-28"},"text":"Oct. 28, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1182"},"text":"117 Stat. 1182","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd44a4db-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd44a4dc-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd44a4dd-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective at the end of the 12-month period beginning on ","children":[{"tag":"date","attrib":{"date":"2003-10-28"},"text":"Oct. 28, 2003","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/100/s20"},"text":"section 20 of Pub. L. 108–100","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5001"},"text":"section 5001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
