{"tag":"section","attrib":{"id":"iddc40c8ef-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1759"},"text":null,"children":[{"tag":"num","attrib":{"value":"1759"},"text":"§ 1759.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc40c8f0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1759/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (b), Federal credit union membership shall consist of the incorporators and such other persons and incorporated and unincorporated organizations, to the extent permitted by rules and regulations prescribed by the Board, as may be elected to membership and as such shall each, subscribe to at least one share of its stock and pay the initial installment thereon and a uniform entrance fee if required by the board of directors. Shares may be issued in joint tenancy with right of survivorship with any persons designated by the credit union member, but no joint tenant shall be permitted to vote, obtain loans, or hold office, unless he is within the field of membership and is a qualified member.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc40c8f1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1759/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership field","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the other provisions of this section, the membership of any Federal credit union shall be limited to the membership described in one of the following categories:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc40c8f2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1759/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Single common-bond credit union","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"One group that has a common bond of occupation or association.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc40c8f3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1759/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multiple common-bond credit union","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"More than one group—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc40c8f4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1759/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each of which has (within the group) a common bond of occupation or association; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc40c8f5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1759/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of members, each of which (at the time the group is first included within the field of membership of a credit union described in this paragraph) does not exceed any numerical limitation applicable under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc40c8f6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1759/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community credit union","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Persons or organizations within a well-defined local community, neighborhood, or rural district.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc40c8f7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1759/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc40c8f8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1759/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grandfathered members and groups","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc40c8f9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1759/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding subsection (b)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddc40c8fa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1759/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person or organization that is a member of any Federal credit union as of ","children":[{"tag":"date","attrib":{"date":"1998-08-07"},"text":"August 7, 1998","children":[],"tail":", may remain a member of the credit union after "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"August 7, 1998","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc40c8fb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1759/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of any group whose members constituted a portion of the membership of any Federal credit union as of ","children":[{"tag":"date","attrib":{"date":"1998-08-07"},"text":"August 7, 1998","children":[],"tail":", shall continue to be eligible to become a member of that credit union, by virtue of membership in that group, after "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"August 7, 1998","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc40c8fc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1759/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Successors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the common bond of any group referred to in subparagraph (A) is defined by any particular organization or business entity, subparagraph (A) shall continue to apply with respect to any successor to the organization or entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc40c8fd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1759/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for underserved areas","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding subsection (b), in the case of a Federal credit union, the field of membership category of which is described in subsection (b)(2), the Board may allow the membership of the credit union to include any person or organization within a local community, neighborhood, or rural district if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc40c8fe-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1759/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Board determines that the local community, neighborhood, or rural district—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddc40c8ff-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1759/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an “investment area”, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4702/16"},"text":"section 4702(16) of this title","children":[],"tail":", and meets such additional requirements as the Board may impose; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc40c900-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1759/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is underserved, based on data of the Board and the Federal banking agencies (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"section 1813 of this title","children":[],"tail":"), by other depository institutions (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s461/b/1/A"},"text":"section 461(b)(1)(A) of this title","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc40c901-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1759/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the credit union establishes and maintains an office or facility in the local community, neighborhood, or rural district at which credit union services are available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc40c902-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1759/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multiple common-bond credit union group requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc40c903-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1759/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Numerical limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), only a group with fewer than 3,000 members shall be eligible to be included in the field of membership category of a credit union described in subsection (b)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc40c904-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1759/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any Federal credit union, the field of membership category of which is described in subsection (b)(2), the numerical limitation in paragraph (1) of this subsection shall not apply with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc40c905-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1759/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any group that the Board determines, in writing and in accordance with the guidelines and regulations issued under paragraph (3), could not feasibly or reasonably establish a new single common-bond credit union, the field of membership category of which is described in subsection (b)(1) because—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddc40c906-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1759/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the group lacks sufficient volunteer and other resources to support the efficient and effective operation of a credit union;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc40c907-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1759/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the group does not meet the criteria that the Board has determined to be important for the likelihood of success in establishing and managing a new credit union, including demographic characteristics such as geographical location of members, diversity of ages and income levels, and other factors that may affect the financial viability and stability of a credit union; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc40c908-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1759/d/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the group would be unlikely to operate a safe and sound credit union;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc40c909-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1759/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any group transferred from another credit union—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddc40c90a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1759/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in connection with a merger or consolidation recommended by the Board or any appropriate State credit union supervisor based on safety and soundness concerns with respect to that other credit union; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc40c90b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1759/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the Board in the Board’s capacity as conservator or liquidating agent with respect to that other credit union; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc40c90c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1759/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any group transferred in connection with a voluntary merger, having received conditional approval by the Administration of the merger application prior to ","children":[{"tag":"date","attrib":{"date":"1996-10-25"},"text":"October 25, 1996","children":[],"tail":", but not having consummated the merger prior to "},{"tag":"date","attrib":{"date":"1996-10-25"},"text":"October 25, 1996","children":[],"tail":", if the merger is consummated not later than 180 days after "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"August 7, 1998","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc40c90d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1759/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations and guidelines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall issue guidelines or regulations, after notice and opportunity for comment, setting forth the criteria that the Board will apply in determining under this subsection whether or not an additional group may be included within the field of membership category of an existing credit union described in subsection (b)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc40c90e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1759/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional membership eligibility provisions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc40c90f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1759/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership eligibility limited to immediate family or household members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No individual shall be eligible for membership in a credit union on the basis of the relationship of the individual to another person who is eligible for membership in the credit union, unless the individual is a member of the immediate family or household (as those terms are defined by the Board, by regulation) of the other person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc40c910-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1759/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retention of membership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1764"},"text":"section 1764 of this title","children":[],"tail":", once a person becomes a member of a credit union in accordance with this subchapter, that person or organization may remain a member of that credit union until the person or organization chooses to withdraw from the membership of the credit union."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc40c911-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1759/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria for approval of expansion of multiple common-bond credit unions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc40c912-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1759/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc40c913-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1759/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage the formation of separately chartered credit unions instead of approving an application to include an additional group within the field of membership of an existing credit union whenever practicable and consistent with reasonable standards for the safe and sound operation of the credit union; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc40c914-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1759/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the formation of a separate credit union by the group is not practicable or consistent with the standards referred to in subparagraph (A), require the inclusion of the group in the field of membership of a credit union that is within reasonable proximity to the location of the group whenever practicable and consistent with reasonable standards for the safe and sound operation of the credit union.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc40c915-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1759/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board may not approve any application by a Federal credit union, the field of membership category of which is described in subsection (b)(2) to include any additional group within the field of membership of the credit union (or an application by a Federal credit union described in subsection (b)(1) to include an additional group and become a credit union described in subsection (b)(2)), unless the Board determines, in writing, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc40c916-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1759/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the credit union has not engaged in any unsafe or unsound practice (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1786/b"},"text":"section 1786(b) of this title","children":[],"tail":") that is material during the 1-year period preceding the date of filing of the application;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc40c917-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1759/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the credit union is adequately capitalized;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc40c918-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1759/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the credit union has the administrative capability to serve the proposed membership group and the financial resources to meet the need for additional staff and assets to serve the new membership group;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc40c919-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1759/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any potential harm that the expansion of the field of membership of the credit union may have on any other insured credit union and its members is clearly outweighed in the public interest by the probable beneficial effect of the expansion in meeting the convenience and needs of the members of the group proposed to be included in the field of membership; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc40c91a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1759/f/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the credit union has met such additional requirements as the Board may prescribe, by regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc40c91b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1759/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations required for community credit unions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc40c91c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1759/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of well-defined local community, neighborhood, or rural district","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall prescribe, by regulation, a definition for the term “well-defined local community, neighborhood, or rural district” for purposes of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc40c91d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1759/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making any determination with regard to the field of membership of a credit union described in subsection (b)(3); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc40c91e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1759/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing the criteria applicable with respect to any such determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc40c91f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1759/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope of application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The definition prescribed by the Board under paragraph (1) shall apply with respect to any application to form a new credit union, or to alter or expand the field of membership of an existing credit union, that is filed with the Board after ","children":[{"tag":"date","attrib":{"date":"1998-08-07"},"text":"August 7, 1998","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc40c920-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-26/ch750"},"text":"June 26, 1934, ch. 750","children":[],"tail":", title I, § 109, formerly § 9, "},{"tag":"ref","attrib":{"href":"/us/stat/48/1219"},"text":"48 Stat. 1219","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1946-07-31/ch711/s2"},"text":"July 31, 1946, ch. 711, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/744"},"text":"60 Stat. 744","children":[],"tail":"; 1947 Reorg. Plan No. 1, § 401, eff. "},{"tag":"date","attrib":{"date":"1947-07-01"},"text":"July 1, 1947","children":[],"tail":", 12 F.R. 4534, "},{"tag":"ref","attrib":{"href":"/us/stat/61/952"},"text":"61 Stat. 952","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1948-06-29/ch711"},"text":"June 29, 1948, ch. 711","children":[],"tail":", §§ 1, 2, "},{"tag":"ref","attrib":{"href":"/us/stat/62/1091"},"text":"62 Stat. 1091","children":[],"tail":"; renumbered § 10 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/86/354/s1"},"text":"Pub. L. 86–354, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-09-22"},"text":"Sept. 22, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/631"},"text":"73 Stat. 631","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/206/s2/1"},"text":"Pub. L. 91–206, § 2(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-03-10"},"text":"Mar. 10, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/49"},"text":"84 Stat. 49","children":[],"tail":"; renumbered title I, § 109, "},{"tag":"ref","attrib":{"href":"/us/pl/91/468/s1/2"},"text":"Pub. L. 91–468, § 1(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-19"},"text":"Oct. 19, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/994"},"text":"84 Stat. 994","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/93/383/tVII/s722"},"text":"Pub. L. 93–383, title VII, § 722","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-22"},"text":"Aug. 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/719"},"text":"88 Stat. 719","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/630/tV/s502/b"},"text":"Pub. L. 95–630, title V, § 502(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3681"},"text":"92 Stat. 3681","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/219/tI"},"text":"Pub. L. 105–219, title I","children":[],"tail":", §§ 101–103, "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/914-917"},"text":"112 Stat. 914–917","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/351/tVII/s726/9"},"text":"Pub. L. 109–351, title VII, § 726(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-13"},"text":"Oct. 13, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2002"},"text":"120 Stat. 2002","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc40c921-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc40c922-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc40c923-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (c)(2)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/351"},"text":"Pub. L. 109–351","children":[],"tail":" made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4702/16"},"text":"section 4702(16) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/219/s101/1/A"},"text":"Pub. L. 105–219, § 101(1)(A)","children":[],"tail":", designated existing provisions as subsec. (a) and inserted heading and “Subject to subsection (b),” before “Federal credit union membership shall consist of”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/219/s101/1/B"},"text":"Pub. L. 105–219, § 101(1)(B)","children":[],"tail":", which directed the amendment of subsec. (a) by striking out “, except that Federal credit union membership shall be limited to groups having a common bond of occupation or association, or to groups within a well-defined neighborhood, community, or rural district” after “directors”, was executed by striking out such language which began with a semicolon rather than a comma after “directors” to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/219/s101/2"},"text":"Pub. L. 105–219, § 101(2)","children":[],"tail":", added subsecs. (b) to (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/219/s102"},"text":"Pub. L. 105–219, § 102","children":[],"tail":", added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/219/s103"},"text":"Pub. L. 105–219, § 103","children":[],"tail":", added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/630"},"text":"Pub. L. 95–630","children":[],"tail":" substituted “Board” for “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/383"},"text":"Pub. L. 93–383","children":[],"tail":" substituted “a uniform entrance fee if required by the board of directors” for “the entrance fee”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/206"},"text":"Pub. L. 91–206","children":[],"tail":" substituted “Administrator” for “Director”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1959—","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/354"},"text":"Pub. L. 86–354","children":[],"tail":" substituted “persons” for “person” before “designated”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1946—Act ","children":[{"tag":"date","attrib":{"date":"1946-07-31"},"text":"July 31, 1946","children":[],"tail":", inserted sentence at end permitting a Federal credit union to issue shares in joint tenancy with a right of survivorship."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc40c924-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddc40c925-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/630"},"text":"Pub. L. 95–630","children":[],"tail":" effective on expiration of 120 days after "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", and transitional provisions, see "},{"tag":"ref","attrib":{"href":"/us/pl/95/630/s509"},"text":"section 509 of Pub. L. 95–630","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1752"},"text":"section 1752 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddc40c926-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report and Congressional Review Requirement for Certain Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/219/tII/s205"},"text":"Pub. L. 105–219, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/923"},"text":"112 Stat. 923","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/219/tII/s205"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“A regulation prescribed by the Board [National Credit Union Administration Board] shall be treated as a major rule for purposes of chapter 8 of title 5, United States Code, if the regulation defines, or amends the definition of—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘immediate family or household’ for purposes of section 109(e)(1) of the Federal Credit Union Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1759/e/1"},"text":"12 U.S.C. 1759(e)(1)","children":[],"tail":"] (as added by section 101 of this Act); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘well-defined local community, neighborhood, or rural district’ for purposes of section 109(g) of the Federal Credit Union Act (as added by section 103 of this Act).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
