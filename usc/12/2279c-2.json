{"tag":"section","attrib":{"id":"iddce7b845-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279c–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2279c–2"},"text":"§ 2279c–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reconsideration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddce7b846-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279c–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A stockholder vote in favor of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce7b847-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279c–2/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the merger of districts under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce7b848-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279c–2/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the merger of banks within a district under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2279a"},"text":"section 2279a of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce7b849-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279c–2/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transfer of the lending authority of a Federal land bank or a merged bank having a Federal land bank as one of its constituents, under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2279b"},"text":"section 2279b of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce7b84a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279c–2/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the merger of two or more associations under section 2279c–1 or 2279f–1 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce7b84b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279c–2/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the termination of the status of an institution as a System institution under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2279d"},"text":"section 2279d of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce7b84c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279c–2/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the merger of similar banks under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2279f"},"text":"section 2279f of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall not take effect except in accordance with subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce7b84d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279c–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reconsideration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce7b84e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279c–2/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after a stockholder vote in favor of any of the actions described in subsection (a), the officer or employee that records such vote shall ensure that all stockholders of the voting entity receive notice of the final results of the vote.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce7b84f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279c–2/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A voluntary merger, transfer, or termination that is approved by a vote of the stockholders of two or more banks or associations shall not take effect until the expiration of 30 days after the date on which the stockholders of such banks or associations are notified of the final result of the vote in accordance with paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce7b850-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279c–2/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Petition filed","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a petition for reconsideration of a merger, transfer, or termination vote, signed by at least 15 percent of the stockholders of one or more of the affected banks or associations, is presented to the Farm Credit Administration within 30 days after the date of the notification required under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddce7b851-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279c–2/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a voluntary merger, transfer, or termination shall not take effect until the expiration of 60 days after the date on which the stockholders were notified of the final result of the vote; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce7b852-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279c–2/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a special meeting of the stockholders of the affected banks or associations shall be held during the period referred to in subparagraph (A) to reconsider the vote.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce7b853-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279c–2/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vote on reconsideration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a majority of stockholders of any one of the affected banks or associations voting, in person or by written proxy, at a duly authorized stockholders’ meeting, vote against the proposed merger, transfer, or termination, such action shall not take place.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce7b854-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279c–2/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to file petition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a petition for reconsideration of such vote is either not filed prior to the 60th day after the vote or, if timely filed, is not signed by at least 15 percent of the stockholders, the merger, transfer, or termination shall become effective in accordance with the plan of merger, transfer, or termination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddce7b855-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tVII/s7"},"text":"Pub. L. 92–181, title VII, § 7","children":[],"tail":".9, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tIV/s416"},"text":"Pub. L. 100–233, title IV, § 416","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1648"},"text":"101 Stat. 1648","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/tIV/s408/n"},"text":"Pub. L. 100–399, title IV, § 408(n)","children":[],"tail":", ("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"1988-08-17"},"text":"Aug. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1002"},"text":"102 Stat. 1002","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tV/s5411/40"},"text":"Pub. L. 115–334, title V, § 5411(40)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4683"},"text":"132 Stat. 4683","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddce7b856-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddce7b857-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddce7b858-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" struck out subsec. (c) which related to special reconsideration regarding the organization as a separate association by certain associations that had voluntarily merged with one or more associations."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s408/n/1"},"text":"Pub. L. 100–399, § 408(n)(1)","children":[],"tail":", substituted “this chapter” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2252/a/2"},"text":"section 2252(a)(2) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s408/n/5"},"text":"Pub. L. 100–399, § 408(n)(5)","children":[],"tail":", redesignated par. (5) as (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s408/n/2"},"text":"Pub. L. 100–399, § 408(n)(2)","children":[],"tail":", inserted reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2279f–1"},"text":"section 2279f–1 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s408/n/5"},"text":"Pub. L. 100–399, § 408(n)(5)","children":[],"tail":", redesignated par. (6) as (5). Former par. (5) redesignated (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s408/n/3"},"text":"Pub. L. 100–399, § 408(n)(3)","children":[],"tail":", substituted “or” for “and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s408/n/5"},"text":"Pub. L. 100–399, § 408(n)(5)","children":[],"tail":", redesignated par. (7) as (6). Former par. (6) redesignated (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s408/n/4"},"text":"Pub. L. 100–399, § 408(n)(4)","children":[],"tail":", substituted “section 2279f” for “section 2279f–1”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s408/n/5"},"text":"Pub. L. 100–399, § 408(n)(5)","children":[],"tail":", redesignated par. (7) as (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s408"},"text":"Pub. L. 100–399, § 408","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"), struck out comma before “shall not take effect” and substituted “such banks or” for “such”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddce7b859-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddce7b85a-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399"},"text":"Pub. L. 100–399","children":[],"tail":" effective as if enacted immediately after enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/100/233"},"text":"Pub. L. 100–233","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/s1001/a"},"text":"section 1001(a) of Pub. L. 100–399","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2002"},"text":"section 2002 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
