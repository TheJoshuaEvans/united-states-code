{"tag":"section","attrib":{"id":"iddd4e41f2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231"},"text":null,"children":[{"tag":"num","attrib":{"value":"5231"},"text":"§ 5231.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special Inspector General for the Troubled Asset Relief Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd4e41f3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Inspector General","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby established the Office of the Special Inspector General for the Troubled Asset Relief Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd4e41f4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment of Inspector General; removal","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd4e41f5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The head of the Office of the Special Inspector General for the Troubled Asset Relief Program is the Special Inspector General for the Troubled Asset Relief Program (in this section referred to as the “Special Inspector General”), who shall be appointed by the President, by and with the advice and consent of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4e41f6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The appointment of the Special Inspector General shall be made on the basis of integrity and demonstrated ability in accounting, auditing, financial analysis, law, management analysis, public administration, or investigations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4e41f7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The nomination of an individual as Special Inspector General shall be made as soon as practicable after the establishment of any program under sections 5211 and 5212 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4e41f8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Special Inspector General shall be removable from office in accordance with the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s403/b"},"text":"section 403(b) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4e41f9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7324"},"text":"section 7324 of title 5","children":[],"tail":", the Special Inspector General shall not be considered an employee who determines policies to be pursued by the United States in the nationwide administration of Federal law."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4e41fa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The annual rate of basic pay of the Special Inspector General shall be the annual rate of basic pay for an Inspector General under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s403/e"},"text":"section 403(e) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd4e41fb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd4e41fc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" It shall be the duty of the Special Inspector General to conduct, supervise, and coordinate audits and investigations of the purchase, management, and sale of assets by the Secretary of the Treasury under any program established by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5211"},"text":"section 5211 of this title","children":[],"tail":", and the management by the Secretary of any program established under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5212"},"text":"section 5212 of this title","children":[],"tail":", including by collecting and summarizing the following information:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd4e41fd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the categories of troubled assets purchased or otherwise procured by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd4e41fe-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A listing of the troubled assets purchased in each such category described under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd4e41ff-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An explanation of the reasons the Secretary deemed it necessary to purchase each such troubled asset.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd4e4200-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A listing of each financial institution that such troubled assets were purchased from.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd4e4201-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A listing of and detailed biographical information on each person or entity hired to manage such troubled assets.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd4e4202-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A current estimate of the total amount of troubled assets purchased pursuant to any program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5211"},"text":"section 5211 of this title","children":[],"tail":", the amount of troubled assets on the books of the Treasury, the amount of troubled assets sold, and the profit and loss incurred on each sale or disposition of each such troubled asset."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd4e4203-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/c/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A listing of the insurance contracts issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5212"},"text":"section 5212 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4e4204-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Special Inspector General shall establish, maintain, and oversee such systems, procedures, and controls as the Special Inspector General considers appropriate to discharge the duty under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4e4205-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In addition to the duties specified in paragraphs (1) and (2), the Inspector General shall also have the duties and responsibilities of inspectors general under chapter 4 of title 5.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4e4206-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd4e4207-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided under subparagraph (B) and in addition to the duties specified in paragraphs (1), (2), and (3), the Special Inspector General shall have the authority to conduct, supervise, and coordinate an audit or investigation of any action taken under this subchapter as the Special Inspector General determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd4e4208-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subparagraph (A) shall not apply to any action taken under section 5225, 5226, 5227, or 5233 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd4e4209-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers and authorities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd4e420a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In carrying out the duties specified in subsection (c), the Special Inspector General shall have the authorities provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s406"},"text":"section 406 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4e420b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Special Inspector General shall carry out the duties specified in subsection (c)(1) and (4) in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s404/b/1"},"text":"section 404(b)(1) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4e420c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of the Special Inspector General for the Troubled Asset Relief Program shall be treated as an office included under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s406/f/3"},"text":"section 406(f)(3) of title 5","children":[],"tail":" relating to the exemption from the initial determination of eligibility by the Attorney General."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd4e420d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personnel, facilities, and other resources","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd4e420e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd4e420f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Special Inspector General may select, appoint, and employ such officers and employees as may be necessary for carrying out the duties of the Special Inspector General, subject to the provisions of title 5 governing appointments in the competitive service, and the provisions of chapter 51 and subchapter III of chapter 53 of such title, relating to classification and General Schedule pay rates.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd4e4210-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd4e4211-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to clause (ii), the Special Inspector General may exercise the authorities of subsections (b) through (i) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3161"},"text":"section 3161 of title 5","children":[],"tail":" (without regard to subsection (a) of that section)."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd4e4212-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In exercising the employment authorities under subsection (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3161"},"text":"section 3161 of title 5","children":[],"tail":", as provided under clause (i) of this subparagraph—"}],"tail":null},{"tag":"subclause","attrib":{"id":"iddd4e4213-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/e/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Special Inspector General may not make any appointment on and after the date occurring 6 months after ","children":[{"tag":"date","attrib":{"date":"2009-04-24"},"text":"April 24, 2009","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddd4e4214-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/e/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paragraph (2) of that subsection (relating to periods of appointments) shall not apply; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddd4e4215-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/e/1/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no period of appointment may exceed the date on which the Office of the Special Inspector General terminates under subsection (k).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4e4216-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Special Inspector General may obtain services as authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109"},"text":"section 3109 of title 5","children":[],"tail":" at daily rates not to exceed the equivalent rate prescribed for grade GS–15 of the General Schedule by section 5332 of such title."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4e4217-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Special Inspector General may enter into contracts and other arrangements for audits, studies, analyses, and other services with public agencies and with private persons, and make such payments as may be necessary to carry out the duties of the Inspector General.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4e4218-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd4e4219-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon request of the Special Inspector General for information or assistance from any department, agency, or other entity of the Federal Government, the head of such entity shall, insofar as is practicable and not in contravention of any existing law, furnish such information or assistance to the Special Inspector General, or an authorized designee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd4e421a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whenever information or assistance requested by the Special Inspector General is, in the judgment of the Special Inspector General, unreasonably refused or not provided, the Special Inspector General shall report the circumstances to the appropriate committees of Congress without delay.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4e421b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd4e421c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/e/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided under subparagraph (B), if an annuitant receiving an annuity from the Civil Service Retirement and Disability Fund becomes employed in a position within the Office of the Special Inspector General for the Troubled Asset Relief Program, his annuity shall continue. An annuitant so reemployed shall not be considered an employee for purposes of chapter 83 or 84.","children":[{"tag":"ref","attrib":{"idref":"fn002460"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002460"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd4e421d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/e/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subparagraph (A) shall apply to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd4e421e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/e/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than 25 employees at any time as designated by the Special Inspector General; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd4e421f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/e/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay periods beginning after ","children":[{"tag":"date","attrib":{"date":"2009-04-24"},"text":"April 24, 2009","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd4e4220-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corrective responses to audit problems","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd4e4221-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take action to address deficiencies identified by a report or investigation of the Special Inspector General or other auditor engaged by the TARP; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4e4222-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certify to appropriate committees of Congress that no action is necessary or appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd4e4223-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation and coordination with other entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the duties, responsibilities, and authorities of the Special Inspector General under this section, the Special Inspector General shall work with each of the following entities, with a view toward avoiding duplication of effort and ensuring comprehensive oversight of the Troubled Asset Relief Program through effective cooperation and coordination:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd4e4224-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Inspector General of the Department of Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4e4225-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Inspector General of the Federal Deposit Insurance Corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4e4226-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Inspector General of the Securities and Exchange Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4e4227-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Inspector General of the Federal Reserve Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4e4228-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/g/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Inspector General of the Federal Housing Finance Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4e4229-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/g/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Inspector General of any other entity as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd4e422a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Council of the Inspectors General on Integrity and Efficiency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Special Inspector General shall be a member of the Council of the Inspectors General on Integrity and Efficiency established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s424"},"text":"section 424 of title 5","children":[],"tail":" until the date of termination of the Office of the Special Inspector General for the Troubled Asset Relief Program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd4e422b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd4e422c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 60 days after the confirmation of the Special Inspector General, and not later than 30 days following the end of each fiscal quarter, the Special Inspector General shall submit to the appropriate committees of Congress a report summarizing the activities of the Special Inspector General during that fiscal quarter. Each report shall include, for the period covered by such report, a detailed statement of all purchases, obligations, expenditures, and revenues associated with any program established by the Secretary of the Treasury under sections 5211 and 5212 of this title, as well as the information collected under subsection (c)(1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4e422d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than ","children":[{"tag":"date","attrib":{"date":"2009-09-01"},"text":"September 1, 2009","children":[],"tail":", the Special Inspector General shall submit a report to Congress assessing use of any funds, to the extent practical, received by a financial institution under the TARP and make the report available to the public, including posting the report on the home page of the website of the Special Inspector General within 24 hours after the submission of the report."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4e422e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Nothing in this subsection shall be construed to authorize the public disclosure of information that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd4e422f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/i/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specifically prohibited from disclosure by any other provision of law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd4e4230-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/i/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specifically required by Executive order to be protected from disclosure in the interest of national defense or national security or in the conduct of foreign affairs; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd4e4231-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/i/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a part of an ongoing criminal investigation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4e4232-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/i/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any reports required under this section shall also be submitted to the Congressional Oversight Panel established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5233"},"text":"section 5233 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4e4233-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/i/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided under paragraph (3), all reports submitted under this subsection shall be available to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd4e4234-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd4e4235-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Of the amounts made available to the Secretary of the Treasury under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5228"},"text":"section 5228 of this title","children":[],"tail":", $50,000,000 shall be available to the Special Inspector General to carry out this section, not later than 7 days after "},{"tag":"date","attrib":{"date":"2009-04-24"},"text":"April 24, 2009","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4e4236-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount available under paragraph (1) shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd4e4237-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Office of the Special Inspector General shall terminate on the later of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd4e4238-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/k/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date that the last troubled asset acquired by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5211"},"text":"section 5211 of this title","children":[],"tail":" has been sold or transferred out of the ownership or control of the Federal Government; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4e4239-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5231/k/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of expiration of the last insurance contract issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5212"},"text":"section 5212 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd4e423a-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/343/dA/tI/s121"},"text":"Pub. L. 110–343, div. A, title I, § 121","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3788"},"text":"122 Stat. 3788","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/15"},"text":"Pub. L. 111–15","children":[],"tail":", §§ 2–6, "},{"tag":"date","attrib":{"date":"2009-04-24"},"text":"Apr. 24, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1603-1605"},"text":"123 Stat. 1603–1605","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/b/35"},"text":"Pub. L. 117–286, § 4(b)(35)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4347"},"text":"136 Stat. 4347","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd4e423b-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd4e423c-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd4e423d-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Chapter 83 or 84, referred to in subsec. (e)(5)(A), probably means chapter 83 or 84 of Title 5, Government Organization and Employees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd4e423e-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/b/35/A"},"text":"Pub. L. 117–286, § 4(b)(35)(A)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t5/s403/b"},"text":"section 403(b) of title 5","children":[],"tail":".” for “section 3(b) of the Inspector General Act of 1978 (5 U.S.C. App.).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/b/35/B"},"text":"Pub. L. 117–286, § 4(b)(35)(B)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t5/s403/e"},"text":"section 403(e) of title 5","children":[],"tail":".” for “section 3(e) of the Inspector General Act of 1978 (5 U.S.C. App.).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/b/35/C"},"text":"Pub. L. 117–286, § 4(b)(35)(C)","children":[],"tail":", substituted “chapter 4 of title 5.” for “the Inspector General Act of 1978.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/b/35/D"},"text":"Pub. L. 117–286, § 4(b)(35)(D)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t5/s406"},"text":"section 406 of title 5","children":[],"tail":".” for “section 6 of the Inspector General Act of 1978.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/b/35/E"},"text":"Pub. L. 117–286, § 4(b)(35)(E)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t5/s404/b/1"},"text":"section 404(b)(1) of title 5","children":[],"tail":".” for “section 4(b)(1) of the Inspector General Act of 1978.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/b/35/F"},"text":"Pub. L. 117–286, § 4(b)(35)(F)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t5/s406/f/3"},"text":"section 406(f)(3) of title 5","children":[],"tail":"” for “section 6(e)(3) of the Inspector General Act of 1978 (5 U.S.C. App.)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/b/35/G"},"text":"Pub. L. 117–286, § 4(b)(35)(G)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t5/s424"},"text":"section 424 of title 5","children":[],"tail":"” for “section 11 of the Inspector General Act of 1978 (5 U.S.C. App.)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/15/s2/1"},"text":"Pub. L. 111–15, § 2(1)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/15/s2/2/A"},"text":"Pub. L. 111–15, § 2(2)(A)","children":[],"tail":", substituted “subsection (c)(1) and (4)” for “subsection (c)(1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/15/s2/2/B"},"text":"Pub. L. 111–15, § 2(2)(B)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/15/s3/1"},"text":"Pub. L. 111–15, § 3(1)","children":[],"tail":", designated existing provisions as subpar. (A) and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/15/s3/2"},"text":"Pub. L. 111–15, § 3(2)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (f) to (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/15/s4/2"},"text":"Pub. L. 111–15, § 4(2)","children":[],"tail":", added subsecs. (f) to (h). Former subsecs. (f) to (h) redesignated (i) to (k), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/15/s4/1"},"text":"Pub. L. 111–15, § 4(1)","children":[],"tail":", redesignated subsec. (f) as (i)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/15/s5/1"},"text":"Pub. L. 111–15, § 5(1)","children":[],"tail":", substituted “Not later than 60 days after the confirmation of the Special Inspector General, and not later than 30 days following the end of each fiscal quarter, the Special Inspector General shall submit to the appropriate committees of Congress a report summarizing the activities of the Special Inspector General during that fiscal quarter.” for “Not later than 60 days after the confirmation of the Special Inspector General, and every calendar quarter thereafter, the Special Inspector General shall submit to the appropriate committees of Congress a report summarizing the activities of the Special Inspector General during the 120-day period ending on the date of such report.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i)(2) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/15/s5/2"},"text":"Pub. L. 111–15, § 5(2)","children":[],"tail":", (3), added par. (2) and redesignated former pars. (2) and (3) as (3) and (4), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/15/s5/4"},"text":"Pub. L. 111–15, § 5(4)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/15/s4/1"},"text":"Pub. L. 111–15, § 4(1)","children":[],"tail":", redesignated subsec. (g) as (j)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (j)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/15/s6"},"text":"Pub. L. 111–15, § 6","children":[],"tail":", inserted “, not later than 7 days after "},{"tag":"date","attrib":{"date":"2009-04-24"},"text":"April 24, 2009","children":[],"tail":"” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (k). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/15/s4/1"},"text":"Pub. L. 111–15, § 4(1)","children":[],"tail":", redesignated subsec. (h) as (k)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
