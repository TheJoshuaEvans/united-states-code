{"tag":"section","attrib":{"id":"iddcc64c3f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2145"},"text":null,"children":[{"tag":"num","attrib":{"value":"2145"},"text":"§ 2145.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exchange of ownership interests","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"On the establishment of the consolidated bank, ownership interests of the stockholders and subscribers to the guaranty funds of the constituent district banks for cooperatives (including stock, participation certificates, and allocated equities) shall be exchanged for like ownership interests in the consolidated bank on a book value basis.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddcc64c40-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tIII/s3"},"text":"Pub. L. 92–181, title III, § 3","children":[],"tail":".24, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tIV/s415/2"},"text":"Pub. L. 100–233, title IV, § 415(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1644"},"text":"101 Stat. 1644","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
