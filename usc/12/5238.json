{"tag":"section","attrib":{"id":"iddd50b2af-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5238"},"text":null,"children":[{"tag":"num","attrib":{"value":"5238"},"text":"§ 5238.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study on mark-to-market accounting","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd50b2b0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5238/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Securities and Exchange Commission, in consultation with the Board and the Secretary, shall conduct a study on mark-to-market accounting standards as provided in Statement Number 157 of the Financial Accounting Standards Board, as such standards are applicable to financial institutions, including depository institutions. Such a study shall consider at a minimum—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd50b2b1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5238/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effects of such accounting standards on a financial institution’s balance sheet;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd50b2b2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5238/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impacts of such accounting on bank failures in 2008;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd50b2b3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5238/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact of such standards on the quality of financial information available to investors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd50b2b4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5238/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the process used by the Financial Accounting Standards Board in developing accounting standards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd50b2b5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5238/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the advisability and feasibility of modifications to such standards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd50b2b6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5238/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alternative accounting standards to those provided in such Statement Number 157.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd50b2b7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5238/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Securities and Exchange Commission shall submit to Congress a report of such study before the end of the 90-day period beginning on ","children":[{"tag":"date","attrib":{"date":"2008-10-03"},"text":"October 3, 2008","children":[],"tail":", containing the findings and determinations of the Commission, including such administrative and legislative recommendations as the Commission determines appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd50b2b8-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/343/dA/tI/s133"},"text":"Pub. L. 110–343, div. A, title I, § 133","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3798"},"text":"122 Stat. 3798","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
