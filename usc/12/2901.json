{"tag":"section","attrib":{"id":"iddcf858ff-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2901"},"text":null,"children":[{"tag":"num","attrib":{"value":"2901"},"text":"§ 2901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional findings and statement of purpose","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcf85900-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2901/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcf85901-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2901/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regulated financial institutions are required by law to demonstrate that their deposit facilities serve the convenience and needs of the communities in which they are chartered to do business;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf85902-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2901/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the convenience and needs of communities include the need for credit services as well as deposit services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf85903-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2901/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regulated financial institutions have continuing and affirmative obligation to help meet the credit needs of the local communities in which they are chartered.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcf85904-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2901/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" It is the purpose of this chapter to require each appropriate Federal financial supervisory agency to use its authority when examining financial institutions, to encourage such institutions to help meet the credit needs of the local communities in which they are chartered consistent with the safe and sound operation of such institutions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcf85905-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/128/tVIII/s802"},"text":"Pub. L. 95–128, title VIII, § 802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-10-12"},"text":"Oct. 12, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1147"},"text":"91 Stat. 1147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcf85906-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcf85907-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"iddcf85908-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/128/tVIII/s801"},"text":"Pub. L. 95–128, title VIII, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-10-12"},"text":"Oct. 12, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1147"},"text":"91 Stat. 1147","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/128/tVIII/s801"},"text":"“This title [enacting this chapter] may be cited as the ‘Community Reinvestment Act of 1977’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddcf85909-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Responsiveness to Community Needs for Financial Services","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/102/tVII/s715"},"text":"Pub. L. 106–102, title VII, § 715","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1470"},"text":"113 Stat. 1470","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/102/tVII/s715"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Study","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Treasury, in consultation with the Federal banking agencies (as defined in section 3(z) of the Federal Deposit Insurance Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813/z"},"text":"12 U.S.C. 1813(z)","children":[],"tail":"]), shall conduct a study of the extent to which adequate services are being provided as intended by the Community Reinvestment Act of 1977 ["},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2901"},"text":"12 U.S.C. 2901","children":[],"tail":" et seq.], including services in low- and moderate-income neighborhoods and for persons of modest means, as a result of the enactment of this Act [see Tables for classification]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Treasury shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before ","children":[{"tag":"date","attrib":{"date":"2000-03-15"},"text":"March 15, 2000","children":[],"tail":", submit a baseline report to the Congress on the study conducted pursuant to subsection (a); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before the end of the 2-year period beginning on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":"], in consultation with the Federal banking agencies, submit a final report to the Congress on the study conducted pursuant to subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recommendations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The final report submitted under paragraph (1)(B) shall include such recommendations as the Secretary determines to be appropriate for administrative and legislative action with respect to institutions covered under the Community Reinvestment Act of 1977 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2901"},"text":"12 U.S.C. 2901","children":[],"tail":" et seq.].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddcf8590a-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report on Community Development Lending","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tIX/s910"},"text":"Pub. L. 102–550, title IX, § 910","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3874"},"text":"106 Stat. 3874","children":[],"tail":", provided that not later than 12 months after "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", the Board of Governors of the Federal Reserve System shall submit a report to Congress comparing residential, small business, and commercial lending by insured depository institutions in low-income, minority, and distressed neighborhoods to such lending in other neighborhoods, with the report to contain comparisons of relevant risks and reasons for different lending practices."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
