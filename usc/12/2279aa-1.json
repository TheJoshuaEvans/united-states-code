{"tag":"section","attrib":{"id":"iddcea27d0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"2279aa–1"},"text":"§ 2279aa–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Agricultural Mortgage Corporation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcea27d1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcea27d2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby established a corporation to be known as the Federal Agricultural Mortgage Corporation, which shall be a federally chartered instrumentality of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcea27d3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institution within Farm Credit System","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation shall be an institution of the Farm Credit System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcea27d4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–1/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcea27d5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–1/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation shall not be liable for any debt or obligation of any other institution of the Farm Credit System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcea27d6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–1/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" System institutions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Farm Credit System and System institutions (other than the Corporation) shall not be liable for any debt or obligation of the Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcea27d7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Corporation shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcea27d8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in consultation with originators, develop uniform underwriting, security appraisal, and repayment standards for qualified loans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcea27d9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine the eligibility of agricultural mortgage marketing facilities to contract with the Corporation for the provision of guarantees for specific mortgage pools;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcea27da-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide guarantees for the timely repayment of principal and interest on securities representing interests in, or obligations backed by, pools of qualified loans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcea27db-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–1/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchase qualified loans and issue securities representing interests in, or obligations backed by, the qualified loans, guaranteed for the timely repayment of principal and interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcea27dc-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tVIII/s8"},"text":"Pub. L. 92–181, title VIII, § 8","children":[],"tail":".1, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tVII/s702"},"text":"Pub. L. 100–233, title VII, § 702","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1687"},"text":"101 Stat. 1687","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/105/tI/s103"},"text":"Pub. L. 104–105, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/163"},"text":"110 Stat. 163","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcea27dd-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcea27de-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcea27df-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/105"},"text":"Pub. L. 104–105","children":[],"tail":" added par. (4)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
