{"tag":"section","attrib":{"id":"iddd50b2ef-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5261"},"text":null,"children":[{"tag":"num","attrib":{"value":"5261"},"text":"§ 5261.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gain or loss from sale or exchange of certain preferred stock","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd50b2f0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5261/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of title 26, gain or loss from the sale or exchange of any applicable preferred stock by any applicable financial institution shall be treated as ordinary income or loss.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd50b2f1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5261/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable preferred stock","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “applicable preferred stock” means any stock—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd50b2f2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5261/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" which is preferred stock in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd50b2f3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5261/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal National Mortgage Association, established pursuant to the Federal National Mortgage Association Charter Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1716"},"text":"12 U.S.C. 1716","children":[],"tail":" et seq.), or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd50b2f4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5261/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Home Loan Mortgage Corporation, established pursuant to the Federal Home Loan Mortgage Corporation Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1451"},"text":"12 U.S.C. 1451","children":[],"tail":" et seq.), and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd50b2f5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5261/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd50b2f6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5261/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was held by the applicable financial institution on ","children":[{"tag":"date","attrib":{"date":"2008-09-06"},"text":"September 6, 2008","children":[],"tail":", or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd50b2f7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5261/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was sold or exchanged by the applicable financial institution on or after ","children":[{"tag":"date","attrib":{"date":"2008-01-01"},"text":"January 1, 2008","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"2008-09-07"},"text":"September 7, 2008","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd50b2f8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5261/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable financial institution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd50b2f9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5261/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (2), the term “applicable financial institution” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd50b2fa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5261/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a financial institution referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s582/c/2"},"text":"section 582(c)(2) of title 26","children":[],"tail":", or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd50b2fb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5261/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a depository institution holding company (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813/w/1"},"text":"section 1813(w)(1) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd50b2fc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5261/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for certain sales","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd50b2fd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5261/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a sale or exchange described in subsection (b)(2)(B), an entity shall be treated as an applicable financial institution only if it was an entity described in subparagraph (A) or (B) of paragraph (1) at the time of the sale or exchange, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd50b2fe-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5261/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a sale or exchange after ","children":[{"tag":"date","attrib":{"date":"2008-09-06"},"text":"September 6, 2008","children":[],"tail":", of preferred stock described in subsection (b)(2)(A), an entity shall be treated as an applicable financial institution only if it was an entity described in subparagraph (A) or (B) of paragraph (1) at all times during the period beginning on "},{"tag":"date","attrib":{"date":"2008-09-06"},"text":"September 6, 2008","children":[],"tail":", and ending on the date of the sale or exchange of the preferred stock."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd50b2ff-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5261/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for certain property not held on ","children":[{"tag":"date","attrib":{"date":"2008-09-06"},"text":"September 6, 2008","children":[],"tail":null}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Treasury or the Secretary’s delegate may extend the application of this section to all or a portion of the gain or loss from a sale or exchange in any case where—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd50b300-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5261/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an applicable financial institution sells or exchanges applicable preferred stock after ","children":[{"tag":"date","attrib":{"date":"2008-09-06"},"text":"September 6, 2008","children":[],"tail":", which the applicable financial institution did not hold on such date, but the basis of which in the hands of the applicable financial institution at the time of the sale or exchange is the same as the basis in the hands of the person which held such stock on such date, or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd50b301-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5261/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the applicable financial institution is a partner in a partnership which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd50b302-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5261/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" held such stock on ","children":[{"tag":"date","attrib":{"date":"2008-09-06"},"text":"September 6, 2008","children":[],"tail":", and later sold or exchanged such stock, or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd50b303-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5261/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sold or exchanged such stock during the period described in subsection (b)(2)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd50b304-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5261/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulatory authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury or the Secretary’s delegate may prescribe such guidance, rules, or regulations as are necessary to carry out the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd50b305-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5261/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply to sales or exchanges occurring after ","children":[{"tag":"date","attrib":{"date":"2007-12-31"},"text":"December 31, 2007","children":[],"tail":", in taxable years ending after such date."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd50b306-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/343/dA/tIII/s301"},"text":"Pub. L. 110–343, div. A, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3802"},"text":"122 Stat. 3802","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd50b307-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd50b308-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd50b309-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal National Mortgage Association Charter Act, referred to in subsec. (b)(1)(A), is title III of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-27/ch847"},"text":"act June 27, 1934, ch. 847","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/1252"},"text":"48 Stat. 1252","children":[],"tail":", which is classified generally to subchapter III (§ 1716 et seq.) of chapter 13 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1716"},"text":"section 1716 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Federal Home Loan Mortgage Corporation Act, referred to in subsec. (b)(1)(B), is title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/351"},"text":"Pub. L. 91–351","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-07-24"},"text":"July 24, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/451"},"text":"84 Stat. 451","children":[],"tail":", which is classified generally to chapter 11A (§ 1451 et seq.) of this title. For complete classification of this Act to the Code, see Short Title and Statement of Purpose note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1451"},"text":"section 1451 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
