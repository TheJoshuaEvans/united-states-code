{"tag":"section","attrib":{"id":"iddd425b44-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5002"},"text":null,"children":[{"tag":"num","attrib":{"value":"5002"},"text":"§ 5002.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter, the following definitions shall apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd425b45-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5002/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Account","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “account” means a deposit account at a bank.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd425b46-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5002/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bank","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “bank” means any person that is located in a State and engaged in the business of banking and includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd425b47-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5002/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any depository institution (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s461/b/1/A"},"text":"section 461(b)(1)(A) of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd425b48-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5002/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any Federal reserve bank;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd425b49-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5002/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any Federal home loan bank; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd425b4a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5002/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to the extent it acts as a payor—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd425b4b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5002/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Treasury of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd425b4c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5002/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Postal Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd425b4d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5002/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State government; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd425b4e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5002/2/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a unit of general local government (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4001/24"},"text":"section 4001(24) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd425b4f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5002/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Banking terms","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd425b50-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5002/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collecting bank","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “collecting bank” means any bank handling a check for collection except the paying bank.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd425b51-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5002/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Depositary bank","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “depositary bank” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd425b52-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5002/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the first bank to which a check is transferred, even if such bank is also the paying bank or the payee; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd425b53-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5002/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a bank to which a check is transferred for deposit in an account at such bank, even if the check is physically received and indorsed first by another bank.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd425b54-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5002/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Paying bank","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “paying bank” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd425b55-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5002/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the bank by which a check is payable, unless the check is payable at or through another bank and is sent to the other bank for payment or collection; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd425b56-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5002/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the bank at or through which a check is payable and to which the check is sent for payment or collection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd425b57-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5002/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Returning bank","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd425b58-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5002/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “returning bank” means a bank (other than the paying or depositary bank) handling a returned check or notice in lieu of return.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd425b59-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5002/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment as collecting bank","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No provision of this chapter shall be construed as affecting the treatment of a returning bank as a collecting bank for purposes of section 4–202(b) of the Uniform Commercial Code.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd425b5a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5002/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Board” means the Board of Governors of the Federal Reserve System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd425b5b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5002/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Business day","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “business day” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4001/3"},"text":"section 4001(3) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd425b5c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5002/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Check","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “check”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd425b5d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5002/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means a draft, payable on demand and drawn on or payable through or at an office of a bank, whether or not negotiable, that is handled for forward collection or return, including a substitute check and a travelers check; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd425b5e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5002/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include a noncash item or an item payable in a medium other than United States dollars.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd425b5f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5002/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consumer","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “consumer” means an individual who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd425b60-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5002/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a check handled for forward collection, draws the check on a consumer account; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd425b61-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5002/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a check handled for return, deposits the check into, or cashes the check against, a consumer account.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd425b62-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5002/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consumer account","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “consumer account” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4001/10"},"text":"section 4001(10) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd425b63-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5002/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Customer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “customer” means a person having an account with a bank.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd425b64-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5002/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forward collection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “forward collection” means the transfer by a bank of a check to a collecting bank for settlement or the paying bank for payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd425b65-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5002/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indemnifying bank","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “indemnifying bank” means a bank that is providing an indemnity under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5005"},"text":"section 5005 of this title","children":[],"tail":" with respect to a substitute check."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd425b66-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5002/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" MICR line","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “MICR line” and “magnetic ink character recognition line” mean the numbers, which may include the bank routing number, account number, check number, check amount, and other information, that are printed near the bottom of a check in magnetic ink in accordance with generally applicable industry standards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd425b67-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5002/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Noncash item","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “noncash item” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4001/14"},"text":"section 4001(14) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd425b68-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5002/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “person” means a natural person, corporation, unincorporated company, partnership, government unit or instrumentality, trust, or any other entity or organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd425b69-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5002/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reconverting bank","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “reconverting bank” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd425b6a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5002/15/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the bank that creates a substitute check; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd425b6b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5002/15/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if a substitute check is created by a person other than a bank, the first bank that transfers or presents such substitute check.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd425b6c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5002/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Substitute check","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “substitute check” means a paper reproduction of the original check that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd425b6d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5002/16/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains an image of the front and back of the original check;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd425b6e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5002/16/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bears a MICR line containing all the information appearing on the MICR line of the original check, except as provided under generally applicable industry standards for substitute checks to facilitate the processing of substitute checks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd44a45f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5002/16/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conforms, in paper stock, dimension, and otherwise, with generally applicable industry standards for substitute checks; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd44a460-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5002/16/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is suitable for automated processing in the same manner as the original check.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd44a461-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5002/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813/a"},"text":"section 1813(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd44a462-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5002/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Truncate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “truncate” means to remove an original paper check from the check collection or return process and send to a recipient, in lieu of such original paper check, a substitute check or, by agreement, information relating to the original check (including data taken from the MICR line of the original check or an electronic image of the original check), whether with or without subsequent delivery of the original paper check.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd44a463-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5002/19"},"text":null,"children":[{"tag":"num","attrib":{"value":"19"},"text":"(19)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uniform Commercial Code","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Uniform Commercial Code” means the Uniform Commercial Code in effect in a State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd44a464-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5002/20"},"text":null,"children":[{"tag":"num","attrib":{"value":"20"},"text":"(20)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Unless the context requires otherwise, the terms not defined in this section shall have the same meanings as in the Uniform Commercial Code.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd44a465-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/100/s3"},"text":"Pub. L. 108–100, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-10-28"},"text":"Oct. 28, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1178"},"text":"117 Stat. 1178","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd44a466-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd44a467-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd44a468-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/100"},"text":"Pub. L. 108–100","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-10-28"},"text":"Oct. 28, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1177"},"text":"117 Stat. 1177","children":[],"tail":", which is classified generally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5001"},"text":"section 5001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd44a469-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd44a46a-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective at the end of the 12-month period beginning on ","children":[{"tag":"date","attrib":{"date":"2003-10-28"},"text":"Oct. 28, 2003","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/100/s20"},"text":"section 20 of Pub. L. 108–100","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5001"},"text":"section 5001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
