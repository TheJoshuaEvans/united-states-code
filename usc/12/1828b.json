{"tag":"section","attrib":{"id":"iddc8f84dc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1828b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1828b"},"text":"§ 1828b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency data sharing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc8f84dd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1828b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent not prohibited by other law, the Comptroller of the Currency, the Director of the Office of Thrift Supervision, the Federal Deposit Insurance Corporation, and the Board of Governors of the Federal Reserve System shall make available to the Attorney General and the Federal Trade Commission any data in the possession of any such banking agency that the antitrust agency deems necessary for antitrust review of any transaction requiring notice to any such antitrust agency or the approval of such agency under section 1842 or 1843 of this title, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1828/c"},"text":"section 1828(c) of this title","children":[],"tail":", the National Bank Consolidation and Merger Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t12/s215"},"text":"12 U.S.C. 215","children":[],"tail":" et seq.], "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1467a"},"text":"section 1467a of this title","children":[],"tail":", or the antitrust laws."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc8f84de-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1828b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc8f84df-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1828b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any information or material obtained by any agency pursuant to subsection (a) shall be treated as confidential.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc8f84e0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1828b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures for disclosure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any information or material obtained by any agency pursuant to subsection (a) is proposed to be disclosed to a third party, written notice of such disclosure shall first be provided to the agency from which such information or material was obtained and an opportunity shall be given to such agency to oppose or limit the proposed disclosure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc8f84e1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1828b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other privileges not waived by disclosure under this section","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provision by any Federal agency of any information or material pursuant to subsection (a) to another agency shall not constitute a waiver, or otherwise affect, any privilege any agency or person may claim with respect to such information under Federal or State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc8f84e2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1828b/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No provision of this section shall be construed as preventing or limiting access to any information by any duly authorized committee of the Congress or the Comptroller General of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc8f84e3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1828b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Banking agency information sharing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The provisions of subsection (b) shall apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc8f84e4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1828b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any information or material obtained by any Federal banking agency (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813/z"},"text":"section 1813(z) of this title","children":[],"tail":") from any other Federal banking agency; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc8f84e5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1828b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any report of examination or other confidential supervisory information obtained by any State agency or authority, or any other person, from a Federal banking agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc8f84e6-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/102/tI/s132"},"text":"Pub. L. 106–102, title I, § 132","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1382"},"text":"113 Stat. 1382","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc8f84e7-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc8f84e8-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddc8f84e9-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Bank Consolidation and Merger Act, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1918-11-07/ch209"},"text":"act Nov. 7, 1918, ch. 209","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/86/230/s20"},"text":"Pub. L. 86–230, § 20","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-09-08"},"text":"Sept. 8, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/460"},"text":"73 Stat. 460","children":[],"tail":", which is classified generally to subchapter XVI (§ 215 et seq.) of chapter 2 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s215"},"text":"section 215 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddc8f84ea-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Gramm-Leach-Bliley Act, and not as part of the Federal Deposit Insurance Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc8f84eb-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddc8f84ec-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 120 days after ","children":[{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/102/s161"},"text":"section 161 of Pub. L. 106–102","children":[],"tail":", set out as an Effective Date of 1999 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s24"},"text":"section 24 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
