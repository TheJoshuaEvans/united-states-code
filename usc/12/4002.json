{"tag":"section","attrib":{"id":"iddd129891-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002"},"text":null,"children":[{"tag":"num","attrib":{"value":"4002"},"text":"§ 4002.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expedited funds availability schedules","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd129892-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Next business day availability for certain deposits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd129893-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cash deposits; wire transfers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (e) and in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4003"},"text":"section 4003 of this title","children":[],"tail":", in any case in which—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd129894-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any cash is deposited in an account at a receiving depository institution staffed by individuals employed by such institution, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd129895-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funds are received by a depository institution by wire transfer for deposit in an account at such institution,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"such cash or funds shall be available for withdrawal not later than the business day after the business day on which such cash is deposited or such funds are received for deposit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd129896-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Government checks; certain other checks","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds deposited in an account at a depository institution by check shall be available for withdrawal not later than the business day after the business day on which such funds are deposited in the case of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd129897-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a check which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd129898-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is drawn on the Treasury of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd129899-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is endorsed only by the person to whom it was issued;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd12989a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a check which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd12989b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is drawn by a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd12989c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is deposited in a receiving depository institution which is located in such State and is staffed by individuals employed by such institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd12989d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is deposited with a special deposit slip which indicates it is a check drawn by a State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd12989e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/a/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is endorsed only by the person to whom it was issued;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd12989f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a check which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd1298a0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is drawn by a unit of general local government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd1298a1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is deposited in a receiving depository institution which is located in the same State as such unit of general local government and is staffed by individuals employed by such institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd1298a2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/a/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is deposited with a special deposit slip which indicates it is a check drawn by a unit of general local government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd1298a3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/a/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is endorsed only by the person to whom it was issued;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd1298a4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the first $200 deposited by check or checks on any one business day;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd1298a5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a check deposited in a branch of a depository institution and drawn on the same or another branch of the same depository institution if both such branches are located in the same State or the same check processing region;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd1298a6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a cashier’s check, certified check, teller’s check, or depository check which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd1298a7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/a/2/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is deposited in a receiving depository institution which is staffed by individuals employed by such institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd1298a8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/a/2/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is deposited with a special deposit slip which indicates it is a cashier’s check, certified check, teller’s check, or depository check, as the case may be; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd1298a9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/a/2/F/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is endorsed only by the person to whom it was issued.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1298aa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permanent schedule","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd1298ab-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of funds deposited by local checks","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (3) of this subsection, subsections (a)(2), (d), and (e) of this section, and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4003"},"text":"section 4003 of this title","children":[],"tail":", not more than 1 business day shall intervene between the business day on which funds are deposited in an account at a depository institution by a check drawn on a local originating depository institution and the business day on which the funds involved are available for withdrawal."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1298ac-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of funds deposited by nonlocal checks","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (3) of this subsection, subsections (a)(2), (d), and (e) of this section, and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4003"},"text":"section 4003 of this title","children":[],"tail":", not more than 4 business days shall intervene between the business day on which funds are deposited in an account at a depository institution by a check drawn on a nonlocal originating depository institution and the business day on which such funds are available for withdrawal."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1298ad-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time period adjustments for cash withdrawal of certain checks","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd1298ae-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), funds deposited in an account in a depository institution by check (other than a check described in subsection (a)(2)) shall be available for cash withdrawal not later than the business day after the business day on which such funds otherwise are available under paragraph (1) or (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd1298af-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 5 p.m. cash availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than $400 (or the maximum amount allowable in the case of a withdrawal from an automated teller machine but not more than $400) of funds deposited by one or more checks to which this paragraph applies shall be available for cash withdrawal not later than 5 o’clock post meridian of the business day on which such funds are available under paragraph (1) or (2). If funds deposited by checks described in both paragraph (1) and paragraph (2) become available for cash withdrawal under this paragraph on the same business day, the limitation contained in this subparagraph shall apply to the aggregate amount of such funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd1298b0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" $200 availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amount available for withdrawal under this paragraph shall be in addition to the amount available under subsection (a)(2)(D).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1298b1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subsection shall apply with respect to funds deposited by check in an account at a depository institution on or after ","children":[{"tag":"date","attrib":{"date":"1990-09-01"},"text":"September 1, 1990","children":[],"tail":", except that the Board may, by regulation, make this subsection or any part of this subsection applicable earlier than "},{"tag":"date","attrib":{"date":"1990-09-01"},"text":"September 1, 1990","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1298b2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary schedule","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd1298b3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of local checks","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd1298b4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraph (B) of this paragraph, subsections (a)(2), (d), and (e) of this section, and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4003"},"text":"section 4003 of this title","children":[],"tail":", not more than 2 business days shall intervene between the business day on which funds are deposited in an account at a depository institution by a check drawn on a local originating depository institution and the business day on which such funds are available for withdrawal."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd1298b5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time period adjustment for cash withdrawal of certain checks","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd1298b6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in clause (ii), funds deposited in an account in a depository institution by check drawn on a local depository institution that is not a participant in the same check clearinghouse association as the receiving depository institution (other than a check described in subsection (a)(2)) shall be available for cash withdrawal not later than the business day after the business day on which such funds otherwise are available under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd1298b7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 5 p.m. cash availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than $400 (or the maximum amount allowable in the case of a withdrawal from an automated teller machine but not more than $400) of funds deposited by one or more checks to which this subparagraph applies shall be available for cash withdrawal not later than 5 o’clock post meridian of the business day on which such funds are available under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd1298b8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/c/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" $200 availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amount available for withdrawal under this subparagraph shall be in addition to the amount available under subsection (a)(2)(D).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1298b9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of nonlocal checks","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsections (a)(2), (d), and (e) of this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4003"},"text":"section 4003 of this title","children":[],"tail":", not more than 6 business days shall intervene between the business day on which funds are deposited in an account at a depository institution by a check drawn on a nonlocal originating depository institution and the business day on which such funds are available for withdrawal."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1298ba-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subsection shall apply with respect to funds deposited by check in an account at a depository institution after ","children":[{"tag":"date","attrib":{"date":"1988-08-31"},"text":"August 31, 1988","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"1990-09-01"},"text":"September 1, 1990","children":[],"tail":", except as may be otherwise provided under subsection (b)(4)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1298bb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time period adjustments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd1298bc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction generally","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the Board, jointly with the Director of the Bureau of Consumer Financial Protection, shall, by regulation, reduce the time periods established under subsections (b), (c), and (e) to as short a time as possible and equal to the period of time achievable under the improved check clearing system for a receiving depository institution to reasonably expect to learn of the nonpayment of most items for each category of checks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1298bd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension for certain deposits in noncontiguous States or territories","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, any time period established under subsection (b), (c), or (e) shall be extended by 1 business day in the case of any deposit which is both—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd1298be-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deposited in an account at a depository institution which is located in Alaska, Hawaii, Puerto Rico, American Samoa, the Commonwealth of the Northern Mariana Islands, Guam, or the Virgin Islands; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd1298bf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deposited by a check drawn on an originating depository institution which is not located in the same State, commonwealth, or territory as the receiving depository institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1298c0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposits at ATM","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd1298c1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonproprietary ATM","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd1298c2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 4 business days shall intervene between the business day a deposit described in subparagraph (B) is made at a nonproprietary automated teller machine (for deposit in an account at a depository institution) and the business day on which funds from such deposit are available for withdrawal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd1298c3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposits described in this paragraph ","children":[{"tag":"ref","attrib":{"idref":"fn002361"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002361"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “subparagraph”."}],"tail":null}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A deposit is described in this subparagraph if it is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd1298c4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a cash deposit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd1298c5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a deposit made by a check described in subsection (a)(2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd1298c6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/e/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a deposit made by a check drawn on a local originating depository institution (other than a check described in subsection (a)(2)); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd1298c7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/e/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a deposit made by a check drawn on a nonlocal originating depository institution (other than a check described in subsection (a)(2)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1298c8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proprietary ATM—temporary and permanent schedules","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of subsections (a), (b), and (c) shall apply with respect to any funds deposited at a proprietary automated teller machine for deposit in an account at a depository institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1298c9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study and report on ATM’s","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall, either directly or through the Consumer Advisory Council, establish and maintain a dialogue with depository institutions and their suppliers on the computer software and hardware available for use by automated teller machines, and shall, not later than September 1 of each of the first 3 calendar years beginning after ","children":[{"tag":"date","attrib":{"date":"1987-08-10"},"text":"August 10, 1987","children":[],"tail":", report to the Congress regarding such software and hardware and regarding the potential for improving the processing of automated teller machine deposits."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1298ca-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Check return; notice of nonpayment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No provision of this section shall be construed as requiring that, with respect to all checks deposited in a receiving depository institution—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd1298cb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such checks be physically returned to such depository institution; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1298cc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4002/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any notice of nonpayment of any such check be given to such depository institution within the times set forth in subsection (a), (b), (c), or (e) or in the regulations issued under any such subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd1298cd-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/86/tVI/s603"},"text":"Pub. L. 100–86, title VI, § 603","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-08-10"},"text":"Aug. 10, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/637"},"text":"101 Stat. 637","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/625/tX/s1001"},"text":"Pub. L. 101–625, title X, § 1001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4424"},"text":"104 Stat. 4424","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/242/tII/s227/a"},"text":"Pub. L. 102–242, title II, § 227(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2307"},"text":"105 Stat. 2307","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1086/a"},"text":"Pub. L. 111–203, title X, § 1086(a)","children":[],"tail":", (e), "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2085"},"text":"124 Stat. 2085","children":[],"tail":", 2086; "},{"tag":"ref","attrib":{"href":"/us/pl/115/174/tII/s208/a/2"},"text":"Pub. L. 115–174, title II, § 208(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-05-24"},"text":"May 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1312"},"text":"132 Stat. 1312","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd1298ce-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd1298cf-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd1298d0-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (d)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/174"},"text":"Pub. L. 115–174","children":[],"tail":" inserted “American Samoa, the Commonwealth of the Northern Mariana Islands, Guam,” after “Puerto Rico,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1086/e/1"},"text":"Pub. L. 111–203, § 1086(e)(1)","children":[],"tail":", substituted “$200” for “$100”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b)(3)(C), (c)(1)(B)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1086/e/2"},"text":"Pub. L. 111–203, § 1086(e)(2)","children":[],"tail":", (3), substituted “$200” for “$100” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1086/a"},"text":"Pub. L. 111–203, § 1086(a)","children":[],"tail":", inserted “, jointly with the Director of the Bureau of Consumer Financial Protection,” after “Board”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/s227/b/1/A"},"text":"Pub. L. 102–242, § 227(b)(1)(A)","children":[],"tail":", struck out “—temporary schedule” after “ATM” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/s227/a"},"text":"Pub. L. 102–242, § 227(a)","children":[],"tail":", struck out subpar. (C) which read as follows: “This paragraph shall apply with respect to funds deposited at a nonproprietary automated teller machine after "},{"tag":"date","attrib":{"date":"1988-08-31"},"text":"August 31, 1988","children":[],"tail":", and prior to the expiration of the 2-year period beginning on "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"November 28, 1990","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/s227/a"},"text":"Pub. L. 102–242, § 227(a)","children":[],"tail":", (b)(1)(B), redesignated pars. (3) and (4) as (2) and (3), respectively, and struck out former par. (2) which related to permanent schedule for funds deposited at nonproprietary automated teller machines."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (e)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625/s1001/1"},"text":"Pub. L. 101–625, § 1001(1)","children":[],"tail":", substituted “4” for “6”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625/s1001/2"},"text":"Pub. L. 101–625, § 1001(2)","children":[],"tail":", substituted “prior to the expiration of the 2-year period beginning on "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"November 28, 1990","children":[],"tail":"” for “before "},{"tag":"date","attrib":{"date":"1990-09-01"},"text":"September 1, 1990","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625/s1001/3"},"text":"Pub. L. 101–625, § 1001(3)","children":[],"tail":", substituted “the expiration of the 2-year period beginning on "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"November 28, 1990","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1990-09-01"},"text":"September 1, 1990","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd1298d1-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd1298d2-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/174"},"text":"Pub. L. 115–174","children":[],"tail":" effective 30 days after "},{"tag":"date","attrib":{"date":"2018-05-24"},"text":"May 24, 2018","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/174/s208/b"},"text":"section 208(b) of Pub. L. 115–174","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4001"},"text":"section 4001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd1298d3-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective on the designated transfer date, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1100H"},"text":"section 1100H of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd1508d4-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1988-09-01"},"text":"Sept. 1, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/86/s613/b"},"text":"section 613(b) of Pub. L. 100–86","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4001"},"text":"section 4001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
