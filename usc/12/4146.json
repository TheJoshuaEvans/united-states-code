{"tag":"section","attrib":{"id":"iddd1c35b3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4146"},"text":null,"children":[{"tag":"num","attrib":{"value":"4146"},"text":"§ 4146.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd1c35b4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4146/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “community-based nonprofit housing developer” means a nonprofit community development corporation that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd1c35b5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4146/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been classified by the Internal Revenue Service as an exempt organization under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/3"},"text":"section 501(c)(3) of title 26","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd1c35b6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4146/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been in existence for at least 2 years prior to the date of the grant application;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd1c35b7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4146/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a record of service to low- and moderate-income people in the community in which the project is located;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd1c35b8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4146/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is organized at the neighborhood, city, county or multi-county level; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd1c35b9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4146/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a corporation acquiring eligible housing under subchapter I of this chapter, agrees to form a purchaser entity that conforms to the definition of a community-based nonprofit organization under such subchapter and agrees to use its best efforts to secure majority tenant consent to the acquisition of the project for which grant assistance is requested; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1c35ba-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4146/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms “eligible low-income housing”, “nonprofit organization”, “owner”, and “resident council” have the meanings given such terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4119"},"text":"section 4119 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd1c35bb-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/242/tII/s256"},"text":"Pub. L. 100–242, title II, § 256","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tIII/s312"},"text":"Pub. L. 102–550, title III, § 312","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3769"},"text":"106 Stat. 3769","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
