{"tag":"section","attrib":{"id":"iddb22aef4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s215a–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"215a–1"},"text":"§ 215a–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interstate consolidations and mergers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddb22aef5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s215a–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A national bank may engage in a consolidation or merger under this subchapter with an out-of-State bank if the consolidation or merger is approved pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1831u"},"text":"section 1831u of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb22aef6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s215a–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope of application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall not apply with respect to any consolidation or merger before ","children":[{"tag":"date","attrib":{"date":"1997-06-01"},"text":"June 1, 1997","children":[],"tail":", unless the home State of each bank involved in the transaction has in effect a law described in "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1831u/a/3"},"text":"section 1831u(a)(3) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb22aef7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s215a–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “home State” and “out-of-State bank” have the same meaning as in section 1831u(f) ","children":[{"tag":"ref","attrib":{"idref":"fn002027"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002027"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddb22aef8-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1918-11-07/ch209/s4"},"text":"Nov. 7, 1918, ch. 209, § 4","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/328/tI/s102/b/4/D"},"text":"Pub. L. 103–328, title I, § 102(b)(4)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-29"},"text":"Sept. 29, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2351"},"text":"108 Stat. 2351","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb22aef9-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb22aefa-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddb22aefb-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1831u"},"text":"Section 1831u of this title","children":[],"tail":", referred to in subsec. (c), was subsequently amended, and subsec. (f) of section 1831u no longer defines the terms “home State” and “out-of-State bank”. However, such terms are defined elsewhere in that section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
