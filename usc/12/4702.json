{"tag":"section","attrib":{"id":"iddd36746a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4702"},"text":null,"children":[{"tag":"num","attrib":{"value":"4702"},"text":"§ 4702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter, the following definitions shall apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd36746b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4702/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Administrator” means the Administrator of the Fund appointed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4703/b"},"text":"section 4703(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd36746c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4702/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate Federal banking agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “appropriate Federal banking agency” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"section 1813 of this title","children":[],"tail":", and also includes the National Credit Union Administration Board with respect to insured credit unions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd36746d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4702/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Affiliate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “affiliate” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1841/k"},"text":"section 1841(k) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd36746e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4702/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Board” means the Community Development Advisory Board established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4703/d"},"text":"section 4703(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd36746f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4702/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community development financial institution","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd367470-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4702/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “community development financial institution” means a person (other than an individual) that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd367471-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4702/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a primary mission of promoting community development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd367472-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4702/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serves an investment area or targeted population;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd367473-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4702/5/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides development services in conjunction with equity investments or loans, directly or through a subsidiary or affiliate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd367474-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4702/5/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintains, through representation on its governing board or otherwise, accountability to residents of its investment area or targeted population; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd367475-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4702/5/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not an agency or instrumentality of the United States, or of any State or political subdivision of a State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd367476-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4702/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions for qualification of holding companies","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd367477-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4702/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consolidated treatment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A depository institution holding company may qualify as a community development financial institution only if the holding company and the subsidiaries and affiliates of the holding company collectively satisfy the requirements of subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd367478-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4702/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion of subsidiary or affiliate for failure to meet consolidated treatment rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No subsidiary or affiliate of a depository institution holding company may qualify as a community development financial institution if the holding company and the subsidiaries and affiliates of the holding company do not collectively meet the requirements of subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd367479-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4702/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions for subsidiaries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No subsidiary of an insured depository institution may qualify as a community development financial institution if the insured depository institution and its subsidiaries do not collectively meet the requirements of subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd36747a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4702/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community partner","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “community partner” means a person (other than an individual) that provides loans, equity investments, or development services, including a depository institution holding company, an insured depository institution, an insured credit union, a nonprofit organization, a State or local government agency, a quasi-governmental entity, and an investment company authorized to operate pursuant to the Small Business Investment Act of 1958 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s661"},"text":"15 U.S.C. 661","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd36747b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4702/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community partnership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “community partnership” means an agreement between a community development financial institution and a community partner to provide development services, loans, or equity investments, to an investment area or targeted population.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd36747c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4702/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Depository institution holding company","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “depository institution holding company” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"section 1813 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd36747d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4702/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “development services” means activities that promote community development and are integral to lending or investment activities, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd36747e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4702/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" business planning;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd36747f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4702/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" financial and credit counseling; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd367480-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4702/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" marketing and management assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd367481-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4702/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Fund” means the Community Development Financial Institutions Fund established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4703/a"},"text":"section 4703(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd367482-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4702/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian reservation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian reservation” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1903/10"},"text":"section 1903(10) of title 25","children":[],"tail":", and shall include land held by incorporated Native groups, regional corporations, and village corporations, as defined in or established pursuant to the Alaska Native Claims Settlement Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1601"},"text":"43 U.S.C. 1601","children":[],"tail":" et seq.], public domain Indian allotments, and former Indian reservations in the State of Oklahoma."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd367483-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4702/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian tribe","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian tribe” means any Indian tribe, band, pueblo, nation, or other organized group or community, including any Alaska Native village or regional or village corporation, as defined in or established pursuant to the Alaska Native Claims Settlement Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1601"},"text":"43 U.S.C. 1601","children":[],"tail":" et seq.], which is recognized as eligible for the special programs and services provided by the United States to Indians because of their status as Indians."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd367484-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4702/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Insured community development financial institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “insured community development financial institution” means any community development financial institution that is an insured depository institution or an insured credit union.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd367485-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4702/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Insured credit union","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “insured credit union” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1752/7"},"text":"section 1752(7) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd367486-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4702/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Insured depository institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “insured depository institution” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"section 1813 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd367487-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4702/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment area","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “investment area” means a geographic area (or areas) including an Indian reservation that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd367488-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4702/16/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd367489-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4702/16/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets objective criteria of economic distress developed by the Fund, which may include the percentage of low-income families or the extent of poverty, the rate of unemployment or underemployment, rural population outmigration, lag in population growth, and extent of blight and disinvestment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd36748a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4702/16/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has significant unmet needs for loans or equity investments; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd36748b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4702/16/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encompasses or is located in an empowerment zone or enterprise community designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s1391"},"text":"section 1391 of title 26","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd36748c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4702/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Low-income","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “low-income” means having an income, adjusted for family size, of not more than—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd36748d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4702/17/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for metropolitan areas, 80 percent of the area median income; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd36748e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4702/17/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for nonmetropolitan areas, the greater of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd36748f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4702/17/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 80 percent of the area median income; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd367490-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4702/17/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 80 percent of the statewide nonmetropolitan area median income.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd367491-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4702/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"section 1813 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd367492-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4702/19"},"text":null,"children":[{"tag":"num","attrib":{"value":"19"},"text":"(19)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsidiary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “subsidiary” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"section 1813 of this title","children":[],"tail":", except that a community development financial institution that is a corporation shall not be considered to be a subsidiary of any insured depository institution or depository institution holding company that controls less than 25 percent of any class of the voting shares of such corporation, and does not otherwise control in any manner the election of a majority of the directors of the corporation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd367493-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4702/20"},"text":null,"children":[{"tag":"num","attrib":{"value":"20"},"text":"(20)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Targeted population","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “targeted population” means individuals, or an identifiable group of individuals, including an Indian tribe, who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd367494-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4702/20/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are low-income persons; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd367495-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4702/20/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise lack adequate access to loans or equity investments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd367496-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4702/21"},"text":null,"children":[{"tag":"num","attrib":{"value":"21"},"text":"(21)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “training program” means the training program operated by the Fund under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4708"},"text":"section 4708 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail"