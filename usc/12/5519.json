{"tag":"section","attrib":{"id":"iddd71f6a4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5519"},"text":null,"children":[{"tag":"num","attrib":{"value":"5519"},"text":"§ 5519.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion for auto dealers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd71f6a5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5519/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale, servicing, and leasing of motor vehicles excluded","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as permitted in subsection (b), the Bureau may not exercise any rulemaking, supervisory, enforcement or any other authority, including any authority to order assessments, over a motor vehicle dealer that is predominantly engaged in the sale and servicing of motor vehicles, the leasing and servicing of motor vehicles, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd71f6a6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5519/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain functions excepted","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) shall not apply to any person, to the extent that such person—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd71f6a7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5519/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides consumers with any services related to residential or commercial mortgages or self-financing transactions involving real property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd71f6a8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5519/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" operates a line of business—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd71f6a9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5519/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that involves the extension of retail credit or retail leases involving motor vehicles; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd71f6aa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5519/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd71f6ab-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5519/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extension of retail credit or retail leases are provided directly to consumers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd71f6ac-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5519/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the contract governing such extension of retail credit or retail leases is not routinely assigned to an unaffiliated third party finance or leasing source; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd71f6ad-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5519/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offers or provides a consumer financial product or service not involving or related to the sale, financing, leasing, rental, repair, refurbishment, maintenance, or other servicing of motor vehicles, motor vehicle parts, or any related or ancillary product or service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd71f6ae-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5519/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preservation of authorities of other agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsections (b) and (d), nothing in this title,","children":[{"tag":"ref","attrib":{"idref":"fn002516"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002516"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" including subtitle F, shall be construed as modifying, limiting, or superseding the operation of any provision of Federal law, or otherwise affecting the authority of the Board of Governors, the Federal Trade Commission, or any other Federal agency, with respect to a person described in subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd71f6af-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5519/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Trade Commission authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s57a"},"text":"section 57a of title 15","children":[],"tail":", the Federal Trade Commission is authorized to prescribe rules under sections 45 and 57a(a)(1)(B) of title 15."},{"tag":"ref","attrib":{"idref":"fn002517"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002517"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. The period probably should be a comma."}],"tail":" in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":", with respect to a person described in subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd71f6b0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5519/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with Office of Service Member Affairs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board of Governors and the Federal Trade Commission shall coordinate with the Office of Service Member Affairs, to ensure that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd71f6b1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5519/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" service members and their families are educated and empowered to make better informed decisions regarding consumer financial products and services offered by motor vehicle dealers, with a focus on motor vehicle dealers in the proximity of military installations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd71f6b2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5519/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complaints by service members and their families concerning such motor vehicle dealers are effectively monitored and responded to, and where appropriate, enforcement action is pursued by the authorized agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd71f6b3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5519/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the following definitions shall apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd71f6b4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5519/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Motor vehicle","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “motor vehicle” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd71f6b5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5519/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any self-propelled vehicle designed for transporting persons or property on a street, highway, or other road;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd71f6b6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5519/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recreational boats and marine equipment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd71f6b7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5519/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" motorcycles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd71f6b8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5519/f/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" motor homes, recreational vehicle trailers, and slide-in campers, as those terms are defined in sections 571.3 and 575.103 (d) of title 49, Code of Federal Regulations, or any successor thereto; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd71f6b9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5519/f/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other vehicles that are titled and sold through dealers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd71f6ba-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5519/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Motor vehicle dealer","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “motor vehicle dealer” means any person or resident in the United States, or any territory of the United States, who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd71f6bb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5519/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is licensed by a State, a territory of the United States, or the District of Columbia to engage in the sale of motor vehicles; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd71f6bc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5519/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" takes title to, holds an ownership in, or takes physical custody of motor vehicles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd71f6bd-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1029"},"text":"Pub. L. 111–203, title X, § 1029","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2004"},"text":"124 Stat. 2004","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd71f6be-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd71f6bf-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd71f6c0-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This title, referred to in subsec. (c), is title X of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1955"},"text":"124 Stat. 1955","children":[],"tail":", known as the Consumer Financial Protection Act of 2010, which enacted this subchapter and enacted, amended, and repealed numerous other sections and notes in the Code. For complete classification of title X to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subtitle F, referred to in subsec. (c), is subtitle F (§§ 1061–1067) of title X of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2035"},"text":"124 Stat. 2035","children":[],"tail":", which is classified generally to part F (§ 5581 et seq.) of this subchapter. For complete classification of subtitle F to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd71f6c1-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd71f6c2-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the designated transfer date, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1029A"},"text":"section 1029A of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5511"},"text":"section 5511 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
