{"tag":"section","attrib":{"id":"iddb73b4f1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1429"},"text":null,"children":[{"tag":"num","attrib":{"value":"1429"},"text":"§ 1429.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility to secure advances","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any member of a Federal Home Loan Bank shall be entitled to apply in writing for advances. Such application shall be in such form as shall be required by the Federal Home Loan Bank. Such Federal Home Loan Bank may at its discretion deny any such application, or may grant it on such conditions as the Federal Home Loan Bank may prescribe.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddb73b4f2-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1932-07-22/ch522/s9"},"text":"July 22, 1932, ch. 522, § 9","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/47/731"},"text":"47 Stat. 731","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/73/tVII"},"text":"Pub. L. 101–73, title VII","children":[],"tail":", §§ 701(b)(1), (3)(A), 710(a), "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/412"},"text":"103 Stat. 412","children":[],"tail":", 418; "},{"tag":"ref","attrib":{"href":"/us/pl/106/102/tVI/s606/f/1"},"text":"Pub. L. 106–102, title VI, § 606(f)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1455"},"text":"113 Stat. 1455","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb73b4f3-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb73b4f4-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddb73b4f5-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/102"},"text":"Pub. L. 106–102","children":[],"tail":" struck out “with the approval of the Board” after “Federal Home Loan Bank” in second sentence and struck out “, subject to the approval of the Board,” after “deny any such application, or” in third sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/s710/a"},"text":"Pub. L. 101–73, § 710(a)","children":[],"tail":", struck out “or nonmember borrower” after “Any member”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/s701/b/1"},"text":"Pub. L. 101–73, § 701(b)(1)","children":[],"tail":", (3)(A), substituted “Board” for “board” wherever appearing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
