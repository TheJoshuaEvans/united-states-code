{"tag":"section","attrib":{"id":"iddd0b6c43-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3420"},"text":null,"children":[{"tag":"num","attrib":{"value":"3420"},"text":"§ 3420.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grand jury information; notification of certain persons prohibited","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd0b6c44-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3420/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Financial records about a customer obtained from a financial institution pursuant to a subpena issued under the authority of a Federal grand jury—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd0b6c45-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3420/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be returned and actually presented to the grand jury unless the volume of such records makes such return and actual presentation impractical in which case the grand jury shall be provided with a description of the contents of the records.; ","children":[{"tag":"ref","attrib":{"idref":"fn002354"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002354"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd0b6c46-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3420/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be used only for the purpose of considering whether to issue an indictment or presentment by that grand jury, or of prosecuting a crime for which that indictment or presentment is issued, or for a purpose authorized by rule 6(e) of the Federal Rules of Criminal Procedure, or for a purpose authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s3412/a"},"text":"section 3412(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd0b6c47-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3420/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be destroyed or returned to the financial institution if not used for one of the purposes specified in paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd0b6c48-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3420/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be maintained, or a description of the contents of such records shall not be maintained by any Government authority other than in the sealed records of the grand jury, unless such record has been used in the prosecution of a crime for which the grand jury issued an indictment or presentment or for a purpose authorized by rule 6(e) of the Federal Rules of Criminal Procedure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd0b6c49-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3420/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd0b6c4a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3420/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" No officer, director, partner, employee, or shareholder of, or agent or attorney for, a financial institution shall, directly or indirectly, notify any person named in a grand jury subpoena served on such institution in connection with an investigation relating to a possible—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd0b6c4b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3420/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" crime against any financial institution or supervisory agency or crime involving a violation of the Controlled Substance Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s801"},"text":"21 U.S.C. 801","children":[],"tail":" et seq.], the Controlled Substances Import and Export Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t21/s951"},"text":"21 U.S.C. 951","children":[],"tail":" et seq.], section 1956, 1957, or 1960 of title 18, sections 5313, 5316, 5322, 5324, 5331, and 5332 of title 31, or "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6050I"},"text":"section 6050I of title 26","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd0b6c4c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3420/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conspiracy to commit such a crime,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"about the existence or contents of such subpoena, or information that has been furnished to the grand jury in response to such subpoena.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd0b6c4d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3420/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1818"},"text":"Section 1818 of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1786/k/2"},"text":"section 1786(k)(2) of this title","children":[],"tail":" shall apply to any violation of this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd0b6c4e-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/630/tXI/s1120"},"text":"Pub. L. 95–630, title XI, § 1120","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3709"},"text":"92 Stat. 3709","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVI/s6186/e"},"text":"Pub. L. 100–690, title VI, § 6186(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4358"},"text":"102 Stat. 4358","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/73/tIX/s943"},"text":"Pub. L. 101–73, title IX, § 943","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/497"},"text":"103 Stat. 497","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXV/s1532"},"text":"Pub. L. 102–550, title XV, § 1532","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4066"},"text":"106 Stat. 4066","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/56/tIII/s358/f/3"},"text":"Pub. L. 107–56, title III, § 358(f)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-10-26"},"text":"Oct. 26, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/327"},"text":"115 Stat. 327","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dF/tLXIII/s6308/d"},"text":"Pub. L. 116–283, div. F, title LXIII, § 6308(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4594"},"text":"134 Stat. 4594","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd0b6c4f-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd0b6c50-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd0b6c51-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Rule 6(e) of the Federal Rules of Criminal Procedure, referred to in subsec. (a)(2), (4), is set out in the Appendix to Title 18, Crimes and Criminal Procedure.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Controlled Substance Act, referred to in subsec. (b)(1)(A), probably means the Controlled Substances Act, which is title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/513"},"text":"Pub. L. 91–513","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-27"},"text":"Oct. 27, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1242"},"text":"84 Stat. 1242","children":[],"tail":", and which is classified principally to subchapter I (§ 801 et seq.) of chapter 13 of Title 21, Food and Drugs. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s801"},"text":"section 801 of Title 21","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Controlled Substances Import and Export Act, referred to in subsec. (b)(1)(A), is title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/513"},"text":"Pub. L. 91–513","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-27"},"text":"Oct. 27, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1285"},"text":"84 Stat. 1285","children":[],"tail":", as amended, which is classified principally to subchapter II (§ 951 et seq.) of chapter 13 of Title 21. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s951"},"text":"section 951 of Title 21","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd0b6c52-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “, 1957, or 1960 of title 18” for “or 1957 of title 18” and “, 5322, 5324, 5331, and 5332 of title 31” for “and 5324 of title 31”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/56"},"text":"Pub. L. 107–56","children":[],"tail":" inserted “, or for a purpose authorized by "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s3412/a"},"text":"section 3412(a) of this title","children":[],"tail":"” before semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550"},"text":"Pub. L. 102–550","children":[],"tail":" inserted before semicolon “or crime involving a violation of the Controlled Substance Act, the Controlled Substances Import and Export Act, section 1956 or 1957 of title 18, sections 5313, 5316 and 5324 of title 31, or "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6050I"},"text":"section 6050I of title 26","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73"},"text":"Pub. L. 101–73","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" inserted “unless the volume of such records makes such return and actual presentation impractical in which case the grand jury shall be provided with a description of the contents of the records.” before semicolon at end."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd0b6c53-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd0b6c54-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2001 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/56"},"text":"Pub. L. 107–56","children":[],"tail":" applicable with respect to reports filed or records maintained on, before, or after "},{"tag":"date","attrib":{"date":"2001-10-26"},"text":"Oct. 26, 2001","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/56/s358/h"},"text":"section 358(h) of Pub. L. 107–56","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1829b"},"text":"section 1829b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"