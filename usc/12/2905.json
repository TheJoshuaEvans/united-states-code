{"tag":"section","attrib":{"id":"iddcf8593c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2905"},"text":null,"children":[{"tag":"num","attrib":{"value":"2905"},"text":"§ 2905.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Regulations to carry out the purposes of this chapter shall be published by each appropriate Federal financial supervisory agency, except that the Comptroller of the Currency shall prescribe regulations applicable to savings associations and the Board of Governors shall prescribe regulations applicable to insured State member banks, bank holding companies and savings and loan holding companies,,","children":[{"tag":"ref","attrib":{"idref":"fn002325"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002325"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" and shall take effect no later than 390 days after "},{"tag":"date","attrib":{"date":"1977-10-12"},"text":"October 12, 1977","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddcf8593d-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/128/tVIII/s806"},"text":"Pub. L. 95–128, title VIII, § 806","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-10-12"},"text":"Oct. 12, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1148"},"text":"91 Stat. 1148","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tIII/s358/2"},"text":"Pub. L. 111–203, title III, § 358(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1548"},"text":"124 Stat. 1548","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes