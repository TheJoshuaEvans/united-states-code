{"tag":"section","attrib":{"id":"iddc91cf9c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1830"},"text":null,"children":[{"tag":"num","attrib":{"value":"1830"},"text":"§ 1830.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nondiscrimination","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It is not the purpose of this chapter to discriminate in any manner against State nonmember banks or State savings associations and in favor of national or member banks or Federal savings associations, respectively. It is the purpose of this chapter to provide all banks and savings associations with the same opportunity to obtain and enjoy the benefits of this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc91cf9d-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-21/ch967/s2"},"text":"Sept. 21, 1950, ch. 967, § 2","children":[],"tail":"[22], formerly § 2[20], "},{"tag":"ref","attrib":{"href":"/us/stat/64/893"},"text":"64 Stat. 893","children":[],"tail":"; renumbered § 2[21], "},{"tag":"ref","attrib":{"href":"/us/pl/90/203/s3"},"text":"Pub. L. 90–203, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-12-15"},"text":"Dec. 15, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/610"},"text":"81 Stat. 610","children":[],"tail":"; renumbered § 2[22], "},{"tag":"ref","attrib":{"href":"/us/pl/91/508/tI/s101"},"text":"Pub. L. 91–508, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-26"},"text":"Oct. 26, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1114"},"text":"84 Stat. 1114","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/73/tII/s223"},"text":"Pub. L. 101–73, title II, § 223","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/273"},"text":"103 Stat. 273","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc91cf9e-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc91cf9f-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"iddc91cfa0-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section is derived from subsec. (y) of former ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s264"},"text":"section 264 of this title","children":[],"tail":". See Codification note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1811"},"text":"section 1811 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc91cfa1-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73"},"text":"Pub. L. 101–73","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “It is not the purpose of this chapter to discriminate in any manner against State nonmember banks and in favor of national or member banks; but the purpose is to provide all banks with the same opportunity to obtain and enjoy the benefits of this chapter. No bank shall be discriminated against because its capital stock is less than the amount required for eligibility for admission into the Federal Reserve System.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
