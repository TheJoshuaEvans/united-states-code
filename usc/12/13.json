{"tag":"section","attrib":{"id":"iddafed314-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"§ 13.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rooms for Currency Bureau","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There shall be assigned, from time to time, to the Comptroller of the Currency, by the Secretary of the Treasury, suitable rooms in the Treasury Building for conducting the business of the Currency Bureau, containing safe and secure fireproof vaults, in which the Comptroller shall deposit and safely keep all the plates not necessarily in the possession of engravers or printers, and other valuable things belonging to his department; and the Comptroller shall from time to time furnish the necessary furniture, stationery, fuel, lights, and other proper conveniences for the transaction of the business of his office.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddafed315-3a6f-11f1-8fa0-c065796a7f06"},"text":"(R.S. § 331.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddafed316-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddafed317-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddafed318-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The bureau referred to in text is known as the Office of the Comptroller of the Currency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddafed319-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 331 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1864-06-03/ch106/s3"},"text":"act June 3, 1864, ch. 106, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/13/100"},"text":"13 Stat. 100","children":[],"tail":", which was the National Bank Act. See "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s38"},"text":"section 38 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"iddafed31a-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddafed31b-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Exception as to Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions vested by any provision of law in Comptroller of the Currency, referred to in this section, not included in transfer of functions to Secretary of the Treasury, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
