{"tag":"section","attrib":{"id":"iddc302791-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1747a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1747a"},"text":"§ 1747a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility for insurance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc302792-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1747a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To be eligible for insurance under this subchapter, a project shall meet the following conditions:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc302793-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1747a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall be satisfied that there is, in the locality or metropolitan area of such project, a need for new rental dwellings at rents comparable to the rents proposed to be charged for the dwellings in such project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc302794-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1747a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such project shall be economically sound, and the dwellings in such project shall be acceptable to the Secretary as to quality, design, size, and type.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc302795-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1747a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any insurance contract executed by the Secretary under this subchapter shall be conclusive evidence of the eligibility of the project and the investor for such insurance, and the validity of any insurance contract so executed shall be incontestable in the hands of an investor from the date of the execution of such contract, except for fraud or misrepresentation on the part of such investor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc302796-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1747a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" After completion of the project the investor must establish in a manner satisfactory to the Secretary that the project is free and clear of liens and that there are no other outstanding unpaid obligations contracted in connection with the construction of the project, except taxes and such other liens and obligations as may be approved or prescribed by the Secretary. Debentures issued by the investor which are payable out of net income from the project and from the benefits of the insurance contract shall not be construed as “unpaid obligations” as such term is used in this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc302797-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-27/ch847"},"text":"June 27, 1934, ch. 847","children":[],"tail":", title VII, § 702, as added "},{"tag":"ref","attrib":{"href":"/us/act/1948-08-10/ch832"},"text":"Aug. 10, 1948, ch. 832","children":[],"tail":", title IV, § 401, "},{"tag":"ref","attrib":{"href":"/us/stat/62/1276"},"text":"62 Stat. 1276","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/act/1950-04-20/ch94"},"text":"Apr. 20, 1950, ch. 94","children":[],"tail":", title I, § 122, "},{"tag":"ref","attrib":{"href":"/us/stat/64/59"},"text":"64 Stat. 59","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1951-09-01/ch378"},"text":"Sept. 1, 1951, ch. 378","children":[],"tail":", title VI, § 609(a), "},{"tag":"ref","attrib":{"href":"/us/stat/65/316"},"text":"65 Stat. 316","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/19/s1/a/3"},"text":"Pub. L. 90–19, § 1(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-05-25"},"text":"May 25, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/17"},"text":"81 Stat. 17","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc302798-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc302799-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc30279a-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1967—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/19"},"text":"Pub. L. 90–19","children":[],"tail":" substituted “Secretary” for “Commissioner” wherever appearing in subsecs. (a)(1), (2), (b), and (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1951—Subsec. (c). Act ","children":[{"tag":"date","attrib":{"date":"1951-09-01"},"text":"Sept. 1, 1951","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1950—Act ","children":[{"tag":"date","attrib":{"date":"1950-04-20"},"text":"Apr. 20, 1950","children":[],"tail":", substituted “Commissioner” for “Administrator” wherever appearing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
