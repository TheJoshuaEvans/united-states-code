{"tag":"section","attrib":{"id":"iddb48d44e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s505"},"text":null,"children":[{"tag":"num","attrib":{"value":"505"},"text":"§ 505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil money penalty","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb48d44f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s505/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" First tier","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any member bank which, and any institution-affiliated party (within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813/u"},"text":"section 1813(u) of this title","children":[],"tail":") with respect to such member bank who, violates any provision of this section, or any regulation issued pursuant thereto, shall forfeit and pay a civil penalty of not more than $5,000 for each day during which such violation continues."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb48d450-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s505/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Second tier","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding paragraph (1), any member bank which, and any institution-affiliated party (within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813/u"},"text":"section 1813(u) of this title","children":[],"tail":") with respect to such member bank who—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddb48d451-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s505/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddb48d452-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s505/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commits any violation described in paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddb48d453-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s505/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recklessly engages in an unsafe or unsound practice in conducting the affairs of such member bank; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddb48d454-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s505/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" breaches any fiduciary duty;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb48d455-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s505/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" which violation, practice, or breach—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddb48d456-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s505/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is part of a pattern of misconduct;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddb48d457-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s505/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" causes or is likely to cause more than a minimal loss to such member bank; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddb48d458-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s505/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" results in pecuniary gain or other benefit to such party,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall forfeit and pay a civil penalty of not more than $25,000 for each day during which such violation, practice, or breach continues.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb48d459-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s505/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Third tier","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding paragraphs (1) and (2), any member bank which, and any institution-affiliated party (within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813/u"},"text":"section 1813(u) of this title","children":[],"tail":") with respect to such member bank who—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddb48d45a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s505/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" knowingly—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddb48d45b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s505/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commits any violation described in paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddb48d45c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s505/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engages in any unsafe or unsound practice in conducting the affairs of such member bank; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddb48d45d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s505/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" breaches any fiduciary duty; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb48d45e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s505/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly or recklessly causes a substantial loss to such member bank or a substantial pecuniary gain or other benefit to such party by reason of such violation, practice, or breach,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall forfeit and pay a civil penalty in an amount not to exceed the applicable maximum amount determined under paragraph (4) for each day during which such violation, practice, or breach continues.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb48d45f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s505/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum amounts of penalties for any violation described in paragraph (3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The maximum daily amount of any civil penalty which may be assessed pursuant to paragraph (3) for any violation, practice, or breach described in such paragraph is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddb48d460-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s505/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any person other than a member bank, an amount not to exceed $1,000,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb48d461-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s505/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a member bank, an amount not to exceed the lesser of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddb48d462-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s505/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,000,000; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddb48d463-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s505/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 percent of the total assets of such member bank.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb48d464-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s505/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment; etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any penalty imposed under paragraph (1), (2), or (3) may be assessed and collected by the Board in the manner provided in subparagraphs (E), (F), (G), and (I) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1818/i/2"},"text":"section 1818(i)(2) of this title","children":[],"tail":" for penalties imposed (under such section) and any such assessment shall be subject to the provisions of such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb48d465-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s505/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hearing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The member bank or other person against whom any penalty is assessed under this section shall be afforded an agency hearing if such member bank or person submits a request for such hearing within 20 days after the issuance of the notice of assessment. ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1818/h"},"text":"Section 1818(h) of this title","children":[],"tail":" shall apply to any proceeding under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb48d466-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s505/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disbursement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All penalties collected under authority of this section shall be deposited into the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb48d467-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s505/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Violate” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “violate” includes any action (alone or with another or others) for or toward causing, bringing about, participating in, counseling, or aiding or abetting a violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb48d468-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s505/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall prescribe regulations establishing such procedures as may be necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddb48d469-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1913-12-23/ch6/s19"},"text":"Dec. 23, 1913, ch. 6, § 19","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), formerly § 19(j), as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/630/tI/s102"},"text":"Pub. L. 95–630, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3642"},"text":"92 Stat. 3642","children":[],"tail":"; renumbered § 19("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), "},{"tag":"ref","attrib":{"href":"/us/pl/96/221/tI/s105/f"},"text":"Pub. L. 96–221, title I, § 105(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-03-31"},"text":"Mar. 31, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/140"},"text":"94 Stat. 140","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/320/tIV/s424/a"},"text":"Pub. L. 97–320, title IV, § 424(a)","children":[],"tail":", (d)(2), (e), "},{"tag":"date","attrib":{"date":"1982-10-15"},"text":"Oct. 15, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1522"},"text":"96 Stat. 1522","children":[],"tail":", 1523; "},{"tag":"ref","attrib":{"href":"/us/pl/101/73/tIX/s907/h"},"text":"Pub. L. 101–73, title IX, § 907(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/472"},"text":"103 Stat. 472","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb48d46a-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb48d46b-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddb48d46c-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This section, referred to in pars. (1) and (8), means section 19 of act ","children":[{"tag":"date","attrib":{"date":"1913-12-23"},"text":"Dec. 23, 1913","children":[],"tail":", which is classified to sections 142, 371b, 371b–1, 374, 374a, 461, 463 to 466, 505, and 506 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddb48d46d-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73"},"text":"Pub. L. 101–73","children":[],"tail":" amended section generally, revising and restating as pars. (1) to (9) provisions of former pars. (1) to (7) which related to civil penalty respecting depository, reserve, etc., requirements; amount; hearing; review; action by Attorney General; and regulations."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/320/s424/a"},"text":"Pub. L. 97–320, § 424(a)","children":[],"tail":", (d)(2), inserted proviso giving Board discretionary authority to compromise, etc., any civil money penalty imposed under this section, and substituted “may be assessed” for “shall be assessed”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/320/s424/e"},"text":"Pub. L. 97–320, § 424(e)","children":[],"tail":", substituted “twenty days from the service” for “ten days from the date”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddb48d46e-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddb48d46f-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73"},"text":"Pub. L. 101–73","children":[],"tail":" applicable to conduct engaged in after "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", except that increased maximum penalties of $5,000 and $25,000 may apply to conduct engaged in before such date if such conduct is not already subject to a notice issued by the appropriate agency and occurred after completion of the last report of the examination of the institution by the appropriate agency occurring before "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", see section 907("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":") of "},{"tag":"ref","attrib":{"href":"/us/pl/101/73"},"text":"Pub. L. 101–73","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s93"},"text":"section 93 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddb48d470-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective with respect to violations occurring or continuing after ","children":[{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/630/s109"},"text":"section 109 of Pub. L. 95–630","children":[],"tail":" set out as an Effective Date of 1978 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s93"},"text":"section 93 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
