{"tag":"section","attrib":{"id":"iddd556dc8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5333"},"text":null,"children":[{"tag":"num","attrib":{"value":"5333"},"text":"§ 5333.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study of the effects of size and complexity of financial institutions on capital market efficiency and economic growth","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd556dc9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5333/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study required","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd556dca-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5333/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Chairperson of the Council shall carry out a study of the economic impact of possible financial services regulatory limitations intended to reduce systemic risk. Such study shall estimate the benefits and costs on the efficiency of capital markets, on the financial sector, and on national economic growth, of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd556dcb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5333/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" explicit or implicit limits on the maximum size of banks, bank holding companies, and other large financial institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd556dcc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5333/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limits on the organizational complexity and diversification of large financial institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd556dcd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5333/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requirements for operational separation between business units of large financial institutions in order to expedite resolution in case of failure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd556dce-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5333/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limits on risk transfer between business units of large financial institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd556dcf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5333/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requirements to carry contingent capital or similar mechanisms;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd556dd0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5333/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limits on commingling of commercial and financial activities by large financial institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd556dd1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5333/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" segregation requirements between traditional financial activities and trading or other high-risk operations in large financial institutions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd556dd2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5333/a/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other limitations on the activities or structure of large financial institutions that may be useful to limit systemic risk.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd556dd3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5333/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The study required by this section shall include recommendations for the optimal structure of any limits considered in subparagraphs (A) through (E), in order to maximize their effectiveness and minimize their economic impact.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd556dd4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5333/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than the end of the 180-day period beginning on ","children":[{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", and not later than every 5 years thereafter, the Chairperson shall issue a report to the Congress containing any findings and determinations made in carrying out the study required under subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd556dd5-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tI/s123"},"text":"Pub. L. 111–203, title I, § 123","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1412"},"text":"124 Stat. 1412","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
