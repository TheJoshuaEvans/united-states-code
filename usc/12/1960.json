{"tag":"section","attrib":{"id":"iddcb7f51b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1960"},"text":null,"children":[{"tag":"num","attrib":{"value":"1960"},"text":"§ 1960.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Safe harbor with respect to keep open directives","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcb7f51c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1960/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “financial institution” means an entity to which ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1953/b"},"text":"section 1953(b) of this title","children":[],"tail":" applies."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcb7f51d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1960/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Safe harbor","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to a customer account or customer transaction of a financial institution, if a Federal law enforcement agency, after notifying FinCEN of the intent to submit a written request to the financial institution that the financial institution keep that account or transaction open (referred to in this section as a “keep open request”), or if a State, Tribal, or local law enforcement agency with the concurrence of FinCEN submits a keep open request—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcb7f51e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1960/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the financial institution shall not be liable under this chapter for maintaining that account or transaction consistent with the parameters and timing of the request; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb7f51f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1960/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no Federal or State department or agency may take any adverse supervisory action under this chapter with respect to the financial institution solely for maintaining that account or transaction consistent with the parameters of the request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcb7f520-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1960/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section may be construed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcb7f521-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1960/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prevent a Federal or State department or agency from verifying the validity of a keep open request submitted under subsection (b) with the law enforcement agency submitting that request;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb7f522-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1960/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to relieve a financial institution from complying with any reporting requirements, including the reporting of suspicious transactions under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s5318/g"},"text":"section 5318(g) of title 31","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb7f523-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1960/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to extend the safe harbor described in subsection (b) to any actions taken by the financial institution—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcb7f524-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1960/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before the date of the keep open request to maintain a customer account; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcb7f525-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1960/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after the termination date stated in the keep open request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcb7f526-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1960/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Letter termination date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of this section, any keep open request submitted under subsection (b) shall include a termination date after which that request shall no longer apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcb7f527-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1960/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Record keeping","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any Federal, State, Tribal, or local law enforcement agency that submits to a financial institution a keep open request shall, not later than 2 business days after the date on which the request is submitted to the financial institution—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcb7f528-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1960/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to FinCEN a copy of the request; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb7f529-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1960/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alert FinCEN as to whether the financial institution has implemented the request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcb7f52a-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/508/tI/s130"},"text":"Pub. L. 91–508, title I, § 130","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dF/tLXIII/s6306/a/2"},"text":"Pub. L. 116–283, div. F, title LXIII, § 6306(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4588"},"text":"134 Stat. 4588","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
