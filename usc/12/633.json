{"tag":"section","attrib":{"id":"iddb4d8fa8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s633"},"text":null,"children":[{"tag":"num","attrib":{"value":"633"},"text":"§ 633.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Potential liability on foreign accounts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddb4d8fa9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s633/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions from repayment requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A member bank shall not be required to repay any deposit made at a foreign branch of the bank if the branch cannot repay the deposit due to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb4d8faa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s633/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an act of war, insurrection, or civil strife; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb4d8fab-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s633/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an action by a foreign government or instrumentality (whether de jure or de facto) in the country in which the branch is located;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"unless the member bank has expressly agreed in writing to repay the deposit under those circumstances.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb4d8fac-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s633/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board and the Comptroller of the Currency may jointly prescribe such regulations as they deem necessary to implement this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddb4d8fad-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1913-12-23/ch6/s25C"},"text":"Dec. 23, 1913, ch. 6, § 25C","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/325/tIII/s326/a"},"text":"Pub. L. 103–325, title III, § 326(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2229"},"text":"108 Stat. 2229","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb4d8fae-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb4d8faf-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddb4d8fb0-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as section 25C of the Federal Reserve Act, and not as part of section 25A of that Act which comprises this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddb4d8fb1-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddb4d8fb2-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Existing Claims Not Affected","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/tIII/s326/c"},"text":"Pub. L. 103–325, title III, § 326(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2229"},"text":"108 Stat. 2229","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/325/tIII/s326/c"},"text":"“Section 25C of the Federal Reserve Act [this section] (as added by subsection (a)) shall not be applied retroactively and shall not be construed to affect or apply to any claim or cause of action addressed by that section arising from events or circumstances that occurred before the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
