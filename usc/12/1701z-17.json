{"tag":"section","attrib":{"id":"iddbbb45e3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701z–17"},"text":null,"children":[{"tag":"num","attrib":{"value":"1701z–17"},"text":"§ 1701z–17.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increasing access and understanding of energy efficient mortgages","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddbbb45e4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701z–17/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As used in this section, the term “energy efficient mortgage” has the same meaning as given that term in paragraph (24) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12704"},"text":"section 12704 of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddbbb45e5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701z–17/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendations to eliminate barriers to use of energy efficient mortgages","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddbbb45e6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701z–17/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", the Secretary of Housing and Urban Development, in conjunction with the Secretary of Energy and the Administrator of the Environmental Protection Agency, shall consult with the residential mortgage industry and States to develop recommendations to eliminate the barriers that exist to increasing the availability, use, and purchase of energy efficient mortgages, including such barriers as—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddbbb45e7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701z–17/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the lack of reliable and accessible information on such mortgages, including estimated energy savings and other benefits of energy efficient housing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddbbb45e8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701z–17/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the confusion regarding underwriting requirements and differences among various energy efficient mortgage programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddbbb45e9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701z–17/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the complex and time consuming process of securing such mortgages;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddbbb45ea-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701z–17/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the lack of publicly available research on the default risk of such mortgages; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddbbb45eb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701z–17/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the availability of certified or accredited home energy rating services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddbbb45ec-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701z–17/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Housing and Urban Development shall submit a report to Congress that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddbbb45ed-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701z–17/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" summarizes the recommendations developed under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddbbb45ee-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701z–17/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes any recommendations for statutory, regulatory, or administrative changes that the Secretary deems necessary to institute such recommendations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddbbb45ef-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701z–17/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy efficient mortgages outreach campaign","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddbbb45f0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701z–17/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Housing and Urban Development, in consultation and coordination with the Secretary of Energy, the Administrator of the Environmental Protection Agency, and State Energy and Housing Finance Directors, shall carry out an education and outreach campaign to inform and educate consumers, home builders, residential lenders, and other real estate professionals on the availability, benefits, and advantages of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddbbb45f1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701z–17/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improved energy efficiency in housing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddbbb45f2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701z–17/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" energy efficient mortgages.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddbbb45f3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701z–17/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as are necessary to carry out the education and outreach campaign described under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddbbb45f4-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/dB/tIX/s2902"},"text":"Pub. L. 110–289, div. B, title IX, § 2902","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2876"},"text":"122 Stat. 2876","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddbbb45f5-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddbbb45f6-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddbbb45f7-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Foreclosure Prevention Act of 2008, and also as part of the Housing and Economic Recovery Act of 2008, and not as part of the National Housing Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
