{"tag":"section","attrib":{"id":"iddd52fd53-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5326"},"text":null,"children":[{"tag":"num","attrib":{"value":"5326"},"text":"§ 5326.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd52fd54-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5326/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (b), the Council, acting through the Office of Financial Research, may require a bank holding company with total consolidated assets of $250,000,000,000 or greater or a nonbank financial company supervised by the Board of Governors, and any subsidiary thereof, to submit certified reports to keep the Council informed as to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd52fd55-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5326/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the financial condition of the company;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd52fd56-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5326/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" systems for monitoring and controlling financial, operating, and other risks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd52fd57-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5326/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transactions with any subsidiary that is a depository institution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd52fd58-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5326/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the activities and operations of the company and any subsidiary thereof, could, under adverse circumstances, have the potential to disrupt financial markets or affect the overall financial stability of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd52fd59-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5326/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of existing reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd52fd5a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5326/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of compliance with subsection (a), the Council, acting through the Office of Financial Research, shall, to the fullest extent possible, use—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd52fd5b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5326/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reports that a bank holding company, nonbank financial company supervised by the Board of Governors, or any functionally regulated subsidiary of such company has been required to provide to other Federal or State regulatory agencies or to a relevant foreign supervisory authority;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd52fd5c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5326/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information that is otherwise required to be reported publicly; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd52fd5d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5326/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" externally audited financial statements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd52fd5e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5326/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each bank holding company described in subsection (a) and nonbank financial company supervised by the Board of Governors, and any subsidiary thereof, shall provide to the Council, at the request of the Council, copies of all reports referred to in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd52fd5f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5326/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall maintain the confidentiality of the reports obtained under subsection (a) and paragraph (1)(A) of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd52fd60-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tI/s116"},"text":"Pub. L. 111–203, title I, § 116","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1406"},"text":"124 Stat. 1406","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/174/tIV/s401/c/1/B"},"text":"Pub. L. 115–174, title IV, § 401(c)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-05-24"},"text":"May 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1358"},"text":"132 Stat. 1358","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd52fd61-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd52fd62-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd52fd63-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/174"},"text":"Pub. L. 115–174","children":[],"tail":" substituted “$250,000,000,000” for “$50,000,000,000” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd52fd64-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd52fd65-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Except as otherwise provided, amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/174"},"text":"Pub. L. 115–174","children":[],"tail":" effective 18 months after "},{"tag":"date","attrib":{"date":"2018-05-24"},"text":"May 24, 2018","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/174/s401/d"},"text":"section 401(d) of Pub. L. 115–174","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5365"},"text":"section 5365 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd52fd66-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For construction of amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/174"},"text":"Pub. L. 115–174","children":[],"tail":" as applied to certain foreign banking organizations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/174/s401/g"},"text":"section 401(g) of Pub. L. 115–174","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5365"},"text":"section 5365 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
