{"tag":"section","attrib":{"id":"iddd23619a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4513a"},"text":null,"children":[{"tag":"num","attrib":{"value":"4513a"},"text":"§ 4513a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Housing Finance Oversight Board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd23619b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4513a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established the Federal Housing Finance Oversight Board, which shall advise the Director with respect to overall strategies and policies in carrying out the duties of the Director under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd23619c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4513a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board may not exercise any executive authority, and the Director may not delegate to the Board any of the functions, powers, or duties of the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd23619d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4513a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall be comprised of 4 members, of whom—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd23619e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4513a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member shall be the Secretary of the Treasury;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd23619f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4513a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member shall be the Secretary of Housing and Urban Development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2361a0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4513a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member shall be the Chairman of the Securities and Exchange Commission; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2361a1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4513a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member shall be the Director, who shall serve as the Chairperson of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2361a2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4513a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2361a3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4513a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall meet upon notice by the Director, but in no event shall the Board meet less frequently than once every 3 months.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2361a4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4513a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Either the Secretary of the Treasury, the Secretary of Housing and Urban Development, or the Chairman of the Securities and Exchange Commission may, upon giving written notice to the Director, require a special meeting of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2361a5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4513a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Testimony","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On an annual basis, the Board shall testify before Congress regarding—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2361a6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4513a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the safety and soundness of the regulated entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2361a7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4513a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any material deficiencies in the conduct of the operations of the regulated entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2361a8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4513a/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the overall operational status of the regulated entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2361a9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4513a/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of the performance of the regulated entities in carrying out their respective missions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2361aa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4513a/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operations, resources, and performance of the Agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2361ab-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4513a/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other matters relating to the Agency and its fulfillment of its mission, as the Board determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd2361ac-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXIII/s1313A"},"text":"Pub. L. 102–550, title XIII, § 1313A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tI/s1103/a"},"text":"Pub. L. 110–289, div. A, title I, § 1103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2665"},"text":"122 Stat. 2665","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd2361ad-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd2361ae-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd2361af-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a), was in the original “this title”, meaning title XIII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550"},"text":"Pub. L. 102–550","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3941"},"text":"106 Stat. 3941","children":[],"tail":", which is classified principally to this chapter. For complete classification of title XIII to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4501"},"text":"section 4501 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
