{"tag":"section","attrib":{"id":"iddcd23390-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2276"},"text":null,"children":[{"tag":"num","attrib":{"value":"2276"},"text":"§ 2276.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to and examination by Comptroller General of books, documents, etc., of farm credit system banks and institutions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"On and after ","children":[{"tag":"date","attrib":{"date":"1985-12-19"},"text":"December 19, 1985","children":[],"tail":", the Comptroller General or his duly authorized representatives shall have access to and the right to examine all books, documents, papers, records, or other recorded information within the possession or control of the Federal land banks and Federal land bank associations, Federal intermediate credit banks and production credit associations and banks for cooperatives."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddcd23391-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/190/s107"},"text":"Pub. L. 99–190, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-19"},"text":"Dec. 19, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1316"},"text":"99 Stat. 1316","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcd23392-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcd23393-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddcd23394-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Farm Credit Act of 1971 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
