{"tag":"section","attrib":{"id":"iddd1e7f52-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4226"},"text":null,"children":[{"tag":"num","attrib":{"value":"4226"},"text":"§ 4226.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights of declarants; notifications; Government accountability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd1e7f53-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4226/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person who has filed a declaration that meets the requirements of sections 4221 through 4224 of this title shall have the rights stated in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1e7f54-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4226/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of decision not to pursue","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If, after review, the Attorney General concludes that the information contained in a declaration should not be pursued in a proceeding to recover the asset or assets, the Attorney General shall so notify the declarant in writing and shall provide a brief statement of the reasons that the declaration will not be pursued.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1e7f55-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4226/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judgment, order, or settlement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd1e7f56-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4226/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When the United States obtains a final judgment, order, or settlement transferring to the United States title to an asset or assets identified in a valid declaration filed under section 4221 ","children":[{"tag":"ref","attrib":{"idref":"fn002390"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002390"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title, the Attorney General shall notify the declarant in writing of the entry of the judgment, order, or settlement."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1e7f57-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4226/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A notice described in paragraph (1) shall contain—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd1e7f58-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4226/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Attorney General’s determination of the amount of the award due the declarant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4225/c"},"text":"section 4225(c) of this title","children":[],"tail":" upon recovery by the United States; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd1e7f59-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4226/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a short statement of reasons for the amount of the award.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1e7f5a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4226/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of pendency of investigation or proceeding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd1e7f5b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4226/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to paragraph (2), if the Attorney General has not provided the declarant with notice under subsection (b) or a notice of invalidity pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4224"},"text":"section 4224 of this title","children":[],"tail":" within 1 year after the date of filing of the declaration, the Attorney General shall notify the declarant in writing that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd1e7f5c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4226/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a pending investigation or proceeding in the course of which the declarant’s allegations are being addressed; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd1e7f5d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4226/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the declarant’s allegations have not yet been addressed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1e7f5e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4226/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Attorney General certifies that it is in the interest of the United States to give further consideration to the information provided in the declaration for an additional 90-day period, the Attorney General shall so notify the declarant in writing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1e7f5f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4226/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality of notices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All notices provided to a declarant under this section shall be kept confidential by the declarant in the same manner, and subject to the same penalties, as the declaration under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4223"},"text":"section 4223 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd1e7f60-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXV/s2581"},"text":"Pub. L. 101–647, title XXV, § 2581","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4902"},"text":"104 Stat. 4902","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd1e7f61-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd1e7f62-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd1e7f63-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4221"},"text":"Section 4221 of this title","children":[],"tail":", referred to in subsec. (c)(1), was in the original “section 831”, and was translated as reading “section 2576”, meaning "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/s2576"},"text":"section 2576 of Pub. L. 101–647","children":[],"tail":", as the probable intent of Congress, because "},{"tag":"ref","attrib":{"href":"/us/pl/101/647"},"text":"Pub. L. 101–647","children":[],"tail":" does not contain a section 831."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
