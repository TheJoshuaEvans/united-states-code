{"tag":"section","attrib":{"id":"iddc051fb5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1715z–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"1715z–5"},"text":"§ 1715z–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purchase of fee simple title from lessors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc051fb6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1715z–5/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization to insure loans for purpose of financing purchases","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized, upon such terms and conditions as he may prescribe, to make commitments to insure and to insure loans made by financial institutions for the purpose of financing purchases by homeowners of the fee simple title to property on which their homes are located.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc051fb7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1715z–5/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc051fb8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1715z–5/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “financial institution” means a lender approved by the Secretary as eligible for insurance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1703"},"text":"section 1703 of this title","children":[],"tail":" or a mortgagee approved under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1709/b/1"},"text":"section 1709(b)(1) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc051fb9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1715z–5/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “homeowner” means a lessee under a long-term ground lease.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc051fba-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1715z–5/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility for insurance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible for insurance under this section, a loan shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc051fbb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1715z–5/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relate to property on which there is located a dwelling designed principally for a one-, two-, three-, or four-family residence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc051fbc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1715z–5/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not exceed the cost of purchasing the fee simple title, or $10,000 ($30,000, if the property is located in Hawaii) per family unit, whichever is the lesser;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc051fbd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1715z–5/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be limited to an amount which when added to any outstanding indebtedness related to the property (as determined by the Secretary) creates a total outstanding indebtedness which does not exceed the applicable mortgage limit prescribed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1709/b"},"text":"section 1709(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc051fbe-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1715z–5/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bear interest at such rate as may be agreed upon by the mortgagor and the mortgagee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc051fbf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1715z–5/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have a maturity satisfactory to the Secretary, but not to exceed twenty years from the beginning of amortization of the loan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc051fc0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1715z–5/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comply with such other terms, conditions, and restrictions as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc051fc1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1715z–5/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of other provisions of law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of paragraphs (3), (5), (6), (7), (8), and (10) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1715k/h"},"text":"section 1715k(h) of this title","children":[],"tail":" shall be applicable to loans insured under this section and, as applied to loans insured under this section, references in those paragraphs to “home improvement loans” and “this subsection” shall be construed to refer to loans under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc051fc2-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-27/ch847"},"text":"June 27, 1934, ch. 847","children":[],"tail":", title II, § 240, as added "},{"tag":"ref","attrib":{"href":"/us/pl/90/448/tIII/s304/a"},"text":"Pub. L. 90–448, title III, § 304(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-08-01"},"text":"Aug. 1, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/507"},"text":"82 Stat. 507","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/557/tIII/s314"},"text":"Pub. L. 95–557, title III, § 314","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-31"},"text":"Oct. 31, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2099"},"text":"92 Stat. 2099","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/399/tIII/s333/f"},"text":"Pub. L. 96–399, title III, § 333(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-08"},"text":"Oct. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1653"},"text":"94 Stat. 1653","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/181/tI"},"text":"Pub. L. 98–181, title I","children":[],"tail":" [title IV, § 404(b)(13)], "},{"tag":"date","attrib":{"date":"1983-11-30"},"text":"Nov. 30, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1210"},"text":"97 Stat. 1210","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/479/tII/s204/a/10"},"text":"Pub. L. 98–479, title II, § 204(a)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-17"},"text":"Oct. 17, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2232"},"text":"98 Stat. 2232","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc051fc3-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc051fc4-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc051fc5-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/479"},"text":"Pub. L. 98–479","children":[],"tail":" substituted “purchases” for “purchasers”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/181"},"text":"Pub. L. 98–181","children":[],"tail":" substituted provision that the interest rate be such rate as agreed upon by the mortgagor and the mortgagee for provision that the interest rate not exceed such per centum per annum, not in excess of 6 per centum, on the amount of the principal obligation outstanding at any time, as the Secretary finds necessary to meet market conditions, and such other charges as approved by the Secretary."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/399"},"text":"Pub. L. 96–399","children":[],"tail":" struck out “or three-quarters of the remaining economic life of the home, whichever is the lesser” after “loan”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/557"},"text":"Pub. L. 95–557","children":[],"tail":" inserted “($30,000, if the property is located in Hawaii)” after “$10,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
