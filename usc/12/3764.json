{"tag":"section","attrib":{"id":"iddd104e41-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3764"},"text":null,"children":[{"tag":"num","attrib":{"value":"3764"},"text":"§ 3764.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Record of foreclosure and sale","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd104e42-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3764/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statements included","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To establish a sufficient record of foreclosure and sale, the foreclosure commissioner shall include in the recitals of the deed to the purchaser, or prepare as an affidavit or addendum to the deed, a statement setting forth—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd104e43-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3764/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date, time, and place of the foreclosure sale;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd104e44-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3764/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the mortgage was held by the Secretary, the date of the mortgage, the office in which the mortgage was recorded, and the liber number and folio or other appropriate description of the recordation of the mortgage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd104e45-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3764/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the particulars of the foreclosure commissioner’s service of the notice of default and foreclosure sale in accordance with sections 3758 and 3760 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd104e46-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3764/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date and place of filing the notice of default and foreclosure sale;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd104e47-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3764/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the foreclosure was conducted in accordance with the provisions of this chapter and with the terms of the notice of default and foreclosure sale; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd104e48-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3764/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sale amount.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd104e49-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3764/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of statements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The items set forth in subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd104e4a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3764/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be prima facie evidence of the truth of such facts in any Federal or State court; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd104e4b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3764/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evidence a conclusive presumption in favor of bona fide purchasers and encumbrancers for value without notice.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Encumbrancers for value include liens placed by lenders who provide the purchaser with purchase money in exchange for a security interest in the newly-conveyed property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd104e4c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3764/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recordation of instruments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The deed executed by the foreclosure commissioner, the foreclosure commissioner’s affidavit (if prepared) and any other instruments submitted for recordation in relation to the foreclosure of the security property under this chapter shall be accepted for recordation by the registrar of deeds or other appropriate official of the county or counties in which the security property is located upon tendering of payment of the usual recording fees for such instruments, and without regard to the compliance of those instruments with any other local filing requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd104e4d-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/327/tII"},"text":"Pub. L. 103–327, title II","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-28"},"text":"Sept. 28, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2316"},"text":"108 Stat. 2316","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd104e4e-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd104e4f-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd104e50-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is based on section 815 of title VIII of S. 2281, One Hundred Third Congress, as reported ","children":[{"tag":"date","attrib":{"date":"1994-07-13"},"text":"July 13, 1994","children":[],"tail":", which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/103/327"},"text":"Pub. L. 103–327","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
