{"tag":"section","attrib":{"id":"iddb631353-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635i–9"},"text":null,"children":[{"tag":"num","attrib":{"value":"635i–9"},"text":"§ 635i–9.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Market windows","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddb631354-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635i–9/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enhanced transparency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To ensure that the Bank financing remains fully competitive, the United States should seek enhanced transparency over the activities of market windows in the OECD Export Credit Arrangement. If such transparency indicates that market windows are disadvantaging United States exporters, the United States should seek negotiations for multilateral disciplines and transparency within the OECD Export Credit Arrangement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb631355-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635i–9/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Bank may provide financing on terms and conditions that are inconsistent with those permitted under the OECD Export Credit Arrangement—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb631356-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635i–9/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to match financing terms and conditions that are being offered by market windows on terms that are inconsistent with those permitted under the OECD Export Credit Arrangement, if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddb631357-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635i–9/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" matching such terms and conditions advances the negotiations for multilateral disciplines and transparency within the OECD Export Credit Arrangement; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb631358-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635i–9/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transparency verifies that the market window financing is being offered on terms that are more favorable than the terms and conditions that are available from private financial markets; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb631359-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635i–9/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when the foreign government-supported institution refuses to provide sufficient transparency to permit the Bank to make a determination under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb63135a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635i–9/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “OECD” means the Organization for Economic Cooperation and Development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddb63135b-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-07-31/ch341/s15"},"text":"July 31, 1945, ch. 341, § 15","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/189/s10/b/1"},"text":"Pub. L. 107–189, § 10(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-06-14"},"text":"June 14, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/703"},"text":"116 Stat. 703","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb63135c-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddb63135d-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddb63135e-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/189/s10/b/2"},"text":"Pub. L. 107–189, § 10(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-06-14"},"text":"June 14, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/703"},"text":"116 Stat. 703","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/189/s10/b/2"},"text":"“Within 2 years after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2002-06-14"},"text":"June 14, 2002","children":[],"tail":"], the Secretary of the Treasury shall submit to the Committee on Financial Services of the House of Representatives and the Committee on Banking, Housing, and Urban Affairs of the Senate a report on the rationale for seeking or not seeking negotiations for multilateral disciplines and transparency, the successes, failures, and obstacles in initiating negotiations, and if negotiations were initiated, in reaching an agreement.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
