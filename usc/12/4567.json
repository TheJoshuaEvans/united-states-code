{"tag":"section","attrib":{"id":"iddd2a8d3c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4567"},"text":null,"children":[{"tag":"num","attrib":{"value":"4567"},"text":"§ 4567.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Affordable housing allocations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd2a8d3d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4567/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Set aside and allocation of amounts by enterprises","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (b), in each fiscal year—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2a8d3e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4567/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Federal Home Loan Mortgage Corporation shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd2a8d3f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4567/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set aside an amount equal to 4.2 basis points for each dollar of the unpaid principal balance of its total new business purchases; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd2a8d40-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4567/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" allocate or otherwise transfer—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd2a8d41-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4567/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 65 percent of such amounts to the Secretary of Housing and Urban Development to fund the Housing Trust Fund established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4568"},"text":"section 4568 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd2a8d42-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4567/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 35 percent of such amounts to fund the Capital Magnet Fund established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4569"},"text":"section 4569 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2a8d43-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4567/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Federal National Mortgage Association shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd2a8d44-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4567/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set aside an amount equal to 4.2 basis points for each dollar of unpaid principal balance of its total new business purchases; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd2a8d45-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4567/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" allocate or otherwise transfer—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd2a8d46-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4567/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 65 percent of such amounts to the Secretary of Housing and Urban Development to fund the Housing Trust Fund established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4568"},"text":"section 4568 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd2a8d47-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4567/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 35 percent of such amounts to fund the Capital Magnet Fund established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4569"},"text":"section 4569 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2a8d48-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4567/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension of contributions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall temporarily suspend allocations under subsection (a) by an enterprise upon a finding by the Director that such allocations—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2a8d49-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4567/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are contributing, or would contribute, to the financial instability of the enterprise;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2a8d4a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4567/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are causing, or would cause, the enterprise to be classified as undercapitalized; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2a8d4b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4567/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are preventing, or would prevent, the enterprise from successfully completing a capital restoration plan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4622"},"text":"section 4622 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2a8d4c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4567/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of pass-through of cost of allocations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall, by regulation, prohibit each enterprise from redirecting the costs of any allocation required under this section, through increased charges or fees, or decreased premiums, or in any other manner, to the originators of mortgages purchased or securitized by the enterprise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2a8d4d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4567/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement of requirements on enterprise","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Compliance by the enterprises with the requirements under this section shall be enforceable under subpart 3. Any reference in such subpart to this part or to an order, rule, or regulation under this part specifically includes this section and any order, rule, or regulation under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2a8d4e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4567/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required amount for HOPE reserve fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the aggregate amount allocated under subsection (a), 25 percent shall be deposited into a fund established in the Treasury of the United States by the Secretary of the Treasury for such purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2a8d4f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4567/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No funds under this chapter may be used in conjunction with property taken by eminent domain, unless eminent domain is employed only for a public use, except that, for purposes of this section, public use shall not be construed to include economic development that primarily benefits any private entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd2a8d50-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXIII/s1337"},"text":"Pub. L. 102–550, title XIII, § 1337","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tI/s1131/b"},"text":"Pub. L. 110–289, div. A, title I, § 1131(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2711"},"text":"122 Stat. 2711","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd2a8d51-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd2a8d52-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd2a8d53-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (f), was in the original “this title”, meaning title XIII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550"},"text":"Pub. L. 102–550","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3941"},"text":"106 Stat. 3941","children":[],"tail":", which is classified principally to this chapter. For complete classification of title XIII to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4501"},"text":"section 4501 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"iddd2a8d54-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 4567, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXIII/s1337"},"text":"Pub. L. 102–550, title XIII, § 1337","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3964"},"text":"106 Stat. 3964","children":[],"tail":", related to reports during transition, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tI/s1131/a"},"text":"Pub. L. 110–289, div. A, title I, § 1131(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2711"},"text":"122 Stat. 2711","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
