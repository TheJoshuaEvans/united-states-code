{"tag":"section","attrib":{"id":"iddceee370-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2408"},"text":null,"children":[{"tag":"num","attrib":{"value":"2408"},"text":"§ 2408.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated without fiscal year limitations such sums, not to exceed $2,000,000, as may be necessary to carry out the provisions of this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddceee371-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/495/tII/s208"},"text":"Pub. L. 93–495, title II, § 208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-28"},"text":"Oct. 28, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1511"},"text":"88 Stat. 1511","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
