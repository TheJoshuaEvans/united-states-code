{"tag":"section","attrib":{"id":"iddce7b85f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279d"},"text":null,"children":[{"tag":"num","attrib":{"value":"2279d"},"text":"§ 2279d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of System institution status","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddce7b860-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A System institution may terminate the status of the institution as a System institution if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce7b861-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the institution provides written notice to the Farm Credit Administration Board not later than 90 days prior to the proposed termination date;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce7b862-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the termination is approved by the Farm Credit Administration Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce7b863-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279d/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriate Federal or State authority grants approval to charter the institution as a bank, savings and loan association, or other financial institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce7b864-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279d/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the institution pays to the Farm Credit Insurance Fund the amount by which the total capital of the institution exceeds 6 percent of the assets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce7b865-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279d/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the institution pays or makes adequate provision for payment of all outstanding debt obligations of the institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce7b866-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279d/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the termination is approved by a majority of the stockholders of the institution voting, in person or by written proxy, at a duly authorized stockholders’ meeting, held prior to giving notice to the Farm Credit Administration Board; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce7b867-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279d/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the institution meets such other conditions as the Farm Credit Administration Board by regulation considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce7b868-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On termination of its status as a System institution—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce7b869-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Farm Credit Administration Board shall revoke the charter of the institution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce7b86a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the institution shall no longer be an instrumentality of the United States under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddce7b86b-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tVII/s7"},"text":"Pub. L. 92–181, title VII, § 7","children":[],"tail":".10, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tIV/s416"},"text":"Pub. L. 100–233, title IV, § 416","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1650"},"text":"101 Stat. 1650","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tV/s5411/41"},"text":"Pub. L. 115–334, title V, § 5411(41)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4683"},"text":"132 Stat. 4683","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddce7b86c-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddce7b86d-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddce7b86e-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" added par. (4) and struck out former par. (4) which read as follows: “the institution pays to the Farm Credit Assistance Fund, as created under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2278b–5"},"text":"section 2278b–5 of this title","children":[],"tail":", if the termination is prior to "},{"tag":"date","attrib":{"date":"1992-01-01"},"text":"January 1, 1992","children":[],"tail":", or pays to the Farm Credit Insurance Fund, if the termination is after such date, the amount by which the total capital of the institution exceeds, 6 percent of the assets;”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
