{"tag":"section","attrib":{"id":"iddd01f5ee-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3111"},"text":null,"children":[{"tag":"num","attrib":{"value":"3111"},"text":"§ 3111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, with the intent to deceive, to gain financially, or to cause financial gain or loss to any person, knowingly violates any provision of this chapter or any regulation or order issued by the appropriate Federal banking agency under this chapter shall be imprisoned not more than 5 years or fined not more than $1,000,000 for each day during which a violation continues, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd01f5ef-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/369/s17"},"text":"Pub. L. 95–369, § 17","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/242/tII/s213"},"text":"Pub. L. 102–242, title II, § 213","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2303"},"text":"105 Stat. 2303","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd01f5f0-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd01f5f1-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd01f5f2-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For definition of “this chapter”, referred to in text, see References in Text note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s3101"},"text":"section 3101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
