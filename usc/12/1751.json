{"tag":"section","attrib":{"id":"iddc3c0e23-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1751"},"text":null,"children":[{"tag":"num","attrib":{"value":"1751"},"text":"§ 1751.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short title","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"This chapter may be cited as the “Federal Credit Union Act”.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc3c0e24-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-26/ch750/s1"},"text":"June 26, 1934, ch. 750, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/1216"},"text":"48 Stat. 1216","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/354/s1"},"text":"Pub. L. 86–354, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-09-22"},"text":"Sept. 22, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/628"},"text":"73 Stat. 628","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc3c0e25-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc3c0e26-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc3c0e27-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1959—","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/354"},"text":"Pub. L. 86–354","children":[],"tail":" reen acted section without change."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc3c0e28-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"iddc3c0e29-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/dT/s101"},"text":"Pub. L. 117–103, div. T, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/823"},"text":"136 Stat. 823","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/103/dT/s101"},"text":"“This division [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1764"},"text":"section 1764 of this title","children":[],"tail":"] may be cited as the ‘Credit Union Governance Modernization Act of 2022’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"iddc3c0e2a-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2014 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/252/s1"},"text":"Pub. L. 113–252, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2893"},"text":"128 Stat. 2893","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/252/s1"},"text":"“This Act [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1787"},"text":"section 1787 of this title","children":[],"tail":"] may be cited as the ‘Credit Union Share Insurance Fund Parity Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"iddc3c0e2b-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/219/s1/a"},"text":"Pub. L. 105–219, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/913"},"text":"112 Stat. 913","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/219/s1/a"},"text":"“This Act [enacting sections 1757a and 1790d of this title, amending sections 1752a, 1759, 1782, and 1784 to 1787 of this title, repealing ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1762"},"text":"section 1762 of this title","children":[],"tail":", and enacting provisions set out as notes under this section and sections 1752a, 1757a, 1759, 1790d, 4801, and 4803 of this title] may be cited as the ‘Credit Union Membership Access Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"iddc3c0e2c-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1987 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/86/tVII/s701"},"text":"Pub. L. 100–86, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-08-10"},"text":"Aug. 10, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/652"},"text":"101 Stat. 652","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/86/tVII/s701"},"text":"“This title [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1772c"},"text":"section 1772c of this title","children":[],"tail":" and amending sections 1757, 1761a, 1761b, 1764, 1766, 1767, and 1786 to 1788 of this title and sections 45, 46, and 57a of Title 15, Commerce and Trade] may be cited as the ‘Credit Union Amendments of 1987’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"iddc3c0e2d-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/630/tXVIII/s1801"},"text":"Pub. L. 95–630, title XVIII, § 1801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3719"},"text":"92 Stat. 3719","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/630/tXVIII/s1801"},"text":"“This title [enacting subchapter III of this chapter and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1757"},"text":"section 1757 of this title","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s709"},"text":"section 709 of Title 18","children":[],"tail":", Crimes and Criminal Procedure, and section 856 of former Title 31, Money and Finance] may be cited as the ‘National Credit Union Central Liquidity Facility Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddc3c0e2e-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Congressional Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/219/s2"},"text":"Pub. L. 105–219, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/913"},"text":"112 Stat. 913","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/219/s2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Congress finds the following:","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The American credit union movement began as a cooperative effort to serve the productive and provident credit needs of individuals of modest means.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Credit unions continue to fulfill this public purpose, and current members and membership groups should not face divestiture from the financial services institution of their choice as a result of recent court action.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To promote thrift and credit extension, a meaningful affinity and bond among members, manifested by a commonality of routine interaction, shared and related work experiences, interests, or activities, or the maintenance of an otherwise well-understood sense of cohesion or identity is essential to the fulfillment of the public mission of credit unions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Credit unions, unlike many other participants in the financial services market, are exempt from Federal and most State taxes because they are member-owned, democratically operated, not-for-profit organizations generally managed by volunteer boards of directors and because they have the specified mission of meeting the credit and savings needs of consumers, especially persons of modest means.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Improved credit union safety and soundness provisions will enhance the public benefit that citizens receive from these cooperative financial services institutions.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"iddc3c0e2f-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary and Department of Health, Education, and Welfare redesignated Secretary and Department of Health and Human Services by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s3508"},"text":"section 3508 of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"iddc3c0e30-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"iddc3c0e31-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Transfer of functions of Farm Credit Administration and Governor thereof to Bureau of Farm Credit Unions and Director thereof under jurisdiction of Federal Security Agency by ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-29/ch711"},"text":"act June 29, 1948, ch. 711","children":[],"tail":", §§ 1, 2, "},{"tag":"ref","attrib":{"href":"/us/stat/62/1091"},"text":"62 Stat. 1091","children":[],"tail":", and abolishment of Agency and transfer of its functions to Department of Health, Education, and Welfare by Reorg. Plan No. 1 of 1953, § 5, eff. "},{"tag":"date","attrib":{"date":"1953-04-11"},"text":"Apr. 11, 1953","children":[],"tail":", 18 F.R. 2053, "},{"tag":"ref","attrib":{"href":"/us/stat/67/632"},"text":"67 Stat. 632","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1752a"},"text":"section 1752a of this title","children":[],"tail":", and notes thereunder."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of Farm Credit Administration and Governor thereof under this chapter, together with functions of Secretary of Agriculture with respect thereto, transferred to Federal Deposit Insurance Corporation by Reorg. Plan No. 1 of 1947, § 401, eff. ","children":[{"tag":"date","attrib":{"date":"1947-07-01"},"text":"July 1, 1947","children":[],"tail":", 12 F.R. 4534, "},{"tag":"ref","attrib":{"href":"/us/stat/61/952"},"text":"61 Stat. 952","children":[],"tail":", set out in the Appendix to Title 5, Government Organization and Employees. A similar transfer of functions for duration of World War II was effected by Ex. Ord. No. 9148, "},{"tag":"date","attrib":{"date":"1942-04-27"},"text":"Apr. 27, 1942","children":[],"tail":", 7 F.R. 3145."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Farm Credit Administration transferred to Department of Agriculture by Reorg. Plan No. I of 1939, § 401, eff. ","children":[{"tag":"date","attrib":{"date":"1939-07-01"},"text":"July 1, 1939","children":[],"tail":", 4 F.R. 2730, "},{"tag":"ref","attrib":{"href":"/us/stat/53/1429"},"text":"53 Stat. 1429","children":[],"tail":", set out in the Appendix to Title 5."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
