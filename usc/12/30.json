{"tag":"section","attrib":{"id":"iddb0ae12d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s30"},"text":null,"children":[{"tag":"num","attrib":{"value":"30"},"text":"§ 30.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Change of name or location","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddb0ae12e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s30/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Name change","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any national banking association, upon written notice to the Comptroller of the Currency, may change its name, except that such new name shall include the word “National”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb0ae12f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s30/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Location change","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any national banking association, upon written notice to the Comptroller of the Currency, may change the location of its main office to any authorized branch location within the limits of the city, town, or village in which it is situated, or, with a vote of shareholders owning two-thirds of the stock of such association for a relocation outside such limits and upon receipt of a certificate of approval from the Comptroller of the Currency, to any other location within or outside the limits of the city, town, or village in which it is located, but not more than thirty miles beyond such limits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb0ae130-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s30/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s36"},"text":"section 36 of this title","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a national bank which relocates the main office of such bank from 1 State to another State after ","children":[{"tag":"date","attrib":{"date":"1997-05-31"},"text":"May 31, 1997","children":[],"tail":", the bank may retain and operate branches within the State from which the bank relocated such office only to the extent authorized in "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s36/e/2"},"text":"section 36(e)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb0ae131-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s30/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retention of “Federal” in name of converted Federal savings association","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb0ae132-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s30/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subsection (a) or any other provision of law, any depository institution, the charter of which is converted from that of a Federal savings association to a national bank or a State bank after ","children":[{"tag":"date","attrib":{"date":"1999-11-12"},"text":"November 12, 1999","children":[],"tail":", may retain the term “Federal” in the name of such institution if such institution remains an insured depository institution."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb0ae133-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s30/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, the terms “depository institution”, “insured depository institution”, “national bank”, and “State bank” have the meanings given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"section 1813 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddb0ae134-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1886-05-01/ch73/s2"},"text":"May 1, 1886, ch. 73, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/24/18"},"text":"24 Stat. 18","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/230/s3"},"text":"Pub. L. 86–230, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-09-08"},"text":"Sept. 8, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/457"},"text":"73 Stat. 457","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/320/tIV/s405/a"},"text":"Pub. L. 97–320, title IV, § 405(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-15"},"text":"Oct. 15, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1512"},"text":"96 Stat. 1512","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/457/s19/a"},"text":"Pub. L. 97–457, § 19(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2509"},"text":"96 Stat. 2509","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/328/tI/s102/b/2"},"text":"Pub. L. 103–328, title I, § 102(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-29"},"text":"Sept. 29, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2350"},"text":"108 Stat. 2350","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/102/tVII/s723"},"text":"Pub. L. 106–102, title VII, § 723","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1471"},"text":"113 Stat. 1471","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb0ae135-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb0ae136-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddb0ae137-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/102"},"text":"Pub. L. 106–102","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/328"},"text":"Pub. L. 103–328","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/457"},"text":"Pub. L. 97–457","children":[],"tail":" inserted “for a relocation outside such limits” after “stock of such association”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/320"},"text":"Pub. L. 97–320","children":[],"tail":" designated existing provisions as subsec. (a), substituted provisions permitting a change of name upon written notice to the Comptroller, such new name to include “National”, for provisions permitting a change of name or location of the main office, with approval of the Comptroller, within city limits, etc., or outside such limits by vote of shareholders, such change to be validated by certificate of approval, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1959—","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/230"},"text":"Pub. L. 86–230","children":[],"tail":" required approval of Comptroller of the Currency before a national bank could change location of its main office within the limitations of the city, town, or village in which it is situated."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"iddb0ae138-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddb0ae139-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Exception as to Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions vested by any provision of law in Comptroller of the Currency, referred to in this section, not included in transfer of functions to Secretary of the Treasury, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
