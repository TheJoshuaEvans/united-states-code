{"tag":"section","attrib":{"id":"iddc5896b9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1790c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1790c"},"text":"§ 1790c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reward for information leading to recoveries or civil penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Board may pay rewards in connection with an offense affecting an insured credit union, under the same circumstances and subject to the same limitations that a Federal banking agency may pay rewards under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1831j"},"text":"section 1831j of this title","children":[],"tail":" in connection with an offense affecting a depository institution insured by the Federal Deposit Insurance Corporation."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc5896ba-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-26/ch750"},"text":"June 26, 1934, ch. 750","children":[],"tail":", title II, § 214, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/73/tIX/s933/b"},"text":"Pub. L. 101–73, title IX, § 933(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/496"},"text":"103 Stat. 496","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
