ref","attrib":{"href":"/us/act/1934-04-27/ch168/s9"},"text":"act Apr. 27, 1934, ch. 168, § 9","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/646"},"text":"48 Stat. 646","children":[],"tail":", related to purchase of obligations of, and loans to, Federal Home Loan Banks, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/act/1935-05-28/ch150/s17/b"},"text":"act May 28, 1935, ch. 150, § 17(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/297"},"text":"49 Stat. 297","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddb86c7dd-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (e)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/251/s3/d/1"},"text":"Pub. L. 113–251, § 3(d)(1)","children":[],"tail":", inserted “, other than a savings promotion raffle,” after “arrangement” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/251/s3/d/2"},"text":"Pub. L. 113–251, § 3(d)(2)","children":[],"tail":", added subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s369/4/A/i"},"text":"Pub. L. 111–203, § 369(4)(A)(i)","children":[],"tail":", struck out “Federal” before “savings” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s369/4/A/ii"},"text":"Pub. L. 111–203, § 369(4)(A)(ii)","children":[],"tail":", added pars. (1) and (2) and struck out former pars. (1) and (2) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—The Director shall provide for the examination, safe and sound operation, and regulation of savings associations."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—The Director may issue such regulations as the Director determines to be appropriate to carry out the responsibilities of the Director or the Office.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s369/4/A/iii"},"text":"Pub. L. 111–203, § 369(4)(A)(iii)","children":[],"tail":", substituted “Comptroller and the Corporation” for “Director” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s369/4/B/ii"},"text":"Pub. L. 111–203, § 369(4)(B)(ii)","children":[],"tail":", substituted “Comptroller” for “Director” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s369/4/B/i"},"text":"Pub. L. 111–203, § 369(4)(B)(i)","children":[],"tail":", inserted “and” at end of subpar. (A), substituted a period for “; and” at end of subpar. (B), and struck out subpar. (C) which read as follows: “prior to "},{"tag":"date","attrib":{"date":"1994-01-01"},"text":"January 1, 1994","children":[],"tail":", require full compliance by savings associations with accounting standards in effect at any time before such date not later than provided under the schedule in section 563.23–3 of title 12, Code of Federal Regulations (as in effect on "},{"tag":"date","attrib":{"date":"1989-05-01"},"text":"May 1, 1989","children":[],"tail":").”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s369/4/C"},"text":"Pub. L. 111–203, § 369(4)(C)","children":[],"tail":", substituted “The regulations of the Comptroller and the policies of the Comptroller and the Corporation” for “All regulations and policies of the Director” and struck out “of the Currency” before “for national”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s369/4/D"},"text":"Pub. L. 111–203, § 369(4)(D)","children":[],"tail":", substituted “Comptroller” for “Director”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (f), (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s369/4/E"},"text":"Pub. L. 111–203, § 369(4)(E)","children":[],"tail":", (F), substituted “appropriate Federal banking agency” for “Director” in two places."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddb86c7de-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddb86c7df-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective on the transfer date, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s351"},"text":"section 351 of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s906"},"text":"section 906 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddb86c7e0-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Preserving Minority Ownership of Minority Financial Institutions","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/tIII/s308"},"text":"Pub. L. 101–73, title III, § 308","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/353"},"text":"103 Stat. 353","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tIII/s367/4"},"text":"Pub. L. 111–203, title III, § 367(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1556"},"text":"124 Stat. 1556","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/203/tIII/s367/4"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation on Methods","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Treasury shall consult with the Chairman of the Board of Governors of the Federal Reserve System, the Comptroller of the Currency, the Chairman of the National Credit Union Administration, and the Chairperson of the Board of Directors of the Federal Deposit Insurance Corporation on methods for best achieving the following goals:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Preserving the present number of minority depository institutions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Preserving their minority character in cases involving mergers or acquisition of a minority depository institution by using general preference guidelines in the following order:","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Same type of minority depository institution in the same city.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Same type of minority depository institution in the same State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Same type of minority depository institution nationwide.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any type of minority depository institution in the same city.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"“(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any type of minority depository institution in the same State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"“(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any type of minority depository institution nationwide.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"“(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other bidders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Providing technical assistance to prevent insolvency of institutions not now insolvent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Promoting and encouraging creation of new minority depository institutions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Providing for training, technical assistance, and educational programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Minority financial institution","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term ‘minority depository institution’ means any depository institution that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if a privately owned institution, 51 percent is owned by one or more socially and economically disadvantaged individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if publicly owned, 51 percent of the stock is owned by one or more socially and economically disadvantaged individuals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a mutual institution where the majority of the Board of Directors, account holders, and the community which it services is predominantly minority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Minority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘minority’ means any black American, Native American, Hispanic American, or Asian American.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Treasury, the Chairman of the Board of Governors of the Federal Reserve System, the Comptroller of the Currency, the Chairman of the National Credit Union Administration, and the Chairperson of Board of Directors of the Federal Deposit Insurance Corporation shall each submit an annual report to the Congress containing a description of actions taken to carry out this section.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddb86c7e1-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of Home Owners’ Loan Corporation","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1953-06-30/ch170/s21"},"text":"Act June 30, 1953, ch. 170, § 21","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/67/126"},"text":"67 Stat. 126","children":[],"tail":", provided for dissolution and abolition of Home Owners’ Loan Corporation established by former "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1463"},"text":"section 1463 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
