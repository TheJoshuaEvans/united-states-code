{"tag":"section","attrib":{"id":"iddb86c7ae-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1463"},"text":null,"children":[{"tag":"num","attrib":{"value":"1463"},"text":"§ 1463.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supervision of savings associations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddb86c7af-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1463/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings associations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb86c7b0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1463/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Examination and safe and sound operation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddb86c7b1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1463/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal savings associations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Comptroller shall provide for the examination and safe and sound operation of Federal savings associations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb86c7b2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1463/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State savings associations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation shall provide for the examination and safe and sound operation of State savings associations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb86c7b3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1463/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations for savings associations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Comptroller may prescribe regulations with respect to savings associations, as the Comptroller determines to be appropriate to carry out the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb86c7b4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1463/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Safe and sound housing credit to be encouraged","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Comptroller and the Corporation shall exercise all powers granted to the Comptroller and the Corporation under this chapter so as to encourage savings associations to provide credit for housing safely and soundly.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb86c7b5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1463/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accounting and disclosure","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb86c7b6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1463/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Comptroller shall, by regulation, prescribe uniform accounting and disclosure standards for savings associations, to be used in determining savings associations’ compliance with all applicable regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb86c7b7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1463/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific requirements for accounting standards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1464/t"},"text":"section 1464(t) of this title","children":[],"tail":", the uniform accounting standards prescribed under paragraph (1) shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddb86c7b8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1463/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporate generally accepted accounting principles to the same degree that such principles are used to determine compliance with regulations prescribed by the Federal banking agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb86c7b9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1463/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow for no deviation from full compliance with such standards as are in effect after ","children":[{"tag":"date","attrib":{"date":"1993-12-31"},"text":"December 31, 1993","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb86c7ba-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1463/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to prescribe more stringent accounting standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Comptroller may at any time prescribe accounting standards more stringent than required under paragraph (2) if the Comptroller determines that the more stringent standards are necessary to ensure the safe and sound operation of savings associations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb86c7bb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1463/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stringency of standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The regulations of the Comptroller and the policies of the Comptroller and the Corporation governing the safe and sound operation of savings associations, including regulations and policies governing asset classification and appraisals, shall be no less stringent than those established by the Comptroller for national banks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb86c7bc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1463/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment of certain funds in accounts of savings associations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The savings accounts and share accounts of savings associations insured by the Corporation shall be lawful investments and may be accepted as security for all public funds of the United States, fiduciary and trust funds under the authority or control of the United States or any officer thereof, and for the funds of all corporations organized under the laws of the United States (subject to any regulatory authority otherwise applicable), regardless of any limitation of law upon the investment of any such funds or upon the acceptance of security for the investment or deposit of any of such funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb86c7bd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1463/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation by savings associations in lotteries and related activities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb86c7be-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1463/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation prohibited","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No savings association may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddb86c7bf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1463/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deal in lottery tickets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb86c7c0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1463/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deal in bets used as a means or substitute for participation in a lottery;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb86c7c1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1463/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" announce, advertise, or publicize the existence of any lottery; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb86c7c2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1463/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" announce, advertise, or publicize the existence or identity of any participant or winner, as such, in a lottery.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb86c7c3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1463/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of facilities prohibited","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No savings association may permit—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddb86c7c4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1463/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of any part of any of its own offices by any person for any purpose forbidden to the institution under paragraph (1); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb86c7c5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1463/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct access by the public from any of its own offices to any premises used by any person for any purpose forbidden to the institution under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb86c7c6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1463/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddb86c7c7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1463/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deal in","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “deal in” includes making, taking, buying, selling, redeeming, or collecting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb86c7c8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1463/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lottery","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “lottery” includes any arrangement, other than a savings promotion raffle, under which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddb86c7c9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1463/e/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3 or more persons (hereafter in this subparagraph referred to as the “participants”) advance money or credit to another in exchange for the possibility or expectation that 1 or more but not all of the participants (hereafter in this paragraph referred to as the “winners”) will receive by reason of those participants’ advances more than the amounts those participants have advanced; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddb86c7ca-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1463/e/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the identity of the winners is determined by any means which includes—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddb86c7cb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1463/e/3/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a random selection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddb86c7cc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1463/e/3/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a game, race, or contest; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddb86c7cd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1463/e/3/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any record or tabulation of the result of 1 or more events in which any participant has no interest except for the bearing that event has on the possibility that the participant may become a winner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb86c7ce-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1463/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lottery ticket","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “lottery ticket” includes any right, privilege, or possibility (and any ticket, receipt, record, or other evidence of any such right, privilege, or possibility) of becoming a winner in a lottery.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb86c7cf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1463/e/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings promotion raffle","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “savings promotion raffle” means a contest in which the sole consideration required for a chance of winning designated prizes is obtained by the deposit of a specified amount of money in a savings account or other savings program, where each ticket or entry has an equal chance of being drawn, such contest being subject to regulations that may from time to time be promulgated by the appropriate prudential regulator (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5481"},"text":"section 5481 of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb86c7d0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1463/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for State lotteries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraphs (1) and (2) shall not apply with respect to any savings association accepting funds from, or performing any lawful services for, any State operating a lottery, or any officer or employee of such a State who is charged with administering the lottery.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb86c7d1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1463/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Comptroller shall prescribe such regulations as may be necessary to provide for enforcement of this subsection and to prevent any evasion of any provision of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb86c7d2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1463/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federally related mortgage loan disclosures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A savings association may not make a federally related mortgage loan to an agent, trustee, nominee, or other person acting in a fiduciary capacity without requiring that the identity of the person receiving the beneficial interest of such loan shall at all times be revealed to the savings association. At the request of the appropriate Federal banking agency, the savings association shall report to the appropriate Federal banking agency the identity of such person and the nature and amount of the loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb86c7d3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1463/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preemption of State usury laws","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb86c7d4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1463/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any State law, a savings association may charge interest on any extension of credit at a rate of not more than 1 percent in excess of the discount rate on 90-day commercial paper in effect at the Federal Reserve bank in the Federal Reserve district in which such savings association is located or at the rate allowed by the laws of the State in which such savings association is located, whichever is greater.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb86c7d5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1463/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the rate prescribed in paragraph (1) exceeds the rate such savings association would be permitted to charge in the absence of this subsection, the receiving or charging a greater rate of interest than that prescribed by paragraph (1), when knowingly done, shall be deemed a forfeiture of the entire interest which the extension of credit carries with it, or which has been agreed to be paid thereon. If such greater rate of interest has been paid, the person who paid it may recover, in a civil action commenced in a court of appropriate jurisdiction not later than 2 years after the date of such payment, an amount equal to twice the amount of the interest paid from the savings association taking or receiving such interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb86c7d6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1463/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form and maturity of securities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No savings association shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb86c7d7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1463/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue securities which guarantee a definite maturity except with the specific approval of the appropriate Federal banking agency, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb86c7d8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1463/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue any securities the form of which has not been approved by the appropriate Federal banking agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddb86c7d9-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-06-13/ch64/s4"},"text":"June 13, 1933, ch. 64, § 4","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/73/tIII/s301"},"text":"Pub. L. 101–73, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/280"},"text":"103 Stat. 280","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tIII/s369/4"},"text":"Pub. L. 111–203, title III, § 369(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1558"},"text":"124 Stat. 1558","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/251/s3/d"},"text":"Pub. L. 113–251, § 3(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2889"},"text":"128 Stat. 2889","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb86c7da-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb86c7db-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"iddb86c7dc-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1463, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-06-13/ch64/s4"},"text":"June 13, 1933, ch. 64, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/129"},"text":"48 Stat. 129","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1934-04-27/ch168"},"text":"Apr. 27, 1934, ch. 168","children":[],"tail":", §§ 1(a), 2–4, 13, "},{"tag":"ref","attrib":{"href":"/us/stat/48/643-645"},"text":"48 Stat. 643–645","children":[],"tail":", 647; "},{"tag":"ref","attrib":{"href":"/us/act/1934-06-27/ch847"},"text":"June 27, 1934, ch. 847","children":[],"tail":", title V, §§ 506, 508(b), "},{"tag":"ref","attrib":{"href":"/us/stat/48/1263"},"text":"48 Stat. 1263","children":[],"tail":", 1264; "},{"tag":"ref","attrib":{"href":"/us/act/1935-05-28/ch150"},"text":"May 28, 1935, ch. 150","children":[],"tail":", §§ 10–17(a), "},{"tag":"ref","attrib":{"href":"/us/stat/49/296"},"text":"49 Stat. 296","children":[],"tail":", 297; "},{"tag":"ref","attrib":{"href":"/us/act/1939-08-11/ch684"},"text":"Aug. 11, 1939, ch. 684","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/1403"},"text":"53 Stat. 1403","children":[],"tail":"; "},{"tag":"ref","attrib"