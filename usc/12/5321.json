{"tag":"section","attrib":{"id":"iddd50b37b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5321"},"text":null,"children":[{"tag":"num","attrib":{"value":"5321"},"text":"§ 5321.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial Stability Oversight Council established","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd50b37c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5321/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Effective on ","children":[{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", there is established the Financial Stability Oversight Council."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd50b37d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5321/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall consist of the following members:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd50b37e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5321/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voting members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The voting members, who shall each have 1 vote on the Council shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd50b37f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5321/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Treasury, who shall serve as Chairperson of the Council;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd50b380-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5321/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chairman of the Board of Governors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd50b381-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5321/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Comptroller of the Currency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd52fc72-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5321/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the Bureau;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd52fc73-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5321/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chairman of the Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd52fc74-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5321/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chairperson of the Corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd52fc75-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5321/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chairperson of the Commodity Futures Trading Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd52fc76-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5321/b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the Federal Housing Finance Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd52fc77-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5321/b/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chairman of the National Credit Union Administration Board; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd52fc78-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5321/b/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an independent member appointed by the President, by and with the advice and consent of the Senate, having insurance expertise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd52fc79-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5321/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonvoting members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The nonvoting members, who shall serve in an advisory capacity as a nonvoting member of the Council, shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd52fc7a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5321/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the Office of Financial Research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd52fc7b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5321/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the Federal Insurance Office;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd52fc7c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5321/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State insurance commissioner, to be designated by a selection process determined by the State insurance commissioners;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd52fc7d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5321/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State banking supervisor, to be designated by a selection process determined by the State banking supervisors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd52fc7e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5321/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State securities commissioner (or an officer performing like functions), to be designated by a selection process determined by such State securities commissioners.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd52fc7f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5321/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonvoting member participation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The nonvoting members of the Council shall not be excluded from any of the proceedings, meetings, discussions, or deliberations of the Council, except that the Chairperson may, upon an affirmative vote of the member agencies, exclude the nonvoting members from any of the proceedings, meetings, discussions, or deliberations of the Council when necessary to safeguard and promote the free exchange of confidential supervisory information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd52fc80-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5321/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms; vacancy","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd52fc81-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5321/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The independent member of the Council shall serve for a term of 6 years, and each nonvoting member described in subparagraphs (C), (D), and (E) of subsection (b)(2) shall serve for a term of 2 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd52fc82-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5321/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any vacancy on the Council shall be filled in the manner in which the original appointment was made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd52fc83-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5321/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acting officials may serve","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the event of a vacancy in the office of the head of a member agency or department, and pending the appointment of a successor, or during the absence or disability of the head of a member agency or department, the acting head of the member agency or department shall serve as a member of the Council in the place of that agency or department head.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd52fc84-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5321/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of independent member","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding paragraph (1), if a successor to the independent member of the Council serving under subsection (b)(1)(J) is not appointed and confirmed by the end of the term of service of such member, such member may continue to serve until the earlier of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd52fc85-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5321/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 18 months after the date on which the term of service ends; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd52fc86-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5321/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which a successor to such member is appointed and confirmed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd52fc87-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5321/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical and professional advisory committees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council may appoint such special advisory, technical, or professional committees as may be useful in carrying out the functions of the Council, including an advisory committee consisting of State regulators, and the members of such committees may be members of the Council, or other persons, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd52fc88-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5321/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd52fc89-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5321/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall meet at the call of the Chairperson or a majority of the members then serving, but not less frequently than quarterly.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd52fc8a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5321/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules for conducting business","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall adopt such rules as may be necessary for the conduct of the business of the Council. Such rules shall be rules of agency organization, procedure, or practice for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd52fc8b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5321/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Unless otherwise specified, the Council shall make all decisions that it is authorized or required to make by a majority vote of the voting members then serving.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd52fc8c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5321/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonapplicability of chapter 10 of title 5","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Chapter 10 of title 5 shall not apply to the Council, or to any special advisory, technical, or professional committee appointed by the Council, except that, if an advisory, technical, or professional committee has one or more members who are not employees of or affiliated with the United States Government, the Council shall publish a list of the names of the members of such committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd52fc8d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5321/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance from Federal agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any department or agency of the United States may provide to the Council and any special advisory, technical, or professional committee appointed by the Council, such services, funds, facilities, staff, and other support services as the Council may determine advisable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd52fc8e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5321/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation of members","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd52fc8f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5321/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal employee members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All members of the Council who are officers or employees of the United States shall serve without compensation in addition to that received for their services as officers or employees of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd52fc90-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5321/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd52fc91-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5321/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Detail of Government employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any employee of the Federal Government may be detailed to the Council without reimbursement, and such detail shall be without interruption or loss of civil service status or privilege. An employee of the Federal Government detailed to the Council shall report to and be subject to oversight by the Council during the assignment to the Council, and shall be compensated by the department or agency from which the employee was detailed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd52fc92-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tI/s111"},"text":"Pub. L. 111–203, title I, § 111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1392"},"text":"124 Stat. 1392","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/61/s2"},"text":"Pub. L. 115–61, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-09-27"},"text":"Sept. 27, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1158"},"text":"131 Stat. 1158","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/58"},"text":"Pub. L. 117–286, § 4(a)(58)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4311"},"text":"136 Stat. 4311","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd52fc93-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd52fc94-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd52fc95-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s111"},"text":"section 111 of Pub. L. 111–203","children":[],"tail":". Subsec. (i)(2) of "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s111"},"text":"section 111 of Pub. L. 111–203","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5314"},"text":"section 5314 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd52fc96-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “chapter 10 of title 5” for “FACA” in heading and “Chapter 10 of title 5” for “The Federal Advisory Committee Act (5 U.S.C. App.)” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/61"},"text":"Pub. L. 115–61","children":[],"tail":" added par. (4)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
