{"tag":"section","attrib":{"id":"iddd046830-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3339"},"text":null,"children":[{"tag":"num","attrib":{"value":"3339"},"text":"§ 3339.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions of Federal financial institutions regulatory agencies relating to appraisal standards","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Each Federal financial institutions regulatory agency and the Resolution Trust Corporation shall prescribe appropriate standards for the performance of real estate appraisals in connection with federally related transactions under the jurisdiction of each such agency or instrumentality. These rules shall require, at a minimum—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd046831-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3339/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that real estate appraisals be performed in accordance with generally accepted appraisal standards as evidenced by the appraisal standards promulgated by the Appraisal Standards Board of the Appraisal Foundation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd046832-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3339/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that such appraisals shall be written appraisals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd046833-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3339/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that such appraisals shall be subject to appropriate review for compliance with the Uniform Standards of Professional Appraisal Practice.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Each such agency or instrumentality may require compliance with additional standards if it makes a determination in writing that such additional standards are required in order to properly carry out its statutory responsibilities.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd046834-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/tXI/s1110"},"text":"Pub. L. 101–73, title XI, § 1110","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/514"},"text":"103 Stat. 514","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tXIV/s1473/e/1"},"text":"Pub. L. 111–203, title XIV, § 1473(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2191"},"text":"124 Stat. 2191","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd046835-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd046836-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd046837-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" added par. (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd046838-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd046839-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective on the date on which final regulations implementing that amendment take effect, or on the date that is 18 months after the designated transfer date if such regulations have not been issued by that date, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1400/c"},"text":"section 1400(c) of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1601"},"text":"section 1601 of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
