{"tag":"section","attrib":{"id":"iddafed30d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"§ 12.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Seal of Comptroller","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The seal devised by the Comptroller of the Currency for his office, and approved by the Secretary of the Treasury, shall continue to be the seal of office of the comptroller, and may be renewed when necessary. A description of the seal, with an impression thereof, and a certificate of approval by the Secretary of the Treasury, shall be filed in the office of the Secretary of State.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddafed30e-3a6f-11f1-8fa0-c065796a7f06"},"text":"(R.S. § 330; ","children":[{"tag":"ref","attrib":{"href":"/us/act/1875-02-18/ch80/s1"},"text":"Feb. 18, 1875, ch. 80, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/18/317"},"text":"18 Stat. 317","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddafed30f-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddafed310-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddafed311-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 330 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1864-06-03/ch106/s2"},"text":"act June 3, 1864, ch. 106, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/13/100"},"text":"13 Stat. 100","children":[],"tail":", which was the National Bank Act. See "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s38"},"text":"section 38 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"iddafed312-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddafed313-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Exception as to Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions vested by any provision of law in Comptroller of the Currency, referred to in this section, not included in transfer of functions to Secretary of the Treasury, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
