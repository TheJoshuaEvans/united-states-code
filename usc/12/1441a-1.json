{"tag":"section","attrib":{"id":"iddb7d518f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1441a–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1441a–1"},"text":"§ 1441a–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1441a–2"},"text":"section 1441a–2 of this title","children":[],"tail":":"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb7d5190-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1441a–1/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State housing finance authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “State housing finance authority” means any public agency, authority, or corporation which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddb7d5191-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1441a–1/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serves as an instrumentality of any State or any political subdivision of any State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb7d5192-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1441a–1/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" functions as a source of residential mortgage loan financing in that State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb7d5193-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1441a–1/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonprofit entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “nonprofit entity” means any not-for-profit corporation chartered under State law that is exempt from Federal taxation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c"},"text":"section 501(c) of title 26","children":[],"tail":" and no part of the net earnings of which inures to the benefit of any member, founder, contributor, or individual (including any nonprofit entity established by the corporation established under title IX of the Housing and Urban Development Act of 1968 ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3931"},"text":"42 U.S.C. 3931","children":[],"tail":" et seq.])."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb7d5194-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1441a–1/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mortgage-related assets","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “mortgage-related assets” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddb7d5195-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1441a–1/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" residential mortgage loans secured by 1- to 4-family or multifamily dwellings; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb7d5196-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1441a–1/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" real property improved with 1- to 4-family or multifamily residential dwellings,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"which are located within the jurisdiction of the applicable State housing finance authority or within the geographical area served by the nonprofit entity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb7d5197-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1441a–1/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Net income","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “net income” means income after deduction of all associated expenses calculated in accordance with generally accepted accounting principles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddb7d5198-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/tXIII/s1301"},"text":"Pub. L. 101–73, title XIII, § 1301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/547"},"text":"103 Stat. 547","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb7d5199-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb7d519a-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddb7d519b-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Housing and Urban Development Act of 1968, referred to in par. (2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/448"},"text":"Pub. L. 90–448","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-08-01"},"text":"Aug. 1, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/476"},"text":"82 Stat. 476","children":[],"tail":". Title IX of the Housing and Urban Development Act of 1968 is classified principally to chapter 49 (§ 3931 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title of 1968 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1701"},"text":"section 1701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddb7d519c-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Financial Institutions Reform, Recovery, and Enforcement Act of 1989, and not as part of the Federal Home Loan Bank Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
