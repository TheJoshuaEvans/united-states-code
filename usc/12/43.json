{"tag":"section","attrib":{"id":"iddb0d2b99-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s43"},"text":null,"children":[{"tag":"num","attrib":{"value":"43"},"text":"§ 43.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interpretations concerning preemption of certain State laws","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddb0d2b9a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s43/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice and opportunity for comment required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before issuing any opinion letter or interpretive rule, in response to a request or upon the agency’s own motion, that concludes that Federal law preempts the application to a national bank of any State law regarding community reinvestment, consumer protection, fair lending, or the establishment of intrastate branches, or before making a determination under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s36/f/1/A/ii"},"text":"section 36(f)(1)(A)(ii) of this title","children":[],"tail":", the appropriate Federal banking agency (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"section 1813 of this title","children":[],"tail":") shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb0d2b9b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s43/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish in the Federal Register notice of the preemption or discrimination issue that the agency is considering (including a description of each State law at issue);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb0d2b9c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s43/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" give interested parties not less than 30 days in which to submit written comments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb0d2b9d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s43/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in developing the final opinion letter or interpretive rule issued by the agency, or making any determination under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s36/f/1/A/ii"},"text":"section 36(f)(1)(A)(ii) of this title","children":[],"tail":", consider any comments received."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb0d2b9e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s43/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The appropriate Federal banking agency shall publish in the Federal Register—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb0d2b9f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s43/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any final opinion letter or interpretive rule concluding that Federal law preempts the application of any State law regarding community reinvestment, consumer protection, fair lending, or establishment of intrastate branches to a national bank; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb0d2ba0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s43/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any determination under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s36/f/1/A/ii"},"text":"section 36(f)(1)(A)(ii) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb0d2ba1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s43/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb0d2ba2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s43/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No new issue or significant basis","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section shall not apply with respect to any opinion letter or interpretive rule that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddb0d2ba3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s43/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" raises issues of Federal preemption of State law that are essentially identical to those previously resolved by the courts or on which the agency has previously issued an opinion letter or interpretive rule; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb0d2ba4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s43/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" responds to a request that contains no significant legal basis on which to make a preemption determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb0d2ba5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s43/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial, legislative, or intragovernmental materials","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply with respect to materials prepared for use in judicial proceedings or submission to Congress or a Member of Congress, or for intragovernmental use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb0d2ba6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s43/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The appropriate Federal banking agency may make exceptions to subsection (a) if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddb0d2ba7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s43/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agency determines in writing that the exception is necessary to avoid a serious and imminent threat to the safety and soundness of any national bank; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb0d2ba8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s43/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the opinion letter or interpretive rule is issued in connection with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddb0d2ba9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s43/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an acquisition of 1 or more banks in default or in danger of default (as such terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"section 1813 of this title","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddb0d2baa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s43/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an acquisition with respect to which the Federal Deposit Insurance Corporation provides assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1823/c"},"text":"section 1823(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddb0d2bab-3a6f-11f1-8fa0-c065796a7f06"},"text":"(R.S. § 5244, as added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/328/tI/s114"},"text":"Pub. L. 103–328, title I, § 114","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-29"},"text":"Sept. 29, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2366"},"text":"108 Stat. 2366","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb0d2bac-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb0d2bad-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddb0d2bae-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another R.S. § 5244 is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s8"},"text":"section 8 of Title 33","children":[],"tail":", Navigation and Navigable Waters."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
