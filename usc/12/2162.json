{"tag":"section","attrib":{"id":"iddcc8bdfc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2162"},"text":null,"children":[{"tag":"num","attrib":{"value":"2162"},"text":"§ 2162.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of borrower stock","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcc8bdfd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2162/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retirement of stock","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other section of this chapter, each institution of the Farm Credit System, when retiring eligible borrower stock in accordance with this chapter, shall retire such stock at par value.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcc8bdfe-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2162/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain powers not affected","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section does not affect the authority of any institution of the Farm Credit System—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcc8bdff-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2162/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to retire or cancel borrower stock at par value for application against a loan in default;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc8be00-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2162/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to cancel borrower stock at par value under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2202b"},"text":"section 2202b of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc8be01-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2162/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to apply, against any outstanding indebtedness to a System association arising out of or in connection with a liquidation referred to in subsection (d)(2), the par value of borrower stock frozen in such liquidation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcc8be02-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2162/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inability to retire stock at par value","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcc8be03-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2162/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an institution is unable to retire eligible borrower stock at par value due to the liquidation of the institution, the Farm Credit System Insurance Corporation, acting as receiver, shall retire such stock at par value as would have been retired in the ordinary course of business of the institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc8be04-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2162/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Farm Credit System Insurance Corporation shall use such funds from the Farm Credit Insurance Fund as are sufficient to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcc8be05-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2162/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcc8be06-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2162/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Borrower stock","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “borrower stock” means voting and nonvoting stock, equivalent contributions to a guaranty fund, participation certificates, allocated equities, and other similar equities that are subject to retirement under a revolving cycle issued by any System institution and held by any person other than any System institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc8be07-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2162/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible borrower stock","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible borrower stock” means borrower stock that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcc8be08-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2162/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is outstanding on ","children":[{"tag":"date","attrib":{"date":"1988-01-06"},"text":"January 6, 1988","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcc8be09-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2162/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is issued or allocated after ","children":[{"tag":"date","attrib":{"date":"1988-01-06"},"text":"January 6, 1988","children":[],"tail":", but prior to the earlier of—"}],"tail":null},{"tag":"clause","attrib":{"id":"iddcc8be0a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2162/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of each bank and association, the date of approval, by the stockholders of such bank or association, of the capitalization requirements of the institution in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2154a"},"text":"section 2154a of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcc8be0b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2162/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date that is 9 months after ","children":[{"tag":"date","attrib":{"date":"1988-01-06"},"text":"January 6, 1988","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcc8be0c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2162/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was, after ","children":[{"tag":"date","attrib":{"date":"1983-01-01"},"text":"January 1, 1983","children":[],"tail":", but before "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"January 6, 1988","children":[],"tail":", frozen by an institution that was placed in liquidation; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcc8be0d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2162/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was retired at less than par value by an institution that was placed in liquidation after ","children":[{"tag":"date","attrib":{"date":"1983-01-01"},"text":"January 1, 1983","children":[],"tail":", but before "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"January 6, 1988","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc8be0e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2162/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “institution” means a bank or association chartered under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc8be0f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2162/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Par value","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “par value” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcc8be10-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2162/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of stock, par value;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcc8be11-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2162/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of participation certificates and other equities and interests not described in subparagraph (C), face or equivalent value; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcc8be12-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2162/d/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of participation certificates and allocated equities subject to retirement under a revolving cycle but that a System institution elects to retire out of order for application against a loan in default or otherwise as provided in this chapter, par or face value discounted, at a rate determined by the institution, to reflect the present value of the equity or interest as of the date of such retirement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcc8be13-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tIV/s4"},"text":"Pub. L. 92–181, title IV, § 4","children":[],"tail":".9A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tI/s101"},"text":"Pub. L. 100–233, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1572"},"text":"101 Stat. 1572","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/tI/s101/b"},"text":"Pub. L. 100–399, title I, § 101(b)","children":[],"tail":"–(d), "},{"tag":"date","attrib":{"date":"1988-08-17"},"text":"Aug. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/989"},"text":"102 Stat. 989","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tV/s5411/20"},"text":"Pub. L. 115–334, title V, § 5411(20)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4681"},"text":"132 Stat. 4681","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcc8be14-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcc8be15-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"iddcc8be16-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 4.9A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181"},"text":"Pub. L. 92–181","children":[],"tail":", which authorized a central reserve for Farm Credit System, was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2161"},"text":"section 2161 of this title","children":[],"tail":" and was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/s101/a"},"text":"Pub. L. 100–399, § 101(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcc8be17-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" inserted par. (1) designation and heading before “If an institution”, substituted “the Farm Credit System Insurance Corporation, acting as receiver,” for “the receiver of the institution” and “business of the institution.” for “business of the institution, and—”, added par. (2), and struck out former pars. (1) and (2) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) during the 5-year period beginning on ","children":[{"tag":"date","attrib":{"date":"1988-01-06"},"text":"January 6, 1988","children":[],"tail":", the Assistance Board shall direct the Financial Assistance Corporation to provide the receiver with sufficient funds to enable the receiver to carry out this subsection; and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) after such 5-year period, the Farm Credit System Insurance Corporation shall provide the receiver with sufficient funds from the Farm Credit Insurance Fund to enable the receiver to carry out this subsection.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s101/b"},"text":"Pub. L. 100–399, § 101(b)","children":[],"tail":", struck out provision that an institution whose capital stock is impaired coordinate retirement of stock under this section with the activities of the Assistance Board and the Financial Assistance Corporation."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s101/c"},"text":"Pub. L. 100–399, § 101(c)","children":[],"tail":", inserted “stock” in subsec. heading and amended text generally. Prior to amendment, text read as follows: “If an institution is unable to retire eligible borrower stock at par value due to the freezing of such stock during a liquidation of the institution, the receiver of the institution shall retire such stock at par value as would have been retired in the ordinary course of business of the institution and the Financial Assistance Corporation, on request of the Assistance Board, shall provide the receiver with sufficient funds to enable the receiver to carry out this subsection.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s101/d"},"text":"Pub. L. 100–399, § 101(d)","children":[],"tail":", in introductory provision substituted “issued or allocated” for “required to be purchased, and is purchased, as a condition of obtaining a loan made” and in cl. (i) substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2154a"},"text":"section 2154a of this title","children":[],"tail":"” for “section 4.9B”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcc8be18-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcc8be19-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399"},"text":"Pub. L. 100–399","children":[],"tail":" effective as if enacted immediately after enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/100/233"},"text":"Pub. L. 100–233","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/s1001/a"},"text":"section 1001(a) of Pub. L. 100–399","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2002"},"text":"section 2002 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
