{"tag":"section","attrib":{"id":"iddd1c3579-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4142"},"text":null,"children":[{"tag":"num","attrib":{"value":"4142"},"text":"§ 4142.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of this subchapter are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd1c357a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4142/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote the ability of residents of eligible low-income housing to meaningfully participate in the preservation process established by this title ","children":[{"tag":"ref","attrib":{"idref":"fn002378"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002378"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and affect decisions about the future of their housing;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1c357b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4142/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote the ability of community-based nonprofit housing developers and resident councils to acquire, rehabilitate, and competently own and manage eligible housing as rental or cooperative housing for low- and moderate-income people; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1c357c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4142/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist the Secretary in discharging the obligation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4110"},"text":"section 4110 of this title","children":[],"tail":" to notify potential qualified purchasers of the availability of properties for sale and to otherwise facilitate the coordination and oversight of the preservation program established under this title."},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd1c357d-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/242/tII/s252"},"text":"Pub. L. 100–242, title II, § 252","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tIII/s312"},"text":"Pub. L. 102–550, title III, § 312","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3766"},"text":"106 Stat. 3766","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd1c357e-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd1c357f-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd1c3580-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This title, referred to in pars. (1) and (3), means title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/242"},"text":"Pub. L. 100–242","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/101/625/tVI/s601/a"},"text":"Pub. L. 101–625, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4249"},"text":"104 Stat. 4249","children":[],"tail":", known as the Low-Income Housing Preservation and Resident Homeownership Act of 1990, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4101"},"text":"section 4101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
