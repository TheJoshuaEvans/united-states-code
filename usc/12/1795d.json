{"tag":"section","attrib":{"id":"iddc5b07bc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1795d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1795d"},"text":"§ 1795d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capital stock","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc5b07bd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1795d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Opening of books; minimum subscription","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As soon as practicable, the Board shall open books for subscriptions to the capital stock of the Facility. The minimum subscription shall be $50.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc5b07be-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1795d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The capital stock of the Facility—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc5b07bf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1795d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be divided into shares having a par value of $50 each;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc5b07c0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1795d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be paid for with cash or with securities of the United States or any Agency thereof in accordance with requirements the Board may impose;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc5b07c1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1795d/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall share in dividend distributions at rates determined by the Board. However, rates on the required capital stock shall be without preference; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc5b07c2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1795d/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be transferred or hypothecated except as provided for herein.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc5b07c3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1795d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Redemption of stock","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"When circumstances require that all or a portion of a member’s stock be redeemed by the Facility, the Board shall pay an amount equal to what the member originally paid for the stock less any amount owed by the member to the Facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc5b07c4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1795d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of subscription amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At least one-half of the payment for the subscription amount required for membership under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1795c"},"text":"section 1795c of this title","children":[],"tail":" shall be transferred to the Facility. The remainder may be held by the member on call of the Board and shall be invested in assets designated by the Board."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc5b07c5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1795d/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction on advances to credit unions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A credit union or credit union group that becomes a member of the Facility later than six months after the date the Board opens books for capital stock subscriptions, may not borrow or receive advances from the Facility without approval by the Board for a period of six months after becoming a member.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc5b07c6-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-26/ch750"},"text":"June 26, 1934, ch. 750","children":[],"tail":", title III, formerly subch. III, § 305, as added and amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/630/tV/s502/b"},"text":"Pub. L. 95–630, title V, § 502(b)","children":[],"tail":", title XVIII, § 1802, "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3681"},"text":"92 Stat. 3681","children":[],"tail":", 3721; "},{"tag":"ref","attrib":{"href":"/us/pl/96/221/tIII/s309/a/2"},"text":"Pub. L. 96–221, title III, § 309(a)(2)","children":[],"tail":", (4), (b)(1), "},{"tag":"date","attrib":{"date":"1980-03-31"},"text":"Mar. 31, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/148"},"text":"94 Stat. 148","children":[],"tail":", 149.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc5b07c7-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc5b07c8-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddc5b07c9-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/221/s309/b/1"},"text":"Section 309(b)(1) of Pub. L. 96–221","children":[],"tail":" redesignated subch. III as title III of "},{"tag":"ref","attrib":{"href":"/us/act/1934-06-26/ch750"},"text":"act June 26, 1934, ch. 750","children":[],"tail":", cited as a credit to this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc5b07ca-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/221/s309/a/4"},"text":"Pub. L. 96–221, § 309(a)(4)","children":[],"tail":", substituted “Board” for “Administrator”, such change having been previously made by "},{"tag":"ref","attrib":{"href":"/us/pl/95/630"},"text":"Pub. L. 95–630","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/221/s309/a/2"},"text":"Pub. L. 96–221, § 309(a)(2)","children":[],"tail":", (4), substituted “Board” for “Administrator” wherever appearing, such change having been previously made by "},{"tag":"ref","attrib":{"href":"/us/pl/95/630"},"text":"Pub. L. 95–630","children":[],"tail":", and in par. (3) inserted specific requirement that rates on required capital stock be without preference."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/221/s309/a/4"},"text":"Pub. L. 96–221, § 309(a)(4)","children":[],"tail":", substituted “Board” for “Administrator” wherever appearing, such change having been previously made by "},{"tag":"ref","attrib":{"href":"/us/pl/95/630"},"text":"Pub. L. 95–630","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/630/s502/b"},"text":"Pub. L. 95–630, § 502(b)","children":[],"tail":", substituted “Board” for “Administrator” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc5b07cb-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddc5b07cc-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment effective on expiration of 120 days after ","children":[{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", and transitional provisions, see "},{"tag":"ref","attrib":{"href":"/us/pl/95/630/s509"},"text":"section 509 of Pub. L. 95–630","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1752"},"text":"section 1752 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddc5b07cd-3a6f-