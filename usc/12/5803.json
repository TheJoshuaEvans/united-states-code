{"tag":"section","attrib":{"id":"iddd804e3b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5803"},"text":null,"children":[{"tag":"num","attrib":{"value":"5803"},"text":"§ 5803.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" LIBOR contracts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd804e3c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5803/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On the LIBOR replacement date, the Board-selected benchmark replacement shall be the benchmark replacement for any LIBOR contract that, after giving any effect to subsection (b)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd804e3d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5803/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains no fallback provisions; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd804e3e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5803/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" contains fallback provisions that identify neither—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd804e3f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5803/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a specific benchmark replacement; nor","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd804e40-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5803/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a determining person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd804e41-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5803/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fallback provisions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On the LIBOR replacement date, any reference in the fallback provisions of a LIBOR contract to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd804e42-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5803/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a benchmark replacement that is based in any way on any LIBOR value, except to account for the difference between LIBOR and the benchmark replacement; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd804e43-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5803/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a requirement that a person (other than a benchmark administrator) conduct a poll, survey, or inquiries for quotes or information concerning interbank lending or deposit rates;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be disregarded as if not included in the fallback provisions of such LIBOR contract and shall be deemed null and void and without any force or effect.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd804e44-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5803/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of determining person","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd804e45-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5803/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (f)(2), a determining person may select the Board-selected benchmark replacement as the benchmark replacement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd804e46-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5803/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any selection by a determining person of the Board-selected benchmark replacement pursuant to paragraph (1) shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd804e47-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5803/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" irrevocable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd804e48-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5803/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made by the earlier of the LIBOR replacement date and the latest date for selecting a benchmark replacement according to the terms of the LIBOR contract; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd804e49-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5803/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" used in any determinations of the benchmark under or with respect to the LIBOR contract occurring on and after the LIBOR replacement date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd804e4a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5803/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No selection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a determining person does not select a benchmark replacement by the date specified in paragraph (2)(B), the Board-selected benchmark replacement, on and after the LIBOR replacement date, shall be the benchmark replacement for the LIBOR contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd804e4b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5803/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conforming changes","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd804e4c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5803/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Board-selected benchmark replacement becomes the benchmark replacement for a LIBOR contract pursuant to subsection (a) or (c), all benchmark replacement conforming changes shall become an integral part of the LIBOR contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd804e4d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5803/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No consent required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A calculating person shall not be required to obtain consent from any other person prior to the adoption of benchmark replacement conforming changes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd804e4e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5803/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment by Board","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd804e4f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5803/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), on the LIBOR replacement date, the Board shall adjust the Board-selected benchmark replacement for each category of LIBOR contract that the Board may identify to include the relevant tenor spread adjustment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd804e50-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5803/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consumer loans","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For LIBOR contracts that are consumer loans, the Board shall adjust the Board-selected benchmark replacement as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd804e51-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5803/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" During the 1-year period beginning on the LIBOR replacement date, incorporate an amount, to be determined for any business day during that period, that transitions linearly from the difference between the Board-selected benchmark replacement and the corresponding LIBOR tenor determined as of the day immediately before the LIBOR replacement date to the relevant tenor spread adjustment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd804e52-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5803/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" On and after the date that is 1 year after the LIBOR replacement date, incorporate the relevant tenor spread adjustment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd804e53-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5803/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this chapter may be construed to alter or impair—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd804e54-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5803/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any written agreement specifying that a LIBOR contract shall not be subject to this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd804e55-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5803/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in subsection (b), any LIBOR contract that contains fallback provisions that identify a benchmark replacement that is not based in any way on any LIBOR value (including the prime rate or the effective Federal funds rate);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd804e56-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5803/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in subsection (b) or (c)(3), any LIBOR contract subject to subsection (c)(1) as to which a determining person does not elect to use a Board-selected benchmark replacement pursuant to that subsection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd804e57-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5803/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the application to a Board-selected benchmark replacement of any cap, floor, modifier, or spread adjustment to which LIBOR had been subject pursuant to the terms of a LIBOR contract;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd804e58-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5803/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any provision of Federal consumer financial law that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd804e59-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5803/f/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requires creditors to notify borrowers regarding a change-in-terms; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd804e5a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5803/f/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" governs the reevaluation of rate increases on credit card accounts under open-ended (not home-secured) consumer credit plans; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd804e5b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5803/f/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5804/c"},"text":"section 5804(c) of this title","children":[],"tail":", the rights or obligations of any person, or the authorities of any agency, under Federal consumer financial law, as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5481"},"text":"section 5481 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd804e5c-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/dU/s104"},"text":"Pub. L. 117–103, div. U, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/828"},"text":"136 Stat. 828","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd804e5d-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd804e5e-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd804e5f-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (f), was in the original “this division”, meaning div. U of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103"},"text":"Pub. L. 117–103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/825"},"text":"136 Stat. 825","children":[],"tail":", known as the Adjustable Interest Rate (LIBOR) Act, which is classified principally to this chapter. For complete classification of div. U to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5801"},"text":"section 5801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
