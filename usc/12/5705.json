{"tag":"section","attrib":{"id":"iddd7e04ae-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5705"},"text":null,"children":[{"tag":"num","attrib":{"value":"5705"},"text":"§ 5705.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approving collateral support and other innovative credit access and guarantee initiatives for small businesses and manufacturers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd7e04af-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5705/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A participating State that establishes a new, or has an existing, credit support program that meets the eligibility criteria in subsection (c) may apply to the Secretary to have the State other credit support program approved as eligible for Federal contributions to, or for the account of, the State program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd7e04b0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5705/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall approve such State other credit support program as eligible for Federal contributions to, or for the account of, the program if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd7e04b1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5705/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines that the State satisfies the requirements of paragraphs (1) through (3) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5704/b"},"text":"section 5704(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e04b2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5705/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines that the State other credit support program meets the eligibility criteria in subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e04b3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5705/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines the State other credit support program to be eligible based on the additional considerations in subsection (d); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e04b4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5705/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within 9 months after ","children":[{"tag":"date","attrib":{"date":"2021-03-11"},"text":"March 11, 2021","children":[],"tail":", the State has filed with Treasury a complete application for Treasury approval."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd7e04b5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5705/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility criteria for State other credit support programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For a State other credit support program to be approved under this section, that program shall be required to be a program of the State that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd7e04b6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5705/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" can demonstrate that, at a minimum, $1 of public investment by the State program will cause and result in $1 of new private credit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e04b7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5705/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" can demonstrate a reasonable expectation that, when considered with all other State programs of the State, such State programs together have the ability to use amounts of new Federal contributions to, or for the account of, all such programs in the State to cause and result in amounts of new small business lending at least 10 times the new Federal contribution amount;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e04b8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5705/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for those State other credit support programs that provide their credit support through 1 or more financial institution lenders, requires the financial institution lenders to have a meaningful amount of their own capital resources at risk in their small business lending; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e04b9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5705/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" uses Federal funds allocated under this chapter to extend credit support that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd7e04ba-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5705/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" targets an average borrower size of 500 employees or less;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7e04bb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5705/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not extend credit support to borrowers that have more than 750 employees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7e04bc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5705/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" targets support towards loans with an average principal amount of $5,000,000 or less; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7e04bd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5705/c/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not extend credit support to loans that exceed a principal amount of $20,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd7e04be-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5705/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making a determination that a State other credit support program is eligible for Federal contributions to, or for the account of, the State program, the Secretary shall take into account the following additional considerations:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd7e04bf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5705/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The anticipated benefits to the State, its businesses, and its residents to be derived from the Federal contributions to, or for the account of, the approved State other credit support program, including the extent to which resulting small business lending will expand economic opportunities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e04c0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5705/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The operational capacity, skills, and experience of the management team of the State other credit support program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e04c1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5705/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The capacity of the State other credit support program to manage increases in the volume of its small business lending.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e04c2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5705/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The internal accounting and administrative controls systems of the State other credit support program, and the extent to which they can provide reasonable assurance that funds of the State program are safeguarded against waste, loss, unauthorized use, or misappropriation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e04c3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5705/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The soundness of the program design and implementation plan of the State other credit support program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd7e04c4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5705/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal contributions to approved State other credit support programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State other credit support program approved under this section will be eligible for receiving Federal contributions to, or for the account of, the State program in an amount consistent with the schedule describing the apportionment of allocated Federal funds among State programs delivered by the State to the Secretary under the allocation agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd7e04c5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5705/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum Program Requirements for State other credit support programs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd7e04c6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5705/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fund ","children":[{"tag":"ref","attrib":{"idref":"fn002545"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002545"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Secretary”."}],"tail":" to prescribe"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, by regulation or other guidance, prescribe Program requirements for approved State other credit support programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e04c7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5705/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations for fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In prescribing minimum Program requirements for approved State other credit support programs, the Secretary shall take into consideration, to the extent the Secretary determines applicable and appropriate, the minimum Program requirements for approved State capital access programs in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5704/e"},"text":"section 5704(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd7e04c8-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/240/tIII/s3006"},"text":"Pub. L. 111–240, title III, § 3006","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-09-27"},"text":"Sept. 27, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2577"},"text":"124 Stat. 2577","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/2/tIII/s3301/a/1/D"},"text":"Pub. L. 117–2, title III, § 3301(a)(1)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-03-11"},"text":"Mar. 11, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/69"},"text":"135 Stat. 69","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd7e04c9-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd7e04ca-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd7e04cb-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2"},"text":"Pub. L. 117–2","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2021-03-11"},"text":"March 11, 2021","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2010-09-27"},"text":"September 27, 2010","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd7e04cc-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd7e04cd-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2"},"text":"Pub. L. 117–2","children":[],"tail":" applicable with respect to funds appropriated under "},{"tag":"ref","attrib":{"href":"/us/pl/117/2/s3301"},"text":"section 3301 of Pub. L. 117–2","children":[],"tail":" and funds appropriated on and after "},{"tag":"date","attrib":{"date":"2021-03-11"},"text":"Mar. 11, 2021","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/2/s3301/g"},"text":"section 3301(g) of Pub. L. 117–2","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5701"},"text":"section 5701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
