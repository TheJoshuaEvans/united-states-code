{"tag":"section","attrib":{"id":"iddcfd3b68-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3042"},"text":null,"children":[{"tag":"num","attrib":{"value":"3042"},"text":"§ 3042.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations for advances; deposits into separate Account in Bank; availability of amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are hereby authorized to be appropriated to the Office for the purpose of making advances under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s3043"},"text":"section 3043 of this title","children":[],"tail":" an amount not to exceed $14,000,000 for fiscal year 1982. Any amounts appropriated to the Office shall be deposited by the Office in a separate account in the Bank (hereinafter the “Account”), and shall remain available until expended. Repayments of capital investment advances made pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s3043/a"},"text":"section 3043(a) of this title","children":[],"tail":" and interest supplement advances made pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s3043/b"},"text":"section 3043(b) of this title","children":[],"tail":" and payments of interest thereon pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s3043/c"},"text":"section 3043(c) of this title","children":[],"tail":" shall also be deposited in the Account. No other funds of the Bank shall be transferred into the Account. The Account shall be used by the Office only as authorized in "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s3043"},"text":"section 3043 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddcfd3b69-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/351/tII/s202"},"text":"Pub. L. 95–351, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-08-20"},"text":"Aug. 20, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/511"},"text":"92 Stat. 511","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tIII/s395/b/1"},"text":"Pub. L. 97–35, title III, § 395(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/438"},"text":"95 Stat. 438","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcfd3b6a-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcfd3b6b-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcfd3b6c-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1981—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":" substituted provisions authorizing appropriations for fiscal year 1982, for provisions authorizing appropriations for the fiscal year ending "},{"tag":"date","attrib":{"date":"1979-09-30"},"text":"Sept. 30, 1979","children":[],"tail":", and the next two succeeding fiscal years."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcfd3b6d-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcfd3b6e-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1981 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1981-10-01"},"text":"Oct. 1, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/s395/b/3"},"text":"section 395(b)(3) of Pub. L. 97–35","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s3014"},"text":"section 3014 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
