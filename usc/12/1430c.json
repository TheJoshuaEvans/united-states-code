{"tag":"section","attrib":{"id":"iddb73b568-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1430c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1430c"},"text":"§ 1430c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Housing goals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddb73b569-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1430c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall establish housing goals with respect to the purchase of mortgages, if any, by the Federal Home Loan Banks. Such goals shall be consistent with the goals established under sections 4561 through 4564 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb73b56a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1430c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In establishing the goals required by subsection (a), the Director shall consider the unique mission and ownership structure of the Federal Home Loan Banks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb73b56b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1430c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transition period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To facilitate an orderly transition, the Director shall establish interim target goals for purposes of this section for each of the 2 calendar years following ","children":[{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb73b56c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1430c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring and enforcement of goals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirements of section 4566 ","children":[{"tag":"ref","attrib":{"idref":"fn002069"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002069"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title, shall apply to this section, in the same manner and to the same extent as that section applies to the Federal housing enterprises."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb73b56d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1430c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall annually report to Congress on the performance of the Banks in meeting the goals established under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddb73b56e-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1932-07-22/ch522/s10C"},"text":"July 22, 1932, ch. 522, § 10C","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tII/s1205"},"text":"Pub. L. 110–289, div. A, title II, § 1205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2786"},"text":"122 Stat. 2786","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb73b56f-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb73b570-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddb73b571-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4566"},"text":"Section 4566 of this title","children":[],"tail":", referred to in subsec. (d), was in the original “section 1336 of the Federal Housing Enterprises Safety and Soundness Act of 1992”, which was translated as meaning section 1336 of the Federal Housing Enterprises Financial Safety and Soundness Act of 1992, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
