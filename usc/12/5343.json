{"tag":"section","attrib":{"id":"iddd556e2c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5343"},"text":null,"children":[{"tag":"num","attrib":{"value":"5343"},"text":"§ 5343.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose and duties of the Office","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd556e2d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5343/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose and duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purpose of the Office is to support the Council in fulfilling the purposes and duties of the Council, as set forth in part A, and to support member agencies, by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd556e2e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5343/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collecting data on behalf of the Council, and providing such data to the Council and member agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd556e2f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5343/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" standardizing the types and formats of data reported and collected;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd556e30-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5343/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performing applied research and essential long-term research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd556e31-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5343/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing tools for risk measurement and monitoring;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd556e32-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5343/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performing other related services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd556e33-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5343/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making the results of the activities of the Office available to financial regulatory agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd556e34-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5343/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisting such member agencies in determining the types and formats of data authorized by this Act to be collected by such member agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd556e35-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5343/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Office may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd556e36-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5343/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" share data and information, including software developed by the Office, with the Council, member agencies, and the Bureau of Economic Analysis, which shared data, information, and software—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd556e37-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5343/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be maintained with at least the same level of security as is used by the Office; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd556e38-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5343/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not be shared with any individual or entity without the permission of the Council;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd556e39-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5343/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sponsor and conduct research projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd556e3a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5343/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist, on a reimbursable basis, with financial analyses undertaken at the request of other Federal agencies that are not member agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd556e3b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5343/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rulemaking authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd556e3c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5343/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office, in consultation with the Chairperson, shall issue rules, regulations, and orders only to the extent necessary to carry out the purposes and duties described in paragraphs (1), (2), and (7) of subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd556e3d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5343/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standardization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Member agencies, in consultation with the Office, shall implement regulations promulgated by the Office under paragraph (1) to standardize the types and formats of data reported and collected on behalf of the Council, as described in subsection (a)(2). If a member agency fails to implement such regulations prior to the expiration of the 3-year period following the date of publication of final regulations, the Office, in consultation with the Chairperson, may implement such regulations with respect to the financial entities under the jurisdiction of the member agency. This paragraph shall not supersede or interfere with the independent authority of a member agency under other law to collect data, in such format and manner as the member agency requires.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd556e3e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5343/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Testimony","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd556e3f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5343/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Office shall report to and testify before the Committee on Banking, Housing, and Urban Affairs of the Senate and the Committee on Financial Services of the House of Representatives annually on the activities of the Office, including the work of the Data Center and the Research and Analysis Center, and the assessment of the Office of significant financial market developments and potential emerging threats to the financial stability of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd556e40-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5343/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No prior review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No officer or agency of the United States shall have any authority to require the Director to submit the testimony required under paragraph (1) or other congressional testimony to any officer or agency of the United States for approval, comment, or review prior to the submission of such testimony. Any such testimony to Congress shall include a statement that the views expressed therein are those of the Director and do not necessarily represent the views of the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd556e41-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5343/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may provide additional reports to Congress concerning the financial stability of the United States. The Director shall notify the Council of any such additional reports provided to Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd556e42-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5343/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subpoena","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd556e43-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5343/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director may require from a financial company, by subpoena, the production of the data requested under subsection (a)(1) and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5344/b/1"},"text":"section 5344(b)(1) of this title","children":[],"tail":", but only upon a written finding by the Director that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd556e44-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5343/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such data is required to carry out the functions described under this part; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd556e45-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5343/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office has coordinated with the relevant primary financial regulatory agency, as required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5344/b/1/B/ii"},"text":"section 5344(b)(1)(B)(ii) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd556e46-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5343/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Format","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subpoenas under paragraph (1) shall bear the signature of the Director, and shall be served by any person or class of persons designated by the Director for that purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd556e47-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5343/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of contumacy or failure to obey a subpoena, the subpoena shall be enforceable by order of any appropriate district court of the United States. Any failure to obey the order of the court may be punished by the court as a contempt of court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd556e48-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tI/s153"},"text":"Pub. L. 111–203, title I, § 153","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1415"},"text":"124 Stat. 1415","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd556e49-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd556e4a-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd556e4b-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (a)(7), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1376"},"text":"124 Stat. 1376","children":[],"tail":", known as the Dodd-Frank Wall Street Reform and Consumer Protection Act, which enacted this chapter and chapters 108 (§ 8201 et seq.) and 109 (§ 8301 et seq.) of Title 15, Commerce and Trade, and enacted, amended, and repealed numerous other sections and notes in the Code. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
