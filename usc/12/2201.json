{"tag":"section","attrib":{"id":"iddcc8be59-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2201"},"text":null,"children":[{"tag":"num","attrib":{"value":"2201"},"text":"§ 2201.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of action on application","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcc8be5a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2201/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan applications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each qualified lender to which a person has applied for a loan shall provide the person with prompt written notice of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcc8be5b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2201/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the action on the application;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc8be5c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2201/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the loan applied for is reduced or denied, the reasons for such action; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc8be5d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2201/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant’s right to review under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2202"},"text":"section 2202 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcc8be5e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2201/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distressed loans","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each qualified lender that has a distressed loan outstanding that is subject to restructuring requirements under this chapter shall provide, in accordance with regulations prescribed by the Farm Credit Administration, the borrower with prompt written notice of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcc8be5f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2201/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any action taken with respect to restructuring the loan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2202a"},"text":"section 2202a of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc8be60-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2201/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if restructuring is denied, the reasons for such action; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc8be61-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2201/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the borrower’s right to review under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2202"},"text":"section 2202 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcc8be62-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tIV/s4"},"text":"Pub. L. 92–181, title IV, § 4","children":[],"tail":".13B, formerly § 4.13, "},{"tag":"date","attrib":{"date":"1971-12-10"},"text":"Dec. 10, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/613"},"text":"85 Stat. 613","children":[],"tail":", renumbered § 4.13B and amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/205/tIII"},"text":"Pub. L. 99–205, title III","children":[],"tail":", §§ 301(a), 302, "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1707"},"text":"99 Stat. 1707","children":[],"tail":", 1708; "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tI/s105"},"text":"Pub. L. 100–233, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1579"},"text":"101 Stat. 1579","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcc8be63-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcc8be64-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcc8be65-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/233"},"text":"Pub. L. 100–233","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “Every applicant for a loan from an institution of the System shall be entitled to prompt written notice of action on his application, and, if the loan applied for is reduced or denied, the reason for such action, and of the applicant’s right to review under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2202"},"text":"section 2202 of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/205/s302"},"text":"Pub. L. 99–205, § 302","children":[],"tail":", provided for a “written” notice and for the applicant’s right to review under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2202"},"text":"section 2202 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcc8be66-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcc8be67-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1985 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/205"},"text":"Pub. L. 99–205","children":[],"tail":" effective thirty days after "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/205/s401"},"text":"section 401 of Pub. L. 99–205","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2001"},"text":"section 2001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
