{"tag":"section","attrib":{"id":"iddd7e0465-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5703"},"text":null,"children":[{"tag":"num","attrib":{"value":"5703"},"text":"§ 5703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approving States for participation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd7e0466-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5703/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any State may apply to the Secretary for approval to be a participating State under the Program and to be eligible for an allocation of Federal funds under the Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd7e0467-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5703/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General approval criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall approve a State to be a participating State, if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd7e0468-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5703/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a specific department, agency, or political subdivision of the State has been designated to implement a State program and participate in the Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e0469-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5703/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all legal actions necessary to enable such designated department, agency, or political subdivision to implement a State program and participate in the Program have been accomplished;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e046a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5703/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State has filed an application with the Secretary for approval of a State capital access program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5704"},"text":"section 5704 of this title","children":[],"tail":" or approval as a State other credit support program under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5705"},"text":"section 5705 of this title","children":[],"tail":", in each case within the time period provided in the respective section; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e046b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5703/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the State and the Secretary have executed an allocation agreement that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd7e046c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5703/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conforms to the requirements of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7e046d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5703/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensures that the State program complies with such national standards as are established by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5708/a/2"},"text":"section 5708(a)(2) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7e046e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5703/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sets forth internal control, compliance, and reporting requirements as established by the Secretary, and such other terms and conditions necessary to carry out the purposes of this chapter, including an agreement by the State to allow the Secretary to audit State programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7e046f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5703/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requires that the State program be fully positioned, within 90 days of the State’s execution of the allocation agreement with the Secretary, to act on providing the kind of credit support that the State program was established to provide; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7e0470-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5703/b/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes an agreement by the State to deliver to the Secretary, and update annually, a schedule describing how the State intends to apportion among its State programs the Federal funds allocated to the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd7e0471-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5703/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contractual arrangements for implementation of State programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State may be approved to be a participating State, and be eligible for an allocation of Federal funds under the Program, if the State has contractual arrangements for the implementation and administration of its State program with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd7e0472-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5703/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an existing, approved State program administered by another State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e0473-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5703/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an authorized agent of, or entity supervised by, the State, including for-profit and not-for-profit entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd7e0474-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5703/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special permission","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd7e0475-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5703/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Circumstances when a municipality may apply directly","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a State does not, within 60 days after ","children":[{"tag":"date","attrib":{"date":"2021-03-11"},"text":"March 11, 2021","children":[],"tail":", file with the Secretary a notice of its intent to apply for approval by the Secretary of a State program or within 9 months after "},{"tag":"date","attrib":{"date":"2021-03-11"},"text":"March 11, 2021","children":[],"tail":", file with the Secretary a complete application for approval of a State program, the Secretary may grant to municipalities of that State a special permission that will allow them to apply directly to the Secretary without the State for approval to be participating municipalities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e0476-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5703/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing requirements applicable to municipalities applying directly","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To qualify for the special permission, a municipality of a State shall be required, within 12 months after ","children":[{"tag":"date","attrib":{"date":"2021-03-11"},"text":"March 11, 2021","children":[],"tail":", to file with the Secretary a complete application for approval by the Secretary of a State program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e0477-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5703/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notices of intent and applications from more than 1 municipality","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A municipality of a State may combine with 1 or more other municipalities of that State to file a joint notice of intent to file and a joint application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e0478-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5703/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The general approval criteria in paragraphs (2) and (4) shall apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e0479-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5703/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation to municipalities","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd7e047a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5703/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" If more than 3","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If more than 3 municipalities, or combination of municipalities as provided in paragraph (3), of a State apply for approval by the Secretary to be participating municipalities under this subsection, and the applications meet the approval criteria in paragraph (4), the Secretary shall allocate Federal funds to the 3 municipalities with the largest populations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7e047b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5703/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" If 3 or fewer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If 3 or fewer municipalities, or combination of municipalities as provided in paragraph (3), of a State apply for approval by the Secretary to be participating municipalities under this subsection, and the applications meet the approval criteria in paragraph (4), the Secretary shall allocate Federal funds to each applicant municipality or combination of municipalities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e047c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5703/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Apportionment of allocated amount among participating municipalities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary approves municipalities to be participating municipalities under this subsection, the Secretary shall apportion the full amount of the Federal funds that are allocated to that State to municipalities that are approved under this subsection in amounts proportionate to the population of those municipalities, based on the most recent available decennial census.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e047d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5703/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approving State programs for municipalities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary approves municipalities to be participating municipalities under this subsection, the Secretary shall take into account the additional considerations in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5705/d"},"text":"section 5705(d) of this title","children":[],"tail":" in making the determination under section 5704 or 5705 of this title that the State program or programs to be implemented by the participating municipalities, including a State capital access program, is eligible for Federal contributions to, or for the account of, the State program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd7e047e-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/240/tIII/s3004"},"text":"Pub. L. 111–240, title III, § 3004","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-09-27"},"text":"Sept. 27, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2573"},"text":"124 Stat. 2573","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/2/tIII/s3301/a/1/B"},"text":"Pub. L. 117–2, title III, § 3301(a)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-03-11"},"text":"Mar. 11, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/69"},"text":"135 Stat. 69","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd7e047f-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd7e0480-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd7e0481-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (d)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2"},"text":"Pub. L. 117–2","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2021-03-11"},"text":"March 11, 2021","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2010-09-27"},"text":"September 27, 2010","children":[],"tail":"” whenever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd7e0482-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd7e0483-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2"},"text":"Pub. L. 117–2","children":[],"tail":" applicable with respect to funds appropriated under "},{"tag":"ref","attrib":{"href":"/us/pl/117/2/s3301"},"text":"section 3301 of Pub. L. 117–2","children":[],"tail":" and funds appropriated on and after "},{"tag":"date","attrib":{"date":"2021-03-11"},"text":"Mar. 11, 2021","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/2/s3301/g"},"text":"section 3301(g) of Pub. L. 117–2","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5701"},"text":"section 5701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
