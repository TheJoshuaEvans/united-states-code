{"tag":"section","attrib":{"id":"iddccfe9d4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2257a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2257a"},"text":"§ 2257a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uniform financial reporting instructions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddccfe9d5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2257a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each System institution shall comply with uniform financial reporting instructions required by the Farm Credit Administration, to standardize and facilitate the reporting of System data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddccfe9d6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2257a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computerized system","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the financial reports are maintained by a computer system, each System institution may develop an internal computer system or it may contract out to a vendor under open competitive bidding any or all aspects of the computerized system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddccfe9d7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2257a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of proposal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within 6 months of ","children":[{"tag":"date","attrib":{"date":"1988-01-06"},"text":"January 6, 1988","children":[],"tail":", each System institution shall submit to the Farm Credit Administration a report on the plan of that institution to bring the operations of the institution into compliance with the uniform financial reporting instructions required by the Farm Credit Administration."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddccfe9d8-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tV/s5"},"text":"Pub. L. 92–181, title V, § 5","children":[],"tail":".22A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tIV/s429"},"text":"Pub. L. 100–233, title IV, § 429","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1658"},"text":"101 Stat. 1658","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
