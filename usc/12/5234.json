{"tag":"section","attrib":{"id":"iddd4e4291-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5234"},"text":null,"children":[{"tag":"num","attrib":{"value":"5234"},"text":"§ 5234.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation with the FBI","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any Federal financial regulatory agency shall cooperate with the Federal Bureau of Investigation and other law enforcement agencies investigating fraud, misrepresentation, and malfeasance with respect to development, advertising, and sale of financial products.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd4e4292-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/343/dA/tI/s127"},"text":"Pub. L. 110–343, div. A, title I, § 127","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3796"},"text":"122 Stat. 3796","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
