{"tag":"section","attrib":{"id":"iddb203dc9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s214c"},"text":null,"children":[{"tag":"num","attrib":{"value":"214c"},"text":"§ 214c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conversions in contravention of State law","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No conversion of a national banking association into a State bank or its merger or consolidation with a State bank shall take place under this subchapter and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s321"},"text":"section 321 of this title","children":[],"tail":" in contravention of the law of the State in which the national banking association is located; and no such conversion, merger, or consolidation shall take place under said sections unless under the law of the State in which such national banking association is located State banks may without approval by any State authority convert into and merge or consolidate with national banking associations under limitations or conditions no more restrictive than those contained in "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s214a"},"text":"section 214a of this title","children":[],"tail":" with respect to the conversion of a national bank into, or merger or consolidation of a national bank with, a State bank under State charter."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddb203dca-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-08-17/ch729/s4"},"text":"Aug. 17, 1950, ch. 729, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/456"},"text":"64 Stat. 456","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1952-07-12/ch696"},"text":"July 12, 1952, ch. 696","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/590"},"text":"66 Stat. 590","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1954-09-03/ch1263/s25"},"text":"Sept. 3, 1954, ch. 1263, § 25","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/1235"},"text":"68 Stat. 1235","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb203dcb-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb203dcc-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddb203dcd-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1954—Act ","children":[{"tag":"date","attrib":{"date":"1954-09-03"},"text":"Sept. 3, 1954","children":[],"tail":", substituted “this subchapter and "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s321"},"text":"section 321 of this title","children":[],"tail":"” for “sections 214 to 214c, 264(e)(2), (i)(2), (v)(4), and 321 of this title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1952—Act ","children":[{"tag":"date","attrib":{"date":"1952-07-12"},"text":"July 12, 1952","children":[],"tail":", amended section so that the limitation of this section beyond which State law cannot go will be measured by the standard set out in "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s214a"},"text":"section 214a of this title","children":[],"tail":" for National-to-State conversions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
