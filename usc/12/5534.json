{"tag":"section","attrib":{"id":"iddd7466ff-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5534"},"text":null,"children":[{"tag":"num","attrib":{"value":"5534"},"text":"§ 5534.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Response to consumer complaints and inquiries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd746700-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5534/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timely regulator response to consumers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Bureau shall establish, in consultation with the appropriate Federal regulatory agencies, reasonable procedures to provide a timely response to consumers, in writing where appropriate, to complaints against, or inquiries concerning, a covered person, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd746701-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5534/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" steps that have been taken by the regulator in response to the complaint or inquiry of the consumer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd746702-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5534/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any responses received by the regulator from the covered person; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd746703-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5534/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any follow-up actions or planned follow-up actions by the regulator in response to the complaint or inquiry of the consumer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd746704-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5534/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timely response to regulator by covered person","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A covered person subject to supervision and primary enforcement by the Bureau pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5515"},"text":"section 5515 of this title","children":[],"tail":" shall provide a timely response, in writing where appropriate, to the Bureau, the prudential regulators, and any other agency having jurisdiction over such covered person concerning a consumer complaint or inquiry, including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd746705-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5534/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" steps that have been taken by the covered person to respond to the complaint or inquiry of the consumer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd746706-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5534/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" responses received by the covered person from the consumer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd746707-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5534/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" follow-up actions or planned follow-up actions by the covered person to respond to the complaint or inquiry of the consumer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd746708-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5534/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of information to consumers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd746709-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5534/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A covered person subject to supervision and primary enforcement by the Bureau pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5515"},"text":"section 5515 of this title","children":[],"tail":" shall, in a timely manner, comply with a consumer request for information in the control or possession of such covered person concerning the consumer financial product or service that the consumer obtained from such covered person, including supporting written documentation, concerning the account of the consumer."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd74670a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5534/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A covered person subject to supervision and primary enforcement by the Bureau pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5515"},"text":"section 5515 of this title","children":[],"tail":", a prudential regulator, and any other agency having jurisdiction over a covered person subject to supervision and primary enforcement by the Bureau pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5515"},"text":"section 5515 of this title","children":[],"tail":" may not be required by this section to make available to the consumer—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd74670b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5534/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any confidential commercial information, including an algorithm used to derive credit scores or other risk scores or predictors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd74670c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5534/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any information collected by the covered person for the purpose of preventing fraud or money laundering, or detecting or making any report regarding other unlawful or potentially unlawful conduct;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd74670d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5534/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any information required to be kept confidential by any other provision of law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd74670e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5534/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any nonpublic or confidential information, including confidential supervisory information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd74670f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5534/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements with other agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Bureau shall enter into a memorandum of understanding with any affected Federal regulatory agency regarding procedures by which any covered person, and the prudential regulators, and any other agency having jurisdiction over a covered person, including the Secretary of the Department of Housing and Urban Development and the Secretary of Education, shall comply with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd746710-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1034"},"text":"Pub. L. 111–203, title X, § 1034","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2008"},"text":"124 Stat. 2008","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd746711-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd746712-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd746713-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the designated transfer date, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1037"},"text":"section 1037 of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5531"},"text":"section 5531 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
