{"tag":"section","attrib":{"id":"iddd1e7f26-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4221"},"text":null,"children":[{"tag":"num","attrib":{"value":"4221"},"text":"§ 4221.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Filing of confidential declarations by private persons identifying specific assets","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd1e7f27-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4221/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After the United States obtains a final judgment or settlement in any action referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4201"},"text":"section 4201 of this title","children":[],"tail":", any person may file a declaration identifying specific assets which might be recovered by the United States in satisfaction of that judgment or settlement."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1e7f28-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4221/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Place of filing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A declaration under subsection (a) shall be filed with the Attorney General of the United States or with an agent designated by him for receiving declarations under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd1e7f29-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXV/s2576"},"text":"Pub. L. 101–647, title XXV, § 2576","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4899"},"text":"104 Stat. 4899","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
