{"tag":"section","attrib":{"id":"iddb631371-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635n"},"text":null,"children":[{"tag":"num","attrib":{"value":"635n"},"text":"§ 635n.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of loans, guarantees, and insurance as to sales of defense articles or services","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Bank shall not extend loans, guarantees, or insurance under this subchapter in connection with the sale of defense articles or defense services.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddb631372-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/390/s5"},"text":"Pub. L. 90–390, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-07-07"},"text":"July 7, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/297"},"text":"82 Stat. 297","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
