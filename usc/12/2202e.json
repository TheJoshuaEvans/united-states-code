{"tag":"section","attrib":{"id":"iddccb07ce-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202e"},"text":null,"children":[{"tag":"num","attrib":{"value":"2202e"},"text":"§ 2202e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver of mediation rights by borrowers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No System institution may make a loan secured by a mortgage or lien on agricultural property to a borrower on the condition that the borrower waive any right under the mediation program of any State.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddccb07cf-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tIV/s4"},"text":"Pub. L. 92–181, title IV, § 4","children":[],"tail":".14E, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tV/s511"},"text":"Pub. L. 100–233, title V, § 511","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1664"},"text":"101 Stat. 1664","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s282/f/2"},"text":"Pub. L. 103–354, title II, § 282(f)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3235"},"text":"108 Stat. 3235","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddccb07d0-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddccb07d1-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddccb07d2-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354"},"text":"Pub. L. 103–354","children":[],"tail":" struck out “agricultural loan” before “mediation program”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
