{"tag":"section","attrib":{"id":"iddcc402a7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2123"},"text":null,"children":[{"tag":"num","attrib":{"value":"2123"},"text":"§ 2123.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board of directors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcc402a8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2123/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each bank for cooperatives shall elect a board of directors of such number, for such term, in such manner, and with such qualifications as may be required in its bylaws, except that at least one member shall be elected by the other directors, which member shall not be a director, officer, employee, or stockholder of a System institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcc402a9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2123/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nomination and election","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcc402aa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2123/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If approved by the stockholders through a bylaw amendment, the nomination and election of one member from a bank for cooperatives shall be carried out with each voting stockholder of a bank for cooperatives having one vote, plus a number of votes (or fractional part thereof) equal to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcc402ab-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2123/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of stockholders eligible to vote; multiplied by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcc402ac-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2123/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percentage (or fractional part thereof) of the total equity interest (including allocated, but not unallocated, surplus and reserves) in the bank of all stockholders held by the individual voting stockholder at the close of the immediately preceding fiscal year of the bank.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc402ad-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2123/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Number of votes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The total number of votes under this subsection shall be the number of voting stockholders of a bank for cooperatives multiplied by two.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcc402ae-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tIII/s3"},"text":"Pub. L. 92–181, title III, § 3","children":[],"tail":".2, "},{"tag":"date","attrib":{"date":"1971-12-10"},"text":"Dec. 10, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/603"},"text":"85 Stat. 603","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/205/tII/s205/e/2"},"text":"Pub. L. 99–205, title II, § 205(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1705"},"text":"99 Stat. 1705","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/tIX/s901/d"},"text":"Pub. L. 100–399, title IX, § 901(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-17"},"text":"Aug. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1007"},"text":"102 Stat. 1007","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/552/tV/s503"},"text":"Pub. L. 102–552, title V, § 503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4130"},"text":"106 Stat. 4130","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tV/s5411/5"},"text":"Pub. L. 115–334, title V, § 5411(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4679"},"text":"132 Stat. 4679","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcc402af-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcc402b0-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcc402b1-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s5411/5/B"},"text":"Pub. L. 115–334, § 5411(5)(B)","children":[],"tail":", (C), redesignated subsec. (a)(1) as (a) and subsec. (a)(2) as (b), inserted headings, and struck out former subsec. (b) which read as follows: “The board of directors of the Central Bank for Cooperatives shall consist of one member elected by the board of each bank for cooperatives, including the United Bank for Cooperatives if the Central Bank for Cooperatives is not merged into such bank, and one member appointed by the Farm Credit Administration.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s5411/5/A/i"},"text":"Pub. L. 115–334, § 5411(5)(A)(i)","children":[],"tail":", struck out “not merged into the United Bank for Cooperatives or the National Bank for Cooperatives” after “Each bank for cooperatives”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s5411/5/A/ii"},"text":"Pub. L. 115–334, § 5411(5)(A)(ii)","children":[],"tail":", struck out “(other than the National Bank for Cooperatives)” after “a bank for cooperatives” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s5411/5/C/ii"},"text":"Pub. L. 115–334, § 5411(5)(C)(ii)","children":[],"tail":", (D)(ii), redesignated subsec. (a)(2)(A) and cls. (i) and (ii) thereof as subsec. (b)(1) and subpars. (A) and (B) thereof, respectively, inserted par. heading, and realigned margins."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s5411/5/D/i"},"text":"Pub. L. 115–334, § 5411(5)(D)(i)","children":[],"tail":", (E), redesignated subsec. (a)(2)(B) as subsec. (b)(2), inserted heading, and substituted “this subsection” for “this paragraph”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/552"},"text":"Pub. L. 102–552","children":[],"tail":" designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399"},"text":"Pub. L. 100–399","children":[],"tail":" amended subsec. (a) generally. Prior to amendment, subsec. (a) read as follows: “In the case of a district bank for cooperatives, the board of directors shall be the farm credit district board and in the case of the Central Bank for Cooperatives shall be a separate board of not more than thirteen members, one from each farm credit district and one at large. One district director of the Central Bank Board shall be elected by each district farm credit board and the member at large shall be appointed by the Farm Credit Administration.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399"},"text":"Pub. L. 100–399","children":[],"tail":" amended subsec. (b) generally. Prior to amendment, subsec. (b) read as follows: “For the purposes of this section the provisions of sections 2222(b) and (c), 2225, 2226, and 2227 of this title shall apply to and shall be the authority of the Central Bank for Cooperatives the same as though it were a district bank.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/205"},"text":"Pub. L. 99–205","children":[],"tail":" substituted “Farm Credit Administration” for “Governor with the advice and consent of the Federal Farm Credit Board”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcc402b2-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcc402b3-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399"},"text":"Pub. L. 100–399","children":[],"tail":" effective immediately after amendment made by "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/s401"},"text":"section 401 of Pub. L. 100–233","children":[],"tail":", which was effective 6 months after "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/s1001/b"},"text":"section 1001(b) of Pub. L. 100–399","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2002"},"text":"section 2002 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcc402b4-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1985 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/205"},"text":"Pub. L. 99–205","children":[],"tail":" effective thirty days after "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/205/s401"},"text":"section 401 of Pub. L. 99–205","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2001"},"text":"section 2001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
