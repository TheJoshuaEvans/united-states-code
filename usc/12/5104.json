{"tag":"section","attrib":{"id":"iddd4715f6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5104"},"text":null,"children":[{"tag":"num","attrib":{"value":"5104"},"text":"§ 5104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State license and registration application and issuance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd4715f7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Background checks","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In connection with an application to any State for licensing and registration as a State-licensed loan originator, the applicant shall, at a minimum, furnish to the Nationwide Mortgage Licensing System and Registry information concerning the applicant’s identity, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd4715f8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5104/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fingerprints for submission to the Federal Bureau of Investigation, and any governmental agency or entity authorized to receive such information for a State and national criminal history background check; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4715f9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5104/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" personal history and experience, including authorization for the System to obtain—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd4715fa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5104/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an independent credit report obtained from a consumer reporting agency described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681a/p"},"text":"section 1681a(p) of title 15","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd4715fb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5104/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information related to any administrative, civil or criminal findings by any governmental jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd4715fc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance of license","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The minimum standards for licensing and registration as a State-licensed loan originator shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd4715fd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5104/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The applicant has never had a loan originator license revoked in any governmental jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4715fe-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5104/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The applicant has not been convicted of, or pled guilty or nolo contendere to, a felony in a domestic, foreign, or military court—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd4715ff-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5104/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the 7-year period preceding the date of the application for licensing and registration; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd471600-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5104/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at any time preceding such date of application, if such felony involved an act of fraud, dishonesty, or a breach of trust, or money laundering.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd471601-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5104/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The applicant has demonstrated financial responsibility, character, and general fitness such as to command the confidence of the community and to warrant a determination that the loan originator will operate honestly, fairly, and efficiently within the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd471602-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5104/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The applicant has completed the pre-licensing education requirement described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd471603-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5104/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The applicant has passed a written test that meets the test requirement described in subsection (d).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd471604-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5104/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The applicant has met either a net worth or surety bond requirement, or paid into a State fund, as required by the State pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5107/d/6"},"text":"section 5107(d)(6) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd471605-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5104/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pre-licensing education of loan originators","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd471606-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5104/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum educational requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to meet the pre-licensing education requirement referred to in subsection (b)(4), a person shall complete at least 20 hours of education approved in accordance with paragraph (2), which shall include at least—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd471607-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5104/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3 hours of Federal law and regulations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd471608-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5104/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3 hours of ethics, which shall include instruction on fraud, consumer protection, and fair lending issues; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd471609-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5104/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 hours of training related to lending standards for the nontraditional mortgage product marketplace.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd47160a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5104/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approved educational courses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraph (1), pre-licensing education courses shall be reviewed, and approved by the Nationwide Mortgage Licensing System and Registry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd47160b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5104/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation and standards","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd47160c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5104/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To maintain the independence of the approval process, the Nationwide Mortgage Licensing System and Registry shall not directly or indirectly offer pre-licensure educational courses for loan originators.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd47160d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5104/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In approving courses under this section, the Nationwide Mortgage Licensing System and Registry shall apply reasonable standards in the review and approval of courses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd47160e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5104/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Testing of loan originators","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd47160f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5104/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to meet the written test requirement referred to in subsection (b)(5), an individual shall pass, in accordance with the standards established under this subsection, a qualified written test developed by the Nationwide Mortgage Licensing System and Registry and administered by an approved test provider.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd471610-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5104/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified test","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A written test shall not be treated as a qualified written test for purposes of paragraph (1) unless the test adequately measures the applicant’s knowledge and comprehension in appropriate subject areas, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd471611-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5104/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ethics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd471612-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5104/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal law and regulation pertaining to mortgage origination;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd471613-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5104/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State law and regulation pertaining to mortgage origination;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd471614-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5104/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal and State law and regulation, including instruction on fraud, consumer protection, the nontraditional mortgage marketplace, and fair lending issues.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd471615-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5104/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum competence","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd471616-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5104/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Passing score","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual shall not be considered to have passed a qualified written test unless the individual achieves a test score of not less than 75 percent correct answers to questions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd471617-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5104/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial retests","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual may retake a test 3 consecutive times with each consecutive taking occurring at least 30 days after the preceding test.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd471618-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5104/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequent retests","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After failing 3 consecutive tests, an individual shall wait at least 6 months before taking the test again.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd471619-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5104/d/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retest after lapse of license","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State-licensed loan originator who fails to maintain a valid license for a period of 5 years or longer shall retake the test, not taking into account any time during which such individual is a registered loan originator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd47161a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5104/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mortgage call reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each mortgage licensee shall submit to the Nationwide Mortgage Licensing System and Registry reports of condition, which shall be in such form and shall contain such information as the Nationwide Mortgage Licensing System and Registry may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd47161b-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tV/s1505"},"text":"Pub. L. 110–289, div. A, title V, § 1505","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2814"},"text":"122 Stat. 2814","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
