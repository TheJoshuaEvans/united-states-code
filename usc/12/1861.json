{"tag":"section","attrib":{"id":"iddcb5ab65-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1861"},"text":null,"children":[{"tag":"num","attrib":{"value":"1861"},"text":"§ 1861.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short title and definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcb5ab66-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1861/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short title","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This chapter may be cited as the “Bank Service Company Act”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcb5ab67-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1861/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcb5ab68-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1861/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “appropriate Federal banking agency” shall have the meaning provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813/q"},"text":"section 1813(q) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb5ab69-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1861/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “bank service company” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcb5ab6a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1861/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any corporation—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddcb5ab6b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1861/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is organized to perform services authorized by this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcb5ab6c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1861/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all of the capital stock of which is owned by 1 or more insured depository institutions; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcb5ab6d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1861/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any limited liability company—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddcb5ab6e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1861/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is organized to perform services authorized by this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcb5ab6f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1861/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all of the members of which are 1 or more insured depository institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb5ab70-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1861/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Board” means the Board of Governors of the Federal Reserve System;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb5ab71-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1861/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “depository institution” means, except when such term appears in connection with the term “insured depository institution”, an insured bank, a savings association, a financial institution subject to examination by the appropriate Federal banking agency or the National Credit Union Administration Board, or a financial institution the accounts or deposits of which are insured or guaranteed under State law and are eligible to be insured by the Federal Deposit Insurance Corporation or the National Credit Union Administration Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb5ab72-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1861/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Insured depository institution","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The terms “depository institution” and “savings association” have the same meanings as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"section 1813 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb5ab73-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1861/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “invest” includes any advance of funds to a bank service company, whether by the purchase of stock, the making of a loan, or otherwise, except a payment for rent earned, goods sold and delivered, or services rendered prior to the making of such payment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb5ab74-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1861/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “limited liability company” means any company, partnership, trust, or similar business entity organized under the law of a State (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"section 1813 of this title","children":[],"tail":") which provides that a member or manager of such company is not personally liable for a debt, obligation, or liability of the company solely by reason of being, or acting as, a member or manager of such company;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb5ab75-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1861/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “principal investor” means the insured depository institution that has the largest dollar amount invested in the equity of a bank service company. In any case where two or more insured depository institutions have equal dollar amounts invested in a bank service company, the company shall, prior to commencing operations, select one of the insured depository institutions as its principal investor and shall notify the depository institution’s appropriate Federal banking agency of that choice within 5 business days of its selection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb5ab76-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1861/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms “State depository institution”, “Federal depository institution”, “State savings association” and “Federal savings association” have the same meanings as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"section 1813 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcb5ab77-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/856/s1"},"text":"Pub. L. 87–856, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-23"},"text":"Oct. 23, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/1132"},"text":"76 Stat. 1132","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/320/tVII/s709"},"text":"Pub. L. 97–320, title VII, § 709","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-15"},"text":"Oct. 15, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1540"},"text":"96 Stat. 1540","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/457/s32/a"},"text":"Pub. L. 97–457, § 32(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2511"},"text":"96 Stat. 2511","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tII/s2613/a"},"text":"Pub. L. 104–208, div. A, title II, § 2613(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-476"},"text":"110 Stat. 3009–476","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/351/tVI/s602/b/1"},"text":"Pub. L. 109–351, title VI, § 602(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-13"},"text":"Oct. 13, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1979"},"text":"120 Stat. 1979","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tIII/s357/1"},"text":"Pub. L. 111–203, title III, § 357(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1547"},"text":"124 Stat. 1547","children":[],"tail":", 1548.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcb5ab78-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcb5ab79-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcb5ab7a-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s357/1"},"text":"Pub. L. 111–203, § 357(1)","children":[],"tail":", inserted “a savings association,” after “an insured bank,”, substituted “appropriate Federal banking agency” for “Director of the Office of Thrift Supervision”, and struck out “, the Federal Savings and Loan Insurance Corporation,” after “Federal Deposit Insurance Corporation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s357/2"},"text":"Pub. L. 111–203, § 357(2)","children":[],"tail":", substituted “terms ‘depository institution’ and ‘savings association’ have the same meanings as in section 1813” for “term ‘insured depository institution’ has the same meaning as in section 1813(c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (b)(2)(A)(ii), (B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/351/s602/b/1/F"},"text":"Pub. L. 109–351, § 602(b)(1)(F)","children":[],"tail":", substituted “insured depository institutions” for “insured banks”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/351/s602/b/1/A"},"text":"Pub. L. 109–351, § 602(b)(1)(A)","children":[],"tail":", inserted “, except when such term appears in connection with the term ‘insured depository institution’,” after “means” and substituted “Director of the Office of Thrift Supervision” for “Federal Home Loan Bank Board”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/351/s602/b/1/B"},"text":"Pub. L. 109–351, § 602(b)(1)(B)","children":[],"tail":", added par. (5) and struck out former par. (5) which defined “insured bank”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/351/s602/b/1/G"},"text":"Pub. L. 109–351, § 602(b)(1)(G)","children":[],"tail":", substituted “means the insured depository institution” for “means the insured bank”, “insured depository institutions” for “insured banks” in two places, and “the depository institution’s appropriate” for “the bank’s appropriate”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/351/s602/b/1/C"},"text":"Pub. L. 109–351, § 602(b)(1)(C)","children":[],"tail":"–(E), added par. (9)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s2613/a"},"text":"Pub. L. 104–208, § 2613(a)","children":[],"tail":", inserted heading and amended text of subsec. (a) generally. Prior to amendment, text read as follows: “This chapter may be cited as the ‘Bank Service Corporation Act’.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s2613/b/1"},"text":"Pub. L. 104–208, § 2613(b)(1)","children":[],"tail":", amended par. (2) generally. Prior to amendment, par. (2) read as follows: “the term ‘bank service corporation’ means a corporation organized to perform services authorized by this chapter, all of the capital stock of which is owned by one or more insured banks;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s2613/b/2"},"text":"Pub. L. 104–208, § 2613(b)(2)","children":[],"tail":", substituted “company” for “corporation” and struck out “and” after semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s2613/b/3"},"text":"Pub. L. 104–208, § 2613(b)(3)","children":[],"tail":", added par. (7). Former par. (7) redesignated (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s2613/b/4"},"text":"Pub. L. 104–208, § 2613(b)(4)","children":[],"tail":", substituted “company” for “corporation” wherever appearing and “equity” for “capital stock”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s2613/b/3"},"text":"Pub. L. 104–208, § 2613(b)(3)","children":[],"tail":", redesignated par. (7) as (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/457"},"text":"Pub. L. 97–457","children":[],"tail":" substituted “a” for “or another” after “insured bank,” and inserted reference to a financial institution insured by State law and eligible to be insured by certain Federal agencies."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/320"},"text":"Pub. L. 97–320","children":[],"tail":" substituted provision that this chapter may be cited as the “Bank Service Corporation Act” for provision that term “Federal supervisory agency” meant the Comptroller of the Currency, the Board of Governors of the Federal Reserve System, or the Board of Directors of the Federal Deposit Insurance Corporation."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/320"},"text":"Pub. L. 97–320","children":[],"tail":" substituted definitions of “appropriate Federal banking agency”, “bank service corporation”, “Board”, “depository institution”, “insured bank”, “invest”, and “principal investor” for provision that term “bank services” meant services such as check and deposit sorting and posting, computation and posting of interest and other credits and charges, preparation and mailing of checks, statements, notices, and similar items, or any other clerical, bookkeeping, accounting, statistical, or similar functions performed for a bank."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/320"},"text":"Pub. L. 97–320","children":[],"tail":" redesignated provisions of subsec. (c) defining “bank service corporation” as (b)(2), and revised definition."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/320"},"text":"Pub. L. 97–320","children":[],"tail":" redesignated provisions of subsec. (d) as (b)(6)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcb5ab7b-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcb5ab7c-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective on the transfer date, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s351"},"text":"section 351 of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s906"},"text":"section 906 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
