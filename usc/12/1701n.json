{"tag":"section","attrib":{"id":"iddba37839-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701n"},"text":null,"children":[{"tag":"num","attrib":{"value":"1701n"},"text":"§ 1701n.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction of vulnerability of congested urban areas to enemy attack","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Department of Housing and Urban Development, and any other departments or agencies of the Federal Government having powers, functions, or duties with respect to housing under any law shall exercise such powers, functions, or duties in such manner as, consistent with the requirements thereof, will facilitate progress in the reduction of the vulnerability of congested urban areas to enemy attack.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddba3783a-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-02/ch649"},"text":"Aug. 2, 1954, ch. 649","children":[],"tail":", title VIII, § 811, "},{"tag":"ref","attrib":{"href":"/us/stat/68/646"},"text":"68 Stat. 646","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/19/s10/g"},"text":"Pub. L. 90–19, § 10(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-05-25"},"text":"May 25, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/23"},"text":"81 Stat. 23","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddba3783b-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddba3783c-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddba3783d-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Housing Act of 1954, and not as part of the National Housing Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddba3783e-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1967—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/19"},"text":"Pub. L. 90–19","children":[],"tail":" substituted “Department of Housing and Urban Development” for “Housing and Home Finance Agency, including its constituent agencies”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
