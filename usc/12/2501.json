{"tag":"section","attrib":{"id":"iddceee374-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2501"},"text":null,"children":[{"tag":"num","attrib":{"value":"2501"},"text":"§ 2501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional findings and declaration of purpose","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Congress finds and declares that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddceee375-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2501/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the books and records of banking and financial organizations and business associations engaged in issuing and selling money orders and traveler’s checks do not, as a matter of business practice, show the last known addresses of purchasers of such instruments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddceee376-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2501/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a substantial majority of such purchasers reside in the States where such instruments are purchased;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddceee377-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2501/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the States wherein the purchasers of money orders and traveler’s checks reside should, as a matter of equity among the several States, be entitled to the proceeds of such instruments in the event of abandonment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddceee378-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2501/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is a burden on interstate commerce that the proceeds of such instruments are not being distributed to the States entitled thereto; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddceee379-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2501/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of maintaining and retrieving addresses of purchasers of money orders and traveler’s checks is an additional burden on interstate commerce since it has been determined that most purchasers reside in the State of purchase of such instruments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddceee37a-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/495/tVI/s601"},"text":"Pub. L. 93–495, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-28"},"text":"Oct. 28, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1525"},"text":"88 Stat. 1525","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddceee37b-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddceee37c-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddceee37d-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Applicability to Sums Payable on Money Orders, Etc., Deemed Abandoned on or After ","children":[{"tag":"date","attrib":{"date":"1965-02-01"},"text":"February 1, 1965","children":[],"tail":"; Exception"}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/495/tVI/s604"},"text":"Pub. L. 93–495, title VI, § 604","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-28"},"text":"Oct. 28, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1526"},"text":"88 Stat. 1526","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/93/495/tVI/s604"},"text":"“This title [enacting this chapter] shall be applicable to sums payable on money orders, traveler’s checks, and similar written instruments deemed abandoned on or after ","children":[{"tag":"date","attrib":{"date":"1965-02-01"},"text":"February 1, 1965","children":[],"tail":", except to the extent that such sums have been paid over to a State prior to "},{"tag":"date","attrib":{"date":"1974-01-01"},"text":"January 1, 1974","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
