{"tag":"section","attrib":{"id":"iddcbcd6fc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2015"},"text":null,"children":[{"tag":"num","attrib":{"value":"2015"},"text":"§ 2015.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lending authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcbcd6fd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2015/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Real estate loans and related assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcbcd6fe-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2015/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Real estate loans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Farm Credit Banks may make or participate with other lenders in long-term real estate mortgage loans in rural areas, as defined by the Farm Credit Administration, or to producers or harvesters of aquatic products, and make continuing commitments to make such loans under specified circumstances, for a term of not less than 5 nor more than 40 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbcd6ff-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2015/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Farm Credit Banks may provide and extend financial assistance to, and discount for, or purchase from, a Federal land bank association any note, draft, or other obligation with the endorsement or guarantee of the association, the proceeds of which have been advanced to persons eligible and for purposes of financing by the association, as authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2279b/a"},"text":"section 2279b(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcbcd700-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2015/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intermediate credit","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcbcd701-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2015/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Farm Credit Banks are authorized to make loans and extend other similar financial assistance to and to discount for or purchase from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcbcd702-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2015/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any production credit association, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcbcd703-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2015/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any national bank, State bank, trust company, agricultural credit corporation, incorporated livestock loan company, savings institution, credit union, or any association of agricultural producers engaged in the making of loans to farmers and ranchers, and any corporation engaged in the making of loans to producers or harvesters of aquatic products,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"any note, draft, or other obligation with the institution’s endorsement or guarantee, the proceeds of which note, draft, or other obligation have been advanced to persons and for purposes eligible for financing by production credit associations as authorized by this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbf20f4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2015/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation with other entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Farm Credit Banks may participate with one or more production credit associations or other Farm Credit Banks in the making of loans to eligible borrowers and may participate with one or more other Farm Credit System institutions in loans made under this subchapter or other subchapters of this chapter on the basis prescribed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2206"},"text":"section 2206 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbf20f5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2015/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on extension of financial services","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcbf20f6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2015/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No paper shall be purchased from or discounted for, and no loans shall be made or other similar financial assistance extended by a Farm Credit Bank to any entity identified in paragraph (1)(B) of this subsection if the amount of such paper added to the aggregate liabilities of such entity, whether direct or contingent (other than bona fide deposit liabilities), exceeds ten times the paid-in and unimpaired capital and surplus of such entity or the amount of such liabilities permitted under the laws of the jurisdiction creating such institution, whichever is the lesser.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcbf20f7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2015/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on national bank","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall be unlawful for any national bank which is indebted to any Farm Credit Bank, on paper discounted or purchased under paragraph (1), to incur any additional indebtedness, if by virtue of such additional indebtedness its aggregate liabilities direct or contingent, will exceed the limitation described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbf20f8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2015/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" FCA regulations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcbf20f9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2015/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All of the loans, financial assistance, discounts and purchases authorized by this subsection shall be subject to regulations of the Farm Credit Administration and shall be secured by collateral, if any, as may be required in such regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcbf20fa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2015/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The regulations shall assure that such loans, financial assistance, discounts, and purchases are available on a reasonable basis to any financing institution authorized to receive such services under paragraph (1)(B) of this subsection, and that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddcbf20fb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2015/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is significantly involved in lending for agricultural or aquatic purposes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcbf20fc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2015/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrates a continuing need for supplementary sources of funds to meet the credit requirements of its agricultural or aquatic borrowers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcbf20fd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2015/b/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has limited access to national or regional capital markets; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcbf20fe-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2015/b/4/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not use such services to expand its financing activities to persons and for purposes other than those authorized under subchapter II.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcbf20ff-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2015/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The regulations may authorize a Farm Credit Bank to charge reasonable fees for any commitment to extend service under this section to such a financing institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcbf2100-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2015/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsidiaries and affiliates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, a financing institution together with the subsidiaries and affiliates of such may be considered as one, but such determination to consider such institution together with the subsidiaries and affiliates of such as one shall be made in the first instance by the bank and in the event of a denial by the bank of its services to a financial institution, then by the Farm Credit Administration on a case-by-case basis with due regard to the total relationship of the financing institution, its subsidiaries, and affiliates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbf2101-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2015/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall require termination of discount relationships in existence on ","children":[{"tag":"date","attrib":{"date":"1980-12-24"},"text":"December 24, 1980","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcbf2102-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tI/s1"},"text":"Pub. L. 92–181, title I, § 1","children":[],"tail":".7, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tIV/s401"},"text":"Pub. L. 100–233, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1625"},"text":"101 Stat. 1625","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/tIV/s401/e"},"text":"Pub. L. 100–399, title IV, § 401(e)","children":[],"tail":", (f), "},{"tag":"date","attrib":{"date":"1988-08-17"},"text":"Aug. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/995"},"text":"102 Stat. 995","children":[],"tail":", 996.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcbf2103-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcbf2104-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddcbf2105-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (b)(5), “","children":[{"tag":"date","attrib":{"date":"1980-12-24"},"text":"December 24, 1980","children":[],"tail":"” substituted for “the effective date of the Farm Credit Act Amendments of 1980”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"iddcbf2106-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2015, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tI/s1"},"text":"Pub. L. 92–181, title I, § 1","children":[],"tail":".7, "},{"tag":"date","attrib":{"date":"1971-12-10"},"text":"Dec. 10, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/585"},"text":"85 Stat. 585","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/592/tI/s104"},"text":"Pub. L. 96–592, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-24"},"text":"Dec. 24, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3438"},"text":"94 Stat. 3438","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/509/tI/s1033/a"},"text":"Pub. L. 99–509, title I, § 1033(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1877"},"text":"100 Stat. 1877","children":[],"tail":", related to interest rates and other charges, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/s401"},"text":"Pub. L. 100–233, § 401","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcbf2107-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s401/e"},"text":"Pub. L. 100–399, § 401(e)","children":[],"tail":", inserted in heading “and related assistance” and amended text generally. Prior to amendment, text read as follows: “The Farm Credit Banks are authorized to make or participate with other lenders in long-term real estate mortgage loans in rural areas, as defined by the Farm Credit Administration, or to producers or harvesters of aquatic products, and make continuing commitments to make such loans under specified circumstances, for a term of not less than 5 nor more than 40 years.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s401/f/1"},"text":"Pub. L. 100–399, § 401(f)(1)","children":[],"tail":", struck out provision that banks may own and lease or lease with an option to purchase to persons eligible for assistance under this subchapter, equipment needed in the operations of such persons."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s401/f/2"},"text":"Pub. L. 100–399, § 401(f)(2)","children":[],"tail":", substituted in heading “services” for “assistance” and in subpar. (B) “described in subparagraph (A)” for “herein contained”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s401/f/3"},"text":"Pub. L. 100–399, § 401(f)(3)","children":[],"tail":", substituted “subsection” for “section”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcbf2108-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcbf2109-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399"},"text":"Pub. L. 100–399","children":[],"tail":" effective immediately after amendment made by "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/s401"},"text":"section 401 of Pub. L. 100–233","children":[],"tail":", which was effective 6 months after "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/s1001/b"},"text":"section 1001(b) of Pub. L. 100–399","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2002"},"text":"section 2002 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddcbf210a-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/233/tIV/s401"},"text":"Pub. L. 100–233, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1622"},"text":"101 Stat. 1622","children":[],"tail":", provided that this section is effective 6 months after "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
