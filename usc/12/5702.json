{"tag":"section","attrib":{"id":"iddd7e0428-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5702"},"text":null,"children":[{"tag":"num","attrib":{"value":"5702"},"text":"§ 5702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal funds allocated to States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd7e0429-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5702/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program established; purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established the State Small Business Credit Initiative, to be administered by the Secretary. Under the Program, the Secretary shall allocate Federal funds to participating States and make the allocated funds available to the participating States as provided in this section for the uses described in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd7e042a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5702/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation formula","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd7e042b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5702/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after ","children":[{"tag":"date","attrib":{"date":"2021-03-11"},"text":"March 11, 2021","children":[],"tail":", the Secretary shall allocate Federal funds to participating States so that each State is eligible to receive an amount equal to what the State would receive under the 2021 allocation, as determined under paragraph (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e042c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5702/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 2021 allocation formula","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd7e042d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5702/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to States other than Tribal governments, the Secretary shall determine the 2021 allocation by allocating Federal funds among the States in the proportion that each such State’s 2020 State employment decline bears to the aggregate of the 2020 State employment declines for all States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7e042e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5702/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum allocation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall adjust the allocations under subparagraph (A) for each State to the extent necessary to ensure that no State receives less than 0.9 percent of the Federal funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7e042f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5702/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002544"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002544"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Two subpars. (C) have been enacted."}],"tail":" 2020 State employment decline defined"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this paragraph and with respect to a State, the term “2020 State employment decline” means the excess (if any) of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd7e0430-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5702/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of individuals employed in such State determined for December 2019; over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd7e0431-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5702/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of individuals employed in such State determined for December 2020.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7e0432-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5702/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" Separate allocation for Tribal governments"}],"tail":null},{"tag":"clause","attrib":{"id":"iddd7e0433-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5702/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to States that are Tribal governments, the Secretary shall determine the 2021 allocation by allocating $500,000,000 among the Tribal governments in the proportion the Secretary determines appropriate, including with consideration to available employment and economic data regarding each such Tribal government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd7e0434-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5702/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of intent; timing of allocation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to allocations to States that are Tribal governments, the Secretary may—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddd7e0435-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5702/b/2/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require Tribal governments that individually or jointly wish to participate in the Program to file a notice of intent with the Secretary not later than 30 days after ","children":[{"tag":"date","attrib":{"date":"2021-03-11"},"text":"March 11, 2021","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddd7e0436-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5702/b/2/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notwithstanding paragraph (1), allocate Federal funds to participating Tribal governments not later than 60 days after ","children":[{"tag":"date","attrib":{"date":"2021-03-11"},"text":"March 11, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7e0437-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5702/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment data","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary determines that employment data with respect to a State is unavailable from the Bureau of Labor Statistics of the Department of Labor, the Secretary shall consider such other economic and employment data that is otherwise available for purposes of determining the employment data of such State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd7e0438-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5702/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of allocated amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount allocated by the Secretary to each participating State under subsection (b) shall be made available to the State as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd7e0439-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5702/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocated amount generally to be available to State in one-thirds","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd7e043a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5702/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd7e043b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5702/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" apportion the participating State’s allocated amount into thirds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd7e043c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5702/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transfer to the participating State the first ⅓ when the Secretary approves the State for participation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5703"},"text":"section 5703 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd7e043d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5702/c/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transfer to the participating State each successive ⅓ when the State has certified to the Secretary that it has expended, transferred, or obligated 80 percent of the last transferred ⅓ for Federal contributions to, or for the account of, State programs that have delivered loans or investments to eligible businesses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7e043e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5702/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to withhold pending audit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may withhold the transfer of any successive ⅓ pending results of a financial audit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7e043f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5702/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspector General audits","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd7e0440-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5702/c/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Inspector General of the Department of the Treasury shall carry out an audit of the participating State’s use of allocated Federal funds transferred to the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd7e0441-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5702/c/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recoupment of misused transferred funds required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The allocation agreement between the Secretary and the participating State shall provide that the Secretary shall recoup any allocated Federal funds transferred to the participating State if the results of the an audit include a finding that there was an intentional or reckless misuse of transferred funds by the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd7e0442-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5702/c/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty for misstatement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any participating State that is found to have intentionally misstated any report issued to the Secretary under the Program shall be ineligible to receive any additional funds under the Program. Funds that had been allocated or that would otherwise have been allocated to such participating State shall be paid into the general fund of the Treasury for reduction of the public debt.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd7e0443-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5702/c/1/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Municipalities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subparagraph, the term “participating State” shall include a municipality given special permission to participate in the Program, under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5703/d"},"text":"section 5703(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7e0444-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5702/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may, in the Secretary’s discretion, transfer the full amount of the participating State’s allocated amount to the State in a single transfer if the participating State applies to the Secretary for approval to use the full amount of the allocation as collateral for a qualifying loan or swap funding facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e0445-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5702/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transferred amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each amount transferred to a participating State under this section shall remain available to the State until used by the State as permitted under paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e0446-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5702/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of transferred funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each participating State may use funds transferred to it under this section only—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd7e0447-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5702/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for making Federal contributions to, or for the account of, an approved State program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7e0448-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5702/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as collateral for a qualifying loan or swap funding facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7e0449-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5702/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the first ⅓ transferred, for paying administrative costs incurred by the State in implementing an approved State program in an amount not to exceed 5 percent of that first ⅓; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7e044a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5702/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of each successive ⅓ transferred, for paying administrative costs incurred by the State in implementing an approved State program in an amount not to exceed 3 percent of that successive ⅓.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e044b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5702/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of availability of amounts not transferred","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd7e044c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5702/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any portion of a participating State’s allocated amount that has not been transferred to the State under this section may be deemed by the Secretary to be no longer allocated to the State and no longer available to the State and shall be returned to the general fund of the Treasury or reallocated as described under subparagraph (B), if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd7e044d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5702/c/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the second ⅓ of a State’s allocated amount has not been transferred to the State before the end of the end of the 3-year period beginning on the date that the Secretary approves the State for participation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd7e044e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5702/c/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the last ⅓ of a State’s allocated amount has not been transferred to the State before the end of the end of the 6-year period beginning on the date that the Secretary approves the State for participation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7e044f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5702/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reallocation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amount deemed by the Secretary to be no longer allocated to a State and no longer available to such State under subparagraph (A) may be reallocated by the Secretary to other participating States. In making such a reallocation, the Secretary shall not take into account the minimum allocation requirements under subsection (b)(2)(B) or the specific allocation for Tribal governments described under subsection (b)(2)(C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e0450-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5702/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transferred amounts not assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amounts transferred to a participating State under this section shall not be considered assistance for purposes of subtitle V of title 31.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e0451-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5702/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd7e0452-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5702/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “allocated amount” means the total amount of Federal funds allocated by the Secretary under subsection (b) to the participating State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7e0453-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5702/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “⅓” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd7e0454-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5702/c/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the first ⅓ and second ⅓, an amount equal to 33 percent of a participating State’s allocated amount; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd7e0455-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5702/c/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the last ⅓, an amount equal to 34 percent of a participating State’s allocated amount.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd7e0456-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5702/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional allocations to support business enterprises owned and controlled by socially and economically disadvantaged individuals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the amounts appropriated for fiscal year 2021 to carry out the Program, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd7e0457-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5702/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allocate $1,500,000,000 to States from funds allocated under this section and, by regulation or other guidance, prescribe Program requirements that the funds be expended for business enterprises owned and controlled by socially and economically disadvantaged individuals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e0458-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5702/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allocate such amounts to States based on the needs of business enterprises owned and controlled by socially and economically disadvantaged individuals, as determined by the Secretary, in each State, and not subject to the allocation formula described under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd7e0459-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5702/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incentive allocations to support business enterprises owned and controlled by socially and economically disadvantaged individuals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amounts appropriated for fiscal year 2021 to carry out the Program, the Secretary shall set aside $1,000,000,000 for an incentive program under which the Secretary shall increase the second ⅓ and last ⅓ allocations for States that demonstrate robust support, as determined by the Secretary, for business concerns owned and controlled by socially and economically disadvantaged individuals in the deployment of prior allocation amounts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd7e045a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5702/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional allocations to support very small businesses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd7e045b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5702/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amounts appropriated to carry out the Program, the Secretary shall allocate not less than $500,000,000 to States from funds allocated under this section to be expended for very small businesses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e045c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5702/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Very small business defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the term “very small business”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd7e045d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5702/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means a business with fewer than 10 employees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7e045e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5702/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may include independent contractors and sole proprietors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd7e045f-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/240/tIII/s3003"},"text":"Pub. L. 111–240, title III, § 3003","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-09-27"},"text":"Sept. 27, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2570"},"text":"124 Stat. 2570","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/2/tIII/s3301/a/1/A"},"text":"Pub. L. 117–2, title III, § 3301(a)(1)(A)","children":[],"tail":", (b), (c), "},{"tag":"date","attrib":{"date":"2021-03-11"},"text":"Mar. 11, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/67"},"text":"135 Stat. 67","children":[],"tail":", 69, 70.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd7e0460-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd7e0461-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd7e0462-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2/s3301/a/1/A/i/I"},"text":"Pub. L. 117–2, § 3301(a)(1)(A)(i)(I)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) required allocation of funds by 30 days after "},{"tag":"date","attrib":{"date":"2010-09-27"},"text":"Sept. 27, 2010","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2/s3301/a/1/A/ii/II/bb"},"text":"Pub. L. 117–2, § 3301(a)(1)(A)(ii)(II)(bb)","children":[],"tail":", substituted “2020” for “2008” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2/s3301/a/1/A/i/II/aa"},"text":"Pub. L. 117–2, § 3301(a)(1)(A)(i)(II)(aa)","children":[],"tail":", substituted “2021” for “2009” in heading and in subpar. (A)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2/s3301/a/1/A/i/II/cc"},"text":"Pub. L. 117–2, § 3301(a)(1)(A)(i)(II)(cc)","children":[],"tail":", substituted “With respect to States other than Tribal governments, the Secretary” for “The Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2/s3301/a/1/A/i/II/ee"},"text":"Pub. L. 117–2, § 3301(a)(1)(A)(i)(II)(ee)","children":[],"tail":", added subpar. (C) relating to separate allocation for tribal governments."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(C)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2/s3301/a/1/A/i/II/dd"},"text":"Pub. L. 117–2, § 3301(a)(1)(A)(i)(II)(dd)","children":[],"tail":", substituted “2019” for “2007” in cl. (i) of subpar. (C) defining 2020 State employment decline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2/s3301/a/1/A/i/II/ee"},"text":"Pub. L. 117–2, § 3301(a)(1)(A)(i)(II)(ee)","children":[],"tail":", added subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2/s3301/a/1/A/i/III"},"text":"Pub. L. 117–2, § 3301(a)(1)(A)(i)(III)","children":[],"tail":", struck out par. (3) which provided for the 2010 allocation formula."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(A)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2/s3301/a/1/A/ii/I"},"text":"Pub. L. 117–2, § 3301(a)(1)(A)(ii)(I)","children":[],"tail":", inserted before period at end “that have delivered loans or investments to eligible businesses”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2/s3301/a/1/A/ii/II"},"text":"Pub. L. 117–2, § 3301(a)(1)(A)(ii)(II)","children":[],"tail":", amended par. (4) generally. Prior to amendment, text read as follows: “Any portion of a participating State’s allocated amount that has not been transferred to the State under this section by the end of the 2-year period beginning on the date that the Secretary approves the State for participation may be deemed by the Secretary to be no longer allocated to the State and no longer available to the State and shall be returned to the General Fund of the Treasury.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2/s3301/b"},"text":"Pub. L. 117–2, § 3301(b)","children":[],"tail":", added subsecs. (d) and (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2/s3301/c"},"text":"Pub. L. 117–2, § 3301(c)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd7e0463-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd7e0464-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2"},"text":"Pub. L. 117–2","children":[],"tail":" applicable with respect to funds appropriated under "},{"tag":"ref","attrib":{"href":"/us/pl/117/2/s3301"},"text":"section 3301 of Pub. L. 117–2","children":[],"tail":" and funds appropriated on and after "},{"tag":"date","attrib":{"date":"2021-03-11"},"text":"Mar. 11, 2021","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/2/s3301/g"},"text":"section 3301(g) of Pub. L. 117–2","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5701"},"text":"section 5701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
