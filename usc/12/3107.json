{"tag":"section","attrib":{"id":"iddd01f59b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3107"},"text":null,"children":[{"tag":"num","attrib":{"value":"3107"},"text":"§ 3107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Representative offices","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd01f59c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3107/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prior approval to establish representative offices","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd01f59d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3107/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No foreign bank may establish a representative office without the prior approval of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd01f59e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3107/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards for approval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In acting on any application under this paragraph to establish a representative office, the Board shall take into account the standards contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s3105/d/2"},"text":"section 3105(d)(2) of this title","children":[],"tail":" and may impose any additional requirements that the Board determines to be necessary to carry out the purposes of this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd01f59f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3107/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of representative offices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board may order the termination of the activities of a representative office of a foreign bank on the basis of the standards, procedures, and requirements applicable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s3105/e"},"text":"section 3105(e) of this title","children":[],"tail":" with respect to branches and agencies."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd01f5a0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3107/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Examinations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board may make examinations of each representative office of a foreign bank, the cost of which shall be assessed against and paid by such foreign bank. The Board may also make examinations of any affiliate of a foreign bank conducting business in any State if the Board deems it necessary to determine and enforce compliance with this chapter, the Bank Holding Company Act of 1956 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1841"},"text":"12 U.S.C. 1841","children":[],"tail":" et seq.], or other applicable Federal banking law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd01f5a1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3107/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance with State law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This chapter does not authorize the establishment of a representative office in any State in contravention of State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd01f5a2-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/369/s10"},"text":"Pub. L. 95–369, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-09-17"},"text":"Sept. 17, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/624"},"text":"92 Stat. 624","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/242/tII/s204"},"text":"Pub. L. 102–242, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2292"},"text":"105 Stat. 2292","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXVI/s1604/a/4"},"text":"Pub. L. 102–550, title XVI, § 1604(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4082"},"text":"106 Stat. 4082","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/102/tI/s142/b"},"text":"Pub. L. 106–102, title I, § 142(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1384"},"text":"113 Stat. 1384","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd01f5a3-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd01f5a4-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd01f5a5-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For definition of “this chapter”, referred to in subsecs. (a)(2), (c), and (d), see References in Text note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s3101"},"text":"section 3101 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Bank Holding Company Act of 1956, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-05-09/ch240"},"text":"act May 9, 1956, ch. 240","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/133"},"text":"70 Stat. 133","children":[],"tail":", which is classified principally to chapter 17 (§ 1841 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1841"},"text":"section 1841 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd01f5a6-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/102"},"text":"Pub. L. 106–102","children":[],"tail":" inserted at end “The Board may also make examinations of any affiliate of a foreign bank conducting business in any State if the Board deems it necessary to determine and enforce compliance with this chapter, the Bank Holding Company Act of 1956, or other applicable Federal banking law.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550"},"text":"Pub. L. 102–550","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t12/s3105/e"},"text":"section 3105(e) of this title","children":[],"tail":"” for “paragraphs (1), (2), and (3) of "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s3105/d"},"text":"section 3105(d) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242"},"text":"Pub. L. 102–242","children":[],"tail":" amended section generally. Prior to amendment, section read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) Any foreign bank that maintains an office other than a branch or agency in any State shall register with the Secretary of the Treasury in accordance with rules prescribed by him, within one hundred and eighty days after ","children":[{"tag":"date","attrib":{"date":"1978-09-17"},"text":"September 17, 1978","children":[],"tail":", or the date on which the office is established, whichever is later."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) This chapter does not authorize the establishment of any such office in any State in contravention of State law.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd01f5a7-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd01f5a8-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1999 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/102"},"text":"Pub. L. 106–102","children":[],"tail":" effective 120 days after "},{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/102/s161"},"text":"section 161 of Pub. L. 106–102","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s24"},"text":"section 24 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd01f5a9-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550"},"text":"Pub. L. 102–550","children":[],"tail":" effective as if included in the Federal Deposit Insurance Corporation Improvement Act of 1991, "},{"tag":"ref","attrib":{"href":"/us/pl/102/242"},"text":"Pub. L. 102–242","children":[],"tail":", as of "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/s1609/a"},"text":"section 1609(a) of Pub. L. 102–550","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s191"},"text":"section 191 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd01f5aa-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Moratorium on Examination Fees Under This Chapter","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/328/tI/s115/b"},"text":"Pub. L. 103–328, title I, § 115(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-29"},"text":"Sept. 29, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2368"},"text":"108 Stat. 2368","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/328/tI/s115/b"},"text":"“The provision of section 10(c) of the International Banking Act of 1978 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s3107/c"},"text":"12 U.S.C. 3107(c)","children":[],"tail":"] relating to the cost of examinations under such section shall not apply with respect to any examination under such section which begins before or during the 3-year period beginning on "},{"tag":"date","attrib":{"date":"1994-07-25"},"text":"July 25, 1994","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
