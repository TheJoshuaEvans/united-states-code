{"tag":"section","attrib":{"id":"iddd1e7f7d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4242"},"text":null,"children":[{"tag":"num","attrib":{"value":"4242"},"text":"§ 4242.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract decisions nonreviewable","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other law, no court shall have jurisdiction over any claim based on the Attorney General’s decision to refuse to enter into a contract for legal services referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4241"},"text":"section 4241 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd1e7f7e-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXV/s2589"},"text":"Pub. L. 101–647, title XXV, § 2589","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4905"},"text":"104 Stat. 4905","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
