{"tag":"section","attrib":{"id":"iddc5b0819-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1795k"},"text":null,"children":[{"tag":"num","attrib":{"value":"1795k"},"text":"§ 1795k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State and local tax exemption","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc5b081a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1795k/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Franchise, activities, etc., of Central Liquidity Facility; exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Central Liquidity Facility, and its franchise, activities, capital reserves, surplus, and income, shall be exempt from all State and local taxation now or hereafter imposed, other than taxes on real property held by the Facility (to the same extent, according to its value, as other similar property held by other persons is taxed).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc5b081b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1795k/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notes, bonds, debentures and other obligations of Central Liquidity Facility; exceptions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc5b081c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1795k/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), the notes, bonds, debentures, and other obligations issued on behalf of the Central Liquidity Facility and the income therefrom shall be exempt from all State and local taxation now or hereafter imposed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc5b081d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1795k/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any obligation described in paragraph (1) shall not be exempt from State or local gift, estate, inheritance, legacy, succession, or other wealth transfer taxes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc5b081e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1795k/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “State” defined; tax status","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc5b081f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1795k/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “State” includes the District of Columbia; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc5b0820-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1795k/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" taxes imposed by counties or municipalities, or any territory, dependency, or possession of the United States shall be treated as local taxes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc5b0821-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-26/ch750"},"text":"June 26, 1934, ch. 750","children":[],"tail":", title III, § 312, as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dB/tVIII/s2813/a/2"},"text":"Pub. L. 98–369, div. B, title VIII, § 2813(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1206"},"text":"98 Stat. 1206","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc5b0822-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc5b0823-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddc5b0824-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dB/tVIII/s2813/c"},"text":"Pub. L. 98–369, div. B, title VIII, § 2813(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1207"},"text":"98 Stat. 1207","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/369/dB/tVIII/s2813/c"},"text":"“The amendments made by this section [enacting this section and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1795b"},"text":"section 1795b of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s501"},"text":"section 501 of Title 26","children":[],"tail":", Internal Revenue Code] shall take effect on "},{"tag":"date","attrib":{"date":"1979-10-01"},"text":"October 1, 1979","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
