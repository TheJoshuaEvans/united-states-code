{"tag":"section","attrib":{"id":"iddb2c24f7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s282"},"text":null,"children":[{"tag":"num","attrib":{"value":"282"},"text":"§ 282.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subscription to capital stock by national banking association","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Every national banking association within each Federal reserve district shall be required to subscribe to the capital stock of the Federal reserve bank for that district in a sum equal to six per centum of the paid-up capital stock and surplus of such bank, one-sixth of the subscription to be payable on call of the Board of Governors of the Federal Reserve System, one-sixth within three months and one-sixth within six months thereafter, and the remainder of the subscription, or any part thereof, shall be subject to call when deemed necessary by the Board, said payments to be in gold or gold certificates.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddb2c24f8-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1913-12-23/ch6/s2"},"text":"Dec. 23, 1913, ch. 6, § 2","children":[],"tail":" (part), "},{"tag":"ref","attrib":{"href":"/us/stat/38/252"},"text":"38 Stat. 252","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1935-08-23/ch614"},"text":"Aug. 23, 1935, ch. 614","children":[],"tail":", title II, § 203(a), "},{"tag":"ref","attrib":{"href":"/us/stat/49/704"},"text":"49 Stat. 704","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb2c24f9-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb2c24fa-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddb2c24fb-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is based on part of the third par. of section 2 of act ","children":[{"tag":"date","attrib":{"date":"1913-12-23"},"text":"Dec. 23, 1913","children":[],"tail":". The rest of the third par. was not included in the Code. For classification of other pars. of section 2 of this Act, see Codification note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s222"},"text":"section 222 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddb2c24fc-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"iddb2c24fd-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 203(a) of act ","children":[{"tag":"date","attrib":{"date":"1935-08-23"},"text":"Aug. 23, 1935","children":[],"tail":", changed name of Federal Reserve Board to Board of Governors of the Federal Reserve System."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
