{"tag":"section","attrib":{"id":"iddd06b231-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3402"},"text":null,"children":[{"tag":"num","attrib":{"value":"3402"},"text":"§ 3402.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to financial records by Government authorities prohibited; exceptions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Except as provided by section 3403(c) or (d), 3413, or 3414 of this title, no Government authority may have access to or obtain copies of, or the information contained in the financial records of any customer from a financial institution unless the financial records are reasonably described and—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd06b232-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3402/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such customer has authorized such disclosure in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s3404"},"text":"section 3404 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd06b233-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3402/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such financial records are disclosed in response to an administrative subpena or summons which meets the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s3405"},"text":"section 3405 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd06b234-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3402/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such financial records are disclosed in response to a search warrant which meets the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s3406"},"text":"section 3406 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd06b235-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3402/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such financial records are disclosed in response to a judicial subpena which meets the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s3407"},"text":"section 3407 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd06b236-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3402/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such financial records are disclosed in response to a formal written request which meets the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s3408"},"text":"section 3408 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd06b237-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/630/tXI/s1102"},"text":"Pub. L. 95–630, title XI, § 1102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3697"},"text":"92 Stat. 3697","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd06b238-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd06b239-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd06b23a-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective upon the expiration of 120 days after ","children":[{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/630/s2101"},"text":"section 2101 of Pub. L. 95–630","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s375b"},"text":"section 375b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
