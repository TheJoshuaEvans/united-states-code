{"tag":"section","attrib":{"id":"iddd4e425b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5232"},"text":null,"children":[{"tag":"num","attrib":{"value":"5232"},"text":"§ 5232.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit reform","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd4e425c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5232/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (b), the costs of purchases of troubled assets made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5211/a"},"text":"section 5211(a) of this title","children":[],"tail":" and guarantees of troubled assets under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5212"},"text":"section 5212 of this title","children":[],"tail":", and any cash flows associated with the activities authorized in "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5212"},"text":"section 5212 of this title","children":[],"tail":" and subsections (a), (b), and (c) of "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5216"},"text":"section 5216 of this title","children":[],"tail":" shall be determined as provided under the Federal Credit Reform Act of 1990 ("},{"tag":"ref","attrib":{"href":"/us/usc/t2/s661"},"text":"2 U.S.C. 661","children":[],"tail":" et."},{"tag":"ref","attrib":{"idref":"fn002462"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002462"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd4e425d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5232/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Costs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of section 502(5) of the Federal Credit Reform Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s661a/5"},"text":"2 U.S.C. 661a(5)","children":[],"tail":")—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd4e425e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5232/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of troubled assets and guarantees of troubled assets shall be calculated by adjusting the discount rate in section 502(5)(E) (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s661a/5/E"},"text":"2 U.S.C. 661a(5)(E)","children":[],"tail":") for market risks; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4e425f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5232/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of a modification of a troubled asset or guarantee of a troubled asset shall be the difference between the current estimate consistent with paragraph (1) under the terms of the troubled asset or guarantee of the troubled asset and the current estimate consistent with paragraph (1) under the terms of the troubled asset or guarantee of the troubled asset, as modified.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd4e4260-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/343/dA/tI/s123"},"text":"Pub. L. 110–343, div. A, title I, § 123","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3790"},"text":"122 Stat. 3790","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd4e4261-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd4e4262-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd4e4263-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Credit Reform Act of 1990, referred to in subsec. (a), is title V of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/344"},"text":"Pub. L. 93–344","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXIII/s13201/a"},"text":"Pub. L. 101–508, title XIII, § 13201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-609"},"text":"104 Stat. 1388–609","children":[],"tail":", which is classified generally to subchapter III (§ 661 et seq.) of chapter 17A of Title 2, The Congress. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s621"},"text":"section 621 of Title 2","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
