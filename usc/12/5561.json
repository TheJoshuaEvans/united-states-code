{"tag":"section","attrib":{"id":"iddd7467d0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5561"},"text":null,"children":[{"tag":"num","attrib":{"value":"5561"},"text":"§ 5561.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this part, the following definitions shall apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd7467d1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5561/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bureau investigation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Bureau investigation” means any inquiry conducted by a Bureau investigator for the purpose of ascertaining whether any person is or has been engaged in any conduct that is a violation, as defined in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7467d2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5561/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bureau investigator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Bureau investigator” means any attorney or investigator employed by the Bureau who is charged with the duty of enforcing or carrying into effect any Federal consumer financial law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7467d3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5561/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Custodian","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “custodian” means the custodian or any deputy custodian designated by the Bureau.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7467d4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5561/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Documentary material","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “documentary material” includes the original or any copy of any book, document, record, report, memorandum, paper, communication, tabulation, chart, logs, electronic files, or other data or data compilations stored in any medium.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7467d5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5561/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “violation” means any act or omission that, if proved, would constitute a violation of any provision of Federal consumer financial law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd7467d6-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1051"},"text":"Pub. L. 111–203, title X, § 1051","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2018"},"text":"124 Stat. 2018","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd7467d7-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd7467d8-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd7467d9-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1058"},"text":"Pub. L. 111–203, title X, § 1058","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2035"},"text":"124 Stat. 2035","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/203/tX/s1058"},"text":"“This subtitle [subtitle E (§§ 1051–1058), enacting this part] shall become effective on the designated transfer date.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[The term “designated transfer date” is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5481/9"},"text":"section 5481(9) of this title","children":[],"tail":" as the date established under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5582"},"text":"section 5582 of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
