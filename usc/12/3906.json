{"tag":"section","attrib":{"id":"iddd129803-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3906"},"text":null,"children":[{"tag":"num","attrib":{"value":"3906"},"text":"§ 3906.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection and disclosure of international lending data","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd129804-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3906/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of information to Federal banking agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each appropriate Federal banking agency shall require, by regulation, each banking institution with foreign country exposure to submit, no fewer than four times each calendar year, information regarding such exposure in a format prescribed by such regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd129805-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3906/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure of information to the public","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each appropriate Federal banking agency shall require, by regulation, banking institutions to disclose to the public information regarding material foreign country exposure in relation to assets and to capital.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd129806-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3906/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations and orders of Federal banking agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The appropriate Federal banking agencies shall promulgate regulations or orders necessary to implement this section within one hundred and twenty days after ","children":[{"tag":"date","attrib":{"date":"1983-11-30"},"text":"November 30, 1983","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd129807-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/181/tI"},"text":"Pub. L. 98–181, title I","children":[],"tail":" [title IX, § 907], "},{"tag":"date","attrib":{"date":"1983-11-30"},"text":"Nov. 30, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1280"},"text":"97 Stat. 1280","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
