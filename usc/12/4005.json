{"tag":"section","attrib":{"id":"iddd15092d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4005"},"text":null,"children":[{"tag":"num","attrib":{"value":"4005"},"text":"§ 4005.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of interest","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd15092e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4005/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (b) or (c) and notwithstanding any other provision of law, interest shall accrue on funds deposited in an interest-bearing account at a depository institution beginning not later than the business day on which the depository institution receives provisional credit for such funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd15092f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4005/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for credit unions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) shall not apply to an account at a depository institution described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s461/b/1/A/iv"},"text":"section 461(b)(1)(A)(iv) of this title","children":[],"tail":" if the depository institution—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd150930-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4005/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" begins the accrual of interest or dividends at a later date than the date described in subsection (a) with respect to all funds, including cash, deposited in such account; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd150931-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4005/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides notice of the interest payment policy in the manner required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4004/e"},"text":"section 4004(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd150932-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4005/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for checks returned unpaid","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No provision of this chapter shall be construed as requiring the payment of interest or dividends on funds deposited by a check which is returned unpaid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd150933-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/86/tVI/s606"},"text":"Pub. L. 100–86, title VI, § 606","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-08-10"},"text":"Aug. 10, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/646"},"text":"101 Stat. 646","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd150934-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd150935-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd150936-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1988-09-01"},"text":"Sept. 1, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/86/s613/b"},"text":"section 613(b) of Pub. L. 100–86","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4001"},"text":"section 4001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
