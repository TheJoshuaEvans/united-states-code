{"tag":"section","attrib":{"id":"iddcb33a7d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1850a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1850a"},"text":"§ 1850a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Securities holding companies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcb33a7e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1850a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcb33a7f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1850a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “associated person of a securities holding company” means a person directly or indirectly controlling, controlled by, or under common control with, a securities holding company;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb33a80-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1850a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “foreign bank” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s3101/7"},"text":"section 3101(7) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb33a81-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1850a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “insured bank” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"section 1813 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb33a82-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1850a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “securities holding company”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcb33a83-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1850a/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddcb33a84-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1850a/a/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person (other than a natural person) that owns or controls 1 or more brokers or dealers registered with the Commission; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcb33a85-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1850a/a/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the associated persons of a person described in clause (i); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcb33a86-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1850a/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" does not include a person that is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddcb33a87-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1850a/a/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonbank financial company supervised by the Board under title I; ","children":[{"tag":"ref","attrib":{"idref":"fn002290"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002290"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcb33a88-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1850a/a/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an insured bank (other than an institution described in subparagraphs ","children":[{"tag":"ref","attrib":{"idref":"fn002291"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002291"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “subparagraph”."}],"tail":" (D), (F), or (H) of section 2(c)(2) of the Bank Holding Company Act of 1956 ("},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1841/c/2"},"text":"12 U.S.C. 1841(c)(2)","children":[],"tail":") "},{"tag":"ref","attrib":{"idref":"fn002292"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002292"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" So in original. Another closing parenthesis probably should appear."}],"tail":" or a savings association;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcb33a89-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1850a/a/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an affiliate of an insured bank (other than an institution described in subparagraphs ","children":[{"tag":"sup","attrib":{},"text":"2","children":[],"tail":" (D), (F), or (H) of section 2(c)(2) of the Bank Holding Company Act of 1956 ("},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1841/c/2"},"text":"12 U.S.C. 1841(c)(2)","children":[],"tail":") "},{"tag":"sup","attrib":{},"text":"3","children":[],"tail":" or an affiliate of a savings association;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcb33a8a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1850a/a/4/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a foreign bank, foreign company, or company that is described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s3106/a"},"text":"section 3106(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcb33a8b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1850a/a/4/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a foreign bank that controls, directly or indirectly, a corporation chartered under section 25A of the Federal Reserve Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s611"},"text":"12 U.S.C. 611","children":[],"tail":" et seq.); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcb33a8c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1850a/a/4/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to comprehensive consolidated supervision by a foreign regulator;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb33a8d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1850a/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “supervised securities holding company” means a securities holding company that is supervised by the Board of Governors under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb33a8e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1850a/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms “affiliate”, “bank”, “bank holding company”, “company”, “control”, “savings association”, and “subsidiary” have the same meanings as in section 2 of the Bank Holding Company Act of 1956 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1841"},"text":"12 U.S.C. 1841","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcb33a8f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1850a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supervision of a securities holding company not having a bank or savings association affiliate","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcb33a90-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1850a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A securities holding company that is required by a foreign regulator or provision of foreign law to be subject to comprehensive consolidated supervision may register with the Board of Governors under paragraph (2) to become a supervised securities holding company. Any securities holding company filing such a registration shall be supervised in accordance with this section, and shall comply with the rules and orders prescribed by the Board of Governors applicable to supervised securities holding companies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb33a91-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1850a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registration as a supervised securities holding company","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcb33a92-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1850a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A securities holding company that elects to be subject to comprehensive consolidated supervision shall register by filing with the Board of Governors such information and documents as the Board of Governors, by regulation, may prescribe as necessary or appropriate in furtherance of the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcb33a93-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1850a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A securities holding company that registers under subparagraph (A) shall be deemed to be a supervised securities holding company, effective on the date that is 45 days after the date of receipt of the registration information and documents under subparagraph (A) by the Board of Governors, or within such shorter period as the Board of Governors, by rule or order, may determine.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcb33a94-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1850a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supervision of securities holding companies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcb33a95-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1850a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recordkeeping and reporting","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcb33a96-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1850a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recordkeeping and reporting required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each supervised securities holding company and each affiliate of a supervised securities holding company shall make and keep for periods determined by the Board of Governors such records, furnish copies of such records, and make such reports, as the Board of Governors determines to be necessary or appropriate to carry out this section, to prevent evasions thereof, and to monitor compliance by the supervised securities holding company or affiliate with applicable provisions of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcb33a97-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1850a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form and contents","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddcb33a98-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1850a/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any record or report required to be made, furnished, or kept under this paragraph shall—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddcb33a99-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1850a/c/1/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be prepared in such form and according to such specifications (including certification by a registered public accounting firm), as the Board of Governors may require; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddcb33a9a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1850a/c/1/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be provided promptly to the Board of Governors at any time, upon request by the Board of Governors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcb33a9b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1850a/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Records and reports required to be made, furnished, or kept under this paragraph may include—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddcb33a9c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1850a/c/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a balance sheet or income statement of the supervised securities holding company or an affiliate of a supervised securities holding company;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddcb33a9d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1850a/c/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the consolidated capital and liquidity of the supervised securities holding company;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddcb33a9e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1850a/c/1/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a report by an independent auditor attesting to the compliance of the supervised securities holding company with the internal risk management and internal control objectives of the supervised securities holding company; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddcb33a9f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1850a/c/1/B/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a report concerning the extent to which the supervised securities holding company or affiliate has complied with the provisions of this section and any regulations prescribed and orders issued under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb33aa0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1850a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of existing reports","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcb33aa1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1850a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board of Governors shall, to the fullest extent possible, accept reports in fulfillment of the requirements of this paragraph that a supervised securities holding company or an affiliate of a supervised securities holding company has been required to provide to another regulatory agency or a self-regulatory organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcb33aa2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1850a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A supervised securities holding company or an affiliate of a supervised securities holding company shall promptly provide to the Board of Governors, at the request of the Board of Governors, any report described in subparagraph (A), as permitted by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb33aa3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1850a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Examination authority","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcb33aa4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1850a/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Focus of examination authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board of Governors may make examinations of any supervised securities holding company and any affiliate of a supervised securities holding company to carry out this subsection, to prevent evasions thereof, and to monitor compliance by the supervised securities holding company or affiliate with applicable provisions of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcb33aa5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1850a/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deference to other examinations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subparagraph, the Board of Governors shall, to the fullest extent possible, use the reports of examination made by other appropriate Federal or State regulatory authorities with respect to any functionally regulated subsidiary or any institution described in subparagraph (D), (F), or (H) of section 2(c)(2) of the Bank Holding Company Act of 1956 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1841/c/2"},"text":"12 U.S.C. 1841(c)(2)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcb33aa6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1850a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capital and risk management","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcb33aa7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1850a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board of Governors shall, by regulation or order, prescribe capital adequacy and other risk management standards for supervised securities holding companies that are appropriate to protect the safety and soundness of the supervised securities holding companies and address the risks posed to financial stability by supervised securities holding companies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb33aa8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1850a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Differentiation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In imposing standards under this subsection, the Board of Governors may differentiate among supervised securities holding companies on an individual basis, or by category, taking into consideration the requirements under paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb33aa9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1850a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any standards imposed on a supervised securities holding company under this subsection shall take into account—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcb33aaa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1850a/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the differences among types of business activities carried out by the supervised securities holding company;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcb33aab-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1850a/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount and nature of the financial assets of the supervised securities holding company;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcb33aac-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1850a/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount and nature of the liabilities of the supervised securities holding company, including the degree of reliance on short-term funding;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcb33aad-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1850a/d/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent and nature of the off-balance sheet exposures of the supervised securities holding company;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcb33aae-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1850a/d/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent and nature of the transactions and relationships of the supervised securities holding company with other financial companies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcb33aaf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1850a/d/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the importance of the supervised securities holding company as a source of credit for households, businesses, and State and local governments, and as a source of liquidity for the financial system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcb33ab0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1850a/d/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature, scope, and mix of the activities of the supervised securities holding company.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb33ab1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1850a/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A capital requirement imposed under this subsection may not take effect earlier than 180 days after the date on which a supervised securities holding company is provided notice of the capital requirement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcb33ab2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1850a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other provisions of law applicable to supervised securities holding companies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcb33ab3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1850a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Deposit Insurance Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsections (b), (c) through (s), and (u) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1818"},"text":"section 1818 of this title","children":[],"tail":" shall apply to any supervised securities holding company, and to any subsidiary (other than a bank or an institution described in subparagraph (D), (F), or (H) of section 2(c)(2) of the Bank Holding Company Act of 1956 ("},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1841/c/2"},"text":"12 U.S.C. 1841(c)(2)","children":[],"tail":")) of a supervised securities holding company, in the same manner as such subsections apply to a bank holding company for which the Board of Governors is the appropriate Federal banking agency. For purposes of applying such subsections to a supervised securities holding company or a subsidiary (other than a bank or an institution described in subparagraph (D), (F), or (H) of section 2(c)(2) of the Bank Holding Company Act of 1956 ("},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1841/c/2"},"text":"12 U.S.C. 1841(c)(2)","children":[],"tail":")) of a supervised securities holding company, the Board of Governors shall be deemed the appropriate Federal banking agency for the supervised securities holding company or subsidiary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb33ab4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1850a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bank Holding Company Act of 1956","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as the Board of Governors may otherwise provide by regulation or order, a supervised securities holding company shall be subject to the provisions of the Bank Holding Company Act of 1956 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1841"},"text":"12 U.S.C. 1841","children":[],"tail":" et seq.) in the same manner and to the same extent a bank holding company is subject to such provisions, except that a supervised securities holding company may not, by reason of this paragraph, be deemed to be a bank holding company for purposes of section 4 of the Bank Holding Company Act of 1956 ("},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1843"},"text":"12 U.S.C. 1843","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcb33ab5-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tVI/s618"},"text":"Pub. L. 111–203, title VI, § 618","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1616"},"text":"124 Stat. 1616","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcb33ab6-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcb33ab7-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddcb33ab8-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Title I, referred to in subsec. (a)(4)(B)(i), is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1391"},"text":"124 Stat. 1391","children":[],"tail":", known as the Financial Stability Act of 2010, which is classified principally to subchapter I (§ 5311 et seq.) of chapter 53 of this title. For complete classification of title I to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 25A of the Federal Reserve Act, referred to in subsec. (a)(4)(B)(v), popularly known as the Edge Act, is classified to subchapter II (§ 611 et seq.) of chapter 6 of this title. For complete classification of this Act to the Code, see Short Title note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s611"},"text":"section 611 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Bank Holding Company Act of 1956, referred to in subsec. (e)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-05-09/ch240"},"text":"act May 9, 1956, ch. 240","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/133"},"text":"70 Stat. 133","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1841"},"text":"section 1841 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddcb33ab9-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Bank and Savings Association Holding Company and Depository Institution Regulatory Improvements Act of 2010, and also as part of the Dodd-Frank Wall Street Reform and Consumer Protection Act, and not as part of the Bank Holding Company Act of 1956 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcb33aba-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddcb33abb-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 1 day after ","children":[{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s4"},"text":"section 4 of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"section 5301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"iddcb33abc-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of terms used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"section 5301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
