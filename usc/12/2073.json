{"tag":"section","attrib":{"id":"iddcbf21a0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2073"},"text":null,"children":[{"tag":"num","attrib":{"value":"2073"},"text":"§ 2073.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General corporate powers","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Each production credit association shall be a body corporate and, subject to supervision by the Farm Credit Bank for the district and regulation by the Farm Credit Administration, shall have the power to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcbf21a1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2073/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have succession until terminated in accordance with this chapter or any other Act of Congress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbf21a2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2073/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adopt and use a corporate seal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbf21a3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2073/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make contracts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbf21a4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2073/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sue and be sued;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbf21a5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2073/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquire, hold, dispose, and otherwise exercise all of the usual incidents of ownership of real and personal property necessary or convenient to the business of the association;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbf21a6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2073/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operate under the direction of the board of directors of the association in accordance with the provisions of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbf21a7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2073/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subscribe to stock of the bank;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbf21a8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2073/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchase stock of the bank held by other production credit associations and stock of other production credit associations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbf21a9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2073/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contribute to the capital of the bank or other production credit associations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbf21aa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2073/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" invest funds of the association as may be approved by the Farm Credit Bank under regulations of the Farm Credit Administration and deposit the current funds and securities of such with the Farm Credit Bank, a member bank of the Federal Reserve System, or any bank insured under the Federal Deposit Insurance Corporation, and may pay fees therefor and receive interest thereon as may be agreed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbf21ab-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2073/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" buy and sell obligations of or insured by the United States or of any agency thereof or of any banks of the Farm Credit System and buy from and sell to such banks, interests in loans and in other financial assistance extended and nonvoting stock, as may be authorized by the Farm Credit Bank in accordance with regulations of the Farm Credit Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbf21ac-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2073/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" borrow money from the Farm Credit Bank, and with the approval of such bank, borrow from and issue notes or other obligations to any commercial bank or other financial institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbf21ad-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2073/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make and participate in loans, accept advance payments, and provide services and other assistance as authorized in this part and charge fees therefor, and when authorized by the bank participate with one or more other Farm Credit System institutions in loans made under this subchapter or other subchapters of this chapter on the basis prescribed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2206"},"text":"section 2206 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbf21ae-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2073/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" endorse and become liable on loans discounted or pledged to the Farm Credit Bank;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbf21af-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2073/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as may be authorized by the Farm Credit Bank in accordance with regulations of the Farm Credit Administration, agree with other Farm Credit System institutions to share loan or other losses, whether to protect against capital impairment or for any other purpose;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbf21b0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2073/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" prescribe, by its board of directors, its bylaws that shall be consistent with law, and that shall provide for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcbf21b1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2073/16/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the classes of its stock and the manner in which such stock shall be issued, transferred, and retired; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcbf21b2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2073/16/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the manner in which it is to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddcbf21b3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2073/16/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" select officers and employees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcbf21b4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2073/16/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquire, hold, and transfer property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcbf21b5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2073/16/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct general business; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcbf21b6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2073/16/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exercise and enjoy the privileges granted to it by law;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbf21b7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2073/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide by its board of directors for a manager or other chief executive officer, and provide for such other officers or employees as may be necessary, including joint employees as provided in this chapter, define their duties, and require surety bonds or make other provisions against losses occasioned by employees, but no director shall, within one year after the date when such director ceases to be a member of the board, serve as a salaried employee of the association on the board of which he served;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbf21b8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2073/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" elect by the board of directors of the association a loan committee with power to approve applications for membership in the association and loans or participations or, with the approval of the bank, delegate the approval of applications for membership and loans or participations within specified limits to other committees or to authorized officers and employees of the association;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbf21b9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2073/19"},"text":null,"children":[{"tag":"num","attrib":{"value":"19"},"text":"(19)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform any functions delegated to the association by the bank;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbf21ba-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2073/20"},"text":null,"children":[{"tag":"num","attrib":{"value":"20"},"text":"(20)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exercise by the board of directors or authorized officers or employees of the association, all such incidental powers as may be necessary or expedient to carry on the business of the association; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbf21bb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2073/21"},"text":null,"children":[{"tag":"num","attrib":{"value":"21"},"text":"(21)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operate as an originator and become certified as a certified facility under subchapter VIII.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcbf21bc-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tII/s2"},"text":"Pub. L. 92–181, title II, § 2","children":[],"tail":".2, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tIV/s401"},"text":"Pub. L. 100–233, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1630"},"text":"101 Stat. 1630","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/tIV/s401"},"text":"Pub. L. 100–399, title IV, § 401","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"1988-08-17"},"text":"Aug. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/997"},"text":"102 Stat. 997","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcbf21bd-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcbf21be-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"iddcbf21bf-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2073, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tII/s2"},"text":"Pub. L. 92–181, title II, § 2","children":[],"tail":".2, "},{"tag":"date","attrib":{"date":"1971-12-10"},"text":"Dec. 10, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/592"},"text":"85 Stat. 592","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/592/tII/s202"},"text":"Pub. L. 96–592, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-24"},"text":"Dec. 24, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3440"},"text":"94 Stat. 3440","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/205/tII/s205/e/2"},"text":"Pub. L. 99–205, title II, § 205(e)(2)","children":[],"tail":"–(5), title VI, § 604, "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1704"},"text":"99 Stat. 1704","children":[],"tail":", 1711; "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tVIII"},"text":"Pub. L. 100–233, title VIII","children":[],"tail":", §§ 802(j), 805(e), "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1711"},"text":"101 Stat. 1711","children":[],"tail":", 1715, related to Federal intermediate credit bank stock, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/s401"},"text":"Pub. L. 100–233, § 401","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcbf21c0-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Par. (16). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s401"},"text":"Pub. L. 100–399, § 401","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(1), amended par. (16) generally. Prior to amendment, par. (16) read as follows: “prescribe by the board of directors of the association the bylaws not inconsistent with law providing for—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) the classes of association stock and the manner in which the stock shall be issued, transferred, and retired;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) the officers and employees elected or provided for;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) the property acquired, held, and transferred by the association; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(D) the general business conducted, and the privileges granted to the association by law exercised and enjoyed;”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (17). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s401"},"text":"Pub. L. 100–399, § 401","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(2), substituted “provide by its board of directors for” for “elect by the board of directors of the association” and “serve as” for “be elected or designated”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (21). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s401"},"text":"Pub. L. 100–399, § 401","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(3)–(5), added par. (21)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcbf21c1-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcbf21c2-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399"},"text":"Pub. L. 100–399","children":[],"tail":" effective immediately after amendment made by "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/s401"},"text":"section 401 of Pub. L. 100–233","children":[],"tail":", which was effective 6 months after "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/s1001/b"},"text":"section 1001(b) of Pub. L. 100–399","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2002"},"text":"section 2002 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddcbf21c3-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/233/tIV/s401"},"text":"Pub. L. 100–233, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1622"},"text":"101 Stat. 1622","children":[],"tail":", provided in part that this section is effective 6 months after "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
