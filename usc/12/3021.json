{"tag":"section","attrib":{"id":"iddcfaca31-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3021"},"text":null,"children":[{"tag":"num","attrib":{"value":"3021"},"text":"§ 3021.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report to Congress; contents","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Board of the Bank shall report annually to the appropriate committees of the Congress on the Bank’s capital, operations, and financial condition and make recommendations for legislation needed to improve its services.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddcfaca32-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/351/tI/s111"},"text":"Pub. L. 95–351, title I, § 111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-08-20"},"text":"Aug. 20, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/510"},"text":"92 Stat. 510","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
