{"tag":"section","attrib":{"id":"iddd850913-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5914"},"text":null,"children":[{"tag":"num","attrib":{"value":"5914"},"text":"§ 5914.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd850914-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5914/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reporting requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Beginning on the date that is 1 year after ","children":[{"tag":"date","attrib":{"date":"2025-07-18"},"text":"July 18, 2025","children":[],"tail":", and annually thereafter, the primary Federal payment stablecoin regulators, in consultation with State payment stablecoin regulators, as necessary, shall submit to the Committee on Banking, Housing, and Urban Affairs of the Senate, the Committee on Financial Services of the House of Representatives, and the Director of the Office of Financial Research a report, which may include a classified annex, if applicable, on the status of the payment stablecoin industry, including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd850915-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5914/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of trends in payment stablecoin activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd850916-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5914/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the number of applications for approval as a permitted payment stablecoin issuer under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5904"},"text":"section 5904 of this title","children":[],"tail":", including aggregate approvals and rejections of applications; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd850917-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5914/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the potential financial stability risks posed to the safety and soundness of the broader financial system by payment stablecoin activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd850918-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5914/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" FSOC report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Financial Stability Oversight Council shall incorporate the findings in the report under subsection (a) into the annual report of the Council required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5322/a/2/N"},"text":"section 5322(a)(2)(N) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd850919-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/27/s15"},"text":"Pub. L. 119–27, § 15","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-18"},"text":"July 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/460"},"text":"139 Stat. 460","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd85091a-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"iddd85091b-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Delayed Effective Date of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For delayed effective date of section, see Effective Date note below.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd85091c-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd85091d-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the earlier of the date that is 18 months after ","children":[{"tag":"date","attrib":{"date":"2025-07-18"},"text":"July 18, 2025","children":[],"tail":", or the date that is 120 days after the date on which the primary Federal payment stablecoin regulators issue any final regulations implementing "},{"tag":"ref","attrib":{"href":"/us/pl/119/27"},"text":"Pub. L. 119–27","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/119/27/s20"},"text":"section 20 of Pub. L. 119–27","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5901"},"text":"section 5901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
