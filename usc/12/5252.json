{"tag":"section","attrib":{"id":"iddd50b2d6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5252"},"text":null,"children":[{"tag":"num","attrib":{"value":"5252"},"text":"§ 5252.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports by the Office of Management and Budget and the Congressional Budget Office","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd50b2d7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5252/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports by the Office of Management and Budget","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Within 60 days of the first exercise of the authority granted in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5211/a"},"text":"section 5211(a) of this title","children":[],"tail":", but in no case later than "},{"tag":"date","attrib":{"date":"2008-12-31"},"text":"December 31, 2008","children":[],"tail":", and annually thereafter, the Office of Management and Budget shall report to the President and the Congress—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd50b2d8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5252/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estimate, notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s661a/5/F"},"text":"section 661a(5)(F) of title 2","children":[],"tail":", as of the first business day that is at least 30 days prior to the issuance of the report, of the cost of the troubled assets, and guarantees of the troubled assets, determined in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5232"},"text":"section 5232 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd50b2d9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5252/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information used to derive the estimate, including assets purchased or guaranteed, prices paid, revenues received, the impact on the deficit and debt, and a description of any outstanding commitments to purchase troubled assets; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd50b2da-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5252/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a detailed analysis of how the estimate has changed from the previous report.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Beginning with the second report under subsection (a), the Office of Management and Budget shall explain the differences between the Congressional Budget Office estimates delivered in accordance with subsection (b) and prior Office of Management and Budget estimates.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd50b2db-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5252/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports by the Congressional Budget Office","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Within 45 days of receipt by the Congress of each report from the Office of Management and Budget under subsection (a), the Congressional Budget Office shall report to the Congress the Congressional Budget Office’s assessment of the report submitted by the Office of Management and Budget, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd50b2dc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5252/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of the troubled assets and guarantees of the troubled assets,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd50b2dd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5252/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information and valuation methods used to calculate such cost, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd50b2de-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5252/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact on the deficit and the debt.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd50b2df-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5252/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial expertise","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the duties in this subsection ","children":[{"tag":"ref","attrib":{"idref":"fn002467"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002467"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “section”."}],"tail":" or performing analyses of activities under this chapter, the Director of the Congressional Budget Office may employ personnel and procure the services of experts and consultants."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd50b2e0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5252/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary to produce reports required by this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd50b2e1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5252/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sunset","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding the previous provisions of this section, the reporting and comment requirements under this section shall terminate with the annual period on the last day of which all troubled assets acquired by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5211"},"text":"section 5211 of this title","children":[],"tail":" have been sold or transferred out of the ownership or control of the Federal Government."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd50b2e2-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/343/dA/tII/s202"},"text":"Pub. L. 110–343, div. A, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3800"},"text":"122 Stat. 3800","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/204/s1/b/1"},"text":"Pub. L. 112–204, § 1(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-12-04"},"text":"Dec. 4, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1485"},"text":"126 Stat. 1485","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd50b2e3-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd50b2e4-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd50b2e5-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (c), was in the original “this Act” and was translated as reading “this division”, meaning div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/343"},"text":"Pub. L. 110–343","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3765"},"text":"122 Stat. 3765","children":[],"tail":", known as the Emergency Economic Stabilization Act of 2008, to reflect the probable intent of Congress. For complete classification of division A to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5201"},"text":"section 5201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd50b2e6-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/204/s1/b/1/A"},"text":"Pub. L. 112–204, § 1(b)(1)(A)","children":[],"tail":", substituted “annually” for “semiannually”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/204/s1/b/1/B"},"text":"Pub. L. 112–204, § 1(b)(1)(B)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd50b2e7-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd50b2e8-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/204/s1/b/2"},"text":"Pub. L. 112–204, § 1(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-12-04"},"text":"Dec. 4, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1486"},"text":"126 Stat. 1486","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/204/s1/b/2"},"text":"“The amendments made by this subsection [amending this section] shall take effect the first day after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2012-12-04"},"text":"Dec. 4, 2012","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
