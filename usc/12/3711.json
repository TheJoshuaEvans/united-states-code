{"tag":"section","attrib":{"id":"iddd0ddd3a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3711"},"text":null,"children":[{"tag":"num","attrib":{"value":"3711"},"text":"§ 3711.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreclosure costs","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The following foreclosure costs shall be paid from the sale proceeds prior to satisfaction of any other claim to such sale proceeds:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd0ddd3b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3711/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" necessary advertising costs and postage incurred in giving notice pursuant to sections 3708 and 3710 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd0ddd3c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3711/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mileage for posting notices and for the foreclosure commissioner’s attendance at the sale at the rate provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1921"},"text":"section 1921 of title 28","children":[],"tail":" for mileage by the most reasonable road distance;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd0ddd3d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3711/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reasonable and necessary costs actually incurred in connection with any necessary search of title and lien records;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd0ddd3e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3711/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" necessary out-of-pocket costs incurred by the foreclosure commissioner to record documents; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd0ddd3f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3711/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a commission for the foreclosure commissioner for the conduct of the foreclosure to the extent authorized by regulations issued by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd0ddd40-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tIII/s369C"},"text":"Pub. L. 97–35, title III, § 369C","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/429"},"text":"95 Stat. 429","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
