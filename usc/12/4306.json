{"tag":"section","attrib":{"id":"iddd1e7fea-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4306"},"text":null,"children":[{"tag":"num","attrib":{"value":"4306"},"text":"§ 4306.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of interest","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd1e7feb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4306/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Calculated on full amount of principal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Interest on an interest-bearing account at any depository institution shall be calculated by such institution on the full amount of principal in the account for each day of the stated calculation period at the rate or rates of interest disclosed pursuant to this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1e7fec-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4306/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No particular method of compounding interest required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall not be construed as prohibiting or requiring the use of any particular method of compounding or crediting of interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1e7fed-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4306/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Date by which interest must accrue","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Interest on accounts that are subject to this chapter shall begin to accrue not later than the business day specified for interest-bearing accounts in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4005"},"text":"section 4005 of this title","children":[],"tail":", subject to subsections (b) and (c) of such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd1e7fee-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/tII/s267"},"text":"Pub. L. 102–242, title II, § 267","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2338"},"text":"105 Stat. 2338","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXVI/s1604/e/2/B"},"text":"Pub. L. 102–550, title XVI, § 1604(e)(2)(B)","children":[],"tail":", (C), "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4084"},"text":"106 Stat. 4084","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd1e7fef-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd1e7ff0-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd1e7ff1-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsecs. (a), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550"},"text":"Pub. L. 102–550","children":[],"tail":" made technical amendment to references to “this chapter” to reflect correction of corresponding provision of original act."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd1e7ff2-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd1e7ff3-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550"},"text":"Pub. L. 102–550","children":[],"tail":" effective as if included in the Federal Deposit Insurance Corporation Improvement Act of 1991, "},{"tag":"ref","attrib":{"href":"/us/pl/102/242"},"text":"Pub. L. 102–242","children":[],"tail":", as of "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/s1609/a"},"text":"section 1609(a) of Pub. L. 102–550","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s191"},"text":"section 191 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
