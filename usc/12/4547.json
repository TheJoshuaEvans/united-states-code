{"tag":"section","attrib":{"id":"iddd281c63-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4547"},"text":null,"children":[{"tag":"num","attrib":{"value":"4547"},"text":"§ 4547.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enterprise guarantee fees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd281c64-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4547/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the following definitions shall apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd281c65-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4547/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guarantee fee","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “guarantee fee”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd281c66-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4547/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means a fee described in subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd281c67-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4547/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd281c68-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4547/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the guaranty fee charged by the Federal National Mortgage Association with respect to mortgage-backed securities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd281c69-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4547/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the management and guarantee fee charged by the Federal Home Loan Mortgage Corporation with respect to participation certificates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd281c6a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4547/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Average fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “average fees” means the average contractual fee rate of single-family guaranty arrangements by an enterprise entered into during 2011, plus the recognition of any up-front cash payments over an estimated average life, expressed in terms of basis points. Such definition shall be interpreted in a manner consistent with the annual report on guarantee fees by the Federal Housing Finance Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd281c6b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4547/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increase","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd281c6c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4547/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd281c6d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4547/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Phased increase required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (c), the Director shall require each enterprise to charge a guarantee fee in connection with any guarantee of the timely payment of principal and interest on securities, notes, and other obligations based on or backed by mortgages on residential real properties designed principally for occupancy of from 1 to 4 families, consummated after ","children":[{"tag":"date","attrib":{"date":"2011-12-23"},"text":"December 23, 2011","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd281c6e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4547/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of the increase required under this section shall be determined by the Director to appropriately reflect the risk of loss, as well ","children":[{"tag":"ref","attrib":{"idref":"fn002409"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002409"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by “as”."}],"tail":" the cost of capital allocated to similar assets held by other fully private regulated financial institutions, but such amount shall be not less than an average increase of 10 basis points for each origination year or book year above the average fees imposed in 2011 for such guarantees. The Director shall prohibit an enterprise from offsetting the cost of the fee to mortgage originators, borrowers, and investors by decreasing other charges, fees, or premiums, or in any other manner."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd281c6f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4547/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to limit offer of guarantee","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall prohibit an enterprise from consummating any offer for a guarantee to a lender for mortgage-backed securities, if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd281c70-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4547/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the guarantee is inconsistent with the requirements of this section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd281c71-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4547/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the risk of loss is allowed to increase, through lowering of the underwriting standards or other means, for the primary purpose of meeting the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd281c72-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4547/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit in Treasury","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts received from fee increases imposed under this section shall be deposited directly into the United States Treasury, and shall be available only to the extent provided in subsequent appropriations Acts. The fees charged pursuant to this section shall not be considered a reimbursement to the Federal Government for the costs or subsidy provided to an enterprise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd281c73-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4547/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Phase-in","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd281c74-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4547/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director may provide for compliance with subsection (b) by allowing each enterprise to increase the guarantee fee charged by the enterprise gradually over the 2-year period beginning on ","children":[{"tag":"date","attrib":{"date":"2011-12-23"},"text":"December 23, 2011","children":[],"tail":", in a manner sufficient to comply with this section. In determining a schedule for such increases, the Director shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd281c75-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4547/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for uniform pricing among lenders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd281c76-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4547/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for adjustments in pricing based on risk levels; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd281c77-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4547/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take into consideration conditions in financial markets.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd281c78-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4547/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection shall be interpreted to undermine the minimum increase required by subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd281c79-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4547/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information collection and annual analysis","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall require each enterprise to provide to the Director, as part of its annual report submitted to Congress—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd281c7a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4547/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd281c7b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4547/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" changes made to up-front fees and annual fees as part of the guarantee fees negotiated with lenders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd281c7c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4547/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" changes to the riskiness of the new borrowers compared to previous origination years or book years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd281c7d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4547/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any adjustments required to improve for future origination years or book years, in order to be in complete compliance with subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd281c7e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4547/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of how the changes in the guarantee fees described in paragraph (1) met the requirements of subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd281c7f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4547/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd281c80-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4547/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required adjustments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Based on the information from subsection (d) and any other information the Director deems necessary, the Director shall require an enterprise to make adjustments in its guarantee fee in order to be in compliance with subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd281c81-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4547/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Noncompliance penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An enterprise that has been found to be out of compliance with subsection (b) for any 2 consecutive years shall be precluded from providing any guarantee for a period, determined by rule of the Director, but in no case less than 1 year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd281c82-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4547/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection shall be interpreted as preventing the Director from initiating and implementing an enforcement action against an enterprise, at a time the Director deems necessary, under other existing enforcement authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd281c83-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4547/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expiration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of this section shall expire on ","children":[{"tag":"date","attrib":{"date":"2032-10-01"},"text":"October 1, 2032","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd281c84-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXIII/s1327"},"text":"Pub. L. 102–550, title XIII, § 1327","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/112/78/tIV/s401"},"text":"Pub. L. 112–78, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-23"},"text":"Dec. 23, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1287"},"text":"125 Stat. 1287","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dI/s90005"},"text":"Pub. L. 117–58, div. I, § 90005","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1346"},"text":"135 Stat. 1346","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd281c85-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd281c86-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"iddd281c87-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 4547, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXIII/s1327"},"text":"Pub. L. 102–550, title XIII, § 1327","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3956"},"text":"106 Stat. 3956","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tI/s1122/a/1"},"text":"Pub. L. 110–289, div. A, title I, § 1122(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2689"},"text":"122 Stat. 2689","children":[],"tail":", related to authority to require reports by enterprises, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA"},"text":"Pub. L. 110–289, div. A","children":[],"tail":" , title I, § 1104(b), "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2667"},"text":"122 Stat. 2667","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd281c88-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":" substituted “2032” for “2021”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
