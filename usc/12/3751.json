{"tag":"section","attrib":{"id":"iddd0ddd62-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3751"},"text":null,"children":[{"tag":"num","attrib":{"value":"3751"},"text":"§ 3751.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings and purpose","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd0ddd63-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3751/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd0ddd64-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3751/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the disparate State laws under which mortgages are foreclosed on behalf of the Secretary covering 1- to 4-family residential properties—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd0ddd65-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3751/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" burden certain programs administered by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd0ddd66-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3751/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the costs of collecting obligations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd0ddd67-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3751/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" generally are a detriment to the community in which the properties are located;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd0ddd68-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3751/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the long periods required to complete the foreclosure of such mortgages under certain State laws—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd0ddd69-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3751/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lead to deterioration in the condition of the properties involved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd0ddd6a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3751/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" necessitate substantial Federal holding expenditures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd0ddd6b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3751/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the risk of vandalism, fire loss, depreciation, damage, and waste with respect to the properties; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd0ddd6c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3751/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adversely affect the neighborhoods in which the properties are located;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd0ddd6d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3751/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" these conditions seriously impair the ability of the Secretary to protect the Federal financial interest in the affected properties and frustrate attainment of the objectives of the underlying Federal program authority;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd0ddd6e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3751/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the availability of uniform and more expeditious procedures, with no right of redemption in the mortgagor or others, for the foreclosure of these mortgages by the Secretary will tend to ameliorate these conditions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd0ddd6f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3751/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing the Secretary with a nonjudicial foreclosure procedure will reduce unnecessary litigation by removing many foreclosures from the courts if they contribute to overcrowded calendars.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd0ddd70-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3751/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purpose of this chapter is to create a uniform Federal foreclosure remedy for single family mortgages that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd0ddd71-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3751/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are held by the Secretary pursuant to title I or title II of the National Housing Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1702"},"text":"12 U.S.C. 1702","children":[],"tail":" et seq., 1707 et seq.]; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd0ddd72-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3751/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" secure loans obligated by the Secretary under section 1452b ","children":[{"tag":"ref","attrib":{"idref":"fn002355"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002355"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 42."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd0ddd73-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/327/tII"},"text":"Pub. L. 103–327, title II","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-28"},"text":"Sept. 28, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2316"},"text":"108 Stat. 2316","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd0ddd74-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd0ddd75-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd0ddd76-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Housing Act, referred to in subsec. (b)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-27/ch847"},"text":"act June 27, 1934, ch. 847","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/1246"},"text":"48 Stat. 1246","children":[],"tail":". Titles I and II of the Act are classified generally to subchapters I (§ 1702 et seq.) and II (§ 1707 et seq.), respectively, of chapter 13 of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1701"},"text":"section 1701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1452b"},"text":"Section 1452b of title 42","children":[],"tail":", referred to in subsec. (b)(2), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/101/625/tII/s289/b/1"},"text":"Pub. L. 101–625, title II, § 289(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4128"},"text":"104 Stat. 4128","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd0ddd77-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is based on section 802 of title VIII of S. 2281, One Hundred Third Congress, as reported ","children":[{"tag":"date","attrib":{"date":"1994-07-13"},"text":"July 13, 1994","children":[],"tail":", which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/103/327"},"text":"Pub. L. 103–327","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd0ddd78-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd0ddd79-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/327/tII"},"text":"Pub. L. 103–327, title II","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-28"},"text":"Sept. 28, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2316"},"text":"108 Stat. 2316","children":[],"tail":", provided in part that title VIII of S. 2281, One Hundred Third Congress, as reported "},{"tag":"date","attrib":{"date":"1994-07-13"},"text":"July 13, 1994","children":[],"tail":", which is classified to this chapter, is incorporated into "},{"tag":"ref","attrib":{"href":"/us/pl/103/327"},"text":"Pub. L. 103–327","children":[],"tail":" and deemed enacted into law upon enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/103/327"},"text":"Pub. L. 103–327","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1994-09-28"},"text":"Sept. 28, 1994","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"iddd0ddd7a-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 801 of title VIII of S. 2281, One Hundred Third Congress, as reported ","children":[{"tag":"date","attrib":{"date":"1994-07-13"},"text":"July 13, 1994","children":[],"tail":", which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/103/327/tII"},"text":"Pub. L. 103–327, title II","children":[],"tail":" [title VIII, § 801], "},{"tag":"date","attrib":{"date":"1994-09-28"},"text":"Sept. 28, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2316"},"text":"108 Stat. 2316","children":[],"tail":", provided in part, that: "},{"tag":"quotedContent","attrib":{},"text":"“This title [enacting this chapter] may be cited as the ‘Single Family Mortgage Foreclosure Act of 1994’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
