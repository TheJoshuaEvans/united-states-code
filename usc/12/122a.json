{"tag":"section","attrib":{"id":"iddb191251-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s122a"},"text":null,"children":[{"tag":"num","attrib":{"value":"122a"},"text":"§ 122a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Redeemed notes of unidentifiable issue; funds charged against","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Federal Reserve bank notes redeemed by the Treasurer of the United States under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s121a"},"text":"section 121a of this title","children":[],"tail":" shall be charged against the balance of deposits for the retirement of Federal Reserve bank notes under the provisions of sections 122 and 445 "},{"tag":"ref","attrib":{"idref":"fn002021"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002021"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title; and charges for Federal Reserve notes redeemed by the Treasurer of the United States under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s121a"},"text":"section 121a of this title","children":[],"tail":" shall be apportioned among the twelve Federal Reserve banks as determined by the Board of Governors of the Federal Reserve System."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddb191252-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-06-13/ch62/s2"},"text":"June 13, 1933, ch. 62, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/128"},"text":"48 Stat. 128","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/427/s4/b"},"text":"Pub. L. 89–427, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-05-20"},"text":"May 20, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/161"},"text":"80 Stat. 161","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/325/tVI/s602/g/8/B"},"text":"Pub. L. 103–325, title VI, § 602(g)(8)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2294"},"text":"108 Stat. 2294","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb191253-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb191254-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddb191255-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s122"},"text":"Section 122 of this title","children":[],"tail":", referred to in text, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s5/b"},"text":"Pub. L. 97–258, § 5(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1068"},"text":"96 Stat. 1068","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s445"},"text":"Section 445 of this title","children":[],"tail":", referred to in text, was repealed by "},{"tag":"ref","attrib":{"href":"/us/act/1945-06-12/ch186/s3"},"text":"act June 12, 1945, ch. 186, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/59/238"},"text":"59 Stat. 238","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddb191256-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325"},"text":"Pub. L. 103–325","children":[],"tail":" struck out “National-bank notes and” before “Federal Reserve bank notes redeemed” and “national-bank notes and” after “deposits for the retirement of”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/427"},"text":"Pub. L. 89–427","children":[],"tail":" substituted provisions allowing the Board of Governors of the Federal Reserve System to determine the proper apportioning between the Federal Reserve banks of the charges for the redemption by the Treasurer of the United States of Federal Reserve notes that are unidentifiable as to bank of issue for provisions that set out the exact formula for determining the proper apportioning of charges using a proportion based upon the amount of Federal Reserve notes of each Federal Reserve bank in circulation in the 31st day of December of the year preceding the date of redemption, with the amount apportioned under the formula charged by the Treas­urer of the United States against deposit in the gold-redemption fund made by the bank or its Federal Reserve agent."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"iddb191257-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"iddb191258-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions to Secretary of the Treasury, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s55"},"text":"section 55 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
