{"tag":"section","attrib":{"id":"iddb11e649-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s74"},"text":null,"children":[{"tag":"num","attrib":{"value":"74"},"text":"§ 74.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any vacancy in the board shall be filled by appointment by the remaining directors, and any director so appointed shall hold his place until the next election.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddb11e64a-3a6f-11f1-8fa0-c065796a7f06"},"text":"(R.S. § 5148.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb11e64b-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb11e64c-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddb11e64d-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 5148 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1864-06-03/ch106/s10"},"text":"act June 3, 1864, ch. 106, § 10","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/13/102"},"text":"13 Stat. 102","children":[],"tail":", which was the National Bank Act. See "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s38"},"text":"section 38 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
