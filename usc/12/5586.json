{"tag":"section","attrib":{"id":"iddd7b92c9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5586"},"text":null,"children":[{"tag":"num","attrib":{"value":"5586"},"text":"§ 5586.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interim authority of the Secretary","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd7b92ca-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5586/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to perform the functions of the Bureau under this part until the Director of the Bureau is confirmed by the Senate in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5491"},"text":"section 5491 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd7b92cb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5586/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interim administrative services by the Department of the Treasury","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Department of the Treasury may provide administrative services necessary to support the Bureau before the designated transfer date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd7b92cc-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1066"},"text":"Pub. L. 111–203, title X, § 1066","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2055"},"text":"124 Stat. 2055","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
