{"tag":"section","attrib":{"id":"iddafc88d0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"§ 2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comptroller of the Currency; appointment; term","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Comptroller of the Currency shall be appointed by the President, by and with the advice and consent of the Senate, and shall hold his office for a term of five years unless sooner removed by the President, upon reasons to be communicated by him to the Senate.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddafc88d1-3a6f-11f1-8fa0-c065796a7f06"},"text":"(R.S. § 325; ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-23/ch614"},"text":"Aug. 23, 1935, ch. 614","children":[],"tail":", title II, § 209, "},{"tag":"ref","attrib":{"href":"/us/stat/49/707"},"text":"49 Stat. 707","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddafc88d2-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddafc88d3-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddafc88d4-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 325 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1864-06-03/ch106/s1"},"text":"act June 3, 1864, ch. 106, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/13/99"},"text":"13 Stat. 99","children":[],"tail":", which was the National Bank Act. See "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s38"},"text":"section 38 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions of this section which prescribed the annual basic compensation of the Comptroller of the Currency were omitted to conform to the provisions of the Executive Schedule. See ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5314"},"text":"section 5314 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddafc88d5-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1935—Act ","children":[{"tag":"date","attrib":{"date":"1935-08-23"},"text":"Aug. 23, 1935","children":[],"tail":", struck out “on the recommendation of the Secretary of the Treasury” after “President”, where first appearing, and changed the salary from “$5,000 a year” to “$15,000 a year”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddafc88d6-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"repeals","id":"iddafc88d7-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeals","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1949-10-15/ch695/s4"},"text":"Act Oct. 15, 1949, ch. 695, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/880"},"text":"63 Stat. 880","children":[],"tail":", formerly cited as a credit to this section, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/89/554/s8/a"},"text":"Pub. L. 89–554, § 8(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/655"},"text":"80 Stat. 655","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"iddafc88d8-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddafc88d9-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Exception as to Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions vested by any provision of law in Comptroller of the Currency, referred to in this section, were not included in transfer of functions to Secretary of the Treasury, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
