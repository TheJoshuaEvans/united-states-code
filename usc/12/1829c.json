{"tag":"section","attrib":{"id":"iddc91cf79-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1829c"},"text":"§ 1829c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Making online banking initiation legal and easy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc91cf7a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc91cf7b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Affiliate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “affiliate” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1841"},"text":"section 1841 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc91cf7c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Driver’s license","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “driver’s license” means a license issued by a State to an individual that authorizes the individual to operate a motor vehicle on public streets, roads, or highways.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc91cf7d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829c/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal bank secrecy laws","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Federal bank secrecy laws” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc91cf7e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829c/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1829b"},"text":"section 1829b of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc91cf7f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829c/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1953"},"text":"section 1953 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc91cf80-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829c/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subchapter II of chapter 53 of title 31.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc91cf81-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829c/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial institution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “financial institution” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc91cf82-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829c/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an insured depository institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc91cf83-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829c/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an insured credit union; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc91cf84-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829c/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any affiliate of an insured depository institution or insured credit union.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc91cf85-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829c/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial product or service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “financial product or service” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5481"},"text":"section 5481 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc91cf86-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829c/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Insured credit union","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “insured credit union” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1752"},"text":"section 1752 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc91cf87-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829c/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Insured depository institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “insured depository institution” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"section 1813 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc91cf88-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829c/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Online service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “online service” means any Internet-based service, such as a website or mobile application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc91cf89-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829c/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personal identification card","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “personal identification card” means an identification document issued by a State or local government to an individual solely for the purpose of identification of that individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc91cf8a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829c/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personal information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “personal information” means the information displayed on or electronically encoded on a driver’s license or personal identification card that is reasonably necessary to fulfill the purpose and uses permitted by subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc91cf8b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829c/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “scan” means the act of using a device or software to decipher, in an electronically readable format, personal information displayed on or electronically encoded on a driver’s license or personal identification card.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc91cf8c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829c/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means any State of the United States, the District of Columbia, the Commonwealth of Puerto Rico, and any other commonwealth, possession, or territory of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc91cf8d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of a driver’s license or personal identification card","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc91cf8e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"When an individual initiates a request through an online service to open an account with a financial institution or obtain a financial product or service from a financial institution, the financial institution may record personal information from a scan of the driver’s license or personal identification card of the individual, or make a copy or receive an image of the driver’s license or personal identification card of the individual, and store or retain such information in any electronic format for the purposes described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc91cf8f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses of information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as required to comply with Federal bank secrecy laws, a financial institution may only use the information obtained under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc91cf90-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829c/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to verify the authenticity of the driver’s license or personal identification card;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc91cf91-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829c/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to verify the identity of the individual; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc91cf92-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829c/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to comply with a legal requirement to record, retain, or transmit the personal information in connection with opening an account or obtaining a financial product or service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc91cf93-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deletion of image","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A financial institution that makes a copy or receives an image of a driver’s license or personal identification card of an individual in accordance with paragraphs (1) and (2) shall, after using the image for the purposes described in paragraph (2), permanently delete—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc91cf94-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829c/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any image of the driver’s license or personal identification card, as applicable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc91cf95-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829c/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any copy of any such image.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc91cf96-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829c/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure of personal information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to amend, modify, or otherwise affect any State or Federal law that governs a financial institution’s disclosure and security of personal information that is not publicly available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc91cf97-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relation to State law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of this section shall preempt and supersede any State law that conflicts with a provision of this section, but only to the extent of such conflict.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc91cf98-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/174/tII/s213"},"text":"Pub. L. 115–174, title II, § 213","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-05-24"},"text":"May 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1319"},"text":"132 Stat. 1319","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc91cf99-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc91cf9a-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddc91cf9b-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Economic Growth, Regulatory Relief, and Consumer Protection Act, and not as part of the Federal Deposit Insurance Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
