{"tag":"section","attrib":{"id":"iddcfaca4a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3026"},"text":null,"children":[{"tag":"num","attrib":{"value":"3026"},"text":"§ 3026.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceleration of the Final Government Equity Redemption Date","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcfaca4b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3026/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcfaca4c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3026/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcfaca4d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3026/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Final Government Equity Redemption Date shall occur on ","children":[{"tag":"date","attrib":{"date":"1981-12-31"},"text":"December 31, 1981","children":[],"tail":", or not later than 10 days after the date of the enactment of the first Act providing for appropriations for fiscal year 1982 (other than continuing appropriations) for the Department of Housing and Urban Development and Independent Agencies, whichever occurs later."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcfaca4e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3026/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 5 days after the Final Government Equity Redemption Date, the Secretary of the Treasury shall publish a notice in the Federal Register indicating the day on which the Final Government Equity Redemption Date occurred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcfd3b4f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3026/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcfd3b50-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3026/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Before the Final Government Equity Redemption Date, the Secretary of the Treasury shall purchase all class A stock for which the Congress has appropriated funds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcfd3b51-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3026/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" After the Final Government Equity Redemption Date, the Secretary of the Treasury shall not purchase any class A stock.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcfd3b52-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3026/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcfd3b53-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3026/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" On the Final Government Equity Redemption Date, all class A stock held by the Secretary of the Treasury on such date shall be redeemed by the Bank in exchange for class A notes which are issued by the Bank to the Secretary of the Treasury on behalf of the United States and which have a total face value equal to the total par value of the class A stock which is so redeemed, plus any unpaid dividends on such stock.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcfd3b54-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3026/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" During the period beginning on the Final Government Equity Redemption Date and ending on ","children":[{"tag":"date","attrib":{"date":"1990-12-31"},"text":"December 31, 1990","children":[],"tail":", not less than 30 percent of the revenue derived from the sale of stock by the Bank, other than the sale of class B stock or class C stock, shall be used, upon receipt, to retire class A notes."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcfd3b55-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3026/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" After ","children":[{"tag":"date","attrib":{"date":"1990-12-31"},"text":"December 31, 1990","children":[],"tail":", the Bank shall maintain a repayment schedule for class A notes which will assure full repayment of all class A notes not later than "},{"tag":"date","attrib":{"date":"2020-12-31"},"text":"December 31, 2020","children":[],"tail":". The requirement specified in the previous sentence is in addition to the requirement regarding the redemption of class A notes which is specified in "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s3014/c"},"text":"section 3014(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcfd3b56-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3026/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcfd3b57-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3026/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States shall not be responsible for any obligation of the Bank which is incurred after the Final Government Equity Redemption Date.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcfd3b58-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3026/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As soon as practicable after ","children":[{"tag":"date","attrib":{"date":"1981-08-13"},"text":"August 13, 1981","children":[],"tail":", the Board shall adopt bylaws which will assist in expediting and coordinating the activities which will occur with respect to the Final Government Equity Redemption Date."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcfd3b59-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/351/tI/s116"},"text":"Pub. L. 95–351, title I, § 116","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tIII/s391/a/1"},"text":"Pub. L. 97–35, title III, § 391(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/433"},"text":"95 Stat. 433","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcfd3b5a-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcfd3b5b-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddcfd3b5c-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of the first Act providing for appropriations for fiscal year 1982 (other than continuing appropriations) for the Department of Housing and Urban Development and Independent Agencies, referred to in subsec. (a)(1)(A), is ","children":[{"tag":"date","attrib":{"date":"1981-12-23"},"text":"Dec. 23, 1981","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/97/101"},"text":"Pub. L. 97–101","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1417"},"text":"95 Stat. 1417","children":[],"tail":", known as the Department of Housing and Urban Development—Independent Agencies Appropriation Act, 1982."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcfd3b5d-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddcfd3b5e-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tIII/s391/a/2"},"text":"Pub. L. 97–35, title III, § 391(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/434"},"text":"95 Stat. 434","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/35/tIII/s391/a/2"},"text":"“The amendment made by paragraph (1) [enacting this section] shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddcfd3b5f-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Final Government Equity Redemption Date Established","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/101/tV/s501/36"},"text":"Pub. L. 97–101, title V, § 501(36)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-23"},"text":"Dec. 23, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1440"},"text":"95 Stat. 1440","children":[],"tail":", provided in part that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/101/tV/s501/36"},"text":"“the final Government equity redemption date for the National Consumer Cooperative Bank shall occur on ","children":[{"tag":"date","attrib":{"date":"1981-12-31"},"text":"December 31, 1981","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
