{"tag":"section","attrib":{"id":"iddd01f641-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3206"},"text":null,"children":[{"tag":"num","attrib":{"value":"3206"},"text":"§ 3206.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration and enforcement","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"This chapter shall be administered and enforced by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd01f642-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3206/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Comptroller of the Currency with respect to national banks and Federal savings associations (the deposits of which are insured by the Federal Deposit Insurance Corporation),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd01f643-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3206/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Board of Governors of the Federal Reserve System with respect to State banks which are members of the Federal Reserve System, bank holding companies, and savings and loan holding companies,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd01f644-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3206/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Board of Directors of the Federal Deposit Insurance Corporation with respect to State banks which are not members of the Federal Reserve System but the deposits of which are insured by the Federal Deposit Insurance Corporation and State savings associations (the deposits of which are insured by the Federal Deposit Insurance Corporation),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd01f645-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3206/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Credit Union Administration with respect to credit unions the accounts of which are insured by the National Credit Union Administration, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd01f646-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3206/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon referral by the agencies named in the foregoing paragraphs (1) through (4), the Attorney General shall have the authority to enforce compliance by any person with this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd01f647-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/630/tII/s207"},"text":"Pub. L. 95–630, title II, § 207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3674"},"text":"92 Stat. 3674","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/73/tVII/s744/r"},"text":"Pub. L. 101–73, title VII, § 744(r)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/440"},"text":"103 Stat. 440","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/386/s8/e/1"},"text":"Pub. L. 108–386, § 8(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2232"},"text":"118 Stat. 2232","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tIII/s360/1"},"text":"Pub. L. 111–203, title III, § 360(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1548"},"text":"124 Stat. 1548","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd01f648-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd01f649-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd01f64a-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s360/1/A"},"text":"Pub. L. 111–203, § 360(1)(A)","children":[],"tail":", inserted “and Federal savings associations (the deposits of which are insured by the Federal Deposit Insurance Corporation)” before the comma."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s360/1/B"},"text":"Pub. L. 111–203, § 360(1)(B)","children":[],"tail":", substituted “, bank holding companies, and savings and loan holding companies” for “, and bank holding companies”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s360/1/C"},"text":"Pub. L. 111–203, § 360(1)(C)","children":[],"tail":", substituted “Corporation and State savings associations (the deposits of which are insured by the Federal Deposit Insurance Corporation),” for “Corporation,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"re