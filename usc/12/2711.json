{"tag":"section","attrib":{"id":"iddcf60f1b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2711"},"text":null,"children":[{"tag":"num","attrib":{"value":"2711"},"text":"§ 2711.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonapplicability of other laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any provision of law which limits the nature, amount, term, form, or rate of interest, or the nature, amount, or form of security of loans or advances of credit, loans, or advances of credit may be made in accordance with the provisions of this chapter without regard to such provision of law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddcf60f1c-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/50/tI/s110"},"text":"Pub. L. 94–50, title I, § 110","children":[],"tail":", formerly § 112, "},{"tag":"date","attrib":{"date":"1975-07-02"},"text":"July 2, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/254"},"text":"89 Stat. 254","children":[],"tail":"; renumbered § 110, "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tXIV/s1496/b/8"},"text":"Pub. L. 111–203, title XIV, § 1496(b)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2209"},"text":"124 Stat. 2209","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcf60f1d-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcf60f1e-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvi