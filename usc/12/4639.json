{"tag":"section","attrib":{"id":"iddd367430-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4639"},"text":null,"children":[{"tag":"num","attrib":{"value":"4639"},"text":"§ 4639.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public disclosure of final orders and agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd367431-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4639/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall make available to the public—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd367432-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4639/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any written agreement or other written statement for which a violation may be redressed by the Director or any modification to or termination thereof, unless the Director, in the Director’s discretion, determines that public disclosure would be contrary to the public interest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd367433-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4639/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any order that is issued with respect to any administrative enforcement proceeding initiated by the Director under this subchapter and that has become final in accordance with sections 4633 and 4634 of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd367434-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4639/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any modification to or termination of any final order made public pursuant to this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd367435-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4639/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hearings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All hearings on the record with respect to any notice of charges issued by the Director shall be open to the public, unless the Director, in the Director’s discretion, determines that holding an open hearing would be contrary to the public interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd367436-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4639/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delay of public disclosure under exceptional circumstances","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Director makes a determination in writing that the public disclosure of any final order pursuant to subsection (a) would seriously threaten the financial health or security of the regulated entity, the Director may delay the public disclosure of such order for a reasonable time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd367437-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4639/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Documents filed under seal in public enforcement hearings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may file any document or part thereof under seal in any hearing commenced by the Director if the Director determines in writing that disclosure thereof would be contrary to the public interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd367438-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4639/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retention of documents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall keep and maintain a record, for not less than 6 years, of all documents described in subsection (a) and all enforcement agreements and other supervisory actions and supporting documents issued with respect to or in connection with any enforcement proceeding initiated by the Director under this subchapter or any other law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd367439-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4639/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosures to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section may not be construed to authorize the withholding, or to prohibit the disclosure, of any information to the Congress or any committee or subcommittee thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd36743a-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXIII/s1379B"},"text":"Pub. L. 102–550, title XIII, § 1379B","children":[],"tail":", formerly § 1379, "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3993"},"text":"106 Stat. 3993","children":[],"tail":"; renumbered § 1379B and amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tI"},"text":"Pub. L. 110–289, div. A, title I","children":[],"tail":", §§ 1153(a)(1), 1156(b)(3), "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2770"},"text":"122 Stat. 2770","children":[],"tail":", 2777.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd36743b-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd36743c-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"iddd36743d-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/s1379B"},"text":"section 1379B of Pub. L. 102–550","children":[],"tail":" was renumbered section 1379D and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4641"},"text":"section 4641 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd36743e-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/s1156/b/3"},"text":"Pub. L. 110–289, § 1156(b)(3)","children":[],"tail":", substituted “regulated entity” for “enterprise”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
