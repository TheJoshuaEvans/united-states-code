{"tag":"section","attrib":{"id":"iddcc40325-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2133"},"text":null,"children":[{"tag":"num","attrib":{"value":"2133"},"text":"§ 2133.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of assets on liquidation or dissolution","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In the case of liquidation or dissolution of any bank for cooperatives, after payment or retirement, first, of all liabilities; second, of all capital stock issued before ","children":[{"tag":"date","attrib":{"date":"1956-01-01"},"text":"January 1, 1956","children":[],"tail":", at par, and all nonvoting stock at par; and third, all voting stock at par; any surplus and reserves existing on "},{"tag":"date","attrib":{"date":"1956-01-01"},"text":"January 1, 1956","children":[],"tail":", shall be paid to the holders of stock issued before that date, and voting stock pro rata; and any remaining allocated surplus and reserves shall be distributed to those entities to which they are allocated on the books of the bank, and any other remaining surplus shall be paid to the holders of outstanding voting stock. If it should become necessary to use any surplus or reserves to pay any liabilities or to retire any capital stock, unallocated reserves or surplus, allocated reserves and surplus shall be exhausted in accordance with rules prescribed by the Farm Credit Administration."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddcc64c16-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tIII/s3"},"text":"Pub. L. 92–181, title III, § 3","children":[],"tail":".12, "},{"tag":"date","attrib":{"date":"1971-12-10"},"text":"Dec. 10, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/608"},"text":"85 Stat. 608","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/205/tII/s205/e/9"},"text":"Pub. L. 99–205, title II, § 205(e)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1705"},"text":"99 Stat. 1705","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tVIII/s805"},"text":"Pub. L. 100–233, title VIII, § 805","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1716"},"text":"101 Stat. 1716","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcc64c17-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcc64c18-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcc64c19-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/233"},"text":"Pub. L. 100–233","children":[],"tail":" inserted “the” before “Farm Credit Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/205"},"text":"Pub. L. 99–205","children":[],"tail":" struck out “, any stock held by the Governor of the Farm Credit Administration at par” before “, and all nonvoting stock at par”, and struck out “stock held by the Governor of the Farm Credit Administration,” before “and voting stock pro rata” in first sentence."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcc64c1a-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcc64c1b-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1985 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/205"},"text":"Pub. L. 99–205","children":[],"tail":" effective thirty days after "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/205/s401"},"text":"section 401 of Pub. L. 99–205","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2001"},"text":"section 2001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
