{"tag":"section","attrib":{"id":"iddce7b87d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279f"},"text":null,"children":[{"tag":"num","attrib":{"value":"2279f"},"text":"§ 2279f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Merger of similar banks","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddce7b87e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Banks organized or operating under this chapter may merge with banks in other districts operating under the same subchapter if the plan of merger is approved by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce7b87f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279f/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Farm Credit Administration Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce7b880-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279f/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the respective Boards of Directors of the banks involved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce7b881-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279f/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a majority vote of the stockholders of each bank voting, in person or by proxy, at a duly authorized stockholders’ meeting, with each association having a number of votes equal to the number of such association’s voting stockholders; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce7b882-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279f/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a bank for cooperatives, a majority of the total equity interests in such merging bank for cooperatives (including allocated, but not unallocated, surplus and reserves) held by those stockholders or subscribers to the guaranty fund of the bank voting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce7b883-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers and capitalization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Sections 2279a–2 and 2279a–3 of this title shall apply to banks merged under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce7b884-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board of directors","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce7b885-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279f/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After a merger under subsection (a), a board of directors shall be created for the resulting bank.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce7b886-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279f/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The board shall be composed of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddce7b887-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279f/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two directors elected by each of the bank boards, with at least one such director from each bank being elected by the eligible stockholders of, or subscribers to, the guaranty fund of the merging banks; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce7b888-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279f/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one outside director elected by the directors elected under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce7b889-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279f/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outside director","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddce7b88a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279f/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The outside director elected under paragraph (2)(B) shall be experienced in financial services and credit, and within the 2-year period prior to such election, shall not have been a borrower from, shareholder in, or director, officer, employee, or agent of any institution of the Farm Credit System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce7b88b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279f/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to elect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the other members of the board fail to elect an outside director, the Farm Credit Administration Board shall appoint a qualified person to serve on the board of directors until such member is so elected.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce7b88c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279f/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bylaws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraph (2), the bylaws of the merged bank may, with the approval of the Farm Credit Administration, provide for a different number of directors to be selected in a different manner, except that the bylaws shall provide for at least one outside director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddce7b88d-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tVII/s7"},"text":"Pub. L. 92–181, title VII, § 7","children":[],"tail":".12, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tIV/s416"},"text":"Pub. L. 100–233, title IV, § 416","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1652"},"text":"101 Stat. 1652","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/tIV/s408/q"},"text":"Pub. L. 100–399, title IV, § 408(q)","children":[],"tail":", (r), "},{"tag":"date","attrib":{"date":"1988-08-17"},"text":"Aug. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1002"},"text":"102 Stat. 1002","children":[],"tail":", 1003.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddce7b88e-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddce7b88f-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddce7b890-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s408/q"},"text":"Pub. L. 100–399, § 408(q)","children":[],"tail":", substituted “Powers and capitalization” for “Procedures” in heading and, in amending text generally, substituted “Sections 2279a–2 and 2279a–3 of this title” for “The provisions of sections 2279a–2 through 2279a–4 of this title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s408/r"},"text":"Pub. L. 100–399, § 408(r)","children":[],"tail":", substituted “directors” for “members”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddce7b891-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddce7b892-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399"},"text":"Pub. L. 100–399","children":[],"tail":" effective as if enacted immediately after enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/100/233"},"text":"Pub. L. 100–233","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/s1001/a"},"text":"section 1001(a) of Pub. L. 100–399","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2002"},"text":"section 2002 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
