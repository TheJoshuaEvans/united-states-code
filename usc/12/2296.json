{"tag":"section","attrib":{"id":"iddceee324-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2296"},"text":null,"children":[{"tag":"num","attrib":{"value":"2296"},"text":"§ 2296.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increase not authorized in amounts of obligations issued, sold, or guaranteed by Federal agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed as authorizing an increase in the amounts of obligations issued, sold, or guaranteed by any Federal agency which issues, sells, or guarantees obligations purchased by the Bank.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddceee325-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/224/s18"},"text":"Pub. L. 93–224, § 18","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-12-29"},"text":"Dec. 29, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/942"},"text":"87 Stat. 942","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
