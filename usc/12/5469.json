{"tag":"section","attrib":{"id":"iddd6aca6d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5469"},"text":null,"children":[{"tag":"num","attrib":{"value":"5469"},"text":"§ 5469.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rulemaking","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Board of Governors, the Supervisory Agencies, and the Council are authorized to prescribe such rules and issue such orders as may be necessary to administer and carry out their respective authorities and duties granted under this subchapter and prevent evasions thereof.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd6aca6e-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tVIII/s810"},"text":"Pub. L. 111–203, title VIII, § 810","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1820"},"text":"124 Stat. 1820","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
