{"tag":"section","attrib":{"id":"iddc244059-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1732"},"text":null,"children":[{"tag":"num","attrib":{"value":"1732"},"text":"§ 1732.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separability","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If any provision of this chapter, or the application thereof to any person or circumstances, is held invalid, the remainder of the chapter, and the application of such provision to other persons or circumstances, shall not be affected thereby.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc24405a-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-27/ch847"},"text":"June 27, 1934, ch. 847","children":[],"tail":", title V, § 513A, formerly § 513, "},{"tag":"ref","attrib":{"href":"/us/stat/48/1265"},"text":"48 Stat. 1265","children":[],"tail":"; renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/98/479/tII/s204/a/19"},"text":"Pub. L. 98–479, title II, § 204(a)(19)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-17"},"text":"Oct. 17, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2232"},"text":"98 Stat. 2232","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc24405b-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc24405c-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddc24405d-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"References in Other Laws","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/479/tII/s204/a/19"},"text":"Pub. L. 98–479, title II, § 204(a)(19)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-17"},"text":"Oct. 17, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2232"},"text":"98 Stat. 2232","children":[],"tail":", provided in part that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/479/tII/s204/a/19"},"text":"“Any reference in any law, regulation, order, document, record, or other paper of the United States to the section redesignated in this paragraph [this section] hereby is deemed to refer to section 513A of the National Housing Act [this section].”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
