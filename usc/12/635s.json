{"tag":"section","attrib":{"id":"iddb655c95-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635s"},"text":null,"children":[{"tag":"num","attrib":{"value":"635s"},"text":"§ 635s.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddb655c96-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635s/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb655c97-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635s/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Advisory Council on International Monetary and Financial Policies shall coordinate the implementation of the tied aid credit programs authorized by sections 635q and 635r of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb655c98-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635s/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No financing may be approved under the tied aid credit programs authorized by section 635q or 635r of this title without the unanimous consent of the members of the National Advisory Council on International Monetary and Financial Policies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb655c99-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635s/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Trade and Development Agency shall be represented at any meetings of the National Advisory Council on International Monetary and Financial Policies for discussion of tied aid credit matters, and the representative of the Trade and Development Agency at any such meeting shall have the right to vote on any decisions of the Advisory Council relating to tied aid credit matters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddb655c9a-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/181/tI"},"text":"Pub. L. 98–181, title I","children":[],"tail":" [title VI, § 646], "},{"tag":"date","attrib":{"date":"1983-11-30"},"text":"Nov. 30, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1265"},"text":"97 Stat. 1265","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tII/s2204/c/2"},"text":"Pub. L. 100–418, title II, § 2204(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1331"},"text":"102 Stat. 1331","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/549/tII/s202/c/1"},"text":"Pub. L. 102–549, title II, § 202(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3658"},"text":"106 Stat. 3658","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb655c9b-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb655c9c-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddb655c9d-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (b). ","children":[{"tag":