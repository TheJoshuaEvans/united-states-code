{"tag":"section","attrib":{"id":"iddd150911-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4004"},"text":null,"children":[{"tag":"num","attrib":{"value":"4004"},"text":"§ 4004.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure of funds availability policies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd150912-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4004/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice for new accounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before an account is opened at a depository institution, the depository institution shall provide written notice to the potential customer of the specific policy of such depository institution with respect to when a customer may withdraw funds deposited into the customer’s account.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd150913-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4004/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preprinted deposit slips","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All preprinted deposit slips that a depository institution furnishes to its customers shall contain a summary notice, as prescribed by the Board, jointly with the Director of the Bureau of Consumer Financial Protection, in regulations, that deposited items may not be available for immediate withdrawal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd150914-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4004/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mailing of notice","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd150915-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4004/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" First mailing after enactment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the first regularly scheduled mailing to customers occurring after ","children":[{"tag":"date","attrib":{"date":"1988-09-01"},"text":"September 1, 1988","children":[],"tail":", but not more than 60 days after "},{"tag":"date","attrib":{"date":"1988-09-01"},"text":"September 1, 1988","children":[],"tail":", each depository institution shall send a written notice containing the specific policy of such depository institution with respect to when a customer may withdraw funds deposited into such customer’s account, unless the depository institution has provided a disclosure which meets the requirements of this section before "},{"tag":"date","attrib":{"date":"1988-09-01"},"text":"September 1, 1988","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd150916-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4004/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequent changes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A depository institution shall send a written notice to customers at least 30 days before implementing any change to the depository institution’s policy with respect to when customers may withdraw funds deposited into consumer accounts, except that any change which expedites the availability of such funds shall be disclosed not later than 30 days after implementation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd150917-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4004/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Upon request","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon the request of any person, a depository institution shall provide or send such person a written notice containing the specific policy of such depository institution with respect to when a customer may withdraw funds deposited into a customer’s account.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd150918-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4004/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Posting of notice","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd150919-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4004/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific notice at manned teller stations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each depository institution shall post, in a conspicuous place in each location where deposits are accepted by individuals employed by such depository institution, a specific notice which describes the time periods applicable to the availability of funds deposited in a consumer account.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd15091a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4004/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General notice at automated teller machines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any automated teller machine at which any funds are received for deposit in an account at any depository institution, the Board, jointly with the Director of the Bureau of Consumer Financial Protection, shall prescribe, by regulations, that the owner or operator of such automated teller machine shall post or provide a general notice that funds deposited in such machine may not be immediately available for withdrawal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd15091b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4004/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of interest payment policy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a depository institution described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4005/b"},"text":"section 4005(b) of this title","children":[],"tail":" begins the accrual of interest or dividends at a later date than the date described in "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4005/a"},"text":"section 4005(a) of this title","children":[],"tail":" with respect to all funds, including cash, deposited in an interest-bearing account at such depository institution, any notice required to be provided under subsections (a) and (c) shall contain a written description of the time at which such depository institution begins to accrue interest or dividends on such funds."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd15091c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4004/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Model disclosure forms","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd15091d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4004/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prepared by Board and Bureau","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board, jointly with the Director of the Bureau of Consumer Financial Protection, shall publish model disclosure forms and clauses for common transactions to facilitate compliance with the disclosure requirements of this section and to aid customers by utilizing readily understandable language.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd15091e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4004/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of forms to achieve compliance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A depository institution shall be deemed to be in compliance with the requirements of this section if such institution—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd15091f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4004/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uses any appropriate model form or clause as published by the Board, jointly with the Director of the Bureau of Consumer Financial Protection,,","children":[{"tag":"ref","attrib":{"idref":"fn002363"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002363"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd150920-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4004/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" uses any such model form or clause and changes such form or clause by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd150921-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4004/f/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deleting any information which is not required by this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd150922-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4004/f/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rearranging the format.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd150923-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4004/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary use","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter requires the use of any such model form or clause prescribed by the Board, jointly with the Director of the Bureau of Consumer Financial Protection, under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd150924-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4004/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice and comment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Model disclosure forms and clauses shall be adopted by the Board, jointly with the Director of the Bureau of Consumer Financial Protection, only after notice duly given in the Federal Register and an opportunity for public comment in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd150925-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/86/tVI/s605"},"text":"Pub. L. 100–86, title VI, § 605","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-08-10"},"text":"Aug. 10, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/644"},"text":"101 Stat. 644","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1086/c"},"text":"Pub. L. 111–203, title X, § 1086(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2086"},"text":"124 Stat. 2086","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd150926-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd150927-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd150928-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"After enactment, referred to in the heading of subsec. (c)(1), probably means after the effective date of this section, which is ","children":[{"tag":"date","attrib":{"date":"1988-09-01"},"text":"Sept. 1, 1988","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd150929-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsecs. (b), (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1086/c/1"},"text":"Pub. L. 111–203, § 1086(c)(1)","children":[],"tail":", inserted “, jointly with the Director of the Bureau of Consumer Financial Protection,” after “Board”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1086/c/2"},"text":"Pub. L. 111–203, § 1086(c)(2)","children":[],"tail":", inserted “and Bureau” after “Board” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1086/c/1"},"text":"Pub. L. 111–203, § 1086(c)(1)","children":[],"tail":", inserted “, jointly with the Director of the Bureau of Consumer Financial Protection,” after “Board”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2)(A), (3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1086/c/1"},"text":"Pub. L. 111–203, § 1086(c)(1)","children":[],"tail":", inserted “, jointly with the Director of the Bureau of Consumer Financial Protection,” after “Board”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd15092a-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd15092b-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective on the designated transfer date, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1100H"},"text":"section 1100H of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd15092c-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1988-09-01"},"text":"Sept. 1, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/86/s613/b"},"text":"section 613(b) of Pub. L. 100–86","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4001"},"text":"section 4001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
