{"tag":"section","attrib":{"id":"iddd76d86f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5565"},"text":null,"children":[{"tag":"num","attrib":{"value":"5565"},"text":"§ 5565.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relief available","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd76d870-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5565/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative proceedings or court actions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd76d871-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5565/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The court (or the Bureau, as the case may be) in an action or adjudication proceeding brought under Federal consumer financial law, shall have jurisdiction to grant any appropriate legal or equitable relief with respect to a violation of Federal consumer financial law, including a violation of a rule or order prescribed under a Federal consumer financial law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd76d872-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5565/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relief","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Relief under this section may include, without limitation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd76d873-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5565/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rescission or reformation of contracts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd76d874-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5565/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" refund of moneys or return of real property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd76d875-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5565/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" restitution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd76d876-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5565/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disgorgement or compensation for unjust enrichment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd76d877-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5565/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payment of damages or other monetary relief;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd76d878-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5565/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public notification regarding the violation, including the costs of notification;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd76d879-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5565/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limits on the activities or functions of the person; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd76d87a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5565/a/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" civil money penalties, as set forth more fully in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd76d87b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5565/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No exemplary or punitive damages","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection shall be construed as authorizing the imposition of exemplary or punitive damages.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd76d87c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5565/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery of costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any action brought by the Bureau, a State attorney general, or any State regulator to enforce any Federal consumer financial law, the Bureau, the State attorney general, or the State regulator may recover its costs in connection with prosecuting such action if the Bureau, the State attorney general, or the State regulator is the prevailing party in the action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd76d87d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5565/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil money penalty in court and administrative actions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd76d87e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5565/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person that violates, through any act or omission, any provision of Federal consumer financial law shall forfeit and pay a civil penalty pursuant to this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd76d87f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5565/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty amounts","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd76d880-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5565/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" First tier","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For any violation of a law, rule, or final order or condition imposed in writing by the Bureau, a civil penalty may not exceed $5,000 for each day during which such violation or failure to pay continues.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd76d881-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5565/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Second tier","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraph (A), for any person that recklessly engages in a violation of a Federal consumer financial law, a civil penalty may not exceed $25,000 for each day during which such violation continues.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd76d882-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5565/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Third tier","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subparagraphs (A) and (B), for any person that knowingly violates a Federal consumer financial law, a civil penalty may not exceed $1,000,000 for each day during which such violation continues.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd76d883-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5565/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mitigating factors","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining the amount of any penalty assessed under paragraph (2), the Bureau or the court shall take into account the appropriateness of the penalty with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd76d884-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5565/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the size of financial resources and good faith of the person charged;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd76d885-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5565/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the gravity of the violation or failure to pay;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd76d886-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5565/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the severity of the risks to or losses of the consumer, which may take into account the number of products or services sold or provided;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd76d887-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5565/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the history of previous violations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd76d888-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5565/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other matters as justice may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd76d889-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5565/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to modify or remit penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Bureau may compromise, modify, or remit any penalty which may be assessed or had already been assessed under paragraph (2). The amount of such penalty, when finally determined, shall be exclusive of any sums owed by the person to the United States in connection with the costs of the proceeding, and may be deducted from any sums owing by the United States to the person charged.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd76d88a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5565/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice and hearing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No civil penalty may be assessed under this subsection with respect to a violation of any Federal consumer financial law, unless—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd76d88b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5565/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Bureau gives notice and an opportunity for a hearing to the person accused of the violation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd76d88c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5565/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriate court has ordered such assessment and entered judgment in favor of the Bureau.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd76d88d-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1055"},"text":"Pub. L. 111–203, title X, § 1055","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2029"},"text":"124 Stat. 2029","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd76d88e-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd76d88f-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd76d890-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the designated transfer date, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1058"},"text":"section 1058 of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5561"},"text":"section 5561 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
