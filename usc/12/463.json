{"tag":"section","attrib":{"id":"iddb4419ac-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s463"},"text":null,"children":[{"tag":"num","attrib":{"value":"463"},"text":"§ 463.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on amount of balance with any depository institution without access to Federal Reserve advances","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No member bank shall keep on deposit with any depository institution which is not authorized to have access to Federal Reserve advances under section 347b ","children":[{"tag":"ref","attrib":{"idref":"fn002047"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002047"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title a sum in excess of 10 per centum of its own paid-up capital and surplus."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddb4419ad-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1913-12-23/ch6/s19/e"},"text":"Dec. 23, 1913, ch. 6, § 19(e)","children":[],"tail":", formerly § 19 (par. 8), "},{"tag":"ref","attrib":{"href":"/us/stat/38/270"},"text":"38 Stat. 270","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1914-08-15/ch252"},"text":"Aug. 15, 1914, ch. 252","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/691"},"text":"38 Stat. 691","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1917-06-21/ch32/s10"},"text":"June 21, 1917, ch. 32, § 10","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/40/239"},"text":"40 Stat. 239","children":[],"tail":"; renumbered § 19(e), "},{"tag":"ref","attrib":{"href":"/us/pl/89/597/s2/b"},"text":"Pub. L. 89–597, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-21"},"text":"Se