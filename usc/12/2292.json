{"tag":"section","attrib":{"id":"iddceee310-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2292"},"text":null,"children":[{"tag":"num","attrib":{"value":"2292"},"text":"§ 2292.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report to the President and Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Bank shall, as soon as practicable after the end of each fiscal year, transmit to the President and the Congress an annual report of its operations and activities.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddceee311-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/224/s13"},"text":"Pub. L. 93–224, § 13","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-12-29"},"text":"Dec. 29, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/941"},"text":"87 Stat. 941","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
