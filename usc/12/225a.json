{"tag":"section","attrib":{"id":"iddb24f889-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s225a"},"text":null,"children":[{"tag":"num","attrib":{"value":"225a"},"text":"§ 225a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of long run growth of monetary and credit aggregates","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Board of Governors of the Federal Reserve System and the Federal Open Market Committee shall maintain long run growth of the monetary and credit aggregates commensurate with the economy’s long run potential to increase production, so as to promote effectively the goals of maximum employment, stable prices, and moderate long-term interest rates.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddb24f88a-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1913-12-23/ch6/s2A"},"text":"Dec. 23, 1913, ch. 6, § 2A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/188/tII/s202"},"text":"Pub. L. 95–188, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-11-16"},"text":"Nov. 16, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1387"},"text":"91 Stat. 1387","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/523/tI/s108/a"},"text":"Pub. L. 95–523, title I, § 108(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-27"},"text":"Oct. 27, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1897"},"text":"92 Stat. 1897","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tIII/s3005/c"},"text":"Pub. L. 100–418, title III, § 3005(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1375"},"text":"102 Stat. 1375","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/tX/s1003/a"},"text":"Pub. L. 106–569, title X, § 1003(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/3028"},"text":"114 Stat. 3028","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb24f88b-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb24f88c-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddb24f88d-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/188/s202"},"text":"section 202 of Pub. L. 95–188","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s302"},"text":"section 302 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddb24f88e-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/569"},"text":"Pub. L. 106–569","children":[],"tail":" struck out provisions after first sentence relating to annual reports to Congress, transmittal of reports to Congressional Committees, consultations with Committees, report of Committee, changing conditions affecting achievement of objectives and plans, and explanation for deviations from objectives and plans."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418"},"text":"Pub. L. 100–418","children":[],"tail":" inserted “, including an analysis of the impact of the exchange rate of the dollar on those trends” after “the Nation” in cl. (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/523"},"text":"Pub. L. 95–523","children":[],"tail":" substituted provisions relating to independent written reports of the Board of Governors to the Congress for provisions relating to the consultations of the Board of Governors with Congress at semi-annual hearings, substituted “the objectives and plans with respect to the ranges” for “such ranges”, inserted “of the monetary and credit aggregates disclosed in the reports submitted under this section” after “growth or diminution”, and inserted proviso respecting the inclusion of an explanation of reasons for revisions or deviations in subsequent consultations and reports."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddb24f88f-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddb24f890-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/523/tI/s108/b"},"text":"Pub. L. 95–523, title I, § 108(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-27"},"text":"Oct. 27, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1898"},"text":"92 Stat. 1898","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/523/tI/s108/b"},"text":"“The amendment made by subsection (a) [amending this section] takes effect on ","children":[{"tag":"date","attrib":{"date":"1979-01-01"},"text":"January 1, 1979","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
