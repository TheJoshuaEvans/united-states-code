{"tag":"section","attrib":{"id":"iddd52fd7d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5329"},"text":null,"children":[{"tag":"num","attrib":{"value":"5329"},"text":"§ 5329.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Resolution of supervisory jurisdictional disputes among member agencies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd52fd7e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5329/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Request for Council recommendation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall seek to resolve a dispute among 2 or more member agencies, if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd52fd7f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5329/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member agency has a dispute with another member agency about the respective jurisdiction over a particular bank holding company, nonbank financial company, or financial activity or product (excluding matters for which another dispute mechanism specifically has been provided under title X); ","children":[{"tag":"ref","attrib":{"idref":"fn002471"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002471"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd52fd80-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5329/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Council determines that the disputing agencies cannot, after a demonstrated good faith effort, resolve the dispute without the intervention of the Council; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd52fd81-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5329/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any of the member agencies involved in the dispute—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd52fd82-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5329/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides all other disputants prior notice of the intent to request dispute resolution by the Council; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd52fd83-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5329/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requests in writing, not earlier than 14 days after providing the notice described in subparagraph (A), that the Council seek to resolve the dispute.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd52fd84-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5329/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Council recommendation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall seek to resolve each dispute described in subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd52fd85-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5329/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within a reasonable time after receiving the dispute resolution request;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd52fd86-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5329/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after consideration of relevant information provided by each agency party to the dispute; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd52fd87-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5329/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by agreeing with 1 of the disputants regarding the entirety of the matter, or by determining a compromise position.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd52fd88-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5329/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of recommendation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any Council recommendation under this section shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd52fd89-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5329/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be in writing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd52fd8a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5329/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include an explanation of the reasons therefor; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd52fd8b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5329/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be approved by the affirmative vote of ⅔ of the voting members of the Council then serving.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd52fd8c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5329/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonbinding effect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any recommendation made by the Council under subsection (c) shall not be binding on the Federal agencies that are parties to the dispute.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd52fd8d-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tI/s119"},"text":"Pub. L. 111–203, title I, § 119","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1408"},"text":"124 Stat. 1408","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd52fd8e-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd52fd8f-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd52fd90-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Title X, referred to in subsec. (a)(1), is title X of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1955"},"text":"124 Stat. 1955","children":[],"tail":", known as the Consumer Financial Protection Act of 2010, which enacted subchapter V (§ 5481 et seq.) of this chapter and enacted, amended, and repealed numerous other sections and notes in the Code. For complete classification of title X to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
