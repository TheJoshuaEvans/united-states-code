{"tag":"section","attrib":{"id":"iddcde1a1f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–8"},"text":null,"children":[{"tag":"num","attrib":{"value":"2277a–8"},"text":"§ 2277a–8.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conduct of corporate affairs; examination of System institutions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcde1a20-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–8/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conduct of corporate affairs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcde1a21-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–8/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fair administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board of Directors shall administer the affairs of the Corporation fairly and impartially and without discrimination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcde1a22-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–8/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Obligations and expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board of Directors shall determine and prescribe the manner in which the obligations of the Corporation may be incurred and the expenses of the Corporation may be allowed and paid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcde1a23-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–8/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of mails","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation may use the United States mails in the same manner and under the same conditions as the executive departments of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcde1a24-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–8/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation, with the consent of any board, commission, independent establishment, or executive department of the Federal Government, including any field service thereof, may avail itself of the use of information, services, and facilities thereof in carrying out this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcde1a25-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–8/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of Farm Credit Administration personnel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent practicable, the Corporation shall use the personnel and resources of the Farm Credit Administration to minimize duplication of effort and to reduce costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcde1a26-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–8/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Examination of System institutions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcde1a27-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–8/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Examination authority","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcde1a28-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–8/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Board of Directors considers it necessary to examine an insured System bank, a production credit association, an association making direct loans under the authority provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2279b"},"text":"section 2279b of this title","children":[],"tail":", or any System institution in receivership, the Board may, using Farm Credit Administration examiners, conduct the examination using reports and other information on the System institution prepared or held by the Farm Credit Administration. Notwithstanding any other provision of this chapter, on cancellation of the charter of a System institution, the Corporation shall have authority to examine the system "},{"tag":"ref","attrib":{"idref":"fn002304"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002304"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be capitalized."}],"tail":" institution in receivership. An examination shall be performed at such intervals as the Corporation shall determine."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcde1a29-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–8/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Request for additional examination or other information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Board determines that such reports or information are not adequate to enable the Corporation to carry out the duties of the Corporation under this subsection, the Board shall request the Farm Credit Administration to examine or to obtain other information from or about the System institution and provide to the Corporation the resulting examination report or such other information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcde1a2a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–8/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment of examiners","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Farm Credit Administration informs the Corporation that the Farm Credit Administration is unable to comply with a request made under paragraph (1)(B) with respect to a System institution, the Board may appoint examiners to examine the institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcde1a2b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–8/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers and report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each examiner appointed under paragraph (2) shall make such examination of the affairs of the System institution as the Board may direct, and shall make a full and detailed report of the examination to the Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcde1a2c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–8/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment of claim agents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board of Directors of the Corporation shall appoint claim agents who may investigate and examine all claims for insured obligations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcde1a2d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–8/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oath, affirmations, and testimony","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In connection with examinations under this section, the Corporation or its designated representatives may administer oaths and affirmations, and may examine, take, and preserve testimony under oath, as to any matter with respect to the affairs of any such institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcde1a2e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–8/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation with FCA examiners","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The examiners appointed by the Board of Directors shall cooperate to the maximum extent possible with examiners of the Farm Credit Administration to minimize duplication of effort and minimize costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcde1a2f-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tV/s5"},"text":"Pub. L. 92–181, title V, § 5","children":[],"tail":".59, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tIII/s302"},"text":"Pub. L. 100–233, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1615"},"text":"101 Stat. 1615","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/220/s6/b/3"},"text":"Pub. L. 101–220, § 6(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-12"},"text":"Dec. 12, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1880"},"text":"103 Stat. 1880","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/552/tII/s203"},"text":"Pub. L. 102–552, title II, § 203","children":[],"tail":", title V, § 513(a), "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4106"},"text":"106 Stat. 4106","children":[],"tail":", 4133; "},{"tag":"ref","attrib":{"href":"/us/pl/104/105/tII/s216"},"text":"Pub. L. 104–105, title II, § 216","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/179"},"text":"110 Stat. 179","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcde1a30-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcde1a31-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcde1a32-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/105"},"text":"Pub. L. 104–105","children":[],"tail":" inserted at end “Notwithstanding any other provision of this chapter, on cancellation of the charter of a System institution, the Corporation shall have authority to examine the system institution in receivership. An examination shall be performed at such intervals as the Corporation shall determine.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/552/s513/a/1"},"text":"Pub. L. 102–552, § 513(a)(1)","children":[],"tail":", substituted “System institutions” for “insured System banks” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/552/s203"},"text":"Pub. L. 102–552, § 203","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/552/s513/a/2"},"text":"Pub. L. 102–552, § 513(a)(2)","children":[],"tail":", added subsec. (b) and struck out former subsec. (b) which read as follows: “(b) "},{"tag":"inline","attrib":{},"text":"Examination of Insured System Banks.—","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) ","children":[{"tag":"inline","attrib":{},"text":"Appointment of examiners","children":[],"tail":".—The Board of Directors may appoint examiners who may, on behalf of the Corporation, examine any insured System bank, any production credit association, any other association making direct loans under authority provided under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2279b"},"text":"section 2279b of this title","children":[],"tail":", and any System institution in receivership, if in the judgment of the Board of Directors an examination of the institution is necessary."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) ","children":[{"tag":"inline","attrib":{},"text":"Powers and report","children":[],"tail":".—Each examiner may make a thorough examination of all affairs of the institution, and shall make a full and detailed report of the condition of the institution to the Corporation."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) ","children":[{"tag":"inline","attrib":{},"text":"Appointment of claim agents","children":[],"tail":".—The Board of Directors, in like manner, shall appoint claim agents who may investigate and examine all claims for insured obligations.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/220"},"text":"Pub. L. 101–220","children":[],"tail":" inserted “any other association making direct loans under authority provided under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2279b"},"text":"section 2279b of this title","children":[],"tail":",” after “any production credit association,”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcde1a33-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcde1a34-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/220"},"text":"Pub. L. 101–220","children":[],"tail":" effective for insurance premiums due to the Farm Credit System Insurance Corporation under this chapter on or after "},{"tag":"date","attrib":{"date":"1990-01-01"},"text":"Jan. 1, 1990","children":[],"tail":", based on the loan volume of each bank for each calendar year beginning with calendar year 1989, and effective for the calculation of the initial premium payment required under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2277a–5/c"},"text":"section 2277a–5(c) of this title","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/220/s6/c"},"text":"section 6(c) of Pub. L. 101–220","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2020"},"text":"section 2020 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
