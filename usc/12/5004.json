{"tag":"section","attrib":{"id":"iddd44a479-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5004"},"text":null,"children":[{"tag":"num","attrib":{"value":"5004"},"text":"§ 5004.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Substitute check warranties","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"A bank that transfers, presents, or returns a substitute check and receives consideration for the check warrants, as a matter of law, to the transferee, any subsequent collecting or returning bank, the depositary bank, the drawee, the drawer, the payee, the depositor, and any endorser (regardless of whether the warrantee receives the substitute check or another paper or electronic form of the substitute check or original check) that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd44a47a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5004/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the substitute check meets all the requirements for legal equivalence under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5003/b"},"text":"section 5003(b) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd44a47b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5004/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no depositary bank, drawee, drawer, or endorser will receive presentment or return of the substitute check, the original check, or a copy or other paper or electronic version of the substitute check or original check such that the bank, drawee, drawer, or endorser will be asked to make a payment based on a check that the bank, drawee, drawer, or endorser has already paid.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd44a47c-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/100/s5"},"text":"Pub. L. 108–100, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-10-28"},"text":"Oct. 28, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1181"},"text":"117 Stat. 1181","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd44a47d-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd44a47e-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd44a47f-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective at the end of the 12-month period beginning on ","children":[{"tag":"date","attrib":{"date":"2003-10-28"},"text":"Oct. 28, 2003","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/100/s20"},"text":"section 20 of Pub. L. 108–100","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5001"},"text":"section 5001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
