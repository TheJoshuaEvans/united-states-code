{"tag":"section","attrib":{"id":"iddcf85978-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2908"},"text":null,"children":[{"tag":"num","attrib":{"value":"2908"},"text":"§ 2908.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small bank regulatory relief","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcf85979-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2908/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsections (b) and (c), any regulated financial institution with aggregate assets of not more than $250,000,000 shall be subject to routine examination under this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcf8597a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2908/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than once every 60 months for an institution that has achieved a rating of “outstanding record of meeting community credit needs” at its most recent examination under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2903"},"text":"section 2903 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf8597b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2908/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than once every 48 months for an institution that has received a rating of “satisfactory record of meeting community credit needs” at its most recent examination under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2903"},"text":"section 2903 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf8597c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2908/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as deemed necessary by the appropriate Federal financial supervisory agency, for an institution that has received a rating of less than “satisfactory record of meeting community credit needs” at its most recent examination under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2903"},"text":"section 2903 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcf8597d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2908/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No exception from CRA examinations in connection with applications for deposit facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A regulated financial institution described in subsection (a) shall remain subject to examination under this chapter in connection with an application for a deposit facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcf8597e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2908/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discretion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A regulated financial institution described in subsection (a) may be subject to more frequent or less frequent examinations for reasonable cause under such circumstances as may be determined by the appropriate Federal financial supervisory agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcf8597f-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/128/tVIII/s809"},"text":"Pub. L. 95–128, title VIII, § 809","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/102/tVII/s712"},"text":"Pub. L. 106–102, title VII, § 712","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1469"},"text":"113 Stat. 1469","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
