{"tag":"section","attrib":{"id":"iddcc19203-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2091"},"text":null,"children":[{"tag":"num","attrib":{"value":"2091"},"text":"§ 2091.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organizations; articles; charters; powers of the Farm Credit Administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcc19204-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2091/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Charter","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Federal land bank association shall continue as a federally chartered instrumentality of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcc19205-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2091/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organization","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcc19206-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2091/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Federal land bank association may be organized by any group of 10 or more persons desiring to borrow money from a Farm Credit Bank under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2015/a"},"text":"section 2015(a) of this title","children":[],"tail":", including persons to whom the Farm Credit Bank has made a loan directly or through an agent and has taken as security real estate located in the territory proposed to be served by the association."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc19207-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2091/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Articles of association","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcc19208-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2091/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Description of territory","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The articles of association shall describe the territory within which the association proposes to carry on its operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcc19209-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2091/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission to FCB","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Proposed articles shall be forwarded to the Farm Credit Bank for the district, accompanied by an agreement to subscribe on behalf of the association for stock in accordance with the bylaws of the Farm Credit Bank.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcc1920a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2091/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stock purchase","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Association stock may be paid for by surrendering for cancellation stock in the bank held by a borrower and the issuance of an equivalent amount of stock to such borrower in the association.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcc1920b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2091/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The articles shall be accompanied by a statement signed by each of the members of the proposed association establishing—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddcc1920c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2091/b/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual’s eligibility and request for a Farm Credit Bank loan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcc1920d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2091/b/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the real estate with respect to which the individual desires the loan for is not being served by another Federal land bank association; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcc1920e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2091/b/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the individual is or will become a stockholder in the proposed association.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcc1920f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2091/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission to FCA","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A copy of the articles of association shall be forwarded to the Farm Credit Administration with the recommendations of the bank concerning the need for the proposed association in order to adequately serve the credit needs of eligible persons in the proposed territory and a statement as to whether or not the territory includes any territory described in the charter of another Federal land bank association.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc19210-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2091/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Denials of charters","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Farm Credit Administration for good cause shown may deny the charter applied for.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc19211-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2091/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of articles","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On the approval of the proposed articles by the Farm Credit Administration and the issuance of such charter, the association shall become as of such date a federally chartered body corporate and an instrumentality of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcc19212-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2091/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" FCA authority on organization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Farm Credit Administration shall have power, in the terms of the charter, under rules and regulations prescribed by the Farm Credit Administration—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcc19213-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2091/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide for the organization of the association;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc19214-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2091/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide for the initial amount of stock of the association;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc19215-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2091/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide for the territory within which the association may carry on its operations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc19216-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2091/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to approve amendments to the charter of such association.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcc19217-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tII/s2"},"text":"Pub. L. 92–181, title II, § 2","children":[],"tail":".10, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tIV/s401"},"text":"Pub. L. 100–233, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1634"},"text":"101 Stat. 1634","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/tIV/s401/s"},"text":"Pub. L. 100–399, title IV, § 401(s)","children":[],"tail":", (t), "},{"tag":"date","attrib":{"date":"1988-08-17"},"text":"Aug. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/998"},"text":"102 Stat. 998","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcc19218-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcc19219-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"iddcc1921a-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2091, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tII/s2"},"text":"Pub. L. 92–181, title II, § 2","children":[],"tail":".10, "},{"tag":"date","attrib":{"date":"1971-12-10"},"text":"Dec. 10, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/597"},"text":"85 Stat. 597","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/592/tII/s207"},"text":"Pub. L. 96–592, title II, § 207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-24"},"text":"Dec. 24, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3442"},"text":"94 Stat. 3442","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/205/tII/s205/e/10"},"text":"Pub. L. 99–205, title II, § 205(e)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1704"},"text":"99 Stat. 1704","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tVIII"},"text":"Pub. L. 100–233, title VIII","children":[],"tail":", §§ 802("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), 805(g), "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1711"},"text":"101 Stat. 1711","children":[],"tail":", 1715, related to organization and charters of production credit associations, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/s401"},"text":"Pub. L. 100–233, § 401","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcc1921b-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s401/s/1"},"text":"Pub. L. 100–399, § 401(s)(1)","children":[],"tail":", inserted “under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2015/a"},"text":"section 2015(a) of this title","children":[],"tail":"” after “a Farm Credit Bank”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(D)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s401/s/2"},"text":"Pub. L. 100–399, § 401(s)(2)","children":[],"tail":", amended cl. (i) generally. Prior to amendment, cl. (i) read as follows: “the individual’s eligibility for, and request or need of the individual of a Farm Credit Bank loan;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s401/t"},"text":"Pub. L. 100–399, § 401(t)","children":[],"tail":", amended subsec. (c) generally. Prior to amendment, subsec. (c) read as follows: “The Farm Credit Administration shall have power, in the terms of the charter, under rules and regulations prescribed by the Farm Credit Administration or by approving the bylaws of the association, to provide for the—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) organization of the association;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) the initial amount of stock of such association;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) the territory within which the operations of the association may be carried on; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) to direct at any time changes in the charter of such association as the Farm Credit Administration finds necessary in accomplishing the purposes of this chapter.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcc1921c-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcc1921d-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399"},"text":"Pub. L. 100–399","children":[],"tail":" effective immediately after amendment made by "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/s401"},"text":"section 401 of Pub. L. 100–233","children":[],"tail":", which was effective 6 months after "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/s1001/b"},"text":"section 1001(b) of Pub. L. 100–399","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2002"},"text":"section 2002 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddcc1921e-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/233/tIV/s401"},"text":"Pub. L. 100–233, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1622"},"text":"101 Stat. 1622","children":[],"tail":", provided that this section is effective 6 months after "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
