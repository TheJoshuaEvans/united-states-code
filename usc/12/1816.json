{"tag":"section","attrib":{"id":"iddc647d6f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1816"},"text":null,"children":[{"tag":"num","attrib":{"value":"1816"},"text":"§ 1816.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors to be considered","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The factors that are required, under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1814"},"text":"section 1814 of this title","children":[],"tail":", to be considered in connection with, and enumerated in, any certificate issued pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1814"},"text":"section 1814 of this title","children":[],"tail":" and that are required, under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1815"},"text":"section 1815 of this title","children":[],"tail":", to be considered by the Board of Directors in connection with any determination by such Board pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1815"},"text":"section 1815 of this title","children":[],"tail":" are the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc647d70-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1816/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The financial history and condition of the depository institution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc647d71-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1816/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The adequacy of the depository institution’s capital structure.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc647d72-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1816/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The future earnings prospects of the depository institution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc647d73-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1816/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The general character and fitness of the management of the depository institution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc647d74-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1816/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The risk presented by such depository institution to the Deposit Insurance Fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc647d75-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1816/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The convenience and needs of the community to be served by such depository institution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc647d76-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1816/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether the depository institution’s corporate powers are consistent with the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc647d77-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-21/ch967/s2"},"text":"Sept. 21, 1950, ch. 967, § 2","children":[],"tail":"[6], "},{"tag":"ref","attrib":{"href":"/us/stat/64/876"},"text":"64 Stat. 876","childre