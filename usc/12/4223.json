{"tag":"section","attrib":{"id":"iddd1e7f2f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4223"},"text":null,"children":[{"tag":"num","attrib":{"value":"4223"},"text":"§ 4223.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality of declarations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd1e7f30-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4223/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of confidentiality","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A declarant and the declarant’s agents shall not disclose the existence or filing of a declaration filed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4221"},"text":"section 4221 of this title","children":[],"tail":" until:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd1e7f31-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4223/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the declarant receives notice that the Attorney General has concluded that an action should not be pursued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4226/b"},"text":"section 4226(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1e7f32-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4223/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the declarant receives notice of an award pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4226/c"},"text":"section 4226(c) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1e7f33-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4223/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the declarant is granted a contract to pursue an action under section 4225(b) or 4227 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1e7f34-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4223/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of confidentiality to prevent prejudice","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd1e7f35-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4223/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other law, the contents of a declaration shall not be disclosed by the declarant if the disclosure would prejudice or compromise in any way the completion of any government investigation or any criminal or civil case that may arise out of, or make use of, information contained in a declaration, but information contained in a declaration may be disclosed as required by duly issued and authorized legal process.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1e7f36-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4223/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Attorney General may in a circumstance described in paragraph (1) notify a declarant that continued confidentiality is required under this subsection notwithstanding paragraph (1) or (2) of subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1e7f37-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4223/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loss of rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A declarant who discloses, except as provided by this subchapter, the existence or filing of a declaration or the contents thereof to anyone other than a duly authorized Federal or State investigator or the declarant’s attorney shall immediately lose all rights under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd1e7f38-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXV/s2578"},"text":"Pub. L. 101–647, title XXV, § 2578","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4900"},"text":"104 Stat. 4900","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
