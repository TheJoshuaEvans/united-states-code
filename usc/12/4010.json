{"tag":"section","attrib":{"id":"iddd15099e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4010"},"text":null,"children":[{"tag":"num","attrib":{"value":"4010"},"text":"§ 4010.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil liability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd15099f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4010/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil liability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided in this section, any depository institution which fails to comply with any requirement imposed under this chapter or any regulation prescribed under this chapter with respect to any person other than another depository institution is liable to such person in an amount equal to the sum of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd1509a0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4010/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any actual damage sustained by such person as a result of the failure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1509a1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4010/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd1509a2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4010/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an individual action, such additional amount as the court may allow, except that the liability under this subparagraph shall not be less than $100 nor greater than $1,000; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd1509a3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4010/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a class action, such amount as the court may allow, except that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd1509a4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4010/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as to each member of the class, no minimum recovery shall be applicable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd1509a5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4010/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total recovery under this subparagraph in any class action or series of class actions arising out of the same failure to comply by the same depository institution shall not be more than the lesser of $500,000 or 1 percent of the net worth of the depository institution involved; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1509a6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4010/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any successful action to enforce the foregoing liability, the costs of the action, together with a reasonable attorney’s fee as determined by the court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1509a7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4010/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Class action awards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining the amount of any award in any class action, the court shall consider, among other relevant factors—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd1509a8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4010/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of any actual damages awarded;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1509a9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4010/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the frequency and persistence of failures of compliance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1509aa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4010/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the resources of the depository institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1509ab-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4010/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of persons adversely affected; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1509ac-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4010/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the failure of compliance was intentional.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1509ad-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4010/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bona fide errors","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd1509ae-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4010/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A depository institution may not be held liable in any action brought under this section for a violation of this chapter if the depository institution demonstrates by a preponderance of the evidence that the violation was not intentional and resulted from a bona fide error, notwithstanding the maintenance of procedures reasonably adapted to avoid any such error.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1509af-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4010/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Examples","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Examples of a bona fide error include clerical, calculation, computer malfunction and programming, and printing errors, except that an error of legal judgment with respect to a depository institution’s obligation under this chapter is not a bona fide error.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1509b0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4010/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any action under this section may be brought in any United States district court, or in any other court of competent jurisdiction, within one year after the date of the occurrence of the violation involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1509b1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4010/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reliance on Board rulings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No provision of this section imposing any liability shall apply to any act done or omitted in good faith in conformity with any rule, regulation, or interpretation thereof by the Board of Governors of the Federal Reserve System, notwithstanding the fact that after such act or omission has occurred, such rule, regulation, or interpretation is amended, rescinded, or determined by judicial or other authority to be invalid for any reason.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1509b2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4010/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to establish rules regarding losses and liability among depository institutions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board is authorized to impose on or allocate among depository institutions the risks of loss and liability in connection with any aspect of the payment system, including the receipt, payment, collection, or clearing of checks, and any related function of the payment system with respect to checks. Liability under this subsection shall not exceed the amount of the check giving rise to the loss or liability, and, where there is bad faith, other damages, if any, suffered as a proximate consequence of any act or omission giving rise to the loss or liability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd1509b3-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/86/tVI/s611"},"text":"Pub. L. 100–86, title VI, § 611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-08-10"},"text":"Aug. 10, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/650"},"text":"101 Stat. 650","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd1509b4-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd1509b5-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd1509b6-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1988-09-01"},"text":"Sept. 1, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/86/s613/b"},"text":"section 613(b) of Pub. L. 100–86","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4001"},"text":"section 4001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
