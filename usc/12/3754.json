{"tag":"section","attrib":{"id":"iddd0ddd9e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3754"},"text":null,"children":[{"tag":"num","attrib":{"value":"3754"},"text":"§ 3754.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of foreclosure commissioner","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd0ddd9f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3754/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may designate a person or persons to serve as a foreclosure commissioner or commissioners for the purpose of foreclosing upon a single family mortgage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd0ddda0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3754/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Power of sale","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A foreclosure commissioner designated under this section shall have a nonjudicial power of sale.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd0ddda1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3754/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The foreclosure commissioner, if a natural person, shall be a resident of the State in which the security property is located and, if not a natural person, the foreclosure commissioner must be duly authorized to transact business under laws of the State in which the security property is located. No person shall be designated as a foreclosure commissioner unless that person is responsible, financially sound, and competent to conduct a foreclosure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd0ddda2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3754/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation procedure","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd0ddda3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3754/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Written designation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may designate a foreclosure commissioner by executing a written designation stating the name and business or residential address of the commissioner, except that if a person is designated in his or her capacity as an official or employee of a government or corporate entity, such person may be designated by his or her unique title or position instead of by name.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd104da4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3754/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Substitute commissioners","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may, with or without cause, designate a substitute foreclosure commissioner to replace a previously designated foreclosure commissioner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd104da5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3754/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Number","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"More than 1 foreclosure commissioner may be designated at any time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd104da6-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/327/tII"},"text":"Pub. L. 103–327, title II","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-28"},"text":"Sept. 28, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2316"},"text":"108 Stat. 2316","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd104da7-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd104da8-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd104da9-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is based on section 805 of title VIII of S. 2281, One Hundred Third Congress, as reported ","children":[{"tag":"date","attrib":{"date":"1994-07-13"},"text":"July 13, 1994","children":[],"tail":", which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/103/327"},"text":"Pub. L. 103–327","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
