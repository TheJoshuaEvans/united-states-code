{"tag":"section","attrib":{"id":"iddcec72ad-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–11"},"text":null,"children":[{"tag":"num","attrib":{"value":"2279aa–11"},"text":"§ 2279aa–11.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supervision, examination, and report of condition","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcec72ae-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–11/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcec72af-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–11/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of this chapter, the Farm Credit Administration shall have the authority to provide, acting through the Office of Secondary Market Oversight—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcec72b0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–11/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the examination of the Corporation and its affiliates; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcec72b1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–11/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for the general supervision of the safe and sound performance of the powers, functions, and duties vested in the Corporation and its affiliates by this subchapter, including through the use of the authorities granted to the Farm Credit Administration under—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddcec72b2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–11/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" part C of subchapter V; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcec72b3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–11/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" beginning 6 months after ","children":[{"tag":"date","attrib":{"date":"1991-12-13"},"text":"December 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2252/a/9"},"text":"section 2252(a)(9) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcec72b4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–11/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In exercising its authority pursuant to this section, the Farm Credit Administration shall consider—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcec72b5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–11/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purposes for which the Corporation was created;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcec72b6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–11/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the practices appropriate to the conduct of secondary markets in agricultural loans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcec72b7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–11/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reduced levels of risk associated with appropriately structured secondary market transactions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcec72b8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–11/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Secondary Market Oversight","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcec72b9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–11/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"1991-12-13"},"text":"December 13, 1991","children":[],"tail":", the Farm Credit Administration Board shall establish within the Farm Credit Administration the Office of Secondary Market Oversight."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcec72ba-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–11/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Farm Credit Administration Board shall carry out the authority set forth in this section through the Office of Secondary Market Oversight.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcec72bb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–11/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Secondary Market Oversight shall be managed by a full-time Director who shall be selected by and report to the Farm Credit Administration Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcec72bc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–11/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Examinations and audits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcec72bd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–11/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The financial transactions of the Corporation shall be examined by examiners of the Farm Credit Administration in accordance with the principles and procedures applicable to commercial corporate transactions under such rules and regulations as may be prescribed by the Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcec72be-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–11/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Frequency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The examinations shall occur at such times as the Farm Credit Administration Board may determine, but in no event less than once each year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcec72bf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–11/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The examiners shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcec72c0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–11/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have access to all books, accounts, financial records, reports, files, and all other papers, things, or property belonging to or in use by the Corporation and necessary to facilitate the audit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcec72c1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–11/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be afforded full access for verifying transactions with certified facilities and other entities with whom the Corporation conducts transactions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcec72c2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–11/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report of condition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation shall make and publish an annual report of condition as prescribed by the Farm Credit Administration. Each report shall contain financial statements prepared in accordance with generally accepted accounting principles and contain such additional information as the Farm Credit Administration may by regulation prescribe. The financial statements of the Corporation shall be audited by an independent public accountant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcec72c3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–11/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" FCA assessments to cover costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Farm Credit Administration shall assess the Corporation for the cost to the Administration of any regulatory activities conducted under this section, including the cost of any examination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcec72c4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–11/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Affiliate” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As used in this subchapter, the term “affiliate” shall mean an entity effectively controlled or owned by the Corporation, except that such term shall not include an originator (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2279aa"},"text":"section 2279aa of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcec72c5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–11/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employees and personnel","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Farm Credit Administration Board shall ensure that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcec72c6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–11/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Secondary Market Oversight has access to a sufficient number of qualified and trained employees to adequately supervise the secondary market activities of the Corporation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcec72c7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–11/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the supervision of the powers, functions, and duties of the Corporation is performed, to the extent practicable, by personnel who are not responsible for the supervision of the banks and associations of the Farm Credit System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcec72c8-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tVIII/s8"},"text":"Pub. L. 92–181, title VIII, § 8","children":[],"tail":".11, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tVII/s702"},"text":"Pub. L. 100–233, title VII, § 702","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1702"},"text":"101 Stat. 1702","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXVIII/s1840"},"text":"Pub. L. 101–624, title XVIII, § 1840","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3835"},"text":"104 Stat. 3835","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tV/s503/a"},"text":"Pub. L. 102–237, title V, § 503(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1870"},"text":"105 Stat. 1870","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/552/tIII/s308/b/2"},"text":"Pub. L. 102–552, title III, § 308(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4116"},"text":"106 Stat. 4116","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/105/tI/s111"},"text":"Pub. L. 104–105, title I, § 111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/165"},"text":"110 Stat. 165","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tV/s5411/47"},"text":"Pub. L. 115–334, title V, § 5411(47)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4685"},"text":"132 Stat. 4685","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcec72c9-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcec72ca-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcec72cb-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" substituted “2279aa of this title)” for “2279aa(7) of this title)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/105"},"text":"Pub. L. 104–105","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2279aa/7"},"text":"section 2279aa(7) of this title","children":[],"tail":"” for “paragraphs (3) and (7), respectively, of "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2279aa"},"text":"section 2279aa of this title","children":[],"tail":"” and struck out “a certified facility or” before “an originator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a)(1)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/552"},"text":"Pub. L. 102–552","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"December 13, 1991","children":[],"tail":"” for “the date of enactment of this section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237/s503/a/1"},"text":"Pub. L. 102–237, § 503(a)(1)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) read as follows: “Notwithstanding any other provision of this chapter, the Farm Credit Administration shall have the authority to—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) provide for the examination of the condition of the Corporation and its affiliates; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) provide for the general supervision of the safe and sound performance of the powers, functions, and duties vested in the Corporation and its affiliates by this subchapter, including through the use of the enforcement powers of the Farm Credit Administration under part C of subchapter V of this chapter.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237/s503/a/2"},"text":"Pub. L. 102–237, § 503(a)(2)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237/s503/a/3"},"text":"Pub. L. 102–237, § 503(a)(3)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/s1840/1"},"text":"Pub. L. 101–624, § 1840(1)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) read as follows: “Notwithstanding any other provision of this chapter, the regulatory authority of the Farm Credit Administration with respect to the Corporation shall be confined to—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) providing for the examination of the condition of the Corporation; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) providing for the general supervision of the safe and sound performance of the powers, functions, and duties vested in the Corporation by this subchapter, including through the use of the enforcement powers of the Farm Credit Administration under part C of subchapter V of this chapter.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/s1840/2"},"text":"Pub. L. 101–624, § 1840(2)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
