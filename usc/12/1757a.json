{"tag":"section","attrib":{"id":"iddc3e57c5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1757a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1757a"},"text":"§ 1757a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on member business loans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc3e57c6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1757a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On and after ","children":[{"tag":"date","attrib":{"date":"1998-08-07"},"text":"August 7, 1998","children":[],"tail":", no insured credit union may make any member business loan that would result in a total amount of such loans outstanding at that credit union at any one time equal to more than the lesser of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc3e57c7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1757a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1.75 times the actual net worth of the credit union; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc3e57c8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1757a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1.75 times the minimum net worth required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1790d/c/1/A"},"text":"section 1790d(c)(1)(A) of this title","children":[],"tail":" for a credit union to be well capitalized."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc3e57c9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1757a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) does not apply in the case of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc3e57ca-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1757a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an insured credit union chartered for the purpose of making, or that has a history of primarily making, member business loans to its members, as determined by the Board; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc3e57cb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1757a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an insured credit union that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc3e57cc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1757a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serves predominantly low-income members, as defined by the Board; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc3e57cd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1757a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a community development financial institution, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4702"},"text":"section 4702 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc3e57ce-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1757a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc3e57cf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1757a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “member business loan”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc3e57d0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1757a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means any loan, line of credit, or letter of credit, the proceeds of which will be used for a commercial, corporate or other business investment property or venture, or agricultural purpose; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc3e57d1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1757a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" does not include an extension of credit—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddc3e57d2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1757a/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is fully secured by a lien on a 1- to 4-family dwelling;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc3e57d3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1757a/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is fully secured by shares in the credit union making the extension of credit or deposits in other financial institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc3e57d4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1757a/c/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is described in subparagraph (A), if it was made to a borrower or an associated member that has a total of all such extensions of credit in an amount equal to less than $50,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc3e57d5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1757a/c/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the repayment of which is fully insured or fully guaranteed by, or where there is an advance commitment to purchase in full by, any agency of the Federal Government or of a State, or any political subdivision thereof; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc3e57d6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1757a/c/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is granted by a corporate credit union (as that term is defined by the Board) to another credit union.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc3e57d7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1757a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “net worth”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc3e57d8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1757a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to any insured credit union, means the credit union’s retained earnings balance, as determined under generally accepted accounting principles; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc3e57d9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1757a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to a credit union that serves predominantly low-income members, as defined by the Board, includes secondary capital accounts that are—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddc3e57da-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1757a/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uninsured; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc3e57db-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1757a/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subordinate to all other claims against the credit union, including the claims of creditors, shareholders, and the Fund; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc3e57dc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1757a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “associated member” means any member having a shared ownership, investment, or other pecuniary interest in a business or commercial endeavor with the borrower.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc3e57dd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1757a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on existing loans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An insured credit union that has, on ","children":[{"tag":"date","attrib":{"date":"1998-08-07"},"text":"August 7, 1998","children":[],"tail":", a total amount of outstanding member business loans that exceeds the amount permitted under subsection (a) shall, not later than 3 years after "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"August 7, 1998","children":[],"tail":", reduce the total amount of outstanding member business loans to an amount that is not greater than the amount permitted under subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc3e57de-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1757a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation and cooperation with State credit union supervisors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In implementing this section, the Board shall consult and seek to work cooperatively with State officials having jurisdiction over State-chartered insured credit unions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc3e57df-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-26/ch750"},"text":"June 26, 1934, ch. 750","children":[],"tail":", title I, § 107A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/219/tII/s203/a"},"text":"Pub. L. 105–219, title II, § 203(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/920"},"text":"112 Stat. 920","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/174/tI/s105/a"},"text":"Pub. L. 115–174, title I, § 105(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-05-24"},"text":"May 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1301"},"text":"132 Stat. 1301","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc3e57e0-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc3e57e1-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc3e57e2-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (c)(1)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/174"},"text":"Pub. L. 115–174","children":[],"tail":" struck out “that is the primary residence of a member” after “dwelling”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc3e57e3-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddc3e57e4-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rule of Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/174/tI/s105/b"},"text":"Pub. L. 115–174, title I, § 105(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-05-24"},"text":"May 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1301"},"text":"132 Stat. 1301","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/174/tI/s105/b"},"text":"“Nothing in this section [amending this section] or the amendment made by this section shall preclude the National Credit Union Administration from treating an extension of credit that is fully secured by a lien on a 1- to 4-family dwelling that is not the primary residence of a member as a member business loan for purposes other than the member business loan limitation requirements under section 107A of the Federal Credit Union Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1757a"},"text":"12 U.S.C. 1757a","children":[],"tail":").”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddc3e57e5-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Study and Report","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/219/tII/s203/b"},"text":"Pub. L. 105–219, title II, § 203(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/922"},"text":"112 Stat. 922","children":[],"tail":", required the Secretary to conduct a study of member business lending by insured credit unions, with a final report to be sent to Congress not later than 12 months after "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
