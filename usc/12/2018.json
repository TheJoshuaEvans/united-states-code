{"tag":"section","attrib":{"id":"iddcbf2120-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2018"},"text":null,"children":[{"tag":"num","attrib":{"value":"2018"},"text":"§ 2018.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security; terms","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcbf2121-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2018/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Real estate loans","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcbf2122-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2018/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum level of loans","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcbf2123-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2018/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Real estate mortgage loans originated by a Farm Credit Bank, or in which a Farm Credit Bank participates in with a lender that is not a System institution, shall not exceed 85 percent of the appraised value of the real estate security, except as provided for in subparagraphs (C) and (D).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcbf2124-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2018/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Farm Credit Administration may, by regulation, require that loans not exceed 75 percent of the appraised value of the real estate security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcbf2125-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2018/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guaranteed loans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the loan is guaranteed by Federal, State, or other governmental agencies, the loan may not exceed 97 percent of the appraised value of the real estate security, as may be authorized under regulations of the Farm Credit Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcbf2126-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2018/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private mortgage insurance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A loan on which private mortgage insurance is obtained may exceed 85 percent of the appraised value of the real estate security to the extent that the loan amount in excess of such 85 percent is covered by the insurance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbf2127-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2018/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All loans originated or participated in by a bank under this section shall be secured by first liens on interests in real estate of such classes as may be prescribed by regulations of the Farm Credit Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbf2128-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2018/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Value of security","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To adequately secure the loan, the value of security shall be determined by appraisal under standards prescribed by the bank in accordance with regulations of the Farm Credit Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbf2129-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2018/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional security","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Additional security for any loan may be required by the bank to supplement real estate security. Credit factors, other than the ratio between the amount of the loan and the security value, shall be given due consideration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcbf212a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2018/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intermediate credit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Loans, other than real estate loans, and discounts made under the provisions of this subchapter shall be repayable in not more than 7 years (15 years if made to producers or harvesters of aquatic products) from the time that such are made or discounted by the Farm Credit Bank, except that the Board of Directors, under regulations of the Farm Credit Administration, may approve policies permitting loans, advances, or discounts (other than those made to producers or harvesters of aquatic products) to be repayable in not more than 10 years from the time that such are made or discounted by such bank.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcbf212b-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tI/s1"},"text":"Pub. L. 92–181, title I, § 1","children":[],"tail":".10, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tIV/s401"},"text":"Pub. L. 100–233, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1627"},"text":"101 Stat. 1627","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/tIV/s401/h"},"text":"Pub. L. 100–399, title IV, § 401(h)","children":[],"tail":", (i), "},{"tag":"date","attrib":{"date":"1988-08-17"},"text":"Aug. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/996"},"text":"102 Stat. 996","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/105/tII"},"text":"Pub. L. 104–105, title II","children":[],"tail":", §§ 202, 203, "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/172"},"text":"110 Stat. 172","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcbf212c-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcbf212d-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"iddcbf212e-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2018, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tI/s1"},"text":"Pub. L. 92–181, title I, § 1","children":[],"tail":".10, "},{"tag":"date","attrib":{"date":"1971-12-10"},"text":"Dec. 10, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/586"},"text":"85 Stat. 586","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/592/tI/s107"},"text":"Pub. L. 96–592, title I, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-24"},"text":"Dec. 24, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3438"},"text":"94 Stat. 3438","children":[],"tail":", related to purposes, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/s401"},"text":"Pub. L. 100–233, § 401","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcbf212f-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/105/s202/b"},"text":"Pub. L. 104–105, § 202(b)","children":[],"tail":", substituted “subparagraphs (C) and (D)” for “paragraphs (2) and (3)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/105/s202/a"},"text":"Pub. L. 104–105, § 202(a)","children":[],"tail":", added subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/105/s203"},"text":"Pub. L. 104–105, § 203","children":[],"tail":", struck out heading and text of par. (5). Text read as follows: “Each Farm Credit Bank shall require a financial statement from each borrower at least once every 3 years, or during such shorter period of time as may be required under regulations of the Farm Credit Administration.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s401/h/1"},"text":"Pub. L. 100–399, § 401(h)(1)","children":[],"tail":", substituted “prescribed by regulations of” for “approved by”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s401/h/2"},"text":"Pub. L. 100–399, § 401(h)(2)","children":[],"tail":", substituted “under standards” for “under appraisal standards” and “in accordance with regulations of” for “and approved by”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s401/i"},"text":"Pub. L. 100–399, § 401(i)","children":[],"tail":", substituted “harvesters of aquatic products) from” for “harvester of aquatic products) from”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcbf2130-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcbf2131-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399"},"text":"Pub. L. 100–399","children":[],"tail":" effective immediately after amendment made by "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/s401"},"text":"section 401 of Pub. L. 100–233","children":[],"tail":", which was effective 6 months after "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/s1001/b"},"text":"section 1001(b) of Pub. L. 100–399","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2002"},"text":"section 2002 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddcbf2132-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/233/tIV/s401"},"text":"Pub. L. 100–233, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1622"},"text":"101 Stat. 1622","children":[],"tail":", provided that this section is effective 6 months after "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
