{"tag":"section","attrib":{"id":"iddd556dbd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5332"},"text":null,"children":[{"tag":"num","attrib":{"value":"5332"},"text":"§ 5332.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" GAO audit of Council","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd556dbe-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5332/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to audit","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Comptroller General of the United States may audit the activities of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd556dbf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5332/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Council; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd556dc0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5332/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person or entity acting on behalf of or under the authority of the Council, to the extent that such activities relate to work for the Council by such person or entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd556dc1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5332/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to information","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd556dc2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5332/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, the Comptroller General shall, upon request and at such reasonable time and in such reasonable form as the Comptroller General may request, have access to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd556dc3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5332/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any records or other information under the control of or used by the Council;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd556dc4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5332/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any records or other information under the control of a person or entity acting on behalf of or under the authority of the Council, to the extent that such records or other information is relevant to an audit under subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd556dc5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5332/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the officers, directors, employees, financial advisors, staff, working groups, and agents and representatives of the Council (as related to the activities on behalf of the Council of such agent or representative), at such reasonable times as the Comptroller General may request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd556dc6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5332/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Copies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Comptroller General may make and retain copies of such books, accounts, and other records, access to which is granted under this section, as the Comptroller General considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd556dc7-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tI/s122"},"text":"Pub. L. 111–203, title I, § 122","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1411"},"text":"124 Stat. 1411","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
