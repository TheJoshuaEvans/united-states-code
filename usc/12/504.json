{"tag":"section","attrib":{"id":"iddb466328-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s504"},"text":null,"children":[{"tag":"num","attrib":{"value":"504"},"text":"§ 504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil money penalty","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddb466329-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s504/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" First tier","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any member bank which, and any institution-affiliated party (within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813/u"},"text":"section 1813(u) of this title","children":[],"tail":") with respect to such member bank who, violates any provision of section 371c, 371c–1, 375, 375a, 375b, 376, or 503 of this title, or any regulation issued pursuant thereto, shall forfeit and pay a civil penalty of not more than $5,000 for each day during which such violation continues."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb46632a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s504/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Second tier","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding subsection (a), any member bank which, and any institution-affiliated party (within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813/u"},"text":"section 1813(u) of this title","children":[],"tail":") with respect to such member bank who "},{"tag":"ref","attrib":{"idref":"fn002052"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002052"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a dash."}],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb46632b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s504/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddb46632c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s504/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commits any violation described in subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb46632d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s504/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recklessly engages in an unsafe or unsound practice in conducting the affairs of such member bank; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb46632e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s504/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" breaches any fiduciary duty;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb46632f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s504/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" which violation, practice, or breach—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddb466330-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s504/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is part of a pattern of misconduct;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb466331-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s504/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" causes or is likely to cause more than a minimal loss to such member bank; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb466332-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s504/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" results in pecuniary gain or other benefit to such party,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall forfeit and pay a civil penalty of not more than $25,000 for each day during which such violation, practice, or breach continues.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb466333-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s504/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Third tier","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding subsections (a) and (b), any member bank which, and any institution-affiliated party (within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813/u"},"text":"section 1813(u) of this title","children":[],"tail":") with respect to such member bank who—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb466334-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s504/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" knowingly—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddb466335-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s504/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commits any violation described in subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb466336-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s504/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engages in any unsafe or unsound practice in conducting the affairs of such credit union; ","children":[{"tag":"ref","attrib":{"idref":"fn002053"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002053"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “such member bank”."}],"tail":" or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb466337-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s504/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" breaches any fiduciary duty; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb466338-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s504/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly or recklessly causes a substantial loss to such credit union ","children":[{"tag":"sup","attrib":{},"text":"2","children":[],"tail":" or a substantial pecuniary gain or other benefit to such party by reason of such violation, practice, or breach,"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall forfeit and pay a civil penalty in an amount not to exceed the applicable maximum amount determined under subsection (d) for each day during which such violation, practice, or breach continues.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb466339-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s504/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum amounts of penalties for any violation described in subsection (c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The maximum daily amount of any civil penalty which may be assessed pursuant to subsection (c) for any violation, practice, or breach described in such subsection is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb46633a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s504/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any person other than a member bank, an amount to not exceed $1,000,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb46633b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s504/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a member bank, an amount not to exceed the lesser of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddb46633c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s504/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,000,000; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb46633d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s504/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 percent of the total assets of such member bank.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb46633e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s504/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment; etc.","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any penalty imposed under subsection (a), (b), or (c) shall be assessed and collected ","children":[{"tag":"ref","attrib":{"idref":"fn002054"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002054"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" So in original. Probably should be followed by a dash rather than “by”."}],"tail":" by"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb46633f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s504/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a national bank, by the Comptroller of the Currency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb466340-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s504/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a State member bank, by the Board,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"in the manner provided in subparagraphs (E), (F), (G), and (I) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1818/i/2"},"text":"section 1818(i)(2) of this title","children":[],"tail":" for penalties imposed (under such section) and any such assessment shall be subject to the provisions of such section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb466341-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s504/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hearing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The member bank or other person against whom any penalty is assessed under this section shall be afforded an agency hearing if such member bank or person submits a request for such hearing within 20 days after the issuance of the notice of assessment. ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1818/h"},"text":"Section 1818(h) of this title","children":[],"tail":" shall apply to any proceeding under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb466342-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s504/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disbursement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All penalties collected under authority of this paragraph shall be deposited into the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb466343-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s504/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Violate” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “violate” includes any action (alone or with another or others) for or toward causing, bringing about, participating in, counseling, or aiding or abetting a violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb466344-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s504/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Comptroller of the Currency and the Board shall prescribe regulations establishing such procedures as may be necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb466345-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s504/m"},"text":null,"children":[{"tag":"num","attrib":{"value":"m"},"text":"(m)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002055"},"text":"4","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002055"},"text":null,"children":[{"tag":"num","attrib":{},"text":"4","children":[],"tail":" So in original. No subsecs. (j) to ("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":") have been enacted."}],"tail":" Notice under this section after separation from service"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The resignation, termination of employment or participation, or separation of an institution-affiliated party (within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813/u"},"text":"section 1813(u) of this title","children":[],"tail":") with respect to a member bank (including a separation caused by the closing of such a bank) shall not affect the jurisdiction and authority of the appropriate Federal banking agency to issue any notice and proceed under this section against any such party, if such notice is served before the end of the 6-year period beginning on the date such party ceased to be such a party with respect to such bank (whether such date occurs before, on, or after "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"August 9, 1989","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddb466346-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1913-12-23/ch6/s29"},"text":"Dec. 23, 1913, ch. 6, § 29","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/630/tI/s101"},"text":"Pub. L. 95–630, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3641"},"text":"92 Stat. 3641","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/320/tIV/s424/c"},"text":"Pub. L. 97–320, title IV, § 424(c)","children":[],"tail":", (d)(1), (e), "},{"tag":"date","attrib":{"date":"1982-10-15"},"text":"Oct. 15, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1523"},"text":"96 Stat. 1523","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/73/tIX"},"text":"Pub. L. 101–73, title IX","children":[],"tail":", §§ 905(f), 907(g), "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/461"},"text":"103 Stat. 461","children":[],"tail":", 470.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb48d447-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb48d448-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddb48d449-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (a), “section 371c, 371c–1, 375, 375a, 375b, 376, or 503 of this title” was in the original “section 22, 23A, or 23B”, meaning section 22, 23A, or 23B of the Federal Reserve Act. Sections 23A and 23B are classified to sections 371c and 371c–1, respectively, of this title. Subsections (d) to (h) of section 22 are classified to sections 375, 375a, 375b, 376, and 503 of this title. The text of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s375"},"text":"section 375 of this title","children":[],"tail":" was struck out by "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tVI/s615/b"},"text":"Pub. L. 111–203, title VI, § 615(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1615"},"text":"124 Stat. 1615","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddb48d44a-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/s907/g"},"text":"Pub. L. 101–73, § 907(g)","children":[],"tail":", amended section generally, substituting provisions of subsecs. (a) to (i) for former provisions which related to the following: subsec. (a), making loans, extensions of credit, purchases of securities, etc., respecting affiliates, executive officers, etc.; subsec. (b), amount of penalty; subsec. (c), opportunity for hearing; subsec. (d), review by United States court of appeals; subsec. (e), action by Attorney General for failure to pay assessment; subsec. (f), promulgation of regulations; and subsec. (g), penalties covered into Treasury of United States."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (m). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/s905/f"},"text":"Pub. L. 101–73, § 905(f)","children":[],"tail":", added subsec. (m)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/320/s424/c"},"text":"Pub. L. 97–320, § 424(c)","children":[],"tail":", (d)(1), inserted proviso giving agency discretionary authority to compromise, etc., any civil money penalty imposed under its authority, and substituted “may be assessed” for “shall be assessed”, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/320/s424/e"},"text":"Pub. L. 97–320, § 424(e)","children":[],"tail":", substituted “twenty days from the service” for “ten days from the date”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddb48d44b-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddb48d44c-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/s907/g"},"text":"section 907(g) of Pub. L. 101–73","children":[],"tail":" applicable to conduct engaged in after "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", except that increased maximum penalties of $5,000 and $25,000 may apply to conduct engaged in before such date if such conduct is not already subject to a notice issued by the appropriate agency and occurred after completion of the last report of the examination of the institution by the appropriate agency occurring before "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", see section 907("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":") of "},{"tag":"ref","attrib":{"href":"/us/pl/101/73"},"text":"Pub. L. 101–73","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s93"},"text":"section 93 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddb48d44d-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective with respect to violations occurring or continuing after ","children":[{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/630/s109"},"text":"section 109 of Pub. L. 95–630","children":[],"tail":" set out as an Effective Date of 1978 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s93"},"text":"section 93 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
