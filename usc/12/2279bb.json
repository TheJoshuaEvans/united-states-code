{"tag":"section","attrib":{"id":"iddcec7301-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"2279bb"},"text":"§ 2279bb.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this part:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcec7302-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “compensation” means any payment of money or the provision of any other thing of current or potential value in connection with employment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcec7303-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Core capital","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “core capital” means, with respect to the Corporation, the sum of the following (as determined in accordance with generally accepted accounting principles):","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcec7304-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The par value of outstanding common stock.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcec7305-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The par value of outstanding preferred stock.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcec7306-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paid-in capital.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcec7307-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Retained earnings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcec7308-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Director” means the Director of the Office of Secondary Market Oversight of the Farm Credit Administration, selected under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2279aa–11/a/3"},"text":"section 2279aa–11(a)(3) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcec7309-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Office” means the Office of Secondary Market Oversight of the Farm Credit Administration, established in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2279aa–11/a"},"text":"section 2279aa–11(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcec730a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulatory capital","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “regulatory capital” means, with respect to the Corporation, the core capital of the Corporation plus an allowance for losses and guarantee claims, as determined in accordance with generally accepted accounting principles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcec730b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means the States of the United States, the District of Columbia, the Commonwealth of Puerto Rico, the Commonwealth of the Northern Mariana Islands, Guam, the Virgin Islands, American Samoa, the Trust Territory of the Pacific Islands, and any other territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcec730c-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tVIII/s8"},"text":"Pub. L. 92–181, title VIII, § 8","children":[],"tail":".31, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tV/s503/b/2"},"text":"Pub. L. 102–237, title V, § 503(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1871"},"text":"105 Stat. 1871","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcec730d-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"iddcec730e-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddcec730f-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Termination of Trust Territory of the Pacific Islands","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For termination of Trust Territory of the Pacific Islands, see note set out preceding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1681"},"text":"section 1681 of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
