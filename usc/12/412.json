21","children":[],"tail":" effective on first day of sixth month which begins after "},{"tag":"date","attrib":{"date":"1980-03-31"},"text":"Mar. 31, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/221/s108"},"text":"section 108 of Pub. L. 96–221","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s248"},"text":"section 248 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddb3f37ed-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment effective upon expiration of 120 days after ","children":[{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", see sec. 2101 of "},{"tag":"ref","attrib":{"href":"/us/pl/95/630"},"text":"Pub. L. 95–630","children":[],"tail":" set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s375b"},"text":"section 375b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddb3f37ee-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"United States Obligations as Collateral; Extension of Period","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The period within which direct obligations of the United States could be accepted as collateral security under this section was extended to ","children":[{"tag":"date","attrib":{"date":"1937-03-03"},"text":"Mar. 3, 1937","children":[],"tail":", by Proclamation No. 2117, of "},{"tag":"date","attrib":{"date":"1935-02-14"},"text":"Feb. 14, 1935","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/3437"},"text":"49 Stat. 3437","children":[],"tail":"; extended to "},{"tag":"date","attrib":{"date":"1939-06-30"},"text":"Jun