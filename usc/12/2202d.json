{"tag":"section","attrib":{"id":"iddcc8bed3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202d"},"text":null,"children":[{"tag":"num","attrib":{"value":"2202d"},"text":"§ 2202d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of borrowers who meet all loan obligations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcc8bed4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreclosure prohibited","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A qualified lender may not foreclose on any loan because of the failure of the borrower thereof to post additional collateral, if the borrower has made all accrued payments of principal, interest, and penalties with respect to the loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcc8bed5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition against required principal reduction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A qualified lender may not require any borrower to reduce the outstanding principal balance of any loan made to the borrower by any amount that exceeds the regularly scheduled principal installment payment (when due and payable), unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcc8bed6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the borrower sells or otherwise disposes of part or all of the collateral; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc8bed7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the parties agree otherwise in a written agreement entered into by the parties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcc8bed8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonenforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After a borrower has made all accrued payments of principal, interest, and penalties with respect to a loan made by a qualified lender, the lender shall not enforce acceleration of the borrower’s repayment schedule due to the borrower having not timely made one or more principal or interest payments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcc8bed9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Placing loans in nonaccrual status","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcc8beda-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202d/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a qualified lender places any loan in nonaccrual status, the lender shall document such change of status and promptly notify the borrower thereof in writing of such action and the reasons therefor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc8bedb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202d/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of denial","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the borrower was not delinquent in any principal or interest payment under the loan at the time of such action and the borrower’s request to have the loan placed back into accrual status is denied, the borrower may obtain a review of such denial before the appropriate credit review committee under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2202"},"text":"section 2202 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddccb07cc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202d/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subsection shall only apply if a loan being placed in nonaccrual status results in an adverse action being taken against the borrower.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddccb07cd-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tIV/s4"},"text":"Pub. L. 92–181, title IV, § 4","children":[],"tail":".14D, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tI/s107"},"text":"Pub. L. 100–233, title I, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1581"},"text":"101 Stat. 1581","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
