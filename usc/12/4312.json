{"tag":"section","attrib":{"id":"iddd20ef33-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4312"},"text":null,"children":[{"tag":"num","attrib":{"value":"4312"},"text":"§ 4312.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on State law","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The provisions of this chapter do not supersede any provisions of the law of any State relating to the disclosure of yields payable or terms for accounts to the extent such State law requires the disclosure of such yields or terms for accounts, except to the extent that those laws are inconsistent with the provisions of this chapter, and then only to the extent of the inconsistency. The Bureau may determine whether such inconsistencies exist.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd20ef34-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/tII/s273"},"text":"Pub. L. 102–242, title II, § 273","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2342"},"text":"105 Stat. 2342","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXVI/s1604/e/2/R"},"text":"Pub. L. 102–550, title XVI, § 1604(e)(2)(R)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4084"},"text":"106 Stat. 4084","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1100B/1"},"text":"Pub. L. 111–203, title X, § 1100B(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2109"},"text":"124 Stat. 2109","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","