{"tag":"section","attrib":{"id":"iddcf8593a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2904"},"text":null,"children":[{"tag":"num","attrib":{"value":"2904"},"text":"§ 2904.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Each appropriate Federal financial supervisory agency shall include in its annual report to the Congress a section outlining the actions it has taken to carry out its responsibilities under this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddcf8593b-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/128/tVIII/s805"},"text":"Pub. L. 95–128, title VIII, § 805","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-10-12"},"text":"Oct. 12, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1148"},"text":"91 Stat. 1148","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
