{"tag":"section","attrib":{"id":"iddd104ea6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3804"},"text":null,"children":[{"tag":"num","attrib":{"value":"3804"},"text":"§ 3804.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of preemption provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd104ea7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3804/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s3803"},"text":"section 3803 of this title","children":[],"tail":" shall not apply to any alternative mortgage transaction in any State made on or after the effective date (if such effective date occurs on or after "},{"tag":"date","attrib":{"date":"1982-10-15"},"text":"October 15, 1982","children":[],"tail":", and prior to a date three years after "},{"tag":"date","attrib":{"date":"1982-10-15"},"text":"October 15, 1982","children":[],"tail":") of a State law or a certification that the voters of such State have voted in favor of any provision, constitutional or otherwise, which states explicitly and by its terms that such State does not want the preemption provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s3803"},"text":"section 3803 of this title","children":[],"tail":" to apply with respect to alternative mortgage transactions (or to any class or type of alternative mortgage transaction) subject to the laws of such State, except that "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s3803"},"text":"section 3803 of this title","children":[],"tail":" shall continue to apply to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd104ea8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3804/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any alternative mortgage transaction undertaken on or after such date pursuant to an agreement to undertake such alternative mortgage transaction which was entered into on or after ","children":[{"tag":"date","attrib":{"date":"1982-10-15"},"text":"October 15, 1982","children":[],"tail":", and prior to such later date (the “preemption period”); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd104ea9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3804/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any renewal, extension, refinancing, or other modification of an alternative mortgage transaction that was entered into during the preemption period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd104eaa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3804/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An alternative mortgage transaction shall be deemed to have been undertaken during the preemption period to which this section applies if it—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd104eab-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3804/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is funded or extended in whole or in part during the preemption period, regardless of whether pursuant to a commitment or other agreement therefor made prior to that period; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd104eac-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3804/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a renewal, extension, refinancing, or other modification of an alternative mortgage transaction entered into before the preemption period and such renewal, extension, or other modification is made during such period with the written consent of any person obligated to repay such credit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd104ead-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/320/tVIII/s805"},"text":"Pub. L. 97–320, title VIII, § 805","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-15"},"text":"Oct. 15, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1547"},"text":"96 Stat. 1547","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/181/tI"},"text":"Pub. L. 98–181, title I","children":[],"tail":" [title IV, § 472], "},{"tag":"date","attrib":{"date":"1983-11-30"},"text":"Nov. 30, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1237"},"text":"97 Stat. 1237","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd104eae-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd104eaf-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd104eb0-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1983—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/181"},"text":"Pub. L. 98–181","children":[],"tail":" inserted “(or to any class or type of alternative mortgage transaction)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd104eb1-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd104eb2-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1982-10-15"},"text":"Oct. 15, 1982","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/320/s807/a"},"text":"section 807(a) of Pub. L. 97–320","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s3801"},"text":"section 3801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
