{"tag":"section","attrib":{"id":"iddb24f884-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s225"},"text":null,"children":[{"tag":"num","attrib":{"value":"225"},"text":"§ 225.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal reserve banks; title","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A Federal reserve bank shall include in its title the name of the city in which it is situated, as “Federal Reserve Bank of Chicago.”","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddb24f885-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1913-12-23/ch6/s2"},"text":"Dec. 23, 1913, ch. 6, § 2","children":[],"tail":" (part), "},{"tag":"ref","attrib":{"href":"/us/stat/38/252"},"text":"38 Stat. 252","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb24f886-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb24f887-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddb24f888-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is based on part of the second par. of section 2 of act ","children":[{"tag":"date","attrib":{"date":"1913-12-23"},"text":"Dec. 23, 1913","children":[],"tail":". The rest of the second par. was not included in the Code. For classification of other pars. of section 2 of this Act, see Codification note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s222"},"text":"section 222 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
