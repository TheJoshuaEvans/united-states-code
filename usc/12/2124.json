{"tag":"section","attrib":{"id":"iddcc402b5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2124"},"text":null,"children":[{"tag":"num","attrib":{"value":"2124"},"text":"§ 2124.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stock of banks for cooperatives","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcc402b6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2124/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Capital stock of each bank for cooperatives shall be in such amount as its board determines is required for the purpose of providing adequate capital to permit the bank to meet the credit needs of borrowers from the bank and such amounts may be increased or decreased from time to time in accordance with such needs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcc402b7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2124/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Value","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The capital stock of each bank shall be divided into shares of par value of $100 each and may be of such classes as the board may determine. Such stock may be issued in fractional shares.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcc402b8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2124/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible holders of voting stock","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Voting stock may be issued or transferred to and held only by (i) cooperative associations eligible to borrow from the banks ","children":[{"tag":"ref","attrib":{"idref":"fn002299"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002299"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. There probably should be a semicolon after “banks”."}],"tail":" (ii) other categories of persons and entities described in sections 2128 and 2129 of this title eligible to borrow from the bank, as determined by the bank’s board of directors; and (iii) other banks for cooperatives, and shall not be otherwise transferred, pledged, or hypothecated except as consented to by the issuing bank under regulations of the Farm Credit Administration."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcc402b9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2124/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entitlement to vote","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each holder of one or more shares of voting stock which is eligible to borrow from a bank for cooperatives shall be entitled only to one vote and only in the affairs of the bank in the district in which its principal office is located unless otherwise authorized under regulations issued by the Farm Credit Administration, except that if such holder has not been a borrower from the bank in which it holds such stock within a period of two years next preceding the date fixed by the Farm Credit Administration prior to the commencement of voting, it shall not be entitled to vote.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcc402ba-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2124/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonvoting investment stock","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nonvoting investment stock may be issued in such series and in such amounts as may be determined by the board and may be exchanged for voting stock or sold or transferred to any person subject to the approval of the issuing bank.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcc402bb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2124/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation certificates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Participation certificates may be issued to parties to whom voting stock may not be issued.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcc402bc-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tIII/s3"},"text":"Pub. L. 92–181, title III, § 3","children":[],"tail":".3, "},{"tag":"date","attrib":{"date":"1971-12-10"},"text":"Dec. 10, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/603"},"text":"85 Stat. 603","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/592/tIII/s302"},"text":"Pub. L. 96–592, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-24"},"text":"Dec. 24, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3443"},"text":"94 Stat. 3443","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/205/tII/s205/e/3"},"text":"Pub. L. 99–205, title II, § 205