{"tag":"section","attrib":{"id":"iddb4b1e07-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s612"},"text":null,"children":[{"tag":"num","attrib":{"value":"612"},"text":"§ 612.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Articles of association; contents","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The persons described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s611"},"text":"section 611 of this title","children":[],"tail":" shall enter into articles of association which shall specify in general terms the objects for which the association is formed and may contain any other provisions not inconsistent with law which the association may see fit to adopt for the regulation of its business and the conduct of its affairs."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddb4b1e08-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1913-12-23/ch6/s25A"},"text":"Dec. 23, 1913, ch. 6, § 25A","children":[],"tail":" (par.), formerly § 25(a), as added "},{"tag":"ref","attrib":{"href":"/us/act/1919-12-24/ch18"},"text":"Dec. 24, 1919, ch. 18","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/378"},"text":"41 Stat. 378","children":[],"tail":"; renumbered § 25A, "},{"tag":"ref","attrib":{"href":"/us/pl/102/242/tI/s142/e/2"},"text":"Pub. L. 102–242, title I, § 142(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2281"},"text":"105 Stat. 2281","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb4b1e09-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb4b1e0a-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":n