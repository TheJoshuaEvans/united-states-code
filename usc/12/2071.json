{"tag":"section","attrib":{"id":"iddcbf217a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2071"},"text":null,"children":[{"tag":"num","attrib":{"value":"2071"},"text":"§ 2071.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organization and charters","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcbf217b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2071/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Charter","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each production credit association shall continue as a Federally chartered instrumentality of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcbf217c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2071/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organization","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcbf217d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2071/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Production credit associations may be organized by 10 or more farmers or ranchers or producers or harvesters of aquatic products desiring to borrow money under the provisions of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbf217e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2071/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Articles of association","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The proposed articles of association shall be forwarded to the Farm Credit Bank for the district accompanied by an agreement to subscribe on behalf of the association for stock in the bank in such amounts as may be required by the bank.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbf217f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2071/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of articles","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The articles shall specify in general terms the—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcbf2180-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2071/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" objects for which the association is formed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcbf2181-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2071/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" powers to be exercised by the association in carrying out the functions authorized by this part; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcbf2182-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2071/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" territory the association proposes to serve.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbf2183-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2071/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Signatures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The articles shall be signed by persons desiring to form such an association and shall be accompanied by a statement signed by each such person establishing eligibility to borrow from the association in which such person will become a stockholder.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbf2184-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2071/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Copy to FCA","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A copy of the articles of association shall be forwarded to the Farm Credit Administration with the recommendations of the bank concerning the need for such an association in order to adequately serve the credit needs of eligible persons in the proposed territory and whether that territory includes any area described in the charter of another production credit association.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbf2185-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2071/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Denial of charter","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Farm Credit Administration for good cause shown may deny the charter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbf2186-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2071/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of articles","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On approval of the proposed articles by the Farm Credit Administration, and on the issuance of a charter, the association shall become as of such date a federally chartered body corporate and an instrumentality of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbf2187-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2071/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers of FCA","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Farm Credit Administration shall have the power, under rules and regulations prescribed by the Farm Credit Administration or by prescribing in the terms of the charter, to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcbf2188-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2071/b/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the organization of the association;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcbf2189-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2071/b/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the initial amount of stock of the association;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcbf218a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2071/b/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the territory within which the association’s operations may be carried on; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcbf218b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2071/b/8/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approve amendments to the charter of the association.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcbf218c-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tII/s2"},"text":"Pub. L. 92–181, title II, § 2","children":[],"tail":".0, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tIV/s401"},"text":"Pub. L. 100–233, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1629"},"text":"101 Stat. 1629","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/tIV/s401/m"},"text":"Pub. L. 100–399, title IV, § 401(m)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-17"},"text":"Aug. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/997"},"text":"102 Stat. 997","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tV/s502/b"},"text":"Pub. L. 102–237, title V, § 502(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1868"},"text":"105 Stat. 1868","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcbf218d-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcbf218e-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"iddcbf218f-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2071, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tII/s2"},"text":"Pub. L. 92–181, title II, § 2","children":[],"tail":".0, "},{"tag":"date","attrib":{"date":"1971-12-10"},"text":"Dec. 10, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/590"},"text":"85 Stat. 590","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tVIII/s802/h"},"text":"Pub. L. 100–233, title VIII, § 802(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1711"},"text":"101 Stat. 1711","children":[],"tail":", related to establishment and branches of Federal intermediate credit banks, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/s401"},"text":"Pub. L. 100–233, § 401","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcbf2190-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—Subsec. (b)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237"},"text":"Pub. L. 102–237","children":[],"tail":" substituted “charter, to” for “charter to” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s401/m/1"},"text":"Pub. L. 100–399, § 401(m)(1)","children":[],"tail":", substituted “this part” for “this subchapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s401/m/2"},"text":"Pub. L. 100–399, § 401(m)(2)","children":[],"tail":", (3), struck out “the” before “powers” and substituted “this subtitle” for “this part”, both of which for purposes of codification were translated as “this part”, requiring no change in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s401/m/3"},"text":"Pub. L. 100–399, § 401(m)(3)","children":[],"tail":", struck out “the” before “territory”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s401/m/4"},"text":"Pub. L. 100–399, § 401(m)(4)","children":[],"tail":", struck out in introductory provision “or by approval of bylaws of the association” after “the charter” and amended subpar. (D) generally. Prior to amendment, subpar. (D) read as follows: “direct at any time such changes in the charter as the Farm Credit Administration finds necessary for the accomplishment of the purposes of this chapter”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcbf2191-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcbf2192-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1991 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237"},"text":"Pub. L. 102–237","children":[],"tail":" effective as if included in the provision of the Food, Agriculture, Conservation, and Trade Act of 1990, "},{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":", to which the amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/s1101/b/4"},"text":"section 1101(b)(4) of Pub. L. 102–237","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1421"},"text":"section 1421 of Title 7","children":[],"tail":", Agriculture."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcbf2193-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399"},"text":"Pub. L. 100–399","children":[],"tail":" effective immediately after amendment made by "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/s401"},"text":"section 401 of Pub. L. 100–233","children":[],"tail":", which was effective 6 months after "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/s1001/b"},"text":"section 1001(b) of Pub. L. 100–399","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2002"},"text":"section 2002 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddcbf2194-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/233/tIV/s401"},"text":"Pub. L. 100–233, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1622"},"text":"101 Stat. 1622","children":[],"tail":", provided that this section is effective 6 months after "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddcbf2195-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Merger of Production Credit Associations and Federal Land Bank Associations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/233/tIV/s411"},"text":"Pub. L. 100–233, title IV, § 411","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1638"},"text":"101 Stat. 1638","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/tIV/s403"},"text":"Pub. L. 100–399, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-17"},"text":"Aug. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/999"},"text":"102 Stat. 999","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/399/tIV/s403"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submission of Proposal","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 6 months after the date of the merger of the Federal land bank and the Federal intermediate credit bank in a district, the Boards of Directors of each Federal land bank association and each production credit association in such district, that share substantially the same geographical territory with each other, shall submit to the voting stockholders of each such association for their approval, a plan, approved by the supervising bank and the Farm Credit Administration, for merging such associations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prerequisites to Merger.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Stockholder vote","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The stockholder vote required for approval of a merger under subsection (a) shall be a majority of the voting stockholders of each association voting, in person or by written proxy, at a duly authorized stockholders meeting.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submission to fca","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 60 days prior to the end of the 12-month period beginning on the date of the enactment of this section [","children":[{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":"], the plan of merger under subsection (a), together with all information to be presented to the stockholders, shall be submitted to the Farm Credit Administration."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expedited consideration by fca","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Farm Credit Administration shall expedite its consideration of the plan and accompanying information submitted under paragraph (2) so that review and approval of such plan and information shall be completed by the Administration so as to enable a stockholder vote to occur within the 12-month period referred to in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Direct Lenders","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"On approval of a merger under this subsection, the resulting association shall be a direct lender in the same manner as applies to production credit associations.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddcbf2196-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Reassignment of Associations to Adjoining Districts","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/233/tIV/s433"},"text":"Pub. L. 100–233, title IV, § 433","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1662"},"text":"101 Stat. 1662","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/tIV/s417"},"text":"Pub. L. 100–399, title IV, § 417","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-17"},"text":"Aug. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1004"},"text":"102 Stat. 1004","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/399/tIV/s417"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Petition of Bank","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of law, effective for the 12-month period beginning on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":"], each Federal land bank association or production credit association, whose chartered territory adjoins the territory of another district, may petition the Farm Credit Administration to amend the charters of the association and the adjoining district bank to provide that the territory of the association is part of the adjoining district."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements of Petition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To be considered under this section, the petition must be signed by not less than 15 percent of the stockholders of the association. Only one such petition may be filed by an association under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"FCA Action","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Farm Credit Administration shall take any action necessary—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to amend the charters of the association and the district bank; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to incorporate the petitioning association into the adjoining district if the reassignment is approved by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a majority of the stockholders of the association voting, in person or by proxy, at a duly authorized stockholders’ meeting held for such purpose;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the board of directors of the adjoining district bank;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Farm Credit System Assistance Board; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Farm Credit Administration Board.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
