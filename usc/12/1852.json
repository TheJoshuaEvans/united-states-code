{"tag":"section","attrib":{"id":"iddcb5ab40-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1852"},"text":null,"children":[{"tag":"num","attrib":{"value":"1852"},"text":"§ 1852.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Concentration limits on large financial firms","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcb5ab41-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1852/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcb5ab42-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1852/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Council” means the Financial Stability Oversight Council;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb5ab43-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1852/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “financial company” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcb5ab44-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1852/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an insured depository institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcb5ab45-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1852/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a bank holding company;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcb5ab46-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1852/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a savings and loan holding company;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcb5ab47-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1852/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a company that controls an insured depository institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcb5ab48-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1852/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonbank financial company supervised by the Board under title I of the Dodd-Frank Wall Street Reform and Consumer Protection Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5311"},"text":"12 U.S.C. 5311","children":[],"tail":" et seq.]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcb5ab49-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1852/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a foreign bank or company that is treated as a bank holding company for purposes of this chapter; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb5ab4a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1852/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “liabilities” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcb5ab4b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1852/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to a United States financial company—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddcb5ab4c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1852/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total risk-weighted assets of the financial company, as determined under the risk-based capital rules applicable to bank holding companies, as adjusted to reflect exposures that are deducted from regulatory capital; less","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcb5ab4d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1852/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total regulatory capital of the financial company under the risk-based capital rules applicable to bank holding companies;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcb5ab4e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1852/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to a foreign-based financial company—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddcb5ab4f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1852/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total risk-weighted assets of the United States operations of the financial company, as determined under the applicable risk-based capital rules, as adjusted to reflect exposures that are deducted from regulatory capital; less","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcb5ab50-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1852/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total regulatory capital of the United States operations of the financial company, as determined under the applicable risk-based capital rules; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcb5ab51-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1852/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to an insurance company or other nonbank financial company supervised by the Board, such assets of the company as the Board shall specify by rule, in order to provide for consistent and equitable treatment of such companies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcb5ab52-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1852/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Concentration limit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the recommendations by the Council under subsection (e), a financial company may not merge or consolidate with, acquire all or substantially all of the assets of, or otherwise acquire control of, another company, if the total consolidated liabilities of the acquiring financial company upon consummation of the transaction would exceed 10 percent of the aggregate consolidated liabilities of all financial companies at the end of the calendar year preceding the transaction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcb5ab53-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1852/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception to concentration limit","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With the prior written consent of the Board, the concentration limit under subsection (b) shall not apply to an acquisition—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcb5ab54-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1852/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of a bank in default or in danger of default;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb5ab55-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1852/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to which assistance is provided by the Federal Deposit Insurance Corporation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1823/c"},"text":"section 1823(c) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb5ab56-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1852/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that would result only in a de minimis increase in the liabilities of the financial company.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcb5ab57-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1852/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rulemaking and guidance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall issue regulations implementing this section in accordance with the recommendations of the Council under subsection (e), including the definition of terms, as necessary. The Board may issue interpretations or guidance regarding the application of this section to an individual financial company or to financial companies in general.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcb5ab58-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1852/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Council study and rulemaking","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcb5ab59-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1852/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study and recommendations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 6 months after ","children":[{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", the Council shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcb5ab5a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1852/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complete a study of the extent to which the concentration limit under this section would affect financial stability, moral hazard in the financial system, the efficiency and competitiveness of United States financial firms and financial markets, and the cost and availability of credit and other financial services to households and businesses in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcb5ab5b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1852/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make recommendations regarding any modifications to the concentration limit that the Council determines would more effectively implement this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb5ab5c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1852/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rulemaking","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 9 months after the date of completion of the study under paragraph (1), and notwithstanding subsections (b) and (d), the Board shall issue final regulations implementing this section, which shall reflect any recommendations by the Council under paragraph (1)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcb5ab5d-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-05-09/ch240/s14"},"text":"May 9, 1956, ch. 240, § 14","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tVI/s622"},"text":"Pub. L. 111–203, title VI, § 622","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1632"},"text":"124 Stat. 1632","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcb5ab5e-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcb5ab5f-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddcb5ab60-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Dodd-Frank Wall Street Reform and Consumer Protection Act, referred to in subsec. (a)(2)(E), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1376"},"text":"124 Stat. 1376","children":[],"tail":". Title I of the Act, known as the Financial Stability Act of 2010, is classified principally to subchapter I (§ 5311 et seq.) of chapter 53 of this title. For complete classification of title I to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a)(2)(F), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-05-09/ch240"},"text":"act May 9, 1956, ch. 240","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/133"},"text":"70 Stat. 133","children":[],"tail":", known as the Bank Holding Company Act of 1956, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1841"},"text":"section 1841 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcb5ab61-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddcb5ab62-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 1 day after ","children":[{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s4"},"text":"section 4 of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"section 5301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
