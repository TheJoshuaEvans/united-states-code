"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb92ae96-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb92ae97-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddb92ae98-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73"},"text":"Pub. L. 101–73","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “The provisions of this chapter shall apply to the continental United States (including Alaska), to the State of Hawaii, and to Puerto Rico, Guam and the Virgin Islands.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1960—","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/624"},"text":"Pub. L. 86–624","children":[],"tail":" substituted “State of Hawaii” for “Territory of Hawaii”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1959—","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/70"},"text":"Pub. L. 86–70","children":[],"tail":" substituted “continental United States (including Alaska), to the Territory of Hawaii” for “continental United States, to the Territories of Alaska and Hawaii”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1952—Act ","children":[{"tag":"date","attrib":{"date":"1952-07-14"},"text":"July 14, 1952","children":[],"tail":", inserted “Guam”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
