{"tag":"section","attrib":{"id":"iddb2c2523-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s289"},"text":null,"children":[{"tag":"num","attrib":{"value":"289"},"text":"§ 289.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dividends and surplus funds of reserve banks; transfer for fiscal year 2000","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddb2c2524-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s289/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dividends and surplus funds of reserve banks","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb2c2525-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s289/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stockholder dividends","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddb2c2526-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s289/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dividend amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"After all necessary expenses of a Federal reserve bank have been paid or provided for, the stockholders of the bank shall be entitled to receive an annual dividend on paid-in capital stock of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddb2c2527-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s289/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a stockholder with total consolidated assets of more than $10,000,000,000, the smaller of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddb2c2528-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s289/a/1/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rate equal to the high yield of the 10-year Treasury note auctioned at the last auction held prior to the payment of such dividend; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddb2c2529-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s289/a/1/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 6 percent; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddb2c252a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s289/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a stockholder with total consolidated assets of $10,000,000,000 or less, 6 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb2c252b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s289/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dividend cumulative","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The entitlement to dividends under subparagraph (A) shall be cumulative.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb2c252c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s289/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inflation adjustment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board of Governors of the Federal Reserve System shall annually adjust the dollar amounts of total consolidated assets specified under subparagraph (A) to reflect the change in the Gross Domestic Product Price Index, published by the Bureau of Economic Analysis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb2c252d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s289/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit of net earnings in surplus fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"That portion of net earnings of each Federal reserve bank which remains after dividend claims under paragraph (1)(A) have been fully met shall be deposited in the surplus fund of the bank.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb2c252e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s289/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on surplus funds","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddb2c252f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s289/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The aggregate amount of the surplus funds of the Federal reserve banks may not exceed $6,825,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb2c2530-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s289/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer to the general fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amounts of the surplus funds of the Federal reserve banks that exceed, or would exceed, the limitation under subparagraph (A) shall be transferred to the Board of Governors of the Federal Reserve System for transfer to the Secretary of the Treasury for deposit in the general fund of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb2c2531-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s289/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002034"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002034"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Codification note below."}],"tail":" Transfer for fiscal year 2000"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb2c2532-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s289/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal reserve banks shall transfer from the surplus funds of such banks to the Board of Governors of the Federal Reserve System for transfer to the Secretary of the Treasury for deposit in the general fund of the Treasury, a total amount of $3,752,000,000 in fiscal year 2000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb2c2533-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s289/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocated by Fed","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the total amount required to be paid by the Federal reserve banks under paragraph (1) for fiscal year 2000, the Board shall determine the amount each such bank shall pay in such fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb2c2534-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s289/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Replenishment of surplus fund prohibited","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"During fiscal year 2000, no Federal reserve bank may replenish such bank’s surplus fund by the amount of any transfer by such bank under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddb2c2535-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1913-12-23/ch6/s7/a"},"text":"Dec. 23, 1913, ch. 6, § 7(a)","children":[],"tail":", (b), "},{"tag":"ref","attrib":{"href":"/us/stat/38/258"},"text":"38 Stat. 258","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1919-03-03/ch101/s1"},"text":"Mar. 3, 1919, ch. 101, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/40/1314"},"text":"40 Stat. 1314","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1933-06-16/ch89/s4"},"text":"June 16, 1933, ch. 89, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/163"},"text":"48 Stat. 163","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/tIII/s3002/a"},"text":"Pub. L. 103–66, title III, § 3002(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/337"},"text":"107 Stat. 337","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/325/tVI/s602/d"},"text":"Pub. L. 103–325, title VI, § 602(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2291"},"text":"108 Stat. 2291","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/5/tIII/s302"},"text":"Pub. L. 106–113, div. B, § 1000(a)(5) [title III, § 302]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–304; "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dC/tXXXII"},"text":"Pub. L. 114–94, div. C, title XXXII","children":[],"tail":", §§ 32202, 32203(a), "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1739"},"text":"129 Stat. 1739","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/123/dC/tII/s30205"},"text":"Pub. L. 115–123, div. C, title II, § 30205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-02-09"},"text":"Feb. 9, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/127"},"text":"132 Stat. 127","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/174/tII/s217"},"text":"Pub. L. 115–174, title II, § 217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-05-24"},"text":"May 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1326"},"text":"132 Stat. 1326","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb2c2536-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb2c2537-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddb2c2538-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of subsec. (a) [formerly first undesignated par.] of section 7 of act ","children":[{"tag":"date","attrib":{"date":"1913-12-23"},"text":"Dec. 23, 1913","children":[],"tail":", and subsec. (b) [enacted by "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/5/tIII/s302/2"},"text":"Pub. L. 106–113, div. B, § 1000(a)(5) [title III, § 302(2)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–304] of section 7. Another subsec. (b) of section 7 is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s290"},"text":"section 290 of this title","children":[],"tail":". Subsec. (c) of section 7 is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s531"},"text":"section 531 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddb2c2539-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/174"},"text":"Pub. L. 115–174","children":[],"tail":" substituted “$6,825,000,000” for “$7,500,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123"},"text":"Pub. L. 115–123","children":[],"tail":" substituted “$7,500,000,000” for “$10,000,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s32203/a/1"},"text":"Pub. L. 114–94, § 32203(a)(1)","children":[],"tail":", amended subpar. (A) generally. Prior to amendment, text read as follows: “After all necessary expenses of a Federal reserve bank have been paid or provided for, the stockholders of the bank shall be entitled to receive an annual dividend of 6 percent on paid-in capital stock.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s32203/a/2"},"text":"Pub. L. 114–94, § 32203(a)(2)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s32202"},"text":"Pub. L. 114–94, § 32202","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/s1000/a/5/tIII/s302/1"},"text":"Pub. L. 106–113, § 1000(a)(5) [title III, § 302(1)]","children":[],"tail":", struck out heading and text of par. (3). Text read as follows: “During fiscal years 1997 and 1998, any amount in the surplus fund of any Federal reserve bank in excess of the amount equal to 3 percent of the total paid-in capital and surplus of the member banks of such bank shall be transferred to the Board for transfer to the Secretary of the Treasury for deposit in the general fund of the Treasury.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/s1000/a/5/tIII/s302/2"},"text":"Pub. L. 106–113, § 1000(a)(5) [title III, § 302(2)]","children":[],"tail":", added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Par. (1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/s602/d/1"},"text":"Pub. L. 103–325, § 602(d)(1)","children":[],"tail":", inserted “(A)” after “subparagraph”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/s602/d/2"},"text":"Pub. L. 103–325, § 602(d)(2)","children":[],"tail":", substituted “paragraph (1)(A)” for “subparagraph (A)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66"},"text":"Pub. L. 103–66","children":[],"tail":" inserted section catchline and amended section generally. Prior to amendment, section read as follows: “After all necessary expenses of a Federal reserve bank shall have been paid or provided for, the stockholders shall be entitled to receive an annual dividend of 6 per centum on the paid-in capital stock, which dividend shall be cumulative. After the aforesaid dividend claims have been fully met, the net earnings shall be paid into the surplus fund of the Federal reserve bank.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1933—Act ","children":[{"tag":"date","attrib":{"date":"1933-06-16"},"text":"June 16, 1933","children":[],"tail":", provided that net earnings shall be paid into surplus instead of to the United States as a franchise tax."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddb2c253a-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddb2c253b-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dC/tXXXII/s32203/b"},"text":"Pub. L. 114–94, div. C, title XXXII, § 32203(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1740"},"text":"129 Stat. 1740","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/94/dC/tXXXII/s32203/b"},"text":"“The amendments made by subsection (a) [amending this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"2016-01-01"},"text":"January 1, 2016","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddb2c253c-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1933 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1933-06-16/ch89/s4"},"text":"Act June 16, 1933, ch. 89, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/163"},"text":"48 Stat. 163","children":[],"tail":", provided that the amendment made by that section is effective "},{"tag":"date","attrib":{"date":"1932-07-01"},"text":"July 1, 1932","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddb2c253d-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Discretionary Surplus Funds","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dF/tLXV/s6510"},"text":"Pub. L. 116–283, div. F, title LXV, § 6510","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4633"},"text":"134 Stat. 4633","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/283/dF/tLXV/s6510"},"text":"“The dollar amount specified under section 7(a)(3)(A) of the Federal Reserve Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s289/a/3/A"},"text":"12 U.S.C. 289(a)(3)(A)","children":[],"tail":") is reduced by $40,000,000.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddb2c253e-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Additional Transfers for Fiscal Years 1997 and 1998","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/tIII/s3002/b"},"text":"Pub. L. 103–66, title III, § 3002(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/337"},"text":"107 Stat. 337","children":[],"tail":", provided that in addition to the amounts required to be transferred from the surplus funds of the Federal reserve banks pursuant to former "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s289/a/3"},"text":"section 289(a)(3) of this title","children":[],"tail":", the Federal reserve banks should transfer $106,000,000 in fiscal year 1997 and $107,000,000 in fiscal year 1998 from their surplus funds to the Treasury for deposit in the general fund, and prohibited the banks from replenishing their surplus funds by the amount of such transfer."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
