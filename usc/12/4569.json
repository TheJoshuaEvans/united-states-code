{"tag":"section","attrib":{"id":"iddd2cd6dd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569"},"text":null,"children":[{"tag":"num","attrib":{"value":"4569"},"text":"§ 4569.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capital Magnet Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd2cd6de-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Treasury of the United States a trust fund to be known as the Capital Magnet Fund, which shall be a special account within the Community Development Financial Institutions Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2cd6df-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposits to Trust Fund","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Capital Magnet Fund shall consist of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2cd6e0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amounts transferred to the Fund pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4567"},"text":"section 4567 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2cd6e1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amounts as are or may be appropriated, transferred, or credited to such Fund under any other provisions of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2cd6e2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditures from Trust Fund","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts in the Capital Magnet Fund shall be available to the Secretary of the Treasury to carry out a competitive grant program to attract private capital for and increase investment in—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2cd6e3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development, preservation, rehabilitation, or purchase of affordable housing for primarily extremely low-, very low-, and low-income families; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2cd6e4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" economic development activities or community service facilities, such as day care centers, workforce development centers, and health care clinics, which in conjunction with affordable housing activities implement a concerted strategy to stabilize or revitalize a low-income area or underserved rural area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2cd6e5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of the application of Federal civil rights laws, all assistance provided using amounts in the Capital Magnet Fund shall be considered Federal financial assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2cd6e6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible grantees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grant under this section may be made, pursuant to such requirements as the Secretary of the Treasury shall establish for experience and success in attracting private financing and carrying out the types of activities proposed under the application of the grantee, only to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2cd6e7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Treasury certified community development financial institution; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2cd6e8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit organization having as 1 of its principal purposes the development or management of affordable housing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2cd6e9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible uses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grant amounts awarded from the Capital Magnet Fund pursuant to this section may be used for the purposes described in paragraphs (1) and (2) of subsection (c), including for the following uses:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2cd6ea-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To provide loan loss reserves.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2cd6eb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To capitalize a revolving loan fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2cd6ec-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To capitalize an affordable housing fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2cd6ed-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To capitalize a fund to support activities described in subsection (c)(2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2cd6ee-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For risk-sharing loans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2cd6ef-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2cd6f0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury shall provide, in a competitive application process established by regulation, for eligible grantees under subsection (e) to submit applications for Capital Magnet Fund grants to the Secretary at such time and in such manner as the Secretary shall determine.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2cd6f1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content of application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The application required under paragraph (1) shall include a detailed description of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd2cd6f2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the types of affordable housing, economic, and community revitalization projects that support or sustain residents of an affordable housing project funded by a grant under this section for which such grant amounts would be used, including the proposed use of eligible grants as authorized under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd2cd6f3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the types, sources, and amounts of other funding for such projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd2cd6f4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expected time frame of any grant used for such project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2cd6f5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant limitation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2cd6f6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any 1 eligible grantee and its subsidiaries and affiliates may not be awarded more than 15 percent of the aggregate funds available for grants during any year from the Capital Magnet Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2cd6f7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geographic diversity","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd2cd6f8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury shall seek to fund activities in geographically diverse areas of economic distress, including metropolitan and underserved rural areas in every State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd2cd6f9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Diversity defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this paragraph, geographic diversity includes those areas that meet objective criteria of economic distress developed by the Secretary of the Treasury, which may include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd2cd6fa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/h/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percentage of low-income families or the extent of poverty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd2cd6fb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/h/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rate of unemployment or underemployment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd2cd6fc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/h/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" extent of blight and disinvestment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd2cd6fd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/h/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projects that target extremely low-, very low-, and low-income families in or outside a designated economic distress area; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd2cd6fe-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/h/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other criteria designated by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2cd6ff-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leverage of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each grant from the Capital Magnet Fund awarded under this section shall be reasonably expected to result in eligible housing, or economic and community development projects that support or sustain an affordable housing project funded by a grant under this section whose aggregate costs total at least 10 times the grant amount.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2cd700-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commitment for use deadline","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts made available for grants under this section shall be committed for use within 2 years of the date of such allocation. The Secretary of the Treasury shall recapture into the Capital Magnet Fund any amounts not so used or committed for use and allocate such amounts in the first year after such recapture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2cd701-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/h/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited uses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall, by regulation, set forth prohibited uses of grant amounts awarded under this section, which shall include use for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd2cd702-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/h/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" political activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd2cd703-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/h/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advocacy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd2cd704-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/h/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lobbying, whether directly or through other parties;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd2cd705-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/h/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" counseling services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd2cd706-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/h/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" travel expenses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd2cd707-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/h/5/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preparing or providing advice on tax returns;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"and for the purposes of this paragraph, the prohibited use of funds for political activities includes influencing the selection, nomination, election, or appointment of one or more candidates to any Federal, State or local office as codified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501"},"text":"section 501 of title 26","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2cd708-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/h/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional lobbying restrictions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No assistance or amounts made available under this section may be expended by an eligible grantee to pay any person to influence or attempt to influence any agency, elected official, officer or employee of a State or local government in connection with the making, award, extension, continuation, renewal, amendment, or modification of any State or local government contract, grant, loan, or cooperative agreement as such terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1352"},"text":"section 1352 of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2cd709-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/h/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of consideration of use for meeting housing goals or duty to serve","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In determining the compliance of the enterprises with the housing goals under this section and the duty to serve underserved markets under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4565"},"text":"section 4565 of this title","children":[],"tail":", the Director of the Federal Housing Finance Agency may not consider any Capital Magnet Fund amounts used under this section for eligible activities under subsection (f). The Director of the Federal Housing Finance Agency shall give credit toward the achievement of such housing goals and such duty to serve underserved markets to purchases by the enterprises of mortgages for housing that receives funding from Capital Magnet Fund grant amounts, but only to the extent that such purchases by the enterprises are funded other than with such grant amounts."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2cd70a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/h/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accountability of recipients and grantees","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd2cd70b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/h/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tracking of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Treasury shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd2cd70c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/h/8/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require each grantee to develop and maintain a system to ensure that each recipient of assistance from the Capital Magnet Fund uses such amounts in accordance with this section, the regulations issued under this section, and any requirements or conditions under which such amounts were provided; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd2cd70d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/h/8/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish minimum requirements for agreements, between the grantee and the Capital Magnet Fund, regarding assistance from the Capital Magnet Fund, which shall include—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddd2cd70e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/h/8/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate periodic financial and project reporting, record retention, and audit requirements for the duration of the grant to the recipient to ensure compliance with the limitations and requirements of this section and the regulations under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddd2cd70f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/h/8/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other requirements that the Secretary determines are necessary to ensure appropriate grant administration and compliance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd2cd710-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/h/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Misuse of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary of the Treasury determines, after reasonable notice and opportunity for hearing, that a grantee has failed to comply substantially with any provision of this section and until the Secretary is satisfied that there is no longer any such failure to comply, the Secretary shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd2cd711-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/h/8/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce the amount of assistance under this section to the grantee by an amount equal to the amount of Capital Magnet Fund grant amounts which were not used in accordance with this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd2cd712-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/h/8/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require the grantee to repay the Secretary any amount of the Capital Magnet Fund grant amounts which were not used in accordance with this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd2cd713-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/h/8/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limit the availability of assistance under this section to the grantee to activities or recipients not affected by such failure to comply; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd2cd714-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/h/8/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" terminate any assistance under this section to the grantee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2cd715-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2cd716-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury shall submit a report, on a periodic basis, to the Committee on Banking, Housing, and Urban Affairs of the Senate and the Committee on Financial Services of the House of Representatives describing the activities to be funded under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2cd717-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports available to public","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury shall make the reports required under paragraph (1) publicly available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2cd718-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2cd719-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury shall issue regulations to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2cd71a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The regulations issued under this subsection shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd2cd71b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/j/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authority for the Secretary to audit, provide for an audit, or otherwise verify an enterprise’s activities, to ensure compliance with this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd2cd71c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/j/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a requirement that the Secretary ensure that the allocation of each enterprise is audited not less than annually to ensure compliance with this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd2cd71d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/j/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a requirement that, for the purposes of subparagraphs (A) and (B), any financial statement submitted by a grantee to the Secretary shall be reviewed by an independent certified public accountant in accordance with Statements on Standards for Accounting and Review Services, issued by the American Institute of Certified Public Accountants; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd2cd71e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/j/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" requirements for a process for application to, and selection by, the Secretary for activities to be funded with amounts from the Capital Magnet Fund, which shall provide that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd2cd71f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/j/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funds be fairly distributed to urban, suburban, and rural areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd2cd720-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/j/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" selection shall be based upon specific criteria, including a prioritization of funding based upon—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddd2cd721-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/j/2/D/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability to use such funds to generate additional investments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddd2cd722-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/j/2/D/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affordable housing need (taking into account the distinct needs of different regions of the country); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddd2cd723-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4569/j/2/D/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ability to obligate amounts and undertake activities so funded in a timely manner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd2cd724-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXIII/s1339"},"text":"Pub. L. 102–550, title XIII, § 1339","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tI/s1131/b"},"text":"Pub. L. 110–289, div. A, title I, § 1131(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2723"},"text":"122 Stat. 2723","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
