{"tag":"section","attrib":{"id":"iddd2cd78a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4588"},"text":null,"children":[{"tag":"num","attrib":{"value":"4588"},"text":"§ 4588.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subpoena authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd2cd78b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4588/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the course of or in connection with any administrative proceeding under this subpart, the Director shall have the authority—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2cd78c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4588/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to administer oaths and affirmations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2cd78d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4588/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to take and preserve testimony under oath;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2cd78e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4588/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to issue subpoenas and subpoenas duces tecum; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2cd78f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4588/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to revoke, quash, or modify subpoenas and subpoenas duces tecum issued by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2cd790-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4588/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Witnesses and documents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The attendance of witnesses and the production of documents provided for in this section may be required from any place in any State at any designated place where such proceeding is being conducted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2cd791-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4588/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may bring an action or may request the Attorney General of the United States to bring an action in the United States district court for the judicial district in which such proceeding is being conducted, or where the witness resides or conducts business, or the United States District Court for the District of Columbia, for enforcement of any subpoena or subpoena duces tecum issued pursuant to this section. Such courts shall have jurisdiction and power to order and require compliance therewith.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2cd792-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4588/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees and expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Witnesses subpoenaed under this section shall be paid the same fees and mileage that are paid witnesses in the district courts of the United States. Any court having jurisdiction of any proceeding instituted under this section by an enterprise may allow to any such party such reasonable expenses and attorneys fees as the court deems just and proper. Such expenses and fees shall be paid by the enterprise or from its assets.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd2cd793-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXIII/s1348"},"text":"Pub. L. 102–550, title XIII, § 1348","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3968"},"text":"106 Stat. 3968","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tI/s1130/e/2"},"text":"Pub. L. 110–289, div. A, title I, § 1130(e)(2)","children":[],"tail":", (3)(E), "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2711"},"text":"122 Stat. 2711","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd2cd794-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd2cd795-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd2cd796-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/s1130/e/3/E"},"text":"Pub. L. 110–289, § 1130(e)(3)(E)","children":[],"tail":", substituted “Director” for “Secretary” in introductory provisions and in par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/s1130/e/3/E"},"text":"Pub. L. 110–289, § 1130(e)(3)(E)","children":[],"tail":", substituted “Director” for “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/s1130/e/2"},"text":"Pub. L. 110–289, § 1130(e)(2)","children":[],"tail":", inserted “may bring an action or” before “may request”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
