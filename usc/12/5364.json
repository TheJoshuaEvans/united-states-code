{"tag":"section","attrib":{"id":"iddd57b6d3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5364"},"text":null,"children":[{"tag":"num","attrib":{"value":"5364"},"text":"§ 5364.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition against management interlocks between certain financial companies","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A nonbank financial company supervised by the Board of Governors shall be treated as a bank holding company for purposes of the Depository Institutions ","children":[{"tag":"ref","attrib":{"idref":"fn002475"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002475"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Institution”."}],"tail":" Management Interlocks Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t12/s3201"},"text":"12 U.S.C. 3201","children":[],"tail":" et seq.), except that the Board of Governors shall not exercise the authority provided in section 7 "},{"tag":"ref","attrib":{"idref":"fn002476"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002476"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. There is no section 7 of such Act."}],"tail":" of that Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t12/s3207"},"text":"12 U.S.C. 3207","children":[],"tail":") to permit service by a management official of a nonbank financial company supervised by the Board of Governors as a management official of any bank holding company with total consolidated assets equal to or greater than $250,000,000,000, or other nonaffiliated nonbank financial company supervised by the Board of Governors (other than to provide a temporary exemption for interlocks resulting from a merger, acquisition, or consolidation)."}],"tail":"\n"}],"tail":null},{"ta