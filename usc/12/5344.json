{"tag":"section","attrib":{"id":"iddd556e4c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5344"},"text":null,"children":[{"tag":"num","attrib":{"value":"5344"},"text":"§ 5344.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organizational structure; responsibilities of primary programmatic units","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd556e4d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5344/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are established within the Office, to carry out the programmatic responsibilities of the Office—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd556e4e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5344/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Data Center; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd556e4f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5344/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Research and Analysis Center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd556e50-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5344/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data Center","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd556e51-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5344/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General duties","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd556e52-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5344/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data collection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Data Center, on behalf of the Council, shall collect, validate, and maintain all data necessary to carry out the duties of the Data Center, as described in this part. The data assembled shall be obtained from member agencies, commercial data providers, publicly available data sources, and financial entities under subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd556e53-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5344/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd556e54-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5344/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office may, as determined by the Council or by the Director in consultation with the Council, require the submission of periodic and other reports from any financial company for the purpose of assessing the extent to which a financial activity or financial market in which the financial company participates, or the financial company itself, poses a threat to the financial stability of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd556e55-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5344/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mitigation of report burden","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before requiring the submission of a report from any financial company that is regulated by a member agency, any primary financial regulatory agency, a foreign supervisory authority, or the Office shall coordinate with such agencies or authority, and shall, whenever possible, rely on information available from such agencies or authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd556e56-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5344/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection of financial transaction and position data","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office shall collect, on a schedule determined by the Director, in consultation with the Council, financial transaction data and position data from financial companies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd556e57-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5344/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rulemaking","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office shall promulgate regulations pursuant to subsections (a)(1), (a)(2), (a)(7), and (c)(1) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5343"},"text":"section 5343 of this title","children":[],"tail":" regarding the type and scope of the data to be collected by the Data Center under this paragraph."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd556e58-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5344/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd556e59-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5344/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Data Center shall prepare and publish, in a manner that is easily accessible to the public—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd556e5a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5344/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a financial company reference database;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd556e5b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5344/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a financial instrument reference database; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd556e5c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5344/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" formats and standards for Office data, including standards for reporting financial transaction and position data to the Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd556e5d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5344/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Data Center shall not publish any confidential data under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd556e5e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5344/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information security","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall ensure that data collected and maintained by the Data Center are kept secure and protected against unauthorized disclosure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd556e5f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5344/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Catalog of financial entities and instruments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Data Center shall maintain a catalog of the financial entities and instruments reported to the Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd556e60-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5344/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability to the Council and member agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Data Center shall make data collected and maintained by the Data Center available to the Council and member agencies, as necessary to support their regulatory responsibilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd556e61-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5344/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office shall, after consultation with the member agencies, provide certain data to financial industry participants and to the general public to increase market transparency and facilitate research on the financial system, to the extent that intellectual property rights are not violated, business confidential information is properly protected, and the sharing of such information poses no significant threats to the financial system of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd556e62-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5344/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research and Analysis Center","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd556e63-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5344/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002472"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002472"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. No par. (2) has been enacted."}],"tail":" General duties"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Research and Analysis Center, on behalf of the Council, shall develop and maintain independent analytical capabilities and computing resources—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd556e64-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5344/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop and maintain metrics and reporting systems for risks to the financial stability of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd556e65-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5344/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to monitor, investigate, and report on changes in systemwide risk levels and patterns to the Council and Congress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd556e66-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5344/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct, coordinate, and sponsor research to support and improve regulation of financial entities and markets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd556e67-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5344/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to evaluate and report on stress tests or other stability-related evaluations of financial entities overseen by the member agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd556e68-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5344/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maintain expertise in such areas as may be necessary to support specific requests for advice and assistance from financial regulators;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd556e69-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5344/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to investigate disruptions and failures in the financial markets, report findings, and make recommendations to the Council based on those findings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd556e6a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5344/c/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct studies and provide advice on the impact of policies related to systemic risk; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd556e6b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5344/c/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote best practices for financial risk management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd556e6c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5344/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting responsibilities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd556e6d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5344/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", and not later than 120 days after the end of each fiscal year thereafter, the Office shall prepare and submit a report to Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd556e6e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5344/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report required by this subsection shall assess the state of the United States financial system, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd556e6f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5344/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of any threats to the financial stability of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd556e70-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5344/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status of the efforts of the Office in meeting the mission of the Office; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd556e71-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5344/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" key findings from the research and analysis of the financial system by the Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd556e72-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tI/s154"},"text":"Pub. L. 111–203, title I, § 154","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1416"},"text":"124 Stat. 1416","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
