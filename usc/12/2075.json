{"tag":"section","attrib":{"id":"iddcbf21d1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2075"},"text":null,"children":[{"tag":"num","attrib":{"value":"2075"},"text":"§ 2075.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short- and intermediate-term loans; participation; other financial assistance; terms; conditions; interest; security","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcc191d2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2075/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short- and intermediate-term loans","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each production credit association, under standards prescribed by the board of directors of the Farm Credit Bank of the district, may make, guarantee, or participate with other lenders in short- and intermediate-term loans and other similar financial assistance to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcc191d3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2075/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bona fide farmers and ranchers and the producers or harvesters of aquatic products, for agricultural or aquatic purposes and other requirements of such borrowers, including financing for basic processing and marketing directly related to the operations of the borrower and those of other eligible farmers, ranchers, and producers or harvesters of aquatic products, except that the operations of the borrower shall supply some portion of the total processing or marketing for which financing is extended, except that the aggregate of the financing provided by any association for basic processing and marketing directly related to the operations of farmers, ranchers, and producers or harvesters of aquatic products, if the operations of the applicant supply less than 20 percent of the total processing or marketing for which financing is extended, shall not exceed 15 percent of the total of all outstanding loans of all associations in the district at the end of its preceding fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc191d4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2075/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rural residents for housing financing in rural areas, under regulations of the Farm Credit Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc191d5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2075/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" persons furnishing to farmers and ranchers farm-related services directly related to their on-farm operating needs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcc191d6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2075/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural housing","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcc191d7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2075/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Rural housing financed under this part shall be for single-family, moderate-priced dwellings and the appurtenances of such not inconsistent with the general quality and standards of housing existing in, or planned or recommended for, the rural area where it is located.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc191d8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2075/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The aggregate of such housing loans in an association to persons other than farmers or ranchers shall not exceed 15 percent of the outstanding loans at the end of its preceding fiscal year except on prior approval by the Farm Credit Bank of the district. The aggregate of such housing loans in any farm credit district shall not exceed 15 percent of the outstanding loans of all associations in the district at the end of the preceding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc191d9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2075/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural areas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For rural housing purposes under this section the term “rural areas” shall not be defined to include any city or village having a population in excess of 2,500 inhabitants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc191da-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2075/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equipment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each association may own and lease, or lease with option to purchase, to stockholders of the association equipment needed in the operations of the stockholder.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcc191db-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2075/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest rates and charges","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcc191dc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2075/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Loans authorized in subsection (a) shall bear such rate or rates of interest as are determined under standards prescribed by the board of the bank subject to the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2205"},"text":"section 2205 of this title","children":[],"tail":", and shall be made upon such terms, conditions, and upon such security, if any, as shall be authorized in such standards."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc191dd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2075/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Setting of rates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In setting rates and charges, it shall be the objective to provide the types of credit needed by eligible borrowers, at the lowest reasonable cost on a sound business basis, taking into account the cost of money to the association, necessary reserves and expenses of the association, and services provided to borrowers and members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc191de-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2075/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Varying rates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The loan documents may provide for the interest rate or rates to vary from time to time during the repayment period of the loan in accordance with the rate or rates currently being charged by the association.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc191df-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2075/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prior approval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such standards may require prior approval of the bank on certain classes of loans, and may authorize a continuing commitment to a borrower of a line of credit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcc191e0-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tII/s2"},"text":"Pub. L. 92–181, title II, § 2","children":[],"tail":".4, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tIV/s401"},"text":"Pub. L. 100–233, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1632"},"text":"101 Stat. 1632","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/tIV/s401/p"},"text":"Pub. L. 100–399, title IV, § 401(p)","children":[],"tail":", (q), "},{"tag":"date","attrib":{"date":"1988-08-17"},"text":"Aug. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/997"},"text":"102 Stat. 997","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXVIII/s1832/b"},"text":"Pub. L. 101–624, title XVIII, § 1832(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3832"},"text":"104 Stat. 3832","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tV/s5411/3"},"text":"Pub. L. 115–334, title V, § 5411(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4679"},"text":"132 Stat. 4679","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcc191e1-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcc191e2-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"iddcc191e3-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2075, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tII/s2"},"text":"Pub. L. 92–181, title II, § 2","children":[],"tail":".4, "},{"tag":"date","attrib":{"date":"1971-12-10"},"text":"Dec. 10, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/594"},"text":"85 Stat. 594","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/443"},"text":"Pub. L. 95–443","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-10"},"text":"Oct. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1066"},"text":"92 Stat. 1066","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/592/tII/s204"},"text":"Pub. L. 96–592, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-24"},"text":"Dec. 24, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3441"},"text":"94 Stat. 3441","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/509/tI/s1033/b"},"text":"Pub. L. 99–509, title I, § 1033(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1877"},"text":"100 Stat. 1877","children":[],"tail":", related to terms, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/s401"},"text":"Pub. L. 100–233, § 401","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcc191e4-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" struck out subsec. (d) which described a special rule for providing credit and technical assistance in a district containing only two production credit associations."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":" substituted “some portion of the total processing or marketing for which financing is extended, except that the aggregate of the financing provided by any association for basic processing and marketing directly related to the operations of farmers, ranchers, and producers or harvesters of aquatic products, if the operations of the applicant supply less than 20 percent of the total processing or marketing for which financing is extended, shall not exceed 15 percent of the total of all outstanding loans of all associations in the district at the end of its preceding fiscal year” for “at least 20 percent, or such larger percent as is required by the supervising bank under regulations of the Farm Credit Administration, of the total processing or marketing for which financing is extended”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s401/p"},"text":"Pub. L. 100–399, § 401(p)","children":[],"tail":", substituted “this part” for “this subchapter” and substituted “or planned” for “planned”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s401/q"},"text":"Pub. L. 100–399, § 401(q)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcc191e5-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcc191e6-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399"},"text":"Pub. L. 100–399","children":[],"tail":" effective immediately after amendment made by "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/s401"},"text":"section 401 of Pub. L. 100–233","children":[],"tail":", which was effective 6 months after "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/s1001/b"},"text":"section 1001(b) of Pub. L. 100–399","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2002"},"text":"section 2002 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddcc191e7-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/233/tIV/s401"},"text":"Pub. L. 100–233, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1622"},"text":"101 Stat. 1622","children":[],"tail":", provided that this section is effective 6 months after "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
