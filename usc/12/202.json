{"tag":"section","attrib":{"id":"iddb1df45b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s202"},"text":null,"children":[{"tag":"num","attrib":{"value":"202"},"text":"§ 202.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"As used in this subchapter, the term “bank” means any national banking association or any other financial institution chartered or licensed under Federal law and subject to the supervision of the Comptroller of the Currency; the term “voluntary dissolution and liquidation” means a transaction pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s181"},"text":"section 181 of this title","children":[],"tail":" that involves the assumption of the bank’s insured deposit liabilities and the sale of the bank, or of control of the bank, as a going concern; and the term “State” means any State, Territory, or possession of the United States, and the Canal Zone."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddb1df45c-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-03-09/ch1"},"text":"Mar. 9, 1933, ch. 1","children":[],"tail":", title II, § 202, "},{"tag":"ref","attrib":{"href":"/us/stat/48/2"},"text":"48 Stat. 2","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/73/tVIII/s801"},"text":"Pub. L. 101–73, title VIII, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/441"},"text":"103 Stat. 441","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/351/tVII/s725/b"},"text":"Pub. L. 109–351, title VII, § 725(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-13"},"text":"Oct. 13, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2001"},"text":"120 Stat. 2001","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/356/tI/s123/b"},"text":"Pub. L. 109–356, title I, § 123(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-16"},"text":"Oct. 16, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2028"},"text":"120 Stat. 2028","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb1df45d-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb1df45e-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddb1df45f-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For definition of Canal Zone, referred to in text, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3602/b"},"text":"section 3602(b) of Title 22","children":[],"tail":", Foreign Relations and Intercourse."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddb1df460-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/351"},"text":"Pub. L. 109–351","children":[],"tail":" and 109–356 amended section identically, substituting “means any national” for “means (1) any national” and striking out “, and (2) any bank or trust company located in the District of Columbia and operating under the supervision of the Comptroller of the Currency” before first semicolon."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/s801/1"},"text":"Pub. L. 101–73, § 801(1)","children":[],"tail":", in cl. (1), extended term “bank” to include any financial institution chartered or licensed under Federal law and subject to supervision of Comptroller of the Currency."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/s801/2"},"text":"Pub. L. 101–73, § 801(2)","children":[],"tail":", in cl. (2), inserted definition of term “voluntary dissolution and liquidation”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
