{"tag":"section","attrib":{"id":"iddd281c23-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4544"},"text":null,"children":[{"tag":"num","attrib":{"value":"4544"},"text":"§ 4544.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual housing report","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd281c24-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4544/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After reviewing and analyzing the reports submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1723a/n"},"text":"section 1723a(n) of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1456/f"},"text":"section 1456(f) of this title","children":[],"tail":", the Director shall submit a report, not later than October 30 of each year, to the Committee on Banking, Housing, and Urban Affairs of the Senate and the Committee on Financial Services of the House of Representatives, on the activities of each enterprise."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd281c25-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4544/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report required under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd281c26-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4544/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" discuss—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd281c27-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4544/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the extent to and manner in which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd281c28-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4544/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each enterprise is achieving the annual housing goals established under subpart 2;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd281c29-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4544/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each enterprise is complying with its duty to serve underserved markets, as established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4565"},"text":"section 4565 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd281c2a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4544/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each enterprise is complying with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4567"},"text":"section 4567 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd281c2b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4544/b/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each enterprise received credit towards achieving each of its goals resulting from a transaction or activity pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4561/b/2"},"text":"section 4561(b)(2) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd281c2c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4544/b/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each enterprise is achieving the purposes of the enterprise established by law; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd281c2d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4544/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the actions that each enterprise could undertake to promote and expand the purposes of the enterprise;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd281c2e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4544/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aggregate and analyze relevant data on income to assess the compliance of each enterprise with the housing goals established under subpart 2;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd281c2f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4544/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aggregate and analyze data on income, race, and gender by census tract and other relevant classifications, and compare such data with larger demographic, housing, and economic trends;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd281c30-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4544/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify the extent to which each enterprise is involved in mortgage purchases and secondary market activities involving subprime and nontraditional loans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd281c31-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4544/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compare the characteristics of subprime and nontraditional loans both purchased and securitized by each enterprise to other loans purchased and securitized by each enterprise; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd281c32-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4544/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" compare the characteristics of high-cost loans purchased and securitized, where such securities are not held on portfolio to loans purchased and securitized, where such securities are either retained on portfolio or repurchased by the enterprise, including such characteristics as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd281c33-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4544/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purchase price of the property that secures the mortgage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd281c34-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4544/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the loan-to-value ratio of the mortgage, which shall reflect any secondary liens on the relevant property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd281c35-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4544/b/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms of the mortgage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd281c36-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4544/b/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the creditworthiness of the borrower; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd281c37-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4544/b/6/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other relevant data, as determined by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd281c38-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4544/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data collection and reporting","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd281c39-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4544/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To assist the Director in analyzing the matters described in subsection (b), the Director shall conduct, on a monthly basis, a survey of mortgage markets in accordance with this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd281c3a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4544/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data points","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each monthly survey conducted by the Director under paragraph (1) shall collect data on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd281c3b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4544/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the characteristics of individual mortgages that are eligible for purchase by the enterprises and the characteristics of individual mortgages that are not eligible for purchase by the enterprises including, in both cases, information concerning—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd281c3c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4544/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the price of the house that secures the mortgage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd281c3d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4544/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the loan-to-value ratio of the mortgage, which shall reflect any secondary liens on the relevant property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd281c3e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4544/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms of the mortgage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd281c3f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4544/c/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the creditworthiness of the borrower or borrowers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd281c40-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4544/c/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the mortgage, in the case of a conforming mortgage, was purchased by an enterprise;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd281c41-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4544/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the characteristics of individual subprime and nontraditional mortgages that are eligible for purchase by the enterprises and the characteristics of borrowers under such mortgages, including the creditworthiness of such borrowers and determination whether such borrowers would qualify for prime lending; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd281c42-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4544/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other matters as the Director determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd281c43-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4544/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall make any data collected by the Director in connection with the conduct of a monthly survey available to the public in a timely manner, provided that the Director may modify the data released to the public to ensure that the data—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd281c44-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4544/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not released in an identifiable form; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd281c45-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4544/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not otherwise obtainable from other publicly available data sets.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd281c46-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4544/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, the term “identifiable form” means any representation of information that permits the identity of a borrower to which the information relates to be reasonably inferred by either direct or indirect means.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd281c47-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXIII/s1324"},"text":"Pub. L. 102–550, title XIII, § 1324","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tI/s1125/b"},"text":"Pub. L. 110–289, div. A, title I, § 1125(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2693"},"text":"122 Stat. 2693","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd281c48-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd281c49-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"iddd281c4a-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 4544, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXIII/s1324"},"text":"Pub. L. 102–550, title XIII, § 1324","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3954"},"text":"106 Stat. 3954","children":[],"tail":", related to annual housing report, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tI/s1125/a"},"text":"Pub. L. 110–289, div. A, title I, § 1125(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2693"},"text":"122 Stat. 2693","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
