{"tag":"section","attrib":{"id":"iddd804e97-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901"},"text":null,"children":[{"tag":"num","attrib":{"value":"5901"},"text":"§ 5901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd804e98-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate Federal banking agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “appropriate Federal banking agency” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"section 1813 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd804e99-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bank Secrecy Act","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Bank Secrecy Act” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd804e9a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1829b"},"text":"section 1829b of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd804e9b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 2 of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/508"},"text":"Public Law 91–508","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1951"},"text":"12 U.S.C. 1951","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd804e9c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subchapter II of chapter 53 of title 31.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd804e9d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Board” means the Board of Governors of the Federal Reserve System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd804e9e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comptroller","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Comptroller” means the Office of the Comptroller of the Currency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd804e9f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Corporation” means the Federal Deposit Insurance Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd804ea0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Digital asset","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “digital asset” means any digital representation of value that is recorded on a cryptographically secured distributed ledger.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd804ea1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Digital asset service provider","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “digital asset service provider”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd804ea2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means a person that, for compensation or profit, engages in the business in the United States (including on behalf of customers or users in the United States) of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd804ea3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/7/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exchanging digital assets for monetary value;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd804ea4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/7/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exchanging digital assets for other digital assets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd804ea5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/7/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transferring digital assets to a third party;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd804ea6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/7/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acting as a digital asset custodian; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd804ea7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/7/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participating in financial services relating to digital asset issuance; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd804ea8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" does not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd804ea9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/7/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a distributed ledger protocol;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd804eaa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/7/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing, operating, or engaging in the business of developing distributed ledger protocols or self-custodial software interfaces;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd804eab-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/7/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an immutable and self-custodial software interface;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd804eac-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/7/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing, operating, or engaging in the business of validating transactions or operating a distributed ledger; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd804ead-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/7/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participating in a liquidity pool or other similar mechanism for the provisioning of liquidity for peer-to-peer transactions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd804eae-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distributed ledger","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “distributed ledger” means technology in which data is shared across a network that creates a public digital ledger of verified transactions or information among network participants and cryptography is used to link the data to maintain the integrity of the public ledger and execute other functions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd804eaf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distributed ledger protocol","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “distributed ledger protocol” means publicly available and accessible executable software deployed to a distributed ledger, including smart contracts or networks of smart contracts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd804eb0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal branch","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Federal branch” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"section 1813 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd804eb1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal qualified payment stablecoin issuer","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Federal qualified payment stablecoin issuer” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd804eb2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonbank entity, other than a State qualified payment stablecoin issuer, approved by the Comptroller, pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5904"},"text":"section 5904 of this title","children":[],"tail":", to issue payment stablecoins;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd804eb3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an uninsured national bank—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd804eb4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/11/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is chartered by the Comptroller, pursuant to title LXII of the Revised Statutes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd804eb5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/11/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is approved by the Comptroller, pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5904"},"text":"section 5904 of this title","children":[],"tail":", to issue payment stablecoins; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd804eb6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/11/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Federal branch that is approved by the Comptroller, pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5904"},"text":"section 5904 of this title","children":[],"tail":", to issue payment stablecoins."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd804eb7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign payment stablecoin issuer","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “foreign payment stablecoin issuer” means an issuer of a payment stablecoin that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd804eb8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/12/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" organized under the laws of or domiciled in a foreign country, a territory of the United States, Puerto Rico, Guam, American Samoa, or the Virgin Islands; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd804eb9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/12/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not a permitted payment stablecoin issuer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd804eba-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institution-affiliated party","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to a permitted payment stablecoin issuer, the term “institution-affiliated party” means any director, officer, employee, or controlling stockholder of the permitted payment stablecoin issuer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd804ebb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Insured credit union","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “insured credit union” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1752"},"text":"section 1752 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd804ebc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Insured depository institution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “insured depository institution” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd804ebd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/15/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an insured depository institution, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"section 1813 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd804ebe-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/15/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an insured credit union.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd804ebf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lawful order","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “lawful order” means any final and valid writ, process, order, rule, decree, command, or other requirement issued or promulgated under Federal law, issued by a court of competent jurisdiction or by an authorized Federal agency pursuant to its statutory authority, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd804ec0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/16/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requires a person to seize, freeze, burn, or prevent the transfer of payment stablecoins issued by the person;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd804ec1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/16/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specifies the payment stablecoins or accounts subject to blocking with reasonable particularity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd804ec2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/16/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is subject to judicial or administrative review or appeal as provided by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd804ec3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monetary value","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “monetary value” means a national currency or deposit (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"section 1813 of this title","children":[],"tail":") denominated in a national currency."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd804ec4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Money","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “money”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd804ec5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/18/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means a medium of exchange currently authorized or adopted by a domestic or foreign government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd804ec6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/18/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes a monetary unit of account established by an intergovernmental organization or by agreement between 2 or more countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd804ec7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/19"},"text":null,"children":[{"tag":"num","attrib":{"value":"19"},"text":"(19)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National currency","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “national currency” means each of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd804ec8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/19/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Federal Reserve note (as the term is used in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s411"},"text":"section 411 of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd804ec9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/19/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Money standing to the credit of an account with a Federal Reserve Bank.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd804eca-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/19/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Money issued by a foreign central bank.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd804ecb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/19/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Money issued by an intergovernmental organization pursuant to an agreement by 2 or more governments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd804ecc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/20"},"text":null,"children":[{"tag":"num","attrib":{"value":"20"},"text":"(20)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonbank entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “nonbank entity” means a person that is not a depository institution or subsidiary of a depository institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd804ecd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/21"},"text":null,"children":[{"tag":"num","attrib":{"value":"21"},"text":"(21)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “offer” means to make available for purchase, sale, or exchange.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd804ece-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/22"},"text":null,"children":[{"tag":"num","attrib":{"value":"22"},"text":"(22)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment stablecoin","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “payment stablecoin”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd804ecf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/22/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means a digital asset—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd804ed0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/22/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is, or is designed to be, used as a means of payment or settlement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd804ed1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/22/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the issuer of which—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddd804ed2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/22/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is obligated to convert, redeem, or repurchase for a fixed amount of monetary value, not including a digital asset denominated in a fixed amount of monetary value; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddd804ed3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/22/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" represents that such issuer will maintain, or create the reasonable expectation that it will maintain, a stable value relative to the value of a fixed amount of monetary value; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd804ed4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/22/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" does not include a digital asset that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd804ed5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/22/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a national currency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd804ed6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/22/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a deposit (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"section 1813 of this title","children":[],"tail":"), including a deposit recorded using distributed ledger technology; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd804ed7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/22/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a security, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s77b"},"text":"section 77b of title 15","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78c"},"text":"section 78c of title 15","children":[],"tail":", or "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s80a–2"},"text":"section 80a–2 of title 15","children":[],"tail":", except that, for the avoidance of doubt, no bond, note, evidence of indebtedness, or investment contract that was issued by a permitted payment stablecoin issuer shall qualify as a security solely by virtue of its satisfying the conditions described in subparagraph (A), consistent with section 17 of this Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd804ed8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/23"},"text":null,"children":[{"tag":"num","attrib":{"value":"23"},"text":"(23)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permitted payment stablecoin issuer","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “permitted payment stablecoin issuer” means a person formed in the United States that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd804ed9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/23/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a subsidiary of an insured depository institution that has been approved to issue payment stablecoins under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5904"},"text":"section 5904 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd804eda-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/23/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Federal qualified payment stablecoin issuer; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd804edb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/23/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State qualified payment stablecoin issuer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd804edc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/24"},"text":null,"children":[{"tag":"num","attrib":{"value":"24"},"text":"(24)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “person” means an individual, partnership, company, corporation, association, trust, estate, cooperative organization, or other business entity, incorporated or unincorporated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd804edd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/25"},"text":null,"children":[{"tag":"num","attrib":{"value":"25"},"text":"(25)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Primary Federal payment stablecoin regulator","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “primary Federal payment stablecoin regulator” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd804ede-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/25/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a subsidiary of an insured depository institution (other than an insured credit union), the appropriate Federal banking agency of such insured depository institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd804edf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/25/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to an insured credit union or a subsidiary of an insured credit union, the National Credit Union Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd804ee0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/25/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a State chartered depository institution not specified under subparagraph (A), the Corporation, the Comptroller, or the Board; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd804ee1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/25/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a Federal qualified payment stablecoin issuer, the Comptroller.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd804ee2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/26"},"text":null,"children":[{"tag":"num","attrib":{"value":"26"},"text":"(26)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registered public accounting firm","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “registered public accounting firm” has the meaning given that term under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s7201"},"text":"section 7201 of title 15","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd804ee3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/27"},"text":null,"children":[{"tag":"num","attrib":{"value":"27"},"text":"(27)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stablecoin Certification Review Committee","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Stablecoin Certification Review Committee” means the committee of that name and having the functions as provided in this chapter—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd804ee4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/27/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" of which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd804ee5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/27/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Treasury shall serve as Chair; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd804ee6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/27/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chair of the Board (or the Vice Chair for Supervision, as delegated by the Chair of the Board), and the Chair of the Corporation shall serve as members; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd804ee7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/27/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which, unless otherwise specified in this chapter, shall act by ⅔ vote of its members at any meeting called by the Chair or by unanimous written consent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd804ee8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/28"},"text":null,"children":[{"tag":"num","attrib":{"value":"28"},"text":"(28)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means each of the several States of the United States, the District of Columbia, and each territory of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd804ee9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/29"},"text":null,"children":[{"tag":"num","attrib":{"value":"29"},"text":"(29)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State chartered depository institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State chartered depository institution” has the meaning given the term “State depository institution” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813/c"},"text":"section 1813(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd804eea-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/30"},"text":null,"children":[{"tag":"num","attrib":{"value":"30"},"text":"(30)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State payment stablecoin regulator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State payment stablecoin regulator” means a State agency that has primary regulatory and supervisory authority in such State over entities that issue payment stablecoins.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd804eeb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/31"},"text":null,"children":[{"tag":"num","attrib":{"value":"31"},"text":"(31)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State qualified payment stablecoin issuer","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “State qualified payment stablecoin issuer” means an entity that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd804eec-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/31/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is legally established under the laws of a State and approved to issue payment stablecoins by a State payment stablecoin regulator; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd804eed-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/31/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not an uninsured national bank chartered by the Comptroller pursuant to title LXII of the Revised Statutes, a Federal branch, an insured depository institution, or a subsidiary of such national bank, Federal branch, or insured depository institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd804eee-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/32"},"text":null,"children":[{"tag":"num","attrib":{"value":"32"},"text":"(32)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsidiary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “subsidiary” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"section 1813 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd804eef-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/33"},"text":null,"children":[{"tag":"num","attrib":{"value":"33"},"text":"(33)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsidiary of an insured credit union","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to an insured credit union, the term “subsidiary of an insured credit union” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd804ef0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/33/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an organization providing services to the insured credit union that are associated with the routine operations of credit unions, as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1757/7/I"},"text":"section 1757(7)(I) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd804ef1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/33/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a credit union service organization, as such term is used under part 712 of title 12, Code of Federal Regulations, with respect to which the insured credit union has an ownership interest or to which the insured credit union has extended a loan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd804ef2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5901/33/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a subsidiary of a State chartered insured credit union authorized under State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd804ef3-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/27/s2"},"text":"Pub. L. 119–27, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-18"},"text":"July 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/419"},"text":"139 Stat. 419","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd804ef4-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"iddd804ef5-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Delayed Effective Date of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For delayed effective date of section, see Effective Date note below.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd804ef6-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd804ef7-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/27"},"text":"Pub. L. 119–27","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-18"},"text":"July 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/419"},"text":"139 Stat. 419","children":[],"tail":", known as the Guiding and Establishing National Innovation for U.S. Stablecoins Act and also as the GENIUS Act, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out below and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Title LXII of the Revised Statutes, referred to in pars. (11)(B)(i) and (31)(B), consists of R.S. §§ 5133 to 5244, which are classified to sections 16, 21, 22 to 24a, 25a, 25b, 26, 27, 29, 35 to 37, 39, 43, 52, 53, 55 to 57, 59 to 62, 66, 71, 72 to 76, 81, 83 to 86, 90, 91, 93, 93a, 94, 141 to 144, 161, 164, 181, 182, 192 to 194, 196, 215c, 481 to 485, 501, 541, 548, and 582 of this title. See, also, sections 8, 333, 334, 475, 656, 709, 1004, and 1005 of Title 18, Crimes and Criminal Procedure. For complete classification of R.S. §§ 5133 to 5244 to the Code, see Tables.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 17 of this Act, referred to in par. (22)(B)(iii), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/27/s17"},"text":"section 17 of Pub. L. 119–27","children":[],"tail":", which amended "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1a"},"text":"section 1a of Title 7","children":[],"tail":", Agriculture, and sections 77b, 78c, 78"},{"tag":"i","attrib":{},"text":"lll","children":[],"tail":", 80a–2, 80a–3, and 80b–2 of Title 15, Commerce and Trade."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd804ef8-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd804ef9-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/27/s20"},"text":"Pub. L. 119–27, § 20","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-18"},"text":"July 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/466"},"text":"139 Stat. 466","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/27/s20"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“This Act [see Short Title note set out below], and the amendments made by this Act, shall take effect on the earlier of","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date that is 18 months after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2025-07-18"},"text":"July 18, 2025","children":[],"tail":"]; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date that is 120 days after the date on which the primary Federal payment stablecoin regulators issue any final regulations implementing this Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"iddd804efa-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/27/s1"},"text":"Pub. L. 119–27, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-18"},"text":"July 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/419"},"text":"139 Stat. 419","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/27/s1"},"text":"“This Act [enacting this chapter, amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1"},"text":"section 1 of this title","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s13104"},"text":"section 13104 of Title 5","children":[],"tail":", Government Organization and Employees, "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1a"},"text":"section 1a of Title 7","children":[],"tail":", Agriculture, sections 101, 362, 507, 541, and 1109 of Title 11, Bankruptcy, and sections 77b, 78c, 78"},{"tag":"i","attrib":{},"text":"lll","children":[],"tail":", 80a–2, 80a–3, 80b–2 of Title 15, Commerce and Trade, and enacting provisions set out as a note under this section] may be cited as the ‘Guiding and Establishing National Innovation for U.S. Stablecoins Act’ or the ‘GENIUS Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
