{"tag":"section","attrib":{"id":"iddc15e87f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1715z–25"},"text":null,"children":[{"tag":"num","attrib":{"value":"1715z–25"},"text":"§ 1715z–25.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mortgage modification data collecting and reporting","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc15e880-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1715z–25/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"2009-05-20"},"text":"May 20, 2009","children":[],"tail":", and quarterly thereafter, the Comptroller of the Currency and the Director of the Office of Thrift Supervision,"},{"tag":"ref","attrib":{"idref":"fn002184"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002184"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The comma probably should not appear."}],"tail":" shall jointly submit a report to the Committee on Banking, Housing, and Urban Affairs of the Senate,"},{"tag":"ref","attrib":{"idref":"fn002185"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002185"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. The word “and” probably should appear instead of the comma."}],"tail":" the Committee on Financial Services of the House of Representatives on the volume of mortgage modifications reported to the Office of the Comptroller of the Currency and the Office of Thrift Supervision, under the mortgage metrics program of each such Office, during the previous quarter, including the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc15e881-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1715z–25/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A copy of the data collection instrument currently used by the Office of the Comptroller of the Currency and the Office of Thrift Supervision to collect data on loan modifications.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc15e882-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1715z–25/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The total number of mortgage modifications in each State that result in each of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc15e883-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1715z–25/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Additions of delinquent payments and fees to loan balances.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc183274-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1715z–25/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Interest rate reductions and freezes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc183275-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1715z–25/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Term extensions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc183276-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1715z–25/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reductions of principal.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc183277-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1715z–25/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Deferrals of principal.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc183278-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1715z–25/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Combinations of modifications described in subparagraph (A), (B), (C), (D), or (E).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc183279-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1715z–25/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The total number of mortgage modifications in each State for which the total monthly principal and interest payment resulted in the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc18327a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1715z–25/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An increase.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc18327b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1715z–25/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Remained the same.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc18327c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1715z–25/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Decreased less than 10 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc18327d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1715z–25/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Decreased between 10 percent and 20 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc18327e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1715z–25/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Decreased 20 percent or more.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc18327f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1715z–25/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The total number of loans in each State that have been modified and then entered into default, where the loan modification resulted in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc183280-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1715z–25/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" higher monthly payments by the homeowner;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc183281-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1715z–25/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equivalent monthly payments by the homeowner;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc183282-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1715z–25/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lower monthly payments by the homeowner of up to 10 percent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc183283-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1715z–25/a/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lower monthly payments by the homeowner of between 10 percent to 20 percent; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc183284-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1715z–25/a/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lower monthly payments by the homeowner of more than 20 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc183285-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1715z–25/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data collection","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc183286-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1715z–25/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc183287-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1715z–25/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 60 days after ","children":[{"tag":"date","attrib":{"date":"2009-05-20"},"text":"May 20, 2009","children":[],"tail":", the Comptroller of the Currency and the Director of the Office of Thrift Supervision,"},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" shall issue mortgage modification data collection and reporting requirements to institutions covered under the reporting requirement of the mortgage metrics program of the Comptroller or the Director. Not later than 60 days after the date of the enactment of the Dodd-Frank Wall Street Reform and Consumer Protection Act, the Comptroller of the Currency and the Director of the Office of Thrift Supervision shall update such requirements to reflect amendments made to this section by such Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc183288-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1715z–25/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusiveness of collections","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirements under subparagraph (A) shall provide for the collection of all mortgage modification data needed by the Comptroller of the Currency and the Director of the Office of Thrift Supervision to fulfill the reporting requirements under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc183289-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1715z–25/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Comptroller of the Currency shall report all requirements established under paragraph (1) to each committee receiving the report required under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc18328a-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/22/dA/tI/s104"},"text":"Pub. L. 111–22, div. A, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-05-20"},"text":"May 20, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1636"},"text":"123 Stat. 1636","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tXIV/s1493"},"text":"Pub. L. 111–203, title XIV, § 1493","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2206"},"text":"124 Stat. 2206","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc18328b-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc18328c-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddc18328d-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Dodd-Frank Wall Street Reform and Consumer Protection Act, referred to in subsec. (b)(1)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1376"},"text":"124 Stat. 1376","children":[],"tail":", which enacted chapter 53 (§ 5301 et seq.) of this title and chapters 108 (§ 8201 et seq.) and 109 (§ 8301 et seq.) of Title 15, Commerce and Trade, and enacted, amended, and repealed numerous other sections and notes in the Code. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddc18328e-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Helping Families Save Their Homes Act of 2009, and not as part of the National Housing Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc18328f-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1493/a/1"},"text":"Pub. L. 111–203, § 1493(a)(1)","children":[],"tail":", substituted “in each State that result” for “resulting” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1493/a/2"},"text":"Pub. L. 111–203, § 1493(a)(2)","children":[],"tail":", inserted “each State for” after “modifications in” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1493/a/3"},"text":"Pub. L. 111–203, § 1493(a)(3)","children":[],"tail":", inserted “in each State” after “total number of loans” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1493/b"},"text":"Pub. L. 111–203, § 1493(b)","children":[],"tail":", inserted at end “Not later than 60 days after the date of the enactment of the Dodd-Frank Wall Street Reform and Consumer Protection Act, the Comptroller of the Currency and the Director of the Office of Thrift Supervision shall update such requirements to reflect amendments made to this section by such Act.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc183290-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddc183291-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective on the date on which final regulations implementing that amendment take effect, or on the date that is 18 months after the designated transfer date if such regulations have not been issued by that date, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1400/c"},"text":"section 1400(c) of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1601"},"text":"section 1601 of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
