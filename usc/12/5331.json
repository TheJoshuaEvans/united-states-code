{"tag":"section","attrib":{"id":"iddd556da7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5331"},"text":null,"children":[{"tag":"num","attrib":{"value":"5331"},"text":"§ 5331.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mitigation of risks to financial stability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd556da8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5331/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mitigatory actions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Board of Governors determines that a bank holding company with total consolidated assets of $250,000,000,000 or more, or a nonbank financial company supervised by the Board of Governors, poses a grave threat to the financial stability of the United States, the Board of Governors, upon an affirmative vote of not fewer than ⅔ of the voting members of the Council then serving, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd556da9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5331/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limit the ability of the company to merge with, acquire, consolidate with, or otherwise become affiliated with another company;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd556daa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5331/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" restrict the ability of the company to offer a financial product or products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd556dab-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5331/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require the company to terminate one or more activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd556dac-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5331/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" impose conditions on the manner in which the company conducts 1 or more activities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd556dad-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5331/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Board of Governors determines that the actions described in paragraphs (1) through (4) are inadequate to mitigate a threat to the financial stability of the United States in its recommendation, require the company to sell or otherwise transfer assets or off-balance-sheet items to unaffiliated entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd556dae-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5331/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice and hearing","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd556daf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5331/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board of Governors, in consultation with the Council, shall provide to a company described in subsection (a) written notice that such company is being considered for mitigatory action pursuant to this section, including an explanation of the basis for, and description of, the proposed mitigatory action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd556db0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5331/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hearing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after the date of receipt of notice under paragraph (1), the company may request, in writing, an opportunity for a written or oral hearing before the Board of Governors to contest the proposed mitigatory action. Upon receipt of a timely request, the Board of Governors shall fix a time (not later than 30 days after the date of receipt of the request) and place at which such company may appear, personally or through counsel, to submit written materials (or, at the discretion of the Board of Governors, in consultation with the Council, oral testimony and oral argument).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd556db1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5331/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Decision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 60 days after the date of a hearing under paragraph (2), or not later than 60 days after the provision of a notice under paragraph (1) if no hearing was held, the Board of Governors shall notify the company of the final decision of the Board of Governors, including the results of the vote of the Council, as described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd556db2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5331/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors for consideration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board of Governors and the Council shall take into consideration the factors set forth in subsection (a) or (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5323"},"text":"section 5323 of this title","children":[],"tail":", as applicable, in making any determination under subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd556db3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5331/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application to foreign financial companies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board of Governors may prescribe regulations regarding the application of this section to foreign nonbank financial companies supervised by the Board of Governors and foreign-based bank holding companies—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd556db4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5331/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" giving due regard to the principle of national treatment and equality of competitive opportunity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd556db5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5331/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" taking into account the extent to which the foreign nonbank financial company or foreign-based bank holding company is subject on a consolidated basis to home country standards that are comparable to those applied to financial companies in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd556db6-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tI/s121"},"text":"Pub. L. 111–203, title I, § 121","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1410"},"text":"124 Stat. 1410","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/174/tIV/s401/c/1/C"},"text":"Pub. L. 115–174, title IV, § 401(c)(1)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-05-24"},"text":"May 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1358"},"text":"132 Stat. 1358","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd556db7-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd556db8-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd556db9-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/174"},"text":"Pub. L. 115–174","children":[],"tail":" substituted “$250,000,000,000” for “$50,000,000,000” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd556dba-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd556dbb-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Except as otherwise provided, amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/174"},"text":"Pub. L. 115–174","children":[],"tail":" effective 18 months after "},{"tag":"date","attrib":{"date":"2018-05-24"},"text":"May 24, 2018","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/174/s401/d"},"text":"section 401(d) of Pub. L. 115–174","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5365"},"text":"section 5365 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd556dbc-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For construction of amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/174"},"text":"Pub. L. 115–174","children":[],"tail":" as applied to certain foreign banking organizations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/174/s401/g"},"text":"section 401(g) of Pub. L. 115–174","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5365"},"text":"section 5365 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
