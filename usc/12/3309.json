{"tag":"section","attrib":{"id":"iddd0467c0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3309"},"text":null,"children":[{"tag":"num","attrib":{"value":"3309"},"text":"§ 3309.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Risk management training","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd0467c1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3309/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Seminars","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall develop and administer training seminars in risk management for its employees and the employees of insured financial institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd0467c2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3309/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study of risk management training program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than end of the 1-year period beginning on ","children":[{"tag":"date","attrib":{"date":"1989-08-09"},"text":"August 9, 1989","children":[],"tail":", the Council shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd0467c3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3309/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct a study on the feasibility and appropriateness of establishing a formalized risk management training program designed to lead to the certification of Risk Management Analysts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd0467c4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3309/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report to the Congress the results of such study.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd0467c5-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/630/tX/s1009A"},"text":"Pub. L. 95–630, title X, § 1009A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/73/tXII/s1218"},"text":"Pub. L. 101–73, title XII, § 1218","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/546"},"text":"103 Stat. 546","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
