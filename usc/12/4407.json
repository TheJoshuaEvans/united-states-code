{"tag":"section","attrib":{"id":"iddd20efc2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4407"},"text":null,"children":[{"tag":"num","attrib":{"value":"4407"},"text":"§ 4407.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National emergencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The provisions of this chapter may not be construed to limit the authority of the President under the Trading With the Enemy Act (50 U.S.C. App. 1 et seq.) [now ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4301"},"text":"50 U.S.C. 4301","children":[],"tail":" et seq.] or the International Emergency Economic Powers Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"50 U.S.C. 1701","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd20efc3-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/tIV/s407A"},"text":"Pub. L. 102–242, title IV, § 407A","children":[],"tail":", formerly § 407, "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2375"},"text":"105 Stat. 2375","children":[],"tail":"; renumbered § 407A, "},{"tag":"ref","attrib":{"href":"/us/pl/109/8/tIX/s906/d/1"},"text":"Pub. L. 109–8, title IX, § 906(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/169"},"text":"119 Stat. 169","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd20efc4-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd20efc5-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text"