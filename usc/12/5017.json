{"tag":"section","attrib":{"id":"iddd44a566-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5017"},"text":null,"children":[{"tag":"num","attrib":{"value":"5017"},"text":"§ 5017.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation and report by the Comptroller General","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd44a567-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5017/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During the 5-year period beginning on ","children":[{"tag":"date","attrib":{"date":"2003-10-28"},"text":"October 28, 2003","children":[],"tail":", the Comptroller General of the United States shall evaluate the implementation and administration of this chapter, including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd44a568-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5017/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the gains in economic efficiency made possible from check truncation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd44a569-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5017/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of the benefits accruing to consumers and financial institutions from reduced transportation costs, longer hours for accepting deposits for credit within 1 business day, the impact of fraud losses, and an estimate of consumers’ share of the total benefits derived from this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd44a56a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5017/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of consumer acceptance of the check truncation process resulting from this chapter, as well as any new costs incurred by consumers who had their original checks returned with their regular monthly statements prior to ","children":[{"tag":"date","attrib":{"date":"2003-10-28"},"text":"October 28, 2003","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd44a56b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5017/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before the end of the 5-year period referred to in subsection (a), the Comptroller General shall submit a report to the Congress containing the findings and conclusions of the Comptroller General in connection with the evaluation conducted pursuant to subsection (a), together with such recommendations for legislative and administrative action as the Comptroller General may determine to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd44a56c-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/100/s18"},"text":"Pub. L. 108–100, § 18","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-10-28"},"text":"Oct. 28, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1191"},"text":"117 Stat. 1191","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd44a56d-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd44a56e-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd44a56f-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/100"},"text":"Pub. L. 108–100","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-10-28"},"text":"Oct. 28, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1177"},"text":"117 Stat. 1177","children":[],"tail":", which is classified generally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5001"},"text":"section 5001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd44a570-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd44a571-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective at the end of the 12-month period beginning on ","children":[{"tag":"date","attrib":{"date":"2003-10-28"},"text":"Oct. 28, 2003","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/100/s20"},"text":"section 20 of Pub. L. 108–100","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5001"},"text":"section 5001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
