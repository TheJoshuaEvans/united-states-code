{"tag":"section","attrib":{"id":"iddd425b32-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5001"},"text":null,"children":[{"tag":"num","attrib":{"value":"5001"},"text":"§ 5001.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings; purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd425b33-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5001/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress finds as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd425b34-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5001/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the Expedited Funds Availability Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4001"},"text":"12 U.S.C. 4001","children":[],"tail":" et seq.], enacted on "},{"tag":"date","attrib":{"date":"1987-08-10"},"text":"August 10, 1987","children":[],"tail":", the Congress directed the Board of Governors of the Federal Reserve System to consider establishing regulations requiring Federal reserve banks and depository institutions to provide for check truncation, in order to improve the check processing system."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd425b35-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5001/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In that same Act, the Congress—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd425b36-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5001/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provided the Board of Governors of the Federal Reserve System with full authority to regulate all aspects of the payment system, including the receipt, payment, collection, and clearing of checks, and related functions of the payment system pertaining to checks; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd425b37-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5001/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" directed that the exercise of such authority by the Board superseded any State law, including the Uniform Commercial Code, as in effect in any State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd425b38-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5001/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Check truncation is no less desirable in 2003 for both financial service customers and the financial services industry, to reduce costs, improve efficiency in check collections, and expedite funds availability for customers than it was over 15 years ago when Congress first directed the Board to consider establishing such a process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd425b39-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5001/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this chapter are as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd425b3a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5001/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To facilitate check truncation by authorizing substitute checks.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd425b3b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5001/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To foster innovation in the check collection system without mandating receipt of checks in electronic form.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd425b3c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5001/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To improve the overall efficiency of the Nation’s payments system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd425b3d-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/100/s2"},"text":"Pub. L. 108–100, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-10-28"},"text":"Oct. 28, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1177"},"text":"117 Stat. 1177","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd425b3e-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd425b3f-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd425b40-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Expedited Funds Availability Act, referred to in subsec. (a)(1), (2), is title VI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/86"},"text":"Pub. L. 100–86","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-08-10"},"text":"Aug. 10, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/635"},"text":"101 Stat. 635","children":[],"tail":", which is classified principally to chapter 41 (§ 4001 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4001"},"text":"section 4001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (b), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/100"},"text":"Pub. L. 108–100","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-10-28"},"text":"Oct. 28, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1177"},"text":"117 Stat. 1177","children":[],"tail":", which is classified generally to this chapter. For complete classification of this Act to the Code, see Short Title note set out below and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd425b41-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd425b42-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/100/s20"},"text":"Pub. L. 108–100, § 20","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-10-28"},"text":"Oct. 28, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1194"},"text":"117 Stat. 1194","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/100/s20"},"text":"“This Act [enacting this chapter, amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s412"},"text":"section 412 of this title","children":[],"tail":", and enacting provisions set out as notes under this section] shall take effect at the end of the 12-month period beginning on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2003-10-28"},"text":"Oct. 28, 2003","children":[],"tail":"], except as otherwise specifically provided in this Act.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"iddd425b43-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/100/s1/a"},"text":"Pub. L. 108–100, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-10-28"},"text":"Oct. 28, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1177"},"text":"117 Stat. 1177","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/100/s1/a"},"text":"“This Act [enacting this chapter, amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s412"},"text":"section 412 of this title","children":[],"tail":", and enacting provisions set out as notes under this section] may be cited as the ‘Check Clearing for the 21st Century Act’ or the ‘Check 21 Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
