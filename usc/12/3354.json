{"tag":"section","attrib":{"id":"iddd06b1e3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3354"},"text":null,"children":[{"tag":"num","attrib":{"value":"3354"},"text":"§ 3354.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Automated valuation models used to estimate collateral value for mortgage lending purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd06b1e4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3354/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Automated valuation models shall adhere to quality control standards designed to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd06b1e5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3354/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure a high level of confidence in the estimates produced by automated valuation models;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd06b1e6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3354/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protect against the manipulation of data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd06b1e7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3354/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seek to avoid conflicts of interest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd06b1e8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3354/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require random sample testing and reviews; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd06b1e9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3354/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" account for any other such factor that the agencies listed in subsection (b) determine to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd06b1ea-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3354/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adoption of regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board, the Comptroller of the Currency, the Federal Deposit Insurance Corporation, the National Credit Union Administration Board, the Federal Housing Finance Agency, and the Bureau of Consumer Financial Protection, in consultation with the staff of the Appraisal Subcommittee and the Appraisal Standards Board of the Appraisal Foundation, shall promulgate regulations to implement the quality control standards required under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd06b1eb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3354/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Compliance with regulations issued under this subsection shall be enforced by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd06b1ec-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3354/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a financial institution, or subsidiary owned and controlled by a financial institution and regulated by a Federal financial institution regulatory agency, the Federal financial institution regulatory agency that acts as the primary Federal supervisor of such financial institution or subsidiary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd06b1ed-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3354/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to other participants in the market for appraisals of 1-to-4 unit single family residential real estate, the Federal Trade Commission, the Bureau of Consumer Financial Protection, and a State attorney general.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd06b1ee-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3354/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Automated valuation model defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “automated valuation model” means any computerized model used by mortgage originators and secondary market issuers to determine the collateral worth of a mortgage secured by a consumer’s principal dwelling.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd06b1ef-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/tXI/s1125"},"text":"Pub. L. 101–73, title XI, § 1125","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tXIV/s1473/q"},"text":"Pub. L. 111–203, title XIV, § 1473(q)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2198"},"text":"124 Stat. 2198","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd06b1f0-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd06b1f1-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd06b1f2-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date on which final regulations implementing such section take effect, or on the date that is 18 months after the designated transfer date if such regulations have not been issued by that date, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1400/c"},"text":"section 1400(c) of Pub. L. 111–203","children":[],"tail":", set out as an Effective Date of 2010 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1601"},"text":"section 1601 of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
