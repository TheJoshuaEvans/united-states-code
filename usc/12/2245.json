f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddccd7916-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (c)(2)(C)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “chapter 131 of title 5;” for “the Ethics in Government Act of 1978;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73"},"text":"Pub. L. 101–73","children":[],"tail":" amended par. (2) generally. Prior to amendment, par. (2) read as follows: “The officers and employees of the agency shall be—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) subject to the Ethics in Government Act of 1978 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s701"},"text":"2 U.S.C. 701","children":[],"tail":" et seq.);"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) considered officers or employees of the United States for the purposes of sections 201 through 203, and sections 205 through 209, of title 18; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5373"},"text":"section 5373 of title 5","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/233/s805/x"},"text":"Pub. L. 100–233, § 805(x)","children":[],"tail":", which directed the amendment of this section by striking out the last sentence, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/s702/b"},"text":"Pub. L. 100–399, § 702(b)","children":[],"tail":". See Construction of 1988 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/233/s431/c"},"text":"Pub. L. 100–233, § 431(c)","children":[],"tail":", amended section generally, substituting subsecs. (a) to (d) for former text consisting of single undesignated paragraph."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s415/a"},"text":"Pub. L. 100–399, § 415(a)","children":[],"tail":", substituted “5373” for “5315”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/205"},"text":"Pub. L. 99–205","children":[],"tail":" substituted provisions respecting organization of the Farm Credit Administration for provisions relating to compensation and expense allowance of the Governor of the Farm Credit Administration."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddccd7917-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddccd7918-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s415/a"},"text":"section 415(a) of Pub. L. 100–399","children":[],"tail":" effective as if enacted immediately after enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/100/233"},"text":"Pub. L. 100–233","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/s1001/a"},"text":"section 1001(a) of Pu