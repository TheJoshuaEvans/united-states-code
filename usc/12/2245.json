{"tag":"section","attrib":{"id":"iddccd7906-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2245"},"text":null,"children":[{"tag":"num","attrib":{"value":"2245"},"text":"§ 2245.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organization of Farm Credit Administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddccd7907-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2245/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policies of Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chairman of the Farm Credit Administration Board, in carrying out the powers and duties vested in the Chairman by this chapter, and Acts supplementary thereto, shall be governed by policies of the Board and by such regulatory decisions, findings, and determinations as the Board may by law be authorized to make.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddccd7908-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2245/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chairman of the Board shall appoint such personnel as may be necessary to carry out the functions of the Farm Credit Administration. The appointment by the Chairman of the heads of major administrative divisions under the Board shall be subject to the approval of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddccd7909-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2245/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personnel","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddccd790a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2245/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointments by Board members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Personnel employed regularly and full-time in the immediate offices of Board members shall be appointed by each such Board member.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddccd790b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2245/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Officers and employees","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddccd790c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2245/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment, compensation, and benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chairman shall fix the compensation and number of, and appoint and direct, employees of the Administration. The Chairman may set and adjust the rates of basic pay for employees of the Administration without regard to the provisions of chapter 51, or subchapter III of chapter 53, of title 5. The Chairman may provide such additional compensation and benefits to employees of the Administration as is necessary to maintain comparability with the total amount of compensation and benefits provided by other Federal bank regulatory agencies. In setting and adjusting the total amount of compensation and benefits for employees of the Administration, the Chairman shall consult with, and seek to maintain comparability with, other Federal bank regulatory agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddccd790d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2245/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Other Federal bank regulatory agencies” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, the term “other Federal bank regulatory agencies” has the same meaning given to the term “appropriate Federal banking agency” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813/q"},"text":"section 1813(q) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddccd790e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2245/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ethics in Government","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The officers and employees of the agency shall be—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddccd790f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2245/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to chapter 131 of title 5; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddccd7910-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2245/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" considered officers or employees of the United States for the purposes of sections 201 through 203, and sections 205 through 209, of title 18.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddccd7911-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2245/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delegation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The powers of the Chairman as chief executive officer necessary for day to day management may be exercised and performed by the Chairman through such other officers and employees of the Administration as the Chairman shall designate, except that the Chairman may not delegate powers specifically reserved to the Chairman by this chapter without Board approval.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddccd7912-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2245/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The operations of the Farm Credit Administration, and the salaries of members of the Board and employees of the Administration, shall be funded and paid for from the fund created under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2250"},"text":"section 2250 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddccd7913-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tV/s5"},"text":"Pub. L. 92–181, title V, § 5","children":[],"tail":".11, "},{"tag":"date","attrib":{"date":"1971-12-10"},"text":"Dec. 10, 1971","children":[],"tail"