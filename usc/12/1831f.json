{"tag":"section","attrib":{"id":"iddc944083-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f"},"text":null,"children":[{"tag":"num","attrib":{"value":"1831f"},"text":"§ 1831f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Brokered deposits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc944084-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An insured depository institution that is not well capitalized may not accept funds obtained, directly or indirectly, by or through any deposit broker for deposit into 1 or more deposit accounts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc944085-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renewals and rollovers treated as acceptance of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any renewal of an account in any troubled institution and any rollover of any amount on deposit in any such account shall be treated as an acceptance of funds by such troubled institution for purposes of subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc944086-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation may, on a case-by-case basis and upon application by an insured depository institution which is adequately capitalized (but not well capitalized), waive the applicability of subsection (a) upon a finding that the acceptance of such deposits does not constitute an unsafe or unsound practice with respect to such institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc944087-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limited exception for certain conservatorships","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any insured depository institution for which the Corporation has been appointed as conservator, subsection (a) shall not apply to the acceptance of deposits (described in such subsection) by such institution if the Corporation determines that the acceptance of such deposits—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc944088-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not an unsafe or unsound practice;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc944089-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is necessary to enable the institution to meet the demands of its depositors or pay its obligations in the ordinary course of business; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc94408a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is consistent with the conservator’s fiduciary duty to minimize the institution’s losses.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Effective 90 days after the date on which the institution was placed in conservatorship, the institution may not accept such deposits.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc94408b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction on interest rate paid","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc94408c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc94408d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms “agent institution”, “reciprocal deposits”, and “well capitalized” have the meanings given those terms in subsection (i); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc94408e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “covered insured depository institution” means an insured depository institution that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddc94408f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under subsection (c) or (d), accepts funds obtained, directly or indirectly, by or through a deposit broker; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc944090-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while acting as an agent institution under subsection (i), accepts reciprocal deposits while not well capitalized.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc944091-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A covered insured depository institution may not pay a rate of interest on funds or reciprocal deposits described in paragraph (1) that, at the time that the funds or reciprocal deposits are accepted, significantly exceeds the limit set forth in paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc944092-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limit on interest rates","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The limit on the rate of interest referred to in paragraph (2) shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc944093-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rate paid on deposits of similar maturity in the normal market area of the covered insured depository institution for deposits accepted in the normal market area of the covered insured depository institution; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc944094-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the national rate paid on deposits of comparable maturity, as established by the Corporation, for deposits accepted outside the normal market area of the covered insured depository institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc944095-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional restrictions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation may impose, by regulation or order, such additional restrictions on the acceptance of brokered deposits by any institution as the Corporation may determine to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc944096-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions relating to deposit broker","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc944097-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit broker","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “deposit broker” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc944098-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person engaged in the business of placing deposits, or facilitating the placement of deposits, of third parties with insured depository institutions or the business of placing deposits with insured depository institutions for the purpose of selling interests in those deposits to third parties; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc944099-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agent or trustee who establishes a deposit account to facilitate a business arrangement with an insured depository institution to use the proceeds of the account to fund a prearranged loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc94409a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “deposit broker” does not include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc94409b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an insured depository institution, with respect to funds placed with that depository institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc94409c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee of an insured depository institution, with respect to funds placed with the employing depository institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc94409d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a trust department of an insured depository institution, if the trust in question has not been established for the primary purpose of placing funds with insured depository institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc94409e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/g/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the trustee of a pension or other employee benefit plan, with respect to funds of the plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc94409f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/g/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person acting as a plan administrator or an investment adviser in connection with a pension plan or other employee benefit plan provided that that person is performing managerial functions with respect to the plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9440a0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/g/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the trustee of a testamentary account;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9440a1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/g/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the trustee of an irrevocable trust (other than one described in paragraph (1)(B)), as long as the trust in question has not been established for the primary purpose of placing funds with insured depository institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9440a2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/g/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a trustee or custodian of a pension or profitsharing plan qualified under section 401(d) or 403(a) of title 26; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9440a3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/g/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agent or nominee whose primary purpose is not the placement of funds with depository institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc9440a4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion of depository institutions engaging in certain activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraph (2), the term “deposit broker” includes any insured depository institution that is not well capitalized (as defined in section 1831","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title), and any employee of such institution, which engages, directly or indirectly, in the solicitation of deposits by offering rates of interest which are significantly higher than the prevailing rates of interest on deposits offered by other insured depository institutions in such depository institution’s normal market area."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc9440a5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employee","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, the term “employee” means any employee—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc9440a6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/g/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is employed exclusively by the insured depository institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9440a7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/g/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose compensation is primarily in the form of a salary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9440a8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/g/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who does not share such employee’s compensation with a deposit broker; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9440a9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/g/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose office space or place of business is used exclusively for the benefit of the insured depository institution which employs such individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc9440aa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit solicitation restricted","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An insured depository institution that is undercapitalized, as defined in section 1831","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title, shall not solicit deposits by offering rates of interest that are significantly higher than the prevailing rates of interest on insured deposits—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc9440ab-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in such institution’s normal market areas; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc9440ac-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the market area in which such deposits would otherwise be accepted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc9440ad-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limited exception for reciprocal deposits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc9440ae-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Reciprocal deposits of an agent institution shall not be considered to be funds obtained, directly or indirectly, by or through a deposit broker to the extent that the total amount of such reciprocal deposits does not exceed the lesser of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc9440af-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/i/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $5,000,000,000; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9440b0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/i/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to 20 percent of the total liabilities of the agent institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc9440b1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc9440b2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/i/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agent institution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “agent institution” means an insured depository institution that places a covered deposit through a deposit placement network at other insured depository institutions in amounts that are less than or equal to the standard maximum deposit insurance amount, specifying the interest rate to be paid for such amounts, if the insured depository institution—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddc9440b3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/i/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddc9440b4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/i/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when most recently examined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1820/d"},"text":"section 1820(d) of this title","children":[],"tail":" was found to have a composite condition of outstanding or good; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddc9440b5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/i/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is well capitalized;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc9440b6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/i/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has obtained a waiver pursuant to subsection (c); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc9440b7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/i/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not receive an amount of reciprocal deposits that causes the total amount of reciprocal deposits held by the agent institution to be greater than the average of the total amount of reciprocal deposits held by the agent institution on the last day of each of the 4 calendar quarters preceding the calendar quarter in which the agent institution was found not to have a composite condition of outstanding or good or was determined to be not well capitalized.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9440b8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/i/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered deposit","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered deposit” means a deposit that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddc9440b9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/i/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is submitted for placement through a deposit placement network by an agent institution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc9440ba-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/i/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not consist of funds that were obtained for the agent institution, directly or indirectly, by or through a deposit broker before submission for placement through a deposit placement network.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9440bb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/i/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit placement network","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “deposit placement network” means a network in which an insured depository institution participates, together with other insured depository institutions, for the processing and receipt of reciprocal deposits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9440bc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/i/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Network member bank","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “network member bank” means an insured depository institution that is a member of a deposit placement network.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9440bd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/i/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reciprocal deposits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “reciprocal deposits” means deposits received by an agent institution through a deposit placement network with the same maturity (if any) and in the same aggregate amount as covered deposits placed by the agent institution in other network member banks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9440be-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831f/i/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Well capitalized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “well capitalized” has the meaning given the term in section 1831","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":"(b)(1) of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc9440bf-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-21/ch967/s2"},"text":"Sept. 21, 1950, ch. 967, § 2","children":[],"tail":"[29], as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/73/tII/s224/a"},"text":"Pub. L. 101–73, title II, § 224(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/273"},"text":"103 Stat. 273","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/242/tIII/s301/a"},"text":"Pub. L. 102–242, title III, § 301(a)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2343"},"text":"105 Stat. 2343","children":[],"tail":", 2345; "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXVI/s1605/a/1"},"text":"Pub. L. 102–550, title XVI, § 1605(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4084"},"text":"106 Stat. 4084","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/325/tIII/s337"},"text":"Pub. L. 103–325, title III, § 337","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2235"},"text":"108 Stat. 2235","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/174/tII/s202"},"text":"Pub. L. 115–174, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-05-24"},"text":"May 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1307"},"text":"132 Stat. 1307","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc9440c0-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc9440c1-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc9440c2-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/174/s202/b"},"text":"Pub. L. 115–174, § 202(b)","children":[],"tail":", added subsec. (e) and struck out former subsec. (e). Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Any insured depository institution which, under subsection (c) or (d), accepts funds obtained, directly or indirectly, by or through a deposit broker, may not pay a rate of interest on such funds which, at the time that such funds are accepted, significantly exceeds—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) the rate paid on deposits of similar maturity in such institution’s normal market area for deposits accepted in the institution’s normal market area; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) the national rate paid on deposits of comparable maturity, as established by the Corporation, for deposits accepted outside the institution’s normal market area.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/174/s202/a"},"text":"Pub. L. 115–174, § 202(a)","children":[],"tail":", added subsec. (i)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (g)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325"},"text":"Pub. L. 103–325","children":[],"tail":" inserted “that is not well capitalized (as defined in section 1831"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title)” after “includes any insured depository institution”, substituted “of such institution” for “of any insured depository institution”, and struck out “(with respect to such deposits)” after “offering rates of interest” and “having the same type of charter” after “other insured depository institutions”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/s1605/a/1/A"},"text":"Pub. L. 102–550, § 1605(a)(1)(A)","children":[],"tail":", substituted “An insured” for “A insured”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/s1605/a/1/B"},"text":"Pub. L. 102–550, § 1605(a)(1)(B)","children":[],"tail":", substituted “capitalized (but not well capitalized)” for “capitalized”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/s301/a/1"},"text":"Pub. L. 102–242, § 301(a)(1)","children":[],"tail":", substituted “insured depository institution that is not well capitalized” for “troubled institution”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/s301/a/2"},"text":"Pub. L. 102–242, § 301(a)(2)","children":[],"tail":", substituted “insured depository institution which is adequately capitalized” for “insured depositary institution”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/s301/a/3"},"text":"Pub. L. 102–242, § 301(a)(3)","children":[],"tail":", added pars. (2) and (3) and closing provisions, struck out “and” at end of par. (1), and struck out former par. (2) which read as follows: “either—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) is necessary to enable the institution to meet the demands of its depositors or pay its obligations in the ordinary course of business; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) is consistent with the conservator’s fiduciary duty to minimize the losses of the institution.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e) to (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/s301/a/4"},"text":"Pub. L. 102–242, § 301(a)(4)","children":[],"tail":"–(6), (c), added subsec. (e), redesignated former subsec. (e) as (f) and struck out “troubled” before “institution as the”, redesignated former subsecs. (f) and (g) as (g) and (h), respectively, added subsec. (h), and struck out former subsec. (h), as previously redesignated, which defined “troubled institution”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc9440c3-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddc9440c4-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550"},"text":"Pub. L. 102–550","children":[],"tail":" effective as if included in the Federal Deposit Insurance Corporation Improvement Act of 1991, "},{"tag":"ref","attrib":{"href":"/us/pl/102/242"},"text":"Pub. L. 102–242","children":[],"tail":", as of "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/s1609/a"},"text":"section 1609(a) of Pub. L. 102–550","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s191"},"text":"section 191 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddc9440c5-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/tII/s224/b"},"text":"Pub. L. 101–73, title II, § 224(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/275"},"text":"103 Stat. 275","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/73/tII/s224/b"},"text":"“The amendment made by subsection (a) [enacting this section] shall apply to deposits accepted after the end of the 120-day period beginning on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddc9440c6-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/tIII/s301/d"},"text":"Pub. L. 102–242, title III, § 301(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2345"},"text":"105 Stat. 2345","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/242/tIII/s301/d"},"text":"“The Corporation shall promulgate final regulations to carry out the amendments made under subsections (a), (b), and (c) [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1831f–1"},"text":"section 1831f–1 of this title","children":[],"tail":" and amending this section] not later than 150 days after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":"], and those regulations shall become effective not later than 180 days after that date of enactment, except that such regulations shall not apply to any specific time deposit made before that date of enactment until the stated maturity of the time deposit.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
