{"tag":"section","attrib":{"id":"iddd44a561-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5016"},"text":null,"children":[{"tag":"num","attrib":{"value":"5016"},"text":"§ 5016.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statistical reporting of costs and revenues for transporting checks between reserve banks","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In the annual report prepared by the Board for the first full calendar year after ","children":[{"tag":"date","attrib":{"date":"2003-10-28"},"text":"October 28, 2003","children":[],"tail":", and in each of the 9 subsequent annual reports by the Board, the Board shall include the amount of operating costs attributable to, and an estimate of the Federal Reserve banks’ imputed revenues derived from, the transportation of commercial checks between Federal Reserve bank check processing centers."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd44a562-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/100/s17"},"text":"Pub. L. 108–100, § 17","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-10-28"},"text":"Oct. 28, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1191"},"text":"117 Stat. 1191","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd44a563-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd44a564-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd44a565-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective at the end of the 12-month period beginning on ","children":[{"tag":"date","attrib":{"date":"2003-10-28"},"text":"Oct. 28, 2003","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/100/s20"},"text":"section 20 of Pub. L. 108–100","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5001"},"text":"section 5001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
