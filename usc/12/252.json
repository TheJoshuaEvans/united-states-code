{"tag":"section","attrib":{"id":"iddb29dab9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s252"},"text":null,"children":[{"tag":"num","attrib":{"value":"252"},"text":"§ 252.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit availability assessment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddb29daba-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s252/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb29dabb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s252/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 12 months after ","children":[{"tag":"date","attrib":{"date":"1996-09-30"},"text":"September 30, 1996","children":[],"tail":", and once every 60 months thereafter, the Board, in consultation with the Director of the Office of Thrift Supervision, the Comptroller of the Currency, the Board of Directors of the Corporation, the Administrator of the National Credit Union Administration, the Administrator of the Small Business Administration, and the Secretary of Commerce, shall conduct a study and submit a report to the Congress detailing the extent of small business lending by all creditors."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb29dabc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s252/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of study","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The study required under paragraph (1) shall identify, to the extent practicable, those factors which provide policymakers with insights into the small business credit market, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddb29dabd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s252/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the demand for small business credit, including consideration of the impact of economic cycles on the levels of such demand;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb29dabe-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s252/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the availability of credit to small businesses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb29dabf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s252/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the range of credit options available to small businesses, such as those available from insured depository institutions and other providers of credit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb29dac0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s252/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the types of credit products used to finance small business operations, including the use of traditional loans, leases, lines of credit, home equity loans, credit cards, and other sources of financing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb29dac1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s252/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the credit needs of small businesses, including, if appropriate, the extent to which such needs differ, based upon product type, size of business, cash flow requirements, characteristics of ownership or investors, or other aspects of such business;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb29dac2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s252/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the types of risks to creditors in providing credit to small businesses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb29dac3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s252/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other factors as the Board deems appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb29dac4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s252/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of existing data","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The studies required by this section shall not increase the regulatory or paperwork burden on regulated financial institutions, other sources of small business credit, or small businesses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddb29dac5-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tII/s2227"},"text":"Pub. L. 104–208, div. A, title II, § 2227","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-417"},"text":"110 Stat. 3009–417","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb29dac6-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb29dac7-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddb29dac8-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Economic Growth and Regulatory Paperwork Reduction Act of 1996, and also as part of the Omnibus Consolidated Appropriations Act, 1997, and not as part of the Federal Reserve Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddb29dac9-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"iddb29daca-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions vested in Administrator of National Credit Union Administration transferred and vested in National Credit Union Administration Board pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1752a"},"text":"section 1752a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddb29dacb-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Study of Financial Modernization’s Effect on the Accessibility of Small Business and Farm Loans","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/102/tI/s109"},"text":"Pub. L. 106–102, title I, § 109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1362"},"text":"113 Stat. 1362","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/102/tI/s109"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Study","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Treasury, in consultation with the Federal banking agencies (as defined in section 3(z) of the Federal Deposit Insurance Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813/z"},"text":"12 U.S.C. 1813(z)","children":[],"tail":"]), shall conduct a study of the extent to which credit is being provided to and for small businesses and farms, as a result of this Act [see Tables for classification] and the amendments made by this Act."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Before the end of the 5-year period beginning on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":"], the Secretary, in consultation with the Federal banking agencies, shall submit a report to the Congress on the study conducted pursuant to subsection (a) and shall include such recommendations as the Secretary determines to be appropriate for administrative and legislative action.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"iddb29dacc-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tII/s2001/c"},"text":"Pub. L. 104–208, div. A, title II, § 2001(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-397"},"text":"110 Stat. 3009–397","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/208/dA/tII/s2001/c"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Except as otherwise specified in this title [see Tables for classification], the following definitions shall apply for purposes of this title:","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appraisal subcommittee","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Appraisal Subcommittee’ means the Appraisal Subcommittee established under section 1011 of the Federal Financial Institutions Examination Council Act of 1978 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s3310"},"text":"12 U.S.C. 3310","children":[],"tail":"] (as in existence on the day before the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":"])."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appropriate Federal banking agency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘appropriate Federal banking agency’ has the same meaning as in section 3 of the Federal Deposit Insurance Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"12 U.S.C. 1813","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Board","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Board’ means the Board of Governors of the Federal Reserve System.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Corporation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Corporation’ means the Federal Deposit Insurance Corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Council","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Council’ means the Financial Institutions Examination Council established under section 1004 of the Federal Financial Institutions Examination Council Act of 1978 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s3303"},"text":"12 U.S.C. 3303","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Insured credit union","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘insured credit union’ has the same meaning as in section 101 of the Federal Credit Union Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1752"},"text":"12 U.S.C. 1752","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Insured depository institution","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘insured depository institution’ has the same meaning as in section 3 of the Federal Deposit Insurance Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
