{"tag":"section","attrib":{"id":"iddd425a9c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4903"},"text":null,"children":[{"tag":"num","attrib":{"value":"4903"},"text":"§ 4903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd425a9d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4903/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosures for new mortgages at time of transaction","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd425a9e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4903/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosures for non-exempted transactions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In any case in which private mortgage insurance is required in connection with a residential mortgage transaction (other than a residential mortgage transaction described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4902/g/1"},"text":"section 4902(g)(1) of this title","children":[],"tail":"), at the time at which the transaction is consummated, the mortgagee shall provide to the mortgagor—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd425a9f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4903/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the transaction relates to a fixed rate mortgage—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd425aa0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4903/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a written initial amortization schedule; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd425aa1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4903/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" written notice—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddd425aa2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4903/a/1/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the mortgagor may cancel the requirement in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4902/a"},"text":"section 4902(a) of this title","children":[],"tail":" indicating the date on which the mortgagor may request cancellation, based solely on the initial amortization schedule;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddd425aa3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4903/a/1/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the mortgagor may request cancellation in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4902/a"},"text":"section 4902(a) of this title","children":[],"tail":" earlier than provided for in the initial amortization schedule, based on actual payments;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddd425aa4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4903/a/1/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the requirement for private mortgage insurance will automatically terminate on the termination date in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4902/b"},"text":"section 4902(b) of this title","children":[],"tail":", and what that termination date is with respect to that mortgage; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddd425aa5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4903/a/1/A/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that there are exemptions to the right to cancellation and automatic termination of a requirement for private mortgage insurance in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4902/g"},"text":"section 4902(g) of this title","children":[],"tail":", and whether such an exemption applies at that time to that transaction; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd425aa6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4903/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the transaction relates to an adjustable rate mortgage, a written notice that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd425aa7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4903/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the mortgagor may cancel the requirement in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4902/a"},"text":"section 4902(a) of this title","children":[],"tail":" on the cancellation date, and that the servicer will notify the mortgagor when the cancellation date is reached;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd425aa8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4903/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the requirement for private mortgage insurance will automatically terminate on the termination date, and that on the termination date, the mortgagor will be notified of the termination or that the requirement will be terminated as soon as the mortgagor is current on loan payments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd425aa9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4903/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there are exemptions to the right of cancellation and automatic termination of a requirement for private mortgage insurance in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4902/g"},"text":"section 4902(g) of this title","children":[],"tail":", and whether such an exemption applies at that time to that transaction."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd425aaa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4903/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosures for excepted transactions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a residential mortgage transaction described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4902/g/1"},"text":"section 4902(g)(1) of this title","children":[],"tail":", at the time at which the transaction is consummated, the mortgagee shall provide written notice to the mortgagor that in no case may private mortgage insurance be required beyond the date that is the midpoint of the amortization period of the loan, if the mortgagor is current on payments required by the terms of the residential mortgage."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd425aab-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4903/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual disclosures","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If private mortgage insurance is required in connection with a residential mortgage transaction, the servicer shall disclose to the mortgagor in each such transaction in an annual written statement—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd425aac-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4903/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rights of the mortgagor under this chapter to cancellation or termination of the private mortgage insurance requirement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd425aad-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4903/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an address and telephone number that the mortgagor may use to contact the servicer to determine whether the mortgagor may cancel the private mortgage insurance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd425aae-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4903/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraphs (1) through (3) shall apply with respect to each residential mortgage transaction consummated on or after the date that is 1 year after ","children":[{"tag":"date","attrib":{"date":"1998-07-29"},"text":"July 29, 1998","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd425aaf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4903/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosures for existing mortgages","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If private mortgage insurance was required in connection with a residential mortgage entered into at any time before the effective date of this chapter, the servicer shall disclose to the mortgagor in each such transaction in an annual written statement—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd425ab0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4903/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the private mortgage insurance may, under certain circumstances, be canceled by the mortgagor (with the consent of the mortgagee or in accordance with applicable State law); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd425ab1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4903/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an address and telephone number that the mortgagor may use to contact the servicer to determine whether the mortgagor may cancel the private mortgage insurance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd425ab2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4903/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion in other annual notices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The information and disclosures required under subsection (b) and subsection (a)(3) may be provided on the annual disclosure relating to the escrow account made as required under the Real Estate Settlement Procedures Act of 1974 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2601"},"text":"12 U.S.C. 2601","children":[],"tail":" et seq.], or as part of the annual disclosure of interest payments made pursuant to Internal Revenue Service regulations, and on a form promulgated by the Internal Revenue Service for that purpose."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd425ab3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4903/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standardized forms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The mortgagee or servicer may use standardized forms for the provision of disclosures required under this section, which disclosures shall relate to the mortgagor’s rights under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd425ab4-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/216/s4"},"text":"Pub. L. 105–216, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-29"},"text":"July 29, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/902"},"text":"112 Stat. 902","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/tIV"},"text":"Pub. L. 106–569, title IV","children":[],"tail":", §§ 402(c)(2), 403(b), "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2957"},"text":"114 Stat. 2957","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd425ab5-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd425ab6-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd425ab7-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The effective date of this chapter, referred to in subsec. (b), is 1 year after ","children":[{"tag":"date","attrib":{"date":"1998-07-29"},"text":"July 29, 1998","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/216/s13"},"text":"section 13 of Pub. L. 105–216","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4901"},"text":"section 4901 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Real Estate Settlement Procedures Act of 1974, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/533"},"text":"Pub. L. 93–533","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-12-22"},"text":"Dec. 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1724"},"text":"88 Stat. 1724","children":[],"tail":", which is classified principally to chapter 27 (§ 2601 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2601"},"text":"section 2601 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd425ab8-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/569"},"text":"Pub. L. 106–569","children":[],"tail":", §§ 402(c)(2)(A)(i), 403(b)(1)(A), substituted “residential mortgage transaction (other than a residential mortgage transaction described in "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4902/g/1"},"text":"section 4902(g)(1) of this title","children":[],"tail":")” for “residential mortgage or mortgage transaction (other than a mortgage or mortgage transaction described in "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4902/f/1"},"text":"section 4902(f)(1) of this title","children":[],"tail":")” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(A)(ii)(IV), (B)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/569/s402/c/2/A/ii"},"text":"Pub. L. 106–569, § 402(c)(2)(A)(ii)","children":[],"tail":", (iii), substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4902/g"},"text":"section 4902(g) of this title","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4902/f"},"text":"section 4902(f) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/569"},"text":"Pub. L. 106–569","children":[],"tail":", §§ 402(c)(2)(B), 403(b)(1)(B), substituted “residential mortgage transaction” for “mortgage or mortgage transaction” and “"},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4902/g/1"},"text":"section 4902(g)(1) of this title","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4902/f/1"},"text":"section 4902(f)(1) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/569/s403/b/2"},"text":"Pub. L. 106–569, § 403(b)(2)","children":[],"tail":", substituted “subsection (a)(3)” for “paragraphs (1)(B) and (3) of subsection (a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/569/s403/b/3"},"text":"Pub. L. 106–569, § 403(b)(3)","children":[],"tail":", inserted before period at end “, which disclosures shall relate to the mortgagor’s rights under this chapter”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd425ab9-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd425aba-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 1 year after ","children":[{"tag":"date","attrib":{"date":"1998-07-29"},"text":"July 29, 1998","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/216/s13"},"text":"section 13 of Pub. L. 105–216","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4901"},"text":"section 4901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
