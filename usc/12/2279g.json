{"tag":"section","attrib":{"id":"iddce7b8a1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279g"},"text":null,"children":[{"tag":"num","attrib":{"value":"2279g"},"text":"§ 2279g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transactions to accomplish mergers exempt from certain State taxes","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No State or political subdivision thereof may treat the merger or consolidation of two or more institutions of the Farm Credit System under this subchapter or title IV of the Agricultural Credit Act of 1987 as resulting in a change of ownership of any property owned by any of such merging or consolidating institutions, for purposes of any law of such State or political subdivision providing for reassessment of property on the occurrence of a change of ownership or imposing a tax on the ownership or transfer of property.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddce7b8a2-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tVII/s7"},"text":"Pub. L. 92–181, title VII, § 7","children":[],"tail":".14, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/tIV/s408/u"},"text":"Pub. L. 100–399, title IV, § 408(u)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-17"},"text":"Aug. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1003"},"text":"102 Stat. 1003","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddce7b8a3-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddce7b8a4-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"n