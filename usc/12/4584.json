{"tag":"section","attrib":{"id":"iddd2cd751-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4584"},"text":null,"children":[{"tag":"num","attrib":{"value":"4584"},"text":"§ 4584.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement and jurisdiction","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd2cd752-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4584/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may bring a civil action in the United States District Court for the District of Columbia for the enforcement of any effective notice or order issued under section 4581 or 4585 of this title. Such court shall have jurisdiction and power to order and require compliance herewith.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2cd753-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4584/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this subpart, no court shall have jurisdiction to affect, by injunction or otherwise, the issuance or enforcement of any notice or order under section 4581 or 4585 of this title, or to review, modify, suspend, terminate, or set aside any such notice or order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd2cd754-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXIII/s1344"},"text":"Pub. L. 102–550, title XIII, § 1344","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3966"},"text":"106 Stat. 3966","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tI/s1130/e/1"},"text":"Pub. L. 110–289, div. A, title I, § 1130(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2711"},"text":"122 Stat. 2711","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd2cd755-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd2cd756-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd2cd757-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289"},"text":"Pub. L. 110–289","children":[],"tail":", which directed substitution of “The Director may bring a civil action” for “The Secretary may request the Attorney General of the United States to bring a civil action”, was executed by making the substitution for “The Secretary may request the Attorney General of the United States to bring an action” to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
