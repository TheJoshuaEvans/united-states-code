{"tag":"section","attrib":{"id":"iddd7467a8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5552"},"text":null,"children":[{"tag":"num","attrib":{"value":"5552"},"text":"§ 5552.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preservation of enforcement powers of States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd7467a9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5552/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd7467aa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5552/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action by State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), the attorney general (or the equivalent thereof) of any State may bring a civil action in the name of such State in any district court of the United States in that State or in State court that is located in that State and that has jurisdiction over the defendant, to enforce provisions of this title ","children":[{"tag":"ref","attrib":{"idref":"fn002521"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002521"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" or regulations issued under this title,"},{"tag":"ref","attrib":{"idref":"fn002521"},"text":"1","children":[],"tail":" and to secure remedies under provisions of this title "},{"tag":"ref","attrib":{"idref":"fn002521"},"text":"1","children":[],"tail":" or remedies otherwise provided under other law. A State regulator may bring a civil action or other appropriate proceeding to enforce the provisions of this title "},{"tag":"ref","attrib":{"idref":"fn002521"},"text":"1","children":[],"tail":" or regulations issued under this title "},{"tag":"ref","attrib":{"idref":"fn002521"},"text":"1","children":[],"tail":" with respect to any entity that is State-chartered, incorporated, licensed, or otherwise authorized to do business under State law (except as provided in paragraph (2)), and to secure remedies under provisions of this title "},{"tag":"ref","attrib":{"idref":"fn002521"},"text":"1","children":[],"tail":" or remedies otherwise provided under other provisions of law with respect to such an entity."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7467ab-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5552/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action by State against national bank or Federal savings association to enforce rules","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd7467ac-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5552/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as permitted under subparagraph (B), the attorney general (or equivalent thereof) of any State may not bring a civil action in the name of such State against a national bank or Federal savings association to enforce a provision of this title.","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7467ad-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5552/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement of rules permitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The attorney general (or the equivalent thereof) of any State may bring a civil action in the name of such State against a national bank or Federal savings association in any district court of the United States in the State or in State court that is located in that State and that has jurisdiction over the defendant to enforce a regulation prescribed by the Bureau under a provision of this title ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" and to secure remedies under provisions of this title "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" or remedies otherwise provided under other law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7467ae-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5552/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No provision of this title ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" shall be construed as modifying, limiting, or superseding the operation of any provision of an enumerated consumer law that relates to the authority of a State attorney general or State regulator to enforce such Federal law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd7467af-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5552/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation required","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd7467b0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5552/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd7467b1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5552/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before initiating any action in a court or other administrative or regulatory proceeding against any covered person as authorized by subsection (a) to enforce any provision of this title,","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" including any regulation prescribed by the Bureau under this title,"},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" a State attorney general or State regulator shall timely provide a copy of the complete complaint to be filed and written notice describing such action or proceeding to the Bureau and the prudential regulator, if any, or the designee thereof."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7467b2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5552/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If prior notice is not practicable, the State attorney general or State regulator shall provide a copy of the complete complaint and the notice to the Bureau and the prudential regulator, if any, immediately upon instituting the action or proceeding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7467b3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5552/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of notice","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The notification required under this paragraph shall, at a minimum, describe—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd7467b4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5552/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identity of the parties;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd7467b5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5552/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the alleged facts underlying the proceeding; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd7467b6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5552/b/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether there may be a need to coordinate the prosecution of the proceeding so as not to interfere with any action, including any rulemaking, undertaken by the Bureau, a prudential regulator, or another Federal agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7467b7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5552/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bureau response","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In any action described in paragraph (1), the Bureau may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd7467b8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5552/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intervene in the action as a party;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7467b9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5552/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" upon intervening—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd7467ba-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5552/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remove the action to the appropriate United States district court, if the action was not originally brought there; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd7467bb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5552/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be heard on all matters arising in the action; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7467bc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5552/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appeal any order or judgment, to the same extent as any other party in the proceeding may.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd7467bd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5552/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Bureau shall prescribe regulations to implement the requirements of this section and, from time to time, provide guidance in order to further coordinate actions with the State attorneys general and other regulators.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd7467be-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5552/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preservation of State authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd7467bf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5552/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State claims","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No provision of this section shall be construed as altering, limiting, or affecting the authority of a State attorney general or any other regulatory or enforcement agency or authority to bring an action or other regulatory proceeding arising solely under the law in effect in that State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7467c0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5552/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State securities regulators","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No provision of this title ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" shall be construed as altering, limiting, or affecting the authority of a State securities commission (or any agency or office performing like functions) under State law to adopt rules, initiate enforcement proceedings, or take any other action with respect to a person regulated by such commission or authority."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7467c1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5552/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State insurance regulators","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No provision of this title ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" shall be construed as altering, limiting, or affecting the authority of a State insurance commission or State insurance regulator under State law to adopt rules, initiate enforcement proceedings, or take any other action with respect to a person regulated by such commission or regulator."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd7467c2-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1042"},"text":"Pub. L. 111–203, title X, § 1042","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2012"},"text":"124 Stat. 2012","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd7467c3-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd7467c4-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd7467c5-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This title, referred to in subsecs. (a), (b)(1)(A), and (d)(2), (3), is title X of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1955"},"text":"124 Stat. 1955","children":[],"tail":", known as the Consumer Financial Protection Act of 2010, which enacted this subchapter and enacted, amended, and repealed numerous other sections and notes in the Code. For complete classification of title X to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd7467c6-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd7467c7-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the designated transfer date, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1048"},"text":"section 1048 of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5551"},"text":"section 5551 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
