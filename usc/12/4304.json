{"tag":"section","attrib":{"id":"iddd1e7fc9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4304"},"text":null,"children":[{"tag":"num","attrib":{"value":"4304"},"text":"§ 4304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure requirements for certain accounts","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Bureau shall require, in regulations which the Bureau shall prescribe, such modification in the disclosure requirements under this chapter relating to annual percentage yield as may be necessary to carry out the purposes of this chapter in the case of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd1e7fca-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4304/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accounts with respect to which determination of annual percentage yield is based on an annual rate of interest that is guaranteed for a period of less than 1 year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1e7fcb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4304/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" variable rate accounts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1e7fcc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4304/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accounts which, pursuant to law, do not guarantee payment of a stated rate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1e7fcd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4304/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" multiple rate accounts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1e7fce-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4304/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accounts with respect to which determination of annual percentage yield is based on an annual rate of interest that is guaranteed for a stated term.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd1e7fcf-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/tII/s265"},"text":"Pub. L. 102–242, title II, § 265","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2336"},"text":"105 Stat. 2336","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXVI/s1604/e/2/A"},"text":"Pub. L. 102–550, title XVI, § 1604(e)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4084"},"text":"106 Stat. 4084","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1100B/1"},"text":"Pub. L. 111–203, title X, § 1100B(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2109"},"text":"124 Stat. 2109","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd1e7fd0-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd1e7fd1-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editori