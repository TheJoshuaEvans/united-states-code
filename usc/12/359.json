{"tag":"section","attrib":{"id":"iddb35c233-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s359"},"text":null,"children":[{"tag":"num","attrib":{"value":"359"},"text":"§ 359.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purchase and sale of acceptances of intermediate credit banks and agricultural credit corporations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Every Federal reserve bank shall have power to purchase and sell in the open market, either from or to domestic banks, firms, corporations, or individuals, acceptances of Federal intermediate credit banks and of national agricultural credit corporations, whenever the Board of Governors of the Federal Reserve System shall declare that the public interest so requires.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddb35c234-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1913-12-23/ch6/s14/f"},"text":"Dec. 23, 1913, ch. 6, § 14(f)","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1923-03-04/ch252"},"text":"Mar. 4, 1923, ch. 252","children":[],"tail":", title IV, § 405, "},{"tag":"ref","attrib":{"href":"/us/stat/42/1480"},"text":"42 Stat. 1480","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/act/1935-08-23/ch614"},"text":"Aug. 23, 1935, ch. 614","children":[],"tail":", title II, § 203(a), "},{"tag":"ref","attrib":{"href":"/us/stat/49/704"},"text":"49 Stat. 704","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb35c235-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb35c236-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddb35c237-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of subsec. (f) of section 14 of act ","children":[{"tag":"date","attrib":{"date":"1913-12-23"},"text":"Dec. 23, 1913","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1923-03-04"},"text":"Mar. 4, 1923","children":[],"tail":". For classification to this title of remainder of section 14, see Codification note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s353"},"text":"section 353 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddb35c238-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"iddb35c239-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 203(a) of act ","children":[{"tag":"date","attrib":{"date":"1935-08-23"},"text":"Aug. 23, 1935","children":[],"tail":", changed name of Federal Reserve Board to Board of Governors of the Federal Reserve System."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddb35c23a-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"National Agricultural Credit Corporation","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Title II of the Agricultural Credits Act, act ","children":[{"tag":"date","attrib":{"date":"1923-03-04"},"text":"Mar. 4, 1923","children":[],"tail":", title II, §§ 201–217, "},{"tag":"ref","attrib":{"href":"/us/stat/42/1461"},"text":"42 Stat. 1461","children":[],"tail":", authorized creation of national agricultural credit corporations, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/86/230"},"text":"Pub. L. 86–230","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-09-08"},"text":"Sept. 8, 1959","children":[],"tail":", § 24, "},{"tag":"ref","attrib":{"href":"/us/stat/73/466"},"text":"73 Stat. 466","children":[],"tail":". Prior to such repeal, act "},{"tag":"date","attrib":{"date":"1933-06-16"},"text":"June 16, 1933","children":[],"tail":", § 77, "},{"tag":"ref","attrib":{"href":"/us/stat/48/292"},"text":"48 Stat. 292","children":[],"tail":", had prohibited the creation, after "},{"tag":"date","attrib":{"date":"1933-06-16"},"text":"June 16, 1933","children":[],"tail":", of national agricultural credit corporations authorized to be formed under the Agricultural Credits Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
