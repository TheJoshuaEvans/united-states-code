{"tag":"section","attrib":{"id":"iddd1c35ce-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4203"},"text":null,"children":[{"tag":"num","attrib":{"value":"4203"},"text":"§ 4203.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality of declarations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd1c35cf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4203/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of confidentiality","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A declarant and the declarant’s agents shall not disclose the existence or filing of a declaration filed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4201"},"text":"section 4201 of this title","children":[],"tail":" until—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd1c35d0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4203/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the declarant receives notice that the Attorney General has concluded that an action should not be pursued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4206/b"},"text":"section 4206(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1c35d1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4203/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the declarant receives notice of an award pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4206/c"},"text":"section 4206(c) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1c35d2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4203/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the declarant is granted a contract to pursue an action under section 4205(b) or 4207 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1c35d3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4203/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of confidentiality to prevent prejudice","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd1c35d4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4203/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other law, the contents of a declaration shall not be disclosed by the declarant if the disclosure would prejudice or compromise in any way the completion of any government investigation or any criminal or civil case that may arise out of, or make use of, information contained in a declaration, but information contained in a declaration may be disclosed as required by duly issued and authorized legal process.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1c35d5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4203/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Attorney General may in a circumstance described in paragraph (1) notify a declarant that continued confidentiality is required under this subsection notwithstanding paragraph (1) or (2) of subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1c35d6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4203/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loss of rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A declarant who discloses, except as provided by this chapter,","children":[{"tag":"ref","attrib":{"idref":"fn002383"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002383"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" the existence or filing of a declaration or the contents thereof to anyone other than a duly authorized Federal or State investigator or the declarant’s attorney shall immediately lose all rights under this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd1c35d7-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXV/s2563"},"text":"Pub. L. 101–647, title XXV, § 2563","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4894"},"text":"104 Stat. 4894","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd1c35d8-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd1c35d9-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd1c35da-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (c), was in the original “this title”, and was translated as reading “this subtitle”, meaning subtitle H of title XXV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647"},"text":"Pub. L. 101–647","children":[],"tail":", known as the Financial Institutions Anti-Fraud Enforcement Act of 1990, which is classified principally to this chapter, as the probable intent of Congress. For complete classification of subtitle H to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4201"},"text":"section 4201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
