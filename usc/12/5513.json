{"tag":"section","attrib":{"id":"iddd6fac8a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5513"},"text":null,"children":[{"tag":"num","attrib":{"value":"5513"},"text":"§ 5513.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of Bureau regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd6fac8b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5513/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of Bureau regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On the petition of a member agency of the Council, the Council may set aside a final regulation prescribed by the Bureau, or any provision thereof, if the Council decides, in accordance with subsection (c), that the regulation or provision would put the safety and soundness of the United States banking system or the stability of the financial system of the United States at risk.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd6fac8c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5513/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Petition","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd6fac8d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5513/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedure","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An agency represented by a member of the Council may petition the Council, in writing, and in accordance with rules prescribed pursuant to subsection (f), to stay the effectiveness of, or set aside, a regulation if the member agency filing the petition—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd6fac8e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5513/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has in good faith attempted to work with the Bureau to resolve concerns regarding the effect of the rule on the safety and soundness of the United States banking system or the stability of the financial system of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd6fac8f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5513/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" files the petition with the Council not later than 10 days after the date on which the regulation has been published in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd6fac90-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5513/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any petition filed with the Council under this section shall be published in the Federal Register and transmitted contemporaneously with filing to the Committee on Banking, Housing, and Urban Affairs of the Senate and the Committee on Financial Services of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd6fac91-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5513/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stays and set asides","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd6fac92-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5513/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stay","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd6fac93-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5513/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon the request of any member agency, the Chairperson of the Council may stay the effectiveness of a regulation for the purpose of allowing appropriate consideration of the petition by the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd6fac94-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5513/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expiration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A stay issued under this paragraph shall expire on the earlier of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd6fac95-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5513/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 90 days after the date of filing of the petition under subsection (b); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd6fac96-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5513/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the Council makes a decision under paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd6fac97-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5513/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No adverse inference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After the expiration of any stay imposed under this section, no inference shall be drawn regarding the validity or enforceability of a regulation which was the subject of the petition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd6fac98-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5513/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vote","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd6fac99-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5513/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The decision to issue a stay of, or set aside, any regulation under this section shall be made only with the affirmative vote in accordance with subparagraph (B) of ⅔ of the members of the Council then serving.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd6fac9a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5513/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization to vote","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A member of the Council may vote to stay the effectiveness of, or set aside, a final regulation prescribed by the Bureau only if the agency or department represented by that member has—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd6fac9b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5513/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" considered any relevant information provided by the agency submitting the petition and by the Bureau; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd6fac9c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5513/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made an official determination, at a public meeting where applicable, that the regulation which is the subject of the petition would put the safety and soundness of the United States banking system or the stability of the financial system of the United States at risk.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd6fac9d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5513/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Decisions to set aside","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd6fac9e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5513/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of decision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A decision by the Council to set aside a regulation prescribed by the Bureau, or provision thereof, shall render such regulation, or provision thereof, unenforceable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd6fac9f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5513/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timely action required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council may not issue a decision to set aside a regulation, or provision thereof, which is the subject of a petition under this section after the expiration of the later of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd6faca0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5513/c/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 45 days following the date of filing of the petition, unless a stay is issued under paragraph (1); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd6faca1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5513/c/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expiration of a stay issued by the Council under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd6faca2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5513/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separate authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The issuance of a stay under this section does not affect the authority of the Council to set aside a regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd6faca3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5513/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dismissal due to inaction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A petition under this section shall be deemed dismissed if the Council has not issued a decision to set aside a regulation, or provision thereof, within the period for timely action under paragraph (4)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd6faca4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5513/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication of decision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any decision under this subsection to issue a stay of, or set aside, a regulation or provision thereof shall be published by the Council in the Federal Register as soon as practicable after the decision is made, with an explanation of the reasons for the decision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd6faca5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5513/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rulemaking procedures inapplicable","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The notice and comment procedures under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":" shall not apply to any decision under this section of the Council to issue a stay of, or set aside, a regulation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd6faca6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5513/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial review of decisions by the Council","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A decision by the Council to set aside a regulation prescribed by the Bureau, or provision thereof, shall be subject to review under chapter 7 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd6faca7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5513/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of other law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed as altering, limiting, or restricting the application of any other provision of law, except as otherwise specifically provided in this section, including chapter 5 and chapter 7 of title 5, to a regulation which is the subject of a petition filed under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd6faca8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5513/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings clause","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed as limiting or restricting the Bureau from engaging in a rulemaking in accordance with applicable law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd6faca9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5513/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementing rules","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall prescribe procedural rules to implement this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd6facaa-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1023"},"text":"Pub. L. 111–203, title X, § 1023","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1985"},"text":"124 Stat. 1985","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd6facab-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd6facac-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd6facad-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the designated transfer date, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1029A"},"text":"section 1029A of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5511"},"text":"section 5511 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
