{"tag":"section","attrib":{"id":"iddd1e7f81-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4244"},"text":null,"children":[{"tag":"num","attrib":{"value":"4244"},"text":"§ 4244.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract provisions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"A contract made with a private counsel under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4241"},"text":"section 4241 of this title","children":[],"tail":" shall include—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd1e7f82-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4244/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a provision permitting the Attorney General to terminate either the contract or the private counsel’s representation of the United States in particular cases if the Attorney General finds that such action is in the best interests of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1e7f83-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4244/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a provision requiring private counsel to transmit monthly to the Attorney General a report on the services relating to matters handled pursuant to the contract during the preceding month and the progress made during that period; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1e7f84-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4244/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a provision requiring that the initiation, settlement, dismissal, or compromise of a claim be approved by a duly appointed officer of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd1e7f85-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXV/s2591"},"text":"Pub. L. 101–647, title XXV, § 2591","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4906"},"text":"104 Stat. 4906","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
