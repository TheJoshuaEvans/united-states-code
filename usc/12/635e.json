{"tag":"section","attrib":{"id":"iddb5e3114-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635e"},"text":null,"children":[{"tag":"num","attrib":{"value":"635e"},"text":"§ 635e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aggregate loan, guarantee, and insurance authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddb5e3115-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on outstanding amounts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb5e3116-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Export-Import Bank of the United States shall not have outstanding at any one time loans, guarantees, and insurance in an aggregate amount in excess of the applicable amount.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb5e3117-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable amount defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subsection, the term “applicable amount”, for each of fiscal years 2020 through 2027, means $135,000,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb5e3118-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635e/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Freezing of lending cap if default rate is 2 percent or more","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the rate calculated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s635g/g/1"},"text":"section 635g(g)(1) of this title","children":[],"tail":" is 2 percent or more for a quarter, the Bank may not exceed the amount of loans, guarantees, and insurance outstanding on the last day of that quarter until the rate calculated under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s635g/g/1"},"text":"section 635g(g)(1) of this title","children":[],"tail":" is less than 2 percent."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb5e3119-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635e/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subject to appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All spending and credit authority provided under this subchapter shall be effective for any fiscal year only to such extent or in such amounts as are provided in appropriation Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb5e311a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reserve requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Bank shall build to and hold in reserve, to protect against future losses, an amount that is not less than 5 percent of the aggregate amount of disbursed and outstanding loans, guarantees, and insurance of the Bank.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb5e311b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presidential determination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb5e311c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635e/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than March 31 of each fiscal year, the President of the United States shall determine whether the authority available to the Bank for such fiscal year will be sufficient to meet the Bank’s needs, particularly those needs arising from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddb5e311d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635e/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increases in the level of exports unforeseen at the time of the original budget request for such fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb5e311e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635e/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any increased foreign export credit subsidies; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb5e311f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635e/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the lack of progress in negotiations to reduce or eliminate export credit subsidies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb5e3120-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635e/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Request for legislation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddb5e3121-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635e/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the President of the United States finds that the amount of direct loan authority or guarantee authority available to the Bank for the fiscal year involved exceeds the amount which will be necessary to carry out the Bank’s functions consistent with the availability of qualified applications and limitations imposed by law during such year, the President of the United States shall promptly transmit to the Congress a request for legislation to eliminate the amount of such excess direct loan, loan guarantee, or insurance authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb5e3122-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635e/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continued availability of authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Bank shall continue to make remaining amounts of its authority available for the fiscal year involved, in accordance with its practices and the requirements of this subchapter, unless otherwise directed pursuant to law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddb5e3123-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-07-31/ch341/s6"},"text":"July 31, 1945, ch. 341, § 6","children":[],"tail":", formerly § 7, "},{"tag":"ref","attrib":{"href":"/us/stat/59/529"},"text":"59 Stat. 529","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1951-10-03/ch445/s1/b"},"text":"Oct. 3, 1951, ch. 445, § 1(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/65/367"},"text":"65 Stat. 367","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1953-05-21/ch64/s2"},"text":"May 21, 1953, ch. 64, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/67/28"},"text":"67 Stat. 28","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-09/ch660/s3/b"},"text":"Aug. 9, 1954, ch. 660, § 3(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/678"},"text":"68 Stat. 678","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/424/s1/2"},"text":"Pub. L. 85–424, § 1(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-05-22"},"text":"May 22, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/133"},"text":"72 Stat. 133","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/101/s1/b"},"text":"Pub. L. 88–101, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-08-20"},"text":"Aug. 20, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/128"},"text":"77 Stat. 128","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/267/s1/a"},"text":"Pub. L. 90–267, § 1(a)","children":[],"tail":", (e), "},{"tag":"date","attrib":{"date":"1968-03-13"},"text":"Mar. 13, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/47"},"te