2/145/s121/1"},"text":"Pub. L. 102–145, § 121(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-28"},"text":"Oct. 28, 1991","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/266/s102"},"text":"Pub. L. 102–266, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-04-01"},"text":"Apr. 1, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/95"},"text":"106 Stat. 95","children":[],"tail":"; renumbered § 6 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/429/tI"},"text":"Pub. L. 102–429, title I","children":[],"tail":", §§ 109(b), 121(c)(2), "},{"tag":"date","attrib":{"date":"1992-10-21"},"text":"Oct. 21, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2193"},"text":"106 Stat. 2193","children":[],"tail":", 2199; "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/tXI/s1104/a/3"},"text":"Pub. L. 106–569, title XI, § 1104(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/3031"},"text":"114 Stat. 3031","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/189/s5"},"text":"Pub. L. 107–189, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-06-14"},"text":"June 14, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/699"},"text":"116 Stat. 699","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/438/s9"},"text":"Pub. L. 109–438, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3275"},"text":"120 Stat. 3275","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/122/s3"},"text":"Pub. L. 112–122, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-05-30"},"text":"May 30, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/350"},"text":"126 Stat. 350","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dE/tLI"},"text":"Pub. L. 114–94, div. E, title LI","children":[],"tail":", §§ 51001, 51002(a), "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1763"},"text":"129 Stat. 1763","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/94/dI/tIV/s401/b"},"text":"Pub. L. 116–94, div. I, title IV, § 401(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3021"},"text":"133 Stat. 3021","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb5e3124-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb5e3125-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"iddb5e3126-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-07-31/ch341"},"text":"act July 31, 1945, ch. 341","children":[],"tail":", was renumbered section 5 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s635d"},"text":"section 635d of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddb5e3127-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94"},"text":"Pub. L. 116–94","children":[],"tail":" substituted “for each of fiscal years 2020 through 2027” for “for each of fiscal years 2015 through 2019”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(2) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s51001"},"text":"Pub. L. 114–94, § 51001","children":[],"tail":", added pars. (2) and (3), redesignated former par. (3) as (4), and struck out former par. (2) which defined the term “applicable amount”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s51002/a"},"text":"Pub. L. 114–94, § 51002(a)","children":[],"tail":", added subsec. (b) and redesignated former subsec. (b) as (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (a)(2)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/122"},"text":"Pub. L. 112–122","children":[],"tail":" added subpar. (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/438"},"text":"Pub. L. 109–438","children":[],"tail":" amended subpar. (E) generally. Prior to amendment, subpar. (E) read as follows: “during fiscal year 2006, $100,000,000,000.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/189"},"text":"Pub. L. 107–189","children":[],"tail":" reenacted heading without change and amended text generally. Prior to amendment, text read as follows: “The Export-Import Bank of the United States shall not have outstanding at any one time loans, guaranties, and insurance in an aggregate amount in excess of $75,000,000,000. All spending and credit authority provided under this subchapter shall be effective for any fiscal year only to such extent or in such amounts as are provided in appropriation Acts.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (b)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/569"},"text":"Pub. L. 106–569","children":[],"tail":" redesignated par. (3) as (2) and struck out heading and text of former par. (2). Text read as follows: “Not later than April 15 of each year, the President of the United States shall transmit to the Congress a report on such determination.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/429/s109/b"},"text":"Pub. L. 102–429, § 109(b)","children":[],"tail":", inserted section catchline, redesignated former subsec. (a)(1) as subsec. (a), inserted subsec. heading, substituted “$75,000,000,000” for “$40,000,000,000”, redesignated former subsec. (a)(2) as subsec. (b), redesignated former subpar. (A)(i) as par. (1), former subcls. (I) to (III) as subpars. (A) to (C), respectively, former subpar. (A)(ii) as par. (2), former subpar. (B) as par. (3), and former cls. (i) and (ii) as subpars. (A) and (B), respectively, inserted headings for subsec. (b), pars. (1) to (3), and subpars. (A) and (B) of par. (3), and struck out former subsec. (a)(3) which read as follows: “"},{"tag":"inline","attrib":{},"text":"Authorization of Appropriation","children":[],"tail":".—There are authorized to be appropriated $145,259,000 for fiscal year 1987 to cover the subsidy cost of new direct loans obligated by the Bank in that fiscal year. Any amounts appropriated under this paragraph shall be permanent additions to the capital and reserves of the Bank.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/145/s121/1"},"text":"Pub. L. 102–145, § 121(1)","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/102/266"},"text":"Pub. L. 102–266","children":[],"tail":", struck out subsec. (b) which read as follows: “After "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"January 4, 1975","children":[],"tail":", the Bank shall not approve any loans or financial guarantees, or combination thereof, in connection with exports to the Union of Soviet Socialist Republics in an aggregate amount in excess of $300,000,000. No such loan or financial guarantee, or combination thereof, shall be for the purchase, lease, or procurement of any product or service for production (including processing and distribution) of fossil fuel energy resources. Not more than $40,000,000 of such aggregate amount shall be for the purchase, lease, or procurement of any product or service which involves research or exploration of fossil fuel energy resources. The President may establish a limitation in excess of $300,000,000 if the President determines that such higher limitation is in the national interest and if the President reports such determination to the Congress together with the reasons therefor, including the amount of such proposed increase which would be available for the export of products and services for research, exploration, and production (including processing and distribution) of fossil fuel energy resources in the Union of Soviet Socialist Republics, and if, after the receipt of such report together with the reasons, the Congress adopts a concurrent resolution approving such determination.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/472/s17"},"text":"Pub. L. 99–472, § 17","children":[],"tail":", substituted “All spending and credit authority” for “All spending authority”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/472/s13"},"text":"Pub. L. 99–472, § 13","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/181/s615"},"text":"Pub. L. 98–181, § 615","children":[],"tail":", amended par. (2) generally, substituting provisions requiring a Presidential determination, not later than March 31 of each fiscal year, as to whether the authority available to the Bank for such fiscal year will be sufficient to meet the Bank’s needs, requiring the President to transmit to Congress a report on such determination no later than April 15 of each year, and establishing procedures if the direct loan or guarantee authority available exceeds the amount necessary, for provision limiting gross obligations for the principal amount of direct loans authorized by the Bank during fiscal years 1982 and 1983 to $10,478,000,000, and designating specified amounts thereof for each fiscal year."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/181/s620/d"},"text":"Pub. L. 98–181, § 620(d)","children":[],"tail":", substituted “the President” for “he” before “determines that such higher limitation” and “reports such determination”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":" designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/630"},"text":"Pub. L. 95–630","children":[],"tail":" substituted “$40,000,000,000” for “$25,000,000,000” and inserted provision that all spending authority provided under this chapter be effective for any fiscal year only to such extent or in such amounts as are provided in appropriation Acts."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/646/s8/1"},"text":"Pub. L. 93–646, § 8(1)","children":[],"tail":", (2), designated existing provisions as subsec. (a) and substituted “$25,000,000,000” for “$20,000,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/646/s8/3"},"text":"Pub. L. 93–646, § 8(3)","children":[],"tail":", added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1971—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/126"},"text":"Pub. L. 92–126","children":[],"tail":" substituted “$20,000,000,000” for “$13,500,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1968—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/267"},"text":"Pub. L. 90–267","children":[],"tail":" changed name of “Export-Import Bank of Washington” to “Export-Import Bank of the United States” and substituted “$13,500,000,000” for “$9,000,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1963—","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/101"},"text":"Pub. L. 88–101","children":[],"tail":" substituted “$9,000,000,000” for “$7,000,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/424"},"text":"Pub. L. 85–424","children":[],"tail":" substituted “$7,000,000,000” for “$5,000,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1954—Act ","children":[{"tag":"date","attrib":{"date":"1954-08-09"},"text":"Aug. 9, 1954","children":[],"tail":", substituted “$5,000,000,000” for “four and one-half times the authorized capital stock of the Bank”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1953—Act ","children":[{"tag":"date","attrib":{"date":"1958-05-21"},"text":"May 21, 1958","children":[],"tail":", substituted “loans, guaranties, and insurance” for “loans and guaranties”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1951—Act ","children":[{"tag":"date","attrib":{"date":"1951-10-03"},"text":"Oct. 3, 1951","children":[],"tail":", substituted “four and one-half” for “three and one-half”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddb5e3128-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"t