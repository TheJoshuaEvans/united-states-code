{"tag":"section","attrib":{"id":"iddd04683a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3340"},"text":null,"children":[{"tag":"num","attrib":{"value":"3340"},"text":"§ 3340.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for proposal and adoption of standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Appraisal standards established under this chapter shall be proposed not later than 6 months and shall be adopted in final form and become effective not later than 12 months after ","children":[{"tag":"date","attrib":{"date":"1989-08-09"},"text":"August 9, 1989","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd04683b-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/tXI/s1111"},"text":"Pub. L. 101–73, title XI, § 1111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/514"},"text":"103 Stat. 514","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
