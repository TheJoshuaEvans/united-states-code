{"tag":"section","attrib":{"id":"iddb1b82af-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s164"},"text":null,"children":[{"tag":"num","attrib":{"value":"164"},"text":"§ 164.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty for failure to make reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddb1b82b0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s164/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" First tier","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any association which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb1b82b1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s164/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" maintains procedures reasonably adapted to avoid any inadvertent error and, unintentionally and as a result of such an error—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddb1b82b2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s164/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fails to make, obtain, transmit, or publish any report or information required by the Comptroller of the Currency under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s161"},"text":"section 161 of this title","children":[],"tail":", within the period of time specified by the Comptroller; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb1b82b3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s164/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submits or publishes any false or misleading report or information; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb1b82b4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s164/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inadvertently transmits or publishes any report which is minimally late,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be subject to a penalty of not more than $2,000 for each day during which such failure continues or such false or misleading information is not corrected. The association shall have the burden of proving that an error was inadvertent and that a report was inadvertently transmitted or published late.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb1b82b5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s164/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Second tier","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any association which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb1b82b6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s164/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fails to make, obtain, transmit, or publish any report or information required by the Comptroller of the Currency under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s161"},"text":"section 161 of this title","children":[],"tail":", within the period of time specified by the Comptroller; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb1b82b7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s164/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submits or publishes any false or misleading report or information,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"in a manner not described in subsection (a) shall be subject to a penalty of not more than $20,000 for each day during which such failure continues or such false or misleading information is not corrected.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb1b82b8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s164/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Third tier","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subsections (a) and (b), if any association knowingly or with reckless disregard for the accuracy of any information or report described in subsection (b) submits or publishes any false or misleading report or information, the Comptroller may assess a penalty of not more than $1,000,000 or 1 percent of total assets of the association, whichever is less, per day for each day during which such failure continues or such false or misleading information is not corrected.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb1b82b9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s164/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment; etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any penalty imposed under subsection (a), (b), or (c) shall be assessed and collected by the Comptroller of the Currency in the manner provided in subparagraphs (E), (F), (G), and (I) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1818/i/2"},"text":"section 1818(i)(2) of this title","children":[],"tail":" (for penalties imposed under such section) and any such assessment (including the determination of the amount of the penalty) shall be subject to the provisions of such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb1b82ba-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s164/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hearing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any association against which any penalty is assessed under this subsection ","children":[{"tag":"ref","attrib":{"idref":"fn002022"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002022"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “section”."}],"tail":" shall be afforded an agency hearing if such association submits a request for such hearing within 20 days after the issuance of the notice of assessment. "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1818/h"},"text":"Section 1818(h) of this title","children":[],"tail":" shall apply to any proceeding under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddb1b82bb-3a6f-11f1-8fa0-c065796a7f06"},"text":"(R.S. § 5213; ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/230/s12"},"text":"Pub. L. 86–230, § 12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-09-08"},"text":"Sept. 8, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/458"},"text":"73 Stat. 458","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/73/tIX/s911/b/2"},"text":"Pub. L. 101–73, title IX, § 911(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/478"},"text":"103 Stat. 478","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb1b82bc-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb1b82bd-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddb1b82be-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 5213 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1869-03-03/ch130"},"text":"act Mar. 3, 1869, ch. 130","children":[],"tail":", §§ 1, 2, "},{"tag":"ref","attrib":{"href":"/us/stat/15/326"},"text":"15 Stat. 326","children":[],"tail":", 327."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddb1b82bf-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73"},"text":"Pub. L. 101–73","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “Every association which fails to make and transmit any report required under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s161"},"text":"section 161 of this title","children":[],"tail":" shall be subject to a penalty of $100 for each day after the periods, respectively, therein mentioned, that it delays to make and transmit its report. Whenever any association delays or refuses to pay the penalty herein imposed, after it has been assessed by the Comptroller of the Currency, the amount thereof may be retained by the Treasurer of the United States, upon the order of the Comptroller of the Currency, out of the interest, as it may become due to the association, on the bonds deposited with him to secure circulation. All sums of money collected for penalties under this section shall be paid into the Treasury of the United States.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1959—","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/230"},"text":"Pub. L. 86–230","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t12/s161"},"text":"section 161 of this title","children":[],"tail":"” for “either section 161 or 163 of this title”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddb1b82c0-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddb1b82c1-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73"},"text":"Pub. L. 101–73","children":[],"tail":" applicable with respect to reports filed or required to be filed after "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/73/s911/i"},"text":"section 911(i) of Pub. L. 101–73","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s161"},"text":"section 161 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"iddb1b82c2-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddb1b82c3-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Exception as to Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions vested by any provision of law in Comptroller of the Currency, referred to in this section, not included in transfer of functions to Secretary of the Treasury, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
