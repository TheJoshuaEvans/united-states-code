{"tag":"section","attrib":{"id":"iddd44a525-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5011"},"text":null,"children":[{"tag":"num","attrib":{"value":"5011"},"text":"§ 5011.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consumer awareness","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd44a526-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5011/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each bank shall provide, in accordance with subsection (b), a brief notice about substitute checks that describes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd44a527-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5011/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" how a substitute check is the legal equivalent of an original check for all purposes, including any provision of any Federal or State law, and for all persons, if the substitute check—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd44a528-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5011/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accurately represents all of the information on the front and back of the original check as of the time at which the original check was truncated; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd44a529-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5011/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bears the legend: “This is a legal copy of your check. You can use it in the same way you would use the original check.”; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd44a52a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5011/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the consumer recredit rights established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5006"},"text":"section 5006 of this title","children":[],"tail":" when a consumer believes in good faith that a substitute check was not properly charged to the account of the consumer."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd44a52b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5011/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd44a52c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5011/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing customers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to consumers who are customers of a bank on the effective date of this chapter and who receive original checks or substitute checks, a bank shall provide the notice described in subsection (a) to each such consumer no later than the first regularly scheduled communication with the consumer after the effective date of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd44a52d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5011/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New account holders","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A bank shall provide the notice described in subsection (a) to each consumer who will receive original checks or substitute checks, other than existing customers referred to in paragraph (1), at the time at which the customer relationship is initiated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd44a52e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5011/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mode of delivery","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A bank may send the notices required by this subsection by United States mail or by any other means through which the consumer has agreed to receive account information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd44a52f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5011/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consumers who request copies of checks","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notice shall be provided to each consumer of the bank that requests a copy of a check and receives a substitute check, at the time of the request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd44a530-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5011/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Model language","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd44a531-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5011/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before the end of the 9-month period beginning on ","children":[{"tag":"date","attrib":{"date":"2003-10-28"},"text":"October 28, 2003","children":[],"tail":", the Board shall publish model forms and clauses that a bank may use to describe each of the elements required by subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd44a532-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5011/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Safe harbor","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd44a533-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5011/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A bank shall be treated as being in compliance with the requirements of subsection (a) if the bank’s substitute check notice uses a model form or clause published by the Board and such model form or clause accurately describes the bank’s policies and practices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd44a534-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5011/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deletion or rearrangement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A bank may delete any information in the model form or clause that is not required by this chapter or rearrange the format.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd44a535-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5011/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of model language not required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not be construed as requiring any bank to use a model form or clause that the Board prepares under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd44a536-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/100/s12"},"text":"Pub. L. 108–100, § 12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-10-28"},"text":"Oct. 28, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1189"},"text":"117 Stat. 1189","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd44a537-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd44a538-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd44a539-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The effective date of this chapter, referred to in subsec. (b)(1), is at the end of the 12-month period beginning on ","children":[{"tag":"date","attrib":{"date":"2003-10-28"},"text":"Oct. 28, 2003","children":[],"tail":", except as otherwise specifically provided in this chapter, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/100/s20"},"text":"section 20 of Pub. L. 108–100","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5001"},"text":"section 5001 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (c)(2)(B), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/100"},"text":"Pub. L. 108–100","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-10-28"},"text":"Oct. 28, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1177"},"text":"117 Stat. 1177","children":[],"tail":", which is classified generally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5001"},"text":"section 5001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd44a53a-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd44a53b-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective at the end of the 12-month period beginning on ","children":[{"tag":"date","attrib":{"date":"2003-10-28"},"text":"Oct. 28, 2003","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/100/s20"},"text":"section 20 of Pub. L. 108–100","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5001"},"text":"section 5001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
