{"tag":"section","attrib":{"id":"iddd1e7f8e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4301"},"text":null,"children":[{"tag":"num","attrib":{"value":"4301"},"text":"§ 4301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings and purpose","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd1e7f8f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4301/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Congress hereby finds that economic stability would be enhanced, competition between depository institutions would be improved, and the ability of the consumer to make informed decisions regarding deposit accounts, and to verify accounts, would be strengthened if there was uniformity in the disclosure of terms and conditions on which interest is paid and fees are assessed in connection with such accounts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1e7f90-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4301/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the purpose of this chapter to require the clear and uniform disclosure of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd1e7f91-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4301/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rates of interest which are payable on deposit accounts by depository institutions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1e7f92-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4301/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fees that are assessable against deposit accounts,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"so that consumers can make a meaningful comparison between the competing claims of depository institutions with regard to deposit accounts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd1e7f93-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/tII/s262"},"text":"Pub. L. 102–242, title II, § 262","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2334"},"text":"105 Stat. 2334","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd1e7f94-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd1e7f95-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"iddd1e7f96-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/tII/s261"},"text":"Pub. L. 102–242, title II, § 261","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2334"},"text":"105 Stat. 2334","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/242/tII/s261"},"text":"“This subtitle [subtitle F (§§ 261–274) of title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242"},"text":"Pub. L. 102–242","children":[],"tail":", enacting this chapter] may be cited as the ‘Truth in Savings Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"separability","id":"iddd1e7f97-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Separability","children":[],"tail":null},{"tag":"p","attrib":{},"text":"If any provision of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242"},"text":"Pub. L. 102–242","children":[],"tail":" or any application of any provision thereof to any person or circumstance is held invalid, the remainder of "},{"tag":"ref","attrib":{"href":"/us/pl/102/242"},"text":"Pub. L. 102–242","children":[],"tail":" and the application of any remaining provision of such Act to any other person or circumstance not to be affected by such holding, see "},{"tag":"ref","attrib":{"href":"/us/pl/102/242/s481"},"text":"section 481 of Pub. L. 102–242","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1811"},"text":"section 1811 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
