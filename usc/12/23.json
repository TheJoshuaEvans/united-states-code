{"tag":"section","attrib":{"id":"iddb014456-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s23"},"text":null,"children":[{"tag":"num","attrib":{"value":"23"},"text":"§ 23.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acknowledgment and filing of certificate","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The organization certificate shall be acknowledged before a judge of some court of record, or notary public; and shall be, together with the acknowledgment thereof, authenticated by the seal of such court, or notary, transmitted to the Comptroller of the Currency, who shall record and carefully preserve the same in his office.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddb014457-3a6f-11f1-8fa0-c065796a7f06"},"text":"(R.S. § 5135.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb014458-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb014459-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddb01445a-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 5135 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1864-06-03/ch106/s6"},"text":"act June 3, 1864, ch. 106, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/13/101"},"text":"13 Stat. 101","children":[],"tail":", which was the National Bank Act. See "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s38"},"text":"section 38 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"iddb01445b-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddb01445c-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Exception as to Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions vested by any provision of law in Comptroller of the Currency, referred to in this section, not included in transfer of functions to Secretary of the Treasury, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
