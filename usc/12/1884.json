{"tag":"section","attrib":{"id":"iddcb7f4c0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1884"},"text":null,"children":[{"tag":"num","attrib":{"value":"1884"},"text":"§ 1884.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties for violations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A bank or savings association which violates a rule promulgated pursuant to this chapter shall be subject to a civil penalty which shall not exceed $100 for each day of the violation.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddcb7f4c1-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/389/s5"},"text":"Pub. L. 90–389, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-07-07"},"text":"July 7, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/295"},"text":"82 Stat. 295","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tIII/s356/3"},"text":"Pub. L. 111–203, title III, § 356(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1547"},"text":"124 Stat. 1547","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcb7f4c2-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcb7f4c3-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcb7f4c4-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—",