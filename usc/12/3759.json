{"tag":"section","attrib":{"id":"iddd104dea-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3759"},"text":null,"children":[{"tag":"num","attrib":{"value":"3759"},"text":"§ 3759.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presale reinstatement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd104deb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3759/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal and cancellation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd104dec-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3759/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in sections 3756(b) and 3760(c) of this title, the foreclosure commissioner shall withdraw the security property from foreclosure and cancel the foreclosure sale only if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd104ded-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3759/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary directs the foreclosure commissioner to do so before or at the time of the sale;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd104dee-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3759/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the foreclosure commissioner finds, upon application of the mortgagor not less than 3 days before the date of the sale, that the default or defaults upon which the foreclosure is based did not exist at the time of service of the notice of default and foreclosure sale; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd104def-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3759/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd104df0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3759/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a foreclosure involving a monetary default, there is tendered to the foreclosure commissioner before public auction is completed the entire amount of principal and interest which would be due if payments under the mortgage had not been accelerated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd104df1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3759/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a foreclosure involving a nonmonetary default, the foreclosure commissioner, upon application of the mortgagor before the date of foreclosure sale, finds that such default is cured; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd104df2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3759/a/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" there is tendered to the foreclosure commissioner before public auction is completed—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddd104df3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3759/a/1/C/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all amounts due under the mortgage agreement (excluding additional amounts which would have been due if mortgage payments had been accelerated);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddd104df4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3759/a/1/C/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all amounts of expenditures secured by the mortgage; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddd104df5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3759/a/1/C/iii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all costs of foreclosure incurred for which payment from the proceeds of foreclosure is provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s3761"},"text":"section 3761 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd104df6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3759/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discretionary noncancellation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may refuse to cancel a foreclosure sale pursuant to paragraph (1)(C) if the current mortgagor or owner of record has, on one or more previous occasions, caused a foreclosure of the mortgage, commenced pursuant to this chapter or otherwise, to be canceled by curing a default.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd104df7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3759/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Opportunity of Secretary to dispute withdrawal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before withdrawing the security property from foreclosure under subparagraph (B) or (C) of subsection (a)(1), the foreclosure commissioner shall afford the Secretary a reasonable opportunity to demonstrate why the security property should not be so withdrawn.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd104df8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3759/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of cancellation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd104df9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3759/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mortgage unaffected","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any case in which a foreclosure commenced under this chapter is canceled, the mortgage shall continue in effect as though acceleration had not occurred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd104dfa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3759/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commencement of new foreclosure sale","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Cancellation of a foreclosure sale under this chapter shall have no effect on the commencement of a subsequent foreclosure proceeding under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd104dfb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3759/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of cancellation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The foreclosure commissioner shall file a notice of cancellation in the same place and manner provided for filing the notice of default and foreclosure sale in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s3758"},"text":"section 3758 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd104dfc-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/327/tII"},"text":"Pub. L. 103–327, title II","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-28"},"text":"Sept. 28, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2316"},"text":"108 Stat. 2316","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd104dfd-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd104dfe-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd104dff-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is based on section 810 of title VIII of S. 2281, One Hundred Third Congress, as reported ","children":[{"tag":"date","attrib":{"date":"1994-07-13"},"text":"July 13, 1994","children":[],"tail":", which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/103/327"},"text":"Pub. L. 103–327","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
