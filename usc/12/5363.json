{"tag":"section","attrib":{"id":"iddd57b6c4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5363"},"text":null,"children":[{"tag":"num","attrib":{"value":"5363"},"text":"§ 5363.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd57b6c5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5363/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisitions of banks; treatment as a bank holding company","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1842"},"text":"section 1842 of this title","children":[],"tail":", a nonbank financial company supervised by the Board of Governors shall be deemed to be, and shall be treated as, a bank holding company."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd57b6c6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5363/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of nonbank companies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd57b6c7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5363/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prior notice for large acquisitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1843/k/6/B"},"text":"section 1843(k)(6)(B) of this title","children":[],"tail":", a bank holding company with total consolidated assets equal to or greater than $250,000,000,000 or a nonbank financial company supervised by the Board of Governors shall not acquire direct or indirect ownership or control of any voting shares of any company (other than an insured depository institution) that is engaged in activities described in "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1843/k"},"text":"section 1843(k) of this title","children":[],"tail":" having total consolidated assets of $10,000,000,000 or more, without providing written notice to the Board of Governors in advance of the transaction."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd57b6c8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5363/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The prior notice requirement in paragraph (1) shall not apply with regard to the acquisition of shares that would qualify for the exemptions in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1843/c"},"text":"section 1843(c) of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1843/k/4/E"},"text":"section 1843(k)(4)(E) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd57b6c9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5363/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The notice procedures set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1843/j/1"},"text":"section 1843(j)(1) of this title","children":[],"tail":", without regard to "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1843/j/3"},"text":"section 1843(j)(3) of this title","children":[],"tail":", shall apply to an acquisition of any company (other than an insured depository institution) by a bank holding company with total consolidated assets equal to or greater than $250,000,000,000 or a nonbank financial company supervised by the Board of Governors, as described in paragraph (1), including any such company engaged in activities described in "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1843/k"},"text":"section 1843(k) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd57b6ca-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5363/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards for review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to the standards provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1843/j/2"},"text":"section 1843(j)(2) of this title","children":[],"tail":", the Board of Governors shall consider the extent to which the proposed acquisition would result in greater or more concentrated risks to global or United States financial stability or the United States economy."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd57b6cb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5363/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hart-Scott-Rodino filing requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Solely for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s18a/c/8"},"text":"section 18a(c)(8) of title 15","children":[],"tail":", the transactions subject to the requirements of paragraph (1) shall be treated as if Board of Governors approval is not required."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd57b6cc-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tI/s163"},"text":"Pub. L. 111–203, title I, § 163","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1422"},"text":"124 Stat. 1422","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/174/tIV/s401/c/1/E"},"text":"Pub. L. 115–174, title IV, § 401(c)(1)(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-05-24"},"text":"May 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1358"},"text":"132 Stat. 1358","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd57b6cd-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd57b6ce-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd57b6cf-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(1), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/174"},"text":"Pub. L. 115–174","children":[],"tail":" substituted “$250,000,000,000” for “$50,000,000,000”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd57b6d0-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd57b6d1-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Except as otherwise provided, amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/174"},"text":"Pub. L. 115–174","children":[],"tail":" effective 18 months after "},{"tag":"date","attrib":{"date":"2018-05-24"},"text":"May 24, 2018","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/174/s401/d"},"text":"section 401(d) of Pub. L. 115–174","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5365"},"text":"section 5365 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd57b6d2-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For construction of amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/174"},"text":"Pub. L. 115–174","children":[],"tail":" as applied to certain foreign banking organizations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/174/s401/g"},"text":"section 401(g) of Pub. L. 115–174","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5365"},"text":"section 5365 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
