{"tag":"section","attrib":{"id":"iddc37539f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1749aaa–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"1749aaa–3"},"text":"§ 1749aaa–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe such regulations as may be necessary to carry out this subchapter, after consulting with the Secretary of Health and Human Services with respect to any health or medical aspects of the program under this subchapter which may be involved in such regulations.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc3753a0-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-27/ch847"},"text":"June 27, 1934, ch. 847","children":[],"tail":", title XI, § 1104, as added "},{"tag":"ref","attrib":{"href":"/us/pl/89/754/tV/s502/a"},"text":"Pub. L. 89–754, title V, § 502(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-03"},"text":"Nov. 3, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1275"},"text":"80 Stat. 1275","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/479/tII/s201/a/2"},"text":"Pub. L. 98–479, title II, § 201(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-17"},"text":"Oct. 17, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2227"},"text":"98 Stat. 2227","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc3753a1-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc3753a2-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","chil