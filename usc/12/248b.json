{"tag":"section","attrib":{"id":"iddb29da8e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s248b"},"text":null,"children":[{"tag":"num","attrib":{"value":"248b"},"text":"§ 248b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual independent audits of Federal reserve banks and Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Board shall order an annual independent audit of the financial statements of each Federal reserve bank and the Board.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddb29da8f-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1913-12-23/ch6/s11B"},"text":"Dec. 23, 1913, ch. 6, § 11B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/102/tVII/s726"},"text":"Pub. L. 106–102, title VII, § 726","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1475"},"text":"113 Stat. 1475","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
