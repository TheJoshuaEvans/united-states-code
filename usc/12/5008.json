{"tag":"section","attrib":{"id":"iddd44a501-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5008"},"text":null,"children":[{"tag":"num","attrib":{"value":"5008"},"text":"§ 5008.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delays in an emergency","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A delay by a bank beyond the time limits prescribed or permitted by this chapter shall be excused if the delay is caused by interruption of communication or computer facilities, suspension of payments by another bank, war, emergency conditions, failure of equipment, or other circumstances beyond the control of a bank and if the bank uses such diligence as the circumstances require.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd44a502-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/100/s9"},"text":"Pub. L. 108–100, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-10-28"},"text":"Oct. 28, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1188"},"text":"117 Stat. 1188","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd44a503-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd44a504-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd44a505-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/100"},"text":"Pub. L. 108–100","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-10-28"},"text":"Oct. 28, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1177"},"text":"117 Stat. 1177","children":[],"tail":", which is classified generally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5001"},"text":"section 5001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd44a506-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd44a507-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective at the end of the 12-month period beginning on ","children":[{"tag":"date","attrib":{"date":"2003-10-28"},"text":"Oct. 28, 2003","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/100/s20"},"text":"section 20 of Pub. L. 108–100","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5001"},"text":"section 5001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
