{"tag":"section","attrib":{"id":"iddcd233a6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"2277a–1"},"text":"§ 2277a–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Farm Credit System Insurance Corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is hereby established the Farm Credit System Insurance Corporation which shall insure, in accordance with this part, the timely payment of principal and interest on notes, bonds, debentures, and other obligations issued under subsection (c) or (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2153"},"text":"section 2153 of this title","children":[],"tail":" on behalf of one or more System banks all of which are entitled to the benefits of insurance under this part."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddcd233a7-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tV/s5"},"text":"Pub. L. 92–181, title V, § 5","children":[],"tail":".52, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tIII/s302"},"text":"Pub. L. 100–233, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1611"},"text":"101 Stat. 1611","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
