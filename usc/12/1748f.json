{"tag":"section","attrib":{"id":"iddc32711e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1748f"},"text":null,"children":[{"tag":"num","attrib":{"value":"1748f"},"text":"§ 1748f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized and directed to make such rules and regulations as may be necessary to carry out the provisions of this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc32711f-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-27/ch847"},"text":"June 27, 1934, ch. 847","children":[],"tail":", title VIII, § 807, as added "},{"tag":"ref","attrib":{"href":"/us/act/1949-08-08/ch403/s1"},"text":"Aug. 8, 1949, ch. 403, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/576"},"text":"63 Stat. 576","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/act/1955-08-11/ch783"},"text":"Aug. 11, 1955, ch. 783","children":[],"tail":", title IV, § 401, "},{"tag":"ref","attrib":{"href":"/us/stat/69/651"},"text":"69 Stat. 651","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/19/s1/a/3"},"text":"Pub. L. 90–19, § 1(a)(3)","children":[],"tail":", (q), "},{"tag":"date","attrib":{"date":"1967-05-25"},"text":"May 25, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/17"},"text":"81 Stat. 17","children":[],"tail":", 19.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc327120-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc327121-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc327122-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1967—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/19"},"text":"Pub. L. 90–19","children":[],"tail":" substituted “Secretary” for “Commissioner” and struck out authorization for appointment by the Commissioner of a Special Assistant for Armed Services Housing for Mortgage Insurance with an adequate staff to expedite operations and eliminate administrative obstacles to this subchapter, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1955—Act ","children":[{"tag":"date","attrib":{"date":"1955-08-11"},"text":"Aug. 11, 1955","children":[],"tail":", amended section generally, striking out provisions which stated that nothing should be construed as exempting property from taxation, and inserting provisions authorizing the Commissioner to make rules and regulations and to appoint a Special Assistant."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
