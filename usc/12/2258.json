{"tag":"section","attrib":{"id":"iddccfe9d9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2258"},"text":null,"children":[{"tag":"num","attrib":{"value":"2258"},"text":"§ 2258.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Each institution of the System shall for the purposes of jurisdiction be deemed to be a citizen of the State, commonwealth, or District of Columbia in which its principal office is located.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddccfe9da-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tV/s5"},"text":"Pub. L. 92–181, title V, § 5","children":[],"tail":".23, formerly § 5.24, "},{"tag":"date","attrib":{"date":"1971-12-10"},"text":"Dec. 10, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/624"},"text":"85 Stat. 624","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/184/s1/b"},"text":"Pub. L. 94–184, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-31"},"text":"Dec. 31, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/1060"},"text":"89 Stat. 1060","children":[],"tail":"; renumbered § 5.23, "},{"tag":"ref","attrib":{"href":"/us/pl/99/205/tII/s203/b"},"text":"Pub. L. 99–205, title II, § 203(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1694"},"text":"99 Stat. 1694","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddccfe9db-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddccfe9dc-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"iddccfe9dd-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5.23 of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181"},"text":"Pub. L. 92–181","children":[],"tail":" was renumbered section 5.22 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2257"},"text":"section 2257 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddccfe9de-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1975—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/184"},"text":"Pub. L. 94–184","children":[],"tail":" struck out provisions prohibiting district court jurisdiction on the basis of incorporation under this Act or prior Federal law, and prohibiting jurisdiction except in cases by or against the United States or one of its officers, or against a person over whom State courts have no jurisdiction and except in cases by or against a receiver or conservator appointed under this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
