{"tag":"section","attrib":{"id":"iddd3b2fe8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4719"},"text":null,"children":[{"tag":"num","attrib":{"value":"4719"},"text":"§ 4719.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to establish loan-loss reserve funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd3b2fe9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4719/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this section are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd3b2fea-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4719/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make financial assistance available from the Fund in order to help community development financial institutions defray the costs of operating small dollar loan programs, by providing the amounts necessary for such institutions to establish their own loan loss reserve funds to mitigate some of the losses on such small dollar loan programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3b2feb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4719/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage community development financial institutions to establish and maintain small dollar loan programs that would help give consumers access to mainstream financial institutions and combat high cost small dollar lending.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3b2fec-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4719/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd3b2fed-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4719/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan-loss reserve fund grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Fund shall make grants to community development financial institutions or to any partnership between such community development financial institutions and any other federally insured depository institution with a primary mission to serve targeted investment areas, as such areas are defined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4702/16"},"text":"section 4702(16) of this title","children":[],"tail":", to enable such institutions or any partnership of such institutions to establish a loan-loss reserve fund in order to defray the costs of a small dollar loan program established or maintained by such institution."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3b2fee-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4719/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A community development financial institution or any partnership of institutions established pursuant to paragraph (1) shall provide non-Federal matching funds in an amount equal to 50 percent of the amount of any grant received under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3b2fef-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4719/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any grant amounts received by a community development financial institution or any partnership between or among such institutions under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd3b2ff0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4719/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not be used by such institution to provide direct loans to consumers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3b2ff1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4719/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be used by such institution to help recapture a portion or all of a defaulted loan made under the small dollar loan program of such institution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3b2ff2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4719/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be used to designate and utilize a fiscal agent for services normally provided by such an agent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3b2ff3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4719/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Fund shall make technical assistance grants to community development financial institutions or any partnership between or among such institutions to support and maintain a small dollar loan program. Any grant amounts received under this paragraph may be used for technology, staff support, and other costs associated with establishing a small dollar loan program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3b2ff4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4719/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd3b2ff5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4719/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “consumer reporting agency that compiles and maintains files on consumers on a nationwide basis” has the same meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681a/p"},"text":"section 1681a(p) of title 15","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3b2ff6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4719/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “small dollar loan program” means a loan program wherein a community development financial institution or any partnership between or among such institutions offers loans to consumers that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd3b2ff7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4719/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are made in amounts not exceeding $2,500;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3b2ff8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4719/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" must be repaid in installments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3b2ff9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4719/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have no pre-payment penalty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3b2ffa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4719/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the institution has to report payments regarding the loan to at least 1 of the consumer reporting agencies that compiles and maintains files on consumers on a nationwide basis; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3b2ffb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4719/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet any other affordability requirements as may be established by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd3b2ffc-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/tI/s122"},"text":"Pub. L. 103–325, title I, § 122","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tXII/s1206"},"text":"Pub. L. 111–203, title XII, § 1206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2131"},"text":"124 Stat. 2131","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd3b2ffd-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd3b2ffe-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd3b2fff-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 1 day after ","children":[{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s4"},"text":"section 4 of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"section 5301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
