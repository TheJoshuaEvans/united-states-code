{"tag":"section","attrib":{"id":"iddd8508eb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5910"},"text":null,"children":[{"tag":"num","attrib":{"value":"5910"},"text":"§ 5910.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of payment stablecoin issuers in insolvency proceedings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s507/e"},"text":"section 507(e) of title 11","children":[],"tail":", as added by subsection (d), in any insolvency proceeding of a permitted payment stablecoin issuer under Federal or State law, including any proceeding under that title and any insolvency proceeding administered by a State payment stablecoin regulator with respect to a permitted payment stablecoin issuer—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd8508ec-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5910/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the claim of a person holding payment stablecoins issued by the permitted payment stablecoin issuer shall have priority, on a ratable basis with the claims of other persons holding such payment stablecoins, over the claims of the permitted payment stablecoin issuer and any other holder of claims against the permitted payment stablecoin issuer, with respect to required payment stablecoin reserves;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd8508ed-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5910/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notwithstanding any other provision of law, including the definition of “claim” under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s101/5"},"text":"section 101(5) of title 11","children":[],"tail":", any person holding a payment stablecoin issued by the permitted payment stablecoin issuer shall be deemed to hold a claim; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd8508ee-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5910/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the priority under paragraph (1) shall not apply to claims other than those arising directly from the holding of payment stablecoins.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd8508ef-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/27/s11/a"},"text":"Pub. L. 119–27, § 11(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-18"},"text":"July 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/457"},"text":"139 Stat. 457","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd8508f0-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"iddd8508f1-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Delayed Effective Date of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For delayed effective date of section, see Effective Date note below.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd8508f2-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd8508f3-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsection (d), referred to in introductory provisions, means subsec. (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/27/s11"},"text":"section 11 of Pub. L. 119–27","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd8508f4-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd8508f5-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the earlier of the date that is 18 months after ","children":[{"tag":"date","attrib":{"date":"2025-07-18"},"text":"July 18, 2025","children":[],"tail":", or the date that is 120 days after the date on which the primary Federal payment stablecoin regulators issue any final regulations implementing "},{"tag":"ref","attrib":{"href":"/us/pl/119/27"},"text":"Pub. L. 119–27","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/119/27/s20"},"text":"section 20 of Pub. L. 119–27","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5901"},"text":"section 5901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
