{"tag":"section","attrib":{"id":"iddb3a7c6b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371b–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"371b–2"},"text":"§ 371b–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interbank liabilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddb3a7c6c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371b–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of this section is to limit the risks that the failure of a large depository institution (whether or not that institution is an insured depository institution) would pose to insured depository institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb3a7c6d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371b–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aggregate limits on insured depository institutions’ exposure to other depository institutions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall, by regulation or order, prescribe standards that have the effect of limiting the risks posed by an insured depository institution’s exposure to any other depository institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb3a7c6e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371b–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Exposure” defined","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb3a7c6f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371b–2/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (b), an insured depository institution’s “exposure” to another depository institution means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddb3a7c70-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371b–2/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" all extensions of credit to the other depository institution, regardless of name or description, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddb3a7c71-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371b–2/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all deposits at the other depository institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddb3a7c72-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371b–2/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all purchases of securities or other assets from the other depository institution subject to an agreement to repurchase; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddb3a7c73-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371b–2/c/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all guarantees, acceptances, or letters of credit (including endorsements or standby letters of credit) on behalf of the other depository institution;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb3a7c74-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371b–2/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all purchases of or investments in securities issued by the other depository institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb3a7c75-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371b–2/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all securities issued by the other depository institution accepted as collateral for an extension of credit to any person; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb3a7c76-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371b–2/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all similar transactions that the Board by regulation determines to be exposure for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb3a7c77-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371b–2/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board may, at its discretion, by regulation or order, exempt transactions from the definition of “exposure” if it finds the exemptions to be in the public interest and consistent with the purpose of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb3a7c78-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371b–2/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attribution rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, any transaction by an insured depository institution with any person is a transaction with another depository institution to the extent that the proceeds of the transaction are used for the benefit of, or transferred to, that other depository institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb3a7c79-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371b–2/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Insured depository institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “insured depository institution” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"section 1813 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb3a7c7a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371b–2/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rulemaking authority; enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board may issue such regulations and orders, including definitions consistent with this section, as may be necessary to administer and carry out the purpose of this section. The appropriate Federal banking agency shall enforce compliance with those regulations under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1818"},"text":"section 1818 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddb3a7c7b-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1913-12-23/ch6/s23"},"text":"Dec. 23, 1913, ch. 6, § 23","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/242/tIII/s308/a"},"text":"Pub. L. 102–242, title III, § 308(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2362"},"text":"105 Stat. 2362","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb3a7c7c-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddb3a7c7d-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddb3a7c7e-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/tIII/s308/c"},"text":"Pub. L. 102–242, title III, § 308(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2363"},"text":"105 Stat. 2363","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/242/tIII/s308/c"},"text":"“The amendment made by this section [enacting this section] shall become effective 1 year after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddb3a7c7f-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/tIII/s308/b"},"text":"Pub. L. 102–242, title III, § 308(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2362"},"text":"105 Stat. 2362","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/242/tIII/s308/b"},"text":"“The Board shall prescribe reasonable transition rules to facilitate compliance with section 23 of the Federal Reserve Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s371b–2"},"text":"12 U.S.C. 371b–2","children":[],"tail":"] (as added by subsection (a)).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
