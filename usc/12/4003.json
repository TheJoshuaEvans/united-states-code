{"tag":"section","attrib":{"id":"iddd1508d5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4003"},"text":null,"children":[{"tag":"num","attrib":{"value":"4003"},"text":"§ 4003.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Safeguard exceptions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd1508d6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4003/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New accounts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4002"},"text":"section 4002 of this title","children":[],"tail":", in the case of any account established at a depository institution by a new depositor, the following provisions shall apply with respect to any deposit in such account during the 30-day period (or such shorter period as the Board, jointly with the Director of the Bureau of Consumer Financial Protection, may establish) beginning on the date such account is established—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd1508d7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4003/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Next business day availability of cash and certain items","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (3), in the case of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd1508d8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4003/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any cash deposited in such account;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd1508d9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4003/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any funds received by such depository institution by wire transfer for deposit in such account;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd1508da-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4003/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any funds deposited in such account by cashier’s check, certified check, teller’s check, depository check, or traveler’s check; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd1508db-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4003/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any funds deposited by a government check which is described in subparagraph (A), (B), or (C) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4002/a/2"},"text":"section 4002(a)(2) of this title","children":[],"tail":","}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"such cash or funds shall be available for withdrawal on the business day after the business day on which such cash or funds are deposited or, in the case of a wire transfer, on the business day after the business day on which such funds are received for deposit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1508dc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4003/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of other items","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any funds deposited in such account by a check (other than a check described in subparagraph (C) or (D) of paragraph (1)), the availability for withdrawal of such funds shall not be subject to the provisions of section 4002(b), 4002(c), or paragraphs ","children":[{"tag":"ref","attrib":{"idref":"fn002362"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002362"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “paragraph”."}],"tail":" (1) of "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4002/e"},"text":"section 4002(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1508dd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4003/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation relating to certain checks in excess of $5,000","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of funds deposited in such account during such period by checks described in subparagraph (C) or (D) of paragraph (1) the aggregate amount of which exceeds $5,000—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd1508de-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4003/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paragraph (1) shall apply only with respect to the first $5,000 of such aggregate amount; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd1508df-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4003/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than 8 business days shall intervene between the business day on which any such funds are deposited and the business day on which such excess amount shall be available for withdrawal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1508e0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4003/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Large or redeposited checks; repeated overdrafts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board, jointly with the Director of the Bureau of Consumer Financial Protection, may, by regulation, establish reasonable exceptions to any time limitation established under subsection (a)(2), (b), (c), or (e) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4002"},"text":"section 4002 of this title","children":[],"tail":" for—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd1508e1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4003/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of deposits by one or more checks that exceeds the amount of $5,000 in any one day;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1508e2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4003/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" checks that have been returned unpaid and redeposited; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1508e3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4003/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deposit accounts which have been overdrawn repeatedly.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1508e4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4003/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reasonable cause exception","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd1508e5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4003/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with regulations which the Board, jointly with the Director of the Bureau of Consumer Financial Protection, shall prescribe, subsections (a)(2), (b), (c), and (e) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4002"},"text":"section 4002 of this title","children":[],"tail":" shall not apply with respect to any check deposited in an account at a depository institution if the receiving depository institution has reasonable cause to believe that the check is uncollectible from the originating depository institution. For purposes of the preceding sentence, reasonable cause to believe requires the existence of facts which would cause a well-grounded belief in the mind of a reasonable person. Such reasons shall be included in the notice required under subsection (f)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1508e6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4003/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis for determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No determination under this subsection may be based on any class of checks or persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1508e7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4003/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Overdraft fees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the receiving depository institution determines that a check deposited in an account is a check described in paragraph (1), the receiving depository institution shall not assess any fee for any subsequent overdraft with respect to such account, if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd1508e8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4003/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the depositor was not provided with the written notice required under subsection (f) (with respect to such determination) at the time the deposit was made;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd1508e9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4003/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the overdraft would not have occurred but for the fact that the funds so deposited are not available; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd1508ea-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4003/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the check is collected from the originating depository institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1508eb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4003/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each agency referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4009/a"},"text":"section 4009(a) of this title","children":[],"tail":" shall monitor compliance with the requirements of this subsection in each regular examination of a depository institution and shall describe in each report to the Congress the extent to which this subsection is being complied with. For the purpose of this paragraph, each depository institution shall retain a record of each notice provided under subsection (f) as a result of the application of this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1508ec-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4003/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency conditions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to such regulations as the Board, jointly with the Director of the Bureau of Consumer Financial Protection, may prescribe, subsections (a)(2), (b), (c), and (e) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4002"},"text":"section 4002 of this title","children":[],"tail":" shall not apply to funds deposited by check in any receiving depository institution in the case of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd1508ed-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4003/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any interruption of communication facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1508ee-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4003/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suspension of payments by another depository institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1508ef-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4003/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any war; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1508f0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4003/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any emergency condition beyond the control of the receiving depository institution,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"if the receiving depository institution exercises such diligence as the circumstances require.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1508f1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4003/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prevention of fraud losses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd1508f2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4003/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board, jointly with the Director of the Bureau of Consumer Financial Protection, may, by regulation or order, suspend the applicability of this chapter, or any portion thereof, to any classification of checks if the Board, jointly with the Director of the Bureau of Consumer Financial Protection, determines that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd1508f3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4003/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" depository institutions are experiencing an unacceptable level of losses due to check-related fraud, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd1508f4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4003/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suspension of this chapter, or such portion of this chapter, with regard to the classification of checks involved in such fraud is necessary to diminish the volume of such fraud.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1508f5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4003/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sunset provision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No regulation prescribed or order issued under paragraph (1) shall remain in effect for more than 45 days (excluding Saturdays, Sundays, legal holidays, or any day either House of Congress is not in session).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1508f6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4003/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd1508f7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4003/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of each suspension","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within 10 days of prescribing any regulation or issuing any order under paragraph (1), the Board, jointly with the Director of the Bureau of Consumer Financial Protection, shall transmit a report of such action to the Committee on Banking, Finance and Urban Affairs of the House of Representatives and the Committee on Banking, Housing, and Urban Affairs of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd1508f8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4003/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report under subparagraph (A) shall contain—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd1508f9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4003/e/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the specific reason for prescribing the regulation or issuing the order;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd1508fa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4003/e/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evidence considered by the Board, jointly with the Director of the Bureau of Consumer Financial Protection, in making the determination under paragraph (1) with respect to such regulation or order; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd1508fb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4003/e/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specific examples of the check-related fraud giving rise to such regulation or order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1508fc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4003/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of exception; availability within reasonable time","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd1508fd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4003/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If any exception contained in this section (other than subsection (a)) applies with respect to funds deposited in an account at a depository institution—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd1508fe-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4003/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the depository institution shall provide notice in the manner provided in paragraph (2) of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd1508ff-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4003/f/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the time period within which the funds shall be made available for withdrawal; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd150900-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4003/f/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reason the exception was invoked; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd150901-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4003/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except where other time periods are specifically provided in this chapter, the availability of the funds deposited shall be governed by the policy of the receiving depository institution, but shall not exceed a reasonable period of time as determined by the Board, jointly with the Director of the Bureau of Consumer Financial Protection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd150902-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4003/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for notice","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The notice required under paragraph (1)(A) with respect to a deposit to which an exception contained in this section applies shall be made by the time provided in the following subparagraphs:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd150903-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4003/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a deposit made in person by the depositor at the receiving depository institution, the depository institution shall immediately provide such notice in writing to the depositor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd150904-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4003/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of any other deposit (other than a deposit described in subparagraph (C)), the receiving depository institution shall mail the notice to the depositor not later than the close of the next business day following the business day on which the deposit is received.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd150905-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4003/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a deposit to which subsection (d) or (e) applies, notice shall be provided by the depository institution in accordance with regulations of the Board, jointly with the Director of the Bureau of Consumer Financial Protection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd150906-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4003/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a deposit to which subsection (b)(1) or (b)(2) applies, the depository institution may, for nonconsumer accounts and other classes of accounts, as defined by the Board, that generally have a large number of such deposits, provide notice at or before the time it first determines that the subsection applies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd150907-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4003/f/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a deposit to which subsection (b)(3) applies, the depository institution may, subject to regulations of the Board, provide notice at the beginning of each time period it determines that the subsection applies. In addition to the requirements contained in paragraph (1)(A), the notice shall specify the time period for which the exception will apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd150908-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4003/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequent determinations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the facts upon which the determination of the applicability of an exception contained in subsection (b) or (c) to any deposit only become known to the receiving depository institution after the time notice is required under paragraph (2) with respect to such deposit, the depository institution shall mail such notice to the depositor as soon as practicable, but not later than the first business day following the day such facts become known to the depository institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd150909-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/86/tVI/s604"},"text":"Pub. L. 100–86, title VI, § 604","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-08-10"},"text":"Aug. 10, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/642"},"text":"101 Stat. 642","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/242/tII"},"text":"Pub. L. 102–242, title II","children":[],"tail":", §§ 225, 227(b)(2), "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2307"},"text":"105 Stat. 2307","children":[],"tail":", 2308; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1086/b"},"text":"Pub. L. 111–203, title X, § 1086(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2085"},"text":"124 Stat. 2085","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd15090a-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd15090b-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd15090c-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsecs. (a) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1086/b/1"},"text":"Pub. L. 111–203, § 1086(b)(1)","children":[],"tail":", inserted “, jointly with the Director of the Bureau of Consumer Financial Protection,” after “Board” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1)(B), (2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1086/b/2"},"text":"Pub. L. 111–203, § 1086(b)(2)","children":[],"tail":", substituted “Board, jointly with the Director of the Bureau of Consumer Financial Protection.” for “Board.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/s227/b/2"},"text":"Pub. L. 102–242, § 227(b)(2)","children":[],"tail":", struck out “and (2)” after “paragraphs (1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/s225/1"},"text":"Pub. L. 102–242, § 225(1)","children":[],"tail":", inserted “(a)(2),” after “subsection”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/s225/2"},"text":"Pub. L. 102–242, § 225(2)","children":[],"tail":", substituted “(a)(2)” for “(a)(2)(F)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/s225/3"},"text":"Pub. L. 102–242, § 225(3)","children":[],"tail":", inserted “(a)(2),” after “subsections”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/s225/4"},"text":"Pub. L. 102–242, § 225(4)","children":[],"tail":", substituted “time period within which” for “day”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2)(D), (E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/s225/5"},"text":"Pub. L. 102–242, § 225(5)","children":[],"tail":", added subpars. (D) and (E)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd15090d-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"iddd15090e-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Banking, Finance and Urban Affairs of House of Representatives treated as referring to Committee on Banking and Financial Services of House of Representatives by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/14/s1/a"},"text":"section 1(a) of Pub. L. 104–14","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s21"},"text":"section 21 of Title 2","children":[],"tail":", The Congress. Committee on Banking and Financial Services of House of Representatives abolished and replaced by Committee on Financial Services of House of Representatives, and jurisdiction over matters relating to securities and exchanges and insurance generally transferred from Committee on Energy and Commerce of House of Representatives by House Resolution No. 5, One Hundred Seventh Congress, "},{"tag":"date","attrib":{"date":"2001-01-03"},"text":"Jan. 3, 2001","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd15090f-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective on the designated transfer date, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1100H"},"text":"section 1100H of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd150910-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1988-09-01"},"text":"Sept. 1, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/86/s613/b"},"text":"section 613(b) of Pub. L. 100–86","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4001"},"text":"section 4001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
