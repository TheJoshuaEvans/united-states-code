a System institution, except stock that—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) may be retired by the holder thereof on repayment of the holder’s loan, or otherwise at the option or request of the holder; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) is protected under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2162"},"text":"section 2162 of this title","children":[],"tail":" or is otherwise not at risk.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s301/b"},"text":"Pub. L. 100–399, § 301(b)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2162"},"text":"section 2162 of this title","children":[],"tail":"” for “section 4.9B”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(D)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s301/c/1"},"text":"Pub. L. 100–399, § 301(c)(1)","children":[],"tail":", substituted “producers or” for “producers, or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s301/c/2"},"text":"Pub. L. 100–399, § 301(c)(2)","children":[],"tail":", substituted “voting stock issued” for “stock issued”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(H). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s301/d"},"text":"Pub. L. 100–399, § 301(d)","children":[],"tail":", inserted “, except as otherwise provided in this section” after “the borrower”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(I). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s301/e"},"text":"Pub. L. 100–399, § 301(e)","children":[],"tail":", struck out “standards issued under” after “established under”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s301/f"},"text":"Pub. L. 100–399, § 301(f)","children":[],"tail":", struck out “and in "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2162"},"text":"section 2162 of this title","children":[],"tail":"” after “paragraph (2)” and “or allocated equities” after “retirement of stock”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcc64cb5-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcc64cb6-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of Title 7","children":[],"tail":", Agriculture."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcc64cb7-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399"},"text":"Pub. L. 100