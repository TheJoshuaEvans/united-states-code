{"tag":"section","attrib":{"id":"iddcc64c83-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2154a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2154a"},"text":"§ 2154a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capitalization of System institutions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcc64c84-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2154a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcc64c85-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2154a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permanent capital","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “permanent capital” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcc64c86-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2154a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" current year retained earnings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcc64c87-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2154a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allocated and unallocated earnings (which, in the case of earnings allocated in any form by a System bank to any association or other recipient and retained by the bank, shall be considered, in whole or in part, permanent capital of the bank or of any such association or other recipient as provided under an agreement between the bank and each such association or other recipient);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcc64c88-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2154a/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all surplus (less allowances for losses);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcc64c89-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2154a/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" stock issued by a System institution, except—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddcc64c8a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2154a/a/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stock that may be retired by the holder of the stock on repayment of the holder’s loan, or otherwise at the option or request of the holder; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcc64c8b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2154a/a/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stock that is protected under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2162"},"text":"section 2162 of this title","children":[],"tail":" or is otherwise not at risk; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcc64c8c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2154a/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other debt or equity instruments or other accounts that the Farm Credit Administration determines appropriate to be considered permanent capital.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc64c8d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2154a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stock","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “stock” means voting and nonvoting stock (including preferred stock), equivalent contributions to a guaranty fund, participation certificates, allocated equities, and other forms and types of equities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcc64c8e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2154a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adoption of bylaws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to approval by shareholders under subsection (c)(2), each bank and association shall adopt bylaws, developed by its board of directors, that provide for the capitalization of the institution in accordance with subsection (c)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcc64c8f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2154a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements of bylaws","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcc64c90-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2154a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of this chapter, the bylaws adopted under subsection (b)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcc64c91-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2154a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall provide for such classes, par value, and amounts of the stock of the institution, the manner in which such stock shall be issued, transferred, and retired, and the payment of dividends and patronage refunds, as determined appropriate by the Board of Directors, subject to this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcc64c92-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2154a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may provide for the charging of loan origination fees as determined appropriate by the Board of Directors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcc64c93-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2154a/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall enable the institution to meet the capital adequacy standards established under the regulations issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2154/a"},"text":"section 2154(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcc64c94-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2154a/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall provide for the issuance of voting stock, which may only be held by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddcc64c95-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2154a/c/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" borrowers who are farmers, ranchers, or producers or harvesters of aquatic products, and cooperative associations eligible to borrow from System institutions under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcc64c96-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2154a/c/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" persons and entities eligible to borrow from the banks for cooperatives, as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2124/c/ii"},"text":"section 2124(c)(ii) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcc64c97-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2154a/c/1/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a Central Bank for Cooperatives, other banks for cooperatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcc64c98-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2154a/c/1/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of banks other than banks for cooperatives, System associations;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcc64c99-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2154a/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall require that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddcc64c9a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2154a/c/1/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a condition of borrowing from or through the institution, any borrower who is entitled to hold voting stock or participation certificates shall, at the time a loan is made, acquire voting stock or participation certificates in an amount not less than $1,000 or 2 percent of the amount of the loan, whichever is less; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcc64c9b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2154a/c/1/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within 2 years after the loan of a borrower is repaid in full, any voting stock held by the borrower be converted to nonvoting stock;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcc64c9c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2154a/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may provide that persons who are not borrowers from the institution may hold nonvoting stock of the institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcc64c9d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2154a/c/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall require that any holder of voting stock issued before the adoption of bylaws under this section exchange a portion of such stock for new voting stock;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcc64c9e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2154a/c/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" do not need to provide for maximum or minimum standards of borrower stock ownership based on a percentage of the loan of the borrower, except as otherwise provided in this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcc64c9f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2154a/c/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall permit the retirement of stock at the discretion of the institution if the institution meets the capital adequacy standards established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2154/a"},"text":"section 2154(a) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcc64ca0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2154a/c/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall permit stock to be transferable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc64ca1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2154a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The bylaws adopted by the board of directors of a System institution under subsection (b) shall take effect only on approval of a majority of the stockholders of such institution present and voting, or voting by written proxy, at a duly authorized stockholders’ meeting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcc64ca2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2154a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction of capital","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcc64ca3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2154a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), the board of directors of a System institution may not reduce the permanent capital of the institution through the payment of patronage refunds or dividends, or the retirement of stock if, after or due to such action, the permanent capital of the institution would thereafter fail to meet the minimum capital adequacy standards established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2154/a"},"text":"section 2154(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc64ca4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2154a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall not apply to the payment of noncash patronage refunds by any institution exempt from Federal income tax if the entire refund paid qualifies as permanent capital. Notwithstanding paragraph (1), any System institution subject to Federal income tax may pay patronage refunds partially in cash as long as the cash portion of the refund is the minimum amount required to qualify the refund as a deductible patronage distribution for Federal income tax purposes and the remaining portion of the refund paid qualifies as permanent capital.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcc64ca5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2154a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Farm Credit Administration may issue a directive that requires compliance with subsection (d), to the board of directors of any System institution that fails to comply therewith.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcc64ca6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2154a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loans designated for sale or sold into secondary market","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcc64ca7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2154a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2) and notwithstanding any other provision of this section, the bylaws adopted by a bank or association under subsection (b) may provide—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcc64ca8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2154a/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a loan made on or after ","children":[{"tag":"date","attrib":{"date":"1996-02-10"},"text":"February 10, 1996","children":[],"tail":", that is designated, at the time the loan is made, for sale into a secondary market, that no voting stock or participation certificate purchase requirement shall apply to the borrower for the loan; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcc64ca9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2154a/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a loan made before ","children":[{"tag":"date","attrib":{"date":"1996-02-10"},"text":"February 10, 1996","children":[],"tail":", that is sold into a secondary market, that all outstanding voting stock or participation certificates held by the borrower with respect to the loan shall, subject to subsection (d)(1), be retired."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc64caa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2154a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this section, in the case of a loan sold to a secondary market under subchapter VIII, paragraph (1) shall apply regardless of whether the bank or association retains a subordinated participation interest in a loan or pool of loans or contributes to a cash reserve.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc64cab-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2154a/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcc64cac-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2154a/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraph (B) and notwithstanding any other provision of this section, if a loan designated for sale under paragraph (1)(A) is not sold into a secondary market during the 180-day period that begins on the date of the designation, the voting stock or participation certificate purchase requirement that would otherwise apply to the loan in the absence of a bylaw provision described in paragraph (1)(A) shall be effective.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcc64cad-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2154a/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The bylaws adopted by a bank or association under subsection (b) may provide that if a loan described in subparagraph (A) is sold into a secondary market after the end of the 180-day period described in the subparagraph, all outstanding voting stock or participation certificates held by the borrower with respect to the loan shall, subject to subsection (d)(1), be retired.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcc64cae-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2154a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not be construed to affect the provisions of this chapter that confer on System institutions a lien on borrower stock or other equities and the privilege to retire or cancel such stock or other equities for application against the indebtedness on a defaulted or restructured loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcc64caf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2154a/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Controlling authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent that any provision of this section is inconsistent with any other provision of this chapter (other than ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2162"},"text":"section 2162 of this title","children":[],"tail":"), the provision of this section shall control."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcc64cb0-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tIV/s4"},"text":"Pub. L. 92–181, title IV, § 4","children":[],"tail":".3A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tIII/s301/b"},"text":"Pub. L. 100–233, title III, § 301(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1608"},"text":"101 Stat. 1608","children":[],"tail":"; amended "},{"tag":