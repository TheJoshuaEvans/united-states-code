{"tag":"section","attrib":{"id":"iddd2cd7c0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4611"},"text":null,"children":[{"tag":"num","attrib":{"value":"4611"},"text":"§ 4611.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Risk-based capital levels for regulated entities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd2cd7c1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4611/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2cd7c2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4611/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enterprises","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall, by regulation, establish risk-based capital requirements for the enterprises to ensure that the enterprises operate in a safe and sound manner, maintaining sufficient capital and reserves to support the risks that arise in the operations and management of the enterprises.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2cd7c3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4611/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Home Loan Banks","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall establish risk-based capital standards under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1426"},"text":"section 1426 of this title","children":[],"tail":" for the Federal Home Loan Banks."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2cd7c4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4611/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall limit the authority of the Director to require other reports or undertakings, or take other action, in furtherance of the responsibilities of the Director under this Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd2cd7c5-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXIII/s1361"},"text":"Pub. L. 102–550, title XIII, § 1361","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3972"},"text":"106 Stat. 3972","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tI/s1110/a"},"text":"Pub. L. 110–289, div. A, title I, § 1110(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2675"},"text":"122 Stat. 2675","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd2cd7c6-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd2cd7c7-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd2cd7c8-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550"},"text":"Pub. L. 102–550","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3672"},"text":"106 Stat. 3672","children":[],"tail":", known as the Housing and Community Development Act of 1992. For complete classification of this Act to the Code, see Short Title of 1992 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5301"},"text":"section 5301 of Title 42","children":[],"tail":", The Public Health and Welfare, and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd2cd7c9-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289"},"text":"Pub. L. 110–289","children":[],"tail":" amended section generally. Prior to amendment, section related to risk-based capital levels for enterprises."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
