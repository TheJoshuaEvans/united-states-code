{"tag":"section","attrib":{"id":"iddcb7f504-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1957"},"text":null,"children":[{"tag":"num","attrib":{"value":"1957"},"text":"§ 1957.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional criminal penalty in certain cases","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever willfully violates, or willfully causes a violation of any regulation under this chapter, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1829b"},"text":"section 1829b of this title","children":[],"tail":", or section 1730d "},{"tag":"ref","attrib":{"idref":"fn002296"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002296"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title, where the violation is committed in furtherance of the commission of any violation of Federal law punishable by imprisonment for more than one year, shall be fined not more than $10,000 or imprisoned not more than five years, or both."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddcb7f505-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/508/tI/s127"},"text":"Pub. L. 91–508, title I, § 127","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-26"},"text":"Oct. 26, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1118"},"text":"84 Stat. 1118","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXV/s1535/c/2"},"text":"Pub. L. 102–550, title XV, § 1535(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4067"},"text":"106 Stat. 4067","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"ty