{"tag":"section","attrib":{"id":"iddb92ae6c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1464a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1464a"},"text":"§ 1464a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election to operate as a covered savings association","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddb92ae6d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1464a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “covered savings association” means a Federal savings association that makes an election that is approved under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb92ae6e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1464a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb92ae6f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1464a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with the rules issued under subsection (f), a Federal savings association with total consolidated assets equal to or less than $20,000,000,000, as reported by the association to the Comptroller as of ","children":[{"tag":"date","attrib":{"date":"2017-12-31"},"text":"December 31, 2017","children":[],"tail":", may elect to operate as a covered savings association by submitting a notice to the Comptroller of that election."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb92ae70-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1464a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Federal savings association shall be deemed to be approved to operate as a covered savings association beginning on the date that is 60 days after the date on which the Comptroller receives the notice submitted under paragraph (1), unless the Comptroller notifies the Federal savings association that the Federal savings association is not eligible.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb92ae71-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1464a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights and duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, and except as otherwise provided in this section, a covered savings association shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb92ae72-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1464a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have the same rights and privileges as a national bank that has the main office of the national bank situated in the same location as the home office of the covered savings association; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb92ae73-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1464a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be subject to the same duties, restrictions, penalties, liabilities, conditions, and limitations that would apply to a national bank described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb92ae74-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1464a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of covered savings associations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A covered savings association shall be treated as a Federal savings association for the purposes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb92ae75-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1464a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of governance of the covered savings association, including incorporation, bylaws, boards of directors, shareholders, and distribution of dividends;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb92ae76-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1464a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of consolidation, merger, dissolution, conversion (including conversion to a stock bank or to another charter), conservatorship, and receivership; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb92ae77-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1464a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determined by regulation of the Comptroller.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb92ae78-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1464a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing branches","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A covered savings association may continue to operate any branch or agency that the covered savings association operated on the date on which an election under subsection (b) is approved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb92ae79-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1464a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule making","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Comptroller shall issue rules to carry out this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb92ae7a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1464a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that establish streamlined standards and procedures that clearly identify required documentation and timelines for an election under subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb92ae7b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1464a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that require a Federal savings association that makes an election under subsection (b) to identify specific assets and subsidiaries that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddb92ae7c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1464a/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" do not conform to the requirements for assets and subsidiaries of a national bank; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb92ae7d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1464a/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are held by the Federal savings association on the date on which the Federal savings association submits a notice of the election;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb92ae7e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1464a/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that establish—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddb92ae7f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1464a/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a transition process for bringing the assets and subsidiaries described in paragraph (2) into conformance with the requirements for a national bank; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb92ae80-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1464a/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures for allowing the Federal savings association to submit to the Comptroller an application to continue to hold assets and subsidiaries described in paragraph (2) after electing to operate as a covered savings association;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb92ae81-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1464a/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that establish standards and procedures to allow a covered savings association to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddb92ae82-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1464a/f/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" terminate an election under subsection (b) after an appropriate period of time; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb92ae83-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1464a/f/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make a subsequent election under subsection (b) after terminating an election under subparagraph (A);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb92ae84-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1464a/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that clarify requirements for the treatment of covered savings associations, including the provisions of law that apply to covered savings associations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb92ae85-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1464a/f/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as the Comptroller determines necessary in the interests of safety and soundness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb92ae86-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1464a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grandfathered covered savings associations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the rules issued under subsection (f), a covered savings association may continue to operate as a covered savings association if, after the date on which the election is made under subsection (b), the covered savings association has total consolidated assets greater than $20,000,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddb92ae87-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-06-13/ch64/s5A"},"text":"June 13, 1933, ch. 64, § 5A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/174/tII/s206"},"text":"Pub. L. 115–174, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-05-24"},"text":"May 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1310"},"text":"132 Stat. 1310","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
