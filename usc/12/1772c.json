{"tag":"section","attrib":{"id":"iddc433a02-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1772c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1772c"},"text":"§ 1772c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trust fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, all moneys of the Board shall be treated as trust funds for the purpose of section 906(a)(2) ","children":[{"tag":"ref","attrib":{"idref":"fn002211"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002211"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 2. This section is effective for fiscal year 1986 and every fiscal year thereafter."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc433a03-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-26/ch750"},"text":"June 26, 1934, ch. 750","children":[],"tail":", title I, § 129, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/86/tVII/s708"},"text":"Pub. L. 100–86, title VII, § 708","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-08-10"},"text":"Aug. 10, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/653"},"text":"101 Stat. 653","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc433a04-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc433a05-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddc433a06-3a6f-11f1-8fa0-c0657