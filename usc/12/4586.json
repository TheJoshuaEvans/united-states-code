{"tag":"section","attrib":{"id":"iddd2cd777-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4586"},"text":null,"children":[{"tag":"num","attrib":{"value":"4586"},"text":"§ 4586.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public disclosure of final orders and agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd2cd778-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4586/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall make available to the public—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2cd779-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4586/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any written agreement or other written statement for which a violation may be redressed by the Director or any modification to or termination thereof, unless the Director, in the Secretary’s ","children":[{"tag":"ref","attrib":{"idref":"fn002421"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002421"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Director’s”."}],"tail":" discretion, determines that public disclosure would be contrary to the public interest or determines under subsection (c) that public disclosure would seriously threaten the financial health or security of the enterprise;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2cd77a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4586/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any order that is issued with respect to any administrative enforcement proceeding initiated by the Director under this subpart and that has become final in accordance with sections 4582 and 4583 of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2cd77b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4586/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any modification to or termination of any final order made public pursuant to this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2cd77c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4586/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hearings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All hearings with respect to any notice of charges issued by the Director shall be open to the public, unless the Director, in the Secretary’s ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" discretion, determines that holding an open hearing would be contrary to the public interest."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2cd77d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4586/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delay of public disclosure under exceptional circumstances","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Director makes a determination in writing that the public disclosure of any final order pursuant to subsection (a) would seriously threaten the financial soundness of the enterprise, the Director may delay the public disclosure of such order for a reasonable time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2cd77e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4586/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Documents filed under seal in public enforcement hearings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may file any document or part thereof under seal in any hearing under this subpart if the Director determines in writing that disclosure thereof would be contrary to the public interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2cd77f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4586/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retention of documents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall keep and maintain a record, for not less than 6 years, of all documents described in subsection (a) and all enforcement agreements and other supervisory actions and supporting documents issued with respect to or in connection with any enforcement proceeding initiated by the Director under this subpart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2cd780-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4586/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosures to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section may not be construed to authorize the withholding, or to prohibit the disclosure, of any information to the Congress or any committee or subcommittee thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd2cd781-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXIII/s1346"},"text":"Pub. L. 102–550, title XIII, § 1346","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3968"},"text":"106 Stat. 3968","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tI/s1130/e/3/C"},"text":"Pub. L. 110–289, div. A, title I, § 1130(e)(3)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2711"},"text":"122 Stat. 2711","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd2cd782-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd2cd783-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd2cd784-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsecs. (a) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289"},"text":"Pub. L. 110–289","children":[],"tail":" substituted “Director” for “Secretary” wherever appearing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
