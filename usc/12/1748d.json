{"tag":"section","attrib":{"id":"iddc327113-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1748d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1748d"},"text":"§ 1748d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lease of property; terms and conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whenever the Secretary of the Army, Navy, or Air Force determines that it is necessary to lease any land held by the United States on or near a military installation to effectuate the purposes of this subchapter, he may lease such land upon such terms and conditions as will, in his opinion, best serve the national interest. The authority conferred by this section shall be in addition to and not in derogation of any other power or authority of the Secretary of the Army, Navy, or Air Force.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc327114-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-27/ch847"},"text":"June 27, 1934, ch. 847","children":[],"tail":", title VIII, § 805, as added "},{"tag":"ref","attrib":{"href":"/us/act/1949-08-08/ch403/s1"},"text":"Aug. 8, 1949, ch. 403, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/576"},"text":"63 Stat. 576","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/act/1955-08-11/ch783"},"text":"Aug. 11, 1955, ch. 783","children":[],"tail":", title IV, § 401, "},{"tag":"ref","attrib":{"href":"/us/stat/69/651"},"text":"69 Stat. 651","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc327115-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc327116-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc327117-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1955—Act ","children":[{"tag":"date","attrib":{"date":"1955-08-11"},"text":"Aug. 11, 1955","children":[],"tail":", struck out specific references to sections authorizing leases of property, and struck out the power to sell, transfer, and convey real property."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
