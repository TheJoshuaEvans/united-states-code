{"tag":"section","attrib":{"id":"iddd3fe9da-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4804"},"text":null,"children":[{"tag":"num","attrib":{"value":"4804"},"text":"§ 4804.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elimination of duplicative filings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Federal banking agencies shall work jointly—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd3fe9db-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4804/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to eliminate, to the extent practicable, duplicative or otherwise unnecessary requests for information in connection with applications or notices to the agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3fe9dc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4804/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to harmonize, to the extent practicable, any inconsistent publication and public notice requirements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd3fe9dd-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/tIII/s304"},"text":"Pub. L. 103–325, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2215"},"text":"108 Stat. 2215","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
