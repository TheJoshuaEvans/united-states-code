{"tag":"section","attrib":{"id":"iddb3106f9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s335"},"text":null,"children":[{"tag":"num","attrib":{"value":"335"},"text":"§ 335.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dealing in investment securities; limitations and conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"State member banks shall be subject to the same limitations and conditions with respect to the purchasing, selling, underwriting, and holding of investment securities and stock as are applicable in the case of national banks under paragraph “Seventh” of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s24"},"text":"section 24 of this title","children":[],"tail":". This section shall not apply to any interest held by a State member bank in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s24a"},"text":"section 24a of this title","children":[],"tail":" and subject to the same conditions and limitations provided in such section."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddb3106fa-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1913-12-23/ch6/s9"},"text":"Dec. 23, 1913, ch. 6, § 9","children":[],"tail":" (par.), as added "},{"tag":"ref","attrib":{"href":"/us/act/1933-06-16/ch89/s5/c"},"text":"June 16, 1933, ch. 89, § 5(c)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/165"},"text":"48 Stat. 165","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/102/tI/s121/d/2"},"text":"Pub. L. 106–102, title I, § 121(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1381"},"text":"113 Stat. 1381","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb3106fb-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb3106fc-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddb3106fd-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of the twentieth par. of section 9 of act ","children":[{"tag":"date","attrib":{"date":"1913-12-23"},"text":"Dec. 23, 1913","children":[],"tail":", as amended. The twentieth par. constituted the eighteenth par. of section 9 in 1933 ("},{"tag":"ref","attrib":{"href":"/us/stat/48/16"},"text":"48 Stat. 16","children":[],"tail":"), became the nineteenth par. in 1935 ("},{"tag":"ref","attrib":{"href":"/us/stat/49/704"},"text":"49 Stat. 704","children":[],"tail":"), and became the twentieth par. in 1950 ("},{"tag":"ref","attrib":{"href":"/us/stat/64/458"},"text":"64 Stat. 458","children":[],"tail":"). For further details, see Codification notes set out under sections 321 and 329a of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddb3106fe-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/102"},"text":"Pub. L. 106–102","children":[],"tail":" inserted at end “This section shall not apply to any interest held by a State member bank in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s24a"},"text":"section 24a of this title","children":[],"tail":" and subject to the same conditions and limitations provided in such section.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddb3106ff-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddb310700-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1999 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/102"},"text":"Pub. L. 106–102","children":[],"tail":" effective 120 days after "},{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/102/s161"},"text":"section 161 of Pub. L. 106–102","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s24"},"text":"section 24 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
