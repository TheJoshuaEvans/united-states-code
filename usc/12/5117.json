{"tag":"section","attrib":{"id":"iddd4716b8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5117"},"text":null,"children":[{"tag":"num","attrib":{"value":"5117"},"text":"§ 5117.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment transition of loan originators","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd4716b9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5117/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd4716ba-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5117/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “application State” means a State in which a registered loan originator or a State-licensed loan originator seeks to be licensed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4716bb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5117/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State-licensed mortgage company","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State-licensed mortgage company” means an entity that is licensed or registered under the law of any State to engage in residential mortgage loan origination and processing activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd4716bc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5117/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary authority to originate loans for loan originators moving from a depository institution to a non-depository institution","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd4716bd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5117/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon becoming employed by a State-licensed mortgage company, an individual who is a registered loan originator shall be deemed to have temporary authority to act as a loan originator in an application State for the period described in paragraph (2) if the individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd4716be-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5117/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has not had—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd4716bf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5117/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an application for a loan originator license denied; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd4716c0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5117/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a loan originator license revoked or suspended in any governmental jurisdiction;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd4716c1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5117/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has not been subject to, or served with, a cease and desist order—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd4716c2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5117/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any governmental jurisdiction; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd4716c3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5117/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5113/c"},"text":"section 5113(c) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd4716c4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5117/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not been convicted of a misdemeanor or felony that would preclude licensure under the law of the application State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd4716c5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5117/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has submitted an application to be a State-licensed loan originator in the application State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd4716c6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5117/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was registered in the Nationwide Mortgage Licensing System and Registry as a loan originator during the 1-year period preceding the date on which the information required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5104/a"},"text":"section 5104(a) of this title","children":[],"tail":" is submitted."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4716c7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5117/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The period described in this paragraph shall begin on the date on which an individual described in paragraph (1) submits the information required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5104/a"},"text":"section 5104(a) of this title","children":[],"tail":" and shall end on the earliest of the date—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd4716c8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5117/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on which the individual withdraws the application to be a State-licensed loan originator in the application State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd4716c9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5117/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on which the application State denies, or issues a notice of intent to deny, the application;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd4716ca-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5117/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on which the application State grants a State license; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd4716cb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5117/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is 120 days after the date on which the individual submits the application, if the application is listed on the Nationwide Mortgage Licensing System and Registry as incomplete.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd4716cc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5117/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary authority to originate loans for State-licensed loan originators moving interstate","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd4716cd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5117/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State-licensed loan originator shall be deemed to have temporary authority to act as a loan originator in an application State for the period described in paragraph (2) if the State-licensed loan originator—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd4716ce-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5117/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets the requirements of subparagraphs (A), (B), (C), and (D) of subsection (b)(1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd4716cf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5117/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is employed by a State-licensed mortgage company in the application State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd4716d0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5117/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was licensed in a State that is not the application State during the 30-day period preceding the date on which the information required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5104/a"},"text":"section 5104(a) of this title","children":[],"tail":" was submitted in connection with the application submitted to the application State."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4716d1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5117/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The period described in this paragraph shall begin on the date on which the State-licensed loan originator submits the information required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5104/a"},"text":"section 5104(a) of this title","children":[],"tail":" in connection with the application submitted to the application State and end on the earliest of the date—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd4985d2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5117/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on which the State-licensed loan originator withdraws the application to be a State-licensed loan originator in the application State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd4985d3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5117/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on which the application State denies, or issues a notice of intent to deny, the application;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd4985d4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5117/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on which the application State grants a State license; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd4985d5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5117/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is 120 days after the date on which the State-licensed loan originator submits the application, if the application is listed on the Nationwide Mortgage Licensing System and Registry as incomplete.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd4985d6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5117/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd4985d7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5117/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employer of loan originators","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person employing an individual who is deemed to have temporary authority to act as a loan originator in an application State under this section shall be subject to the requirements of this chapter and to applicable State law to the same extent as if that individual was a State-licensed loan originator licensed by the application State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4985d8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5117/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Engaging in mortgage loan activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any individual who is deemed to have temporary authority to act as a loan originator in an application State under this section and who engages in residential mortgage loan origination activities shall be subject to the requirements of this chapter and to applicable State law to the same extent as if that individual was a State-licensed loan originator licensed by the application State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd4985d9-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tV/s1518"},"text":"Pub. L. 110–289, div. A, title V, § 1518","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/174/tI/s106/a"},"text":"Pub. L. 115–174, title I, § 106(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-05-24"},"text":"May 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1302"},"text":"132 Stat. 1302","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd4985da-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd4985db-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd4985dc-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 18 months after ","children":[{"tag":"date","attrib":{"date":"2018-05-24"},"text":"May 24, 2018","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/174/s106/d"},"text":"section 106(d) of Pub. L. 115–174","children":[],"tail":", set out as an Effective Date of 2018 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5112"},"text":"section 5112 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
