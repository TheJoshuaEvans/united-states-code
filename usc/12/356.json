{"tag":"section","attrib":{"id":"iddb35c21e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s356"},"text":null,"children":[{"tag":"num","attrib":{"value":"356"},"text":"§ 356.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purchase of commercial paper from member banks and sale of same","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Every Federal reserve bank shall have power to purchase from member banks and to sell, with or without its indorsement, bills of exchange arising out of commercial transactions, as hereinbefore defined.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddb35c21f-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1913-12-23/ch6/s14/c"},"text":"Dec. 23, 1913, ch. 6, § 14(c)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/264"},"text":"38 Stat. 264","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb35c220-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb35c221-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddb35c222-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of subsec. (c) of section 14 of act ","children":[{"tag":"date","attrib":{"date":"1913-12-23"},"text":"Dec. 23, 1913","children":[],"tail":". For classification to this title of remainder of section 14, see Codification note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s353"},"text":"section 353 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
