{"tag":"section","attrib":{"id":"iddc268a9d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1735f"},"text":null,"children":[{"tag":"num","attrib":{"value":"1735f"},"text":"§ 1735f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Water and sewerage facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this chapter, no mortgage which covers new construction shall be approved for insurance under this chapter (except pursuant to a commitment made prior to ","children":[{"tag":"date","attrib":{"date":"1965-08-10"},"text":"August 10, 1965","children":[],"tail":") if the mortgaged property includes housing which is not served by a public or adequate community water and sewerage system: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That this limitation shall be applicable only to property which is not served by a system approved by the Secretary pursuant to subchapter IX–A of this chapter, as such subchapter existed immediately before "},{"tag":"date","attrib":{"date":"1989-12-15"},"text":"December 15, 1989","children":[],"tail":", and which is situated in an area certified by appropriate local officials to be an area where the establishment of public or adequate community water and sewerage systems is economically feasible: "},{"tag":"i","attrib":{},"text":"Provided further","children":[],"tail":", That for purposes of this section the economic feasibility of establishing such public or adequate community water and sewerage systems shall be determined without regard to whether such establishment is authorized by law or is subject to approval by one or more local governments or public bodies."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc268a9e-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-27/ch847"},"text":"June 27, 1934, ch. 847","children":[],"tail":", title V, § 522, as added "},{"tag":"ref","attrib":{"href":"/us/pl/89/117/tII/s217/a"},"text":"Pub. L. 89–117, title II, § 217(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-08-10"},"text":"Aug. 10, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/473"},"text":"79 Stat. 473","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/90/19/s1/a/3"},"text":"Pub. L. 90–19, § 1(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-05-25"},"text":"May 25, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/17"},"text":"81 Stat. 17","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/235/tI/s133/d/4"},"text":"Pub. L. 101–235, title I, § 133(d)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-15"},"text":"Dec. 15, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2027"},"text":"103 Stat. 2027","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc268a9f-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc268aa0-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddc268aa1-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subchapter IX–A of this chapter, referred to in text, was repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/235/tI/s133/a"},"text":"Pub. L. 101–235, title I, § 133(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-15"},"text":"Dec. 15, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2027"},"text":"103 Stat. 2027","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc268aa2-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/235"},"text":"Pub. L. 101–235","children":[],"tail":" inserted “, as such subchapter existed immediately before "},{"tag":"date","attrib":{"date":"1989-12-15"},"text":"December 15, 1989","children":[],"tail":",” after “subchapter IX–A of this chapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1967—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/19"},"text":"Pub. L. 90–19","children":[],"tail":" substituted “Secretary” for “Commissioner”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
