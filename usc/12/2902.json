{"tag":"section","attrib":{"id":"iddcf8590b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2902"},"text":null,"children":[{"tag":"num","attrib":{"value":"2902"},"text":"§ 2902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purposes of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcf8590c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2902/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “appropriate Federal financial supervisory agency” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcf8590d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2902/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Comptroller of the Currency with respect to national banks and Federal savings associations (the deposits of which are insured by the Federal Deposit Insurance Corporation);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcf8590e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2902/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Board of Governors of the Federal Reserve System with respect to State chartered banks which are members of the Federal Reserve System, bank holding companies, and savings and loan holding companies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcf8590f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2902/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Deposit Insurance Corporation with respect to State chartered banks and savings banks which are not members of the Federal Reserve System and the deposits of which are insured by the Corporation, and State savings associations (the deposits of which are insured by the Federal Deposit Insurance Corporation).","children":[{"tag":"ref","attrib":{"idref":"fn002322"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002322"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The period probably should be a semicolon."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf85910-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2902/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “regulated financial institution” means an insured depository institution (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"section 1813 of this title","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf85911-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2902/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “application for a deposit facility” means an application to the appropriate Federal financial supervisory agency otherwise required under Federal law or regulations thereunder for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcf85912-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2902/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a charter for a national bank or Federal savings and loan association;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcf85913-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2902/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deposit insurance in connection with a newly chartered State bank, savings bank, savings and loan association or similar institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcf85914-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2902/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment of a domestic branch or other facility with the ability to accept deposits of a regulated financial institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcf85915-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2902/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relocation of the home office or a branch office of a regulated financial institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcf85916-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2902/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the merger or consolidation with, or the acquisition of the assets, or the assumption of the liabilities of a regulated financial institution requiring approval under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1828/c"},"text":"section 1828(c) of this title","children":[],"tail":" or under regulations issued under the authority of title IV "},{"tag":"ref","attrib":{"idref":"fn002323"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002323"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":" of the National Housing Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1724"},"text":"12 U.S.C. 1724","children":[],"tail":" et seq.]; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcf85917-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2902/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the acquisition of shares in, or the assets of, a regulated financial institution requiring approval under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1842"},"text":"section 1842 of this title","children":[],"tail":" or section 408(e) "},{"tag":"sup","attrib":{},"text":"2","children":[],"tail":" of the National Housing Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1730a/e"},"text":"12 U.S.C. 1730a(e)","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf85918-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2902/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A financial institution whose business predominately consists of serving the needs of military personnel who are not located within a defined geographic area may define its “entire community” to include its entire deposit customer base without regard to geographic proximity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcf85919-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/128/tVIII/s803"},"text":"Pub. L. 95–128, title VIII, § 803","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-10-12"},"text":"Oct. 12, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1147"},"text":"91 Stat. 1147","childre