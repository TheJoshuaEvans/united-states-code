{"tag":"section","attrib":{"id":"iddd06b14c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3345"},"text":null,"children":[{"tag":"num","attrib":{"value":"3345"},"text":"§ 3345.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification and licensing requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd06b14d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3345/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this chapter, the term “State certified real estate appraiser” means any individual who has satisfied the requirements for State certification in a State or territory whose criteria for certification as a real estate appraiser currently meets the minimum criteria for certification issued by the Appraiser Qualification Board of the Appraisal Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd06b14e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3345/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No individual shall be a State certified real estate appraiser under this section unless such individual has achieved a passing grade upon a suitable examination administered by a State or territory that is consistent with and equivalent to the Uniform State Certification Examination issued or endorsed by the Appraiser Qualification Board of the Appraisal Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd06b14f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3345/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “State licensed appraiser” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As used in this section, the term “State licensed appraiser” means an individual who has satisfied the requirements for State licensing in a State or territory whose criteria for the licensing of a real estate appraiser currently meet or exceed the minimum criteria issued by the Appraisal Qualifications Board of The Appraisal Foundation for the licensing of real estate appraisers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd06b150-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3345/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional qualification criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed to prevent any Federal agency or instrumentality under this chapter from establishing such additional qualification criteria as may be necessary or appropriate to carry out the statutory responsibilities of such department, agency, or instrumentality.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd06b151-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3345/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum qualification requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any requirements established for individuals in the position of “Trainee Appraiser” and “Supervisory Appraiser” shall meet or exceed the minimum qualification requirements of the Appraiser Qualifications Board of The Appraisal Foundation. The Appraisal Subcommittee shall have the authority to enforce these requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd06b152-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/tXI/s1116"},"text":"Pub. L. 101–73, title XI, § 1116","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/515"},"text":"103 Stat. 515","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/233/tVII/s701/a"},"text":"Pub. L. 102–233, title VII, § 701(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-12"},"text":"Dec. 12, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1792"},"text":"105 Stat. 1792","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/242/tIV/s472/a"},"text":"Pub. L. 102–242, title IV, § 472(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2386"},"text":"105 Stat. 2386","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXVI/s1617/a"},"text":"Pub. L. 102–550, title XVI, § 1617(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4096"},"text":"106 Stat. 4096","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tXIV/s1473/j"},"text":"Pub. L. 111–203, title XIV, § 1473(j)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2195"},"text":"124 Stat. 2195","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd06b153-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd06b154-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd06b155-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1473/j/1"},"text":"Pub. L. 111–203, § 1473(j)(1)","children":[],"tail":", inserted “whose criteria for the licensing of a real estate appraiser currently meet or exceed the minimum criteria issued by the Appraisal Qualifications Board of The Appraisal Foundation for the licensing of real estate appraisers” before the period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1473/j/2"},"text":"Pub. L. 111–203, § 1473(j)(2)","children":[],"tail":", added subsec. (e) and struck out former subsec. (e). Prior to amendment, text read as follows: “The Appraisal Subcommittee shall not set qualifications or experience requirements for the States in licensing real estate appraisers, including a de minimus standard. Recommendations of the Subcommittee shall be nonbinding on the States.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/s1617/a"},"text":"Pub. L. 102–550, § 1617(a)","children":[],"tail":", repealed "},{"tag":"ref","attrib":{"href":"/us/pl/102/233/s701/a"},"text":"Pub. L. 102–233, § 701(a)","children":[],"tail":". See 1991 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242"},"text":"Pub. L. 102–242","children":[],"tail":" added subsec. (e) prohibiting Appraisal Subcommittee from setting qualifications or experience requirements, including a de minimis standard."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/233/s701/a"},"text":"Pub. L. 102–233, § 701(a)","children":[],"tail":", which added subsec. (e) prohibiting Appraisal Subcommittee from setting qualifications or experience requirements, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/s1617/a"},"text":"Pub. L. 102–550, § 1617(a)","children":[],"tail":". See Construction of 1991 Amendment note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd06b156-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd06b157-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective on the date on which final regulations implementing that amendment take effect, or on the date that is 18 months after the designated transfer date if such regulations have not been issued by that date, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1400/c"},"text":"section 1400(c) of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1601"},"text":"section 1601 of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd06b158-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction of 1991 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXVI/s1617/b"},"text":"Pub. L. 102–550, title XVI, § 1617(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4096"},"text":"106 Stat. 4096","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/550/tXVI/s1617/b"},"text":"“No amendments made by title VII of the Resolution Trust Corporation Refinancing, Restructuring, and Improvement Act of 1991 [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s3348"},"text":"section 3348 of this title","children":[],"tail":"] shall be deemed to have taken effect before the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":"] and the provisions of law amended by title VII shall continue in effect as if no such amendments had been made by such title.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
