{"tag":"section","attrib":{"id":"iddd2f47de-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4613"},"text":null,"children":[{"tag":"num","attrib":{"value":"4613"},"text":"§ 4613.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Critical capital levels","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd2f47df-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4613/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enterprises","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter, the critical capital level for each enterprise shall be the sum of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2f47e0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4613/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1.25 percent of the aggregate on-balance sheet assets of the enterprise, as determined in accordance with generally accepted accounting principles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2f47e1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4613/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 0.25 percent of the unpaid principal balance of outstanding mortgage-backed securities and substantially equivalent instruments issued or guaranteed by the enterprise that are not included in paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2f47e2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4613/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 0.25 percent of other off-balance sheet obligations of the enterprise not included in paragraph (2) (excluding commitments in excess of 50 percent of the average dollar amount of the commitments outstanding each quarter over the preceding 4 quarters), except that the Director shall adjust such percentage to reflect differences in the credit risk of such obligations in relation to the instruments included in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2f47e3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4613/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Home Loan Banks","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2f47e4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4613/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subchapter, the critical capital level for each Federal Home Loan Bank shall be such amount of capital as the Director shall, by regulation, require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2f47e5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4613/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration of other critical capital levels","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In establishing the critical capital level under paragraph (1) for the Federal Home Loan Banks, the Director shall take due consideration of the critical capital level established under subsection (a) for the enterprises, with such modifications as the Director determines to be appropriate to reflect the difference in operations between the banks and the enterprises.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd2f47e6-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXIII/s1363"},"text":"Pub. L. 102–550, title XIII, § 1363","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3976"},"text":"106 Stat. 3976","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tI/s1141/a"},"text":"Pub. L. 110–289, div. A, title I, § 1141(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2730"},"text":"122 Stat. 2730","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd2f47e7-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd2f47e8-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd2f47e9-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289"},"text":"Pub. L. 110–289","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd2f47ea-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd2f47eb-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tI/s1141/b"},"text":"Pub. L. 110–289, div. A, title I, § 1141(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2730"},"text":"122 Stat. 2730","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/289/dA/tI/s1141/b"},"text":"“Not later than the expiration of the 180-day period beginning on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":"], the Director of the Federal Housing Finance Agency shall issue regulations pursuant to section 1363(b) of the Federal Housing Enterprises Financial Safety and Soundness Act of 1992 ["},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4613/b"},"text":"12 U.S.C. 4613(b)","children":[],"tail":"] (as added by this section) establishing the critical capital level under such section.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
