{"tag":"section","attrib":{"id":"iddce7b7ab-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–14"},"text":null,"children":[{"tag":"num","attrib":{"value":"2277a–14"},"text":"§ 2277a–14.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddce7b7ac-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–14/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corporate name","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce7b7ad-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–14/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of corporate name","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall be unlawful for any person or entity to use the words “Farm Credit System Insurance Corporation” or any combination of such words that would have the effect of leading the public to believe that there is any connection between such person or entity and the Corporation, by virtue of the name under which such person or entity does business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce7b7ae-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–14/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" False representation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddce7b7af-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–14/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" By outside person or entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall be unlawful for any person or entity to falsely represent by any device, that the notes, bonds, debentures, or other obligations of the person or entity are insured or in any way guaranteed by the Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce7b7b0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–14/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" System banks","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall be unlawful for any insured System bank or person that markets insured obligations to falsely represent the extent to which or the manner in which such obligations are insured by the Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce7b7b1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–14/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person or entity that willfully violates any provision of this subsection shall be fined not more than $1,000, imprisoned for not more than 1 year, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce7b7b2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–14/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments or distributions while in default","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce7b7b3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–14/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall be unlawful for any insured System bank to pay any dividends on bank stock or participation certificates or interest on the capital notes or debentures of such bank (if such interest is required to be paid only out of net profits) or distribute any of the capital assets of such bank while the bank remains in default in the payment of any premium due to the Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce7b7b4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–14/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability of directors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each director or officer of any insured System bank who willfully participates in the declaration or payment of any dividend or interest or in any distribution in violation of this subsection shall be fined not more than $1,000, imprisoned not more than 1 year, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce7b7b5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–14/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subsection shall not apply to any default that is due to a dispute between the insured System bank and the Corporation over the amount of such premium if such bank deposits security satisfactory to the Corporation for payment on final determination of the issue.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce7b7b6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–14/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to file statement or pay premium","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce7b7b7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–14/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any insured System bank that willfully fails or refuses to file any certified statement or pay any premium required under this part shall be subject to a penalty of not more than $100 for each day that such violations continue, which penalty the Corporation may recover for its use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce7b7b8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–14/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subsection shall not apply to conduct with respect to any default that is due to a dispute between the insured System bank and the Corporation over the amount of such premium if such bank deposits security satisfactory to the Corporation for payment on final determination of the issue.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce7b7b9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–14/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment of persons convicted of criminal offenses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce7b7ba-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–14/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except with the prior written consent of the Farm Credit Administration, it shall be unlawful for any person convicted of any criminal offense involving dishonesty or a breach of trust to serve as a director, officer, or employee of any System institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce7b7bb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–14/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each willful violation of paragraph (1), the institution involved shall be subject to a penalty of not more than $100 for each day during which the violation continues, which the Corporation may recover for its use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce7b7bc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–14/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on uses of funds related to Federal Agricultural Mortgage Corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No funds from administrative accounts or from the Farm Credit System Insurance Fund may be used by the Corporation to provide assistance to the Federal Agricultural Mortgage Corporation or to support any activities related to the Federal Agricultural Mortgage Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddce7b7bd-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tV/s5"},"text":"Pub. L. 92–181, title V, § 5","children":[],"tail":".65, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tIII/s302"},"text":"Pub. L. 100–233, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1619"},"text":"101 Stat. 1619","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXVIII/s1837"},"text":"Pub. L. 101–624, title XVIII, § 1837","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3834"},"text":"104 Stat. 3834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tV/s502/k"},"text":"Pub. L. 102–237, title V, § 502(k)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1869"},"text":"105 Stat. 1869","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tV/s5409"},"text":"Pub. L. 115–334, title V, § 5409","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4678"},"text":"132 Stat. 4678","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddce7b7be-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddce7b7bf-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddce7b7c0-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237"},"text":"Pub. L. 102–237","children":[],"tail":" struck out “insured” before “System”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/s1837/1"},"text":"Pub. L. 101–624, § 1837(1)","children":[],"tail":", substituted “insured System institution” for “insured System bank”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/s1837/2"},"text":"Pub. L. 101–624, § 1837(2)","children":[],"tail":", substituted “institution” for “bank”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
