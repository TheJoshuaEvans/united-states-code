{"tag":"section","attrib":{"id":"iddc458413-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1772e"},"text":null,"children":[{"tag":"num","attrib":{"value":"1772e"},"text":"§ 1772e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data standards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc458414-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1772e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall, by rule, adopt data standards for all collections of information and reports regularly filed with or submitted to the Administration under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc458415-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1772e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consistency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The data standards required under subsection (a) shall incorporate, and ensure compatibility with (to the extent feasible), all applicable data standards established in the rules promulgated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5334"},"text":"section 5334 of this title","children":[],"tail":", including, to the extent practicable, by having the characteristics described in clauses (i) through (vi) of subsection (c)(1)(B) of such section 5334."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc458416-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-26/ch750"},"text":"June 26, 1934, ch. 750","children":[],"tail":", title I, § 132, as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLVIII/s5871"},"text":"Pub. L. 117–263, div. E, title LVIII, § 5871","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3436"},"text":"136 Stat. 3436","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc458417-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc458418-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddc458419-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rulemaking","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLVIII/s5873"},"text":"Pub. L. 117–263, div. E, title LVIII, § 5873","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3436"},"text":"136 Stat. 3436","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dE/tLVIII/s5873"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The National Credit Union Administration Board shall issue rules to carry out the amendments made by this subtitle [subtitle G (§§ 5871–5874) of title LVIII of div. E of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":", enacting this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1772f"},"text":"section 1772f of this title","children":[],"tail":"], which shall take effect not later than 2 years after the date on which final rules are promulgated under section 124(b)(2) of the Financial Stability Act of 2010 ["},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5334/b/2"},"text":"12 U.S.C. 5334(b)(2)","children":[],"tail":"], as added by "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5811/a"},"text":"section 5811(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Scaling of Regulatory Requirements; Minimizing Disruption","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In issuing the rules required under subsection (a), the National Credit Union Administration Board—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may scale data reporting requirements in order to reduce any unjustified burden on smaller regulated entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall seek to minimize disruptive changes to the persons affected by those regulations.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddc45841a-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rule of Construction Regarding No New Disclosure Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLVIII/s5874"},"text":"Pub. L. 117–263, div. E, title LVIII, § 5874","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3437"},"text":"136 Stat. 3437","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dE/tLVIII/s5874"},"text":"“Nothing in this subtitle [subtitle G (§§ 5871–5874) of title LVIII of div. E of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":", enacting this section, "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1772f"},"text":"section 1772f of this title","children":[],"tail":", and provisions set out as a note under this section], or the amendments made by this subtitle, shall be construed to require the National Credit Union Administration Board to collect or make publicly available additional information under the Federal Credit Union Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1751"},"text":"12 U.S.C. 1751","children":[],"tail":" et seq.), beyond information that was collected or made publicly available under that Act, as of the day before the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
