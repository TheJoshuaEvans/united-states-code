{"tag":"section","attrib":{"id":"iddc9440ca-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831g"},"text":null,"children":[{"tag":"num","attrib":{"value":"1831g"},"text":"§ 1831g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts between depository institutions and persons providing goods, products, or services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc9440cb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An insured depository institution may not enter into a written or oral contract with any person to provide goods, products, or services to or for the benefit of such depository institution if the performance of such contract would adversely affect the safety or soundness of the institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc9440cc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rulemaking","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation shall prescribe such regulations and issue such orders, including definitions consistent with this section, as may be necessary to administer and carry out the purposes of, and prevent evasions of, this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc9440cd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831g/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any action taken by any appropriate Federal banking agency under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1818"},"text":"section 1818 of this title","children":[],"tail":" to enforce compliance on the part of any insured depository institution with the requirements of this section may include a requirement that such institution properly reflect the transaction on its books and records."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc9440ce-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831g/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No private right of action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section may not be construed as creating any private right of action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc9440cf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831g/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc9440d0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831g/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General and the Comptroller General of the United States shall jointly conduct a study on the extent to which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc9440d1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831g/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" insured depository institutions are entering into contracts with vendors under which the vendors agree to purchase stock or assets from insured depository institutions or to invest capital in or make deposits in such institutions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9440d2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831g/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if such practices occur, the extent to which such practices are having an anticompetitive effect and should be prohibited.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc9440d3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831g/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before the end of the 1-year period beginning on ","children":[{"tag":"date","attrib":{"date":"1989-08-09"},"text":"August 9, 1989","children":[],"tail":", the Attorney General and the Comptroller General shall submit a report to the Congress on the results of the study conducted pursuant to paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc9440d4-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-21/ch967/s2"},"text":"Sept. 21, 1950, ch. 967, § 2","children":[],"tail":"[30], as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/73/tII/s225"},"text":"Pub. L. 101–73, title II, § 225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/275"},"text":"103 Stat. 275","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/325/tVI/s602/a/59"},"text":"Pub. L. 103–325, title VI, § 602(a)(59)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2291"},"text":"108 Stat. 2291","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc9440d5-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc9440d6-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc9440d7-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (e)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325"},"text":"Pub. L. 103–325","children":[],"tail":" substituted “the vendors” for “venders”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
