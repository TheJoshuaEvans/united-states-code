{"tag":"section","attrib":{"id":"iddd660fda-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5433"},"text":null,"children":[{"tag":"num","attrib":{"value":"5433"},"text":"§ 5433.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Property transferred","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd660fdb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5433/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Property defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “property” includes all real property (including leaseholds) and all personal property, including computers, furniture, fixtures, equipment, books, accounts, records, reports, files, memoranda, paper, reports of examination, work papers, and correspondence related to such reports, and any other information or materials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd660fdc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5433/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Property of the Office of Thrift Supervision","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd660fdd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5433/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No later than 90 days after the transfer date, all property of the Office of Thrift Supervision (other than property described under paragraph (b)(2)) that the Comptroller of the Currency and the Chairperson of the Corporation jointly determine is used, on the day before the transfer date, to perform or support the functions of the Office of Thrift Supervision transferred to the Office of the Comptroller of the Currency or the Corporation under this title,","children":[{"tag":"ref","attrib":{"idref":"fn002491"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002491"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" shall be transferred to the Office of the Comptroller of the Currency or the Corporation in a manner consistent with the transfer of employees under this part."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd660fde-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5433/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personal property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All books, accounts, records, reports, files, memoranda, papers, documents, reports of examination, work papers, and correspondence of the Office of Thrift Supervision that the Comptroller of the Currency, the Chairperson of the Corporation, and the Chairman of the Board of Governors jointly determine is used, on the day before the transfer date, to perform or support the functions of the Office of Thrift Supervision transferred to the Board of Governors under this title ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" shall be transferred to the Board of Governors in a manner consistent with the purposes of this title."},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd660fdf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5433/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts related to property transferred","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each contract, agreement, lease, license, permit, and similar arrangement relating to property transferred to the Office of the Comptroller of the Currency or the Corporation by this section shall be transferred to the Office of the Comptroller of the Currency or the Corporation, as appropriate, together with the property to which it relates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd660fe0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5433/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preservation of property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Property identified for transfer under this section shall not be altered, destroyed, or deleted before transfer under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd660fe1-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tIII/s323"},"text":"Pub. L. 111–203, title III, § 323","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1535"},"text":"124 Stat. 1535","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd660fe2-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd660fe3-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd660fe4-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This title, referred to in subsec. (b), is title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1520"},"text":"124 Stat. 1520","children":[],"tail":", known as the Enhancing Financial Institution Safety and Soundness Act of 2010, which enacted this subchapter and sections 4b and 16 of this title, amended sections 1, 11, 248, 461, 481, 482, 1438, 1462, 1462a, 1463, to 1464, 1466a, 1467, 1467a, 1468, 1468a, to 1468b, 1470, 1701c, 1701p–1, 1708, 1757, 1785, 1786, 1787, 1812, 1813, 1817, 1818, 1820, 1821, 1823, 1828, 1829, 1831e, 1831j, 1833b, 1833e, 1834, 1841, 1843, 1844, 1861, 1867, 1881, 1882, 1884, 1972, 2709, 2902, 2905, 3206 to 3208, 3332, 4515, and 4517 of this title, "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s906"},"text":"section 906 of Title 2","children":[],"tail":", The Congress, sections 78c, 78"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":", 78"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"–5, and 78w of Title 15, Commerce and Trade, sections 212, 657, 981, 982, 1006, 1014, and 1032 of Title 18, Crimes and Criminal Procedure, sections 321 and 714 of Title 31, Money and Finance, "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s41501"},"text":"section 41501 of Title 34","children":[],"tail":", Crime Control and Law Enforcement, sections 4003 and 8105 of Title 42, The Public Health and Welfare, and "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s3502"},"text":"section 3502 of Title 44","children":[],"tail":", Public Printing and Documents, repealed "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1441a"},"text":"section 1441a of this title","children":[],"tail":", enacted provisions set out as notes under sections 1, 16, 1438, 1787, 1812, 1817, and 1821 of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s906"},"text":"section 906 of Title 2","children":[],"tail":", and amended provisions set out as notes under sections 1437, 1463, 1464, 1467a, 1707, 1812, and 1818 of this title. For complete classification of title III to the Code, see Short title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd660fe5-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd660fe6-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 1 day after ","children":[{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s4"},"text":"section 4 of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"section 5301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
