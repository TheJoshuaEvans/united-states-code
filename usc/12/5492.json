{"tag":"section","attrib":{"id":"iddd6d3b2f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5492"},"text":null,"children":[{"tag":"num","attrib":{"value":"5492"},"text":"§ 5492.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Executive and administrative powers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd6d3b30-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5492/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers of the Bureau","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Bureau is authorized to establish the general policies of the Bureau with respect to all executive and administrative functions, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd6d3b31-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5492/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment of rules for conducting the general business of the Bureau, in a manner not inconsistent with this title; ","children":[{"tag":"ref","attrib":{"idref":"fn002507"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002507"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd6d3b32-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5492/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to bind the Bureau and enter into contracts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd6d3b33-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5492/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" directing the establishment and maintenance of divisions or other offices within the Bureau, in order to carry out the responsibilities under the Federal consumer financial laws, and to satisfy the requirements of other applicable law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd6d3b34-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5492/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to coordinate and oversee the operation of all administrative, enforcement, and research activities of the Bureau;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd6d3b35-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5492/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to adopt and use a seal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd6d3b36-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5492/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to determine the character of and the necessity for the obligations and expenditures of the Bureau;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd6d3b37-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5492/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appointment and supervision of personnel employed by the Bureau;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd6d3b38-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5492/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the distribution of business among personnel appointed and supervised by the Director and among administrative units of the Bureau;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd6d3b39-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5492/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use and expenditure of funds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd6d3b3a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5492/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implementing the Federal consumer financial laws through rules, orders, guidance, interpretations, statements of policy, examinations, and enforcement actions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd6d3b3b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5492/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performing such other functions as may be authorized or required by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd6d3b3c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5492/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delegation of authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Bureau may delegate to any duly authorized employee, representative, or agent any power vested in the Bureau by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd6d3b3d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5492/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Autonomy of the Bureau","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd6d3b3e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5492/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with the Board of Governors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law applicable to the supervision or examination of persons with respect to Federal consumer financial laws, the Board of Governors may delegate to the Bureau the authorities to examine persons subject to the jurisdiction of the Board of Governors for compliance with the Federal consumer financial laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd6d3b3f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5492/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Autonomy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding the authorities granted to the Board of Governors under the Federal Reserve Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s221"},"text":"12 U.S.C. 221","children":[],"tail":" et seq.], the Board of Governors may not—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd6d3b40-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5492/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intervene in any matter or proceeding before the Director, including examinations or enforcement actions, unless otherwise specifically provided by law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd6d3b41-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5492/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appoint, direct, or remove any officer or employee of the Bureau; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd6d3b42-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5492/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" merge or consolidate the Bureau, or any of the functions or responsibilities of the Bureau, with any division or office of the Board of Governors or the Federal reserve banks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd6d3b43-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5492/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and orders","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No rule or order of the Bureau shall be subject to approval or review by the Board of Governors. The Board of Governors may not delay or prevent the issuance of any rule or order of the Bureau.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd6d3b44-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5492/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendations and testimony","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No officer or agency of the United States shall have any authority to require the Director or any other officer of the Bureau to submit legislative recommendations, or testimony or comments on legislation, to any officer or agency of the United States for approval, comments, or review prior to the submission of such recommendations, testimony, or comments to the Congress, if such recommendations, testimony, or comments to the Congress include a statement indicating that the views expressed therein are those of the Director or such officer, and do not necessarily reflect the views of the Board of Governors or the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd6d3b45-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5492/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clarification of autonomy of the Bureau in legal proceedings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Bureau shall not be liable under any provision of law for any action or inaction of the Board of Governors, and the Board of Governors shall not be liable under any provision of law for any action or inaction of the Bureau.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd6d3b46-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1012"},"text":"Pub. L. 111–203, title X, § 1012","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1965"},"text":"124 Stat. 1965","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd6d3b47-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd6d3b48-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd6d3b49-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This title, referred to in subsec. (a)(1), is title X of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1955"},"text":"124 Stat. 1955","children":[],"tail":", known as the Consumer Financial Protection Act of 2010, which enacted this subchapter and enacted, amended, and repealed numerous other sections and notes in the Code. For complete classification of title X to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Federal Reserve Act, referred to in subsec. (c)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1913-12-23/ch6"},"text":"act Dec. 23, 1913, ch. 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/251"},"text":"38 Stat. 251","children":[],"tail":", which is classified principally to chapter 3 (§ 221 et seq.) of this title. For complete classification of this Act to the Code, see References in Text note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s226"},"text":"section 226 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
