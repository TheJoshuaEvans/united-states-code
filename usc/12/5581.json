{"tag":"section","attrib":{"id":"iddd76d8cf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5581"},"text":null,"children":[{"tag":"num","attrib":{"value":"5581"},"text":"§ 5581.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of consumer financial protection functions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd76d8d0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5581/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Defined terms","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this part—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd76d8d1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5581/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “consumer financial protection functions” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd76d8d2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5581/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all authority to prescribe rules or issue orders or guidelines pursuant to any Federal consumer financial law, including performing appropriate functions to promulgate and review such rules, orders, and guidelines; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd76d8d3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5581/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the examination authority described in subsection (c)(1), with respect to a person described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5515/a"},"text":"section 5515(a) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd76d8d4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5581/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the terms “transferor agency” and “transferor agencies” mean, respectively—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd76d8d5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5581/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Board of Governors (and any Federal reserve bank, as the context requires), the Federal Deposit Insurance Corporation, the Federal Trade Commission, the National Credit Union Administration, the Office of the Comptroller of the Currency, the Office of Thrift Supervision, and the Department of Housing and Urban Development, and the heads of those agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd76d8d6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5581/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agencies listed in subparagraph (A), collectively.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd76d8d7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5581/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (c), consumer financial protection functions are transferred as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd76d8d8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5581/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board of Governors","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd76d8d9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5581/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of functions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All consumer financial protection functions of the Board of Governors are transferred to the Bureau.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd76d8da-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5581/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board of Governors authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Bureau shall have all powers and duties that were vested in the Board of Governors, relating to consumer financial protection functions, on the day before the designated transfer date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd76d8db-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5581/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comptroller of the Currency","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd76d8dc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5581/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of functions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All consumer financial protection functions of the Comptroller of the Currency are transferred to the Bureau.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd76d8dd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5581/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comptroller authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Bureau shall have all powers and duties that were vested in the Comptroller of the Currency, relating to consumer financial protection functions, on the day before the designated transfer date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd76d8de-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5581/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director of the Office of Thrift Supervision","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd76d8df-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5581/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of functions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All consumer financial protection functions of the Director of the Office of Thrift Supervision are transferred to the Bureau.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd76d8e0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5581/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Bureau shall have all powers and duties that were vested in the Director of the Office of Thrift Supervision, relating to consumer financial protection functions, on the day before the designated transfer date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd76d8e1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5581/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Deposit Insurance Corporation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd76d8e2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5581/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of functions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All consumer financial protection functions of the Federal Deposit Insurance Corporation are transferred to the Bureau.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd76d8e3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5581/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corporation authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Bureau shall have all powers and duties that were vested in the Federal Deposit Insurance Corporation, relating to consumer financial protection functions, on the day before the designated transfer date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7921d4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5581/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Trade Commission","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd7921d5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5581/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of functions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority of the Federal Trade Commission under an enumerated consumer law to prescribe rules, issue guidelines, or conduct a study or issue a report mandated under such law shall be transferred to the Bureau on the designated transfer date. Nothing in this title ","children":[{"tag":"ref","attrib":{"idref":"fn002527"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002527"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" shall be construed to require a mandatory transfer of any employee of the Federal Trade Commission."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7921d6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5581/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bureau authority","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd7921d7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5581/b/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Bureau shall have all powers and duties under the enumerated consumer laws to prescribe rules, issue guidelines, or to conduct studies or issue reports mandated by such laws, that were vested in the Federal Trade Commission on the day before the designated transfer date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd7921d8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5581/b/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Trade Commission Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to part B, the Bureau may enforce a rule prescribed under the Federal Trade Commission Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s41"},"text":"15 U.S.C. 41","children":[],"tail":" et seq.] by the Federal Trade Commission with respect to an unfair or deceptive act or practice to the extent that such rule applies to a covered person or service provider with respect to the offering or provision of a consumer financial product or service as if it were a rule prescribed under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5531"},"text":"section 5531 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7921d9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5581/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of the Federal Trade Commission","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd7921da-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5581/b/5/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No provision of this title ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" shall be construed as modifying, limiting, or otherwise affecting the authority of the Federal Trade Commission (including its authority with respect to affiliates described in "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5515/a/1"},"text":"section 5515(a)(1) of this title","children":[],"tail":") under the Federal Trade Commission Act or any other law, other than the authority under an enumerated consumer law to prescribe rules, issue official guidelines, or conduct a study or issue a report mandated under such law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd7921db-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5581/b/5/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission authority relating to rules prescribed by the Bureau","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to part B, the Federal Trade Commission shall have authority to enforce under the Federal Trade Commission Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s41"},"text":"15 U.S.C. 41","children":[],"tail":" et seq.) a rule prescribed by the Bureau under this title "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" with respect to a covered person subject to the jurisdiction of the Federal Trade Commission under that Act, and a violation of such a rule by such a person shall be treated as a violation of a rule issued under section 18 of that Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s57a"},"text":"15 U.S.C. 57a","children":[],"tail":") with respect to unfair or deceptive acts or practices."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7921dc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5581/b/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To avoid duplication of or conflict between rules prescribed by the Bureau under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5531"},"text":"section 5531 of this title","children":[],"tail":" and the Federal Trade Commission under section 18(a)(1)(B) of the Federal Trade Commission Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s57a/a/1/B"},"text":"15 U.S.C. 57a(a)(1)(B)","children":[],"tail":"] that apply to a covered person or service provider with respect to the offering or provision of consumer financial products or services, the agencies shall negotiate an agreement with respect to rulemaking by each agency, including consultation with the other agency prior to proposing a rule and during the comment period."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7921dd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5581/b/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deference","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No provision of this title ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" shall be construed as altering, limiting, expanding, or otherwise affecting the deference that a court affords to the—"}],"tail":null},{"tag":"clause","attrib":{"id":"iddd7921de-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5581/b/5/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal Trade Commission in making determinations regarding the meaning or interpretation of any provision of the Federal Trade Commission Act, or of any other Federal law for which the Commission has authority to prescribe rules; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd7921df-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5581/b/5/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Bureau in making determinations regarding the meaning or interpretation of any provision of a Federal consumer financial law (other than any law described in clause (i)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7921e0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5581/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Credit Union Administration","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd7921e1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5581/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of functions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All consumer financial protection functions of the National Credit Union Administration are transferred to the Bureau.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7921e2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5581/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Credit Union Administration authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Bureau shall have all powers and duties that were vested in the National Credit Union Administration, relating to consumer financial protection functions, on the day before the designated transfer date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7921e3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5581/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Housing and Urban Development","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd7921e4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5581/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of functions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All consumer protection functions of the Secretary of the Department of Housing and Urban Development relating to the Real Estate Settlement Procedures Act of 1974 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2601"},"text":"12 U.S.C. 2601","children":[],"tail":" et seq.), the Secure and Fair Enforcement for Mortgage Licensing Act of 2008 ("},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5102"},"text":"12 U.S.C. 5102","children":[],"tail":" [5101] et seq.), and the Interstate Land Sales Full Disclosure Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1701"},"text":"15 U.S.C. 1701","children":[],"tail":" et seq.) are transferred to the Bureau."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7921e5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5581/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of the Department of Housing and Urban Development","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Bureau shall have all powers and duties that were vested in the Secretary of the Department of Housing and Urban Development relating to the Real Estate Settlement Procedures Act of 1974 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2601"},"text":"12 U.S.C. 2601","children":[],"tail":" et seq.), the Secure and Fair Enforcement for Mortgage Licensing Act of 2008 ("},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5101"},"text":"12 U.S.C. 5101","children":[],"tail":" et seq.), and the Interstate Land Sales Full Disclosure Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1701"},"text":"15 U.S.C. 1701","children":[],"tail":" et seq.), on the day before the designated transfer date."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd7921e6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5581/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorities of the prudential regulators","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd7921e7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5581/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Examination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A transferor agency that is a prudential regulator shall have—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd7921e8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5581/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authority to require reports from and conduct examinations for compliance with Federal consumer financial laws with respect to a person described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5515/a"},"text":"section 5515(a) of this title","children":[],"tail":", that is incidental to the backup and enforcement procedures provided to the regulator under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5515/c"},"text":"section 5515(c) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7921e9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5581/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exclusive authority (relative to the Bureau) to require reports from and conduct examinations for compliance with Federal consumer financial laws with respect to a person described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5516/a"},"text":"section 5516(a) of this title","children":[],"tail":", except as provided to the Bureau under subsections (b) and (c) of "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5516"},"text":"section 5516 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7921ea-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5581/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd7921eb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5581/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority of a transferor agency that is a prudential regulator to enforce compliance with Federal consumer financial laws with respect to a person described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5515/a"},"text":"section 5515(a) of this title","children":[],"tail":", shall be limited to the backup and enforcement procedures in "},{"tag":"ref","attrib":{"idref":"fn002528"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002528"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. The word “in” probably should not appear."}],"tail":" described in "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5515/c"},"text":"section 5515(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7921ec-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5581/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusive authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A transferor agency that is a prudential regulator shall have exclusive authority (relative to the Bureau) to enforce compliance with Federal consumer financial laws with respect to a person described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5516/a"},"text":"section 5516(a) of this title","children":[],"tail":", except as provided to the Bureau under subsections (b) and (c) of "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5516"},"text":"section 5516 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7921ed-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5581/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statutory enforcement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of carrying out the authorities under, and subject to the limitations of, part B, each prudential regulator may enforce compliance with the requirements imposed under this title,","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" and any rule or order prescribed by the Bureau under this title,"},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" under—"}],"tail":null},{"tag":"clause","attrib":{"id":"iddd7921ee-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5581/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Credit Union Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1751"},"text":"12 U.S.C. 1751","children":[],"tail":" et seq.), by the National Credit Union Administration Board with respect to any covered person or service provider that is an insured credit union, or service provider thereto, or any affiliate of an insured credit union, who is subject to the jurisdiction of the Board under that Act; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd7921ef-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5581/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1818"},"text":"section 1818 of this title","children":[],"tail":", by the appropriate Federal banking agency, as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813/q"},"text":"section 1813(q) of this title","children":[],"tail":", with respect to a covered person or service provider that is a person described in "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813/q"},"text":"section 1813(q) of this title","children":[],"tail":" and who is subject to the jurisdiction of that agency, as set forth in sections 1813(q) and 1818 of this title; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd7921f0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5581/c/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Bank Service Company Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1861"},"text":"12 U.S.C. 1861","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd7921f1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5581/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsections (b) and (c) shall become effective on the designated transfer date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd7921f2-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1061"},"text":"Pub. L. 111–203, title X, § 1061","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2035"},"text":"124 Stat. 2035","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd7921f3-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd7921f4-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag"