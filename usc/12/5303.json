{"tag":"section","attrib":{"id":"iddd50b356-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5303"},"text":null,"children":[{"tag":"num","attrib":{"value":"5303"},"text":"§ 5303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Antitrust savings clause","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this Act, or any amendment made by this Act, shall be construed to modify, impair, or supersede the operation of any of the antitrust laws, unless otherwise specified. For purposes of this section, the term “antitrust laws” has the same meaning as in subsection (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s12"},"text":"section 12 of title 15","children":[],"tail":", except that such term includes "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s45"},"text":"section 45 of title 15","children":[],"tail":", to the extent that such section 45 applies to unfair methods of competition."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd50b357-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s6"},"text":"Pub. L. 111–203, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1390"},"text":"124 Stat. 1390","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd50b358-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd50b359-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd50b35a-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"head