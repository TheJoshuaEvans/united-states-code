{"tag":"section","attrib":{"id":"iddcfd3b8b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3051"},"text":null,"children":[{"tag":"num","attrib":{"value":"3051"},"text":"§ 3051.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonprofit corporation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcfd3b8c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3051/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Self-Help Development and Technical Assistance abolished; transfer of assets, etc.","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcfd3b8d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3051/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon the incorporation of the nonprofit corporation described in subsection (b), the Office of Self-Help Development and Technical Assistance is hereby abolished.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcfd3b8e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3051/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcfd3b8f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3051/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the nonprofit corporation described in subsection (b) agrees to accept the liabilities of the Office, the Bank, notwithstanding any other provision of law, shall transfer all assets, liabilities, and property of the Office to such nonprofit corporation on the day on which such nonprofit corporation is incorporated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcfd3b90-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3051/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such assets shall include all sums which are appropriated to the Office by the Congress and all sums which are contained in the Account established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s3042"},"text":"section 3042 of this title","children":[],"tail":". If any such sums are appropriated after the date on which the transfer described in subparagraph (A) occurs, the Bank shall promptly transfer such sums to such nonprofit corporation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcfd3b91-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3051/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment; Board of Directors; functions, etc.","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcfd3b92-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3051/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As soon as possible after ","children":[{"tag":"date","attrib":{"date":"1981-08-13"},"text":"August 13, 1981","children":[],"tail":", the Board shall establish a nonprofit corporation under the laws of the District of Columbia and, notwithstanding the laws of the District of Columbia, name the directors of such nonprofit corporation."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcfd3b93-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3051/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding the laws of the District of Columbia, the Board of Directors of such nonprofit corporation shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcfd3b94-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3051/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" select an executive director who shall be responsible for the administration of such nonprofit corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcfd3b95-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3051/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set the compensation of such executive director and the other employees of such nonprofit corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcfd3b96-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3051/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promulgate and publish the policies of such nonprofit corporation and make such policies available at all times to eligible cooperatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcfd3b97-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3051/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform the functions specified in subparagraphs (A) and (C) of paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcfd3b98-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3051/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Such nonprofit corporation shall only perform—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcfd3b99-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3051/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the functions which are authorized to be performed pursuant to sections 3043 through 3048 of this title and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s3050"},"text":"section 3050 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcfd3b9a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3051/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such functions as are necessary to comply with the laws under which it was incorporated in the District of Columbia; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcfd3b9b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3051/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such functions as are necessary to remain qualified as an organization described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/3"},"text":"section 501(c)(3) of title 26","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcfd3b9c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3051/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding any other provision of law—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcfd3b9d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3051/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Bank may provide administrative or staff support to such nonprofit corporation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcfd3b9e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3051/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any member of the Board of Directors of the Bank may serve as a member of the Board of Directors of such nonprofit corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcfd3b9f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3051/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment for tax purposes","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcfd3ba0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3051/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of law, such nonprofit corporation shall be deemed to be, and treated as, qualified as an organization described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/3"},"text":"section 501(c)(3) of title 26","children":[],"tail":" from the date on which such nonprofit corporation is established under the laws of the District of Columbia until the date on which the Internal Revenue Service makes a final determination on the application which such nonprofit corporation will submit to the Internal Revenue Service seeking status as an organization qualifying under such section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcfd3ba1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3051/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When performed by such nonprofit corporation, the functions described in subsection (b)(3)(A) shall be deemed to be performed for “charitable purposes” within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/3"},"text":"section 501(c)(3) of title 26","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcfd3ba2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3051/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contributions from the Bank","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcfd3ba3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3051/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Board of Directors of the Bank may make contributions to the nonprofit corporation in such amounts as the Board of Directors of the Bank deems appropriate, except that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcfd3ba4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3051/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such contributions may be made only out of the Bank’s earnings, determined in accordance with generally accepted accounting principles; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcfd3ba5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3051/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Bank shall set aside amounts sufficient to satisfy its obligations to the Secretary of the Treasury for payments of principal and interest on class A notes and other debt before making any contributions to such nonprofit corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcfd3ba6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3051/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" During any period in which the nonprofit corporation described in subsection (b) is qualified as an organization described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/3"},"text":"section 501(c)(3) of title 26","children":[],"tail":", contributions made by the Bank pursuant to paragraph (1) shall be treated as charitable contributions within the meaning of "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s170/c/2"},"text":"section 170(c)(2) of title 26","children":[],"tail":", and may be deducted notwithstanding the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s170/b/2"},"text":"section 170(b)(2) of title 26","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcfd3ba7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3051/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" During any period in which the nonprofit corporation described in subsection (b) is qualified as an organization described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/3"},"text":"section 501(c)(3) of title 26","children":[],"tail":", contributions to such nonprofit corporation by any person shall qualify as charitable contributions, as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s170/c"},"text":"section 170(c) of title 26","children":[],"tail":", for purposes of the charitable contribution deduction provided for in "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s170/a"},"text":"section 170(a) of title 26","children":[],"tail":", and shall also qualify for the deductions for estate and gift tax purposes provided for in sections 2055 and 2522 of title 26."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcfd3ba8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3051/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conflict of interest rules","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding the laws of the District of Columbia, the Board of Directors of such nonprofit corporation shall adopt and publish its own conflict of interest rules which shall be no less stringent in effect than the conflict of interest provisions adopted by the Board of Directors of the Bank pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s3024"},"text":"section 3024 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcfd3ba9-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/351/tII/s211"},"text":"Pub. L. 95–351, title II, § 211","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tIII/s395/a"},"text":"Pub. L. 97–35, title III, § 395(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/437"},"text":"95 Stat. 437","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcfd3baa-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcfd3bab-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcfd3bac-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—Subsecs. (b)(3)(C), (c), (d)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" substituted “Internal Revenue Code of 1986” for “Internal Revenue Code of 1954” wherever appearing, which for purposes of codification was translated as “title 26” thus requiring no change in text."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
