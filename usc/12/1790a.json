{"tag":"section","attrib":{"id":"iddc589692-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1790a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1790a"},"text":"§ 1790a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board disapproval of directors, committee members, and senior executive officers of insured credit unions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc589693-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1790a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prior notice required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An insured credit union shall notify the Board of the proposed addition of any individual to the board of directors or committee or the employment of any individual as a senior executive officer of such credit union at least 30 days before such addition or employment becomes effective, if the insured credit union—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc589694-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1790a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been chartered less than 2 years; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc589695-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1790a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in troubled condition, as determined on the basis of such credit union’s most recent report of condition or report of examination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc589696-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1790a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disapproval by Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An insured credit union may not add any individual to the board of directors or employ any individual as a senior executive officer if the Board issues a notice of disapproval of such addition or employment before the end of the 30-day period beginning on the date the agency receives notice of the proposed action pursuant to subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc589697-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1790a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception in extraordinary circumstances","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc589698-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1790a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board may prescribe by regulation conditions under which the prior notice requirement of subsection (a) may be waived in the event of extraordinary circumstances.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc589699-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1790a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No effect on disapproval authority of Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such waivers shall not affect the authority of the Board to issue notices of disapproval of such additions or employment of such individuals within 30 days after each such waiver.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc58969a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1790a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any notice submitted to the Board by any insured credit union pursuant to subsection (a) shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc58969b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1790a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1817/j/6/A"},"text":"section 1817(j)(6)(A) of this title","children":[],"tail":" about the individual; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc58969c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1790a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Board may prescribe by regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc58969d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1790a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standard for disapproval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall issue a notice of disapproval with respect to a notice submitted pursuant to subsection (a) if the competence, experience, character, or integrity of the individual with respect to whom such notice is submitted indicates that it would not be in the best interests of the depositors of the insured credit union or in the best interests of the public to permit the individual to be employed by, or associated with, such insured credit union.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc58969e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1790a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall prescribe by regulation a definition for the terms “troubled condition” and “senior executive officer” for purposes of subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc58969f-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-26/ch750"},"text":"June 26, 1934, ch. 750","children":[],"tail":", title II, § 212, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/73/tIX/s914/b"},"text":"Pub. L. 101–73, title IX, § 914(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/485"},"text":"103 Stat. 485","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc5896a0-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc5896a1-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddc5896a2-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/s914/b"},"text":"Section 914(b) of Pub. L. 101–73","children":[],"tail":", which directed that this section be added to title II of “the Federal Credit Union Insurance Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1781"},"text":"12 U.S.C. 1781","children":[],"tail":" et seq.)” was executed by adding this section to the Federal Credit Union Act, which comprises this chapter, as the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
