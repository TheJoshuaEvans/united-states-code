{"tag":"section","attrib":{"id":"iddc3e577f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1756"},"text":null,"children":[{"tag":"num","attrib":{"value":"1756"},"text":"§ 1756.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports and examinations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Federal credit unions shall be under the supervision of the Board, and shall make financial reports to it as and when it may require, but at least annually. Each Federal credit union shall be subject to examination by, and for this purpose shall make its books and records accessible to, any person designated by the Board.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc3e5780-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-26/ch750"},"text":"June 26, 1934, ch. 750","children":[],"tail":", title I, § 106, formerly § 6, "},{"tag":"ref","attrib":{"href":"/us/stat/48/1218"},"text":"48 Stat. 1218","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1937-12-06/ch3/s1"},"text":"Dec. 6, 1937, ch. 3, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/51/4"},"text":"51 Stat. 4","children":[],"tail":"; 1947 Reorg. Plan No. 1, § 401, eff. "},{"tag":"date","attrib":{"date":"1947-07-01"},"text":"July 1, 1947","children":[],"tail":", 12 F.R. 4534, "},{"tag":"ref","attrib":{"href":"/us/stat/61/952"},"text":"61 Stat. 952","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1948-06-29/ch711"},"text":"June 29, 1948, ch. 711","children":[],"tail":", §§ 1, 2, "},{"tag":"ref","attrib":{"href":"/us/stat/62/1091"},"text":"62 Stat. 1091","children":[],"tail":"; renumbered § 7 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/86/354/s1"},"text":"Pub. L. 86–354, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-09-22"},"text":"Sept. 22, 1959","children":[