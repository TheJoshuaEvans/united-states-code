{"tag":"section","attrib":{"id":"iddd5c99fc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5386"},"text":null,"children":[{"tag":"num","attrib":{"value":"5386"},"text":"§ 5386.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory terms and conditions for all orderly liquidation actions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In taking action under this subchapter, the Corporation shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd5c99fd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5386/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine that such action is necessary for purposes of the financial stability of the United States, and not for the purpose of preserving the covered financial company;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd5c99fe-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5386/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the shareholders of a covered financial company do not receive payment until after all other claims and the Fund are fully paid;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd5c99ff-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5386/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that unsecured creditors bear losses in accordance with the priority of claim provisions in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5390"},"text":"section 5390 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd5c9a00-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5386/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that management responsible for the failed condition of the covered financial company is removed (if such management has not already been removed at the time at which the Corporation is appointed receiver);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd5c9a01-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5386/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the members of the board of directors (or body performing similar functions) responsible for the failed condition of the covered financial company are removed, if such members have not already been removed at the time the Corporation is appointed as receiver; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd5c9a02-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5386/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not take an equity interest in or become a shareholder of any covered financial company or any covered subsidiary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd5c9a03-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tII/s206"},"text":"Pub. L. 111–203, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1459"},"text":"124 Stat. 1459","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd5c9a04-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd5c9a05-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd5c9a06-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in text, was in the original “this title”, meaning title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1442"},"text":"124 Stat. 1442","children":[],"tail":", which is classified principally to this subchapter. For complete classification of title II to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd5c9a07-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd5c9a08-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 1 day after ","children":[{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s4"},"text":"section 4 of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"section 5301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
