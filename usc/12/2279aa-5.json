{"tag":"section","attrib":{"id":"iddcea284d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"2279aa–5"},"text":"§ 2279aa–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification of agricultural mortgage marketing facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcea284e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–5/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility standards","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcea284f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–5/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within 120 days after the date on which the permanent board first meets with a quorum present, the Corporation shall issue standards for the certification of agricultural mortgage marketing facilities (other than the Corporation), including eligibility standards in accordance with paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcea2850-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–5/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to be certified under the standards referred to in paragraph (1), an agricultural mortgage marketing facility (other than the Corporation) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcea2851-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–5/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be an institution of the Farm Credit System or a corporation, association, or trust organized under the laws of the United States or of any State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcea2852-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–5/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet or exceed capital standards established by the Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcea2853-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–5/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have as one of the purposes of the facility, the sale or resale of securities representing interests in, or obligations backed by, pools of qualified loans that have been provided guarantees by the Corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcea2854-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–5/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate managerial ability with respect to agricultural mortgage loan underwriting, servicing, and marketing that is acceptable to the Corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcea2855-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–5/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adopt appropriate agricultural mortgage loan underwriting, appraisal, and servicing standards and procedures that meet or exceed the standards established by the Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcea2856-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–5/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for purposes of enabling the Corporation to examine the facility, agree to allow officers or employees of the Corporation to have access to all books, accounts, financial records, reports, files, and all other papers, things, or property, of any type whatsoever, belonging to or used by the Corporation that are necessary to facilitate an examination of the operations of the facility in connection with securities, and the pools of qualified loans that back securities, for which the Corporation has provided guarantees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcea2857-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–5/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adopt appropriate minimum standards and procedures relating to loan administration and disclosure to borrowers concerning the terms and rights applicable to loans for which guarantee is provided, in conformity with uniform standards established by the Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcea2858-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–5/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nondiscrimination requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The standards established under this subsection shall not discriminate between or against Farm Credit System and non-Farm Credit System applicants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcea2859-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–5/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification by Corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within 60 days after receiving an application for certification under this section, the Corporation shall certify the facility if the facility meets the standards established by the Corporation under subsection (a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcea285a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–5/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum time period for certification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any certification by the Corporation of an agricultural mortgage marketing facility shall be effective for a period determined by the Corporation of not to exceed 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcea285b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–5/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revocation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcea285c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–5/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After notice and an opportunity for a hearing, the Corporation may revoke the certification of an agricultural mortgage marketing facility if the Corporation determines that the facility no longer meets the standards referred to in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcea285d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–5/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of revocation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Revocation of a certification shall not affect any pool guarantee that has been issued by the Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcea285e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–5/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Affiliation of FCS institutions with facility","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcea285f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–5/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of affiliate authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this chapter, any Farm Credit System institution, acting for such institution alone or in conjunction with one or more other such institutions, may establish and operate, as an affiliate, an agricultural mortgage marketing facility if, within a reasonable time after such establishment, such facility obtains and thereafter retains certification under subsection (b) as a certified facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcea2860-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–5/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusive agency agreement authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any number of Farm Credit System institutions (other than the Corporation) may enter into an agreement with any certified facility (including an affiliate established under paragraph (1)) to sell the qualified loans of such institutions exclusively to or through the facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcea2861-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tVIII/s8"},"text":"Pub. L. 92–181, title VIII, § 8","children":[],"tail":".5, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tVII/s702"},"text":"Pub. L. 100–233, title VII, § 702","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1694"},"text":"101 Stat. 1694","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/105/tI/s106"},"text":"Pub. L. 104–105, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/164"},"text":"110 Stat. 164","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcea2862-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcea2863-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcea2864-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/105/s106/1/A"},"text":"Pub. L. 104–105, § 106(1)(A)","children":[],"tail":", inserted “(other than the Corporation)” after “facilities”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/105/s106/1/B"},"text":"Pub. L. 104–105, § 106(1)(B)","children":[],"tail":", inserted “(other than the Corporation)” after “facility” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/105/s106/2"},"text":"Pub. L. 104–105, § 106(2)","children":[],"tail":", struck out “(other than the Corporation)” after “System institution”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
