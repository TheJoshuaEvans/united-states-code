{"tag":"section","attrib":{"id":"iddc244065-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1734"},"text":null,"children":[{"tag":"num","attrib":{"value":"1734"},"text":"§ 1734.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendment, extension, or increase of commitment amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"At any time prior to final endorsement for insurance, the Secretary, in his discretion, may amend, extend, or increase the amount of any commitment, provided the mortgage, as finally endorsed for insurance is eligible for insurance under the provisions of this chapter and the rules and regulations thereunder, in effect at the time the original commitment to insure was issued.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc244066-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-27/ch847"},"text":"June 27, 1934, ch. 847","children":[],"tail":", title V, § 515 as added "},{"tag":"ref","attrib":{"href":"/us/act/1949-10-25/ch729/s3"},"text":"Oct. 25, 1949, ch. 729, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/906"},"text":"63 Stat. 906","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/90/19/s1/a/3"},"text":"Pub. L. 90–19, § 1(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-05-25"},"text":"May 25, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/17"},"text":"81 Stat. 17","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/479/tII/s204/a/20"},"text":"Pub. L. 98–479, title II, § 204(a)(20)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-17"},"text":"Oct. 17, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2232"},"text":"98 Stat. 2232","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc244067-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc244068-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc244069-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/479"},"text":"Pub. L. 98–479","children":[],"tail":" struck out “; mortgage conditions” after “amounts” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1967—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/19"},"text":"Pub. L. 90–19","children":[],"tail":" substituted “Secretary” for “Commissioner”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
