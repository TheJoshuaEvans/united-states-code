{"tag":"section","attrib":{"id":"iddcd2337b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2274"},"text":null,"children":[{"tag":"num","attrib":{"value":"2274"},"text":"§ 2274.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Power to remove directors and officers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this chapter, a Farm Credit Bank board, officer, or employee shall not remove any director or officer of any association.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddcd2337c-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tV/s5"},"text":"Pub. L. 92–181, title V, § 5","children":[],"tail":".38, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tIV/s432/c"},"text":"Pub. L. 100–233, title IV, § 432(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1661"},"text":"101 Stat. 1661","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tV/s5411/35"},"text":"Pub. L. 115–334, title V, § 5411(35)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4683"},"text":"132 Stat. 4683","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcd2337d-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcd2337e-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcd2337f-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" substituted “a Farm Credit Bank board, officer, or employee shall not remove any director or officer of any” for “a farm credit district board, bank board, or bank officer or employee shall not remove any director or officer of any production credit association or Federal land bank”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
