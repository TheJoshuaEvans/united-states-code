{"tag":"section","attrib":{"id":"iddd660fe7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5434"},"text":null,"children":[{"tag":"num","attrib":{"value":"5434"},"text":"§ 5434.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funds transferred","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The funds that, on the day before the transfer date, the Director of the Office of Thrift Supervision (in consultation with the Comptroller of the Currency, the Chairperson of the Corporation, and the Chairman of the Board of Governors) determines are not necessary to dispose of the affairs of the Office of Thrift Supervision under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5435"},"text":"section 5435 of this title","children":[],"tail":" and are available to the Office of Thrift Supervision to pay the expenses of the Office of Thrift Supervision—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd660fe8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5434/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relating to the functions of the Office of Thrift Supervision transferred under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5412/b/2/B"},"text":"section 5412(b)(2)(B) of this title","children":[],"tail":", shall be transferred to the Office of the Comptroller of the Currency on the transfer date;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd660fe9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5434/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relating to the functions of the Office of Thrift Supervision transferred under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5412/b/2/C"},"text":"section 5412(b)(2)(C) of this title","children":[],"tail":", shall be transferred to the Corporation on the transfer date; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd660fea-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5434/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relating to the functions of the Office of Thrift Supervision transferred under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5412/b/1/A"},"text":"section 5412(b)(1)(A) of this title","children":[],"tail":", shall be transferred to the Board of Governors on the transfer date."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd660feb-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tIII/s324"},"text":"Pub. L. 111–203, title III, § 324","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1536"},"text":"124 Stat. 1536","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd660fec-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd660fed-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd660fee-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 1 day after ","children":[{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s4"},"text":"section 4 of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"section 5301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
