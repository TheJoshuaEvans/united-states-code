{"tag":"section","attrib":{"id":"iddd7467c8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5553"},"text":null,"children":[{"tag":"num","attrib":{"value":"5553"},"text":"§ 5553.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preservation of existing contracts","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"This title,","children":[{"tag":"ref","attrib":{"idref":"fn002522"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002522"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and regulations, orders, guidance, and interpretations prescribed, issued, or established by the Bureau, shall not be construed to alter or affect the applicability of any regulation, order, guidance, or interpretation prescribed, issued, and established by the Comptroller of the Currency or the Director of the Office of Thrift Supervision regarding the applicability of State law under Federal banking law to any contract entered into on or before "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", by national banks, Federal savings associations, or subsidiaries thereof that are regulated and supervised by the Comptroller of the Currency or the Director of the Office of Thrift Supervision, respectively."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd7467c9-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1043"},"text":"Pub. L. 111–203, title X, § 1043","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2014"},"text":"124 Stat. 2014","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd7467ca-3a6f-11f1-8fa0-c065796a