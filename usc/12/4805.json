{"tag":"section","attrib":{"id":"iddd3fe9de-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4805"},"text":null,"children":[{"tag":"num","attrib":{"value":"4805"},"text":"§ 4805.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Call report simplification","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd3fe9df-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4805/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modernization of call report filing and disclosure system","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to reduce the administrative requirements pertaining to bank reports of condition, savings association financial reports, and bank holding company consolidated and parent-only financial statements, and to improve the timeliness of such reports and statements, the Federal banking agencies shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd3fe9e0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4805/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" work jointly to develop a system under which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd3fe9e1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4805/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" insured depository institutions and their affiliates may file such reports and statements electronically; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3fe9e2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4805/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal banking agencies may make such reports and statements available to the public electronically; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3fe9e3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4805/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"1994-09-23"},"text":"September 23, 1994","children":[],"tail":", report to the Congress and make recommendations for legislation that would enhance efficiency for filers and users of such reports and statements."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3fe9e4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4805/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uniform reports and simplification of instructions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Federal banking agencies shall, consistent with the principles of safety and soundness, work jointly—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd3fe9e5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4805/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to adopt a single form for the filing of core information required to be submitted under Federal law to all such agencies in the reports and statements referred to in subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3fe9e6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4805/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to simplify instructions accompanying such reports and statements and to provide an index to the instructions that is adequate to meet the needs of both filers and users.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3fe9e7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4805/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of call report schedule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each Federal banking agency shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd3fe9e8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4805/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the information required by schedules supplementing the core information referred to in subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3fe9e9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4805/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eliminate requirements that are not warranted for reasons of safety and soundness or other public purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd3fe9ea-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/tIII/s307"},"text":"Pub. L. 103–325, title III, § 307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2217"},"text":"108 Stat. 2217","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd3fe9eb-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd3fe9ec-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd3fe9ed-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to this section are contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4805a"},"text":"section 4805a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
