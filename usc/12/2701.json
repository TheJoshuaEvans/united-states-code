{"tag":"section","attrib":{"id":"iddcf39ebe-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2701"},"text":null,"children":[{"tag":"num","attrib":{"value":"2701"},"text":"§ 2701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional findings and declaration of purpose","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcf39ebf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2701/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcf39ec0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2701/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Nation is in a severe recession and that the sharp downturn in economic activity has driven large numbers of workers into unemployment and has reduced the incomes of many others;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf39ec1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2701/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a result of these adverse economic conditions the capacity of many homeowners to continue to make mortgage payments has deteriorated and may further deteriorate in the months ahead, leading to the possibility of widespread mortgage foreclosures and distress sales of homes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf39ec2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2701/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" many of these homeowners could retain their homes with temporary financial assistance until economic conditions improve.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcf39ec3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2701/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" It is the purpose of this chapter to provide a standby authority which will prevent widespread mortgage foreclosures and distress sales of homes resulting from the temporary loss of employment and income through a program of emergency loans and advances and emergency mortgage relief payments to homeowners to defray mortgage expenses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcf39ec4-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/50/tI/s102"},"text":"Pub. L. 94–50, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-07-02"},"text":"July 2, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/249"},"text":"89 Stat. 249","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcf39ec5-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcf39ec6-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"iddcf39ec7-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/50/s1"},"text":"Pub. L. 94–50, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-07-02"},"text":"July 2, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/249"},"text":"89 Stat. 249","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/94/50/s1"},"text":"“That this Act [enacting this chapter, amending sections 1723e and 1735b of this title and sections 1452 and 4106 of Title 42, The Public Health and Welfare, enacting provisions set out as a note under this section, and amending provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1723e"},"text":"section 1723e of this title","children":[],"tail":"] may be cited as the ‘Emergency Housing Act of 1975’.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/50/tI/s101"},"text":"Pub. L. 94–50, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-07-02"},"text":"July 2, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/249"},"text":"89 Stat. 249","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/94/50/tI/s101"},"text":"“This title [enacting this chapter] may be cited as the ‘Emergency Homeowners’ Relief Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
