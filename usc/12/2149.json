{"tag":"section","attrib":{"id":"iddcc64c53-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2149"},"text":null,"children":[{"tag":"num","attrib":{"value":"2149"},"text":"§ 2149.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lending limits","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Farm Credit Administration may not establish lending limits for the consolidated bank with respect to any loans or borrowers that are more restrictive than the combined lending limits that were previously established by the Farm Credit Administration for the constituent banks described in section 413(b) of the Agricultural Credit Act of 1987 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2121"},"text":"12 U.S.C. 2121","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/pl/100/233"},"text":"Public Law 100–233","children":[],"tail":") with respect to such loans or borrowers."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddcc64c54-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tIII/s3"},"text":"Pub. L. 92–181, title III, § 3","children":[],"tail":".28, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tIV/s415/2"},"text":"Pub. L. 100–233, title IV, § 415(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1644"},"text":"101 Stat. 1644","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tV/s5411/15"},"text":"Pub. L. 115–334, title V, § 5411(15)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4680"},"text":"132 Stat. 4680","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcc64c55-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcc64c56-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcc64c57-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" substituted “the constituent banks described in section 413(b) of the Agricultural Credit Act of 1987 ("},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2121"},"text":"12 U.S.C. 2121","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/pl/100/233"},"text":"Public Law 100–233","children":[],"tail":")” for “a district bank for cooperatives and the Central Bank for Cooperatives”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
