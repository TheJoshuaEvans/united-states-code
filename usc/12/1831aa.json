{"tag":"section","attrib":{"id":"iddca29836-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"1831aa"},"text":"§ 1831aa.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement of agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddca29837-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831aa/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding clause (i) or (ii) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1818/b/6/A"},"text":"section 1818(b)(6)(A) of this title","children":[],"tail":" or section 1831"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"(e)(2)(E)(i) of this title, the appropriate Federal banking agency for a depository institution may enforce, under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1818"},"text":"section 1818 of this title","children":[],"tail":", the terms of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddca29838-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831aa/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any condition imposed in writing by the agency on the depository institution or an institution-affiliated party in connection with any action on any application, notice, or other request concerning the depository institution; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca29839-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831aa/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any written agreement entered into between the agency and the depository institution or an institution-affiliated party.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca2983a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831aa/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Receiverships and conservatorships","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After the appointment of the Corporation as the receiver or conservator for a depository institution, the Corporation may enforce any condition or agreement described in paragraph (1) or (2) of subsection (a) imposed on or entered into with such institution or institution-affiliated party through an action brought in an appropriate United States district court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddca2983b-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-21/ch967/s2"},"text":"Sept. 21, 1950, ch. 967, § 2","children":[],"tail":"[50], as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/351/tVII/s702/a"},"text":"Pub. L. 109–351, title VII, § 702(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-13"},"text":"Oct. 13, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1985"},"text":"120 Stat. 1985","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
