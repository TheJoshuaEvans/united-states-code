{"tag":"section","attrib":{"id":"iddca4e279-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1833a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1833a"},"text":"§ 1833a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddca4e27a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1833a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whoever violates any provision of law to which this section is made applicable by subsection (c) shall be subject to a civil penalty in an amount assessed by the court in a civil action under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca4e27b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1833a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum amount of penalty","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddca4e27c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1833a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Generally","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of the civil penalty shall not exceed $1,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca4e27d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1833a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for continuing violations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a continuing violation, the amount of the civil penalty may exceed the amount described in paragraph (1) but may not exceed the lesser of $1,000,000 per day or $5,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca4e27e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1833a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for violations creating gain or loss","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddca4e27f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1833a/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If any person derives pecuniary gain from the violation, or if the violation results in pecuniary loss to a person other than the violator, the amount of the civil penalty may exceed the amounts described in paragraphs (1) and (2) but may not exceed the amount of such gain or loss.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddca4e280-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1833a/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As used in this paragraph, the term “person” includes the Bank Insurance Fund, the Savings Association Insurance Fund, and after the merger of such funds, the Deposit Insurance Fund, and the National Credit Union Share Insurance Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca4e281-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1833a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violations to which penalty is applicable","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section applies to a violation of, or a conspiracy to violate—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddca4e282-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1833a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 215, 656, 657, 1005, 1006, 1007, 1014, or 1344 of title 18;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca4e283-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1833a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 287, 1001, 1032,","children":[{"tag":"ref","attrib":{"idref":"fn002274"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002274"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See 1990 Amendment note below."}],"tail":" 1341 or 1343 of title 18 affecting a federally insured financial institution; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca4e284-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1833a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s645/a"},"text":"section 645(a) of title 15","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca4e285-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1833a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply to violations occurring on or after ","children":[{"tag":"date","attrib":{"date":"1984-08-10"},"text":"August 10, 1984","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca4e286-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1833a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attorney General to bring action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A civil action to recover a civil penalty under this section shall be commenced by the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca4e287-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1833a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Burden of proof","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In a civil action to recover a civil penalty under this section, the Attorney General must establish the right to recovery by a preponderance of the evidence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca4e288-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1833a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative subpoenas","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddca4e289-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1833a/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of conducting a civil investigation in contemplation of a civil proceeding under this section, the Attorney General may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddca4e28a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1833a/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administer oaths and affirmations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddca4e28b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1833a/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take evidence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddca4e28c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1833a/g/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by subpoena, summon witnesses and require the production of any books, papers, correspondence, memoranda, or other records which the Attorney General deems relevant or material to the inquiry. Such subpoena may require the attendance of witnesses and the production of any such records from any place in the United States at any place in the United States designated by the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca4e28d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1833a/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures applicable","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The same procedures and limitations as are provided with respect to civil investigative demands in subsections (g), (h), and (j) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1968"},"text":"section 1968 of title 18","children":[],"tail":" apply with respect to a subpoena issued under this subsection. Process required by such subsections to be served upon the custodian shall be served on the Attorney General. Failure to comply with an order of the court to enforce such subpoena shall be punishable as contempt."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca4e28e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1833a/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a subpoena for which the return date is less than 5 days after the date of service, no person shall be found in contempt for failure to comply by the return date if such person files a petition under paragraph (2) not later than 5 days after the date of service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca4e28f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1833a/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statute of limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A civil action under this section may not be commenced later than 10 years after the cause of action accrues.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddca4e290-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/tIX/s951"},"text":"Pub. L. 101–73, title IX, § 951","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/498"},"text":"103 Stat. 498","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXV"},"text":"Pub. L. 101–647, title XXV","children":[],"tail":", §§ 2533, 2596(d), "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4882"},"text":"104 Stat. 4882","children":[],"tail":", 4908; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330003/g"},"text":"Pub. L. 103–322, title XXXIII, § 330003(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2141"},"text":"108 Stat. 2141","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tII/s2704/d/15/A"},"text":"Pub. L. 104–208, div. A, title II, § 2704(d)(15)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-494"},"text":"110 Stat. 3009–494","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/100/s4/b"},"text":"Pub. L. 107–100, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-21"},"text":"Dec. 21, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/966"},"text":"115 Stat. 966","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/171/tII/s2102/b"},"text":"Pub. L. 109–171, title II, § 2102(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-02-08"},"text":"Feb. 8, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/9"},"text":"120 Stat. 9","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/173/s9/g/1"},"text":"Pub. L. 109–173, § 9(g)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-02-15"},"text":"Feb. 15, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3618"},"text":"119 Stat. 3618","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddca4e291-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddca4e292-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddca4e293-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Financial Institutions Reform, Recovery, and Enforcement Act of 1989, and not as part of the Federal Deposit Insurance Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddca4e294-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (b)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/173"},"text":"Pub. L. 109–173","children":[],"tail":" inserted “and after the merger of such funds, the Deposit Insurance Fund,” after “the Savings Association Insurance Fund,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/171"},"text":"Pub. L. 109–171","children":[],"tail":" repealed "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/s2704/d/15/A"},"text":"Pub. L. 104–208, § 2704(d)(15)(A)","children":[],"tail":". See 1996 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/100/s4/b/2/D"},"text":"Pub. L. 107–100, § 4(b)(2)(D)","children":[],"tail":", designated concluding provisions as (d) and inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/100/s4/b/2/B/i"},"text":"Pub. L. 107–100, § 4(b)(2)(B)(i)","children":[],"tail":", which directed the substitution of “1341” for “1341;”, could not be executed because par. (2) does not contain a semicolon after “1341”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/100/s4/b/2/A"},"text":"Pub. L. 107–100, § 4(b)(2)(A)","children":[],"tail":", (B)(ii), (C), added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d) to (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/100/s4/b/1"},"text":"Pub. L. 107–100, § 4(b)(1)","children":[],"tail":", (2)(D), designated concluding provisions of subsec. (c) as (d), inserted heading, and redesignated former subsecs. (d) to (g) as (e) to (h), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s2704/d/15/A"},"text":"Pub. L. 104–208, § 2704(d)(15)(A)","children":[],"tail":", which directed substitution of “Deposit Insurance Fund” for “Bank Insurance Fund, the Savings Association Insurance Fund,”, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/109/171"},"text":"Pub. L. 109–171","children":[],"tail":". See Effective Date of 1996 Amendment note below and 2006 Amendment note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" amended directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/s2596/d"},"text":"Pub. L. 101–647, § 2596(d)","children":[],"tail":". See 1990 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/s2596/d/2"},"text":"Pub. L. 101–647, § 2596(d)(2)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":", inserted at end a flush sentence “This section shall apply to violations occurring on or after "},{"tag":"date","attrib":{"date":"1984-08-10"},"text":"August 10, 1984","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/s2596/d/1"},"text":"Pub. L. 101–647, § 2596(d)(1)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":", which directed insertion of “287, 1001, 1032,” before “1341;”, was executed by making the insertion before “1341 or 1343” to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/s2533"},"text":"Pub. L. 101–647, § 2533","children":[],"tail":", added subsec. (g)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddca4e295-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddca4e296-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/173"},"text":"Pub. L. 109–173","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2006-03-31"},"text":"Mar. 31, 2006","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/173/s9/j"},"text":"section 9(j) of Pub. L. 109–173","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s24"},"text":"section 24 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/171"},"text":"Pub. L. 109–171","children":[],"tail":" effective no later than the first day of the first calendar quarter that begins after the end of the 90-day period beginning "},{"tag":"date","attrib":{"date":"2006-02-08"},"text":"Feb. 8, 2006","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/171/s2102/c"},"text":"section 2102(c) of Pub. L. 109–171","children":[],"tail":", set out as a Merger of BIF and SAIF note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1821"},"text":"section 1821 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddca4e297-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1999-01-01"},"text":"Jan. 1, 1999","children":[],"tail":", if no insured depository institution is a savings association on that date, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/s2704/c"},"text":"section 2704(c) of Pub. L. 104–208","children":[],"tail":", formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1821"},"text":"section 1821 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddca4e298-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330003/g"},"text":"Pub. L. 103–322, title XXXIII, § 330003(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2141"},"text":"108 Stat. 2141","children":[],"tail":", provided that the amendment made by that section is effective retroactively to the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/101/647"},"text":"Pub. L. 101–647","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
