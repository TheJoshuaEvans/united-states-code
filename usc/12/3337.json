{"tag":"section","attrib":{"id":"iddd04680a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3337"},"text":null,"children":[{"tag":"num","attrib":{"value":"3337"},"text":"§ 3337.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Startup funding","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd04680b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3337/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this chapter, the Secretary of the Treasury shall pay to the Appraisal Subcommittee a one-time payment of $5,000,000 on ","children":[{"tag":"date","attrib":{"date":"1989-08-09"},"text":"August 9, 1989","children":[],"tail":". Thereafter, expenses of the subcommittee shall be funded through the collection of registry fees from certain certified and licensed appraisers pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s3338"},"text":"section 3338 of this title","children":[],"tail":" or, if required, pursuant to section 3351(b) "},{"tag":"ref","attrib":{"idref":"fn002344"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002344"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd04680c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3337/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in section 3351(b) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title, funds in addition to the funds provided under subsection (a) may be made available to the Appraisal Subcommittee only if authorized and appropriated by law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd04680d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3337/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment of Treasury loan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"1998-09-30"},"text":"September 30, 1998","children":[],"tail":", the Appraisal Subcommittee shall repay to the Secretary of the Treasury the unpaid portion of the $5,000,000 paid to the Appraisal Subcommittee pursuant to this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd04680e-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/tXI/s1108"},"text":"Pub. L. 101–73, title XI, § 1108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/513"},"text":"103 Stat. 513","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tII/s2212"},"text":"Pub. L. 104–208, div. A, title II, § 2212","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-411"},"text":"110 Stat. 3009–411","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd04680f-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd046810-3a6f-11f1-8fa0-c065796a7f