{"tag":"section","attrib":{"id":"iddd20ef3b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4313"},"text":null,"children":[{"tag":"num","attrib":{"value":"4313"},"text":"§ 4313.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purposes of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd20ef3c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4313/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Account","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “account” means any account intended for use by and generally used by consumers primarily for personal, family, or household purposes that is offered by a depository institution into which a consumer deposits funds, including demand accounts, time accounts, negotiable order of withdrawal accounts, and share draft accounts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd20ef3d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4313/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual percentage yield","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “annual percentage yield” means the total amount of interest that would be received on a $100 deposit, based on the annual rate of simple interest and the frequency of compounding for a 365-day period, expressed as a percentage calculated by a method which shall be prescribed by the Bureau in regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd20ef3e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4313/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual rate of simple interest","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “annual rate of simple interest”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd20ef3f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4313/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means the annualized rate of interest paid with respect to each compounding period, expressed as a percentage; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd20ef40-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4313/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be referred to as the “annual percentage rate”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd20ef41-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4313/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bureau","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Bureau” means the Bureau of Consumer Financial Protection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd20ef42-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4313/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit broker","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “deposit broker”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd20ef43-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4313/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the meaning given to such term in section 1831f(f)(1) ","children":[{"tag":"ref","attrib":{"idref":"fn002396"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002396"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd20ef44-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4313/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes any person who solicits any amount from any other person for deposit in an insured depository institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd20ef45-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4313/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Depository institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “depository institution” has the meaning given such term in clauses (i) through (vi) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s461/b/1/A"},"text":"section 461(b)(1)(A) of this title","children":[],"tail":", but does not include any nonautomated credit union that was not required to comply with the requirements of this chapter "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" as of "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"September 30, 1996","children":[],"tail":", pursuant to the determination of the National Credit Union Administration Bureau."},{"tag":"ref","attrib":{"idref":"fn002397"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002397"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “Board.”"}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd20ef46-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4313/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “interest” includes dividends paid with respect to share draft accounts which are accounts within the meaning of paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd20ef47-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4313/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multiple rate account","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “multiple rate account” means any account that has 2 or more annual rates of simple interest which take effect at the same time or in succeeding periods and which are known at the time of disclosure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd20ef48-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/tII/s274"},"text":"Pub. L. 102–242, title II, § 274","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2342"},"text":"105 Stat. 2342","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXVI/s1604/e/2/S"},"text":"Pub. L. 102–550, title XVI, § 1604(e)(2)(S)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4084"},"text":"106 Stat. 4084","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/325/tIII/s332"},"text":"Pub. L. 103–325, title III, § 332","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2232"},"text":"108 Stat. 2232","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tII/s2604/c"},"text":"Pub. L. 104–208, div. A, title II, § 2604(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-471"},"text":"110 Stat. 3009–471","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1100B/1"},"text":"Pub. L. 111–203, title X, § 1100B(1)","children":[],"tail":", (4), "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2109"},"text":"124 Stat. 2109","children":[],"tail":", 2110.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd20ef49-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd20ef4a-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd20ef4b-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1831f/f/1"},"text":"Section 1831f(f)(1) of this title","children":[],"tail":", referred to in par. (5)(A), was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1831f/g/1"},"text":"section 1831f(g)(1) of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/102/242/tIII/s301/a/4"},"text":"Pub. L. 102–242, title III, § 301(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2344"},"text":"105 Stat. 2344","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This chapter, referred to in par. (6), was in the original “this title”, and was translated as meaning “this subtitle”, which is subtitle F of title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242"},"text":"Pub. L. 102–242","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2334"},"text":"105 Stat. 2334","children":[],"tail":", which enacted this chapter, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd20ef4c-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1100B/1"},"text":"Pub. L. 111–203, § 1100B(1)","children":[],"tail":", substituted “Bureau” for “Board” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1100B/4"},"text":"Pub. L. 111–203, § 1100B(4)","children":[],"tail":", added par. (4) and struck out former par. (4). Prior to amendment, text read as follows: “The term ‘Board’ means the Board of Governors of the Federal Reserve System.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Par. (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" inserted before period at end “, but does not include any nonautomated credit union that was not required to comply with the requirements of this chapter as of "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"September 30, 1996","children":[],"tail":", pursuant to the determination of the National Credit Union Administration Board”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325"},"text":"Pub. L. 103–325","children":[],"tail":" amended par. (1) generally. Prior to amendment, par. (1) read as follows: “The term ‘account’ means any account offered to 1 or more individuals or an unincorporated nonbusiness association of individuals by a depository institution into which a customer deposits funds, including demand accounts, time accounts, negotiable order of withdrawal accounts, and share draft accounts.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550"},"text":"Pub. L. 102–550","children":[],"tail":" made technical amendment to reference to “this chapter” in introductory provisions to reflect correction of corresponding provision of original act."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd20ef4d-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd20ef4e-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective on the designated transfer date, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1100H"},"text":"section 1100H of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd20ef4f-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550"},"text":"Pub. L. 102–550","children":[],"tail":" effective as if included in the Federal Deposit Insurance Corporation Improvement Act of 1991, "},{"tag":"ref","attrib":{"href":"/us/pl/102/242"},"text":"Pub. L. 102–242","children":[],"tail":", as of "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/s1609/a"},"text":"section 1609(a) of Pub. L. 102–550","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s191"},"text":"section 191 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
