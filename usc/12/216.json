{"tag":"section","attrib":{"id":"iddb22af2e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s216"},"text":null,"children":[{"tag":"num","attrib":{"value":"216"},"text":"§ 216.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purpose of this subchapter is to dispose of unclaimed property in the possession, custody, or control of the Comptroller of the Currency by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb22af2f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s216/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing final notice of the availability of unclaimed property from closed national banks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb22af30-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s216/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" barring rights of claimants to obtain such property from the Comptroller after a reasonable period of time following such notice; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb22af31-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s216/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorizing the Comptroller to dispose of such property for which no claims have been filed and validated under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddb22af32-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/221/tVII/s731"},"text":"Pub. L. 96–221, title VII, § 731","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/320/tIV/s408"},"text":"Pub. L. 97–320, title IV, § 408","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-15"},"text":"Oct. 15, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1513"},"text":"96 Stat. 1513","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/351/tVII/s725/c/1"},"text":"Pub. L. 109–351, title VII, § 725(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-13"},"text":"Oct. 13, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2001"},"text":"120 Stat. 2001","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/356/tI/s123/c/1"},"text":"Pub. L. 109–356, title I, § 123(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-16"},"text":"Oct. 16, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2029"},"text":"120 Stat. 2029","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb22af33-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb22af34-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddb22af35-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/351"},"text":"Pub. L. 109–351","children":[],"tail":" and 109–356 amended par. (1) identically, striking out “and closed banks in the District of Columbia” before semicolon at end."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
