{"tag":"section","attrib":{"id":"iddd1c351b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4118"},"text":null,"children":[{"tag":"num","attrib":{"value":"4118"},"text":"§ 4118.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultations with other interested parties","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall confer with any appropriate State or local government agency to confirm any State or local assistance that is available to achieve the purposes of this title ","children":[{"tag":"ref","attrib":{"idref":"fn002372"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002372"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and shall give consideration to the views of any such agency when making determinations under this subchapter. The Secretary shall also confer with appropriate interested parties that the Secretary believes could assist in the development of a plan of action that best achieves the purposes of this subchapter."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd1c351c-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/242/tII/s228"},"text":"Pub. L. 100–242, title II, § 228","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/625/tVI/s601/a"},"text":"Pub. L. 101–625, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4271"},"text":"104 Stat. 4271","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd1c351d-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd1c351e-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd1c351f-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This title, referred to in text, means title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/242"},"text":"Pub. L. 100–242","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/101/625/tVI/s601/a"},"text":"Pub. L. 101–625, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4249"},"text":"104 Stat. 4249","children":[],"tail":", known as the Low-Income Housing Preservation and Resident Homeownership Act of 1990, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4101"},"text":"section 4101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
