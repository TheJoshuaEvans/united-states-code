ail":"\n"},{"tag":"paragraph","attrib":{"id":"iddbd7ce20-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1712a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 1715","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"(d)(3)(ii)(I) of this title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddbd7ce21-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1712a/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 1715","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"(d)(4)(ii)(I) of this title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddbd7ce22-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1712a/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1715v/c/2/A"},"text":"section 1715v(c)(2)(A) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddbd7ce23-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1712a/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1715y/e/3/A"},"text":"section 1715y(e)(3)(A) of this title","children":[],"tail":";"},{"tag":"p","attrib":{},"text":"(collectively hereinafter referred to as the “Dollar Amounts”) shall be adjusted annually (commencing in 2004) on the effective date of the Federal Reserve Board’s adjustment of the $400 figure in the Home Ownership and Equity Protection Act of 1994 (HOEPA). The adjustment of the Dollar Amounts shall be calculated using the percentage change in the Consumer Price Index for All Urban Consumers (CPI–U) as applied by the Federal Reserve Board for purposes of the above-described HOEPA adjustment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddbd7ce24-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1712a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal Reserve Board on a timely basis shall notify the Secretary, or his designee, in writing of the adjustment described in subsection (a) and of the effective date of such adjustment in order to permit the Secretary to undertake publication in the Federal Register of corresponding adjustments to the Dollar Amounts. The dollar amount of any adjustment shall be rounded to the next lower dollar.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddbd7ce25-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-27/ch847"},"text":"June 27, 1934, ch. 847","children":[],"tail":", title II, § 206A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/326/s5/a"},"text":"Pub. L. 107–326, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-04"},"text":"Dec. 4, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2794"},"text":"116 Stat. 2794","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddbd7ce26-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddbd7ce27-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddbd7ce28-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Home Ownership and Equity Protection Act of 1994, referred to in subsec. (a), is subtitle B (§§ 151–158) of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325"},"text":"Pub. L. 103–325","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2190"},"text":"108 Stat. 2190","children":[],"tail":", which enacted sections 1639 and 1648 of Title 15, Commerce and Trade, amended sections 1602, 1604, 1610, 1640, 1641, and 1647 of Title 15, and enacted provisions set out as notes under sections 1601 and 1602 of Title 15. For complete classification of this Act to the Code, see Short Title of 1994 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1601"},"text":"section 1601 of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
