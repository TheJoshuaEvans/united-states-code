{"tag":"section","attrib":{"id":"iddcc8be68-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202"},"text":null,"children":[{"tag":"num","attrib":{"value":"2202"},"text":"§ 2202.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reconsideration of actions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcc8be69-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit review committees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcc8be6a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The board of directors of each qualified lender shall establish one or more credit review committees, which shall include farmer board representation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc8be6b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In no case shall a loan officer involved in the initial decision on a loan serve on the credit review committee when the committee reviews such loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcc8be6c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of decisions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcc8be6d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Denials or reductions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any applicant for a loan from a qualified lender that has received a written notice issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2201"},"text":"section 2201 of this title","children":[],"tail":" of a decision to deny or reduce the loan applied for may submit a written request, not later than 30 days after receiving a notice denying or reducing the amount of the loan application, to obtain a review of the decision before the credit review committee."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc8be6e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Denials of restructuring","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A borrower of a loan from a qualified lender that has received notice, under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2201"},"text":"section 2201 of this title","children":[],"tail":", of a decision to deny loan restructuring with respect to a loan made to the borrower, if the borrower so requests in writing within 7 days after receiving such notice, may obtain a review of such decision in person before the credit review committee."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcc8be6f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personal appearance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An applicant for a loan or for restructuring, who is entitled to and has requested a review under this section, may appear in person before the credit review committee, and may be accompanied by counsel or by any other representative of such person’s choice, to seek a reversal of the decision on the application under review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcc8be70-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Independent appraisal","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcc8be71-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An appeal filed with a credit review committee under this section may include, as a part of the request for a review of the decision filed under subsection (b)(1) or (2), a request for an independent appraisal, by an accredited appraiser, of any interests in property securing the loan (other than the stock or participation certificates of the qualified lender held by the borrower).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc8be72-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Arrangement and cost","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within 30 days after a request for an appraisal under paragraph (1), the credit review committee shall present the borrower with a list of three appraisers approved by the appropriate qualified lender from which the borrower shall select an appraiser to conduct the appraisal the cost of which shall be borne by the borrower, and shall consider the results of such appraisal in any final determination with respect to the loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc8be73-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Copy to borrower","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A copy of any appraisal made under this subsection shall be provided to the borrower.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc8be74-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional collateral","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An independent appraisal shall be permitted if additional collateral for a loan is demanded by the qualified lender when determining whether to restructure the loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcc8be75-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of applicant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Promptly after a review by the credit review committee, the committee shall notify the applicant or borrower, as the case may be, in writing of the decision of the committee and the reasons for the decision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcc8be76-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tIV/s4"},"text":"Pub. L. 92–181, title IV, § 4","children":[],"tail":".14, "},{"tag":"date","attrib":{"date":"1971-12-10"},"text":"Dec. 10, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/613"},"text":"85 Stat. 613","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/205/tIII/s303"},"text":"Pub. L. 99–205, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1708"},"text":"99 Stat. 1708","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tI/s106"},"text":"Pub. L. 100–233, title I, § 106","children":[],"tail":", title VIII, § 805(s), "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1580"},"text":"101 Stat. 1580","children":[],"tail":", 1716; "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/tI/s103"},"text":"Pub. L. 100–399, title I, § 103","children":[],"tail":", title VII, § 702(b), "},{"tag":"date","attrib":{"date":"1988-08-17"},"text":"Aug. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/990"},"text":"102 Stat. 990","children":[],"tail":", 1006.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcc8be77-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcc8be78-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcc8be79-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/233/s805/s"},"text":"Pub. L. 100–233, § 805(s)","children":[],"tail":", which directed amendment of this section by substituting “committees” for “committee(s)”, “2201” for “2199”, and “review” for “reviews”, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/s702/b"},"text":"Pub. L. 100–399, § 702(b)","children":[],"tail":". See Construction of 1988 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/233/s106"},"text":"Pub. L. 100–233, § 106","children":[],"tail":", amended section generally. Prior to amendment, section read as follows: “The board of directors of each Farm Credit System institution shall establish one or more credit review committee(s), which shall include farmer board respresentation. [sic] Any loan applicant who has received written notice, under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2199"},"text":"section 2199 of this title","children":[],"tail":", of a decision to deny or reduce the loan applied for, if the applicant so requests in writing within thirty days after receiving such notice, may obtain a review of such decision in person before the credit review committee. When a loan applicant requests review of an adverse credit decision, a majority of persons serving on such reviews committee must be persons who were not involved in making the adverse decision. Promptly after any such review, the applicant shall be notified in writing of the credit review committee’s decision and the reasons therefor.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s103/a"},"text":"Pub. L. 100–399, § 103(a)","children":[],"tail":", substituted “before the” for “by a”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s103/b"},"text":"Pub. L. 100–399, § 103(b)","children":[],"tail":", inserted “or (2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/205"},"text":"Pub. L. 99–205","children":[],"tail":", in amending section generally, substituted provisions respecting reconsideration of action on loan application for prior reconsideration provisions which read as follows: “Any applicant who has reason to believe that the action on his application by an association failed to take into account facts pertinent to his application, or has misinterpreted or failed to properly apply the applicable law or rules and regulations governing his application, may, if he so requests in writing within thirty days of the date of that notice, request an informal hearing on his application and the action of the association in reduction or denial thereof, or the reason for such action, in person before the loan committee or officer or employee thereof authorized to act on applications under section 2033(11) or 2093(18) of this title. Promptly after such a hearing, he shall be notified of the decision upon reconsideration and the reasons therefor.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcc8be7a-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcc8be7b-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399"},"text":"Pub. L. 100–399","children":[],"tail":" effective as if enacted immediately after enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/100/233"},"text":"Pub. L. 100–233","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/s1001/a"},"text":"section 1001(a) of Pub. L. 100–399","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2002"},"text":"section 2002 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcc8be7c-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1985 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/205"},"text":"Pub. L. 99–205","children":[],"tail":" effective thirty days after "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/205/s401"},"text":"section 401 of Pub. L. 99–205","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2001"},"text":"section 2001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddcc8be7d-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/tVII/s702/b"},"text":"Pub. L. 100–399, title VII, § 702(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-17"},"text":"Aug. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1006"},"text":"102 Stat. 1006","children":[],"tail":", provided that "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/s805/s"},"text":"section 805(s) of Pub. L. 100–233","children":[],"tail":", cited as a credit to this section, is repealed and that this section shall be applied and administered as if such section had not been enacted."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
