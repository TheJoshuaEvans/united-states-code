{"tag":"section","attrib":{"id":"iddcc8be7e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2202a"},"text":"§ 2202a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restructuring distressed loans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcc8be7f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this part and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2219a"},"text":"section 2219a of this title","children":[],"tail":":"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcc8be80-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application for restructuring","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “application for restructuring” means a written request—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcc8be81-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from a borrower for the restructuring of a distressed loan in accordance with a preliminary restructuring plan proposed by the borrower as a part of the application;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcc8be82-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submitted on the appropriate forms prescribed by the qualified lender; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcc8be83-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accompanied by sufficient financial information and repayment projections, where appropriate, as required by the qualified lender to support a sound credit decision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc8be84-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost of foreclosure","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “cost of foreclosure” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcc8be85-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the difference between the outstanding balance due on a loan made by a qualified lender and the liquidation value of the loan, taking into consideration the borrower’s repayment capacity and the liquidation value of the collateral used to secure the loan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcc8be86-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estimated cost of maintaining a loan as a nonperforming asset;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcc8be87-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estimated cost of administrative and legal actions necessary to foreclose a loan and dispose of property acquired as the result of the foreclosure, including attorneys’ fees and court costs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcc8be88-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estimated cost of changes in the value of collateral used to secure a loan during the period beginning on the date of the initiation of an action to foreclose or liquidate the loan and ending on the date of the disposition of the collateral; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcc8be89-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all other costs incurred as the result of the foreclosure or liquidation of a loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc8be8a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distressed loan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “distressed loan” means a loan that the borrower does not have the financial capacity to pay according to its terms and that exhibits one or more of the following characteristics:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcc8be8b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The borrower is demonstrating adverse financial and repayment trends.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcc8be8c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The loan is delinquent or past due under the terms of the loan contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcc8be8d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One or both of the factors listed in subparagraphs (A) and (B), together with inadequate collateralization, present a high probability of loss to the lender.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc8be8e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreclosure proceeding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “foreclosure proceeding” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcc8be8f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a foreclosure or similar legal proceeding to enforce a lien on property, whether real or personal, that secures a nonaccrual or distressed loan; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcc8be90-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the seizing of and realizing on nonreal property collateral, other than collateral subject to a statutory lien arising under subchapter I or II, to effect collection of a nonaccrual or distressed loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc8be91-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcc8be92-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraph (B), the term “loan” means a loan made to a farmer, rancher, or producer or harvester of aquatic products, for any agricultural or aquatic purpose and other credit needs of the borrower, including financing for basic processing and marketing directly related to the borrower’s operations and those of other eligible farmers, ranchers, and producers or harvesters of aquatic products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcc8be93-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion for loans designated for sale into secondary market","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddcc8be94-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/a/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in clause (ii), the term “loan” does not include a loan made on or after ","children":[{"tag":"date","attrib":{"date":"1996-02-10"},"text":"February 10, 1996","children":[],"tail":", that is designated, at the time the loan is made, for sale into a secondary market."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcc8be95-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/a/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unsold loans","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddcc8be96-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/a/5/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subclause (II), if a loan designated for sale under clause (i) is not sold into a secondary market during the 180-day period that begins on the date of the designation, the provisions of this section and sections 2202, 2202b, 2202d, and 2219a of this title that would otherwise apply to the loan in the absence of the exclusion described in clause (i) shall become effective with respect to the loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddcc8be97-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/a/5/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Later sale","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a loan described in subclause (I) is sold into a secondary market after the end of the 180-day period described in subclause (I), subclause (I) shall not apply with respect to the loan beginning on the date of the sale.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc8be98-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified lender","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified lender” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcc8be99-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a System institution that makes loans (as defined in paragraph (5)) except a bank for cooperatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcc8be9a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each bank, institution, corporation, company, union, and association described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2015/b/1/B"},"text":"section 2015(b)(1)(B) of this title","children":[],"tail":" but only with respect to loans discounted or pledged under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2015/b/1"},"text":"section 2015(b)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc8be9b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restructure and restructuring","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “restructure” and “restructuring” include rescheduling, reamortization, renewal, deferral of principal or interest, monetary concessions, and the taking of any other action to modify the terms of, or forbear on, a loan in any way that will make it probable that the operations of the borrower will become financially viable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcc8be9c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcc8be9d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On a determination by a qualified lender that a loan made by the lender is or has become a distressed loan, the lender shall provide written notice to the borrower that the loan may be suitable for restructuring, and include with such notice—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcc8be9e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a copy of the policy of the lender established under subsection (g) that governs the treatment of distressed loans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcc8be9f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all materials necessary to enable the borrower to submit an application for restructuring on the loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc8bea0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice before foreclosure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 45 days before any qualified lender begins foreclosure proceedings with respect to a loan outstanding to any borrower, the lender shall notify the borrower that the loan may be suitable for restructuring and that the lender will review any such suitable loan for restructuring, and shall include with such notice a copy of the policy and the materials described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc8bea1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on foreclosure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No qualified lender may foreclose or continue any foreclosure proceeding with respect to any distressed loan before the lender has completed any pending consideration of the loan for restructuring under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcc8bea2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On determination by a qualified lender that a loan made by the lender is or has become a distressed loan, the lender shall provide a reasonable opportunity for the borrower thereof to personally meet with a representative of the lender—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcc8bea3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to review the status of the loan, the financial condition of the borrower, and the suitability of the loan for restructuring; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc8bea4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a loan that is in nonaccrual status, to develop a plan for restructuring the loan if the loan is suitable for restructuring.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcc8bea5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration of applications","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcc8bea6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"When a qualified lender receives an application for restructuring from a borrower, the qualified lender shall determine whether or not to restructure the loan, taking into consideration—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcc8bea7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the cost to the lender of restructuring the loan is equal to or less than the cost of foreclosure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcc8bea8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the borrower is applying all income over and above necessary and reasonable living and operating expenses to the payment of primary obligations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcc8bea9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the borrower has the financial capacity and the management skills to protect the collateral from diversion, dissipation, or deterioration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcc8beaa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the borrower is capable of working out existing financial difficulties, reestablishing a viable operation, and repaying the loan on a rescheduled basis; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcc8beab-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a distressed loan that is not delinquent, whether restructuring consistent with sound lending practices may be taken to reasonably ensure that the loan will not become a loan that it is necessary to place in nonaccrual status.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc8beac-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications not required for restructuring plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not prevent a qualified lender from proposing a restructuring plan for an individual borrower in the absence of an application for restructuring from the borrower.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcc8bead-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restructuring","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcc8beae-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a qualified lender determines that the potential cost to such qualified lender of restructuring the loan in accordance with a proposed restructuring plan is less than or equal to the potential cost of foreclosure, the qualified lender shall restructure the loan in accordance with the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc8beaf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computation of cost of restructuring","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining whether the potential cost to the qualified lender of restructuring a distressed loan is less than or equal to the potential cost of foreclosure, a qualified lender shall consider all relevant factors, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcc8beb0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the present value of interest income and principal forgone by the lender in carrying out the restructuring plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcc8beb1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reasonable and necessary administrative expenses involved in working with the borrower to finalize and implement the restructuring plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcc8beb2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the borrower has presented a preliminary restructuring plan and cash-flow analysis taking into account income from all sources to be applied to the debt and all assets to be pledged, showing a reasonable probability that orderly debt retirement will occur as a result of the proposed restructuring; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcc8beb3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the borrower has furnished or is willing to furnish complete and current financial statements in a form acceptable to the institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcc8beb4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Least cost alternative","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If two or more restructuring alternatives are available to a qualified lender under this section with respect to a distressed loan, the lender shall restructure the loan in conformity with the alternative that results in the least cost to the lender.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcc8beb5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restructuring policy","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcc8beb6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each bank board of directors shall develop a policy within 60 days after ","children":[{"tag":"date","attrib":{"date":"1988-01-06"},"text":"January 6, 1988","children":[],"tail":", that is consistent with this section, to govern the restructuring of distressed loans. Such policy shall constitute the restructuring policy of each qualified lender within the district."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc8beb7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of policy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The policy established under paragraph (1) shall include an explanation of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcc8beb8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the procedure for submitting an application for restructuring; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcc8beb9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the right of borrowers with distressed loans to seek review by a credit review committee in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2202"},"text":"section 2202 of this title","children":[],"tail":" of a denial of an application for restructuring."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc8beba-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of policy to FCA","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each bank board shall submit the policy of the district governing the treatment of distressed loans under this section to the Farm Credit Administration. Notwithstanding the duty imposed by the preceding sentence, the other duties imposed by this section shall take effect on ","children":[{"tag":"date","attrib":{"date":"1988-01-06"},"text":"January 6, 1988","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcc8bebb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Farm Credit Administration may issue a directive requiring compliance with any provision of this section to any qualified lender that fails to comply with such provision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcc8bebc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permitted foreclosures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not be construed to prevent any qualified lender from enforcing any contractual provision that allows the lender to foreclose a loan, or from taking such other lawful action as the lender deems appropriate, if the lender has reasonable grounds to believe that the loan collateral will be destroyed, dissipated, consumed, concealed, or permanently removed from the State in which the collateral is located.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcc8bebd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of section","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The time limitation prescribed in subsection (b)(2), and the requirements of subsection (c), shall not apply to a loan that became a distressed loan before ","children":[{"tag":"date","attrib":{"date":"1988-01-06"},"text":"January 6, 1988","children":[],"tail":", if the borrower and lender of the loan are in the process of negotiating loan restructuring with respect to the loan."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcc8bebe-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202a/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance in restructuring","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Farm Credit Bank, on request of any association, may assist the association in restructuring loans under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcc8bebf-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tIV/s4"},"text":"Pub. L. 92–181, title IV, § 4","children":[],"tail":".14A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tI/s102/a"},"text":"Pub. L. 100–233, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1574"},"text":"101 Stat. 1574","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/tI/s102/a"},"text":"Pub. L. 100–399, title I, § 102(a)","children":[],"tail":"–(f), "},{"tag":"date","attrib":{"date":"1988-08-17"},"text":"Aug. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/990"},"text":"102 Stat. 990","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/105/tII/s208/a"},"text":"Pub. L. 104–105, title II, § 208(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/173"},"text":"110 Stat. 173","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tV/s5411/22"},"text":"Pub. L. 115–334, title V, § 5411(22)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4681"},"text":"132 Stat. 4681","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcc8bec0-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcc8bec1-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcc8bec2-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s5411/22/A/i"},"text":"Pub. L. 115–334, § 5411(22)(A)(i)","children":[],"tail":", inserted “and "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2219a"},"text":"section 2219a of this title","children":[],"tail":"” after “this part” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5)(B)(ii)(I). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s5411/22/A/ii"},"text":"Pub. L. 115–334, § 5411(22)(A)(ii)","children":[],"tail":", struck out “2202c,” after “2202b,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (h) to (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s5411/22/B"},"text":"Pub. L. 115–334, § 5411(22)(B)","children":[],"tail":", (C), redesignated subsecs. (i) to (k) as (h) to (j), respectively, and struck out former subsec. (h). Prior to amendment, text of subsec. (h) read as follows: “During the 5-year period beginning on "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"January 6, 1988","children":[],"tail":", each qualified lender shall submit semiannual reports to the Farm Credit Administration containing—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) the results of the review of distressed loans of the lender; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) the financial effect of loan restructurings and liquidations on the lender.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (k), (","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"). "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/s5411/22/C"},"text":"Pub. L. 115–334, § 5411(22)(C)","children":[],"tail":", (D), redesignated subsec. ("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":") as (k) and struck out “production credit” after “request of any”. Former subsec. (k) redesignated (j)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/105"},"text":"Pub. L. 104–105","children":[],"tail":" designated existing provisions as subpar. (A), inserted subpar. heading, substituted “Subject to subparagraph (B), the term” for “The term”, and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s102/a"},"text":"Pub. L. 100–399, § 102(a)","children":[],"tail":", struck out “(other than in sections 2205 and 2206 of this title)” after “in this part”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(6)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s102/b"},"text":"Pub. L. 100–399, § 102(b)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2015/b/1/B"},"text":"section 2015(b)(1)(B) of this title","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2074/a/2"},"text":"section 2074(a)(2) of this title","children":[],"tail":"” and “"},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2015/b/1"},"text":"section 2015(b)(1) of this title","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2074/a"},"text":"section 2074(a) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s102/c"},"text":"Pub. L. 100–399, § 102(c)","children":[],"tail":", substituted “cost to such qualified” for “cost to a qualified”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s102/d"},"text":"Pub. L. 100–399, § 102(d)","children":[],"tail":", substituted “bank” for “farm credit district”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s102/e"},"text":"Pub. L. 100–399, § 102(e)","children":[],"tail":", substituted “bank board” for “district board”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"). "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/s102/f"},"text":"Pub. L. 100–399, § 102(f)","children":[],"tail":", substituted “Farm Credit Bank” for “Federal intermediate credit bank”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcc8bec3-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcc8bec4-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by section 102(b), (f) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399"},"text":"Pub. L. 100–399","children":[],"tail":" effective immediately after amendment made by "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/s401"},"text":"section 401 of Pub. L. 100–233","children":[],"tail":", which was effective 6 months after "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", and amendment by section 102(a), (c)–(e) of "},{"tag":"ref","attrib":{"href":"/us/pl/100/399"},"text":"Pub. L. 100–399","children":[],"tail":" effective as if enacted immediately after enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/100/233"},"text":"Pub. L. 100–233","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/s1001"},"text":"section 1001 of Pub. L. 100–399","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2002"},"text":"section 2002 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddcc8bec5-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Sense of Congress","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/233/tI/s102/b"},"text":"Pub. L. 100–233, title I, § 102(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1579"},"text":"101 Stat. 1579","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/233/tI/s102/b"},"text":"“It is the sense of Congress that the banks and associations (except banks for cooperatives) operating under the Farm Credit Act of 1971 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2001"},"text":"12 U.S.C. 2001","children":[],"tail":" et seq.) should administer distressed loans to farmers with the objective of using the loan guarantee programs of the Farmers Home Administration and other loan restructuring measures, including participation in interest rate buy-down programs that are Federally or State funded, and other Federal and State sponsored financial assistance programs that offer relief to financially distressed farmers, as alternatives to foreclosure, considering the availability and appropriateness of such programs on a case-by-case basis.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
