{"tag":"section","attrib":{"id":"iddcd233a8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2277a–2"},"text":"§ 2277a–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board of Directors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcd233a9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation shall be managed by a Board of Directors that shall consist of the members of the Farm Credit Administration Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd233aa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairman","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board of Directors shall be chaired by any Board member other than the Chairman of the Farm Credit Administration Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcd233ab-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tV/s5"},"text":"Pub. L. 92–181, title V, § 5","children":[],"tail":".53, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tIII/s302"},"text":"Pub. L. 100–233, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1611"},"text":"101 Stat. 1611","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/552/tII/s201/a"},"text":"Pub. L. 102–552, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4104"},"text":"106 Stat. 4104","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/105/tII/s219/a"},"text":"Pub. L. 104–105, title II, § 219(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/184"},"text":"110 Stat. 184","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcd233ac-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcd233ad-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcd233ae-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/105"},"text":"Pub. L. 104–105","children":[],"tail":" amended section generally. Prior to amendment, section related to Board of Directors, including provisions relating to establishment, appointment, chairperson, postemployment prohibition, terms of office, succession, vacancies, oath, quorum, meetings, rules and records, compensation, and expenses."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/552"},"text":"Pub. L. 102–552","children":[],"tail":" amended section generally. Prior to amendment, section read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—The Corporation shall be managed by a Board of Directors that shall consist of the members of the Farm Credit Administration Board."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) ","children":[{"tag":"inline","attrib":{},"text":"Chairman","children":[],"tail":".—The Board of Directors shall be chaired by any Board member other than the Chairman of the Farm Credit Administration Board.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcd233af-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcd233b0-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment; Transition Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/552/tII/s201/c"},"text":"Pub. L. 102–552, title II, § 201(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4105"},"text":"106 Stat. 4105","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/552/tII/s201/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this section [amending this section and sections 5314 and 5315 of Title 5, Government Organization and Employees] shall become effective on ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"January 1, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transitional provision","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Board of Directors of the Farm Credit System Insurance Corporation as established by section 5.53 of the Farm Credit Act of 1971 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2277a–2"},"text":"12 U.S.C. 2277a–2","children":[],"tail":") (as it existed before the amendments made by subsection (a) of this section) shall continue in existence and continue to manage the Farm Credit System Insurance Corporation until at least two members are appointed by the President, by and with the advice and consent of the Senate, to the new Board established by section 5.53 of such Act (as amended by subsection (a) of this section).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
