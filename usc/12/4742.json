{"tag":"section","attrib":{"id":"iddd3d9f16-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4742"},"text":null,"children":[{"tag":"num","attrib":{"value":"4742"},"text":"§ 4742.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd3d9f17-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4742/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Fund” means the Community Development Financial Institutions Fund established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4703"},"text":"section 4703 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3d9f18-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4742/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “appropriate Federal banking agency”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd3d9f19-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4742/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"section 1813 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3d9f1a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4742/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes the National Credit Union Administration Board in the case of any credit union the deposits of which are insured in accordance with the Federal Credit Union Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1751"},"text":"12 U.S.C. 1751","children":[],"tail":" et seq.];"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3d9f1b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4742/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “early loan” means a loan enrolled at a time when the aggregate covered amount of loans previously enrolled under the Program by a particular participating financial institution is less than $5,000,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3d9f1c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4742/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “enrolled loan” means a loan made by a participating financial institution that is enrolled by a participating State in accordance with this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3d9f1d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4742/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “financial institution” means any federally chartered or State-chartered commercial bank, savings association, savings bank, or credit union;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3d9f1e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4742/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “participating financial institution” means any financial institution that has entered into a participation agreement with a participating State in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4744"},"text":"section 4744 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3d9f1f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4742/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “participating State” means any State that has been approved for participation in the Program in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4743"},"text":"section 4743 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3d9f20-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4742/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “passive real estate ownership” means ownership of real estate for the purpose of deriving income from speculation, trade, or rental, except that such term shall not include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd3d9f21-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4742/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ownership of that portion of real estate being used or intended to be used for the operation of the business of the owner of the real estate (other than the business of passive ownership of real estate); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3d9f22-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4742/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ownership of real estate for the purpose of construction or renovation, until the completion of the construction or renovation phase;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3d9f23-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4742/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Program” means the Small Business Capital Enhancement Program established under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3d9f24-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4742/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “reserve fund” means a fund, established by a participating State, earmarked for a particular participating financial institution, for the purposes of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd3d9f25-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4742/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" depositing all required premium charges paid by the participating financial institution and by each borrower receiving a loan under the Program from a participating financial institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3d9f26-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4742/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" depositing contributions made by the participating State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3d9f27-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4742/10/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" covering losses on enrolled loans by disbursing accumulated funds; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3d9f28-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4742/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “State” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd3d9f29-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4742/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3d9f2a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4742/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the District of Columbia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3d9f2b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4742/11/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any political subdivision of a State of the United States, which subdivision has a population in excess of the population of the least populated State of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3d9f2c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4742/11/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other political subdivision of a State of the United States that the Fund determines has the capacity to participate in the program.","children":[{"tag":"ref","attrib":{"idref":"fn002438"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002438"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be capitalized."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd3d9f2d-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/tII/s252"},"text":"Pub. L. 103–325, title II, § 252","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2204"},"text":"108 Stat. 2204","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd3d9f2e-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd3d9f2f-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd3d9f30-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Credit Union Act, referred to in par. (2)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-26/ch750"},"text":"act June 26, 1934, ch. 750","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/1216"},"text":"48 Stat. 1216","children":[],"tail":", which is classified generally to chapter 14 (§ 1751 et seq.) of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1751"},"text":"section 1751 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
