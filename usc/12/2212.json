{"tag":"section","attrib":{"id":"iddccb081d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2212"},"text":null,"children":[{"tag":"num","attrib":{"value":"2212"},"text":"§ 2212.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers of Farm Credit Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Farm Credit Administration shall have power, under rules and regulations prescribed by the Farm Credit Administration, to provide for the organization of any corporation chartered under this part and the territory within which its operations may be carried on, and to approve amendments consistent with this chapter to charters or articles of service corporations.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddccb081e-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tIV/s4"},"text":"Pub. L. 92–181, title IV, § 4","children":[],"tail":".26, as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/592/tIV/s404"},"text":"Pub. L. 96–592, title IV, § 404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-24"},"text":"Dec. 24, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3447"},"text":"94 Stat. 3447","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/205/tII/s205/f/9"},"text":"Pub. L. 99–205, title II, § 205(f)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1706"},"text":"99 Stat. 1706","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tVIII/s802/s"},"text":"Pub. L. 100–233, title VIII, § 802(s)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1712"},"text":"101 Stat. 1712","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddccb081f-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddccb0820-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddccb0821-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/233"},"text":"Pub. L. 100–233","children":[],"tail":" struck out “or by prescribing in the terms of the charter or by approval of the bylaws of the corporation” after second reference to Farm Credit Administration, substituted “approve amendments consistent with this chapter to charters or articles of service corporations” for “direct at any time such changes in its charter as the Farm Credit Administration finds necessary for the accomplishment of the purposes of this chapter”, and struck out last sentence which read as follows: “The powers of the Farm Credit Administration to provide for the organization of any corporation chartered under this part include, but are not limited to approval of—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) corporate title;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) general corporate powers;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) eligibility for membership on, and the powers, composition, selection, terms, and compensation of the board of directors;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) classes, issuance, value, and retirement of stock;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(5) sources of operating funds;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(6) dissolution, liquidation, and distribution of assets on liquidation; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(7) application and distribution of earnings.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/205"},"text":"Pub. L. 99–205","children":[],"tail":" substituted “Farm Credit Administration” for “Governor” in heading and wherever appearing in text, and substituted “the Federal Credit Administration” for “he” before “finds necessary” in first sentence."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddccb0822-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddccb0823-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1985 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/205"},"text":"Pub. L. 99–205","children":[],"tail":" effective thirty days after "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/205/s401"},"text":"section 401 of Pub. L. 99–205","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2001"},"text":"section 2001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
