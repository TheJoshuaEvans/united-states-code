{"tag":"section","attrib":{"id":"iddccd791c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2246"},"text":null,"children":[{"tag":"num","attrib":{"value":"2246"},"text":"§ 2246.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory committees","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Chairman of the Board, subject to the approval of the Board, may establish one or more advisory committees in accordance with chapter 10 of title 5 and may appoint to such committee or committees individuals who are members of the Federal Farm Credit Board when such Board is terminated by the Farm Credit Amendments Act of 1985.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddccd791d-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tV/s5"},"text":"Pub. L. 92–181, title V, § 5","children":[],"tail":".12, "},{"tag":"date","attrib":{"date":"1971-12-10"},"text":"Dec. 10, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/620"},"text":"85 Stat. 620","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/205/tII/s201/1"},"text":"Pub. L. 99–205, title II, § 201(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1690"},"text":"99 Stat. 1690","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tIV/s431/d"},"text":"Pub. L. 100–233, title IV, § 431(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1660"},"text":"101 Stat. 1660","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/56"},"text":"Pub. L. 117–286, § 4(a)(56)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"