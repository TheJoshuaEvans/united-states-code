{"tag":"section","attrib":{"id":"iddcea2801-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"2279aa–3"},"text":"§ 2279aa–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers and duties of Corporation and Board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcea2802-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guarantees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After the Board has been duly constituted, subject to the other provisions of this subchapter and other commitments and requirements established pursuant to law, the Corporation may provide guarantees on terms and conditions determined by the Corporation of securities issued on the security of, or in participation in, pooled interests in qualified loans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcea2803-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of Board","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcea2804-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–3/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcea2805-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–3/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine the general policies that shall govern the operations of the Corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcea2806-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–3/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" select, appoint, and determine the compensation of qualified persons to fill such offices as may be provided for in the bylaws of the Corporation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcea2807-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–3/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assign to such persons such executive functions, powers, and duties as may be prescribed by the bylaws of the Corporation or by the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcea2808-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–3/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Executive officers and functions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The persons elected or appointed under paragraph (1)(B) shall be the executive officers of the Corporation and shall discharge the executive functions, powers, and duties of the Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcea2809-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers of Corporation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Corporation shall be a body corporate and shall have the following powers:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcea280a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–3/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To operate under the direction of its Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcea280b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–3/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To issue stock in the manner provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2279aa–4"},"text":"section 2279aa–4 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcea280c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–3/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To adopt, alter, and use a corporate seal, which shall be judicially noted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcea280d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–3/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To provide for a president, 1 or more vice presidents, secretary, treasurer, and such other officers, employees, and agents, as may be necessary, define their duties and compensation levels, all without regard to title 5, and require surety bonds or make other provisions against losses occasioned by acts of such persons.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcea280e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–3/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To provide guarantees in the manner provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2279aa–6"},"text":"section 2279aa–6 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcea280f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–3/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To have succession until dissolved by a law enacted by the Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcea2810-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–3/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To prescribe bylaws, through the Board, not inconsistent with law, that shall provide for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcea2811-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–3/c/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the classes of the stock of the Corporation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcea2812-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–3/c/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the manner in which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddcea2813-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–3/c/7/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the stock shall be issued, transferred, and retired;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcea2814-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–3/c/7/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the officers, employees, and agents of the Corporation are selected;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcea2815-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–3/c/7/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the property of the Corporation is acquired, held, and transferred;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcea2816-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–3/c/7/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the commitments and other financial assistance of the Corporation are made;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcea2817-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–3/c/7/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the general business of the Corporation is conducted; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcea2818-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–3/c/7/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the privileges granted by law to the Corporation are exercised and enjoyed;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcea2819-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–3/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To prescribe such standards as may be necessary to carry out this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcea281a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–3/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To enter into contracts and make payments with respect to the contracts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcea281b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–3/c/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To sue and be sued in its corporate capacity and to complain and defend in any action brought by or against the Corporation in any State or Federal court of competent jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcea281c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–3/c/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To make and perform contracts, agreements, and commitments with persons and entities both inside and outside of the Farm Credit System.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcea281d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–3/c/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To acquire, hold, lease, mortgage or dispose of, at public or private sale, real and personal property, purchase or sell any securities or obligations, and otherwise exercise all the usual incidents of ownership of property necessary and convenient to the business of the Corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcea281e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–3/c/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To purchase, hold, sell, or assign a qualified loan, to issue a guaranteed security, representing an interest in, or an obligation backed by, the qualified loan, and to perform all the functions and responsibilities of an agricultural mortgage marketing facility operating as a certified facility under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcea281f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–3/c/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To establish, acquire, and maintain affiliates (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2279aa–11/e"},"text":"section 2279aa–11(e) of this title","children":[],"tail":") under applicable State laws to carry out any activities that otherwise would be performed directly by the Corporation under this subchapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcea2820-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–3/c/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To exercise such other incidental powers as are necessary to carry out the powers, duties, and functions of the Corporation in accordance with this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcea2821-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–3/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Reserve banks as depositaries and fiscal agents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal Reserve banks shall act as depositories for, and as fiscal agents or custodians of, the Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcea2822-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–3/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to book-entry system","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation shall have access to the book-entry system of the Federal Reserve System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcea2823-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tVIII/s8"},"text":"Pub. L. 92–181, title VIII, § 8","children":[],"tail":".3, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tVII/s702"},"text":"Pub. L. 100–233, title VII, § 702","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1691"},"text":"101 Stat. 1691","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/tVI/s601/c"},"text":"Pub. L. 100–399, title VI, § 601(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-17"},"text":"Aug. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1005"},"text":"102 Stat. 1005","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tV/s503/c"},"text":"Pub. L. 102–237, title V, § 503(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1877"},"text":"105 Stat. 1877","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/552/tIII/s308/b/1"},"text":"Pub. L. 102–552, title III, § 308(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4116"},"text":"106 Stat. 4116","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/105/tI"},"text":"Pub. L. 104–105, title I","children":[],"tail":", §§ 104, 105, "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/163"},"text":"110 Stat. 163","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcea2824-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcea2825-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcea2826-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (c)(13) to (15). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/105/s104"},"text":"Pub. L. 104–105, § 104","children":[],"tail":", added par. (13) and redesignated former pars. (13) and (14) as (14) and (15), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/105/s105/1"},"text":"Pub. L. 104–105, § 105(1)","children":[],"tail":", which directed the amendment of subsec. (d) by substituting “shall act as depositories for, and” for “may act as depositories for, or”, was executed by making the substitution for “may act as depositaries for, or” to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/105/s105/2"},"text":"Pub. L. 104–105, § 105(2)","children":[],"tail":", substituted “Corporation shall have access to” for “Secretary of the Treasury may authorize the Corporation to use”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (c)(13). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/552"},"text":"Pub. L. 102–552","children":[],"tail":" substituted “2279aa–11(e)” for “2279aa–11(g)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (c)(13), (14). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237"},"text":"Pub. L. 102–237","children":[],"tail":" added par. (13) and redesignated former par. (13) as (14)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399"},"text":"Pub. L. 100–399","children":[],"tail":" substituted “such persons” for “the persons”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcea2827-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcea2828-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399"},"text":"Pub. L. 100–399","children":[],"tail":" effective as if enacted immediately after enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/100/233"},"text":"Pub. L. 100–233","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/s1001/a"},"text":"section 1001(a) of Pub. L. 100–399","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2002"},"text":"section 2002 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
