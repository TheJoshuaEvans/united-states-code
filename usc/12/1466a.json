{"tag":"section","attrib":{"id":"iddb92ae99-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1466a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1466a"},"text":"§ 1466a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" District associations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddb92ae9a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1466a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Comptroller shall, with respect to all incorporated or unincorporated building, building or loan, building and loan, or homestead associations, and similar institutions, of or transacting or doing business in the District of Columbia, or maintaining any office in the District of Columbia (other than Federal savings associations), have the same powers and functions as to examination, operation, and regulation as the Comptroller has with respect to Federal savings associations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb92ae9b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1466a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional powers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any such association or institution incorporated under the laws of, or organized in, the District of Columbia shall have in addition to any existing statutory authority such statutory authority as is vested in Federal savings associations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb92ae9c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1466a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Charter amendments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Charters, certificates of incorporation, articles of incorporation, constitutions, bylaws, or other organic documents of associations or institutions referred to in subsection (b) of this section may, without regard to anything contained therein or otherwise, be amended in such manner and to such extent and upon such votes if any as the Comptroller may by regulation or otherwise provide.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb92ae9d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1466a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall cause, or permit the Comptroller to cause, District of Columbia associations to be or become Federal savings associations, or require the Comptroller to impose on District of Columbia associations the same regulations as are imposed on Federal savings associations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddb92ae9e-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-06-13/ch64/s8"},"text":"June 13, 1933, ch. 64, § 8","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/91/609/tIX/s913"},"text":"Pub. L. 91–609, title IX, § 913","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-31"},"text":"Dec. 31, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1815"},"text":"84 Stat. 1815","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/73/tIII/s301"},"text":"Pub. L. 101–73, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/315"},"text":"103 Stat. 315","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tIII/s369/6"},"text":"Pub. L. 111–203, title III, § 369(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1563"},"text":"124 Stat. 1563","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb92ae9f-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb92aea0-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"iddb92aea1-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 8 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-06-13/ch64"},"text":"act June 13, 1933, ch. 64","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/134"},"text":"48 Stat. 134","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1467"},"text":"section 1467 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645/s21"},"text":"act June 25, 1948, ch. 645, § 21","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/862"},"text":"62 Stat. 862","children":[],"tail":", eff. "},{"tag":"date","attrib":{"date":"1948-09-01"},"text":"Sept. 1, 1948","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddb92aea2-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" substituted “Comptroller” for “Director” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73"},"text":"Pub. L. 101–73","children":[],"tail":" amended section generally, substituting provisions relating to Director and Federal savings associations for former provisions relating to Federal Home Loan Bank Board and Federal savings and loan associations."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddb92aea3-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddb92aea4-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective on the transfer date, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s351"},"text":"section 351 of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s906"},"text":"section 906 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
