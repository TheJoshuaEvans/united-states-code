{"tag":"section","attrib":{"id":"iddb7f9c8a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1448"},"text":null,"children":[{"tag":"num","attrib":{"value":"1448"},"text":"§ 1448.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of partial invalidity of chapter","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If any provision of this chapter, or the application thereof to any person or circumstances, is held invalid, the remainder of the chapter, and the application of such provision to other persons or circumstances, shall not be affected thereby.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddb7f9c8b-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1932-07-22/ch522/s28"},"text":"July 22, 1932, ch. 522, § 28","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/47/740"},"text":"47 Stat. 740","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
