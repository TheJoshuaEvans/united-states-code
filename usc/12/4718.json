{"tag":"section","attrib":{"id":"iddd3b2fd1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4718"},"text":null,"children":[{"tag":"num","attrib":{"value":"4718"},"text":"§ 4718.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd3b2fd2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4718/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fund authorization","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd3b2fd3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4718/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To carry out this subchapter, there are authorized to be appropriated to the Fund, to remain available until expended—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd3b2fd4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4718/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $60,000,000 for fiscal year 1995;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3b2fd5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4718/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $104,000,000 for fiscal year 1996;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3b2fd6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4718/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $107,000,000 for fiscal year 1997; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3b2fd7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4718/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $111,000,000 for fiscal year 1998;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"or such greater sums as may be necessary to carry out this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3b2fd8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4718/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative expenses","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd3b2fd9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4718/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of amounts authorized to be appropriated to the Fund pursuant to this section, not more than $5,550,000 may be used by the Fund in each fiscal year to pay the administrative costs and expenses of the Fund. Costs associated with the training program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4708"},"text":"section 4708 of this title","children":[],"tail":" and the technical assistance program established under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4707"},"text":"section 4707 of this title","children":[],"tail":" shall not be considered to be administrative expenses for purposes of this paragraph."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3b2fda-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4718/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Calculations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amounts referred to in paragraphs (3) and (4) shall be calculated after subtracting the amount referred to in subparagraph (A) of this paragraph from the total amount appropriated to the Fund in accordance with paragraph (1) in any fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3b2fdb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4718/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capitalization assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 5 percent of the amounts authorized to be appropriated under paragraph (1) may be used as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4712"},"text":"section 4712 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3b2fdc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4718/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability for funding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4713"},"text":"section 4713 of this title","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"33⅓ percent of the amounts appropriated to the Fund for any fiscal year pursuant to the authorization in paragraph (1) shall be available for use in carrying out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4713"},"text":"section 4713 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3b2fdd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4718/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support of community development financial institutions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall allocate funds authorized under this section, to the maximum extent practicable, for the support of community development financial institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3b2fde-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4718/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community Development Credit Union Revolving Loan Fund","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated for the purposes of the Community Development Credit Union Revolving Loan Fund—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd3b2fdf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4718/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $4,000,000 for fiscal year 1995;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3b2fe0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4718/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $2,000,000 for fiscal year 1996;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3b2fe1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4718/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $2,000,000 for fiscal year 1997; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3b2fe2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4718/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $2,000,000 for fiscal year 1998.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3b2fe3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4718/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Budgetary treatment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts authorized to be appropriated under this section shall be subject to discretionary spending caps, as provided in section 665 ","children":[{"tag":"ref","attrib":{"idref":"fn002437"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002437"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 2, and therefore shall reduce by an equal amount funds made available for other discretionary spending programs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd3b2fe4-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/tI/s121"},"text":"Pub. L. 103–325, title I, § 121","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2189"},"text":"108 Stat. 2189","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd3b2fe5-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd3b2fe6-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd3b2fe7-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s665"},"text":"Section 665 of title 2","children":[],"tail":", referred to in subsec. (c), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/tX/s10118/a"},"text":"Pub. L. 105–33, title X, § 10118(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/695"},"text":"111 Stat. 695","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
