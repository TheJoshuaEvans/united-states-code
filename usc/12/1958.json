{"tag":"section","attrib":{"id":"iddcb7f50c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1958"},"text":null,"children":[{"tag":"num","attrib":{"value":"1958"},"text":"§ 1958.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall have the responsibility to assure compliance with the requirements of this chapter and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1829b"},"text":"section 1829b of this title","children":[],"tail":" and may delegate such responsibility to the appropriate bank supervisory agency, or other supervisory agency. The Secretary may rely on examinations conducted by a State supervisory agency of a category of financial institution, if the Secretary determines that the category of financial institution is required to comply with this chapter and "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1829b"},"text":"section 1829b of this title","children":[],"tail":" (and regulations prescribed under this chapter and "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1829b"},"text":"section 1829b of this title","children":[],"tail":"), or the State supervisory agency examines the category of financial institution for compliance with this chapter and "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1829b"},"text":"section 1829b of this title","children":[],"tail":" (and regulations prescribed under this chapter and "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1829b"},"text":"section 1829b of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddcb7f50d-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/508/tI/s128"},"text":"Pub. L. 91–508, title I, § 128","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-26"},"text":"Oct. 26, 1970","children":[],"tail":", "},{"tag":"ref","att