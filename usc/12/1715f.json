{"tag":"section","attrib":{"id":"iddbe16ab1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1715f"},"text":null,"children":[{"tag":"num","attrib":{"value":"1715f"},"text":"§ 1715f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Process of applications and issuance of commitments","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to process applications and issue commitments with respect to insurance of mortgages under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1706c"},"text":"section 1706c of this title","children":[],"tail":" and subchapter II, VI, VIII, or X of this chapter, even though the permanent mortgage financing may not be insured under this chapter, and in the event the mortgage is not so insured the Secretary is authorized to charge an additional application fee determined by him to be reasonable. The Secretary is authorized to make such rules and regulations as may be necessary to carry out the provisions of this section."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddbe16ab2-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-27/ch847"},"text":"June 27, 1934, ch. 847","children":[],"tail":", title II, § 215, as added "},{"tag":"ref","attrib":{"href":"/us/act/1950-04-20/ch94"},"text":"Apr. 20, 1950, ch. 94","children":[],"tail":", title I, § 115, "},{"tag":"ref","attrib":{"href":"/us/stat/64/56"},"text":"64 Stat. 56","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/act/1951-09-01/ch378"},"text":"Sept. 1, 1951, ch. 378","children":[],"tail":", title II, § 204, "},{"tag":"ref","attrib":{"href":"/us/stat/65/303"},"text":"65 Stat. 303","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/19/s1/a/3"},"text":"Pub. L. 90–19, § 1(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-05-25"},"text":"May 25, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/17"},"text":"81 Stat. 17","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddbe16ab3-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddbe16ab4-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddbe16ab5-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-27/ch847"},"text":"act June 27, 1934, ch. 847","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/1246"},"text":"48 Stat. 1246","children":[],"tail":", which is classified principally to this chapter (§ 1701 et seq.). For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddbe16ab6-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1967—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/19"},"text":"Pub. L. 90–19","children":[],"tail":" substituted “Secretary” for “Commissioner” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1951—Act ","children":[{"tag":"date","attrib":{"date":"1951-09-01"},"text":"Sept. 1, 1951","children":[],"tail":", inserted a reference to subchapter X of this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
