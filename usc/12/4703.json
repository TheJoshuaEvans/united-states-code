{"tag":"section","attrib":{"id":"iddd36749b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703"},"text":null,"children":[{"tag":"num","attrib":{"value":"4703"},"text":"§ 4703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of national Fund for community development banking","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd36749c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd36749d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established a corporation to be known as the Community Development Financial Institutions Fund that shall have the duties and responsibilities specified by this subchapter and subchapter II of this chapter. The Fund shall have succession until dissolved. The offices of the Fund shall be in Washington, D.C. The Fund shall not be affiliated with or be within any other agency or department of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd36749e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wholly owned Government corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Fund shall be a wholly owned Government corporation in the executive branch and shall be treated in all respects as an agency of the United States, except as otherwise provided in this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd36749f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management of Fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd3674a0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment of Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The management of the Fund shall be vested in an Administrator, who shall be appointed by the President. The Administrator shall not engage in any other business or employment during service as the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3674a1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chief financial officer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall appoint a chief financial officer, who shall have the authority and functions of an agency Chief Financial Officer under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s902"},"text":"section 902 of title 31","children":[],"tail":". In the event of a vacancy in the position of the Administrator or during the absence or disability of the Administrator, the chief financial officer shall perform the duties of the position of Administrator."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3674a2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other officers and employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may appoint such other officers and employees of the Fund as the Administrator determines to be necessary or appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3674a3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expedited hiring","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During the 2-year period beginning on ","children":[{"tag":"date","attrib":{"date":"1994-09-23"},"text":"September 23, 1994","children":[],"tail":", the Administrator may—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd3674a4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appoint and terminate the individuals referred to in paragraphs (2) and (3) without regard to the civil service laws and regulations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3674a5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fix the compensation of the individuals referred to in paragraph (3) without regard to the provisions of chapter 51 and subchapter III of chapter 53 of title 5 relating to classification of positions and General Schedule pay rates, except that the rate of pay for such individuals may not exceed the rate payable for level V of the Executive Schedule under section 5316 of such title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3674a6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General powers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the functions of the Fund, the Administrator—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd3674a7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall have all necessary and proper authority to carry out this subchapter and subchapter II of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3674a8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall have the power to adopt, alter, and use a corporate seal for the Fund, which shall be judicially noticed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3674a9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may adopt, amend, and repeal bylaws, rules, and regulations governing the manner in which business of the Fund may be conducted and such rules and regulations as may be necessary or appropriate to implement this subchapter and subchapter II of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3674aa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may enter into, perform, and enforce such agreements, contracts, and transactions as may be deemed necessary or appropriate to the conduct of activities authorized under this subchapter and subchapter II of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3674ab-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may determine the character of and necessity for expenditures of the Fund and the manner in which they shall be incurred, allowed, and paid;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3674ac-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may utilize or employ the services of personnel of any agency or instrumentality of the United States with the consent of the agency or instrumentality concerned on a reimbursable or nonreimbursable basis; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3674ad-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may execute all instruments necessary or appropriate in the exercise of any of the functions of the Fund under this subchapter and subchapter II of this chapter and may delegate to the officers of the Fund such of the powers and responsibilities of the Administrator as the Administrator deems necessary or appropriate for the administration of the Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3674ae-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Board","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd3674af-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established an advisory board to the Fund to be known as the Community Development Advisory Board, which shall be operated in accordance with the provisions of chapter 10 of title 5, except that ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013"},"text":"section 1013 of title 5","children":[],"tail":" does not apply to the Board."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3674b0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall consist of 15 members, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd3674b1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Agriculture or his or her designee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3674b2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Commerce or his or her designee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3674b3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Housing and Urban Development or his or her designee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3674b4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Interior or his or her designee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3674b5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Treasury or his or her designee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3674b6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/d/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator of the Small Business Administration or his or her designee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3674b7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/d/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 9 private citizens, appointed by the President, who shall be selected, to the maximum extent practicable, to provide for national geographic representation and racial, ethnic, and gender diversity, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd3674b8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/d/2/G/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 individuals who are officers of existing community development financial institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd3674b9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/d/2/G/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 individuals who are officers of insured depository institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd3674ba-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/d/2/G/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 individuals who are officers of national consumer or public interest organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd3674bb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/d/2/G/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 individuals who have expertise in community development; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd3674bc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/d/2/G/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 individual who has personal experience and specialized expertise in the unique lending and community development issues confronted by Indian tribes on Indian reservations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3674bd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members of the Board specified in paragraph (2)(G) shall select, by majority vote, a chairperson of the Board, who shall serve for a term of 2 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3674be-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board function","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall be the function of the Board to advise the Administrator on the policies of the Fund regarding activities under this subchapter. The Board shall not advise the Administrator on the granting or denial of any particular application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3674bf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms of private members","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd3674c0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each member of the Board appointed under paragraph (2)(G) shall serve for a term of 4 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3674c1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any member appointed to fill a vacancy occurring prior to the expiration of the term for which the previous member was appointed shall be appointed for the remainder of such term. Members may continue to serve following the expiration of their terms until a successor is appointed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3674c2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall meet at least annually and at such other times as requested by the Administrator or the chairperson. A majority of the members of the Board shall constitute a quorum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3674c3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement for expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members of the Board may receive reimbursement for travel, per diem, and other necessary expenses incurred in the performance of their duties, in accordance with chapter 10 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3674c4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Costs and expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Fund shall provide to the Board all necessary staff and facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3674c5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3674c6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Government Corporation Control Act exemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s9107/b"},"text":"Section 9107(b) of title 31","children":[],"tail":", shall not apply to deposits of the Fund made pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4707"},"text":"section 4707 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3674c7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation of Fund and Federal liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The liability of the Fund and the United States Government arising out of any investment in a community development financial institution in accordance with this subchapter shall be limited to the amount of the investment. The Fund shall be exempt from any assessments and other liabilities that may be imposed on controlling or principal shareholders by any Federal law or the law of any State, Territory, or the District of Columbia. Nothing in this subsection shall affect the application of any Federal tax law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3674c8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on issuance of securities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Fund may not issue stock, bonds, debentures, notes, or other securities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3674c9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3674ca-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assisted institutions not United States instrumentalities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A community development financial institution or other organization that receives assistance pursuant to this subchapter shall not be deemed to be an agency, department, or instrumentality of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3674cb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transition period","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd3674cc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/k/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During the transition period, the Secretary of the Treasury may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd3674cd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/k/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist in the establishment of the administrative functions of the Fund listed in paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3674ce-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/k/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hire not more than 6 individuals to serve as employees of the Fund during the transition period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3674cf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/k/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continued service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Individuals hired in accordance with paragraph (1)(B) may continue to serve as employees of the Fund after the transition period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3674d0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/k/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The administrative functions referred to in paragraph (1)(A) shall be limited to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd3674d1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/k/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing accounting, information, and recordkeeping systems for the Fund; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3674d2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/k/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procuring office space, equipment, and supplies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3674d3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/k/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expedited hiring","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During the transition period, the Secretary of the Treasury may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd3674d4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/k/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appoint and terminate the individuals referred to in paragraph (1)(B) without regard to the civil service laws and regulations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3674d5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/k/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fix the compensation of the individuals referred to in paragraph (1)(B) without regard to the provisions of chapter 51 and subchapter III of chapter 53 of title 5 relating to classification of positions and General Schedule pay rates, except that the rate of pay for such individuals may not exceed the rate payable for level V of the Executive Schedule under section 5316 of such title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3674d6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/k/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"During the transition period, employees of the Department of the Treasury may only comprise less than one-half of the total number of individuals hired in accordance with paragraph (1)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3674d7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/k/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transition expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts previously appropriated to the Department of the Treasury may be used to pay obligations and expenses of the Fund incurred under this section, and such amounts may be reimbursed by the Fund to the Department of the Treasury from amounts appropriated to the Fund for fiscal year 1995.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3674d8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4703/k/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Transition period” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, the term “transition period” means the period beginning on ","children":[{"tag":"date","attrib":{"date":"1994-09-23"},"text":"September 23, 1994","children":[],"tail":", and ending on the date on which the Administrator is appointed."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd3674d9-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/tI/s104"},"text":"Pub. L. 103–325, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2166"},"text":"108 Stat. 2166","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/166/s2/w"},"text":"Pub. L. 112–166, § 2(w)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-10"},"text":"Aug. 10, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1289"},"text":"126 Stat. 1289","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/57"},"text":"Pub. L. 117–286, § 4(a)(57)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4311"},"text":"136 Stat. 4311","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd3674da-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd3674db-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd3674dc-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/s104"},"text":"section 104 of Pub. L. 103–325","children":[],"tail":". Subsecs. (e) and (i) of "},{"tag":"ref","attrib":{"href":"/us/pl/103/325/s104"},"text":"section 104 of Pub. L. 103–325","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s9101"},"text":"section 9101 of Title 31","children":[],"tail":", Money and Finance, and "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"section 5313 of Title 5","children":[],"tail":", Government Organization and Employees, respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd38bdcd-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/57/A"},"text":"Pub. L. 117–286, § 4(a)(57)(A)","children":[],"tail":", substituted “chapter 10 of title 5, except that "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013"},"text":"section 1013 of title 5","children":[],"tail":"” for “the Federal Advisory Committee Act, except that section 14 of that Act”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/57/B"},"text":"Pub. L. 117–286, § 4(a)(57)(B)","children":[],"tail":", substituted “chapter 10 of title 5.” for “the Federal Advisory Committee Act.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/166"},"text":"Pub. L. 112–166","children":[],"tail":" struck out “, by and with the advice and consent of the Senate” before period at end of first sentence."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd38bdce-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd38bdcf-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/166"},"text":"Pub. L. 112–166","children":[],"tail":" effective 60 days after "},{"tag":"date","attrib":{"date":"2012-08-10"},"text":"Aug. 10, 2012","children":[],"tail":", and applicable to appointments made on and after that effective date, including any nomination pending in the Senate on that date, see "},{"tag":"ref","attrib":{"href":"/us/pl/112/166/s6/a"},"text":"section 6(a) of Pub. L. 112–166","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s113"},"text":"section 113 of Title 6","children":[],"tail":", Domestic Security."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd38bdd0-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Administration of Fund by Secretary of the Treasury","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/134/tI/s101/e/tIII"},"text":"Pub. L. 104–134, title I, § 101(e) [title III]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-26"},"text":"Apr. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1321-257"},"text":"110 Stat. 1321–257","children":[],"tail":", 1321–294; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/104/140/s1/a"},"text":"Pub. L. 104–140, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-05-02"},"text":"May 2, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1327"},"text":"110 Stat. 1327","children":[],"tail":", provided in part: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/140/s1/a"},"text":"“That notwithstanding any other provision of law, for purposes of administering the Community Development Financial Institutions Fund, the Secretary of the Treasury shall have all powers and rights of the Administrator of the CDBFI Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4701"},"text":"12 U.S.C. 4701","children":[],"tail":" et seq.] and the Fund shall be within the Department of the Treasury.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following prior appropriations act:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/19/tI"},"text":"Pub. L. 104–19, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-07-27"},"text":"July 27, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/237"},"text":"109 Stat. 237","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
