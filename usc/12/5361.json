{"tag":"section","attrib":{"id":"iddd556eac-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5361"},"text":null,"children":[{"tag":"num","attrib":{"value":"5361"},"text":"§ 5361.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports by and examinations of nonbank financial companies by the Board of Governors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd556ead-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5361/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd556eae-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5361/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board of Governors may require each nonbank financial company supervised by the Board of Governors, and any subsidiary thereof, to submit reports under oath, to keep the Board of Governors informed as to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd556eaf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5361/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the financial condition of the company or subsidiary, systems of the company or subsidiary for monitoring and controlling financial, operating, and other risks, and the extent to which the activities and operations of the company or subsidiary pose a threat to the financial stability of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd556eb0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5361/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compliance by the company or subsidiary with the requirements of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd556eb1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5361/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of existing reports and information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out subsection (a), the Board of Governors shall, to the fullest extent possible, use—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd556eb2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5361/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reports and supervisory information that a nonbank financial company or subsidiary thereof has been required to provide to other Federal or State regulatory agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd556eb3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5361/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information otherwise obtainable from Federal or State regulatory agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd556eb4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5361/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information that is otherwise required to be reported publicly; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd556eb5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5361/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" externally audited financial statements of such company or subsidiary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd556eb6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5361/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon the request of the Board of Governors, a nonbank financial company supervised by the Board of Governors, or a subsidiary thereof, shall promptly provide to the Board of Governors any information described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd556eb7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5361/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data standards for reports under this subsection","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd556eb8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5361/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board of Governors shall adopt data standards for all information that, through a collection of information, is regularly filed with or submitted to the Board of Governors under this subsection by any nonbank financial company supervised by the Board of Governors or any subsidiary thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd556eb9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5361/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consistency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The data standards required under subparagraph (A) shall incorporate, and ensure compatibility with (to the extent feasible), all applicable data standards established in the rules promulgated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5334"},"text":"section 5334 of this title","children":[],"tail":", including, to the extent practicable, by having the characteristics described in clauses (i) through (vi) of subsection (c)(1)(B) of "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5334"},"text":"section 5334 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd556eba-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5361/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Examinations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd556ebb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5361/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2), the Board of Governors may examine any nonbank financial company supervised by the Board of Governors and any subsidiary of such company, to inform the Board of Governors of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd556ebc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5361/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature of the operations and financial condition of the company and such subsidiary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd556ebd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5361/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the financial, operational, and other risks of the company or such subsidiary that may pose a threat to the safety and soundness of such company or subsidiary or to the financial stability of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd556ebe-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5361/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the systems for monitoring and controlling such risks; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd556ebf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5361/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compliance by the company or such subsidiary with the requirements of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd556ec0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5361/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of examination reports and information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, the Board of Governors shall, to the fullest extent possible, rely on reports of examination of any subsidiary depository institution or functionally regulated subsidiary made by the primary financial regulatory agency for that subsidiary, and on information described in subsection (a)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd556ec1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5361/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with primary financial regulatory agency","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board of Governors shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd556ec2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5361/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide reasonable notice to, and consult with, the primary financial regulatory agency for any subsidiary before requiring a report or commencing an examination of such subsidiary under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd556ec3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5361/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" avoid duplication of examination activities, reporting requirements, and requests for information, to the fullest extent possible.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd556ec4-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tI/s161"},"text":"Pub. L. 111–203, title I, § 161","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1420"},"text":"124 Stat. 1420","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLVIII/s5861/a"},"text":"Pub. L. 117–263, div. E, title LVIII, § 5861(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3434"},"text":"136 Stat. 3434","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd556ec5-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd556ec6-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd556ec7-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in subsecs. (a)(1)(B) and (b)(1)(D), was in the original “this title”, meaning title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1391"},"text":"124 Stat. 1391","children":[],"tail":", which is classified principally to this subchapter. For complete classification of title I to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd556ec8-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" added par. (4)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd556ec9-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd556eca-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rule of Construction Regarding No New Disclosure Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" not to be construed to require certain additional information to be collected or disclosed, see "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/s5864"},"text":"section 5864 of Pub. L. 117–263","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s253"},"text":"section 253 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
