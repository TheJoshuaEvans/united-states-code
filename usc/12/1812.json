{"tag":"section","attrib":{"id":"iddc5fc24f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1812"},"text":null,"children":[{"tag":"num","attrib":{"value":"1812"},"text":"§ 1812.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc5fc250-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1812/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board of Directors","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc5fc251-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1812/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The management of the Corporation shall be vested in a Board of Directors consisting of 5 members—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc5fc252-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1812/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 of whom shall be the Comptroller of the Currency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc5fc253-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1812/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 of whom shall be the Director of the Consumer Financial Protection Bureau; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc5fc254-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1812/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3 of whom shall be appointed by the President, by and with the advice and consent of the Senate, from among individuals who are citizens of the United States, 1 of whom shall have State bank supervisory experience.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc5fc255-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1812/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Political affiliation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After ","children":[{"tag":"date","attrib":{"date":"1993-02-28"},"text":"February 28, 1993","children":[],"tail":", not more than 3 of the members of the Board of Directors may be members of the same political party."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc5fc256-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1812/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson and Vice Chairperson","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc5fc257-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1812/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"1 of the appointed members shall be designated by the President, by and with the advice and consent of the Senate, to serve as Chairperson of the Board of Directors for a term of 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc5fc258-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1812/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vice Chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"1 of the appointed members shall be designated by the President, by and with the advice and consent of the Senate, to serve as Vice Chairperson of the Board of Directors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc5fc259-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1812/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acting Chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the event of a vacancy in the position of Chairperson of the Board of Directors or during the absence or disability of the Chairperson, the Vice Chairperson shall act as Chairperson.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc5fc25a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1812/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc5fc25b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1812/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointed members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each appointed member shall be appointed for a term of 6 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc5fc25c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1812/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interim appointments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any member appointed to fill a vacancy occurring before the expiration of the term for which such member’s predecessor was appointed shall be appointed only for the remainder of such term.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc5fc25d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1812/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuation of service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chairperson, Vice Chairperson, and each appointed member may continue to serve after the expiration of the term of office to which such member was appointed until a successor has been appointed and qualified.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc5fc25e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1812/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancy","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc5fc25f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1812/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any vacancy on the Board of Directors shall be filled in the manner in which the original appointment was made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc5fc260-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1812/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acting officials may serve","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the event of a vacancy in the office of the Comptroller of the Currency or the office of Director of the Consumer Financial Protection Bureau and pending the appointment of a successor, or during the absence or disability of the Comptroller of the Currency or the Director of the Consumer Financial Protection Bureau, the acting Comptroller of the Currency or the acting Director of the Consumer Financial Protection Bureau, as the case may be, shall be a member of the Board of Directors in the place of the Comptroller or Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc5fc261-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1812/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ineligibility for other offices","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc5fc262-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1812/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Postservice restriction","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc5fc263-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1812/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No member of the Board of Directors may hold any office, position, or employment in any insured depository institution or any depository institution holding company during—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddc5fc264-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1812/e/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the time such member is in office; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc5fc265-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1812/e/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 2-year period beginning on the date such member ceases to serve on the Board of Directors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc5fc266-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1812/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for members who serve full term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The limitation contained in subparagraph (A)(ii) shall not apply to any member who has ceased to serve on the Board of Directors after serving the full term for which such member was appointed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc5fc267-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1812/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction during service","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No member of the Board of Directors may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc5fc268-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1812/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be an officer or director of any insured depository institution, depository institution holding company, Federal Reserve bank, or Federal home loan bank; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc5fc269-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1812/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hold stock in any insured depository institution or depository institution holding company.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc5fc26a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1812/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon taking office, each member of the Board of Directors shall certify under oath that such member has complied with this subsection and such certification shall be filed with the secretary of the Board of Directors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc5fc26b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1812/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status of employees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc5fc26c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1812/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A director, member, officer, or employee of the Corporation has no liability under the Securities Act of 1933 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s77a"},"text":"15 U.S.C. 77a","children":[],"tail":" et seq.] with respect to any claim arising out of or resulting from any act or omission by such person within the scope of such person’s employment in connection with any transaction involving the disposition of assets (or any interests in any assets or any obligations backed by any assets) by the Corporation. This subsection shall not be construed to limit personal liability for criminal acts or omissions, willful or malicious misconduct, acts or omissions for private gain, or any other acts or omissions outside the scope of such person’s employment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc5fc26d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1812/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Employee of the Corporation” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, the term “employee of the Corporation” includes any employee of the Office of the Comptroller of the Currency or of the Consumer Financial Protection Bureau who serves as a deputy or assistant to a member of the Board of Directors of the Corporation in connection with activities of the Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc5fc26e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1812/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on other law","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This subsection does not affect—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc5fc26f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1812/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other immunities and protections that may be available to such person under applicable law with respect to such transactions, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc5fc270-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1812/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other right or remedy against the Corporation, against the United States under applicable law, or against any person other than a person described in paragraph (1) participating in such transactions.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"This subsection shall not be construed to limit or alter in any way the immunities that are available under applicable law for Federal officials and employees not described in this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc5fc271-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-21/ch967/s2"},"text":"Sept. 21, 1950, ch. 967, § 2","children":[],"tail":"[2], "},{"tag":"ref","attrib":{"href":"/us/stat/64/873"},"text":"64 Stat. 873","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/230/s19"},"text":"Pub. L. 86–230, § 19","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-09-08"},"text":"Sept. 8, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/460"},"text":"73 Stat. 460","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/181/tI"},"text":"Pub. L. 98–181, title I","children":[],"tail":" [title VII, § 702(a)], "},{"tag":"date","attrib":{"date":"1983-11-30"},"text":"Nov. 30, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1267"},"text":"97 Stat. 1267","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/73/tII/s203/a"},"text":"Pub. L. 101–73, title II, § 203(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/188"},"text":"103 Stat. 188","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/18/tI/s103/b"},"text":"Pub. L. 102–18, title I, § 103(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-03-23"},"text":"Mar. 23, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/60"},"text":"105 Stat. 60","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tII/s2243"},"text":"Pub. L. 104–208, div. A, title II, § 2243","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-419"},"text":"110 Stat. 3009–419","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tIII/s336/a"},"text":"Pub. L. 111–203, title III, § 336(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1540"},"text":"124 Stat. 1540","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc5fc272-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc5fc273-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddc5fc274-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Securities Act of 1933, referred to in subsec. (f)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-05-27/ch38/tI"},"text":"act May 27, 1933, ch. 38, title I","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/74"},"text":"48 Stat. 74","children":[],"tail":", which is classified generally to subchapter I (§ 77a et seq.) of chapter 2A of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s77a"},"text":"section 77a of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"iddc5fc275-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section is derived from subsec. (b) of former ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s264"},"text":"section 264 of this title","children":[],"tail":". See Codification note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1811"},"text":"section 1811 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc5fc276-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s336/a/1"},"text":"Pub. L. 111–203, § 336(a)(1)","children":[],"tail":", substituted “Director of the Consumer Financial Protection Bureau” for “Director of the Office of Thrift Supervision”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s336/a/2"},"text":"Pub. L. 111–203, § 336(a)(2)","children":[],"tail":", amended par. (2) generally. Prior to amendment, text read as follows: “In the event of a vacancy in the office of the Comptroller of the Currency or the office of Director of the Office of Thrift Supervision and pending the appointment of a successor, or during the absence or disability of the Comptroller or such Director, the acting Comptroller of the Currency or the acting Director of the Office of Thrift Supervision, as the case may be, shall be a member of the Board of Directors in the place of the Comptroller or Director.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s336/a/3"},"text":"Pub. L. 111–203, § 336(a)(3)","children":[],"tail":", substituted “Consumer Financial Protection Bureau” for “Office of Thrift Supervision”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" inserted “, 1 of whom shall have State bank supervisory experience” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/18"},"text":"Pub. L. 102–18","children":[],"tail":" added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73"},"text":"Pub. L. 101–73","children":[],"tail":" amended section generally, designating existing provisions as subsecs. (a) to (e), and making other changes relating to the make-up and operation of the Board."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/181"},"text":"Pub. L. 98–181","children":[],"tail":" inserted provision that each such appointive member may continue to serve after the expiration of his term until a successor has been appointed and qualified."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1959—","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/230"},"text":"Pub. L. 86–230","children":[],"tail":" provided for membership of Acting Comptroller of the Currency on Board of Directors during absence or disability of Comptroller instead of only during his absence from Washington."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc5fc277-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddc5fc278-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tIII/s336/b"},"text":"Pub. L. 111–203, title III, § 336(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1540"},"text":"124 Stat. 1540","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/203/tIII/s336/b"},"text":"“This section [amending this section], and the amendments made by this section, shall take effect on the transfer date.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definition of “transfer date” as used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s336/b"},"text":"section 336(b) of Pub. L. 111–203","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"section 5301 of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddc5fc279-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transition Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/tII/s203/b"},"text":"Pub. L. 101–73, title II, § 203(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/189"},"text":"103 Stat. 189","children":[],"tail":", which permitted the Chairman of the Board of Directors of the Federal Deposit Insurance Corporation on "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", to continue to serve as the Chairperson until the end of the term to which such Chairman was appointed (notwithstanding any provision of this section), provided that the appointed member of the Board on "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", who is not the Chairman continue to serve in office until the earlier of the end of the term to which such member was appointed or "},{"tag":"date","attrib":{"date":"1993-02-28"},"text":"Feb. 28, 1993","children":[],"tail":", with certain exceptions, and provided that the term of any member appointed to the Board before "},{"tag":"date","attrib":{"date":"1993-02-28"},"text":"Feb. 28, 1993","children":[],"tail":" (including the term of any Chairperson), end on such date, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tIII/s367/1"},"text":"Pub. L. 111–203, title III, § 367(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1556"},"text":"124 Stat. 1556","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddc5fc27a-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Compensation of Board of Directors","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Compensation of Chairman and members of the Board, see sections 5314 and 5315 of Title 5, Government Organization and Employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
