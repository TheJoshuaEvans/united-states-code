{"tag":"section","attrib":{"id":"iddd281c57-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4546"},"text":null,"children":[{"tag":"num","attrib":{"value":"4546"},"text":"§ 4546.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of public disclosure of proprietary information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd281c58-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4546/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (d), the Director may, by regulation or order, provide that certain information shall be treated as proprietary information and not subject to disclosure under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4543"},"text":"section 4543 of this title","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1723a/n/3"},"text":"section 1723a(n)(3) of this title","children":[],"tail":", or "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1456/f/3"},"text":"section 1456(f)(3) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd281c59-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4546/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of information on housing activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall not provide public access to, or disclose to the public, any information required to be submitted by an enterprise under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1723a/n"},"text":"section 1723a(n) of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1456/f"},"text":"section 1456(f) of this title","children":[],"tail":" that the Director determines is proprietary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd281c5a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4546/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nondisclosure pending consideration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section may not be construed to authorize the disclosure of information to, or examination of data by, the public or a representative of any person or agency pending the issuance of a final decision under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd281c5b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4546/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mortgage information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to privacy considerations, as described in section 304(j) of the Home Mortgage Disclosure Act of 1975 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2803/j"},"text":"12 U.S.C. 2803(j)","children":[],"tail":"), the Director shall, by regulation or order, provide that certain information relating to single family mortgage data of the enterprises shall be disclosed to the public, in order to make available to the public—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd281c5c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4546/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the same data from the enterprises that is required of insured depository institutions under the Home Mortgage Disclosure Act of 1975 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2801"},"text":"12 U.S.C. 2801","children":[],"tail":" et seq.]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd281c5d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4546/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information collected by the Director under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4544/b/6"},"text":"section 4544(b)(6) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd281c5e-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXIII/s1326"},"text":"Pub. L. 102–550, title XIII, § 1326","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3955"},"text":"106 Stat. 3955","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tI"},"text":"Pub. L. 110–289, div. A, title I","children":[],"tail":", §§ 1122(a)(1), 1127, "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2689"},"text":"122 Stat. 2689","children":[],"tail":", 2695.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd281c5f-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd281c60-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd281c61-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Home Mortgage Disclosure Act of 1975, referred to in subsec. (d)(1), is title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/200"},"text":"Pub. L. 94–200","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-31"},"text":"Dec. 31, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/1125"},"text":"89 Stat. 1125","children":[],"tail":", which is classified principally to chapter 29 (§ 2801 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2801"},"text":"section 2801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd281c62-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/s1122/a/1"},"text":"Pub. L. 110–289, § 1122(a)(1)","children":[],"tail":", substituted “Director” for “Secretary” wherever appearing in subsecs. (a) and (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/s1127/1"},"text":"Pub. L. 110–289, § 1127(1)","children":[],"tail":", substituted “Subject to subsection (d), the Director” for “The Director”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/s1127/2"},"text":"Pub. L. 110–289, § 1127(2)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
