{"tag":"section","attrib":{"id":"iddba37845-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701p"},"text":null,"children":[{"tag":"num","attrib":{"value":"1701p"},"text":"§ 1701p.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of report to President and Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The annual report made by the Secretary of Housing and Urban Development to the President for submission to the Congress on all operations provided for by section 1701","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title shall contain pertinent information with respect to all projects for which any loan, contribution, or grant has been made by the Department of Housing and Urban Development, including the amount of loans, contributions and grants contracted for."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddba37846-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-02/ch649"},"text":"Aug. 2, 1954, ch. 649","children":[],"tail":", title VIII, § 817, "},{"tag":"ref","attrib":{"href":"/us/stat/68/648"},"text":"68 Stat. 648","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/19/s10/j"},"text":"Pub. L. 90–19, § 10(j)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-05-25"},"text":"May 25, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/23"},"text":"81 Stat. 23","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/375/tII/s207/a"},"text":"Pub. L. 97–375, title II, § 207(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-12-21"},"text":"Dec. 21, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1824"},"text":"96 Stat. 1824","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddba37847-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddba37848-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddba37849-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Housing Act of 1954, and not as part of the National Housing Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddba3784a-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/375"},"text":"Pub. L. 97–375","children":[],"tail":" struck out requirement for the inclusion of pertinent information respecting all builders’ cost certifications required by "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1715r"},"text":"section 1715r of this title","children":[],"tail":", including amounts paid by mortgagors to mortgagees for application to the reduction of the principal obligations of the mortgages pursuant to that section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1967—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/19"},"text":"Pub. L. 90–19","children":[],"tail":" substituted “Secretary of Housing and Urban Development” and “Department of Housing and Urban Development” for “Housing and Home Finance Administrator” and “Housing and Home Finance Agency”, respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
