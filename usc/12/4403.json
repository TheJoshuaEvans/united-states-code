{"tag":"section","attrib":{"id":"iddd20ef8e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4403"},"text":null,"children":[{"tag":"num","attrib":{"value":"4403"},"text":"§ 4403.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bilateral netting","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd20ef8f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4403/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of State or Federal law (other than ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1821/e"},"text":"section 1821(e) of this title","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5390/c"},"text":"section 5390(c) of this title","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4617"},"text":"section 4617 of this title","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1787/c"},"text":"section 1787(c) of this title","children":[],"tail":", or any order authorized under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78eee/b/2"},"text":"section 78eee(b)(2) of title 15","children":[],"tail":"), the covered contractual payment obligations and the covered contractual payment entitlements between any 2 financial institutions shall be terminated, liquidated, accelerated, and netted in accordance with, and subject to the conditions of, the terms of any applicable netting contract (except as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s561/b/2"},"text":"section 561(b)(2) of title 11","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd20ef90-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4403/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on obligation to make payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The only obligation, if any, of a financial institution to make payment with respect to covered contractual payment obligations to another financial institution shall be equal to its net obligation to such other financial institution, and no such obligation shall exist if there is no net obligation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd20ef91-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4403/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on right to receive payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The only right, if any, of a financial institution to receive payments with respect to covered contractual payment entitlements from another financial institution shall be equal to its net entitlement with respect to such other financial institution, and no such right shall exist if there is no net entitlement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd20ef92-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4403/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of net entitlement of failed financial institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The net entitlement of any failed financial institution, if any, shall be paid to the failed financial institution in accordance with, and subject to the conditions of, the applicable netting contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd20ef93-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4403/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effectiveness notwithstanding status as financial institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall be given effect notwithstanding that a financial institution is a failed financial institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd20ef94-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4403/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforceability of security agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of any security agreement or arrangement or other credit enhancement related to one or more netting contracts between any 2 financial institutions shall be enforceable in accordance with their terms (except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s561/b/2"},"text":"section 561(b)(2) of title 11","children":[],"tail":"), and shall not be stayed, avoided, or otherwise limited by any State or Federal law (other than "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1821/e"},"text":"section 1821(e) of this title","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1787/c"},"text":"section 1787(c) of this title","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78eee/b/2"},"text":"section 78eee(b)(2) of title 15","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd20ef95-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/tIV/s403"},"text":"Pub. L. 102–242, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2374"},"text":"105 Stat. 2374","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/8/tIX/s906/b"},"text":"Pub. L. 109–8, title IX, § 906(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/168"},"text":"119 Stat. 168","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/390/s4/a"},"text":"Pub. L. 109–390, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-12"},"text":"Dec. 12, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2695"},"text":"120 Stat. 2695","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tII/s211/c"},"text":"Pub. L. 111–203, title II, § 211(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1514"},"text":"124 Stat. 1514","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd20ef96-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd20ef97-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd20ef98-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" inserted “"},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5390/c"},"text":"section 5390(c) of this title","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4617"},"text":"section 4617 of this title","children":[],"tail":",” after “"},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1821/e"},"text":"section 1821(e) of this title","children":[],"tail":",”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/390"},"text":"Pub. L. 109–390","children":[],"tail":" struck out “paragraphs (8)(E), (8)(F), and (10)(B) of” before “section 1821(e)” and “section 1787(c)” and inserted “terminated, liquidated, accelerated, and” after “institutions shall be”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/390/s4/a/1"},"text":"Pub. L. 109–390, § 4(a)(1)","children":[],"tail":", struck out “paragraphs (8)(E), (8)(F), and (10)(B) of” before “section 1821(e)” and “section 1787(c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/s906/b/1"},"text":"Pub. L. 109–8, § 906(b)(1)","children":[],"tail":", added subsec. (a) and struck out heading and text of former subsec. (a). Text read as follows: “Notwithstanding any other provision of law, the covered contractual payment obligations and the covered contractual payment entitlements between any 2 financial institutions shall be netted in accordance with, and subject to the conditions of, the terms of any applicable netting contract.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/s906/b/2"},"text":"Pub. L. 109–8, § 906(b)(2)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"st