{"tag":"section","attrib":{"id":"iddc183293-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1716"},"text":null,"children":[{"tag":"num","attrib":{"value":"1716"},"text":"§ 1716.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Declaration of purposes of subchapter","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Congress declares that the purposes of this subchapter are to establish secondary market facilities for residential mortgages, to provide that the operations thereof shall be financed by private capital to the maximum extent feasible, and to authorize such facilities to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc183294-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1716/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide stability in the secondary market for residential mortgages;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc183295-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1716/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" respond appropriately to the private capital market;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc183296-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1716/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide ongoing assistance to the secondary market for residential mortgages (including activities relating to mortgages on housing for low- and moderate-income families involving a reasonable economic return that may be less than the return earned on other activities) by increasing the liquidity of mortgage investments and improving the distribution of investment capital available for residential mortgage financing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc183297-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1716/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote access to mortgage credit throughout the Nation (including central cities, rural areas, and underserved areas) by increasing the liquidity of mortgage investments and improving the distribution of investment capital available for residential mortgage financing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc183298-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1716/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" manage and liquidate federally owned mortgage portfolios in an orderly manner, with a minimum of adverse effect upon the residential mortgage market and minimum loss to the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc183299-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-27/ch847"},"text":"June 27, 1934, ch. 847","children":[],"tail":", title III, § 301, "},{"tag":"ref","attrib":{"href":"/us/stat/48/1252"},"text":"48 Stat. 1252","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1935-05-28/ch150/s30"},"text":"May 28, 1935, ch. 150, § 30","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/300"},"text":"49 Stat. 300","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1938-02-03/ch13"},"text":"Feb. 3, 1938, ch. 13","children":[],"tail":", §§ 4, 5, "},{"tag":"ref","attrib":{"href":"/us/stat/52/23"},"text":"52 Stat. 23","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1939-06-03/ch175"},"text":"June 3, 1939, ch. 175","childr