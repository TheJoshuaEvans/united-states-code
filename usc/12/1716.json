t/1952-07-14/ch723"},"text":"July 14, 1952, ch. 723","children":[],"tail":", §§ 3(a), 10(a)(2), "},{"tag":"ref","attrib":{"href":"/us/stat/66/602"},"text":"66 Stat. 602","children":[],"tail":", 603; "},{"tag":"ref","attrib":{"href":"/us/act/1953-06-30/ch170"},"text":"June 30, 1953, ch. 170","children":[],"tail":", §§ 12, 13(a), "},{"tag":"ref","attrib":{"href":"/us/stat/67/125"},"text":"67 Stat. 125","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1954-06-29/ch410/s1/1"},"text":"June 29, 1954, ch. 410, § 1(1)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/320"},"text":"68 Stat. 320","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-02/ch649"},"text":"Aug. 2, 1954, ch. 649","children":[],"tail":", title II, § 201, "},{"tag":"ref","attrib":{"href":"/us/stat/68/612"},"text":"68 Stat. 612","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/448/tVIII/s802/b"},"text":"Pub. L. 90–448, title VIII, § 802(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-08-01"},"text":"Aug. 1, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/536"},"text":"82 Stat. 536","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/73/tVII/s731/m/1"},"text":"Pub. L. 101–73, title VII, § 731(m)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/435"},"text":"103 Stat. 435","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXIII/s1381/a"},"text":"Pub. L. 102–550, title XIII, § 1381(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3994"},"text":"106 Stat. 3994","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc18329a-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc18329b-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc18329c-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/s1381/a/1"},"text":"Pub. L. 102–550, § 1381(a)(1)","children":[],"tail":", substituted “residential” for “home” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/s1381/a/1"},"text":"Pub. L. 102–550, § 1381(a)(1)","children":[],"tail":", substituted “residential” for “home”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/s1381/a/1"},"text":"Pub. L. 102–550, § 1381(a)(1)","children":[],"tail":", (2), substituted “residential” for “home” in two places, substituted “(including activities relating to mortgages on housing for low- and moderate-income families involving a reasonable economic return that may be less than the return earned on other activities)” for “(including mortgages securing housing for low- and moderate-income families involving a reasonable economic return)”, and struck out “and” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/s1381/a/3"},"text":"Pub. L. 102–550, § 1381(a)(3)","children":[],"tail":", (4), added par. (4) and redesignated former par. (4) as (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/s1381/a/1"},"text":"Pub. L. 102–550, § 1381(a)(1)","children":[],"tail":", (3), redesignated par. (4) as (5) and substituted “residential” for “home”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73"},"text":"Pub. L. 101–73","children":[],"tail":" added pars. (1) to (3), struck out subsecs. (a) and (b), and redesignated subsec. (c) as par. (4). Prior to amendment, subsecs. (a) and (b) related to supplementary assistance to the secondary market and to provision of special assistance, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1968—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/448"},"text":"Pub. L. 90–448","children":[],"tail":" struck out provisions which established in the Federal Government a secondary market facility for home mortgages in view of "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1716b"},"text":"section 1716b of this title","children":[],"tail":" which created two separate and distinct corporations."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1954—Act ","children":[{"tag":"date","attrib":{"date":"1954-08-02"},"text":"Aug. 2, 1954","children":[],"tail":", amended section generally, substituting entirely new provisions for provisions now covered by "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1717"},"text":"section 1717 of this title","children":[],"tail":" and other sections in this subchapter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(G). Act ","children":[{"tag":"date","attrib":{"date":"1954-06-29"},"text":"June 29, 1954","children":[],"tail":", substituted in first sentence “"},{"tag":"date","attrib":{"date":"1954-08-01"},"text":"August 1, 1954","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1954-07-01"},"text":"July 1, 1954","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1953—Subsec. (a)(1)(E). Act ","children":[{"tag":"date","attrib":{"date":"1953-06-30"},"text":"June 30, 1953","children":[],"tail":", § 12, in cl. (2), substituted “principal amount to be paid therefor” for “unpaid principal balance thereof”, and “aggregate principal amount” for “aggregate amount”; and substituted three provisos for former proviso which made such cl. (2) and any terms therein inapplicable to any defense or disaster mortgages as defined in subpar. (G) of par. (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(G). Act ","children":[{"tag":"date","attrib":{"date":"1953-06-30"},"text":"June 30, 1953","children":[],"tail":", § 13(a), substituted in first sentence “"},{"tag":"date","attrib":{"date":"1954-07-01"},"text":"July 1, 1954","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1953-07-01"},"text":"July 1, 1953","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1952—Subsec. (a)(1). Act ","children":[{"tag":"date","attrib":{"date":"1952-07-14"},"text":"July 14, 1952","children":[],"tail":", § 3(a)(1), authorized the FNMA to purchase Government-insured or guaranteed home mortgages other than defense or disaster mortgages if they are insured after "},{"tag":"date","attrib":{"date":"1952-02-29"},"text":"Feb. 29, 1952","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(E). Act ","children":[{"tag":"date","attrib":{"date":"1952-07-14"},"text":"July 14, 1952","children":[],"tail":", § 3(a)(2), (3), changed the base date from "},{"tag":"date","attrib":{"date":"1948-04-30"},"text":"Apr. 30, 1948","children":[],"tail":" to "},{"tag":"date","attrib":{"date":"1952-02-29"},"text":"Feb. 29, 1952","children":[],"tail":", and exempted defense or disaster mortgages from the limitation of this subparagraph."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(G). Act ","children":[{"tag":"date","attrib":{"date":"1952-07-14"},"text":"July 14, 1952","children":[],"tail":", § 3(a)(4), increased the FNMA commitment powers from $252,000,000 to $1,152,000,000 outstanding at any one time if the commitments relate to defense or disaster mortgages."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"S.J. Res. ","children":[{"tag":"date","attrib":{"date":"1952-04-09"},"text":"Apr. 9, 1952","children":[],"tail":", increased the $200,000,000 authorization to $252,000,000 and struck out "},{"tag":"date","attrib":{"date":"1951-12-31"},"text":"Dec. 31, 1951","children":[],"tail":", deadline, (1) with respect to programed defense housing for which applications were received prior to "},{"tag":"date","attrib":{"date":"1951-12-28"},"text":"Dec. 28, 1951","children":[],"tail":", and (2) with respect to subchapter VIII military housing if the commitment to insure the mortgage was issued after Dec. 27 and before "},{"tag":"date","attrib":{"date":"1951-12-31"},"text":"Dec. 31, 1951","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). Act ","children":[{"tag":"date","attrib":{"date":"1952-07-14"},"text":"July 14, 1952","children":[],"tail":", inserted “Guam,” after “District of Columbia”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1951—Subsec. (a)(1). Act ","children":[{"tag":"date","attrib":{"date":"1951-09-01"},"text":"Sept. 1, 1951","children":[],"tail":", § 205, inserted reference to subchapter X of this chapter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(G). Act ","children":[{"tag":"date","attrib":{"date":"1951-09-01"},"text":"Sept. 1, 1951","children":[],"tail":", § 608(b), inserted proviso."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1950—Act ","children":[{"tag":"date","attrib":{"date":"1950-04-20"},"text":"Apr. 20, 1950","children":[],"tail":", § 122, substituted “Commissioner” for “Administrator” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). Act ","children":[{"tag":"date","attrib":{"date":"1950-04-20"},"text":"Apr. 20, 1950","children":[],"tail":", § 116(1), (2), inserted “or "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1706c"},"text":"section 1706c of this title","children":[],"tail":"” and first proviso."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(E). Act ","children":[{"tag":"date","attrib":{"date":"1950-04-20"},"text":"Apr. 20, 1950","children":[],"tail":", § 116(3), substituted new proviso for former proviso."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(F). Act ","children":[{"tag":"date","attrib":{"date":"1950-04-20"},"text":"Apr. 20, 1950","children":[],"tail":", § 116(4), substituted provision that no loan made to finance the purchase price or construction cost of a dwelling was to be purchased by the Federal National Mortgage Association unless the Administrator of Veterans’ Affairs certifies that such dwelling conforms with minimum construction requirements prescribed by the Administrator for former provision that such certification was to be given by the mortgagee and that minimum construction standards were to be determined by the provisions within the National Housing Act."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(G). Act ","children":[{"tag":"date","attrib":{"date":"1950-04-20"},"text":"Apr. 20, 1950","children":[],"tail":", § 116(5), added par. (1)(G)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1949—Subsec. (a). Act ","children":[{"tag":"date","attrib":{"date":"1949-08-08"},"text":"Aug. 8, 1949","children":[],"tail":", inserted reference to subchapter VIII in par. (1), and inserted proviso at end of par. (1)(E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(E). Joint Res. ","children":[{"tag":"date","attrib":{"date":"1949-10-25"},"text":"Oct. 25, 1949","children":[],"tail":", struck out proviso and inserted new proviso."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1948—Act ","children":[{"tag":"date","attrib":{"date":"1948-07-01"},"text":"July 1, 1948","children":[],"tail":", amended section generally to create a Federal National Mortgage Association with power to purchase, service, or sell insured or guaranteed mortgage, provide for the powers and succession of the Association, and to eliminate the former national mortgage association."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). Act ","children":[{"tag":"date","attrib":{"date":"1948-08-10"},"text":"Aug. 10, 1948","children":[],"tail":", §§ 201, 202, substituted “subchapter II or VI of this chapter” for “section 1709 or 1738 of this title”, inserted “after "},{"tag":"date","attrib":{"date":"1948-04-30"},"text":"April 30, 1948","children":[],"tail":"”, after “or guaranteed”, and substituted “50” for “25” in cl. (2) of par. (1) (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1941—Subsec. (a)(2). Act ","children":[{"tag":"date","attrib":{"date":"1941-03-28"},"text":"Mar. 28, 1941","children":[],"tail":", substituted “subchapters II and VI” for “subchapter II”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1939—Subsec. (b). Act ","children":[{"tag":"date","attrib":{"date":"1939-06-03"},"text":"June 3, 1939","children":[],"tail":", amended last sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). Act ","children":[{"tag":"date","attrib":{"date":"1939-06-03"},"text":"June 3, 1939","children":[],"tail":", inserted “Alaska, Hawaii or Puerto Rico”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1938—Subsec. (a). Act ","children":[{"tag":"date","attrib":{"date":"1938-02-03"},"text":"Feb. 3, 1938","children":[],"tail":", amended provisions generally, and among other changes, substituted “60 per centum” in subsec. (a)(3), for “80 per centum”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). Act ","children":[{"tag":"date","attrib":{"date":"1938-02-03"},"text":"Feb. 3, 1938","children":[],"tail":", substituted “$2,000,000” for “$5,000,000,” and “that at least 25 per centum thereof has been paid in cash,” for “paid in full in cash”, and inserted “or in first mortgages or such other first liens as are described in section 301 (a) hereof, which mortgages or liens shall be taken at such value as the Administrator may determine, not exceeding (except as to mortgages insured under title II of this Act) 60 per centum of the appraised value of the property as of the date of subscription, and that the remainder of the subscription to such capital stock is payable in the same manner and at such time as may be determined by the Administrator: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That no association shall issue notes, bonds, debentures, or other such obligations until such time as such subscriptions are paid in full in cash or Government securities at their par value or in mortgages or other liens as hereinbefore set forth”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1935—Subsec. (d). Act ","children":[{"tag":"date","attrib":{"date":"1935-05-28"},"text":"May 28, 1935","children":[],"tail":", substituted “$5,000,000” for “$2,000,000”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc18329d-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddc18329e-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1968 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of amendment by title VIII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/448"},"text":"Pub. L. 90–448","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/90/448/s808"},"text":"section 808 of Pub. L. 90–448","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1716b"},"text":"section 1716b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddc18329f-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1949 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Joint Res. ","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-10-25/ch729/s7"},"text":"Oct. 25, 1949, ch. 729, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/906"},"text":"63 Stat. 906","children":[],"tail":", provided in part: “That the amendment made by this section 7 with respect to mortgages guaranteed under section 501 of the Servicemen’s Readjustment Act of 1944, as amended [this section], shall apply only to such mortgages guaranteed after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1949-10-25"},"text":"Oct. 25, 1949","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddc1832a0-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Service or Sale of Mortgages Purchased Prior to ","children":[{"tag":"date","attrib":{"date":"1948-07-01"},"text":"July 1, 1948","children":[],"tail":"; Fulfillment of Prior Commitments"}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1948-07-01/ch784/s2"},"text":"Act July 1, 1948, ch. 784, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/1209"},"text":"62 Stat. 1209","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/act/1948-07-01/ch784/s2"},"text":"“Nothing in the amendment made by the first section of this Act [amending sections 1716, 1717 to 1721 of this title] shall limit the authority of the Federal National Mortgage Association to service or sell any mortgage purchased prior to the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1948-07-01"},"text":"July 1, 1948","children":[],"tail":"], or to purchase, service, or sell any mortgage with respect to which a commitment to purchase was made p