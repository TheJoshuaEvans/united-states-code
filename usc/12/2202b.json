{"tag":"section","attrib":{"id":"iddcc8bec6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2202b"},"text":"§ 2202b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of restructuring on borrower stock","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcc8bec7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Farm Credit Bank","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a Farm Credit Bank forgives and writes off, under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2202a"},"text":"section 2202a of this title","children":[],"tail":", any of the principal outstanding on a loan made to any borrower, the Federal land bank association of which the borrower is a member and stockholder shall cancel the same dollar amount of borrower stock held by the borrower in respect of the loan, up to the total amount of such stock, and, to the extent provided for in the bylaws of the bank relating to its capitalization, the bank shall retire an equal amount of stock owned by the Federal land bank association."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcc8bec8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Production credit association","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a production credit association forgives and writes off, under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2202a"},"text":"section 2202a of this title","children":[],"tail":", any of the principal outstanding on a loan made to any borrower, the association shall cancel the same dollar amount of borrower stock held by the borrower in respect of the loan, up to the total amount of such stock."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcc8bec9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2202b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retention of stock","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subsections (a) and (b), the borrower shall be entitled to retain at least one share of stock to maintain the borrower’s membership and voting interest in the association.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcc8beca-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tIV/s4"},"text":"Pub. L. 92–181, title IV, § 4","children":[],"tail":".14B, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tI/s102/a"},"text":"Pub. L. 100–233, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1577"},"text":"101 Stat. 1577","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/tI/s102/g"},"text":"Pub. L. 100–399, title I, § 102(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-17"},"text":"Aug. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/990"},"text":"102 Stat. 990","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcc8becb-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcc8becc-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcc8becd-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399"},"text":"Pub. L. 100–399","children":[],"tail":" substituted in subsec. heading “Farm Credit Bank” for “Federal land bank” and in text “a Farm Credit Bank” for “a Federal land bank” and “, to the extent provided for in the bylaws of the bank relating to capitalization, the bank shall” for “the Federal land bank shall”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcc8bece-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcc8becf-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399"},"text":"Pub. L. 100–399","children":[],"tail":" effective immediately after amendment made by "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/s401"},"text":"section 401 of Pub. L. 100–233","children":[],"tail":", which was effective 6 months after "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/s1001/b"},"text":"section 1001(b) of Pub. L. 100–399","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2002"},"text":"section 2002 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
