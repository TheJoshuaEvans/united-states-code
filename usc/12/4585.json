{"tag":"section","attrib":{"id":"iddd2cd758-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4585"},"text":null,"children":[{"tag":"num","attrib":{"value":"4585"},"text":"§ 4585.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil money penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd2cd759-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4585/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director may impose a civil money penalty, in accordance with the provisions of this section, on any enterprise that has failed to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2cd75a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4585/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit a report under section 4547 ","children":[{"tag":"ref","attrib":{"idref":"fn002420"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002420"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title, following a notice of such failure, an opportunity for comment by the enterprise, and a final determination by the Director;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2cd75b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4585/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit the information required under subsection (m) or (n) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1723a"},"text":"section 1723a of this title","children":[],"tail":" or subsection (e) or (f) of "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1456"},"text":"section 1456 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2cd75c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4585/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" solely with respect to the housing goals established under sections 4562(a) and 4563(a)(1) of this title, submit a housing plan or perform its responsibilities under a remedial order issued pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4566/c"},"text":"section 4566(c) of this title","children":[],"tail":" within the required period; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2cd75d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4585/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" solely with respect to the housing goals established under sections 4562(a) and 4563(a)(1) of this title, comply with a housing plan for the enterprise under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4566/c"},"text":"section 4566(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2cd75e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4585/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of penalty","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of a penalty under this section, as determined by the Director, may not exceed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2cd75f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4585/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any failure described in paragraph (1), (5), or (6) of subsection (a), $100,000 for each day that the failure occurs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2cd760-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4585/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any failure described in paragraph (2), (3), or (4) of subsection (a), $50,000 for each day that the failure occurs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2cd761-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4585/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2cd762-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4585/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall establish standards and procedures governing the imposition of civil money penalties under this section. Such standards and procedures—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd2cd763-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4585/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall provide for the Director to notify the enterprise in writing of the determination of the Director to impose the penalty, which shall be made on the record;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd2cd764-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4585/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall provide for the imposition of a penalty only after the enterprise has been given an opportunity for a hearing on the record pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4582"},"text":"section 4582 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd2cd765-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4585/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may provide for review by the Director of any determination or order, or interlocutory ruling, arising from a hearing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2cd766-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4585/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors in determining amount of penalty","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining the amount of a penalty under this section, the Director shall give consideration to factors including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd2cd767-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4585/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the gravity of the offense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd2cd768-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4585/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any history of prior offenses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd2cd769-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4585/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ability to pay the penalty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd2cd76a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4585/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" injury to the public;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd2cd76b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4585/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" benefits received;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd2cd76c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4585/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deterrence of future violations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd2cd76d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4585/c/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the length of time that the enterprise should reasonably take to achieve the goal; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd2cd76e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4585/c/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other factors as the Director may determine, by regulation, to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2cd76f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4585/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action to collect penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an enterprise fails to comply with an order by the Director imposing a civil money penalty under this section, after the order is no longer subject to review, as provided in sections 4582 and 4583 of this title, the Director may bring an action in the United States District Court for the District of Columbia to obtain a monetary judgment against the enterprise, and such other relief as may be available. The monetary judgment may, in the court’s discretion, include the attorneys’ fees and other expenses incurred by the United States in connection with the action. In an action under this subsection, the validity and appropriateness of the order imposing the penalty shall not be subject to review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2cd770-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4585/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Settlement by Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may compromise, modify, or remit any civil money penalty which may be, or has been, imposed under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2cd771-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4585/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit of penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall use any civil money penalties collected under this section to help fund the Housing Trust Fund established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4568"},"text":"section 4568 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd2cd772-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXIII/s1345"},"text":"Pub. L. 102–550, title XIII, § 1345","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tI/s1130/d/2"},"text":"Pub. L. 110–289, div. A, title I, § 1130(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2709"},"text":"122 Stat. 2709","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd2cd773-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd2cd774-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd2cd775-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4547"},"text":"Section 4547 of this title","children":[],"tail":", referred to in subsec. (a)(1), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tI/s1104/b"},"text":"Pub. L. 110–289, div. A, title I, § 1104(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2667"},"text":"122 Stat. 2667","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"iddd2cd776-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 4585, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXIII/s1345"},"text":"Pub. L. 102–550, title XIII, § 1345","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3966"},"text":"106 Stat. 3966","children":[],"tail":", related to civil money penalties, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tI/s1130/d/1"},"text":"Pub. L. 110–289, div. A, title I, § 1130(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2709"},"text":"122 Stat. 2709","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
