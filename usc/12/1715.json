{"tag":"section","attrib":{"id":"iddbdcaf66-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1715"},"text":null,"children":[{"tag":"num","attrib":{"value":"1715"},"text":"§ 1715.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statistical and economic surveys","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall cause to be made in connection with the insurance programs such statistical surveys and legal and economic studies as he shall deem useful to guide the development of housing and the creation of a sound mortgage market in the United States, and shall publish from time to time the results of such surveys and studies. Expenses of such studies and surveys, and expenses of publication and distribution of the results of such studies and surveys, shall be charged as a general expense of such insurance fund or funds, as the Secretary shall determine.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddbdcaf67-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-27/ch847"},"text":"June 27, 1934, ch. 847","children":[],"tail":", title II, § 209, "},{"tag":"ref","attrib":{"href":"/us/stat/48/1252"},"text":"48 Stat. 1252","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1938-02-03/ch13/s3"},"text":"Feb. 3, 1938, ch. 13, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/22"},"text":"52 Stat. 22","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1941-03-28/ch31/s4/c"},"text":"Mar. 28, 1941, ch. 31, § 4(c)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/55/62"},"text":"55 Stat. 62","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1950-04-20/ch94"},"text":"Apr. 20, 1950, ch. 94","children":[],"tail":", title I, § 122, "},{"tag":"ref","attrib":{"href":"/us/stat/64/59"},"text":"64 Stat. 59","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/70/tVI/s612/d"},"text":"Pub. L. 87–70, title VI, § 612(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-06-30"},"text":"June 30, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/181"},"text":"75 Stat. 181","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/117/tXI/s1108/f"},"text":"Pub. L. 89–117, title XI, § 1108(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-08-10"},"text":"Aug. 10, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/504"},"text":"79 Stat. 504","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/19/s1/a/3"},"text":"Pub. L. 90–19, § 1(a)(3)","children":[],"tail":", (f), "},{"tag":"date","attrib":{"date":"1967-05-25"},"text":"May 25, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/17"},"text":"81 Stat. 17","children":[],"tail":", 18.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddbdcaf68-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddbdcaf69-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddbdcaf6a-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1967—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/19"},"text":"Pub. L. 90–19","children":[],"tail":" substituted “Secretary” for “Commissioner” wherever appearing and inserted “in connection with the insurance programs” after “made”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1965—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/117"},"text":"Pub. L. 89–117","children":[],"tail":" struck out “or account or accounts,” after “fund or funds,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1961—","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/70"},"text":"Pub. L. 87–70","children":[],"tail":" substituted “shall be charged as a general expense of such insurance fund or funds, or account or accounts, as the Commissioner shall determine” for “shall be charged as a general expense of the Fund, the Housing Fund, and the Defense Housing Insurance Fund in such proportion as the Commissioner shall determine”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1950—Act ","children":[{"tag":"date","attrib":{"date":"1950-04-20"},"text":"Apr. 20, 1950","children":[],"tail":", substituted “Commissioner” for “Administrator” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1941—Act ","children":[{"tag":"date","attrib":{"date":"1941-03-28"},"text":"Mar. 28, 1941","children":[],"tail":", substituted “Fund, the Housing Fund, and the Defense Housing Insurance Fund” for “Fund and the Housing Fund”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1938—Act ","children":[{"tag":"date","attrib":{"date":"1938-02-03"},"text":"Feb. 3, 1938","children":[],"tail":", inserted “and the Housing Fund in such proportion as the Administrator shall determine” after “Fund”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
