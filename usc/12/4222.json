{"tag":"section","attrib":{"id":"iddd1e7f2a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4222"},"text":null,"children":[{"tag":"num","attrib":{"value":"4222"},"text":"§ 4222.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of declarations","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"A declaration filed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4221"},"text":"section 4221 of this title","children":[],"tail":" shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd1e7f2b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4222/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set forth the name and address of the declarant and the basis for the declarant’s knowledge of the facts alleged;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1e7f2c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4222/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allege under oath or affirmation specific facts indicating the nature, location, and approximate dollar value of the asset or assets and the names of all persons known to the declarant to have possession, custody, or control of the asset or assets; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1e7f2d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4222/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allege under oath or affirmation specific facts that establish a prima facie case showing that the asset is legally subject to attachment, garnishment, sequestration, or other proceeding in satisfaction of the judgment referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4221"},"text":"section 4221 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd1e7f2e-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXV/s2577"},"text":"Pub. L. 101–647, title XXV, § 2577","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4900"},"text":"104 Stat. 4900","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
