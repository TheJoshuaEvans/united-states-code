{"tag":"section","attrib":{"id":"iddccb089a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2219b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2219b"},"text":"§ 2219b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of uninsured accounts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddccb089b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2219b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Money of a borrower held by a Farm Credit System institution in an uninsured voluntary or involuntary account as authorized under regulations issued by the Farm Credit Administration (as in effect immediately before ","children":[{"tag":"date","attrib":{"date":"1988-01-06"},"text":"January 6, 1988","children":[],"tail":"), including all such other accounts known as “advanced payment accounts” or “future prepayment accounts” shall, in the event the institution is placed in liquidation, be immediately applied as payment against the indebtedness of any outstanding loans of such borrower."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddccb089c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2219b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Farm Credit Administration shall promulgate regulations—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddccb089d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2219b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that define the term “uninsured voluntary or involuntary account”; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddccb089e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2219b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to otherwise effectively carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddccb089f-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tIV/s4"},"text":"Pub. L. 92–181, title IV, § 4","children":[],"tail":".37, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tI/s110"},"text":"Pub. L. 100–233, title I, § 110","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1585"},"text":"101 Stat. 1585","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddccb08a0-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddccb08a1-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddccb08a2-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 4.37 of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181"},"text":"Pub. L. 92–181","children":[],"tail":" was renumbered section 4.38 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2219c"},"text":"section 2219c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],