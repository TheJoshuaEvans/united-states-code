{"tag":"section","attrib":{"id":"iddd25aae1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4514a"},"text":null,"children":[{"tag":"num","attrib":{"value":"4514a"},"text":"§ 4514a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study and reports on guarantee fees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd25aae2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4514a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ongoing study of fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall conduct an ongoing study of fees charged by enterprises for guaranteeing a mortgage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd25aae3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4514a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection of data","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall, by regulation or order, establish procedures for the collection of data from enterprises for purposes of this subsection,","children":[{"tag":"ref","attrib":{"idref":"fn002404"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002404"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “section”."}],"tail":" including the format and the process for collection of such data."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd25aae4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4514a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall annually submit a report to Congress on the results of the study conducted under subsection (a), based on the aggregated data collected under subsection (a) for the subject year, regarding the amount of such fees and the criteria used by the enterprises to determine such fees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd25aae5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4514a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The reports required under subsection (c) shall identify and analyze—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd25aae6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4514a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the factors considered in determining the amount of the guarantee fees charged;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd25aae7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4514a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total revenue earned by the enterprises from guarantee fees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd25aae8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4514a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total costs incurred by the enterprises for providing guarantees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd25aae9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4514a/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average guarantee fee charged by the enterprises;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd25aaea-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4514a/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of any increase or decrease in guarantee fees from the preceding year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd25aaeb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4514a/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a breakdown of the revenue and costs associated with providing guarantees, based on product type and risk classifications; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd25aaec-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4514a/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a breakdown of guarantee fees charged based on asset size of the originator and the number of loans sold or transferred to an enterprise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd25aaed-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4514a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section may be construed to require or authorize the Director to publicly disclose information that is confidential or proprietary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd25aaee-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tVI/s1601"},"text":"Pub. L. 110–289, div. A, title VI, § 1601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2824"},"text":"122 Stat. 2824","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd25aaef-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd25aaf0-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd25aaf1-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Federal Housing Finance Regulatory Reform Act of 2008, and also as part of the Housing and Economic Recovery Act of 2008, and not as part of the Federal Housing Enterprises Financial Safety and Soundness Act of 1992 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd25aaf2-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"iddd25aaf3-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of terms used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/s1002/b"},"text":"section 1002(b) of Pub. L. 110–289","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4511"},"text":"section 4511 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
