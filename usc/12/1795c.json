{"tag":"section","attrib":{"id":"iddc5b07a4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1795c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1795c"},"text":"§ 1795c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc5b07a5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1795c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit unions serving natural persons","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A credit union primarily serving natural persons may be a Regular member of the Facility by subscribing to the capital stock of the Facility in an amount not less than one-half of 1 per centum of the credit union’s paid-in and unimpaired capital and surplus.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc5b07a6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1795c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit unions serving other credit unions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A credit union or group of credit unions, primarily serving other credit unions, may be an Agent member of the Facility by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc5b07a7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1795c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtaining the approval of the Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc5b07a8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1795c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subscribing to the capital stock of the Facility in an amount not less than one-half of 1 per centum of the paid-in and unimpaired capital and surplus of all those credit unions which primarily serve natural persons, which are members of such credit union or of any credit union comprising such credit union group, and which are not regular members;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc5b07a9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1795c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agreeing to comply with rules and regulations the Board shall prescribe with respect to, but not limited to, management quality, asset and liability safety and soundness, internal operating and control practices and procedures, and participation of natural persons in the affairs of such credit union or credit union group; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc5b07aa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1795c/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agreeing to submit to the supervision of the Board which shall include, but not be limited to, reporting requirements and periodic unrestricted examinations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc5b07ab-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1795c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stock subscription requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Stock subscriptions provided for in subsections (a) and (b)(2) of this section shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc5b07ac-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1795c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" based on an arithmetic average of paid-in capital and surplus over the six months preceding application and membership; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc5b07ad-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1795c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adjusted at the close of each calendar year in accordance with an arithmetic average of paid-in capital and surplus over a period determined by the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc5b07ae-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1795c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions of Agent members of Facility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An Agent member of the Facility shall perform for its member credit unions those functions required by the Board to carry out this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc5b07af-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1795c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal from or termination of membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc5b07b0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1795c/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member of the Facility whose capital stock subscription constitutes less than 5 per centum of such stock outstanding, may withdraw from membership in the Facility six months after notifying the Board of its intention to do so.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc5b07b1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1795c/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member of the Facility whose capital stock subscription constitutes 5 per centum or more of such stock outstanding, may withdraw from membership in the Facility twenty-four months after notifying the Board of its intention to do so.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc5b07b2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1795c/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Board may terminate membership in the Facility if, after opportunity for a hearing, the Board determines a member has failed to comply with any provision of this subchapter or regulation issued pursuant thereto.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc5b07b3-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-26/ch750"},"text":"June 26, 1934, ch. 750","children":[],"tail":", title III, formerly subch. III, § 304, as added and amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/630/tV/s502/b"},"text":"Pub. L. 95–630, title V, § 502(b)","children":[],"tail":", title XVIII, § 1802, "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3681"