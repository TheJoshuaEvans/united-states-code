e 26, 1934, ch. 750","children":[],"tail":", cited as a credit to this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc5b07b7-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/s4016/b/1/B"},"text":"Pub. L. 116–136, § 4016(b)(1)(B)","children":[],"tail":", substituted “all those credit unions” for “such credit unions as the Board may in its discretion determine”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/s4016/a/2"},"text":"Pub. L. 116–136, § 4016(a)(2)","children":[],"tail":", substituted “such credit unions as the Board may in its discretion determine” for “all those credit unions”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/351"},"text":"Pub. L. 109–351","children":[],"tail":" substituted “the affairs of such credit union” for “the affairs or such credit union”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/221/s309/a/4"},"text":"Pub. L. 96–221, § 309(a)(4)","children":[],"tail":", substituted “Board” for “Administrator” wherever appearing, such change having been made previously by "},{"tag":"ref","attrib":{"href":"/us/pl/95/630"},"text":"Pub. L. 95–630","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/221/s309/a/4"},"text":"Pub. L. 96–221, § 309(a)(4)","children":[],"tail":", (b)(2), substituted “Board” for “Administrator” wherever appearing, such change having been made previously by "},{"tag":"ref","attrib":{"href":"/us/pl/95/630"},"text":"Pub. L. 95–630","children":[],"tail":", and “title” for “subchapter” wherever appearing, which for purposes of codification has been editorially translated as “subchapter”, thereby requiring no further change in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/630/s502/b"},"text":"Pub. L. 95–630, § 502(b)","children":[],"tail":", substituted “Board” for “Administrator” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc5b07b8-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddc5b07b9-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2020 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/s4016/b/1/B"},"text":"section 4016(b)(1)(B) of Pub. L. 116–136","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"2021-12-31"},"text":"Dec. 31, 2021","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/116/136/s4016/b/2"},"text":"section 4016(b)(2) of Pub. L. 116–136","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1795a"},"text":"section 1795a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddc5b07ba-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment effective on expiration of 120 days after ","children":[{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", and transitional provisions, see "},{"tag":"ref","attrib":{"href":"/us/pl/95/630/s509"},"text":"section 509 of Pub. L. 95–630","children":[],"tail":" set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1752"},"text":"section 1752 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddc5b07bb-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1979-10-01"},"text":"Oct. 1, 1979","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/630/s1806"},"text":"section 1806 of Pub. L. 95–630","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1795"},"text":"section 1795 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
