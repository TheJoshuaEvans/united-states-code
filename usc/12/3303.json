{"tag":"section","attrib":{"id":"iddd046779-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3303"},"text":null,"children":[{"tag":"num","attrib":{"value":"3303"},"text":"§ 3303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial Institutions Examination Council","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd04677a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment; composition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is established the Financial Institutions Examination Council which shall consist of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd04677b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3303/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Comptroller of the Currency,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd04677c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3303/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chairman of the Board of Directors of the Federal Deposit Insurance Corporation,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd04677d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3303/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Governor of the Board of Governors of the Federal Reserve System designated by the Chairman of the Board,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd04677e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3303/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the Consumer Financial Protection Bureau,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd04677f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3303/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chairman of the National Credit Union Administration Board, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd046780-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3303/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chairman of the State Liaison Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd046781-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairmanship","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members of the Council shall select the first chairman of the Council. Thereafter the chairmanship shall rotate among the members of the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd046782-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3303/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of office","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term of the Chairman of the Council shall be two years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd046783-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3303/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of officers and employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members of the Council may, from time to time, designate other officers or employees of their respective agencies to carry out their duties on the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd046784-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3303/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation and expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each member of the Council shall serve without additional compensation but shall be entitled to reasonable expenses incurred in carrying out his official duties as such a member.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd046785-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/630/tX/s1004"},"text":"Pub. L. 95–630, title X, § 1004","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3694"},"text":"92 Stat. 3694","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/73/tVII/s744/a/2"},"text":"Pub. L. 101–73, title VII, § 744(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/438"},"text":"103 Stat. 438","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/351/tVII/s714/a"},"text":"Pub. L. 109–351, title VII, § 714(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-13"},"text":"Oct. 13, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1995"},"text":"120 Stat. 1995","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1091"},"text":"Pub. L. 111–203, title X, § 1091","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2094"},"text":"124 Stat. 2094","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd046786-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd046787-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd046788-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" substituted “Director of the Consumer Financial Protection Bureau” for “Director, Office of Thrift Supervision”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/351/s714/a/1"},"text":"Pub. L. 109–351, § 714(a)(1)","children":[],"tail":", substituted “Thrift Supervision,” for “Thrift Supervision”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/351/s714/a/2"},"text":"Pub. L. 109–351, § 714(a)(2)","chi