{"tag":"section","attrib":{"id":"iddd3fea2f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4808"},"text":null,"children":[{"tag":"num","attrib":{"value":"4808"},"text":"§ 4808.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revising regulatory requirements for transfers of all types of assets with recourse","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd3fea30-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4808/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review and revision of regulations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd3fea31-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4808/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During the 180-day period beginning on ","children":[{"tag":"date","attrib":{"date":"1994-09-23"},"text":"September 23, 1994","children":[],"tail":", each appropriate Federal banking agency shall, consistent with the principles of safety and soundness and the public interest—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd3fea32-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4808/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the agency’s regulations and written policies relating to transfers of assets with recourse by insured depository institutions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3fea33-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4808/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in consultation with the other Federal banking agencies, promulgate regulations that better reflect the exposure of an insured depository institution to credit risk from transfers of assets with recourse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3fea34-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4808/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before the end of the 180-day period beginning on ","children":[{"tag":"date","attrib":{"date":"1994-09-23"},"text":"September 23, 1994","children":[],"tail":", each appropriate Federal banking agency shall prescribe the regulations developed pursuant to paragraph (1)(B)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3fea35-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4808/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations required","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd3fea36-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4808/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After the end of the 180-day period beginning on ","children":[{"tag":"date","attrib":{"date":"1994-09-23"},"text":"September 23, 1994","children":[],"tail":", the amount of risk-based capital required to be maintained, under regulations prescribed by the appropriate Federal banking agency, by any insured depository institution with respect to assets transferred with recourse by such institution may not exceed the maximum amount of recourse for which such institution is contractually liable under the recourse agreement."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3fea37-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4808/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for safety and soundness","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The appropriate Federal banking agency may require any insured depository institution to maintain risk-based capital in an amount greater than the amount determined under paragraph (1), if the agency determines, by regulation or order, that such higher amount is necessary for safety and soundness reasons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3fea38-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4808/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1835/b"},"text":"section 1835(b) of this title","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not be construed as superseding the applicability of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1835/b"},"text":"section 1835(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3fea39-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4808/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the terms “appropriate Federal banking agency”, “Federal banking agency”, and “insured depository institution” have the same meanings as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"section 1813 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd3fea3a-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/tIII/s350"},"text":"Pub. L. 103–325, title III, § 350","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2242"},"text":"108 Stat. 2242","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
