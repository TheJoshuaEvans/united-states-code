{"tag":"section","attrib":{"id":"iddd47165a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5109"},"text":null,"children":[{"tag":"num","attrib":{"value":"5109"},"text":"§ 5109.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Bureau, the Farm Credit Administration, and the Nationwide Mortgage Licensing System and Registry may charge reasonable fees to cover the costs of maintaining and providing access to information from the Nationwide Mortgage Licensing System and Registry, to the extent that such fees are not charged to consumers for access to such system and registry.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd47165b-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tV/s1510"},"text":"Pub. L. 110–289, div. A, title V, § 1510","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1100/7"},"text":"Pub. L. 111–203, title X, § 1100(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2107"},"text":"124 Stat. 2107","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd47165c-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd47165d-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"iddd47165e-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text