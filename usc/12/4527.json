{"tag":"section","attrib":{"id":"iddd281bda-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4527"},"text":null,"children":[{"tag":"num","attrib":{"value":"4527"},"text":"§ 4527.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data standards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd281bdb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4527/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Agency shall, by rule, adopt data standards for all collections of information that are regularly filed with or submitted to the Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd281bdc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4527/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consistency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The data standards required under subsection (a) shall incorporate, and ensure compatibility with (to the extent feasible), all applicable data standards established in the rules promulgated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5334"},"text":"section 5334 of this title","children":[],"tail":", including, to the extent practicable, by having the characteristics described in clauses (i) through (vi) of subsection (c)(1)(B) of such section 5334."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd281bdd-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXIII/s1319H"},"text":"Pub. L. 102–550, title XIII, § 1319H","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLVIII/s5881"},"text":"Pub. L. 117–263, div. E, title LVIII, § 5881","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3437"},"text":"136 Stat. 3437","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd281bde-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd281bdf-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd281be0-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rulemaking","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLVIII/s5883"},"text":"Pub. L. 117–263, div. E, title LVIII, § 5883","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3437"},"text":"136 Stat. 3437","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dE/tLVIII/s5883"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director of the Federal Housing Finance Agency shall issue rules to carry out the amendments made by this subtitle [subtitle H (§§ 5881–5884) of title LVIII of div. E of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":", enacting this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4528"},"text":"section 4528 of this title","children":[],"tail":"], which shall take effect not later than 2 years after the date on which final rules are promulgated under section 124(b)(2) of the Financial Stability Act of 2010 ["},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5334/b/2"},"text":"12 U.S.C. 5334(b)(2)","children":[],"tail":"], as added by "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5811/a"},"text":"section 5811(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Minimizing Disruption","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In issuing the regulations required under subsection (a), the Director of the Federal Housing Finance Agency shall seek to minimize disruptive changes to the persons affected by those rules.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd281be1-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rule of Construction Regarding No New Disclosure Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLVIII/s5884"},"text":"Pub. L. 117–263, div. E, title LVIII, § 5884","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3438"},"text":"136 Stat. 3438","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dE/tLVIII/s5884"},"text":"“Nothing in this subtitle [subtitle H (§§ 5881–5884) of title LVIII of div. E of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":", enacting this section, "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4528"},"text":"section 4528 of this title","children":[],"tail":", and provisions set out as a note under this section], or the amendments made by this subtitle, shall be construed to require the Federal Housing Finance Agency to collect or make publicly available additional information under the Federal Housing Enterprises Financial Safety and Soundness Act of 1992 ("},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4501"},"text":"12 U.S.C. 4501","children":[],"tail":" et seq.), beyond information that was collected or made publicly available under that Act, as of the day before the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
