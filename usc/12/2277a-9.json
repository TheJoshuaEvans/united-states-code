{"tag":"section","attrib":{"id":"iddcde1a35-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–9"},"text":null,"children":[{"tag":"num","attrib":{"value":"2277a–9"},"text":"§ 2277a–9.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Insurance Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcde1a36-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–9/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby established a Farm Credit Insurance Fund (hereinafter referred to in this section as the “Insurance Fund”) for insuring the timely payment of principal and interest on insured obligations. The assets in the Fund shall be held by the Corporation for the uses and purposes of the Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcde1a37-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–9/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amounts in Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation shall deposit in the Insurance Fund all premium payments received by the Corporation under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcde1a38-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–9/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses of Fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcde1a39-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–9/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory use","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning ","children":[{"tag":"date","attrib":{"date":"1993-01-01"},"text":"January 1, 1993","children":[],"tail":", the Corporation shall expend amounts in the Insurance Fund to the extent necessary to insure the timely payment of interest and principal on insured obligations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcde1a3a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–9/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other mandatory uses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning ","children":[{"tag":"date","attrib":{"date":"1993-01-01"},"text":"January 1, 1993","children":[],"tail":", the Corporation shall use amounts in the Insurance Fund to ensure the retirement of eligible borrower stock at par value under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2162"},"text":"section 2162 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcde1a3b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–9/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permissive uses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation may expend amounts in the Insurance Fund to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2277a–10"},"text":"section 2277a–10 of this title","children":[],"tail":" and to cover the operating costs of the Corporation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcde1a3c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–9/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corporate payment or refunds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation shall make all payments and refunds required to be made by the Corporation under this part from amounts in the Insurance Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcde1a3d-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tV/s5"},"text":"Pub. L. 92–181, title V, § 5","children":[],"tail":".60, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tIII/s302"},"text":"Pub. L. 100–233, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1616"},"text":"101 Stat. 1616","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/tIII/s302/j"},"text":"Pub. L. 100–399, title III, § 302(j)","children":[],"tail":"–("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"1988-08-17"},"text":"Aug. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/994"},"text":"102 Stat. 994","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXVIII/s1836/a"},"text":"Pub. L. 101–624, title XVIII, § 1836(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3833"},"text":"104 Stat. 3833","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/