{"tag":"section","attrib":{"id":"iddd49863e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5214"},"text":null,"children":[{"tag":"num","attrib":{"value":"5214"},"text":"§ 5214.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial Stability Oversight Board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd49863f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5214/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is established the Financial Stability Oversight Board, which shall be responsible for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd498640-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5214/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" reviewing the exercise of authority under a program developed in accordance with this chapter, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd498641-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5214/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" policies implemented by the Secretary and the Office of Financial Stability created under sections 5211 and 5212 of this title, including the appointment of financial agents, the designation of asset classes to be purchased, and plans for the structure of vehicles used to purchase troubled assets; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd498642-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5214/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effect of such actions in assisting American families in preserving home ownership, stabilizing financial markets, and protecting taxpayers;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd498643-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5214/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making recommendations, as appropriate, to the Secretary regarding use of the authority under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd498644-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5214/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reporting any suspected fraud, misrepresentation, or malfeasance to the Special Inspector General for the Troubled Assets Relief Program or the Attorney General of the United States, consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s535/b"},"text":"section 535(b) of title 28","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd498645-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5214/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Financial Stability Oversight Board shall be comprised of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd498646-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5214/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chairman of the Board of Governors of the Federal Reserve System;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd498647-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5214/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd498648-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5214/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the Federal Housing Finance Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd498649-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5214/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chairman of the Securities Exchange Commission; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd49864a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5214/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Housing and Urban Development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd49864b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5214/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The chairperson of the Financial Stability Oversight Board shall be elected by the members of the Board from among the members other than the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd49864c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5214/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Financial Stability Oversight Board shall meet 2 weeks after the first exercise of the purchase authority of the Secretary under this chapter, and monthly thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd49864d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5214/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional authorities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to the responsibilities described in subsection (a), the Financial Stability Oversight Board shall have the authority to ensure that the policies implemented by the Secretary are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd49864e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5214/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in accordance with the purposes of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd49864f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5214/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the economic interests of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd498650-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5214/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consistent with protecting taxpayers, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5223/a"},"text":"section 5223(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd498651-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5214/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit review committee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Financial Stability Oversight Board may appoint a credit review committee for the purpose of evaluating the exercise of the purchase authority provided under this chapter and the assets acquired through the exercise of such authority, as the Financial Stability Oversight Board determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd498652-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5214/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Financial Stability Oversight Board shall report to the appropriate committees of Congress and the Congressional Oversight Panel established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5233"},"text":"section 5233 of this title","children":[],"tail":", not less frequently than quarterly, on the matters described under subsection (a)(1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd498653-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5214/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Financial Stability Oversight Board, and its authority under this section, shall terminate on the expiration of the 15-day period beginning upon the later of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd498654-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5214/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date that the last troubled asset acquired by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5211"},"text":"section 5211 of this title","children":[],"tail":" has been sold or transferred out of the ownership or control of the Federal Government; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd498655-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5214/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of expiration of the last insurance contract issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5212"},"text":"section 5212 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd498656-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/343/dA/tI/s104"},"text":"Pub. L. 110–343, div. A, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3770"},"text":"122 Stat. 3770","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd498657-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd498658-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd498659-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act” and was translated as reading “this division”, meaning div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/343"},"text":"Pub. L. 110–343","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3765"},"text":"122 Stat. 3765","children":[],"tail":", known as the Emergency Economic Stabilization Act of 2008, to reflect the probable intent of Congress. For complete classification of division A to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5201"},"text":"section 5201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
