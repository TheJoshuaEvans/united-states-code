{"tag":"section","attrib":{"id":"iddd804efb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5902"},"text":null,"children":[{"tag":"num","attrib":{"value":"5902"},"text":"§ 5902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance and treatment of payment stablecoins","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd804efc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5902/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on issuers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall be unlawful for any person other than a permitted payment stablecoin issuer to issue a payment stablecoin in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd804efd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5902/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on offers or sales","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd804efe-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5902/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (c) and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5916"},"text":"section 5916 of this title","children":[],"tail":", beginning on the date that is 3 years after "},{"tag":"date","attrib":{"date":"2025-07-18"},"text":"July 18, 2025","children":[],"tail":", it shall be unlawful for a digital asset service provider to offer or sell a payment stablecoin to a person in the United States, unless the payment stablecoin is issued by a permitted payment stablecoin issuer."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd804eff-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5902/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign payment stablecoin issuers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall be unlawful for any digital asset service provider to offer, sell, or otherwise make available in the United States a payment stablecoin issued by a foreign payment stablecoin issuer unless the foreign payment stablecoin issuer has the technological capability to comply, and will comply, with the terms of any lawful order and any reciprocal arrangement pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5916"},"text":"section 5916 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd804f00-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5902/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limited safe harbors","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd804f01-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5902/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Treasury may issue regulations providing safe harbors from subsection (a) that are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd804f02-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5902/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consistent with the purposes of the ","children":[{"tag":"ref","attrib":{"idref":"fn002549"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002549"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “this”."}],"tail":" chapter;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd804f03-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5902/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limited in scope; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd804f04-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5902/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" apply ","children":[{"tag":"ref","attrib":{"idref":"fn002550"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002550"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original."}],"tail":" to a de minimis volume of transactions, as determined by the Secretary of the Treasury."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd804f05-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5902/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unusual and exigent circumstances","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd804f06-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5902/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary of the Treasury determines that unusual and exigent circumstances exist, the Secretary may provide limited safe harbors from subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd804f07-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5902/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Justification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Prior to issuing a limited safe harbor under this paragraph, the Secretary of the Treasury shall submit to the chairs and ranking members of the Committee on Banking, Housing, and Urban Affairs of the Senate and the Committee on Financial Services of the House of Representatives a justification for the determination of the unusual and exigent circumstances, which may be contained in a classified annex, as applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd804f08-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5902/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rulemaking","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5913"},"text":"section 5913 of this title","children":[],"tail":", the Secretary of the Treasury shall issue regulations to implement this section, including regulations to define terms."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd804f09-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5902/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extraterritorial effect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section is intended to have extraterritorial effect if conduct involves the offer or sale of a payment stablecoin to a person located in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd804f0a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5902/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty for violation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd804f0b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5902/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whoever knowingly participates in a violation of subsection (a) shall be fined not more than $1,000,000 for each such violation, imprisoned for not more than 5 years, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd804f0c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5902/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Referral to Attorney General","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a primary Federal payment stablecoin regulator has reason to believe that any person has knowingly violated subsection (a), the primary Federal payment stablecoin regulator may refer the matter to the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd804f0d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5902/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A payment stablecoin that is not issued by a permitted payment stablecoin issuer shall not be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd804f0e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5902/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" treated as cash or as a cash equivalent for accounting purposes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd804f0f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5902/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligible as cash or as a cash equivalent margin and collateral for futures commission merchants, derivative clearing organizations, broker-dealers, registered clearing agencies, and swap dealers; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd804f10-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5902/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acceptable as a settlement asset to facilitate wholesale payments between banking organizations or by a payment infrastructure to facilitate exchange and settlement among banking organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd804f11-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5902/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules of construction","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd804f12-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5902/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exempt transactions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section shall not apply to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd804f13-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5902/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the direct transfer of digital assets between 2 individuals acting on their own behalf and for their own lawful purposes, without the involvement of an intermediary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd804f14-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5902/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ","children":[{"tag":"ref","attrib":{"idref":"fn002551"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002551"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" So in original. The word “to” probably should not appear."}],"tail":" any transaction involving the receipt of digital assets by an individual between an account owned by the individual in the United States and an account owned by the individual abroad that are offered by the same parent company; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd804f15-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5902/h/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ","children":[{"tag":"sup","attrib":{},"text":"3","children":[],"tail":" any transaction by means of a software or hardware wallet that facilitates an individual’s own custody of digital assets."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd804f16-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5902/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treasury authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall alter the existing authority of the Secretary of the Treasury to block, restrict, or limit transactions involving payment stablecoins that reference or are denominated in United States dollars that are subject to the jurisdiction of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd804f17-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/27/s3"},"text":"Pub. L. 119–27, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-18"},"text":"July 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/423"},"text":"139 Stat. 423","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd804f18-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"iddd804f19-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Delayed Effective Date of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For delayed effective date of section, see Effective Date note below.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd804f1a-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd804f1b-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (c)(1)(A) and (h)(2), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/27"},"text":"Pub. L. 119–27","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-18"},"text":"July 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/419"},"text":"139 Stat. 419","children":[],"tail":", known as the Guiding and Establishing National Innovation for U.S. Stablecoins Act and also as the GENIUS Act, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5901"},"text":"section 5901 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd804f1c-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd804f1d-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the earlier of the date that is 18 months after ","children":[{"tag":"date","attrib":{"date":"2025-07-18"},"text":"July 18, 2025","children":[],"tail":", or the date that is 120 days after the date on which the primary Federal payment stablecoin regulators issue any final regulations implementing "},{"tag":"ref","attrib":{"href":"/us/pl/119/27"},"text":"Pub. L. 119–27","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/119/27/s20"},"text":"section 20 of Pub. L. 119–27","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5901"},"text":"section 5901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
