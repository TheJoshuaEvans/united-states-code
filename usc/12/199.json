{"tag":"section","attrib":{"id":"iddb1df44a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s199"},"text":null,"children":[{"tag":"num","attrib":{"value":"199"},"text":"§ 199.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of request","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Such request, if approved by the Comptroller of the Currency, shall be, together with the certificate of facts in the case, and his recommendation as to the amount of money which, in his judgment, should be so used and employed, submitted to the Secretary of the Treasury, and if the same shall likewise be approved by him, the request shall be by the Comptroller of the Currency allowed, and notice thereof, with copies of the request, certificate of facts, and indorsement of approvals, shall be filed with the Treasurer of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddb1df44b-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1886-03-29/ch28/s2"},"text":"Mar. 29, 1886, ch. 28, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/24/8"},"text":"24 Stat. 8","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb1df44c-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddb1df44d-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddb1df44e-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Application to District of Columbia","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions of this section were made applicable to banks, etc., in the District of Columbia by ","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-03-04/ch274/s4"},"text":"act Mar. 4, 1933, ch. 274, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/47/1567"},"text":"47 Stat. 1567","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"iddb1df44f-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"iddb1df450-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions to Secretary of the Treasury, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s55"},"text":"section 55 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
