{"tag":"section","attrib":{"id":"iddafed2d8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4a"},"text":null,"children":[{"tag":"num","attrib":{"value":"4a"},"text":"§ 4a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delegation of authority by Comptroller","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Comptroller of the Currency may delegate to any duly authorized employee, representative, or agent any power vested in the office by law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddafed2d9-3a6f-11f1-8fa0-c065796a7f06"},"text":"(R.S. § 327A, as added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/221/tVII/s707/a"},"text":"Pub. L. 96–221, title VII, § 707(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-03-31"},"text":"Mar. 31, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/188"},"text":"94 Stat. 188","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
