{"tag":"section","attrib":{"id":"iddd7b93cc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5628"},"text":null,"children":[{"tag":"num","attrib":{"value":"5628"},"text":"§ 5628.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation and reports to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For each fiscal year in which a program or project is carried out under this subchapter, the Secretary shall submit a report to the Committee on Banking, Housing, and Urban Affairs of the Senate and the Committee on Financial Services of the House of Representatives containing a description of the activities funded, amounts distributed, and measurable results, as appropriate and available.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd7b93cd-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tXII/s1210"},"text":"Pub. L. 111–203, title XII, § 1210","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2133"},"text":"124 Stat. 2133","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd7b93ce-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd7b93cf-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd7b93d0-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in text, was in the original “this title”, meaning title XII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2129"},"text":"124 Stat. 2129","children":[],"tail":", known as the Improving Access to Mainstream Financial Institutions Act of 2010, which is classified principally to this subchapter. For complete classification of title XII to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
