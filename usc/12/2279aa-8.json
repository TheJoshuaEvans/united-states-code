{"tag":"section","attrib":{"id":"iddcea288b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–8"},"text":null,"children":[{"tag":"num","attrib":{"value":"2279aa–8"},"text":"§ 2279aa–8.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards for qualified loans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcea288c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–8/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcea288d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–8/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation shall establish underwriting, security appraisal, and repayment standards for qualified loans taking into account the nature, risk profile, and other differences between different categories of qualified loans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcea288e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–8/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supervision, examination, and report of condition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The standards shall be subject to the authorities of the Farm Credit Administration under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2279aa–11"},"text":"section 2279aa–11 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcea288f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–8/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mortgage loans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In establishing standards for qualified loans, the Corporation shall confine corporate operations, so far as practicable, to mortgage loans that are deemed by the Board to be of such quality so as to meet, substantially and generally, the purchase standards imposed by private institutional mortgage investors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcea2890-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–8/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To further the purpose of this subchapter to provide a new source of long-term fixed rate financing to assist farmers and ranchers to purchase agricultural real estate, the standards established by the Board pursuant to subsection (a) with respect to loans secured by agricultural real estate shall, at a minimum—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcea2891-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–8/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide that no agricultural mortgage loan with a loan-to-value ratio in excess of 80 percent may be treated as a qualified loan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcea2892-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–8/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require each borrower to demonstrate sufficient cash-flow to adequately service the agricultural mortgage loan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcea2893-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–8/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contain sufficient documentation standards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcea2894-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–8/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contain adequate standards to protect the integrity of the appraisal process with respect to any agricultural mortgage loans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcea2895-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–8/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contain adequate standards to ensure that the farmer or rancher is or will be actively engaged in agricultural production, and require the borrower to certify to the originator that the borrower intends to continue agricultural production on the farm or ranch involved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcea2896-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–8/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimize speculation in agricultural real estate for nonagricultural purposes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcea2897-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–8/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in establishing the value of agricultural real estate, consider the purpose for which the real estate is taxed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcea2898-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–8/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan amount limitation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcea2899-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–8/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A loan secured by agricultural real estate may not be treated as a qualified loan if the principal amount of such loan exceeds $2,500,000, adjusted for inflation, except as provided in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcea289a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–8/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acreage exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall not apply with respect to any agricultural mortgage loan described in such paragraph if such loan is secured by agricultural real estate that, in the aggregate, comprises not more than 2,000 acres.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcea289b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–8/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nondiscrimination requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The standards established under subsection (a) shall not discriminate against small originators or small agricultural mortgage loans that are at least $50,000. The Board shall promote and encourage the inclusion of qualified loans for small farms and family farmers in the agricultural mortgage secondary market.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcea289c-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tVIII/s8"},"text":"Pub. L. 92–181, title VIII, § 8","children":[],"tail":".8, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tVII/s702"},"text":"Pub. L. 100–233, title VII, § 702","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1700"},"text":"101 Stat. 1700","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/tVI/s601/i"},"text":"Pub. L. 100–399, title VI, § 601(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-17"},"text":"Aug. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1005"},"text":"102 Stat. 1005","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/105/tI/s110"},"text":"Pub. L. 104–105, title I, § 110","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/165"},"text":"110 Stat. 165","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tV/s5406/c"},"text":"Pub. L. 110–234, title V, § 5406(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1158"},"text":"122 Stat. 1158","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title V, § 5406(c), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1920; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tV/s5410/a"},"text":"Pub. L. 115–334, title V, § 5410(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4678"},"text":"132 Stat. 4678","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcea289d-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcea289e-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddcea289f-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcea28a0-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" substituted “2,000” for “1,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s5406/c/1"},"text":"Pub. L. 110–246, § 5406(c)(1)","children":[],"tail":", added pars. (1) and (2), designated last sentence as par. (3) and inserted heading, and struck out former first sentence which read as follows: “Not later than 120 days after the appointment and election of the permanent Board, the Corporation, in consultation with originators, shall establish uniform underwriting, security appraisal, and repayment standards for qualified loans.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s5406/c/2/A"},"text":"Pub. L. 110–246, § 5406(c)(2)(A)","children":[],"tail":", inserted “with respect to loans secured by agricultural real estate” after “subsection (a)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s5406/c/2/B"},"text":"Pub. L. 110–246, § 5406(c)(2)(B)","children":[],"tail":", substituted “ensure that the farmer or rancher” for “ensure that the borrower” and “farm or ranch” for “site”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s5406/c/3"},"text":"Pub. L. 110–246, § 5406(c)(3)","children":[],"tail":", inserted “secured by agricultural real estate” after “A loan”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s5406/c/4"},"text":"Pub. L. 110–246, § 5406(c)(4)","children":[],"tail":", (5), redesignated subsec. (e) as (d) and struck out former subsec. (d). Prior to amendment, text read as follows: “No standard prescribed under subsection (a) shall take effect before the later of—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) the end of a period consisting of 30 legislative days and beginning on the date such standards are submitted to the Congress; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) the end of a period consisting of 90 calendar days and beginning on such date.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/105"},"text":"Pub. L. 104–105","children":[],"tail":" inserted at end “The Board shall promote and encourage the inclusion of qualified loans for small farms and family farmers in the agricultural mortgage secondary market.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399"},"text":"Pub. L. 100–399","children":[],"tail":" inserted “permanent” after “appointment and election of the”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcea28a1-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcea28a2-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/tV/s5410/b"},"text":"Pub. L. 115–334, title V, § 5410(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4678"},"text":"132 Stat. 4678","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/334/tV/s5410/b"},"text":"“The amendment made by subsection (a) [amending this section] shall take effect 1 year after the date a report submitted in accordance with section 5414 of this Act [","children":[{"tag":"ref","attrib":{"href":"/us/stat/132/4724"},"text":"132 Stat. 4724","children":[],"tail":"] indicates that it is feasible to increase the acreage limitation in section 8.8(c)(2) of the Farm Credit Act of 1971 ["},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2279aa–8/c/2"},"text":"12 U.S.C. 2279aa–8(c)(2)","children":[],"tail":"] to 2,000 acres [report submitted June 2019].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcea28a3-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of Title 7","children":[],"tail":", Agriculture."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcea28a4-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399"},"text":"Pub. L. 100–399","children":[],"tail":" effective as if enacted immediately after enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/100/233"},"text":"Pub. L. 100–233","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/s1001/a"},"text":"section 1001(a) of Pub. L. 100–399","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2002"},"text":"section 2002 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
