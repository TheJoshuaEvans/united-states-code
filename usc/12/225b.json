{"tag":"section","attrib":{"id":"iddb24f891-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s225b"},"text":null,"children":[{"tag":"num","attrib":{"value":"225b"},"text":"§ 225b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appearances before and reports to the Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddb24f892-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s225b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appearances before the Congress","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb24f893-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s225b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Chairman of the Board shall appear before the Congress at semi-annual hearings, as specified in paragraph (2), regarding—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddb24f894-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s225b/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the efforts, activities, objectives and plans of the Board and the Federal Open Market Committee with respect to the conduct of monetary policy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb24f895-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s225b/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" economic developments and prospects for the future described in the report required in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb24f896-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s225b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Schedule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Chairman of the Board shall appear—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddb24f897-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s225b/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before the Committee on Banking and Financial Services of the House of Representatives on or about February 20 of even numbered calendar years and on or about July 20 of odd numbered calendar years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb24f898-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s225b/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before the Committee on Banking, Housing, and Urban Affairs of the Senate on or about July 20 of even numbered calendar years and on or about February 20 of odd numbered calendar years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb24f899-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s225b/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before either Committee referred to in subparagraph (A) or (B), upon request, following the scheduled appearance of the Chairman before the other Committee under subparagraph (A) or (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb24f89a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s225b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall, concurrent with each semi-annual hearing required by this section, submit a written report to the Committee on Banking, Housing, and Urban Affairs of the Senate and the Committee on Banking and Financial Services of the House of Representatives, containing a discussion of the conduct of monetary policy and economic developments and prospects for the future, taking into account past and prospective developments in employment, unemployment, production, investment, real income, productivity, exchange rates, international trade and payments, and prices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb24f89b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s225b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public access to information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall place on its home Internet website, a link entitled “Audit”, which shall link to a webpage that shall serve as a repository of information made available to the public for a reasonable period of time, not less than 6 months following the date of release of the relevant information, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb24f89c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s225b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reports prepared by the Comptroller General under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s714"},"text":"section 714 of title 31","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb24f89d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s225b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the annual financial statements prepared by an independent auditor for the Board in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s248b"},"text":"section 248b of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb24f89e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s225b/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reports to the Committee on Banking, Housing, and Urban Affairs of the Senate required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s343/3"},"text":"section 343(3) of this title","children":[],"tail":" (relating to emergency lending authority); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb24f89f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s225b/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Board reasonably believes is necessary or helpful to the public in understanding the accounting, financial reporting, and internal controls of the Board and the Federal reserve banks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddb24f8a0-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1913-12-23/ch6/s2B"},"text":"Dec. 23, 1913, ch. 6, § 2B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/tX/s1003/b/1"},"text":"Pub. L. 106–569, title X, § 1003(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/3028"},"text":"114 Stat. 3028","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tXI/s1103/a"},"text":"Pub. L. 111–203, title XI, § 1103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2118"},"text":"124 Stat. 2118","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb24f8a1-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb24f8a2-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddb24f8a3-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddb24f8a4-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"iddb24f8a5-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Banking and Financial Services of House of Representatives abolished and replaced by Committee on Financial Services of House of Representatives, and jurisdiction over matters relating to securities and exchanges and insurance generally transferred from Committee on Energy and Commerce of House of Representatives by House Resolution No. 5, One Hundred Seventh Congress, ","children":[{"tag":"date","attrib":{"date":"2001-01-03"},"text":"Jan. 3, 2001","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddb24f8a6-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective 1 day after "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s4"},"text":"section 4 of Pub. L. 111–203","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"section 5301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
