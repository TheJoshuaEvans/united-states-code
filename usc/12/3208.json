{"tag":"section","attrib":{"id":"iddd01f65c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3208"},"text":null,"children":[{"tag":"num","attrib":{"value":"3208"},"text":"§ 3208.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers available to Attorney General for enforcement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd01f65d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3208/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of the exercise by the Attorney General of the enforcement functions of the Attorney General under section 3206(6) ","children":[{"tag":"ref","attrib":{"idref":"fn002337"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002337"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title, all of the functions and powers of the Attorney General under the Clayton Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s12"},"text":"15 U.S.C. 12","children":[],"tail":" et seq.] are available to the Attorney General, irrespective of any jurisdictional tests in the Clayton Act, including the power to take enforcement actions in the same manner as if the violation had been a violation of the Clayton Act."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd01f65e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3208/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All of the functions and powers of the Attorney General or the Assistant Attorney General in charge of the Antitrust Division of the Department of Justice are available to the Attorney General or to such Assistant Attorney General to investigate possible violations under section 3206(6) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title in the same manner as if such possible violations were possible violations of the Clayton Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s12"},"text":"15 U.S.C. 12","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd01f65f-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/630/tII/s210"},"text":"Pub. L. 95–630, title II, § 210","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/320/tIV/s426"},"text":"Pub. L. 97–320, title IV, § 426","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-15"},"text":"Oct. 15, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1524"},"text":"96 Stat. 1524","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tIII/s360/3"},"text":"Pub. L. 111–203, title III, § 360(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1549"},"text":"124 Stat. 1549","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd01f660-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd01f661-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd01f662-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s3206/6"},"text":"Section 3206(6) of this title","children":[],"tail":", referred to in text, was redesignated section 3206(5) by "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tIII/s360/1/E"},"text":"Pub. L. 111–203, title III, § 360(1)(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1549"},"text":"124 Stat. 1549","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Clayton Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1914-10-15/ch323"},"text":"act Oct. 15, 1914, ch. 323","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/730"},"text":"38 Stat. 730","children":[],"tail":", which is classified generally to sections 12, 13, 14 to 19, 21, and 22 to 27 of Title 15, Commerce and Trade, and sections 52 and 53 of Title 29, Labor. For further details and complete classification of this Act to the Code, see References in Text note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s12"},"text":"section 12 of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd01f663-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" substituted “the enforcement functions of the Attorney General” for “his enforcement functions”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd01f664-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd01f665-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective on the transfer date, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s351"},"text":"section 351 of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s906"},"text":"section 906 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
