{"tag":"section","attrib":{"id":"iddb48d48e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s541"},"text":null,"children":[{"tag":"num","attrib":{"value":"541"},"text":"§ 541.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax on circulating notes generally","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In lieu of all existing taxes, every association shall pay to the Treasurer of the United States, in the months of January and July, a duty of one-half of 1 per centum each half year upon the average amount of its notes in circulation.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddb48d48f-3a6f-11f1-8fa0-c065796a7f06"},"text":"(R.S. § 5214; ","children":[{"tag":"ref","attrib":{"href":"/us/act/1883-03-03/ch121/s1"},"text":"Mar. 3, 1883, ch. 121, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/22/488"},"text":"22 Stat. 488","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb48d490-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb48d491-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddb48d492-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 5214 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1864-06-03/ch106/s41"},"text":"act June 3, 1864, ch. 106, § 41","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/13/111"},"text":"13 Stat. 111","children":[],"tail":", which was part of the National Bank Act. See "},{"tag":"ref","attrib":{"h