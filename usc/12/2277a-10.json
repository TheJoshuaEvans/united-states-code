{"tag":"section","attrib":{"id":"iddcde1a43-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10"},"text":null,"children":[{"tag":"num","attrib":{"value":"2277a–10"},"text":"§ 2277a–10.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers of Corporation with respect to troubled insured System banks","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcde1a44-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to provide assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcde1a45-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stand-alone assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Corporation, in its sole discretion and on such terms and conditions as the Board of Directors may prescribe, may make loans to, purchase the assets or securities of, assume the liabilities of, or make contributions to, any insured System bank if such action is taken—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddce08b46-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prevent the placing of the bank in receivership;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce08b47-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to restore the bank to normal operation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce08b48-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce the risk to the Corporation posed by the bank when severe financial conditions threaten the stability of a significant number of insured System banks or of insured System banks possessing significant financial resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce08b49-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Facilitation of mergers or consolidation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddce08b4a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To facilitate a merger or consolidation of a qualifying insured System bank, the sale of assets of such insured System bank to another insured System bank, the assumption of such insured System bank’s liabilities by such other insured System bank, or the acquisition of the stock of such insured System bank by such other insured System bank, the Corporation, in its sole discretion and on such terms and conditions as the Board of Directors may prescribe, may—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddce08b4b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchase any such assets or assume any such liabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddce08b4c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make loans or contributions to, or purchase debt securities of, such other insured System bank;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddce08b4d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" guarantee such other insured System bank against loss by reason of such other insured System bank’s merging or consolidating with, or assuming the liabilities and purchasing the assets of, such insured System bank; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddce08b4e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10/a/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take any combination of the actions referred to in the preceding clauses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce08b4f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifying insured System bank","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subparagraph (A), the term “qualifying insured System bank” means any insured System bank that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddce08b50-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in receivership;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddce08b51-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is, in the judgment of the Board of Directors, in danger of being placed in receivership; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddce08b52-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is, in the sole discretion of the Corporation, an insured System bank that, when severe financial conditions exist that threaten the stability of a significant number of insured System banks or of insured System banks possessing significant financial resources, requires assistance under subparagraph (A) to lessen the risk to the Corporation posed by such insured System bank under such threat of instability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce08b53-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddce08b54-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Least-cost resolution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Assistance may not be provided to an insured System bank under this subsection unless the means of providing the assistance is the least costly means of providing the assistance by the Farm Credit Insurance Fund of all possible alternatives available to the Corporation, including liquidation of the bank (including paying the insured obligations issued on behalf of the bank). Before making a least-cost determination under this subparagraph, the Corporation shall accord such other insured System banks as the Corporation determines to be appropriate the opportunity to submit information relating to the determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce08b55-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determining least costly approach","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining the least costly alternative under subparagraph (A), the Corporation shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddce08b56-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate alternatives on a present-value basis, using a reasonable discount rate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddce08b57-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" document the evaluation and the assumptions on which the evaluation is based; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddce08b58-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10/a/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" retain the documentation for not less than 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce08b59-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time of determination","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddce08b5a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10/a/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, the determination of the costs of providing any assistance under any provision of this section with respect to any insured System bank shall be made as of the date on which the Corporation makes the determination to provide the assistance to the institution under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddce08b5b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10/a/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule for liquidations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, the determination of the costs of liquidation of any insured System bank shall be made as of the earliest of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddce08b5c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10/a/3/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which a conservator is appointed for the insured System bank;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddce08b5d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10/a/3/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which a receiver is appointed for the insured System bank; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddce08b5e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10/a/3/C/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the Corporation makes any determination to provide any assistance under this section with respect to the insured System bank.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce08b5f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule for stand-alone assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before providing any assistance under paragraph (1), the Corporation shall evaluate the adequacy of managerial resources of the insured System bank. The continued service of any director or senior ranking officer who serves in a policymaking role for the assisted insured System bank, as determined by the Corporation, shall be subject to approval by the Corporation as a condition of assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce08b60-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discretionary determinations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any determination that the Corporation makes under this paragraph shall be in the sole discretion of the Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce08b61-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10/a/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purchase of stock","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation may not use its authority under this subsection to purchase any stock of an insured System bank. The preceding sentence shall not be construed to limit the ability of the Corporation to enter into and enforce covenants and agreements that it determines to be necessary to protect the financial interests of the Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce08b62-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any assistance provided under this subsection may be in subordination to the rights of owners of obligations and other creditors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce08b63-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation, in its annual report to Congress, shall report the total amount saved, or it estimates to be saved, by the Corporation exercising the authority provided to the Corporation in this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce08b64-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to pledge or sell assets","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation, in its discretion, may make loans on the security of, or may purchase, and liquidate or sell, any part of the assets of, any insured System bank that is placed in receivership because of the inability of the bank to pay principal or interest on any of its notes, bonds, debentures, or other obligations in a timely manner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce08b65-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subrogation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce08b66-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On the payment to an owner of an insured obligation issued on behalf of an insured System bank in receivership, the Corporation shall be subrogated to all rights of the owner against the bank to the extent of the payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce08b67-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Receipt of dividends","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subrogation under paragraph (1) shall include the right on the part of the Corporation to receive the same dividends from the proceeds of the assets of the bank as would have been payable to the owner on a claim for the insured obligation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce08b68-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right to assets","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any agreement that shall diminish or defeat the right, title, or interest of the Corporation in any asset acquired by such Corporation under this section, either as security for a loan or by purchase, shall not be valid against the Corporation unless the agreement—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce08b69-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in writing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce08b6a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is executed by the bank and the person or persons claiming an adverse interest thereunder, including the obligor, contemporaneously with the acquisition of the asset by the bank;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce08b6b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been approved by the board of directors of the bank or its loan committee, which approval shall be reflected in the minutes of the board or committee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce08b6c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been, continuously, from the time of its execution, an official record of the bank.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce08b6d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Insured System bank","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As used in this section, the terms “insured System bank” and “bank” include each production credit association and other association making direct loans under the authority provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2279b"},"text":"section 2279b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce08b6e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–10/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation shall not exercise any authority under this section during the 5-year period prior to ","children":[{"tag":"date","attrib":{"date":"1993-01-01"},"text":"January 1, 1993","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddce08b6f-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tV/s5"},"text":"Pub. L. 92–181, title V, § 5","children":[],"tail":".61, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tIII/s302"},"text":"Pub. L. 100–233, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1616"},"text":"101 Stat. 1616","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/220/s6/b/4"},"text":"Pub. L. 101–220, § 6(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-12"},"text":"Dec. 12, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1880"},"text":"103 Stat. 1880","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXVIII/s1836/b"},"text":"Pub. L. 101–624, title XVIII, § 1836(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3833"},"text":"104 Stat. 3833","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/105/tII/s217"},"text":"Pub. L. 104–105, title II, § 217","children":[],