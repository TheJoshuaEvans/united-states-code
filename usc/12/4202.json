{"tag":"section","attrib":{"id":"iddd1c35c8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4202"},"text":null,"children":[{"tag":"num","attrib":{"value":"4202"},"text":"§ 4202.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of declarations","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"A declaration filed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4201"},"text":"section 4201 of this title","children":[],"tail":" shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd1c35c9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4202/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set forth the name and address of the declarant and the basis for the declarant’s knowledge of the facts alleged;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1c35ca-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4202/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allege under oath or affirmation specific facts, relating to a particular transaction or transactions, which constitute a prima facie case of a violation giving rise to an action for civil penalties under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1833a"},"text":"section 1833a of this title","children":[],"tail":" affecting a depository institution insured by the Federal Deposit Insurance Corporation or any other agency or entity of the United States;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1c35cb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4202/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contain at least 1 new factual element necessary to establish a prima facie case that was unknown to the Government at the time of filing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1c35cc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4202/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set forth all facts supporting the allegation of a violation described in paragraph (2) known to the declarant, along with the names of material witnesses and the nature and location of documentary evidence known to the declarant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd1c35cd-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXV/s2562"},"text":"Pub. L. 101–647, title XXV, § 2562","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4894"},"text":"104 Stat. 4894","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
