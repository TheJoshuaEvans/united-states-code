{"tag":"section","attrib":{"id":"iddd092248-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3404"},"text":null,"children":[{"tag":"num","attrib":{"value":"3404"},"text":"§ 3404.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Customer authorizations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd092249-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3404/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement furnished by customer to financial institution and Government authority; contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A customer may authorize disclosure under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s3402/1"},"text":"section 3402(1) of this title","children":[],"tail":" if he furnishes to the financial institution and to the Government authority seeking to obtain such disclosure a signed and dated statement which—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd09224a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3404/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorizes such disclosure for a period not in excess of three months;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd09224b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3404/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" states that the customer may revoke such authorization at any time before the financial records are disclosed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd09224c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3404/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies the financial records which are authorized to be disclosed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd09224d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3404/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specifies the purposes for which, and the Government authority to which, such records may be disclosed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd09224e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3404/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" states the customer’s rights under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd09224f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3404/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization as condition of doing business prohibited","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No such authorization shall be required as a condition of doing business with any financial institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd092250-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3404/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right of customer to access to financial institution’s record of disclosures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The customer has the right, unless the Government authority obtains a court order as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s3409"},"text":"section 3409 of this title","children":[],"tail":", to obtain a copy of the record which the financial institution shall keep of all instances in which the customer’s record is disclosed to a Government authority pursuant to this section, including the identity of the Government authority to which such disclosure is made."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd092251-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/630/tXI/s1104"},"text":"Pub. L. 95–630, title XI, § 1104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3698"},"text":"92 Stat. 3698","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/3"},"text":"Pub. L. 96–3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-03-07"},"text":"Mar. 7, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/5"},"text":"93 Stat. 5","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd092252-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd092253-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd092254-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1979—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/3"},"text":"Pub. L. 96–3","children":[],"tail":" struck out subsec. (d) which had directed that all financial institutions promptly notify all of their customers of their rights under this chapter, that the Board of Governors of the Federal Reserve System prepare a statement of customers’ rights under this chapter, and that the supplying of such a statement to their customers by the financial institutions be deemed compliance with the notification requirement."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd092255-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd092256-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective upon the expiration of 120 days after ","children":[{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/630/s2101"},"text":"section 2101 of Pub. L. 95–630","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s375b"},"text":"section 375b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
