{"tag":"section","attrib":{"id":"iddd850908-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5913"},"text":null,"children":[{"tag":"num","attrib":{"value":"5913"},"text":"§ 5913.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rulemaking","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd850909-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5913/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2025-07-18"},"text":"July 18, 2025","children":[],"tail":", each primary Federal payment stablecoin regulator, the Secretary of the Treasury, and each State payment stablecoin regulator shall promulgate regulations to carry out this chapter through appropriate notice and comment rulemaking."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd85090a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5913/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Federal payment stablecoin regulators, the Secretary of the Treasury, and State payment stablecoin regulators should coordinate, as appropriate, on the issuance of any regulations to implement this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd85090b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5913/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report required","children":[],"tail":