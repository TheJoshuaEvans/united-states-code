{"tag":"section","attrib":{"id":"iddd281c15-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4543"},"text":null,"children":[{"tag":"num","attrib":{"value":"4543"},"text":"§ 4543.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public access to mortgage information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd281c16-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4543/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd281c17-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4543/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall make available to the public, in forms useful to the public (including forms accessible by computers), the data submitted by the enterprises in the reports required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1723a/m"},"text":"section 1723a(m) of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1456/e"},"text":"section 1456(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd281c18-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4543/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Census tract level reporting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such data shall include the data elements required to be reported under the Home Mortgage Disclosure Act of 1975 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2801"},"text":"12 U.S.C. 2801","children":[],"tail":" et seq.], at the census tract level."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd281c19-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4543/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd281c1a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4543/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proprietary data","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), the Director may not make available to the public data that the Director determines pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4546"},"text":"section 4546 of this title","children":[],"tail":" are proprietary information."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd281c1b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4543/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall not restrict access to the data provided in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1723a/m/1/A"},"text":"section 1723a(m)(1)(A) of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1456/e/1/A"},"text":"section 1456(e)(1)(A) of this title","children":[],"tail":" or with subsection (a)(2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd281c1c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4543/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may charge reasonable fees to cover the cost of making data available under this section to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd281c1d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4543/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Data submitted under this section by an enterprise in connection with a provision referred to in subsection (a) shall be made publicly available in accordance with this section not later than September 30 of the year following the year to which the data relates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd281c1e-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXIII/s1323"},"text":"Pub. L. 102–550, title XIII, § 1323","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3954"},"text":"106 Stat. 3954","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tI"},"text":"Pub. L. 110–289, div. A, title I","children":[],"tail":", §§ 1122(a)(1), 1126, "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2689"},"text":"122 Stat. 2689","children":[],"tail":", 2695.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd281c1f-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd281c20-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd281c21-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Home Mortgage Disclosure Act of 1975, referred to in subsec. (a)(2), is title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/200"},"text":"Pub. L. 94–200","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-31"},"text":"Dec. 31, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/1125"},"text":"89 Stat. 1125","children":[],"tail":", which is classified principally to chapter 29 (§ 2801 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2801"},"text":"section 2801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd281c22-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/s1122/a/1"},"text":"Pub. L. 110–289, § 1122(a)(1)","children":[],"tail":", substituted “Director” for “Secretary” wherever appearing in subsecs. (a) to (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/s1126/1"},"text":"Pub. L. 110–289, § 1126(1)","children":[],"tail":", substituted “Availability” for “In general” in subsec. heading, inserted par. (1) designation and heading, and added par. (2). The amendment was executed to reflect the probable intent of Congress, notwithstanding an error in the directory language which did not take into consideration the prior amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/110/289/s1122/a/1"},"text":"Pub. L. 110–289, § 1122(a)(1)","children":[],"tail":". See above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/s1126/2"},"text":"Pub. L. 110–289, § 1126(2)","children":[],"tail":", inserted “or with subsection (a)(2)” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/s1126/3"},"text":"Pub. L. 110–289, § 1126(3)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
