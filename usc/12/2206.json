{"tag":"section","attrib":{"id":"iddccb07e9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2206"},"text":null,"children":[{"tag":"num","attrib":{"value":"2206"},"text":"§ 2206.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation loans","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provisions of this chapter, the terms of any loan participated in by two or more Farm Credit System institutions operating under different subchapters of this chapter, including provisions for capitalization of the portion of the loan participated in by each institution, shall be as may be agreed upon among such institutions and authorized under regulations issued by the Farm Credit Administration, except that for purposes of determining borrower eligibility, membership, term, amount, loan security, and purchase of stock or participation certificates by the borrower, the provisions of law applicable to the loan shall be the provisions in the subchapter under which the institution that originates the loan operates.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddccb07ea-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tIV/s4"},"text":"Pub. L. 92–181, title IV, § 4","children":[],"tail":".18, as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/592/tIV/s403"},"text":"Pub. L. 96–592, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-24"},"text":"Dec. 24, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3446"},"text":"94 Stat. 3446","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/205/tII/s205/f/7"},"text":"Pub. L. 99–205, title II, § 205(f)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1706"},"text":"99 Stat. 1706","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddccb07eb-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddccb07ec-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddccb07ed-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1985—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/205"},"text":"Pub. L. 98–205","children":[],"tail":" inserted “under regulations issued” after “authorized”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddccb07ee-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddccb07ef-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1985 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/205"},"text":"Pub. L. 99–205","children":[],"tail":" effective thirty days after "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/205/s401"},"text":"section 401 of Pub. L. 99–205","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2001"},"text":"section 2001 of this title","children":[],"tail":"."}