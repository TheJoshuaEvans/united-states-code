{"tag":"section","attrib":{"id":"id056c7cfd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1631"},"text":null,"children":[{"tag":"num","attrib":{"value":"1631"},"text":"§ 1631.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of private collection agencies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id056c7cfe-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1631/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the Secretary, under such terms and conditions as the Secretary considers appropriate, shall enter into contracts and incur obligations with one or more persons for collection services to recover indebtedness arising under the customs laws and owed the United States Government, but only after the Customs Service has exhausted all administrative efforts, including all claims against applicable surety bonds, to collect the indebtedness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id056c7cff-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1631/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any contract entered into under subsection (a) shall provide that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id056c7d00-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1631/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary retains the authority to resolve a dispute, compromise a claim, end collection action, and refer a matter to the Attorney General to bring a civil action; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id056c7d01-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1631/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the person is subject to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id056c7d02-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1631/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of title 5","children":[],"tail":" to the extent provided in subsection (m) of such section; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id056c7d03-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1631/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" laws and regulations of the United States Government and State governments related to debt collection practices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id056c7d04-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1631/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The debtor shall be assessed and pay any and all costs associated with collection efforts pursuant to this section. Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3302/b"},"text":"section 3302(b) of title 31","children":[],"tail":", any sum so collected shall be used to pay the costs of debt collection services."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id056c7d05-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title IV, § 631, as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/182/tVI/s671"},"text":"Pub. L. 103–182, title VI, § 671","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-08"},"text":"Dec. 8, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2217"},"text":"107 Stat. 2217","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/295/s3/a/9"},"text":"Pub. L. 104–295, § 3(a)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3516"},"text":"110 Stat. 3516","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/36/tI/s1001/b/5/A"},"text":"Pub. L. 106–36, title I, § 1001(b)(5)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-06-25"},"text":"June 25, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/132"},"text":"113 Stat. 132","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id056c7d06-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id056c7d07-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id056c7d08-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—Subsec. (c). ","childr