{"tag":"section","attrib":{"id":"id060513bd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3007"},"text":null,"children":[{"tag":"num","attrib":{"value":"3007"},"text":"§ 3007.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication of Harmonized Tariff Schedule","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id060513be-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3007/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall compile and publish, at appropriate intervals, and keep up to date the Harmonized Tariff Schedule and related information in the form of printed copy; and, if, in its judgment, such format would serve the public interest and convenience—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id060513bf-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3007/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the form of microfilm images; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060513c0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3007/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the form of electronic media.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id060513c1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3007/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Publications under subsection (a), in whatever format, shall contain—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id060513c2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3007/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the then current Harmonized Tariff Schedule;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060513c3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3007/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" statistical annotations and related statistical information formulated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1484/f"},"text":"section 1484(f) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060513c4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3007/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other matters as the Commission considers to be necessary or appropriate to carry out the purposes enumerated in the Preamble to the Convention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id060513c5-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/tI/s1207"},"text":"Pub. L. 100–418, title I, § 1207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1151"},"text":"102 Stat. 1151","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/295/s21/e/10"},"text":"Pub. L. 104–295, § 21(e)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3531"},"text":"110 Stat. 3531","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id060513c6-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id060513c7-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id060513c8-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Harmonized Tariff Schedule, referred to in subsecs. (a) and (b)(1), is not set out in the Code. See Publication of Harmonized Tariff Schedule note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1202"},"text":"section 1202 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id060513c9-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/295"},"text":"Pub. L. 104–295","children":[],"tail":" substituted “1484(f)” for “1484(e)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
