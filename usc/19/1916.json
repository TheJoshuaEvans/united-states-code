{"tag":"section","attrib":{"id":"id0592a2c7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1916"},"text":null,"children":[{"tag":"num","attrib":{"value":"1916"},"text":"§ 1916.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of financial assistance; recording of mortgages","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0592a2c8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1916/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guarantees, agreements for deferred participation, and loans","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making and administering guarantees, agreements for deferred participation, and loans under section 1914 ","children":[{"tag":"ref","attrib":{"idref":"fn002066"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002066"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title, the Secretary of Commerce may—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0592a2c9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1916/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require security for any such guarantee, agreement, or loan, and enforce, waive, or subordinate such security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0592a2ca-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1916/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assign or sell at public or private sale, or otherwise dispose of, upon such terms and conditions and for such consideration as he shall determine to be reasonable, any evidence of debt, contract, claim, personal property, or security assigned to or held by him in connection with such guarantees, agreements, or loans, and collect, compromise, and obtain deficiency judgments with respect to all obligations assigned to or held by him in connection with such guarantees, agreements, or loans until such time as such obligations may be referred to the Attorney General for suit or collection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0592a2cb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1916/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" renovate, improve, modernize, complete, insure, rent, sell, or otherwise deal with, upon such terms and conditions and for such consideration as he shall determine to be reasonable, any real or personal property conveyed to or otherwise acquired by him in connection with such guarantees, agreements, or loans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0592a2cc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1916/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquire, hold, transfer, release, or convey any real or personal property or any interest therein whenever deemed necessary or appropriate, and execute all legal documents for such purposes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0592a2cd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1916/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exercise all such other powers and take all such other acts as may be necessary or incidental to the carrying out of functions pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1914"},"text":"section 1914 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0592a2ce-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1916/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mortgages","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any mortgage acquired as security under subsection (a) shall be recorded under applicable State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0592a2cf-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/794/tIII/s316"},"text":"Pub. L. 87–794, title III, § 316","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-11"},"text":"Oct. 11, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/888"},"text":"76 Stat. 888","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0592a2d0-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0592a2d1-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0592a2d2-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1914"},"text":"Section 1914 of this title","children":[],"tail":", referred to in subsec. (a), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/93/618/tVI/s602/e"},"text":"Pub. L. 93–618, title VI, § 602(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2072"},"text":"88 Stat. 2072","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
