{"tag":"section","attrib":{"id":"id060784da-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202"},"text":null,"children":[{"tag":"num","attrib":{"value":"3202"},"text":"§ 3202.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Beneficiary country","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id060784db-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id060784dc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “beneficiary country” means any country listed in subsection (b)(1) with respect to which there is in effect a proclamation by the President designating such country as a beneficiary country for purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060784dd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “entered” means entered, or withdrawn from warehouse for consumption, in the customs territory of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060784de-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “HTS” means Harmonized Tariff Schedule of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id060784df-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Countries eligible for designation; congressional notification","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id060784e0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In designating countries as beneficiary countries under this chapter, the President shall consider only the following countries or successor political entities:","children":[{"tag":"p","attrib":{"role":"listItem"},"text":"Bolivia","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"Ecuador","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Colombia","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Peru.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060784e1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Before the President designates any country as a beneficiary country for purposes of this chapter, he shall notify the House of Representatives and the Senate of his intention to make such designation, together with the considerations entering into such decision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id060784e2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on designation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President shall not designate any country a beneficiary country under this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id060784e3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if such country is a Communist country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060784e4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if such country—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id060784e5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has nationalized, expropriated or otherwise seized ownership or control of property owned by a United States citizen or by a corporation, partnership, or association which is 50 percent or more beneficially owned by United States citizens,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id060784e6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has taken steps to repudiate or nullify—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id060784e7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any existing contract or agreement with, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id060784e8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any patent, trademark, or other intellectual property of,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"a United States citizen or a corporation, partnership, or association, which is 50 percent or more beneficially owned by United States citizens, the effect of which is to nationalize, expropriate, or otherwise seize ownership or control of property so owned, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id060784e9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has imposed or enforced taxes or other exactions, restrictive maintenance or operational conditions, or other measures with respect to property so owned, the effect of which is to nationalize, expropriate, or otherwise seize ownership or control of such property, unless the President determines that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id060784ea-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prompt, adequate, and effective compensation has been or is being made to such citizen, corporation, partnership, or association,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id060784eb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" good-faith negotiations to provide prompt, adequate, and effective compensation under the applicable provisions of international law are in progress, or such country is otherwise taking steps to discharge its obligations under international law with respect to such citizen, corporation, partnership, or association, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id060784ec-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/c/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a dispute involving such citizen, corporation, partnership, or association, over compensation for such a seizure has been submitted to arbitration under the provisions of the Convention for the Settlement of Investment Disputes, or in another mutually agreed upon forum, and","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"promptly furnishes a copy of such determination to the Senate and House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060784ed-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if such country fails to act in good faith in recognizing as binding or in enforcing arbitral awards in favor of United States citizens or a corporation, partnership, or association which is 50 percent or more beneficially owned by United States citizens, which have been made by arbitrators appointed for each case or by permanent arbitral bodies to which the parties involved have submitted their dispute;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060784ee-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if such country affords preferential treatment to the products of a developed country, other than the United States, and if such preferential treatment has, or is likely to have, a significant adverse effect on United States commerce, unless the President—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id060784ef-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has received assurances satisfactory to him that such preferential treatment will be eliminated or that action will be taken to assure that there will be no such significant adverse effect, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id060784f0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reports those assurances to the Congress;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060784f1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if a government-owned entity in such country engages in the broadcast of copyrighted material, including films or television material, belonging to United States copyright owners without their express consent or such country fails to work towards the provision of adequate and effective protection of intellectual property rights;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060784f2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unless such country is a signatory to a treaty, convention, protocol, or other agreement regarding the extradition of United States citizens; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060784f3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if such country has not or is not taking steps to afford internationally recognized worker rights (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2467/4"},"text":"section 2467(4) of this title","children":[],"tail":") to workers in the country (including any designated zone in that country)."}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Paragraphs (1), (2), (3), (5), and (7) shall not prevent the designation of any country as a beneficiary country under this chapter if the President determines that such designation will be in the national economic or security interest of the United States and reports such determination to the Congress with his reasons therefor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id060784f4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors affecting designation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining whether to designate any country a beneficiary country under this chapter, the President shall take into account—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id060784f5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an expression by such country of its desire to be so designated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060784f6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the economic conditions in such country, the living standards of its inhabitants, and any other economic factors which he deems appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060784f7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which such country has assured the United States it will provide equitable and reasonable access to the markets and basic commodity resources of such country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060784f8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the degree to which such country follows the accepted rules of international trade provided for under the WTO Agreement and the multilateral trade agreements (as such terms are defined in paragraphs (9) and (4), respectively, of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3501"},"text":"section 3501 of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060784f9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the degree to which such country uses export subsidies or imposes export performance requirements or local content requirements which distort international trade;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060784fa-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the degree to which the trade policies of such country as they relate to other beneficiary countries are contributing to the revitalization of the region;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060784fb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the degree to which such country is undertaking self-help measures to protect its own economic development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060784fc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether or not such country has taken or is taking steps to afford to workers in that country (including any designated zone in that country) internationally recognized worker rights;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060784fd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/d/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which such country provides under its law adequate and effective means for foreign nationals to secure, exercise, and enforce exclusive rights in intellectual property, including patent, trademark, and copyright rights;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060784fe-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/d/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which such country prohibits its nationals from engaging in the broadcast of copyrighted material, including films or television material, belonging to United States copyright owners without their express consent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060784ff-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/d/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether such country has met the narcotics cooperation certification criteria set forth in section 2291(h)(2)(A) ","children":[{"tag":"ref","attrib":{"idref":"fn002152"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002152"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 22 for eligibility for United States assistance; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06078500-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/d/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which such country is prepared to cooperate with the United States in the administration of the provisions of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id06078501-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal or suspension of designation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id06078502-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id06078503-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The President may—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id06078504-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/e/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" withdraw or suspend the designation of any country as a beneficiary country, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id06078505-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/e/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" withdraw, suspend, or limit the application of duty-free treatment under this chapter to any article of any country,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"if, after such designation, the President determines that as a result of changed circumstances such a country should be barred from designation as a beneficiary country.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06078506-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The President may, after the requirements of paragraph (2) have been met—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id06078507-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" withdraw or suspend the designation of any country as an ATPDEA beneficiary country, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id06078508-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" withdraw, suspend, or limit the application of preferential treatment under section 3203(b)(1), (3), or (4) of this title to any article of any country,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"if, after such designation, the President determines that, as a result of changed circumstances, the performance of such country is not satisfactory under the criteria set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3203/b/6/B"},"text":"section 3203(b)(6)(B) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06078509-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0607850a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President shall publish in the Federal Register notice of the action the President proposes to take under paragraph (1) at least 30 days before taking such action.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0607850b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The United States Trade Representative shall, within the 30-day period beginning on the date on which the President publishes under subparagraph (A) notice of proposed action—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0607850c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept written comments from the public regarding such proposed action,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0607850d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hold a public hearing on such proposed action, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0607850e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/e/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" publish in the Federal Register—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0607850f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/e/2/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notice of the time and place of such hearing prior to the hearing, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id06078510-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/e/2/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the time and place at which such written comments will be accepted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id06078511-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id06078512-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2010-06-30"},"text":"June 30, 2010","children":[],"tail":", and annually thereafter during the period this chapter is in effect, the United States Trade Representative shall submit to the Congress a report regarding the operation of this chapter, including—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id06078513-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to subsections (c) and (d), the results of a general review of beneficiary countries based on the considerations described in such subsections; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06078514-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the performance of each beneficiary country or ATPEA ","children":[{"tag":"ref","attrib":{"idref":"fn002153"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002153"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “ATPDEA”."}],"tail":" beneficiary country, as the case may be, under the criteria set forth in "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3203/b/6/B"},"text":"section 3203(b)(6)(B) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06078515-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3202/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public comment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before submitting the report described in paragraph (1), the United States Trade Representative shall publish a notice in the Federal Register requesting public comments on whether beneficiary countries are meeting the criteria listed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3203/b/6/B"},"text":"section 3203(b)(6)(B) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id06078516-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/182/tII/s203"},"text":"Pub. L. 102–182, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-04"},"text":"Dec. 4, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1236"},"text":"105 Stat. 1236","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/tVI/s621/a/3"},"text":"Pub. L. 103–465, title VI, § 621(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4992"},"text":"108 Stat. 4992","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1954/a/2"},"text":"Pub. L. 104–188, title I, § 1954(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1927"},"text":"110 Stat. 1927","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/200/tII/s211/c/2"},"text":"Pub. L. 106–200, title II, § 211(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-05-18"},"text":"May 18, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/287"},"text":"114 Stat. 287","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/210/dC/tXXXI/s3103/b"},"text":"Pub. L. 107–210, div. C, title XXXI, § 3103(b)","children":[],"tail":", (e), "},{"tag":"date","attrib":{"date":"2002-08-06"},"text":"Aug. 6, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1033"},"text":"116 Stat. 1033","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/124/s2/c"},"text":"Pub. L. 111–124, § 2(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-12-28"},"text":"Dec. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/3484"},"text":"123 Stat. 3484","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/344/tII/s201/d"},"text":"Pub. L. 111–344, title II, § 201(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-29"},"text":"Dec. 29, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3616"},"text":"124 Stat. 3616","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id06078517-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id06078518-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id06078519-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Harmonized Tariff Schedule of the United States, referred to in subsec. (a)(3), is not set out in the Code. See Publication of Harmonized Tariff Schedule note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1202"},"text":"section 1202 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2291"},"text":"section 2291 of title 22","children":[],"tail":", referred to in subsec. (d)(11), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/102/583/s6/b/2"},"text":"Pub. L. 102–583, § 6(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-02"},"text":"Nov. 2, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4932"},"text":"106 Stat. 4932","children":[],"tail":". For successor provisions to former subsec. (h), see sections 2291j and 2291k of Title 22, Foreign Relations and Intercourse."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (d)(12), was in the original “this Act” and was translated as reading “this title”, meaning title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/182"},"text":"Pub. L. 102–182","children":[],"tail":" which enacted this chapter, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0607851a-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/344"},"text":"Pub. L. 111–344","children":[],"tail":" substituted “annually” for “every 2 years” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/124"},"text":"Pub. L. 111–124","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2010-06-30"},"text":"June 30, 2010","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2003-04-30"},"text":"April 30, 2003","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/210/s3103/b"},"text":"Pub. L. 107–210, § 3103(b)","children":[],"tail":", designated existing provisions as subpar. (A), redesignated former subpars. (A) and (B) as cls. (i) and (ii), respectively, of subpar. (A), and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/210/s3103/e"},"text":"Pub. L. 107–210, § 3103(e)","children":[],"tail":", substituted “Reporting requirements” for “Report” in heading and amended text generally. Prior to amendment, text read as follows: “Not later than "},{"tag":"date","attrib":{"date":"2001-01-31"},"text":"January 31, 2001","children":[],"tail":", the President shall submit to the Congress a complete report regarding the operation of this chapter, including the results of a general review of beneficiary countries based on the considerations described in subsections (c) and (d) of this section. In reporting on the considerations described in subsection (d)(11) of this section, the President shall report any evidence that the crop eradication and crop substitution efforts of the beneficiary are directly related to the effects of this chapter.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/200"},"text":"Pub. L. 106–200","children":[],"tail":" substituted “Report” for “Triennial report” in heading and “Not later than "},{"tag":"date","attrib":{"date":"2001-01-31"},"text":"January 31, 2001","children":[],"tail":"” for “On or before the 3rd, 6th, and 9th anniversaries of "},{"tag":"date","attrib":{"date":"1991-12-04"},"text":"December 4, 1991","children":[],"tail":"” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (c)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188"},"text":"Pub. L. 104–188","children":[],"tail":" substituted “2467(4) of this title” for “2462(a)(4) of this title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465"},"text":"Pub. L. 103–465","children":[],"tail":" substituted “WTO Agreement and the multilateral trade agreements (as such terms are defined in paragraphs (9) and (4), respectively, of "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3501"},"text":"section 3501 of this title","children":[],"tail":")” for “General Agreement on Tariffs and Trade, as well as applicable trade agreements approved under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2503/a"},"text":"section 2503(a) of this title","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0607851b-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0607851c-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188"},"text":"Pub. L. 104–188","children":[],"tail":" applicable to articles entered on or after "},{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", with provisions relating to retroactive application, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/s1953"},"text":"section 1953 of Pub. L. 104–188","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2461"},"text":"section 2461 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0607851d-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465"},"text":"Pub. L. 103–465","children":[],"tail":" effective on the date on which the WTO Agreement enters into force with respect to the United States ("},{"tag":"date","attrib":{"date":"1995-01-01"},"text":"Jan. 1, 1995","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/s621/b"},"text":"section 621(b) of Pub. L. 103–465","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1677k"},"text":"section 1677k of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0607851e-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Petitions for Review","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/210/dC/tXXXI/s3103/d"},"text":"Pub. L. 107–210, div. C, title XXXI, § 3103(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-06"},"text":"Aug. 6, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1033"},"text":"116 Stat. 1033","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/210/dC/tXXXI/s3103/d"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2002-08-06"},"text":"Aug. 6, 2002","children":[],"tail":"], the President shall promulgate regulations regarding the review of eligibility of articles and countries under the Andean Trade Preference Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3201"},"text":"19 U.S.C. 3201","children":[],"tail":" et seq.], consistent with section 203(e) of such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3202/e"},"text":"19 U.S.C. 3202(e)","children":[],"tail":"], as amended by this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Content of regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The regulations shall be similar to the regulations regarding eligibility under the generalized system of preferences under title V of the Trade Act of 1974 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2461"},"text":"19 U.S.C. 2461","children":[],"tail":" et seq.] with respect to the timetable for reviews and content, and shall include procedures for requesting withdrawal, suspension, or limitations of preferential duty treatment under the Andean Trade Preference Act, conducting reviews of such requests, and implementing the results of the reviews.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For delegation of functions of President under ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/210/s3103/d"},"text":"section 3103(d) of Pub. L. 107–210","children":[],"tail":", set out above, see section 2(a) of Ex. Ord. No. 13277, "},{"tag":"date","attrib":{"date":"2002-11-19"},"text":"Nov. 19, 2002","children":[],"tail":", 67 F.R. 70305, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3801"},"text":"section 3801 of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id0607851f-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id06078520-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Authority","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of President under subsec. (e)(2)(A) of this section, related to publishing notice of proposal to suspend designation of Bolivia as beneficiary country, were delegated to United States Trade Representative by Memorandum of the President of the United States, ","children":[{"tag":"date","attrib":{"date":"2008-09-25"},"text":"Sept. 25, 2008","children":[],"tail":", 73 F.R. 56701."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of functions of President under div. C of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/210"},"text":"Pub. L. 107–210","children":[],"tail":", amending this section, see section 2 of Ex. Ord. No. 13277, "},{"tag":"date","attrib":{"date":"2002-11-19"},"text":"Nov. 19, 2002","children":[],"tail":", 67 F.R. 70305, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3801"},"text":"section 3801 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of President under subsec. (e)(2)(A), related to publishing notice of proposed actions, delegated to United States Trade Representative, see Proc. No. 7616, ","children":[{"tag":"date","attrib":{"date":"2002-10-31"},"text":"Oct. 31, 2002","children":[],"tail":", 67 F.R. 67283, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3203"},"text":"section 3203 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id06078521-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Presidential Designation of Beneficiary Countries","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The following countries were designated as beneficiary countries for purposes of this chapter:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Bolivia, Proc. No. 6456, ","children":[{"tag":"date","attrib":{"date":"1992-07-02"},"text":"July 2, 1992","children":[],"tail":", 57 F.R. 30097; designation suspended by Proc. No. 8323, "},{"tag":"date","attrib":{"date":"2008-11-25"},"text":"Nov. 25, 2008","children":[],"tail":", 73 F.R. 72679, effective "},{"tag":"date","attrib":{"date":"2008-12-15"},"text":"Dec. 15, 2008","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Colombia, Proc. No. 6455, ","children":[{"tag":"date","attrib":{"date":"1992-07-02"},"text":"July 2, 1992","children":[],"tail":", 57 F.R. 30069."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Peru, Proc. No. 6585, ","children":[{"tag":"date","attrib":{"date":"1993-08-11"},"text":"Aug. 11, 1993","children":[],"tail":", 58 F.R. 43239."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
