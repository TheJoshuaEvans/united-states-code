{"tag":"section","attrib":{"id":"id05ef8fee-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2542"},"text":null,"children":[{"tag":"num","attrib":{"value":"2542"},"text":"§ 2542.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and operation of technical offices","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05ef8fef-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2542/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05ef8ff0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2542/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" For nonagricultural products","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce shall establish and maintain within the Department of Commerce a technical office that shall carry out the functions prescribed under subsection (b) with respect to nonagricultural products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05ef8ff1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2542/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" For agricultural products","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture shall establish and maintain within the Department of Agriculture a technical office that shall carry out the functions prescribed under subsection (b) with respect to agricultural products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05ef8ff2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2542/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions of offices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall prescribe for each technical office established under subsection (a) such functions as the President deems necessary or appropriate to implement this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05ef8ff3-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39/tIV/s412"},"text":"Pub. L. 96–39, title IV, § 412","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/244"},"text":"93 Stat. 244","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05ef8ff4-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id05ef8ff5-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id05ef8ff6-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of President under subsec. (b) of this section delegated to Secretary of Commerce regarding technical office established under subsec. (a)(1) of this section, and to Secretary of Agriculture regarding technical office established under subsec. (a)(2) of this section, see section 1–103(a) of Ex. Ord. No. 12188, ","children":[{"tag":"date","attrib":{"date":"1980-01-02"},"text":"Jan. 2, 1980","children":[],"tail":", 45 F.R. 990, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2171"},"text":"section 2171 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
