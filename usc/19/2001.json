{"tag":"section","attrib":{"id":"id05951346-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2001"},"text":null,"children":[{"tag":"num","attrib":{"value":"2001"},"text":"§ 2001.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional declaration of purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of this chapter are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05951347-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2001/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide for the implementation of the Agreement Concerning Automotive Products Between the Government of the United States of America and the Government of Canada signed on ","children":[{"tag":"date","attrib":{"date":"1965-01-16"},"text":"January 16, 1965","children":[],"tail":" (hereinafter referred to as the “Agreement”), in order to strengthen the economic relations and expand trade in automotive products between the United States and Canada; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05951348-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2001/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to authorize the implementation of such other international agreements providing for the mutual reduction or elimination of duties applicable to automotive products as the Government of the United States may hereafter enter into.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05951349-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/283/tI/s102"},"text":"Pub. L. 89–283, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-10-21"},"text":"Oct. 21, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1016"},"text":"79 Stat. 1016","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0595134a-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0595134b-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0595134c-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/283"},"text":"Pub. L. 89–283","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-10-21"},"text":"Oct. 21, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1016"},"text":"79 Stat. 1016","children":[],"tail":", as amended. For complete classification of this Act to the Code, see Short Title note set out below and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0595134d-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id0595134e-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/89/283/tI/s101"},"text":"Pub. L. 89–283, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-10-21"},"text":"Oct. 21, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1016"},"text":"79 Stat. 1016","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/89/283/tI/s101"},"text":"“This Act [enacting this chapter, amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1202"},"text":"section 1202 of this title","children":[],"tail":" and Schedules 2, 3, 5, 6, and 7 of the Tariff Schedules of the United States, and enacting provisions set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1202"},"text":"section 1202 of this title","children":[],"tail":"] may be cited as the ‘Automotive Products Trade Act of 1965’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
