{"tag":"section","attrib":{"id":"id056eeea0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1646a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1646a"},"text":"§ 1646a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supervision by customs officers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Wherever in this chapter any action or thing is required to be done or maintained under the supervision of customs officers, such supervision may be directed and continuous or by occasional verification as may be required by regulations of the Secretary of the Treasury, or, in the absence of such regulations for a particular case, as the principal customs officer concerned shall direct.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id056eeea1-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title IV, § 646, as added "},{"tag":"ref","attrib":{"href":"/us/act/1953-08-08/ch397/s22"},"text":"Aug. 8, 1953, ch. 397, § 22","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/67/520"},"text":"67 Stat. 520","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id056eeea2-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id056eeea3-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id056eeea4-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on and after thirtieth day following ","children":[{"tag":"date","attrib":{"date":"1953-08-08"},"text":"Aug. 8, 1953","children":[],"tail":", see Effective Date of 1953 Amendments note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1304"},"text":"section 1304 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
