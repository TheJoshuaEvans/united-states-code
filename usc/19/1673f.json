{"tag":"section","attrib":{"id":"id057ad4b0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673f"},"text":null,"children":[{"tag":"num","attrib":{"value":"1673f"},"text":"§ 1673f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of difference between deposit of estimated antidumping duty and final assessed duty under antidumping duty order","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id057ad4b1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit of estimated antidumping duty under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1673b/d/1/B"},"text":"section 1673b(d)(1)(B) of this title","children":[],"tail":null}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the amount of a cash deposit, or the amount of any bond or other security, required as security for an estimated antidumping duty under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1673b/d/1/B"},"text":"section 1673b(d)(1)(B) of this title","children":[],"tail":" is different from the amount of the antidumping duty determined under an antidumping duty order published under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1673e"},"text":"section 1673e of this title","children":[],"tail":", then the difference for entries of merchandise entered, or withdrawn from warehouse, for consumption before notice of the affirmative determination of the Commission under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1673d/b"},"text":"section 1673d(b) of this title","children":[],"tail":" is published shall be—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id057ad4b2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673f/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disregarded, to the extent that the cash deposit, bond, or other security is lower than the duty under the order, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id057ad4b3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673f/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" refunded or released, to the extent that the cash deposit, bond, or other security is higher than the duty under the order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id057ad4b4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit of estimated antidumping duty under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1673e/a/3"},"text":"section 1673e(a)(3) of this title","children":[],"tail":null}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the amount of an estimated antidumping duty deposited under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1673e/a/3"},"text":"section 1673e(a)(3) of this title","children":[],"tail":" is different from the amount of the antidumping duty determined under an antidumping duty order published under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1673e"},"text":"section 1673e of this title","children":[],"tail":", then the difference for entries of merchandise entered, or withdrawn from warehouse, for consumption after notice of the affirmative determination of the Commission under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1673d/b"},"text":"section 1673d(b) of this title","children":[],"tail":" is published shall be—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id057ad4b5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673f/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collected, to the extent that the deposit under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1673e/a/3"},"text":"section 1673e(a)(3) of this title","children":[],"tail":" is lower than the duty determined under the order, or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id057ad4b6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673f/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" refunded, to the extent that the deposit under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1673e/a/3"},"text":"section 1673e(a)(3) of this title","children":[],"tail":" is higher than the duty determined under the order,"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"together with interest as provided by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1677g"},"text":"section 1677g of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id057ad4b7-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title VII, § 737, as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/39/tI/s101"},"text":"Pub. L. 96–39, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/173"},"text":"93 Stat. 173","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/tII/s219/c/10"},"text":"Pub. L. 103–465, title II, § 219(c)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4857"},"text":"108 Stat. 4857","children":[],"tail":"; "},{