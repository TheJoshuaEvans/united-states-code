{"tag":"section","attrib":{"id":"id0653d0e2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4513"},"text":null,"children":[{"tag":"num","attrib":{"value":"4513"},"text":"§ 4513.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementing actions in anticipation of entry into force; initial regulations; tariff proclamation authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0653d0e3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4513/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementing actions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0653d0e4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4513/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proclamation authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"After ","children":[{"tag":"date","attrib":{"date":"2020-01-29"},"text":"January 29, 2020","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0653d0e5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4513/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President may proclaim such actions, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0653d0e6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4513/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other appropriate officers of the United States Government may prescribe such regulations,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"as may be necessary to ensure that any provision of this Act, or amendment made by this Act, that takes effect on the date on which the USMCA enters into force is appropriately implemented on such date, but no such proclamation or regulation may have an effective date earlier than the date on which the USMCA enters into force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0653d0e7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4513/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date of certain proclaimed actions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any action proclaimed by the President under the authority of this Act that is not subject to the consultation and layover provisions under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4514"},"text":"section 4514 of this title","children":[],"tail":" may not take effect before the 15th day after the date on which the text of the proclamation is published in the Federal Register."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0653d0e8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4513/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver of 15-day restriction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The 15-day restriction contained in paragraph (2) on the taking effect of proclaimed actions is waived to the extent that the application of such restriction would prevent the taking effect on the date on which the USMCA enters into force of any action proclaimed under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0653d0e9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4513/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial regulations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0653d0ea-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4513/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided by paragraph (2) or (3), initial regulations necessary or appropriate to carry out the actions required by or authorized under this Act or proposed in the statement of administrative action approved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4511/a/2"},"text":"section 4511(a)(2) of this title","children":[],"tail":" to implement the USMCA shall, to the maximum extent feasible, be prescribed within 1 year after the date on which the USMCA enters into force."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0653d0eb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4513/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uniform regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Interim or initial regulations to implement the Uniform Regulations regarding rules of origin provided for under article 5.16 of the USMCA shall be prescribed not later than the date on which the USMCA enters into force.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0653d0ec-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4513/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementing actions with effective dates after entry into force","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any implementing action that takes effect on a date after the date on which the USMCA enters into force, initial regulations to carry out that action shall, to the maximum extent feasible, be prescribed within 1 year after such effective date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0653d0ed-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4513/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tariff modifications","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0653d0ee-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4513/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tariff modifications provided for in the USMCA","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President may proclaim—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0653d0ef-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4513/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such modifications or continuation of any duty,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0653d0f0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4513/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such continuation of duty-free or excise treatment, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0653d0f1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4513/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such additional duties,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"as the President determines to be necessary or appropriate to carry out or apply articles 2.4, 2.5, 2.7, 2.8, 2.9, 2.10, 6.2, and 6.3, the Schedule of the United States to Annex 2–B, including the appendices to that Annex, Annex 2–C, and Annex 6–A, of the USMCA.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0653d0f2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4513/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other tariff modifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the consultation and layover provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4514"},"text":"section 4514 of this title","children":[],"tail":", the President may proclaim—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0653d0f3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4513/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such modifications or continuation of any duty,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0653d0f4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4513/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such modifications as the United States may agree to with a USMCA country regarding the staging of any duty treatment set forth in the Schedule of the United States to Annex 2–B of the USMCA, including the appendices to that Annex,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0653d0f5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4513/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such continuation of duty-free or excise treatment, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0653d0f6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4513/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such additional duties,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"as the President determines to be necessary or appropriate to maintain the general level of reciprocal and mutually advantageous concessions with respect to a USMCA country provided for by the USMCA.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0653d0f7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4513/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conversion to ad valorem rates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraphs (1) and (2), with respect to any good for which the base rate in the Schedule of the United States to Annex 2–B of the USMCA is a specific or compound rate of duty, the President shall substitute for the base rate an ad valorem rate that the President determines to be equivalent to the base rate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0653d0f8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4513/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tariff-rate quotas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In implementing the tariff-rate quotas set forth in the Schedule of the United States to Annex 2–B of the USMCA, the President shall take such actions as may be necessary to ensure that imports of agricultural goods do not disrupt the orderly marketing of agricultural goods in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0653d0f9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4513/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presidential proclamation authority relating to rules of origin","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0653d0fa-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4513/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President may proclaim, as part of the HTS—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0653d0fb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4513/c/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provisions set forth in Annex 4–B of the USMCA;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0653d0fc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4513/c/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provisions set forth in paragraph 2 of article 3.A.6 of Annex 3–A of the USMCA;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0653d0fd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4513/c/5/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provisions set forth in paragraph 5 of Annex 3–B of the USMCA;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0653d0fe-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4513/c/5/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provisions set forth in paragraphs 14(b), 14(c), and 15(e) of Section B of Appendix 2 to Annex 2–B of the USMCA; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0653d0ff-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4513/c/5/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any additional subordinate category that is necessary to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4531"},"text":"section 4531 of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s4532"},"text":"section 4532 of this title","children":[],"tail":" consistent with the USMCA."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0653d100-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4513/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modifications","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0653d101-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4513/c/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the consultation and layover provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4514"},"text":"section 4514 of this title","children":[],"tail":", the President may proclaim modifications to the provisions proclaimed under the authority of subparagraph (A), other than the provisions of chapters 50 through 63 of the USMCA."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0653d102-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4513/c/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for textiles","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding clause (i), and subject to the consultation and layover provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4514"},"text":"section 4514 of this title","children":[],"tail":", the President may proclaim—"}],"tail":null},{"tag":"subclause","attrib":{"id":"id0653d103-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4513/c/5/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such modifications to the provisions proclaimed under the authority of subparagraph (A) as are necessary to implement an agreement with one or more USMCA countries pursuant to article 6.4 of the USMCA; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0653d104-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4513/c/5/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before the end of the 1-year period beginning on the date on which the USMCA enters into force, modifications to correct any typographical, clerical, or other nonsubstantive technical error regarding the provisions of chapters 50 through 63 of the USMCA.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0653d105-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113/tI/s103"},"text":"Pub. L. 116–113, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-01-29"},"text":"Jan. 29, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/15"},"text":"134 Stat. 15","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0653d106-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0653d107-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0653d108-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsecs. (a)(1), (2) and (b)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113"},"text":"Pub. L. 116–113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-01-29"},"text":"Jan. 29, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/11"},"text":"134 Stat. 11","children":[],"tail":", known as the United States-Mexico-Canada Agreement Implementation Act. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s4501"},"text":"section 4501 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0653d109-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0653d10a-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of Subsection (c)","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsec. (c) of this section effective on the date the USMCA entered into force (","children":[{"tag":"date","attrib":{"date":"2020-07-01"},"text":"July 1, 2020","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/116/113/s107/b"},"text":"section 107(b) of Pub. L. 116–113","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s4501"},"text":"section 4501 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id0653d10b-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id0653d10c-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Proc. No. 10053, pars. (5), (6), ","children":[{"tag":"date","attrib":{"date":"2020-06-29"},"text":"June 29, 2020","children":[],"tail":", 85 F.R. 39826, authorized the United States Trade Representative to exercise the authority of the President under subsec. (c)(4) of this section and the Committee for Implementation of Textile Agreements to exercise the authority of the President under subsec. (c)(1) of this section with respect to a good provided for under article 6.2 of the USMCA."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
