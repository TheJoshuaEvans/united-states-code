{"tag":"section","attrib":{"id":"id05dc7d56-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2433"},"text":null,"children":[{"tag":"num","attrib":{"value":"2433"},"text":"§ 2433.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States personnel missing in action in Southeast Asia","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05dc7d57-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2433/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty for noncooperating countries","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, if the President determines that a nonmarket economy country is not cooperating with the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05dc7d58-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2433/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to achieve a complete accounting of all United States military and civilian personnel who are missing in action in Southeast Asia,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05dc7d59-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2433/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to repatriate such personnel who are alive, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05dc7d5a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2433/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to return the remains of such personnel who are dead to the United States,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then, during the period beginning with the date of such determination and ending on the date on which the President determines such country is cooperating with the United States, he may provide that—","children":[],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05dc7d5b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2433/a/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the products of such country may not receive nondiscriminatory treatment,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05dc7d5c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2433/a/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such country may not participate, directly or indirectly, in any program under which the United States extends credit, credit guarantees, or investment guarantees, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05dc7d5d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2433/a/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no commercial agreement entered into under this subchapter between such country and the United States will take effect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05dc7d5e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2433/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply to any country the products of which are eligible for the rates set forth in rate column numbered 1 of the Tariff Schedules of the United States on ","children":[{"tag":"date","attrib":{"date":"1975-01-03"},"text":"January 3, 1975","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05dc7d5f-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/tIV/s403"},"text":"Pub. L. 93–618, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2060"},"text":"88 Stat. 2060","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05dc7d60-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05dc7d61-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id05dc7d62-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Tariff Schedules of the United States, referred to in subsec. (b), to be treated as a reference to the Harmonized Tariff Schedule, pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3012"},"text":"section 3012 of this title","children":[],"tail":". The Harmonized Tariff Schedule is not set out in the Code. See Publication of Harmonized Tariff Schedule note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1202"},"text":"section 1202 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
