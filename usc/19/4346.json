{"tag":"section","attrib":{"id":"id064f1574-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4346"},"text":null,"children":[{"tag":"num","attrib":{"value":"4346"},"text":"§ 4346.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personnel dedicated to the enforcement of intellectual property rights","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id064f1575-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4346/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personnel of U.S. Customs and Border Protection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commissioner and the Director of U.S. Immigration and Customs Enforcement shall ensure that sufficient personnel are assigned throughout U.S. Customs and Border Protection and U.S. Immigration and Customs Enforcement, respectively, who have responsibility for preventing the importation into the United States of merchandise that infringes intellectual property rights.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id064f1576-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4346/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staffing of National Intellectual Property Rights Coordination Center","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commissioner shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id064f1577-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4346/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assign not fewer than 3 full-time employees of U.S. Customs and Border Protection to the National Intellectual Property Rights Coordination Center established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4344"},"text":"section 4344 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064f1578-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4346/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that sufficient personnel are assigned to United States ports of entry to carry out the directives of the Center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id064f1579-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/125/tIII/s307"},"text":"Pub. L. 114–125, title III, § 307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-24"},"text":"Feb. 24, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/152"},"text":"130 Stat. 152","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
