{"tag":"section","attrib":{"id":"id05465742-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1495"},"text":null,"children":[{"tag":"num","attrib":{"value":"1495"},"text":"§ 1495.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnership bond","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"When any bond is required by law or regulations to be executed by any partnership for any purpose connected with the transaction of business at any customhouse, the execution of such bond by any member of such partnership shall bind the other partners in like manner and to the same extent as if such other partners had personally joined in the execution, and an action or suit may be instituted on such bond against all partners as if all had executed the same.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id05465743-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title IV, § 495, "},{"tag":"ref","attrib":{"href":"/us/stat/46/727"},"text":"46 Stat. 727","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05465744-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05465745-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id05465746-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-09-21/ch356/tIV/s495"},"text":"act Sept. 21, 1922, ch. 356, title IV, § 495","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/964"},"text":"42 Stat. 964","children":[],"tail":". That section was superseded by section 495 of act "},{"tag":"date","attrib":{"date":"1930-06-17"},"text":"June 17, 1930","children":[],"tail":", comprising this section, and repealed by section 651(a)(1) of the 1930 act."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions substantially similar to those in this section, except that they applied to bonds for the payment of duties or for any other purpose connected with the general transaction of business at any customs house, were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/act/1876-06-20/ch136"},"text":"act June 20, 1876, ch. 136","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/19/60"},"text":"19 Stat. 60","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/act/1894-08-27/ch349/s70"},"text":"act Aug. 27, 1894, ch. 349, § 70","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/569"},"text":"28 Stat. 569","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/act/1922-09-21/ch356/tIV/s643"},"text":"act Sept. 21, 1922, ch. 356, title IV, § 643","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/989"},"text":"42 Stat. 989","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
