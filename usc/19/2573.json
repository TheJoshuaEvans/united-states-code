{"tag":"section","attrib":{"id":"id05f2008b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2573"},"text":null,"children":[{"tag":"num","attrib":{"value":"2573"},"text":"§ 2573.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress on operation of agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"As soon as practicable after the close of the 3-year period beginning on the date on which this subchapter takes effect, and as soon as practicable after the close of each succeeding 3-year period through 2001, the Trade Representative shall prepare and submit to Congress a report containing an evaluation of the operation of the Agreement, both domestically and internationally, during the period.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id05f2008c-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39/tIV/s453"},"text":"Pub. L. 96–39, title IV, § 453","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/250"},"text":"93 Stat. 250","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/182/tIII/s351/b/2/A"},"text":"Pub. L. 103–182, title III, § 351(b)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-08"},"text":"Dec. 8, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2122"},"text":"107 Stat. 2122","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/tIII/s351/f"},"text":"Pub. L. 103–465, title III, § 351(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4957"},"text":"108 Stat. 4957","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/295/s21/b/1"},"text":