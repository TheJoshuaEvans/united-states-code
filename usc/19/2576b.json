{"tag":"section","attrib":{"id":"id05f200c7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2576b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2576b"},"text":"§ 2576b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subpart definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2571"},"text":"section 2571 of this title","children":[],"tail":", for purposes of this subpart—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id05f200c8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2576b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval procedure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “approval procedure” means any registration, notification, or other mandatory administrative procedure for granting permission for a good or service to be produced, marketed, or used for a stated purpose or under stated conditions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f200c9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2576b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conformity assessment procedure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “conformity assessment procedure” means any procedure used, directly or indirectly, to determine that a technical regulation or standard is fulfilled, including sampling, testing, inspection, evaluation, verification, monitoring, auditing, assurance of conformity, accreditation, registration, or approval used for such a purpose, but does not mean an approval procedure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f200ca-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2576b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Objective","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “objective” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05f200cb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2576b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" safety,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05f200cc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2576b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protection of human, animal, or plant life or health, the environment or consumers, including matters relating to quality and identifiability of goods or services, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05f200cd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2576b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sustainable development,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"but does not include the protection of domestic production.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f200ce-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2576b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “service” means a land transportation service or a telecommunications service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f200cf-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2576b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standard","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “standard” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05f200d0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2576b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" characteristics for a good or a service,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05f200d1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2576b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" characteristics, rules, or guidelines for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id05f200d2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2576b/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" processes or production methods relating to such good, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05f200d3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2576b/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operating methods relating to such service, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05f200d4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2576b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provisions specifying terminology, symbols, packaging, marking, or labelling for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id05f200d5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2576b/5/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a good or its related process or production methods, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05f200d6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2576b/5/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a service or its related operating methods,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"for common and repeated use, including explanatory and other related provisions set out in a document approved by a standardizing body, with which compliance is not mandatory.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f200d7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2576b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards-related measure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “standards-related measure” means a standard, technical regulation, or conformity assessment procedure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f200d8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2576b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical regulation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “technical regulation” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05f200d9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2576b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" characteristics or their related processes and production methods for a good,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05f200da-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2576b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" characteristics for a service or its related operating methods, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05f200db-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2576b/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provisions specifying terminology, symbols, packaging, marking, or labelling for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id05f200dc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2576b/7/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a good or its related process or production method, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05f200dd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2576b/7/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a service or its related operating method,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"set out in a document, including applicable administrative, explanatory, and other related provisions, with which compliance is mandatory.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f200de-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2576b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Telecommunications service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “telecommunications service” means a service provided by means of the transmission and reception of signals by any electromagnetic means, but does not mean the cable, broadcast, or other electromagnetic distribution of radio or television programming to the public generally.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05f200df-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39/tIV/s473"},"text":"Pub. L. 96–39, title IV, § 473","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/182/tIII/s351/a"},"text":"Pub. L. 103–182, title III, § 351(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-08"},"text":"Dec. 8, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2120"},"text":"107 Stat. 2120","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
