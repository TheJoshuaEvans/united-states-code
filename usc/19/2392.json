{"tag":"section","attrib":{"id":"id05d306ef-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2392"},"text":null,"children":[{"tag":"num","attrib":{"value":"2392"},"text":"§ 2392.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment Assistance Coordinating Committee","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is established the Adjustment Assistance Coordinating Committee to consist of a Deputy United States Trade Representative as Chairman, and the officials charged with adjustment assistance responsibilities of the Departments of Labor and Commerce and the Small Business Administration. It shall be the function of the Committee to coordinate the adjustment assistance policies, studies, and programs of the various agencies involved and to promote the efficient and effective delivery of adjustment assistance benefits.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id05d306f0-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/tII/s281"},"text":"Pub. L. 93–618, title II, § 281","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2040"},"text":"88 Stat. 2040","children":[],"tail":"; 1979 Reorg. Plan No. 3, § 1(c), eff. "},{"tag":"date","attrib":{"date":"1980-01-02"},"text":"Jan. 2, 1980","children":[],"tail":", 44 F.R. 69274, "},{"tag":"ref","attrib":{"href":"/us/stat/93/1381"},"text":"93 Stat. 1381","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05d306f1-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id05d306f2-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id05d306f3-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Deputy United States Trade Representative” substituted in text for “Deputy Special Trade Representative”, meaning Deputy Special Representative for Trade Negotiations, pursuant to Reorg. Plan No. 3 of 1979, § 1(c), 44 F.R. 69274, ","children":[{"tag":"ref","attrib":{"href":"/us/stat/93/1381"},"text":"93 Stat. 1381","children":[],"tail":", eff. "},{"tag":"date","attrib":{"date":"1980-01-02"},"text":"Jan. 2, 1980","children":[],"tail":", as provided by section 1–107(a) of Ex. Ord. No. 12188, "},{"tag":"date","attrib":{"date":"1980-01-02"},"text":"Jan. 2, 1980","children":[],"tail":", 45 F.R. 993, set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2171"},"text":"section 2171 of this title","children":[],"tail":". See, also, "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2171"},"text":"section 2171 of this title","children":[],"tail":" as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/97/456"},"text":"Pub. L. 97–456","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
