{"tag":"section","attrib":{"id":"id0653cffe-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4434"},"text":null,"children":[{"tag":"num","attrib":{"value":"4434"},"text":"§ 4434.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lost and stolen passports","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary may not enter into an agreement with the government of a foreign country to establish or maintain U.S. Customs and Border Protection preclearance operations at an airport in such country unless the Secretary certifies to the appropriate congressional committees that such government—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0653cfff-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4434/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" routinely submits information about lost and stolen passports of its citizens and nationals to INTERPOL’s Stolen and Lost Travel Document database; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0653d000-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4434/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes such information available to the United States Government through another comparable means of reporting.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0653d001-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/125/tVIII/s816"},"text":"Pub. L. 114–125, title VIII, § 816","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-24"},"text":"Feb. 24, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/220"},"text":"130 Stat. 220","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
