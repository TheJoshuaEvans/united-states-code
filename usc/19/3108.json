{"tag":"section","attrib":{"id":"id060784a6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3108"},"text":null,"children":[{"tag":"num","attrib":{"value":"3108"},"text":"§ 3108.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id060784a7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3108/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advice from departments and agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Prior to taking any action under this chapter, the President shall seek information and advice from the interagency trade organization established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1872/a"},"text":"section 1872(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id060784a8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3108/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advice from private sector","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id060784a9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3108/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Trade Representative concludes the investigation conducted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3103/a"},"text":"section 3103(a) of this title","children":[],"tail":" or takes action under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3103/c"},"text":"section 3103(c) of this title","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060784aa-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3108/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President establishes specific negotiating objectives under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3104/b"},"text":"section 3104(b) of this title","children":[],"tail":" with respect to any foreign country, or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060784ab-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3108/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President takes action under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3105"},"text":"section 3105 of this title","children":[],"tail":","}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Trade Representative shall provide an opportunity for the presentation of views by any interested party with respect to such investigation, objectives, or action, including appropriate committees established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2155"},"text":"section 2155 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id060784ac-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3108/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultations with Congress and official advisors","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of conducting negotiations under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3104/a"},"text":"section 3104(a) of this title","children":[],"tail":", the Trade Representative shall keep appropriate committees of the Congress, as well as appropriate committees established pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2155"},"text":"section 2155 of this title","children":[],"tail":", currently informed with respect to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id060784ad-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3108/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the negotiating priorities and objectives for each priority foreign country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060784ae-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3108/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the assessment of negotiating prospects, both bilateral and multilateral; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060784af-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3108/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any United States concessions which might be included in negotiations to achieve the objectives described in subsections (c) and (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3104"},"text":"section 3104 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id060784b0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3108/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modification of specific negotiating objectives","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before the President takes any action under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3104/b/2/A"},"text":"section 3104(b)(2)(A) of this title","children":[],"tail":" to refine or modify specific negotiating objectives, the President shall consult with the Congress and with members of the industry, and representatives of labor, affected by the proposed refinement or modification."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id060784b1-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/tI/s1379"},"text":"Pub. L. 100–418, title I, § 1379","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1223"},"text":"102 Stat. 1223","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
