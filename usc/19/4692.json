{"tag":"section","attrib":{"id":"id065d4659-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4692"},"text":null,"children":[{"tag":"num","attrib":{"value":"4692"},"text":"§ 4692.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension of liquidation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id065d465a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4692/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the United States files a request pursuant to article 31–A.4.2 of Annex 31–A of the USMCA, the Trade Representative may direct the Secretary of the Treasury to suspend liquidation for unliquidated entries of goods from such covered facility until such time as the Trade Representative notifies the Secretary that a condition described in subsection (b) has been met.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id065d465b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4692/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Resumption of liquidation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The conditions described in this subsection are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id065d465c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4692/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The rapid response labor panel has determined that there is no denial of rights at the covered facility within the meaning of such terms under Annex 31–A of the USMCA.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065d465d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4692/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A course of remediation for denial of rights has been agreed to and has been completed in accordance with the agreed-upon time.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065d465e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4692/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The denial of rights has been otherwise remedied.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id065d465f-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113/tVII/s752"},"text":"Pub. L. 116–113, title VII, § 752","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-01-29"},"text":"Jan. 29, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/89"},"text":"134 Stat. 89","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
