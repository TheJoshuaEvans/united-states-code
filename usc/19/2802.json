{"tag":"section","attrib":{"id":"id060058f9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2802"},"text":null,"children":[{"tag":"num","attrib":{"value":"2802"},"text":"§ 2802.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id060058fa-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2802/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Committees” means the Committee on Ways and Means of the House of Representatives and the Committee on Finance of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060058fb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2802/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “grape product” means grapes and any product (other than wine) made from grapes, including, but not limited to, raisins and grape juice, whether or not concentrated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060058fc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2802/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “major wine trading country” means any foreign country, or group of foreign countries, designated as such under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2803"},"text":"section 2803 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060058fd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2802/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The phrase “nontariff barrier to (or other distortion of)”, in the context of trade in United States wine, includes any measure implemented by the government of a major wine trading country that either gives a competitive advantage to the wine industry of that country or restricts the importation of United States wine into that country.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060058fe-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2802/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Trade Representative” means the United States Trade Representative.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060058ff-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2802/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “United States wine” means wine produced within the customs territory of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06005900-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2802/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “wine” means any fermented alcoholic beverage that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id06005901-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2802/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is made from grapes or other fruit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06005902-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2802/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains not less than 0.5 percent alcohol by volume and not more than 24 percent alcohol by volume, including all dilutions and mixtures thereof by whatever process produced; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06005903-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2802/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is for nonindustrial use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id06005904-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/573/tIX/s903"},"text":"Pub. L. 98–573, title IX, § 903","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3048"},"text":"98 Stat. 3048","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
