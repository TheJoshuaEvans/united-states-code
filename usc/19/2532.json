{"tag":"section","attrib":{"id":"id05ef8fc6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2532"},"text":null,"children":[{"tag":"num","attrib":{"value":"2532"},"text":"§ 2532.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal standards-related activities","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"No Federal agency may engage in any standards-related activity that creates unnecessary obstacles to the foreign commerce of the United States, including, but not limited to, standards-related activities that violate any of the following requirements:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05ef8fc7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2532/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nondiscriminatory treatment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each Federal agency shall ensure, in applying standards-related activities with respect to any imported product, that such product is treated no less favorably than are like domestic or imported products, including, but not limited to, when applying tests or test methods, no less favorable treatment with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05ef8fc8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2532/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the acceptance of the product for testing in comparable situations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05ef8fc9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2532/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the administration of the tests in comparable situations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05ef8fca-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2532/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fees charged for tests;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05ef8fcb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2532/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the release of test results to the exporter, importer, or agents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05ef8fcc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2532/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the siting of testing facilities and the selection of samples for testing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05ef8fcd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2532/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the treatment of confidential information pertaining to the product.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05ef8fce-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2532/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of international standards","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05ef8fcf-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2532/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B)(ii), each Federal agency, in developing standards, shall take into consideration international standards and shall, if appropriate, base the standards on international standards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05ef8fd0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2532/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this paragraph, the following apply:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id05ef8fd1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2532/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International standards not appropriate","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The reasons for which the basing of a standard on an international standard may not be appropriate include, but are not limited to, the following:","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id05ef8fd2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2532/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" National security requirements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id05ef8fd3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2532/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The prevention of deceptive practices.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id05ef8fd4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2532/2/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The protection of human health or safety, animal or plant life or health, or the environment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id05ef8fd5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2532/2/B/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Fundamental climatic or other geographical factors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id05ef8fd6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2532/2/B/i/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Fundamental technological problems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05ef8fd7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2532/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In developing standards, a Federal agency may, but is not required to, take into consideration any international standard promulgated by an international standards organization the membership of which is described in section 2571(6)(A)(ii) ","children":[{"tag":"ref","attrib":{"idref":"fn002135"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002135"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05ef8fd8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2532/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Federal agency shall, if appropriate, develop standards based on performance criteria, such as those relating to the intended use of a product and the level of performance that the product must achieve under defined conditions, rather than on design criteria, such as those relating to the physical form of the product or the types of material of which the product is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05ef8fd9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2532/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access for foreign suppliers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Federal agency shall, with respect to any conformity assessment procedure used by it, permit access for obtaining an assessment of conformity and the mark of the system, if any, to foreign suppliers of a product on the same basis as access is permitted to suppliers of like products, whether of domestic or other foreign origin.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05ef8fda-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39/tIV/s402"},"text":"Pub. L. 96–39, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/242"},"text":"93 Stat. 242","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/tIII/s351/c"},"text":"Pub. L. 103–465, title III, § 351(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4956"},"text":"108 Stat. 4956","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/295/s20/c/14"},"text":"Pub. L. 104–295, § 20(c)(14)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3529"},"text":"110 Stat. 3529","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05ef8fdb-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05ef8fdc-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id05ef8fdd-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2571/6/A"},"text":"Section 2571(6)(A) of this title","children":[],"tail":", referred to in par. (2)(B)(ii), was amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/tIII/s351/e/4"},"text":"Pub. L. 103–465, title III, § 351(e)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4956"},"text":"108 Stat. 4956","children":[],"tail":", and, as so amended, no longer contains clauses."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id05ef8fde-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/295"},"text":"Pub. L. 104–295","children":[],"tail":" inserted comma after “system, if any”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465"},"text":"Pub. L. 103–465","children":[],"tail":" substituted “Access” for “Certification access” in heading, and, in text, substituted “conformity assessment procedure” for “certification system” and “an assessment of conformity and the mark of the system, if any” for “certification under that system”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id05ef8fdf-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id05ef8fe0-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465"},"text":"Pub. L. 103–465","children":[],"tail":" effective on the date on which the WTO Agreement enters into force with respect to the United States ("},{"tag":"date","attrib":{"date":"1995-01-01"},"text":"Jan. 1, 1995","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/s352"},"text":"section 352 of Pub. L. 103–465","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2531"},"text":"section 2531 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
