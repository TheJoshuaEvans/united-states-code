{"tag":"section","attrib":{"id":"id060eb0f8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3513"},"text":null,"children":[{"tag":"num","attrib":{"value":"3513"},"text":"§ 3513.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementing actions in anticipation of entry into force; regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id060eb0f9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3513/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementing actions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"After ","children":[{"tag":"date","attrib":{"date":"1994-12-08"},"text":"December 8, 1994","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id060eb0fa-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3513/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President may proclaim such actions, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060eb0fb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3513/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other appropriate officers of the United States Government may issue such regulations,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"as may be necessary to ensure that any provision of this Act, or amendment made by this Act, that takes effect on the date any of the Uruguay Round Agreements enters into force with respect to the United States is appropriately implemented on such date. Such proclamation or regulation may not have an effective date earlier than the date of entry into force with respect to the United States of the agreement to which the proclamation or regulation relates.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id060eb0fc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3513/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any interim regulation necessary or appropriate to carry out any action proposed in the statement of administrative action approved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3511/a"},"text":"section 3511(a) of this title","children":[],"tail":" to implement an agreement described in section 3511(d)(7), (12), or (13) of this title shall be issued not later than 1 year after the date on which the agreement enters into force with respect to the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id060eb0fd-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/tI/s103"},"text":"Pub. L. 103–465, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4819"},"text":"108 Stat. 4819","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id060eb0fe-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id060eb0ff-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id060eb100-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465"},"text":"Pub. L. 103–465","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4809"},"text":"108 Stat. 4809","children":[],"tail":", known as the Uruguay Round Agreements Act. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3501"},"text":"section 3501 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id060eb101-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id060eb102-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Uruguay Round Agreements: Entry Into Force","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Uruguay Round Agreements, including the World Trade Organization Agreement and agreements annexed to that Agreement, as referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3511/d"},"text":"section 3511(d) of this title","children":[],"tail":", entered into force with respect to the United States on "},{"tag":"date","attrib":{"date":"1995-01-01"},"text":"Jan. 1, 1995","children":[],"tail":". See note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3511"},"text":"section 3511 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
