{"tag":"section","attrib":{"id":"id064f14a3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4318"},"text":null,"children":[{"tag":"num","attrib":{"value":"4318"},"text":"§ 4318.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commercial risk assessment targeting and trade alerts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id064f14a4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4318/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commercial risk assessment targeting","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out its duties under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s211/g/4"},"text":"section 211(g)(4) of title 6","children":[],"tail":", the National Targeting Center, in coordination with the Office of Trade established under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2084"},"text":"section 2084 of this title","children":[],"tail":", as appropriate, shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id064f14a5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4318/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish targeted risk assessment methodologies and standards—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id064f14a6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4318/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for evaluating the risk that cargo destined for the United States may violate the customs and trade laws of the United States, particularly those laws applicable to merchandise subject to the priority trade issues described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4322"},"text":"section 4322 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id064f14a7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4318/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for issuing, as appropriate, Trade Alerts described in subsection (b);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064f14a8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4318/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to the extent practicable and otherwise authorized by law, use, to administer the methodologies and standards established under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id064f14a9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4318/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publicly available information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id064f14aa-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4318/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information available from the Automated Commercial System, the Automated Commercial Environment, the Automated Targeting System, the Automated Export System, the International Trade Data System established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1411/d"},"text":"section 1411(d) of this title","children":[],"tail":", the TECS (formerly known as the “Treasury Enforcement Communications System”), the case management system of U.S. Immigration and Customs Enforcement, and any successor systems; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id064f14ab-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4318/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information made available to the National Targeting Center, including information provided by private sector entities;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064f14ac-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4318/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the receipt and transmission to the appropriate U.S. Customs and Border Protection offices of allegations from interested parties in the private sector of violations of customs and trade laws of the United States with respect to merchandise relating to the priority trade issues described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4322"},"text":"section 4322 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064f14ad-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4318/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify, on a timely basis, each interested party in the private sector that has submitted an allegation of any violation of the customs and trade laws of the United States of any civil or criminal actions taken by U.S. Customs and Border Protection or any other Federal agency resulting from the allegation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id064f14ae-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4318/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trade Alerts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id064f14af-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4318/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out its duties under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s211/g/4"},"text":"section 211(g)(4) of title 6","children":[],"tail":" and based upon the application of the targeted risk assessment methodologies and standards established under subsection (a), the Executive Director of the National Targeting Center may issue Trade Alerts to directors of United States ports of entry directing further inspection, or physical examination or testing, of specific merchandise to ensure compliance with all applicable customs and trade laws of the United States and regulations administered by U.S. Customs and Border Protection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064f14b0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4318/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determinations not to implement Trade Alerts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The director of a United States port of entry may determine not to conduct further inspections, or physical examination or testing, pursuant to a Trade Alert issued under paragraph (1) if the director—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id064f14b1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4318/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" finds that such a determination is justified by port security interests; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id064f14b2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4318/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 48 hours after making the determination, notifies the Assistant Commissioner of the Office of Field Operations of U.S. Customs and Border Protection of the determination and the reasons for the determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064f14b3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4318/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Summary of determinations not to implement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Assistant Commissioner of the Office of Field Operations of U.S. Customs and Border Protection shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id064f14b4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4318/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compile an annual summary of all determinations by directors of United States ports of entry under paragraph (2) and the reasons for those determinations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id064f14b5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4318/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct an evaluation of the utilization of Trade Alerts issued under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id064f14b6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4318/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than December 31 of each calendar year, submit the summary to the appropriate congressional committees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064f14b7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4318/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspection defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the term “inspection” means the comprehensive evaluation process used by U.S. Customs and Border Protection, other than physical examination or testing, to permit the entry of merchandise into the United States, or the clearance of merchandise for transportation in bond through the United States, for purposes of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id064f14b8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4318/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessing duties;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id064f14b9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4318/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying restricted or prohibited items; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id064f14ba-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4318/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring compliance with all applicable customs and trade laws of the United States and regulations administered by U.S. Customs and Border Protection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id064f14bb-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/125/tI/s111"},"text":"Pub. L. 114–125, title I, § 111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-24"},"text":"Feb. 24, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/139"},"text":"130 Stat. 139","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id064f14bc-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id064f14bd-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id064f14be-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/125/s111"},"text":"section 111 of Pub. L. 114–125","children":[],"tail":". Subsec. (c) of "},{"tag":"ref","attrib":{"href":"/us/pl/114/125/s111"},"text":"section 111 of Pub. L. 114–125","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1415"},"text":"section 1415 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
