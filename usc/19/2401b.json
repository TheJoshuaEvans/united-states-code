date":"2011-02-12"},"text":"Feb. 12, 2011","children":[],"tail":". See Codification note above and 2009 Amendment and Effective and Termination Dates of 2011 Revival notes below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/40"},"text":"Pub. L. 112–40","children":[],"tail":", §§ 223(a)(1), 233, temporarily amended subsec. (d) generally. Prior to amendment, text read as follows: “Not later than "},{"tag":"date","attrib":{"date":"2010-01-30"},"text":"January 30, 2010","children":[],"tail":", and annually thereafter, the Secretary of Agriculture shall submit to the Committee on Finance of the Senate and the Committee on Ways and Means of the House of Representatives a report containing the following information with respect to adjustment assistance provided under this part during the preceding fiscal year:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) A list of the agricultural commodities covered by a certification under this part.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) The States or regions in which such commodities are produced and the aggregate amount of such commodities produced in each such State or region.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) The total number of agricultural commodity producers, by congressional district, receiving benefits under this part.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) The total number of agricultural commodity producers, by congressional district, receiving technical assistance under this part.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"See Codification note above and Effective and Termination Dates of 2011 Revival note below.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5"},"text":"Pub. L. 111–5","children":[],"tail":", §§ 1882(b)(1), 1893, temporarily substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2401a/c"},"text":"section 2401a(c) of this title","children":[],"tail":"” for “section 2401a(c) or (d) of this title, as the case may be,”. See Codification note above and Effective and Termination Dates of 2009 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5"},"text":"Pub. L. 111–5","children":[],"tail":", §§ 1882(b)(2), 1893, temporarily substituted “decrease in the national average price, quantity of production, or value of production of, or cash receipts for,” for “decline in price for”. See Codification note above and Effective and Termination Dates of 2009 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5"},"text":"Pub. L. 111–5","children":[],"tail":", §§ 1884, 1893, temporarily added subsec. (d). See Codification note above and Effective and Termination Dates of 2009 Amendment note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id05d57867-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id05d57868-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective and Termination Dates of 2015 Revival","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For revival and applicability, beginning on ","children":[{"tag":"date","attrib":{"date":"2015-06-29"},"text":"June 29, 2015","children":[],"tail":", of the provisions of this section as in effect on "},{"tag":"date","attrib":{"date":"2013-12-31"},"text":"Dec. 31, 2013","children":[],"tail":", see section 402(b), (c) of "},{"tag":"ref","attrib":{"href":"/us/p