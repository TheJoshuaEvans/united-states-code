{"tag":"section","attrib":{"id":"id064ca444-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4314"},"text":null,"children":[{"tag":"num","attrib":{"value":"4314"},"text":"§ 4314.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint strategic plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id064ca445-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4314/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than one year after ","children":[{"tag":"date","attrib":{"date":"2016-02-24"},"text":"February 24, 2016","children":[],"tail":", and every 2 years thereafter, the Commissioner and the Director of U.S. Immigration and Customs Enforcement shall jointly develop and submit to the appropriate congressional committees a joint strategic plan."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id064ca446-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4314/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The joint strategic plan required under this section shall be comprised of a comprehensive multiyear plan for trade enforcement and trade facilitation, and shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id064ca447-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4314/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of actions taken during the 2-year period preceding the submission of the plan to improve trade enforcement and trade facilitation, including a description and analysis of specific performance measures to evaluate the progress of U.S. Customs and Border Protection and U.S. Immigration and Customs Enforcement in meeting each such responsibility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064ca448-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4314/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of objectives and plans for further improving trade enforcement and trade facilitation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064ca449-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4314/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a specific identification of the priority trade issues described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4322"},"text":"section 4322 of this title","children":[],"tail":" that can be addressed in order to enhance trade enforcement and trade facilitation, and a description of strategies and plans for addressing each such issue, including—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id064ca44a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4314/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the targeting methodologies used for enforcement activities with respect to each such issue;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id064ca44b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4314/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for improving such enforcement activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id064ca44c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4314/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the implementation of previous recommendations for improving such enforcement activities;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064ca44d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4314/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of efforts made to improve consultation and coordination among and within Federal agencies, and in particular between U.S. Customs and Border Protection and U.S. Immigration and Customs Enforcement, regarding trade enforcement and trade facilitation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064ca44e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4314/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the training that has occurred to date within U.S. Customs and Border Protection and U.S. Immigration and Customs Enforcement to improve trade enforcement and trade facilitation, including training at educational seminars carried out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4313"},"text":"section 4313 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064ca44f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4314/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of efforts to work with the World Customs Organization and other international organizations, in consultation with other Federal agencies as appropriate, with respect to enhancing trade enforcement and trade facilitation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064ca450-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4314/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of U.S. Custom ","children":[{"tag":"ref","attrib":{"idref":"fn002169"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002169"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Customs”."}],"tail":" and Border Protection organizational benchmarks for optimizing staffing and wait times at ports of entry;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064ca451-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4314/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a specific identification of any domestic or international best practices that may further improve trade enforcement and trade facilitation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064ca452-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4314/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any legislative recommendations to further improve trade enforcement and trade facilitation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064ca453-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4314/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of efforts made to improve consultation and coordination with the private sector to enhance trade enforcement and trade facilitation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id064ca454-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4314/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id064ca455-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4314/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the joint strategic plan required under this section, the Commissioner and the Director of U.S. Immigration and Customs Enforcement shall consult with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id064ca456-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4314/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" appropriate officials from relevant Federal agencies, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id064ca457-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4314/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of the Treasury;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id064ca458-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4314/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Agriculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id064ca459-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4314/c/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Commerce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id064ca45a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4314/c/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Justice;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id064ca45b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4314/c/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of the Interior;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id064ca45c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4314/c/1/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Health and Human Services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id064ca45d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4314/c/1/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Food and Drug Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id064ca45e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4314/c/1/A/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Consumer Product Safety Commission; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id064ca45f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4314/c/1/A/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of the United States Trade Representative; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id064ca460-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4314/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commercial Customs Operations Advisory Committee established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4316"},"text":"section 4316 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064ca461-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4314/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other consultations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the joint strategic plan required under this section, the Commissioner and the Director shall seek to consult with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id064ca462-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4314/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate officials from relevant foreign law enforcement agencies and international organizations, including the World Customs Organization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id064ca463-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4314/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interested parties in the private sector.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id064ca464-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4314/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The joint strategic plan required under this section shall be submitted in unclassified form, but may include a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id064ca465-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/125/tI/s105"},"text":"Pub. L. 114–125, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-24"},"text":"Feb. 24, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/132"},"text":"130 Stat. 132","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
