{"tag":"section","attrib":{"id":"id057ad4ca-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673h"},"text":null,"children":[{"tag":"num","attrib":{"value":"1673h"},"text":"§ 1673h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of product categories for short life cycle merchandise","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id057ad4cb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of product categories","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id057ad4cc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673h/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Petitions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id057ad4cd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673h/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible domestic entity may file a petition with the Commission requesting that a product category be established with respect to short life cycle merchandise at any time after the merchandise becomes the subject of 2 or more affirmative dumping determinations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id057ad4ce-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673h/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A petition filed under subparagraph (A) shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id057ad4cf-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673h/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify the short life cycle merchandise that is the subject of the affirmative dumping determinations,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id057ad4d0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673h/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify the short life cycle merchandise that the petitioner seeks to have included in the same product category as the merchandise that is subject to the affirmative dumping determinations,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id057ad4d1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673h/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify any short life cycle merchandise the petitioner particularly seeks to have excluded from the product category,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id057ad4d2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673h/a/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide reasons for the inclusions and exclusions specified under clauses (ii) and (iii), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id057ad4d3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673h/a/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify such merchandise in terms of the designations used in the Harmonized Tariff Schedule of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id057ad4d4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673h/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determinations on sufficiency of petition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon receiving a petition under paragraph (1), the Commission shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id057ad4d5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673h/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" request the administering authority to confirm promptly the affirmative determinations on which the petition is based, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id057ad4d6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673h/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon receipt of such confirmation, determine whether the merchandise covered by the confirmed affirmative determinations is short life cycle merchandise and whether the petitioner is an eligible domestic entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id057ad4d7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673h/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice; hearings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the determinations under paragraph (2)(B) are affirmative, the Commission shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id057ad4d8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673h/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish notice in the Federal Register that the petition has been received, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id057ad4d9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673h/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide opportunity for the presentation of views regarding the establishment of the requested product category, including a public hearing if requested by any interested person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id057ad4da-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673h/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determinations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id057ad4db-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673h/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"By no later than the date that is 90 days after the date on which a petition is filed under paragraph (1), the Commission shall determine the scope of the product category into which the short life cycle merchandise that is the subject of the affirmative dumping determinations identified in such petition shall be classified for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id057ad4dc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673h/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modifications not requested by petition","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id057ad4dd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673h/a/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may, on its own initiative, make a determination modifying the scope of any product category established under subparagraph (A) at any time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id057ad4de-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673h/a/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice and hearing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Determinations may be made under clause (i) only after the Commission has—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id057ad4df-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673h/a/4/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" published in the Federal Register notice of the proposed modification, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id057ad4e0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673h/a/4/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provided interested parties an opportunity for a hearing, and a period for the submission of written comments, on the classification of merchandise into the product categories to be affected by such determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id057ad4e1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673h/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis of determinations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making determinations under subparagraph (A) or (B), the Commission shall ensure that each product category consists of similar short life cycle merchandise which is produced by similar processes under similar circumstances and has similar uses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id057ad4e2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id057ad4e3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673h/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible domestic entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible domestic entity” means a manufacturer or producer in the United States, or a certified union or recognized union or group of workers which is representative of an industry in the United States, that manufactures or produces short life cycle merchandise that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id057ad4e4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673h/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" like or directly competitive with other merchandise that is the subject of 2 or more affirmative dumping determinations, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id057ad4e5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673h/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is similar enough to such other merchandise as to be considered for inclusion with such merchandise in a product monitoring category established under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id057ad4e6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673h/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Affirmative dumping determination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “affirmative dumping determination” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id057ad4e7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673h/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any affirmative final determination made by the administering authority under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1673d/a"},"text":"section 1673d(a) of this title","children":[],"tail":" during the 8-year period preceding the filing of the petition under this section that results in the issuance of an antidumping duty order under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1673e"},"text":"section 1673e of this title","children":[],"tail":" which requires the deposit of estimated antidumping duties at a rate of not less than 15 percent ad valorem, or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id057ad4e8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673h/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any affirmative preliminary determination that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id057ad4e9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673h/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is made by the administering authority under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1673b/b"},"text":"section 1673b(b) of this title","children":[],"tail":" during the 8-year period preceding the filing of the petition under this section in the course of an investigation for which no final determination is made under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1673d"},"text":"section 1673d of this title","children":[],"tail":" by reason of a suspension of the investigation under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1673c"},"text":"section 1673c of this title","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id057ad4ea-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673h/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes a determination that the estimated average amount by which the normal value of the merchandise exceeds the export price (or the constructed export price) of the merchandise is not less than 15 percent ad valorem.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id057ad4eb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673h/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subject of affirmative dumping determination","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id057ad4ec-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673h/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Short life cycle merchandise of a manufacturer shall be treated as being the subject of an affirmative dumping determination only if the administering authority—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id057ad4ed-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673h/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes a separate determination of the amount by which the normal value of such merchandise of the manufacturer exceeds the export price (or the constructed export price) of such merchandise of the manufacturer, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id057ad4ee-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673h/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specifically identifies the manufacturer by name with such amount in the affirmative dumping determination or in an antidumping duty order issued as a result of the affirmative dumping determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id057ad4ef-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673h/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Short life cycle merchandise of a manufacturer shall not be treated as being the subject of an affirmative dumping determination if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id057ad4f0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673h/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such merchandise of the manufacturer is part of a group of merchandise to which the administering authority assigns (in lieu of making separate determinations described in subparagraph (A)(i)(I)) an amount determined to be the amount by which the normal value of the merchandise in such group exceeds the export price (or the constructed export price) of the merchandise in such group, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id057ad4f1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673h/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the merchandise and the manufacturer are not specified by name in the affirmative dumping determination or in any antidumping duty order issued as a result of such affirmative dumping determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id057ad4f2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673h/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short life cycle merchandise","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “short life cycle merchandise” means any product that the Commission determines is likely to become outmoded within 4 years, by reason of technological advances, after the product is commercially available. For purposes of this paragraph, the term “outmoded” refers to a kind of style that is no longer state-of-the-art.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id057ad4f3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673h/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transitional rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id057ad4f4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673h/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this section and section 1673b(b)(1)(B) and (C) of this title, all affirmative dumping determinations described in subsection (b)(2)(A) that were made after ","children":[{"tag":"date","attrib":{"date":"1980-12-31"},"text":"December 31, 1980","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"August 23, 1988","children":[],"tail":", and all affirmative dumping determinations described in subsection (b)(2)(B) that were made after "},{"tag":"date","attrib":{"date":"1984-12-31"},"text":"December 31, 1984","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"August 23, 1988","children":[],"tail":", with respect to each category of short life cycle merchandise of the same manufacturer shall be treated as one affirmative dumping determination with respect to that category for that manufacturer which was made on the date on which the latest of such determinations was made."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id057ad4f5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673h/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" No affirmative dumping determination that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id057ad4f6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673h/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is described in subsection (b)(2)(A) and was made before ","children":[{"tag":"date","attrib":{"date":"1981-01-01"},"text":"January 1, 1981","children":[],"tail":", or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id057ad4f7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673h/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is described in subsection (b)(2)(B) and was made before ","children":[{"tag":"date","attrib":{"date":"1985-01-01"},"text":"January 1, 1985","children":[],"tail":","}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"may be taken into account under this section or section 1673b(b)(1)(B) and (C) of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id057ad4f8-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title VII, § 739, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tI/s1323/a"},"text":"Pub. L. 100–418, title I, § 1323(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1195"},"text":"102 Stat. 1195","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/