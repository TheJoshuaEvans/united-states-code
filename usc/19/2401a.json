tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5/s1893"},"text":"Section 1893 of Pub. L. 111–5","children":[],"tail":", which provided for "},{"tag":"date","attrib":{"date":"2011-02-13"},"text":"Feb. 13, 2011","children":[],"tail":", termination of amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/111/5"},"text":"Pub. L. 111–5","children":[],"tail":", was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/112/40/tII/s201/a"},"text":"Pub. L. 112–40, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-10-21"},"text":"Oct. 21, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/403"},"text":"125 Stat. 403","children":[],"tail":", and the provisions of this section, as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/5"},"text":"Pub. L. 111–5","children":[],"tail":" and as in effect on "},{"tag":"date","attrib":{"date":"2011-02-12"},"text":"Feb. 12, 2011","children":[],"tail":", were temporarily revived, effective "},{"tag":"date","attrib":{"date":"2011-10-21"},"text":"Oct. 21, 2011","children":[],"tail":", until "},{"tag":"date","attrib":{"date":"2014-01-01"},"text":"Jan. 1, 2014","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/pl/112/40"},"text":"Pub. L. 112–40","children":[],"tail":", §§ 201(b), (c), 233. See 2009 and 2011 Amendment notes, Effective and Termination Dates of 2009 Amendment notes, and Effective and Termination Dates of 2011 Revival notes below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id05d57857-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/27"},"text":"Pub. L. 114–27","children":[],"tail":", §§ 402(b), (c), 406, temporarily revived the provisions of this section, as in effect on "},{"tag":"date","attrib":{"date":"2013-12-31"},"text":"Dec. 31, 2013","children":[],"tail":". See Codification note above and 2011 Amendment and Effective and Termination Dates of 2015 Revival notes below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/40"},"text":"Pub. L. 112–40","children":[],"tail":", §§ 201(b), (c), 233, temporarily revived the provisions of this section, as in effect on "},{"tag":"date","attrib":{"date":"2011-02-12"},"text":"Feb. 12, 2011","children":[],"tail":". See Codification note above and 2009 Amendment and Effective and Termination Dates of 2011 Revival notes below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsecs. (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5"},"text":"Pub. L. 111–5","children":[],"tail":", §§ 1882(a), 1893, temporarily added subsecs. (c) to (e) and struck out former subsecs. (c) to (e), which related to eligibility requirements for groups of agricultural commodity producers to apply for adjustment assistance, a special rule for such groups after the first year of certification, and determination of qualified year and commodity, respectively. See Codification note above and Effective and Termination Dates of 2009 Amendment note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id05d57858-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id05d57859-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective and Termination Dates of 2015 Revival","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For revival and applicability, beginning on ","children":[{"tag":"date","attrib":{"date":"2015-06-29"},"text":"June 29, 2015","children":[],"tail":", of the provisions of this section as in effect on "},{"tag":"date","attrib":{"date":"2013-12-31"},"text":"Dec. 31, 2013","children":[],"tail":", see section 402(b), (c) of "},{"tag":"ref","attrib":{"href":"/us/pl/114/27"},"text":"Pub. L. 114–27","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2271"},"text":"section 2271 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"For reversion, beginning on ","children":[{"tag":"date","attrib":{"date":"2021-07-01"},"text":"July 1, 2021","children":[],"tail":", to the provisions of this section as in effect on "},{"tag":"date","attrib":{"date":"2014-01-01"},"text":"Jan. 1, 2014","children":[],"tail":", with certain exceptions and subject to "},{"tag":"ref","attrib":{"href":"/us/pl/114/27/s406/b"},"text":"section 406(b) of Pub. L. 114–27","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/27/s406"},"text":"section 406 of Pub. L. 114–27","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2271"},"text":"section 2271 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id05d5785a-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective and Termination Dates of 2011 Revival","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For revival and applicability, beginning on ","children":[{"tag":"date","attrib":{"date":"2011-10-21"},"text":"Oct. 21, 2011","children":[],"tail":", of the provisions of this section as in effect on "},{"tag":"date","attrib":{"date":"2011-02-12"},"text":"Feb. 12, 2011","children":[],"tail":", see section 201(b), (c) of "},{"tag":"ref","attrib":{"href":"/us/pl/112/40"},"text":"Pub. L. 112–40","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2271"},"text":"section 2271 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/40/s233"},"text":"Section 233 of Pub. L. 112–40","children":[],"tail":", formerly set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2271"},"text":"section 2271 of this title","children":[],"tail":", which provided for the reversion, beginning on "},{"tag":"date","attrib":{"date":"2014-01-01"},"text":"Jan. 1, 2014","children":[],"tail":", of the provisions of this section to those in effect on "},{"tag":"date","attrib":{"date":"2011-02-13"},"text":"Feb. 13, 2011","children":[],"tail":", subject to certain exceptions, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/114/27/tIV/s402/a"},"text":"Pub. L. 114–27, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-06-29"},"text":"June 29, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/374"},"text":"129 Stat. 374","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"2015-06-29"},"text":"June 29, 2015","children":[],"tail":". See Codification note above."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id05d5785b-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective and Termination Dates of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Except as otherwise provided and subject to certain applicability provisions, amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5"},"text":"Pub. L. 111–5","children":[],"tail":" effective upon the expiration of the 90-day period beginning on "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/5/s1891"},"text":"section 1891 of Pub. L. 111–5","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2271"},"text":"section 2271 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5/s1893"},"text":"Section 1893 of Pub. L. 111–5","children":[],"tail":", formerly set out as a Termination Date of 2009 Amendment note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2271"},"text":"section 2271 of this title","children":[],"tail":", which provided that, except as otherwise provided, amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/111/5"},"text":"Pub. L. 111–5","children":[],"tail":" not applicable on or after "},{"tag":"date","attrib":{"date":"2011-02-13"},"text":"Feb. 13, 2011","children":[],"tail":", and that this section be applied and administered beginning "},{"tag":"date","attrib":{"date":"2011-02-13"},"text":"Feb. 13, 2011","children":[],"tail":", as if amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/111/5"},"text":"Pub. L. 111–5","children":[],"tail":" had never been enacted, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/112/40/tII/s201/a"},"text":"Pub. L. 112–40, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-10-21"},"text":"Oct. 21, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/403"},"text":"125 Stat. 403","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"2011-10-21"},"text":"Oct. 21, 2011","children":[],"tail":". See Codification note above."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"terminationDate","id":"id05d5785c-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Except as otherwise provided, technical assistance and financial assistance may not be provided under this part after ","children":[{"tag":"date","attrib":{"date":"2022-06-30"},"text":"June 30, 2022","children":[],"tail":", see "},{