{"tag":"section","attrib":{"id":"id05144b9c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s294"},"text":null,"children":[{"tag":"num","attrib":{"value":"294"},"text":"§ 294.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No duty by reason of documented vessel touching at foreign port","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any foreign merchandise taken in at one port of the United States to be conveyed in a United States documented vessel with a registry or coastwise endorsement, or both, to any other port within the same, either under the provisions relating to warehouses, or under the laws regulating the transportation coastwise of merchandise entitled to drawback, as well as any merchandise not entitled to drawback, but on which the import duties chargeable by law shall have been duly paid, shall not become subject to any import duty by reason of the vessel in which they may arrive having touched at a foreign port during the voyage.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id05144b9d-3a70-11f1-8ace-823fb135378d"},"text":"(R.S. § 3127; ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/182/tVI/s686/a/3"},"text":"Pub. L. 103–182, title VI, § 686(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-08"},"text":"Dec. 8, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2220"},"text":"107 Stat. 2220","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/295/s21/e/2"},"text":"Pub. L. 104–295, § 21(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3530"},"text":"110 Stat. 3530","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05144b9e-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05144b9f-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id05144ba0-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 3127 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1848-05-27/ch48/s2"},"text":"act May 27, 1848, ch. 48, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/9/232"},"text":"9 Stat. 232","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id05144ba1-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/295"},"text":"Pub. L. 104–295","children":[],"tail":" substituted “conveyed in a United” for “conveyed a United”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/182"},"text":"Pub. L. 103–182","children":[],"tail":" substituted “a United States documented vessel with a registry or coastwise endorsement, or both,” for “in registered vessels”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
