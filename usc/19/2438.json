{"tag":"section","attrib":{"id":"id05e15ed0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2438"},"text":null,"children":[{"tag":"num","attrib":{"value":"2438"},"text":"§ 2438.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment by Czechoslovakia of amounts owed United States citizens and nationals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05e15ed1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2438/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renegotiation of 1974 agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The arrangement initialed on ","children":[{"tag":"date","attrib":{"date":"1974-07-05"},"text":"July 5, 1974","children":[],"tail":", with respect to the settlement of the claims of citizens and nationals of the United States against the Government of Czechoslovakia shall be renegotiated and shall be submitted to the Congress as part of any agreement entered into under this subchapter with Czechoslovakia."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05e15ed2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2438/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provisional retention of gold","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States shall not release any gold belonging to Czechoslovakia and controlled directly or indirectly by the United States pursuant to the provisions of the Paris Reparations Agreement of ","children":[{"tag":"date","attrib":{"date":"1946-01-24"},"text":"January 24, 1946","children":[],"tail":", or otherwise, until such agreement has been approved by the Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05e15ed3-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/tIV/s408"},"text":"Pub. L. 93–618, title IV, § 408","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2064"},"text":"88 Stat. 2064","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
