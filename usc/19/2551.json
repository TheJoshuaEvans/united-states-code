{"tag":"section","attrib":{"id":"id05f2003d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2551"},"text":null,"children":[{"tag":"num","attrib":{"value":"2551"},"text":"§ 2551.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right of action","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Except as provided under this subpart, the provisions of this part do not create any right of action under the laws of the United States with respect to allegations that any standards-related activity engaged in within the United States violates the obligations of the United States under the Agreement.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id05f2003e-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39/tIV/s421"},"text":"Pub. L. 96–39, title IV, § 421","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/247"},"text":"93 Stat. 247","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
