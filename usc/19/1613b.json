{"tag":"section","attrib":{"id":"id0567c2b4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1613b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1613b"},"text":"§ 1613b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Customs Forfeiture Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0567c2b5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1613b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0567c2b6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1613b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" There is established in the Treasury of the United States a fund to be known as the “Customs Forfeiture Fund” (hereafter in this section referred to as the “Fund”), which shall be available to the United States Customs Service, subject to appropriation, with respect to seizures and forfeitures by the United States Customs Service and the United States Coast Guard under any law enforced or administered by those agencies for payment, or for reimbursement to the appropriation from which payment was made, for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0567c2b7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1613b/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all proper expenses of the seizure (including investigative costs incurred by the United States Customs Service leading to seizures) or the proceedings of forfeiture and sale, including, but not limited to, the expenses of inventory, security, and maintenance of custody of the property, advertisement and sale of the property, and if condemned by the court and a bond for such costs was not given, the costs as taxed by the court;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0567c2b8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1613b/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" awards of compensation to informers under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1619"},"text":"section 1619 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0567c2b9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1613b/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" satisfaction of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0567c2ba-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1613b/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" liens for freight, charges, and contributions in general average, notice of which has been filed with the appropriate customs officer according to law, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0567c2bb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1613b/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other liens against forfeited property;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0567c2bc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1613b/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts authorized by law with respect to remission and mitigation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0567c2bd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1613b/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" claims of parties in interest to property disposed of under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1612/b"},"text":"section 1612(b) of this title","children":[],"tail":", in the amounts applicable to such claims at the time of seizure; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0567c2be-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1613b/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equitable sharing payments made to other Federal agencies, State and local law enforcement agencies, and foreign countries under the authority of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1616a/c"},"text":"section 1616a(c) of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s981"},"text":"section 981 of title 18","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0567c2bf-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1613b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0567c2c0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1613b/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any payment made under subparagraph (C) or (D) of paragraph (1) with respect to a seizure or a forfeiture of property shall not exceed the value of the property at the time of the seizure.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0567c2c1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1613b/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any payment made under subparagraph (F) of paragraph (1) with respect to a seizure or forfeiture of property shall not exceed the value of the property at the time of disposition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0567c2c2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1613b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In addition to the purposes described in paragraph (1), the Fund shall be available for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0567c2c3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1613b/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" purchases by the United States Customs Service of evidence of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0567c2c4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1613b/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" smuggling of controlled substances, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0567c2c5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1613b/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" violations of the currency and foreign transaction reporting requirements of chapter 51 of title 31, if there is a substantial probability that the violations of these requirements are related to the smuggling of controlled substances;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0567c2c6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1613b/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equipment for any vessel, vehicle, or aircraft available for official use by the United States Customs Service to enable the vessel, vehicle, or aircraft to assist in law enforcement functions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0567c2c7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1613b/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reimbursement, at the discretion of the Secretary, of private persons for expenses incurred by such persons in cooperating with the United States Customs Service in investigations and undercover law enforcement operations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0567c2c8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1613b/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publication of the availability of awards under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1619"},"text":"section 1619 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0567c2c9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1613b/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equipment for any vessel, vehicle, or aircraft available for official use by a State or local law enforcement agency to enable the vessel, vehicle, or aircraft to assist in law enforcement functions if the conveyance will be used in joint law enforcement operations with the United States Customs Service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0567c2ca-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1613b/a/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payment of overtime salaries, travel, fuel, training, equipment, and other similar costs of State and local law enforcement officers that are incurred in joint law enforcement operations with the United States Customs Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0567c2cb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1613b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States Coast Guard","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commissioner of U.S. Customs and Border Protection shall make available to the United States Coast Guard, from funds appropriated under subsection (f)(2) in excess of $10,000,000 for a fiscal year, proceeds in the Fund derived from seizures by the Coast Guard. Funds made available under this subsection may be used for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0567c2cc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1613b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equipment for any vessel, vehicle, or aircraft available for official use by the United States Coast Guard to enable the vessel, vehicle, or aircraft to assist in law enforcement functions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0567c2cd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1613b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equipment for any vessel, vehicle, equipment, or aircraft available for official use by a State or local law enforcement agency to enable the vessel, vehicle, or aircraft to assist in law enforcement functions if the conveyance will be used in joint law enforcement operations with the United States Coast Guard;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0567c2ce-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1613b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payment of overtime salaries, travel, fuel, training, equipment, and other similar costs of State and local law enforcement officers that are incurred in joint law enforcement operations with the United States Coast Guard; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0567c2cf-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1613b/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expenses incurred in bringing vessels into compliance with applicable environmental laws prior to disposal by sinking.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0567c2d0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1613b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be deposited into the Fund all forfeited currency and proceeds from forfeiture under any law enforced or administered by the United States Customs Service or the United States Coast Guard and all income from investments made under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0567c2d1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1613b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts in the Fund which are not currently needed for the purposes of this section shall be invested in obligations of, or guaranteed by, the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0567c2d2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1613b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports; audits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0567c2d3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1613b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Commissioner of U.S. Customs and Border Protection shall transmit to the Congress, by no later than February 1 of each fiscal year the following detailed reports:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0567c2d4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1613b/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a report on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0567c2d5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1613b/e/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estimated total value of property forfeited under any law enforced or administered by the United States Customs Service or the United States Coast Guard with respect to which funds were not deposited in the Fund during the previous fiscal year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0567c2d6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1613b/e/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estimated total value of all such property transferred to any State or local law enforcement agency;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0567c2d7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1613b/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a report on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0567c2d8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1613b/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the balance of the Fund at the beginning of the preceding fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0567c2d9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1613b/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" liens and mortgages paid and amount of money shared with State and local law enforcement agencies during the previous fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0567c2da-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1613b/e/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the net amount realized from the operations of the Fund during the previous fiscal year, the amount of seized cash being held as evidence, and the amount of money that has been carried over to the current fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0567c2db-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1613b/e/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any defendant’s equity in property valued at $1,000,000 or more;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0567c2dc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1613b/e/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the balance of the Fund at the end of the previous fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0567c2dd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1613b/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a report containing, for the previous fiscal year—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0567c2de-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1613b/e/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a complete set of audited financial statements (including a balance sheet, income statement, and cash flow analysis) prepared in a manner consistent with the requirements of the Comptroller General, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0567c2df-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1613b/e/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an analysis of income and expenses showing the revenue received or lost—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0567c2e0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1613b/e/1/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by property category (general property, vehicles, vessels, aircraft, cash, and real property) and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0567c2e1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1613b/e/1/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by type of disposition (sales, remissions, cancellations, placed into official use, sharing with State and local agencies, and destructions).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0567c2e2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1613b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Fund shall be subject to audits conducted by the Comptroller General of the United States, under such conditions as the Comptroller General determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0567c2e3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1613b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0567c2e4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1613b/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There are hereby appropriated from the Fund such sums as may be necessary to carry out the purposes set forth in subsection (a)(1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0567c2e5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1613b/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0567c2e6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1613b/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to subparagraph (B), there are authorized to be appropriated from the Fund not to exceed $20,000,000 for each fiscal year to carry out the purposes set forth in subsections (a)(3) and (b) for such fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0567c2e7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1613b/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Of the amount authorized to be appropriated under subparagraph (A), not to exceed the following, shall be available to carry out the purposes set forth in subsection (a)(3):","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0567c2e8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1613b/f/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $14,855,000 for fiscal year 1991.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0567c2e9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1613b/f/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $15,598,000 for fiscal year 1992.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0567c2ea-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1613b/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At the end of each fiscal year, any unobligated amount in excess of $15,000,000 remaining in the Fund shall be deposited into the general fund of the Treasury of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0567c2eb-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title IV, § 613A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/573/tII/s213/a/11"},"text":"Pub. L. 98–573, title II, § 213(a)(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2986"},"text":"98 Stat. 2986","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/570/tI/s1152/b/2"},"text":"Pub. L. 99–570, title I, § 1152(b)(2)","children":[],"tail":", title III, § 3142(a), "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-12"},"text":"100 Stat. 3207–12","children":[],"tail":", 3207–93; "},{"tag":"ref","attrib":{"href":"/us/pl/100/71/tI/s101"},"text":"Pub. L. 100–71, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-07-11"},"text":"July 11, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/438"},"text":"101 Stat. 438","chil