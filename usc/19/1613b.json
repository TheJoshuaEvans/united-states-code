ail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/125/tVIII/s802/d/2"},"text":"Pub. L. 114–125, title VIII, § 802(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-24"},"text":"Feb. 24, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/210"},"text":"130 Stat. 210","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0567c2ec-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0567c2ed-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0567c2ee-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior similar provisions were contained in section 613a of act ","children":[{"tag":"date","attrib":{"date":"1930-06-17"},"text":"June 17, 1930","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s317"},"text":"Pub. L. 98–473, title II, § 317","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2054"},"text":"98 Stat. 2054","children":[],"tail":", which was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1613a"},"text":"section 1613a of this title","children":[],"tail":" and subsequently repealed."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0567c2ef-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/316"},"text":"Pub. L. 104–316","children":[],"tail":" struck out “annual financial” before “audits conducted” and inserted before period at end “, under such conditions as the Comptroller General determines appropriate”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a)(1)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/382/s121/1"},"text":"Pub. L. 101–382, § 121(1)","children":[],"tail":", added subpar. (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/382/s121/2"},"text":"Pub. L. 101–382, § 121(2)","children":[],"tail":", designated existing provisions as subpar. (A) and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/382/s121/3"},"text":"Pub. L. 101–382, § 121(3)","children":[],"tail":", inserted “forfeited currency and” before “proceeds”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/382/s121/4/B/i"},"text":"Pub. L. 101–382, § 121(4)(B)(i)","children":[],"tail":", (ii), redesignated cls. (iii) through (vi) as (ii) through (v), respectively, and struck out former cl. (ii), which read as follows: “sources of receipts (seized cash, conveyances, and others) of the Fund during the previous fiscal year;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/382/s121/4/A"},"text":"Pub. L. 101–382, § 121(4)(A)","children":[],"tail":", (B)(iii), (iv), (C), added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/382/s121/5"},"text":"Pub. L. 101–382, § 121(5)","children":[],"tail":", which amended subsec. (f) generally to read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) Subject to paragraph (2), there are authorized to be appropriated from the Fund not to exceed $20,000,000 for each fiscal year to carry out the purposes set forth in subsections (a)(3) and (b) of this section for such fiscal year.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) Of the amount authorized to be appropriated under paragraph (1), not to exceed the following shall be available to carry out the purposes set forth in subsection (a)(3) of this section:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) $14,855,000 for fiscal year 1991.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) $15,598,000 for fiscal year 1992.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"was repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/s10012/a/1"},"text":"Pub. L. 101–508, § 10012(a)(1)","children":[],"tail":". See Construction of 1990 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/s10012/a/2"},"text":"Pub. L. 101–508, § 10012(a)(2)","children":[],"tail":", amended par. (2) generally. Prior to amendment, par. (2) read as follows: “There are authorized to be appropriated from the Fund not to exceed $20,000,000 for each fiscal year to carry out the purposes set forth in subsections (a)(3) and (b) of this section for such fiscal year.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" amended section generally."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/s1912/2"},"text":"Pub. L. 100–418, § 1912(2)","children":[],"tail":", substituted “private persons” for “private citizens”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/s1912/1"},"text":"Pub. L. 100–418, § 1912(1)","children":[],"tail":", substituted “described in subsection (a) of this section for which the fund is available to the United States Customs Service,” for “beginning on "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"October 30, 1984","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"1987-09-30"},"text":"September 30, 1987","children":[],"tail":",”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/71"},"text":"Pub. L. 100–71","children":[],"tail":" repealed "},{"tag":"ref","attrib":{"href":"/us/pl/99/570/s1152/b/2"},"text":"Pub. L. 99–570, § 1152(b)(2)","children":[],"tail":". See 1986 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5)(v), (vi). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/202"},"text":"Pub. L. 100–202","children":[],"tail":" added cls. (v) and (vi)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570/s1152/b/2"},"text":"Pub. L. 99–570, § 1152(b)(2)","children":[],"tail":", which directed the repeal of this section, was itself repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/100/71"},"text":"Pub. L. 100–71","children":[],"tail":". See Repeal and Revival of Section note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570/s3142/a/1/A"},"text":"Pub. L. 99–570, § 3142(a)(1)(A)","children":[],"tail":", (F), substituted “1991” for “1987” in introductory provisions and amended generally concluding provisions which had read as follows: “In addition to the purposes described in paragraphs (1) through (6), the fund shall be available for purchases by the United States Customs Service of evidence of (A) smuggling of controlled substances, and (B) violations of the currency and foreign transaction reporting requirements of chapter 53 of title 31 if there is a substantial probability that the violations of these requirements are related to the smuggling of controlled substances.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570/s3142/a/1/B"},"text":"Pub. L. 99–570, § 3142(a)(1)(B)","children":[],"tail":", inserted “(including investigative costs leading to seizures)” after “of the seizure”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5), (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570/s3142/a/1/C"},"text":"Pub. L. 99–570, § 3142(a)(1)(C)","children":[],"tail":"–(E), redesignated par. (6) as (5) and struck out former par. (5) which provided that the fund would be available with respect to seizures and forfeitures by the United States Customs Service for equipping for law enforcement functions of forfeited vessels, vehicles and aircraft retained as provided by law for official use by the Customs Service."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570/s3142/a/2"},"text":"Pub. L. 99–570, § 3142(a)(2)","children":[],"tail":", amended subsec. (f) generally. Prior to amendment, subsec. (f) read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) There are authorized to be appropriated from the fund for each of the four fiscal years beginning with fiscal year 1984, not more than $10,000,000.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) At the end of each of the first three of such four fiscal years, any amount in the fund in excess of $10,000,000 shall be deposited in the general fund of the Treasury. At the end of the last of such four fiscal years, any amount in the fund shall be deposited in the general fund of the Treasury, and the fund shall cease to exist.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0567c2f0-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{}