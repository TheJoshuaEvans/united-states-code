{"tag":"section","attrib":{"id":"id05f2009e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2575b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2575b"},"text":"§ 2575b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subpart definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2571"},"text":"section 2571 of this title","children":[],"tail":", for purposes of this subpart—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id05f2009f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2575b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Animal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “animal” includes fish, bees, and wild fauna.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f200a0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2575b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval procedure","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “approval procedure” means any registration, notification, or other mandatory administrative procedure for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05f200a1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2575b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approving the use of an additive for a stated purpose or under stated conditions, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05f200a2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2575b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing a tolerance for a stated purpose or under stated conditions for a contaminant,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"in a food, beverage, or feedstuff prior to permitting the use of the additive or the marketing of a food, beverage, or feedstuff containing the additive or contaminant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f200a3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2575b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contaminant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “contaminant” includes pesticide and veterinary drug residues and extraneous matter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f200a4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2575b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Control or inspection procedure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “control or inspection procedure” means any procedure used, directly or indirectly, to determine that a sanitary or phytosanitary measure is fulfilled, including sampling, testing, inspection, evaluation, verification, monitoring, auditing, assurance of conformity, accreditation, registration, certification, or other procedure involving the physical examination of a good, of the packaging of a good, or of the equipment or facilities directly related to production, marketing, or use of a good, but does not mean an approval procedure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f200a5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2575b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “plant” includes wild flora.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f200a6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2575b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Risk assessment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “risk assessment” means an evaluation of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05f200a7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2575b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential for the introduction, establishment or spread of a pest or disease and associated biological and economic consequences; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05f200a8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2575b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential for adverse effects on human or animal life or health arising from the presence of an additive, contaminant, toxin or disease-causing organism in a food, beverage, or feedstuff.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f200a9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2575b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sanitary or phytosanitary measure","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05f200aa-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2575b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “sanitary or phytosanitary measure” means a measure to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id05f200ab-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2575b/7/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protect animal or plant life or health in the United States from risks arising from the introduction, establishment, or spread of a pest or disease;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05f200ac-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2575b/7/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protect human or animal life or health in the United States from risks arising from the presence of an additive, contaminant, toxin, or disease-causing organism in a food, beverage, or feedstuff;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05f200ad-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2575b/7/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protect human life or health in the United States from risks arising from a disease-causing organism or pest carried by an animal or plant, or a product thereof; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05f200ae-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2575b/7/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevent or limit other damage in the United States arising from the introduction, establishment, or spread of a pest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05f200af-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2575b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The form of a sanitary or phytosanitary measure includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id05f200b0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2575b/7/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" end product criteria;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05f200b1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2575b/7/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a product-related processing or production method;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05f200b2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2575b/7/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a testing, inspection, certification, or approval procedure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05f200b3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2575b/7/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a relevant statistical method;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05f200b4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2575b/7/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a sampling procedure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05f200b5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2575b/7/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a method of risk assessment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05f200b6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2575b/7/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a packaging and labeling requirement directly related to food safety; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05f200b7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2575b/7/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a quarantine treatment, such as a relevant requirement associated with the transportation of animals or plants or with material necessary for their survival during transportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05f200b8-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39/tIV/s463"},"text":"Pub. L. 96–39, title IV, § 463","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/182/tIII/s351/a"},"text":"Pub. L. 103–182, title III, § 351(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-08"},"text":"Dec. 8, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2119"},"text":"107 Stat. 2119","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
