{"tag":"section","attrib":{"id":"id05aa6ff5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2131"},"text":null,"children":[{"tag":"num","attrib":{"value":"2131"},"text":"§ 2131.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriation for GATT revision","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated annually such sums as may be necessary for the payment by the United States of its share of the expenses of the Contracting Parties to the General Agreement on Tariffs and Trade. This authorization does not imply approval or disapproval by the Congress of all articles of the General Agreement on Tariffs and Trade.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id05aa6ff6-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/tI/s121"},"text":"Pub. L. 93–618, title I, § 121","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1986"},"text":"88 Stat. 1986","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/39/tXI/s1106/c/2"},"text":"Pub. L. 96–39, title XI, § 1106(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/311"},"text":"93 Stat. 311","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tI/s1107/b/2"},"text":"Pub. L. 100–418, title I, § 1107(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1135"},"text":"102 Stat. 1135","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tIX/s9001/a/1"},"text":"Pub. L. 100–647, title IX, § 9001(a)(1)",