{"tag":"section","attrib":{"id":"id064ca41e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4313"},"text":null,"children":[{"tag":"num","attrib":{"value":"4313"},"text":"§ 4313.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Educational seminars to improve efforts to classify and appraise imported articles, to improve trade enforcement efforts, and to otherwise facilitate legitimate international trade","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id064ca41f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4313/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commissioner and the Director shall establish and carry out on a fiscal year basis educational seminars to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id064ca420-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4313/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the ability of personnel of U.S. Customs and Border Protection to classify and appraise articles imported into the United States in accordance with the customs and trade laws of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064ca421-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4313/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the trade enforcement efforts of personnel of U.S. Customs and Border Protection and personnel of U.S. Immigration and Customs Enforcement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064ca422-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4313/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise improve the ability and effectiveness of personnel of U.S. Customs and Border Protection and personnel of U.S. Immigration and Customs Enforcement to facilitate legitimate international trade.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id064ca423-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4313/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id064ca424-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4313/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Classifying and appraising imported articles","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out subsection (a)(1), the Commissioner, the Director, and interested parties in the private sector selected under subsection (c) shall provide instruction and related instructional materials at each educational seminar carried out under this section to personnel of U.S. Customs and Border Protection and, as appropriate, to personnel of U.S. Immigration and Customs Enforcement on the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id064ca425-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4313/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Conducting a physical inspection of an article imported into the United States, including testing of samples of the article, to determine if the article is mislabeled in the manifest or other accompanying documentation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id064ca426-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4313/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reviewing the manifest and other accompanying documentation of an article imported into the United States to determine if the country of origin of the article listed in the manifest or other accompanying documentation is accurate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id064ca427-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4313/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Customs valuation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id064ca428-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4313/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Industry supply chains and other related matters as determined to be appropriate by the Commissioner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064ca429-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4313/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trade enforcement efforts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out subsection (a)(2), the Commissioner, the Director, and interested parties in the private sector selected under subsection (c) shall provide instruction and related instructional materials at each educational seminar carried out under this section to personnel of U.S. Customs and Border Protection and, as appropriate, to personnel of U.S. Immigration and Customs Enforcement to identify opportunities to enhance enforcement of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id064ca42a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4313/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Collection of countervailing duties assessed under subtitle A of title VII of the Tariff Act of 1930 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1671"},"text":"19 U.S.C. 1671","children":[],"tail":" et seq.) and antidumping duties assessed under subtitle B of title VII of the Tariff Act of 1930 ("},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1673"},"text":"19 U.S.C. 1673","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id064ca42b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4313/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Addressing evasion of duties on imports of textiles.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id064ca42c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4313/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Protection of intellectual property rights.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id064ca42d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4313/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Enforcement of child labor laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064ca42e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4313/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of Commissioner and Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The instruction and related instructional materials at each educational seminar carried out under this section shall be subject to the approval of the Commissioner and the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id064ca42f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4313/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection process","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id064ca430-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4313/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commissioner shall establish a process to solicit, evaluate, and select interested parties in the private sector for purposes of assisting in providing instruction and related instructional materials described in subsection (b) at each educational seminar carried out under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064ca431-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4313/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commissioner shall evaluate and select interested parties in the private sector under the process established under paragraph (1) based on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id064ca432-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4313/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" availability and usefulness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id064ca433-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4313/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the volume, value, and incidence of mislabeling or misidentification of origin of imported articles; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id064ca434-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4313/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other appropriate criteria established by the Commissioner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064ca435-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4313/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commissioner and the Director shall publish in the Federal Register a detailed description of the process established under paragraph (1) and the criteria established under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id064ca436-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4313/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for antidumping and countervailing duty orders","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id064ca437-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4313/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commissioner shall give due consideration to carrying out an educational seminar under this section in whole or in part to improve the ability of personnel of U.S. Customs and Border Protection to enforce a countervailing or antidumping duty order issued under section 706 or 736 of the Tariff Act of 1930 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1671e"},"text":"19 U.S.C. 1671e","children":[],"tail":" or 1673e) upon the request of a petitioner in an action underlying such countervailing or antidumping duty order."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064ca438-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4313/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interested party","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A petitioner described in paragraph (1) shall be treated as an interested party in the private sector for purposes of the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id064ca439-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4313/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commissioner and the Director shall establish performance standards to measure the development and level of achievement of educational seminars carried out under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id064ca43a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4313/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2016-09-30"},"text":"September 30, 2016","children":[],"tail":", and annually thereafter, the Commissioner and the Director shall submit to the appropriate congressional committees a report on the effectiveness of educational seminars carried out under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id064ca43b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4313/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id064ca43c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4313/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Director” means the Director of U.S. Immigration and Customs Enforcement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064ca43d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4313/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “United States” means the customs territory of the United States, as defined in General Note 2 to the Harmonized Tariff Schedule of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064ca43e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4313/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" U.S. Customs and Border Protection personnel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “U.S. Customs and Border Protection personnel” means import specialists, auditors, and other appropriate employees of the U.S. Customs and Border Protection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064ca43f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4313/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" U.S. Immigration and Customs Enforcement personnel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “U.S. Immigration and Customs Enforcement personnel” means Homeland Security Investigations Directorate personnel and other appropriate employees of U.S. Immigration and Customs Enforcement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id064ca440-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/125/tI/s104"},"text":"Pub. L. 114–125, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-24"},"text":"Feb. 24, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/130"},"text":"130 Stat. 130","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id064ca441-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id064ca442-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id064ca443-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Tariff Act of 1930, referred to in subsec. (b)(2)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"act June 17, 1930, ch. 497","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/590"},"text":"46 Stat. 590","children":[],"tail":". Subtitles A and B of title VII of the Act are classified generally to parts I (§ 671 et seq.) and II (§ 1673 et seq.), respectively, of subtitle IV of chapter 4 of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1654"},"text":"section 1654 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Harmonized Tariff Schedule of the United States, referred to in subsec. (g)(2), is not set out in the Code. See Publication of Harmonized Tariff Schedule note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1202"},"text":"section 1202 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
