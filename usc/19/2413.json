{"tag":"section","attrib":{"id":"id05da3352-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2413"},"text":null,"children":[{"tag":"num","attrib":{"value":"2413"},"text":"§ 2413.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation upon initiation of investigation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05da3353-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2413/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05da3354-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2413/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" On the date on which an investigation is initiated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2412"},"text":"section 2412 of this title","children":[],"tail":", the Trade Representative, on behalf of the United States, shall request consultations with the foreign country concerned regarding the issues involved in such investigation."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05da3355-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2413/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the investigation initiated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2412"},"text":"section 2412 of this title","children":[],"tail":" involves a trade agreement and a mutually acceptable resolution is not reached before the earlier of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05da3356-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2413/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the close of the consultation period, if any, specified in the trade agreement, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05da3357-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2413/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 150th day after the day on which consultation was commenced,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Trade Representative shall promptly request proceedings on the matter under the formal dispute settlement procedures provided under such agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05da3358-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2413/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Trade Representative shall seek information and advice from the petitioner (if any) and the appropriate committees established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2155"},"text":"section 2155 of this title","children":[],"tail":" in preparing United States presentations for consultations and dispute settlement proceedings."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05da3359-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2413/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delay of request for consultations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05da335a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2413/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding the provisions of subsection (a)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05da335b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2413/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Trade Representative may, after consulting with the petitioner (if any), delay for up to 90 days any request for consultations under subsection (a) for the purpose of verifying or improving the petition to ensure an adequate basis for consultation, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05da335c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2413/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if such consultations are delayed by reason of subparagraph (A), each time limitation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2414"},"text":"section 2414 of this title","children":[],"tail":" shall be extended for the period of such delay."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05da335d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2413/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Trade Representative shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05da335e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2413/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish notice of any delay under paragraph (1) in the Federal Register, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05da335f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2413/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report to Congress on the reasons for such delay in the report required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2419/a/3"},"text":"section 2419(a)(3) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05da3360-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/tIII/s303"},"text":"Pub. L. 93–618, title III, § 303","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/39/tIX/s901"},"text":"Pub. L. 96–39, title IX, § 901","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/297"},"text":"93 Stat. 297","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/573/tIII"},"text":"Pub. L. 98–573, title III","children":[],"tail":", §§ 304(d)(2)(B), (e), 306(c)(2)(C)(ii), "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3004"},"text":"98 Stat. 3004","children":[],"tail":", 3005, 3012; "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tI/s1301/a"},"text":"Pub. L. 100–418, title I, § 1301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1170"},"text":"102 Stat. 1170","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05da3361-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05da3362-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id05da3363-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418"},"text":"Pub. L. 100–418","children":[],"tail":" amended section generally, revising and restating substantially similar provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/573"},"text":"Pub. L. 98–573","children":[],"tail":", §§ 304(d)(2)(B), (e)(1), 306(c)(2)(C)(ii), designated existing provisions as subsec. (a), struck out “with respect to a petition” after “"},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2412/b"},"text":"section 2412(b) of this title","children":[],"tail":"”, inserted “or the determination of the Trade Representative under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2412/c/1"},"text":"section 2412(c)(1) of this title","children":[],"tail":"” after “in the petition”, and “(if any)” after “petitioner”, and struck out “private sector” after “appropriate”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/573/s304/e/2"},"text":"Pub. L. 98–573, § 304(e)(2)","children":[],"tail":", added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id05da3364-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id05da3365-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418"},"text":"Pub. L. 100–418","children":[],"tail":" applicable to petitions filed, and investigations initiated, under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2412"},"text":"section 2412 of this title","children":[],"tail":" on or after "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", and petitions filed, and investigations initiated, before "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", if by such date no decision had been made under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2414"},"text":"section 2414 of this title","children":[],"tail":" regarding the petition or investigation, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/s1301/c"},"text":"section 1301(c) of Pub. L. 100–418","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2411"},"text":"section 2411 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
