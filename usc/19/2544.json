{"tag":"section","attrib":{"id":"id05ef900e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2544"},"text":null,"children":[{"tag":"num","attrib":{"value":"2544"},"text":"§ 2544.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards information center","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05ef900f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2544/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce shall maintain within the Department of Commerce a standards information center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05ef9010-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2544/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The standards information center shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05ef9011-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2544/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as the central national collection facility for information relating to (A) standards, technical regulations, conformity assessment procedures, and standards-related activities, whether such standards, technical regulations, conformity assessment procedures, or activities are public or private, domestic or foreign, or international, regional, national, or local and (B) the membership and participation of Federal, State, or local government bodies or private bodies in the United States in international and regional standardizing bodies and conformity assessment systems, as well as in bilateral and multilateral arrangements concerning standards-related activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f20012-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2544/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make available to the public at such reasonable fee as the Secretary shall prescribe, copies of information required to be collected under paragraph (1) other than information to which paragraph (3) applies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f20013-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2544/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use its best efforts to make available to the public, at such reasonable fees as the Secretary shall prescribe, copies of information required to be collected under paragraph (1) that is of private origin, on a cooperative basis with the private individual or entity, foreign or domestic, who holds the copyright on the information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f20014-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2544/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in case of such information that is of foreign origin, provide, at such reasonable fee as the Secretary shall prescribe, such translation services as may be necessary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f20015-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2544/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as the inquiry point for requests for information regarding standards-related activities, whether adopted or proposed, within the United States, except that in carrying out this paragraph, the Secretary of Commerce shall refer all inquiries regarding agricultural products to the technical office established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2542/a/2"},"text":"section 2542(a)(2) of this title","children":[],"tail":" within the Department of Agriculture; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f20016-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2544/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide such other services as may be appropriate, including but not limited to, such services to the technical offices established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2542"},"text":"section 2542 of this title","children":[],"tail":" as may be requested by those offices in carrying out their functions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05f20017-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2544/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sanitary and phytosanitary measures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05f20018-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2544/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The standards information center shall, in addition to the functions specified under subsection (b), make available to the public relevant documents, at such reasonable fees as the Secretary of Commerce may prescribe, and information regarding—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05f20019-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2544/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any sanitary or phytosanitary measure of general application, including any inspection procedure or approval procedure proposed, adopted, or maintained by a Federal agency or agency of a State or local government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05f2001a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2544/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the procedures of a Federal agency or an agency of a State or local government for risk assessment and factors the agency considers in conducting the assessment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05f2001b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2544/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the determination of the levels of protection that a Federal agency or an agency of a State or local government considers appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05f2001c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2544/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the membership and participation of the Federal Government and State and local governments in international and regional sanitary and phytosanitary organizations and systems, and in bilateral and multilateral arrangements regarding sanitary and phytosanitary measures, and the provisions of those systems and arrangements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f2001d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2544/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The definitions in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2575b"},"text":"section 2575b of this title","children":[],"tail":" apply for purposes of this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05f2001e-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39/tIV/s414"},"text":"Pub. L. 96–39, title IV, § 414","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/245"},"text":"93 Stat. 245","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/tIII/s351/d"},"text":"Pub. L. 103–465, title III, § 351(d)","children":[],"tail":", title IV, § 431(a), "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4956"},"text":"108 Stat. 4956","children":[],"tail":", 4966; "},{"tag":"ref","attrib":{"href":"/us/pl/104/295/s20/c/15"},"text":"Pub. L. 104–295, § 20(c)(15)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3529"},"text":"110 Stat. 3529","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05f2001f-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05f20020-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id05f20021-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/295"},"text":"Pub. L. 104–295","children":[],"tail":" struck out comma after “procedures,” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/s351/d"},"text":"Pub. L. 103–465, § 351(d)","children":[],"tail":", inserted “(A)” after “relating to”, substituted “technical regulations, conformity assessment procedures,” for “certification systems” and “such standards, technical regulations, conformity assessment procedures,” for “such standards, systems”, and inserted “and” and cl. (B) before semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/s431/a"},"text":"Pub. L. 103–465, § 431(a)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id05f20022-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id05f20023-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/s351/d"},"text":"section 351(d) of Pub. L. 103–465","children":[],"tail":" effective on the date on which the WTO Agreement enters into force with respect to the United States ("},{"tag":"date","attrib":{"date":"1995-01-01"},"text":"Jan. 1, 1995","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/s352"},"text":"section 352 of Pub. L. 103–465","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2531"},"text":"section 2531 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/s431/a"},"text":"section 431(a) of Pub. L. 103–465","children":[],"tail":" effective on the date of entry into force of the WTO Agreement with respect to the United States ["},{"tag":"date","attrib":{"date":"1995-01-01"},"text":"Jan. 1, 1995","children":[],"tail":"], except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/s451"},"text":"section 451 of Pub. L. 103–465","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3601"},"text":"section 3601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
