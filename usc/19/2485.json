{"tag":"section","attrib":{"id":"id05e61a21-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2485"},"text":null,"children":[{"tag":"num","attrib":{"value":"2485"},"text":"§ 2485.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary limitations on exports of steel to United States","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"No person shall be liable for damages, penalties, or other sanctions under the Federal Trade Commission Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s41"},"text":"15 U.S.C. 41","children":[],"tail":" et seq.] or the Antitrust Acts (as defined in section 4 of the Federal Trade Commission Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s44"},"text":"15 U.S.C. 44","children":[],"tail":"]), or under any similar State law, on account of his negotiating, entering into, participating in, or implementing an arrangement providing for the voluntary limitation on exports of steel and steel products to the United States, or any modification or renewal of such an arrangement, if such arrangement or such modification or renewal—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id05e61a22-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2485/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was undertaken prior to ","children":[{"tag":"date","attrib":{"date":"1975-01-03"},"text":"January 3, 1975","children":[],"tail":", at the request of the Secretary of State or his delegate, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05e61a23-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2485/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ceases to be effective not later than ","children":[{"tag":"date","attrib":{"date":"1975-01-01"},"text":"January 1, 1975","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05e61a24-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/tVI/s607"},"text":"Pub. L. 93–618, title VI, § 607","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2073"},"text":"88 Stat. 2073","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05e61a25-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05e61a26-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id05e61a27-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Trade Commission Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1914-09-26/ch311"},"text":"act Sept. 26, 1914, ch. 311","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/717"},"text":"38 Stat. 717","children":[],"tail":", which is classified generally to subchapter I (§ 41 et seq.) of chapter 2 of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s58"},"text":"section 58 of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
