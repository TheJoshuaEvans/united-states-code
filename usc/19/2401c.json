{"tag":"section","attrib":{"id":"id05d5786d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401c"},"text":null,"children":[{"tag":"num","attrib":{"value":"2401c"},"text":"§ 2401c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study by Secretary of Agriculture when International Trade Commission begins investigation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05d5786e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whenever the International Trade Commission (in this part referred to as the “Commission”) begins an investigation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2252"},"text":"section 2252 of this title","children":[],"tail":" with respect to an agricultural commodity, the Commission shall immediately notify the Secretary of the investigation. Upon receipt of the notification, the Secretary shall immediately conduct a study of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id05d5786f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of agricultural commodity producers producing a like or directly competitive agricultural commodity who have been or are likely to be certified as eligible for adjustment assistance under this part, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05d57870-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the adjustment of such producers to the import competition may be facilitated through the use of existing programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05d57871-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 15 days after the day on which the Commission makes its report under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2252/f"},"text":"section 2252(f) of this title","children":[],"tail":", the Secretary shall submit a report to the President setting forth the findings of the study described in subsection (a). Upon making the report to the President, the Secretary shall also promptly make the report public (with the exception of information which the Secretary determines to be confidential) and shall have a summary of the report published in the Federal Register."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05d57872-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/tII/s294"},"text":"Pub. L. 93–618, title II, § 294","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/210/dA/tI/s141/a"},"text":"Pub. L. 107–210, div. A, title I, § 141(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-06"},"text":"Aug. 6, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/949"},"text":"116 Stat. 949","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05d57873-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id05d57874-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Assistance","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination of assistance under this part after ","children":[{"tag":"date","attrib":{"date":"2022-06-30"},"text":"June 30, 2022","children":[],"tail":", see Termination Date note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id05d57875-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"terminationDate","id":"id05d57876-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Except as otherwise provided, technical assistance and financial assistance may not be provided under this part after ","children":[{"tag":"date","attrib":{"date":"2022-06-30"},"text":"June 30, 2022","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/618/s285"},"text":"section 285 of Pub. L. 93–618","children":[],"tail":", as modified by "},{"tag":"ref","attrib":{"href":"/us/pl/114/27/s406/a/7"},"text":"section 406(a)(7) of Pub. L. 114–27","children":[],"tail":", set out as notes preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2271"},"text":"section 2271 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
