{"tag":"section","attrib":{"id":"id05f20116-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2581"},"text":null,"children":[{"tag":"num","attrib":{"value":"2581"},"text":"§ 2581.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Auction of import licenses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05f20117-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2581/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the President may sell import licenses at public auction under such terms and conditions as he deems appropriate. Regulations prescribed under this subsection shall, to the extent practicable and consistent with efficient and fair administration, insure against inequitable sharing of imports by a relatively small number of the larger importers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05f20118-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2581/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Import license” defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “import license” means any documentation used to administer a quantitative restriction imposed or modified after ","children":[{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":" under—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id05f20119-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2581/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 125, 203, 301, or 406 of the Trade Act of 1974 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2135"},"text":"19 U.S.C. 2135","children":[],"tail":", 2253, 2411, or 2436),"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f2011a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2581/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the International Emergency Economic Powers Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701–170"},"text":"50 U.S.C. 1701–170","children":[],"tail":"6),"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f2011b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2581/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authority under the notes of the Harmonized Tariff Schedule of the United States, but not including any quantitative restriction imposed under section 22 of the Agricultural Adjustment Act of 1934 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s624"},"text":"7 U.S.C. 624","children":[],"tail":"),"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f2011c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2581/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Trading With the Enemy Act (50 U.S.C. App. 1–44),","children":[{"tag":"ref","attrib":{"idref":"fn002136"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002136"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f2011d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2581/b/5"},"text"