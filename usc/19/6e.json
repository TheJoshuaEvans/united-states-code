{"tag":"section","attrib":{"id":"id04fec6df-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s6e"},"text":null,"children":[{"tag":"num","attrib":{"value":"6e"},"text":"§ 6e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Overtime compensation based on standard or daylight saving time","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"On and after ","children":[{"tag":"date","attrib":{"date":"1949-06-30"},"text":"June 30, 1949","children":[],"tail":", overtime compensation of customs officers and employees, as authorized by law, shall be based either on standard or daylight saving time, whichever is observed where overtime services are performed."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id04fec6e0-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-06-30/ch286"},"text":"June 30, 1949, ch. 286","children":[],"tail":", title I, "},{"tag":"ref","attrib":{"href":"/us/stat/63/360"},"text":"63 Stat. 360","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
