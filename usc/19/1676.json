{"tag":"section","attrib":{"id":"id057d1fe0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1676"},"text":null,"children":[{"tag":"num","attrib":{"value":"1676"},"text":"§ 1676.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required consultations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id057d1fe1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1676/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements in response to countervailable subsidies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Within 90 days after the administering authority accepts a quantitative restriction agreement under section 1671c(a)(2) or (c)(3) of this title, the President shall enter into consultations with the government that is party to the agreement for purposes of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id057d1fe2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1676/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eliminating the countervailable subsidy completely, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id057d1fe3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1676/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reducing the net countervailable subsidy to a level that eliminates completely the injurious effect of exports to the United States of the merchandise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id057f8fe4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1676/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modification of agreements on basis of consultations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the direction of the President, the administering authority shall modify a quantitative restriction agreement as a result of consultations entered into under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id057f8fe5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1676/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule regarding agreements under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1671c/c/3"},"text":"section 1671c(c)(3) of this title","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subpart shall cease to apply to a quantitative restriction agreement described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1671c/c/3"},"text":"section 1671c(c)(3) of this title","children":[],"tail":" at such time as that agreement ceases to have force and effect under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1671c/f"},"text":"section 1671c(f) of this title","children":[],"tail":" or violation is found under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1671c/i"},"text":"section 1671c(i) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id057f8fe6-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title VII, § 761, as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/573/tVI/s611/a/4"},"text":"Pub. L. 98–573, title VI, § 611(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","childre