{"tag":"section","attrib":{"id":"id054d8331-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1513"},"text":null,"children":[{"tag":"num","attrib":{"value":"1513"},"text":"§ 1513.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Customs officer’s immunity","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"No customs officer shall be liable in any way to any person for or on account of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id054d8332-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1513/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any ruling or decision regarding the appraisement or the classification of any imported merchandise or regarding the duties, fees, and taxes charged thereon,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id054d8333-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1513/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the collection of any dues, charges, duties, fees, and taxes on or on account of any imported merchandise, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id054d8334-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1513/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other matter or thing as to which any person might under this chapter be entitled to protest or appeal from the decision of such officer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id054d8335-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title IV, § 513, "},{"tag":"ref","attrib":{"href":"/us/stat/46/734"},"text":"46 Stat. 734","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/271/tIII/s301/r"},"text":"Pub. L. 91–271, title III, § 301(r)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-06-02"},"text":"June 2, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/290"},"text":"84 Stat. 290","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/182/tVI/s644"},"text":"Pub. L. 103–182, title VI, § 644","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-08"},"text":"Dec. 8, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2206"},"text":"107 Stat. 2206","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id054d8336-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id054d8337-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id054d8338-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions substantially the same as those in this section, except that they did not specifically refer to rulings or decisions as to appraisement, were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/act/1913-10-03/ch16"},"text":"act Oct. 3, 1913, ch. 16","children":[],"tail":", § III, Z, "},{"tag":"ref","attrib":{"href":"/us/stat/38/191"},"text":"38 Stat. 191","children":[],"tail":", which reenacted without change the provisions of the Customs Administrative "},{"tag":"ref","attrib":{"href":"/us/act/1890-06-10/ch407/s25"},"text":"Act of June 10, 1890, ch. 407, § 25","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/26/141"},"text":"26 Stat. 141","children":[],"tail":", as reenacted by the Payne-Aldrich Tariff "},{"tag":"ref","attrib":{"href":"/us/act/1909-08-05/ch6/s28"},"text":"Act of Aug. 5, 1909, ch. 6, § 28","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/103"},"text":"36 Stat. 103","children":[],"tail":". Section III, Z, of the 1913 act was superseded and more closely assimilated to this section by "},{"tag":"ref","attrib":{"href":"/us/act/1922-09-21/ch356/tIV/s513"},"text":"act Sept. 21, 1922, ch. 356, title IV, § 513","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/969"},"text":"42 Stat. 969","children":[],"tail":", and repealed by section 643 thereof. Section 513 of the 1922 act was superseded by section 513 of act "},{"tag":"date","attrib":{"date":"1930-06-17"},"text":"June 17, 1930","children":[],"tail":", comprising this section, and repealed by section 651(a)(1) of the 1930 act."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id054d8339-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/182"},"text":"Pub. L. 103–182","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “No customs officer shall be in any way liable to any owner, importer, consignee, or agent or any other person for or on account of any rulings or decisions as to the appraisement or the classification of any imported merchandise or the duties charged thereon, or the collection of any dues, charges, or duties on or on account of said merchandise, or any other matter or thing as to which said owner, importer, consignee, or agent might under this chapter be entitled to protest or appeal from the decision of such officer.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/271"},"text":"Pub. L. 91–271","children":[],"tail":" substituted “customs officer” for “collector or other customs officer” and “such officer” for “such collector or other officer”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id054d833a-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id054d833b-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1970 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/271"},"text":"Pub. L. 91–271","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/271/s203"},"text":"section 203 of Pub. L. 91–271","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1500"},"text":"section 1500 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
