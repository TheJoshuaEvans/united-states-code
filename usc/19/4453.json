{"tag":"section","attrib":{"id":"id0653d077-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4453"},"text":null,"children":[{"tag":"num","attrib":{"value":"4453"},"text":"§ 4453.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on compliance with prohibition on importation of goods made with convict, forced, or indentured labor","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2016-02-24"},"text":"February 24, 2016","children":[],"tail":", and annually thereafter, the Commissioner shall submit to the Committee on Finance of the Senate and the Committee on Ways and Means of the House of Representatives a report on compliance with "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1307"},"text":"section 1307 of this title","children":[],"tail":" that includes the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0653d078-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4453/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of instances in which merchandise was denied entry pursuant to that section during the 1-year period preceding the submission of the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0653d079-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4453/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the merchandise denied entry pursuant to that section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0653d07a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4453/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other information as the Commissioner considers appropriate with respect to monitoring and enforcing compliance with that section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0653d07b-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/125/tIX/s910/b"},"text":"Pub. L. 114–125, title IX, § 910(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-24"},"text":"Feb. 24, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/239"},"text":"130 Stat. 239","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
