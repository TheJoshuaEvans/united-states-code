{"tag":"section","attrib":{"id":"id06051336-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2906"},"text":null,"children":[{"tag":"num","attrib":{"value":"2906"},"text":"§ 2906.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id06051337-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2906/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “distortion” includes, but is not limited to, a subsidy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06051338-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2906/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “foreign country” includes any foreign instrumentality. Any territory or possession of a foreign country that is administered separately for customs purposes, shall be treated as a separate foreign country.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06051339-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2906/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “GATT” means the GATT 1947 (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3501/1/A"},"text":"section 3501(1)(A) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0605133a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2906/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “implementing bill” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2191/b/1"},"text":"section 2191(b)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0605133b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2906/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “international trade” includes, but is not limited to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0605133c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2906/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" trade in both goods and services, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0605133d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2906/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foreign direct investment by United States persons, especially if such investment has implications for trade in goods and services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0605133e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2906/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “state trading enterprise” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0605133f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2906/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any agency, instrumentality, or administrative unit of a foreign country which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id06051340-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2906/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchases goods or services in international trade for any purpose other than the use of such goods or services by such agency, instrumentality, administrative unit, or foreign country, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id06051341-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2906/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sells goods or services in international trade; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06051342-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2906/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any business firm which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id06051343-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2906/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is substantially owned or controlled by a foreign country or any agency, instrumentality, or administrative unit thereof,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id06051344-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2906/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is granted (formally or informally) any special or exclusive privilege by such foreign country, agency, instrumentality, or administrative unit, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id06051345-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2906/6/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchases goods or services in international trade for any purpose other than the use of such goods or services by such foreign country, agency, instrumentality, or administrative unit, or which sells goods or services in international trade.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id06051346-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/tI/s1107"},"text":"Pub. L. 100–418, title I, § 1107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1134"},"text":"102 Stat. 1134","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/tVI/s621/a/5"},"text":"Pub. L. 103–465, title VI, § 621(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4993"},"text":"108 Stat. 4993","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id06051347-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id06051348-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id06051349-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this part”, meaning part 1 (§§ 1101 to 1107) of subtitle A of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418"},"text":"Pub. L. 100–418","children":[],"tail":", which enacted this chapter and amended sections 2131, 2133, and 2191 of this title. For complete classification of part 1 to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0605134a-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of subsec. (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/s1107"},"text":"section 1107 of Pub. L. 100–418","children":[],"tail":". Subsec. (b) of "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/s1107"},"text":"section 1107 of Pub. L. 100–418","children":[],"tail":" amended sections 2131 and 2191 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0605134b-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465"},"text":"Pub. L. 103–465","children":[],"tail":" substituted “the GATT 1947 (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3501/1/A"},"text":"section 3501(1)(A) of this title","children":[],"tail":")” for “the General Agreement on Tariffs and Trade”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0605134c-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0605134d-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465"},"text":"Pub. L. 103–465","children":[],"tail":" effective on the date on which the WTO Agreement enters into force with respect to the United States ("},{"tag":"date","attrib":{"date":"1995-01-01"},"text":"Jan. 1, 1995","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/s621/b"},"text":"section 621(b) of Pub. L. 103–465","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1677k"},"text":"section 1677k of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
