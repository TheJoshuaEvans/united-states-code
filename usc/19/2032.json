{"tag":"section","attrib":{"id":"id05951384-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2032"},"text":null,"children":[{"tag":"num","attrib":{"value":"2032"},"text":"§ 2032.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report to Congress","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The President shall submit to the Congress an annual report on the implementation of this chapter. Such report shall include information regarding new negotiations, reductions or eliminations of duties, reciprocal concessions obtained, and other information relating to activities under this chapter. Such report shall also include information providing an evaluation of the Agreement and this chapter in relation to the total national interest, and specifically shall include, to the extent practicable, information with respect to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05951385-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2032/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the production of motor vehicles and motor vehicle parts in the United States and Canada.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05951386-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2032/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the retail prices of motor vehicles and motor vehicle parts in the United States and Canada.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05951387-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2032/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employment in the motor vehicle industry and motor vehicle parts industry in the United States and Canada, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05951388-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2032/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" United States and Canadian trade in motor vehicles and motor vehicle parts, particularly trade between the United States and Canada.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05951389-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/283/tV/s502"},"text":"Pub. L. 89–283, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-10-21"},"text":"Oct. 21, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1025"},"text":"79 Stat. 1025","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0595138a-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0595138b-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0595138c-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/283"},"text":"Pub. L. 89–283","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-10-21"},"text":"Oct. 21, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1016"},"text":"79 Stat. 1016","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2001"},"text":"section 2001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id0595138d-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"executiveOrder","id":"id0595138e-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Ex. Ord. No. 12713. Delegation of Authority for Submission of Report","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Ex. Ord. No. 12713, ","children":[{"tag":"date","attrib":{"date":"1990-05-01"},"text":"May 1, 1990","children":[],"tail":", 55 F.R. 18719, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"By the authority vested in me as President by the Constitution and laws of the United States of America, including the Automotive Products Trade Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2001"},"text":"19 U.S.C. 2001","children":[],"tail":" "},{"tag":"i","attrib":{},"text":"et seq","children":[],"tail":".) (“Act”), and in order to provide for the submission to the Congress of the annual report required by section 502 of the Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2032"},"text":"19 U.S.C. 2032","children":[],"tail":"), it is hereby ordered that authority for submission of the report is delegated to the Secretary of Commerce."}],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"text":"George Bush.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
