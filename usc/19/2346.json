{"tag":"section","attrib":{"id":"id05d095f7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2346"},"text":null,"children":[{"tag":"num","attrib":{"value":"2346"},"text":"§ 2346.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delegation of functions to Small Business Administration; authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05d095f8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2346/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delegation of functions as to eligibility certification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any firm which is small (within the meaning of the Small Business Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s631"},"text":"15 U.S.C. 631","children":[],"tail":" et seq.] and regulations promulgated thereunder), the Secretary may delegate all of his functions under this part (other than the functions under sections 2341 and 2342(d) "},{"tag":"ref","attrib":{"idref":"fn002106"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002106"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title with respect to the certification of eligibility and "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2354"},"text":"section 2354 of this title","children":[],"tail":") to the Administrator of the Small Business Administration."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05d095f9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2346/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary $16,000,000 for each of fiscal years 2003 through 2007, and $4,000,000 for the 3-month period beginning on ","children":[{"tag":"date","attrib":{"date":"2007-10-01"},"text":"October 1, 2007","children":[],"tail":","},{"tag":"ref","attrib":{"idref":"fn002107"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002107"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See Application of Subsection (b) note below."}],"tail":" to carry out the Secretary’s functions under this part in connection with furnishing adjustment assistance to firms. Amounts appropriated under this subsection shall remain available until expended."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05d095fa-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2346/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of unexpended appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The unexpended balances of appropriations authorized by section 1912(d) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title are transferred to the Secretary to carry out his functions under this part."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05d095fb-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/tII/s256"},"text":"Pub. L. 93–618, title II, § 256","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2032"},"text":"88 Stat. 2032","children":[],"tail":"