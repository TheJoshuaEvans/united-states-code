{"tag":"section","attrib":{"id":"id05c96aa9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2313"},"text":null,"children":[{"tag":"num","attrib":{"value":"2313"},"text":"§ 2313.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments to States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05c96aaa-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2313/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification to Secretary of the Treasury for payment to cooperating States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall from time to time certify to the Secretary of the Treasury for payment to each cooperating State the sums necessary to enable such State as agent of the United States to make payments provided for by this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05c96aab-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2313/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Utilization or return of money","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All money paid a State under this section shall be used solely for the purposes for which it is paid; and money so paid which is not used for such purposes shall be returned, at the time specified in the agreement under this subpart, to the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05c96aac-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2313/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Surety bonds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any agreement under this subpart may require any officer or employee of the State certifying payments or disbursing funds under the agreement or otherwise participating in the performance of the agreement, to give a surety bond to the United States in such amount as the Secretary may deem necessary, and may provide for the payment of the cost of such bond from funds for carrying out the purposes of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05c96aad-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/tII/s241"},"text":"Pub. L. 93–618, title II, § 241","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2025"},"text":"88 Stat. 2025","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXXV/s2513/b"},"text":"Pub. L. 97–35, title XXV, § 2513(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/889"},"text":"95 Stat. 889","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05c96aae-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05c96aaf-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id05c96ab0-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1981—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":" struck out provisions relating to payment to the State by the Secretary of the Treasury from the Adjustment Assistance Trust Fund prior to audit or settlement by the General Accounting Office."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":" struck out provisions relating to crediting money returned to the Secretary of the Treasury to the Adjustment Assistance Trust Fund."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id05c96ab1-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id05c96ab2-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1981 Amendment and Transition Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":" effective Aug. 1981, with transition provisions applicable, see "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/s2514"},"text":"section 2514 of Pub. L. 97–35","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2291"},"text":"section 2291 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"terminationDate","id":"id05c96ab3-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"No trade adjustment assistance, vouchers, allowances, or other payments or benefits may be provided under this part after ","children":[{"tag":"date","attrib":{"date":"2022-06-30"},"text":"June 30, 2022","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/93/618/s285"},"text":"section 285 of Pub. L. 93–618","children":[],"tail":", as modified by "},{"tag":"ref","attrib":{"href":"/us/pl/114/27/s406/a/7"},"text":"section 406(a)(7) of Pub. L. 114–27","children":[],"tail":", set out as notes preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2271"},"text":"section 2271 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
