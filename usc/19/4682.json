{"tag":"section","attrib":{"id":"id065d4643-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4682"},"text":null,"children":[{"tag":"num","attrib":{"value":"4682"},"text":"§ 4682.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timeline required","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id065d4644-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4682/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after the establishment of the Forced Labor Enforcement Task Force pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4681/a"},"text":"section 4681(a) of this title","children":[],"tail":", the Task Force shall establish timelines for responding to petitions submitted to the Commissioner of U.S. Customs and Border Protection alleging that goods are being imported by or with child or forced labor."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id065d4645-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4682/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In establishing the timelines during such 90-day period, the Task Force shall consult with the appropriate congressional committees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id065d4646-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4682/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Task Force shall timely submit to the appropriate congressional committees a report that contains the timelines established pursuant to subsection (a) and shall make such report publicly available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id065d4647-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113/tVII/s742"},"text":"Pub. L. 116–113, title VII, § 742","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-01-29"},"text":"Jan. 29, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/88"},"text":"134 Stat. 88","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
