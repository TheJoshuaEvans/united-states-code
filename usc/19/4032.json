{"tag":"section","attrib":{"id":"id0640bce1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4032"},"text":null,"children":[{"tag":"num","attrib":{"value":"4032"},"text":"§ 4032.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional duties on certain agricultural goods","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0640bce2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4032/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General provisions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0640bce3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4032/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of subsection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subsection applies to additional duties assessed under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0640bce4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4032/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable NTR (MFN) rate of duty","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (b), the term “applicable NTR (MFN) rate of duty” means, with respect to a safeguard good, a rate of duty that is the lesser of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0640bce5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4032/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the column 1 general rate of duty that would, at the time the additional duty is imposed under subsection (b), apply to a good classifiable in the same 8-digit subheading of the HTS as the safeguard good; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0640bce6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4032/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the column 1 general rate of duty that would, on the day before the date on which the Agreement enters into force, apply to a good classifiable in the same 8-digit subheading of the HTS as the safeguard good.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0640bce7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4032/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Schedule rate of duty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subsection (b), the term “schedule rate of duty” means, with respect to a safeguard good, the rate of duty for that good that is set out in the Schedule of the United States to Annex 3.3 of the Agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0640bce8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4032/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Safeguard good","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “safeguard good” means a good—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0640bce9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4032/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is included in the Schedule of the United States to Annex 3.15 of the Agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0640bcea-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4032/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that qualifies as an originating good under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4033"},"text":"section 4033 of this title","children":[],"tail":", except that operations performed in or material obtained from the United States shall be considered as if the operations were performed in, and the material was obtained from, a country that is not a party to the Agreement; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0640bceb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4032/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which a claim for preferential tariff treatment under the Agreement has been made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0640bcec-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4032/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No additional duty shall be assessed on a good under subsection (b) if, at the time of entry, the good is subject to import relief under—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0640bced-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4032/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" part A of subchapter III of this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0640bcee-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4032/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 1 of title II of the Trade Act of 1974 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2251"},"text":"19 U.S.C. 2251","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0640bcef-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4032/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The assessment of an additional duty on a good under subsection (b) shall cease to apply to that good on the date on which duty-free treatment must be provided to that good under the Schedule of the United States to Annex 3.3 of the Agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0640bcf0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4032/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 60 days after the Secretary of the Treasury first assesses an additional duty in a calendar year on a good under subsection (b), the Secretary shall notify the country whose good is subject to the additional duty in writing of such action and shall provide to that country data supporting the assessment of the additional duty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0640bcf1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4032/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional duties on safeguard goods","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0640bcf2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4032/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to any duty proclaimed under subsection (a) or (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4031"},"text":"section 4031 of this title","children":[],"tail":", and subject to subsection (a), the Secretary of the Treasury shall assess a duty, in the amount determined under paragraph (2), on a safeguard good of a CAFTA–DR country imported into the United States in a calendar year if the Secretary determines that, prior to such importation, the total volume of that safeguard good of such country that is imported into the United States in that calendar year exceeds 130 percent of the volume that is set out for that safeguard good in the corresponding year in the table for that country contained in Appendix I of the General Notes to the Schedule of the United States to Annex 3.3 of the Agreement. For purposes of this subsection, year 1 in that table corresponds to the calendar year in which the Agreement enters into force."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0640bcf3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4032/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Calculation of additional duty","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The additional duty on a safeguard good under this subsection shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0640bcf4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4032/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a good classified under subheading 1202.10.80, 1202.20.80, 2008.11.15, 2008.11.35, or 2008.11.60 of the HTS—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0640bcf5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4032/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in years 1 through 5, an amount equal to 100 percent of the excess of the applicable NTR (MFN) rate of duty over the schedule rate of duty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0640bcf6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4032/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in years 6 through 10, an amount equal to 75 percent of the excess of the applicable NTR (MFN) rate of duty over the schedule rate of duty; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0640bcf7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4032/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in years 11 through 14, an amount equal to 50 percent of the excess of the applicable NTR (MFN) rate of duty over the schedule rate of duty; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0640bcf8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4032/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of any other safeguard good—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0640bcf9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4032/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in years 1 through 14, an amount equal to 100 percent of the excess of the applicable NTR (MFN) rate of duty over the schedule rate of duty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0640bcfa-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4032/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in years 15 through 17, an amount equal to 75 percent of the excess of the applicable NTR (MFN) rate of duty over the schedule rate of duty; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0640bcfb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4032/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in years 18 and 19, an amount equal to 50 percent of the excess of the applicable NTR (MFN) rate of duty over the schedule rate of duty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0640bcfc-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/53/tII/s202"},"text":"Pub. L. 109–53, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-02"},"text":"Aug. 2, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/468"},"text":"119 Stat. 468","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0640bcfd-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id0640bcfe-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination of section by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/53/s107/d"},"text":"section 107(d) of Pub. L. 109–53","children":[],"tail":", see Effective and Termination Dates note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0640bcff-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0640bd00-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Part A of subchapter III of this chapter, referred to in subsec. (a)(5)(A), was in the original “subtitle A of title III of this Act”, meaning subtitle A (§§ 311–316) of title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/53"},"text":"Pub. L. 109–53","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-02"},"text":"Aug. 2, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/488"},"text":"119 Stat. 488","children":[],"tail":", which enacted part A of subchapter III (§ 4061 et seq.) of this chapter and amended "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2252"},"text":"section 2252 of this title","children":[],"tail":". For complete classification of subtitle A to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Trade Act of 1974, referred to in subsec. (a)(5)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618"},"text":"Pub. L. 93–618","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1978"},"text":"88 Stat. 1978","children":[],"tail":". Chapter 1 of title II of the Act is classified generally to part 1 (§ 2251 et seq.) of subchapter II of chapter 12 of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2101"},"text":"section 2101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0640bd01-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0640bd02-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective and Termination Dates","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date the Dominican Republic-Central America-United States Free Trade Agreement enters into force (","children":[{"tag":"date","attrib":{"date":"2006-03-01"},"text":"Mar. 1, 2006","children":[],"tail":") and to cease to have effect on the date the Agreement ceases to be in force with respect to the United States, and, during any period in which a country ceases to be a CAFTA–DR country, to cease to have effect with respect to such country, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/53/s107"},"text":"section 107 of Pub. L. 109–53","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s4001"},"text":"section 4001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
