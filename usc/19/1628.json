{"tag":"section","attrib":{"id":"id056a0caa-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1628"},"text":null,"children":[{"tag":"num","attrib":{"value":"1628"},"text":"§ 1628.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exchange of information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id056a0cab-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1628/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may by regulation authorize customs officers to exchange information or documents with foreign customs and law enforcement agencies if the Secretary reasonably believes the exchange of information is necessary to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id056a0cac-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1628/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" insure compliance with any law or regulation enforced or administered by the Customs Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id056a0cad-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1628/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administer or enforce multilateral or bilateral agreements to which the United States is a party;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id056a0cae-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1628/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist in investigative, judicial and quasi-judicial proceedings in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id056a0caf-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1628/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an action comparable to any of those described in paragraphs (1) through (4) ","children":[{"tag":"ref","attrib":{"idref":"fn002045"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002045"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “(3)”."}],"tail":" undertaken by a foreign customs or law enforcement agency, or in relation to a proceeding in a foreign country."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id056a0cb0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1628/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nondisclosure and uses of information provided","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id056a0cb1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1628/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information may be provided to foreign customs and law enforcement agencies under subsection (a) only if the Secretary obtains assurances from such agencies that such information will be held in confidence and used only for the law enforcement purposes for which such information is provided to such agencies by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id056a0cb2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1628/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No information may be provided under subsection (a) to any foreign customs or law enforcement agency that has violated any assurances described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id056a0cb3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1628/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Government agency of USMCA country","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id056a0cb4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1628/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may authorize U.S. Customs and Border Protection to exchange information with any government agency of a USMCA country, if the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id056a0cb5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1628/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reasonably believes the exchange of information is necessary to implement chapter 2, 4, 5, 6, or 7 of the USMCA; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id056a0cb6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1628/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtains assurances from such agency that the information will be held in confidence and used only for governmental purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id056a0cb7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1628/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subsection, the terms “USMCA” and “USMCA country” have the meanings given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4502"},"text":"section 4502 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id056a0cb8-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title IV, § 628, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/570/tIII/s3127"},"text":"Pub. L. 99–570, title III, § 3127","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-89"},"text":"100 Stat. 3207–89","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/182/tII/s209"},"text":"Pub. L. 103–182, title II, § 209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-08"},"text":"Dec. 8, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2098"},"text":"107 Stat. 2098","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/113/tII/s209/c"},"text":"Pub. L. 116–113, title II, § 209(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-01-29"},"text":"Jan. 29, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/52"},"text":"134 Stat. 52","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id056a0cb9-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id056a0cba-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id056a0cbb-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113"},"text":"Pub. L. 116–113","children":[],"tail":" added subsec. (c) and struck out former subsec. (c). Prior to amendment, text read as follows: “The Secretary may authorize the Customs Service to exchange information with any government agency of a NAFTA country, as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3301/4"},"text":"section 3301(4) of this title","children":[],"tail":", if the Secretary—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) reasonably believes the exchange of information is necessary to implement chapter 3, 4, or 5 of the North American Free Trade Agreement, and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) obtains assurances from such country that the information will be held in confidence and used only for governmental purposes.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/182"},"text":"Pub. L. 103–182","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id056c7cbc-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id056c7cbd-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2020 Amendment; Retention of Authority To Exchange Information","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113"},"text":"Pub. L. 116–113","children":[],"tail":" effective on the date the USMCA enters into force ("},{"tag":"date","attrib":{"date":"2020-07-01"},"text":"July 1, 2020","children":[],"tail":") and applicable with respect to goods entered for consumption, or withdrawn from warehouse for consumption, on or after that date, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/113/s209/d"},"text":"section 209(d) of Pub. L. 116–113","children":[],"tail":", set out as an Effective Date of 2020 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1304"},"text":"section 1304 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113/tII/s209/e"},"text":"Pub. L. 116–113, title II, § 209(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-01-29"},"text":"Jan. 29, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/53"},"text":"134 Stat. 53","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/113/tII/s209/e"},"text":"“Notwithstanding the amendment made by subsection (c) [amending this section], the Secretary of the Treasury shall retain the authority provided in section 628(c) of the Tariff Act of 1930 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1628/c"},"text":"19 U.S.C. 1628(c)","children":[],"tail":"] (as in effect on the day before the date on which the USMCA enters into force ["},{"tag":"date","attrib":{"date":"2020-07-01"},"text":"July 1, 2020","children":[],"tail":"]) to exchange information with any government agency of a NAFTA country (as defined in section 2 of the North American Free Trade Agreement Implementation Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3301"},"text":"19 U.S.C. 3301","children":[],"tail":"] (as in effect on the day before the date on which the USMCA enters into force)).”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definition of “USMCA” as used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113/s209/e"},"text":"section 209(e) of Pub. L. 116–113","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s4502"},"text":"section 4502 of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id056c7cbe-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/182"},"text":"Pub. L. 103–182","children":[],"tail":" effective on the date the North American Free Trade Agreement enters into force with respect to the United States ("},{"tag":"date","attrib":{"date":"1994-01-01"},"text":"Jan. 1, 1994","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/103/182/s213/b"},"text":"section 213(b) of Pub. L. 103–182","children":[],"tail":", formerly set out as an Effective Date note under former "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3331"},"text":"section 3331 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id056c7cbf-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions, personnel, assets, and liabilities of the United States Customs Service of the Department of the Treasury, including functions of the Secretary of the Treasury relating thereto, to the Secretary of Homeland Security, and for treatment of related references, see sections 203(1), 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":". For establishment of U.S. Customs and Border Protection in the Department of Homeland Security, treated as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" as of "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s211"},"text":"section 211 of Title 6","children":[],"tail":", as amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/114/125"},"text":"Pub. L. 114–125","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/114/125/s802/b"},"text":"section 802(b) of Pub. L. 114–125","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s211"},"text":"section 211 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
