{"tag":"section","attrib":{"id":"id05f2012e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2601"},"text":null,"children":[{"tag":"num","attrib":{"value":"2601"},"text":"§ 2601.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05f2012f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2601/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “agreement” includes any amendment to, or extension of, any agreement under this chapter that enters into force with respect to the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f20130-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2601/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “archaeological or ethnological material of the State Party” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05f20131-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2601/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any object of archaeological interest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05f20132-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2601/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any object of ethnological interest; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05f20133-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2601/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any fragment or part of any object referred to in subparagraph (A) or (B);","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"which was first discovered within, and is subject to export control by, the State Party. For purposes of this paragraph—","children":[],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05f20134-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2601/2/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" no object may be considered to be an object of archaeological interest unless such object—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id05f20135-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2601/2/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is of cultural significance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id05f20136-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2601/2/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is at least two hundred and fifty years old; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id05f20137-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2601/2/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was normally discovered as a result of scientific excavation, clandestine or accidental digging, or exploration on land or under water; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05f20138-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2601/2/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" no object may be considered to be an object of ethnological interest unless such object is—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id05f20139-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2601/2/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the product of a tribal or nonindustrial society, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id05f2013a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2601/2/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" important to the cultural heritage of a people because of its distinctive characteristics, comparative rarity, or its contribution to the knowledge of the origins, development, or history of that people.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f2013b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2601/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Committee” means the Cultural Property Advisory Committee established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2605"},"text":"section 2605 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f2013c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2601/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “consignee” means a consignee as defined in section 1483 ","children":[{"tag":"ref","attrib":{"idref":"fn002137"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002137"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f2013d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2601/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Convention” means the Convention on the means of prohibiting and preventing the illicit import, export, and transfer of ownership of cultural property adopted by the General Conference of the United Nations Educational, Scientific, and Cultural Organization at its sixteenth session.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f2013e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2601/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “cultural property” includes articles described in article 1(a) through (k) of the Convention whether or not any such article is specifically designated as such by any State Party for the purposes of such article.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f2013f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2601/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “designated archaeological or ethnological material” means any archaeological or ethnological material of the State Party which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05f20140-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2601/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id05f20141-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2601/7/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" covered by an agreement under this chapter that enters into force with respect to the United States, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05f20142-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2601/7/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to emergency action under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2603"},"text":"section 2603 of this title","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05f20143-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2601/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is listed by regulation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2604"},"text":"section 2604 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f20144-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2601/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Secretary” means the Secretary of the Treasury or his delegate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f20145-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2601/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “State Party” means any nation which has ratified, accepted, or acceded to the Convention.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f20146-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2601/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “United States” includes the several States, the District of Columbia, and any territory or area the foreign relations for which the United States is responsible.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f20147-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2601/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “United States citizen” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05f20148-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2601/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any individual who is a citizen or national of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05f20149-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2601/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any corporation, partnership, association, or other legal entity organized or existing under the laws of the United States or any State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05f2014a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2601/11/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any department, agency, or entity of the Federal Government or of any government of any State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05f2014b-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/446/tIII/s302"},"text":"Pub. L. 97–446, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2351"},"text":"96 Stat. 2351","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05f2014c-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05f2014d-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id05f2014e-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1483"},"text":"Section 1483 of this title","children":[],"tail":", referred to in par. (4), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/97/446/tII/s201/c"},"text":"Pub. L. 97–446, title II, § 201(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2349"},"text":"96 Stat. 2349","children":[],"tail":". Prior to repeal, section 1483 read: "},{"tag":"quotedContent","attrib":{},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“For the purposes of this subtitle—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All merchandise imported into the United States shall be held to be the property of the person to whom the same is consigned; and the holder of a bill of lading or the holder of an air waybill duly indorsed by the consignee therein named, or, in the case of a bill of lading if consigned to order, by the consignor, shall be deemed the consignee thereof; except that this section shall not limit in any way the rights of the consignor, as prescribed by article 12 of the Warsaw Convention (","children":[{"tag":"ref","attrib":{"href":"/us/stat/49/3017"},"text":"49 Stat. 3017","children":[],"tail":"). The underwriters of abandoned merchandise and the salvors of merchandise saved from a wreck at sea or on or along a coast of the United States may be regarded as the consignees."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person making entry of merchandise under the provisions of subdivision (h) or (i) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1484"},"text":"section 1484 of this title","children":[],"tail":" (relating to entry on carrier’s certificate and on duplicate bill of lading, respectively) shall be deemed the sole consignee thereof.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id05f4714f-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2605"},"text":"Section 2605 of this title","children":[],"tail":", referred to in par. (3), was in original “section 206” and was translated as "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2605"},"text":"section 2605 of this title","children":[],"tail":", which is "},{"tag":"ref","attrib":{"href":"/us/pl/97/446/s306"},"text":"section 306 of Pub. L. 97–446","children":[],"tail":", as the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id05f47150-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id05f47151-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/446/tIII/s315"},"text":"Pub. L. 97–446, title III, § 315","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2363"},"text":"96 Stat. 2363","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/446/tIII/s315"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This title [enacting this chapter] shall take effect on the ninetieth day after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":"] or on any date which the President shall prescribe and publish in the Federal Register, if such date is—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before such ninetieth day and after such date of enactment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after the initial membership of the Committee is appointed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding subsection (a), the members of the Committee may be appointed in the manner provided for in section 306 [2605 of this title] at any time after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id05f47152-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/446/tIII/s301"},"text":"Pub. L. 97–446, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2350"},"text":"96 Stat. 2350","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/446/tIII/s301"},"text":"“This title [enacting this chapter] may be cited as the ‘Convention on Cultural Property Implementation Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id05f47153-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Protecting and Preserving International Cultural Property","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/151"},"text":"Pub. L. 114–151","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-05-09"},"text":"May 9, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/369"},"text":"130 Stat. 369","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/151"},"text":"\n","children":[{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“SECTION 1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" SHORT TITLE.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“This Act may be cited as the ‘Protect and Preserve International Cultural Property Act’.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“SEC. 2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" SENSE OF CONGRESS.","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"“It is the sense of Congress that the President should establish an interagency coordinating committee to coordinate the efforts of the executive branch to protect and preserve international cultural property at risk from political instability, armed conflict, or natural or other disasters. Such committee should—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be chaired by a Department of State employee of Assistant Secretary rank or higher, concurrent with that employee’s other duties;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include representatives of the Smithsonian Institution and Federal agencies with responsibility for the preservation and protection of international cultural property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with governmental and nongovernmental organizations, including the United States Committee of the Blue Shield, museums, educational institutions, and research institutions, and participants in the international art and cultural property market on efforts to protect and preserve international cultural property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" coordinate core United States interests in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protecting and preserving international cultural property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preventing and disrupting looting and illegal trade and trafficking in international cultural property, particularly exchanges that provide revenue to terrorist and criminal organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protecting sites of cultural and archaeological significance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing for the lawful exchange of international cultural property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“SEC. 3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" EMERGENCY PROTECTION FOR SYRIAN CULTURAL PROPERTY.","children":[],"tail":null},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President shall exercise the authority of the President under section 304 of the Convention on Cultural Property Implementation Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2603"},"text":"19 U.S.C. 2603","children":[],"tail":") to impose import restrictions set forth in section 307 of that Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2606"},"text":"19 U.S.C. 2606","children":[],"tail":") with respect to any archaeological or ethnological material of Syria—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 90 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2016-05-09"},"text":"May 9, 2016","children":[],"tail":"];"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without regard to whether Syria is a State Party (as defined in section 302 of that Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2601"},"text":"19 U.S.C. 2601","children":[],"tail":")); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" notwithstanding—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the requirement of subsection (b) of section 304 of that Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2603/b"},"text":"19 U.S.C. 2603(b)","children":[],"tail":") that an emergency condition (as defined in subsection (a) of that section) applies; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the limitations under subsection (c) of that section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Determination Regarding Certification.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determination.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President shall, not less often than annually, determine whether at least 1 of the conditions specified in subparagraph (B) is met, and shall notify the appropriate congressional committees of such determination.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conditions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The conditions referred to in subparagraph (A) are the following:","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Government of Syria is incapable, at the time a determination under such subparagraph is made, of fulfilling the requirements to request an agreement under section 303 of the Convention on Cultural Property Implementation Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2602"},"text":"19 U.S.C. 2602","children":[],"tail":"), including the requirements under subsection (a)(3) of that section."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" It would be against the United States national interest to enter into such an agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination of restrictions.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subparagraph (B), the import restrictions referred to in subsection (a) shall terminate on the date that is 5 years after the date on which the President determines that neither of the conditions specified in paragraph (1)(B) are met.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Request for termination","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If Syria requests to enter into an agreement with the United States pursuant to section 303 of the Convention on Cultural Property Implementation Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2602"},"text":"19 U.S.C. 2602","children":[],"tail":") on or after the date on which the President determines that neither of the conditions specified in paragraph (1)(B) are met, the import restrictions referred to in subsection (a) shall terminate on the earlier of—"}],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date that is 3 years after the date on which Syria makes such a request; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the United States and Syria enter into such an agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President may waive the import restrictions referred to in subsection (a) for specified archaeological and ethnological material of Syria if the President certifies to the appropriate congressional committees that the conditions described in paragraph (2) are met.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conditions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The conditions referred to in paragraph (1) are the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The owner or lawful custodian of the specified archaeological or ethnological material of Syria has requested that such material be temporarily located in the United States for protection purposes; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if no owner or lawful custodian can reasonably be identified, the President determines that, for purposes of protecting and preserving such material, the material should be temporarily located in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such material shall be returned to the owner or lawful custodian when requested by such owner or lawful custodian.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is no credible evidence that granting a waiver under this subsection will contribute to illegal trafficking in archaeological or ethnological material of Syria or financing of criminal or terrorist activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Action","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the President grants a waiver under this subsection, the specified archaeological or ethnological material of Syria that is the subject of such waiver shall be placed in the temporary custody of the United States Government or in the temporary custody of a cultural or educational institution within the United States for the purpose of protection, restoration, conservation, study, or exhibition, without profit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Immunity from seizure","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any archaeological or ethnological material that enters the United States pursuant to a waiver granted under this section shall have immunity from seizure under ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/259"},"text":"Public Law 89–259","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2459"},"text":"22 U.S.C. 2459","children":[],"tail":"). All provisions of "},{"tag":"ref","attrib":{"href":"/us/pl/89/259"},"text":"Public Law 89–259","children":[],"tail":" shall apply to such material as if immunity from seizure had been granted under that Public Law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appropriate congressional committees","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term ‘appropriate congressional committees’ means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Relations and the Committee on Finance of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Affairs and the Committee on Ways and Means of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Archaeological or ethnological material of syria","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘archaeological or ethnological material of Syria’ means cultural property (as defined in section 302 of the Convention on Cultural Property Implementation Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2601"},"text":"19 U.S.C. 2601","children":[],"tail":")) that is unlawfully removed from Syria on or after "},{"tag":"date","attrib":{"date":"2011-03-15"},"text":"March 15, 2011","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“SEC. 4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" REPORT.","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"“Not later than 1 year after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2016-05-09"},"text":"May 9, 2016","children":[],"tail":"], and annually thereafter for the next 6 years, the President shall submit to the appropriate congressional committees a report on the efforts of the executive branch, during the 12-month period preceding the submission of the report, to protect and preserve international cultural property, including—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether an interagency coordinating committee as described in section 2 has been established and, if such a committee has been established, a description of the activities undertaken by such committee, including a list of the entities participating in such activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of measures undertaken pursuant to relevant statutes, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actions to implement and enforce section 3 of this Act and section 3002 of the Emergency Protection for Iraqi Cultural Antiquities Act of 2004 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/429"},"text":"Public Law 108–429","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/118/2599"},"text":"118 Stat. 2599","children":[],"tail":"), including measures to dismantle international networks that traffic illegally in cultural property;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of any requests for a waiver under section 3(c) of this Act and, for each such request, whether a waiver was granted;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of the statutes and regulations employed in criminal, civil, and civil forfeiture actions to prevent illegal trade and trafficking in cultural property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actions undertaken to ensure the consistent and effective application of law in cases relating to illegal trade and trafficking in cultural property; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"“(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actions undertaken to promote the legitimate commercial and non-commercial exchange and movement of cultural property; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actions undertaken in fulfillment of international agreements on cultural property protection, including the Convention for the Protection of Cultural Property in the Event of Armed Conflict, done at The Hague ","children":[{"tag":"date","attrib":{"date":"1954-05-14"},"text":"May 14, 1954","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id05f47154-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id05f47155-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions and Authorities Under the Protect and Preserve International Cultural Property Act","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"2016-08-01"},"text":"Aug. 1, 2016","children":[],"tail":", 81 F.R. 55105, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum for the Secretary of State","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"By the authority vested in me as President by the Constitution and the laws of the United States of America, including ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"section 301 of title 3","children":[],"tail":", United States Code, the functions and authorities conferred upon the President by the Protect and Preserve International Cultural Property Act ("},{"tag":"ref","attrib":{"href":"/us/pl/114/151"},"text":"Public Law 114–151","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/369"},"text":"130 Stat. 369","children":[],"tail":") are hereby delegated to the Secretary of State. In the performance of such functions, the Secretary of State shall consult the Secretaries of Homeland Security and the Treasury, and the heads of other departments and agencies, as appropriate."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"You are authorized and directed to publish this memorandum in the Federal Register.","children":[],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"text":"Barack Obama.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
