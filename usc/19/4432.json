{"tag":"section","attrib":{"id":"id06515fce-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4432"},"text":null,"children":[{"tag":"num","attrib":{"value":"4432"},"text":"§ 4432.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of preclearance operations","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1629"},"text":"section 1629 of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1103/a/7"},"text":"section 1103(a)(7) of title 8","children":[],"tail":", and provided that an aviation security preclearance agreement (as defined in section 44901(d)(4)(B) "},{"tag":"ref","attrib":{"idref":"fn002173"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002173"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 49) is in effect, the Secretary may establish and maintain U.S. Customs and Border Protection preclearance operations in a foreign country—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id06515fcf-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4432/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prevent terrorists, instruments of terrorism, and other security threats from entering the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06515fd0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4432/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prevent inadmissible persons from entering the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06515fd1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4432/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that merchandise destined for the United States complies with applicable laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06515fd2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4432/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure the prompt processing of persons eligible to travel to the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06515fd3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4432/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to accomplish such other objectives as the Secretary determines are necessary to protect the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id06515fd4-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/125/tVIII/s813"},"text":"Pub. L. 114–125, title VIII, § 813","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-24"},"text":"Feb. 24, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/217"},"text":"130 Stat. 217","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id06515fd5-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id06515fd6-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id06515fd7-3a70-11f1-