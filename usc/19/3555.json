{"tag":"section","attrib":{"id":"id0610fb24-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3555"},"text":null,"children":[{"tag":"num","attrib":{"value":"3555"},"text":"§ 3555.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Objectives for extended negotiations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0610fb25-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3555/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trade in financial services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The principal negotiating objective of the United States in the extended negotiations on financial services to be conducted under the auspices of the WTO is to seek to secure commitments, from a wide range of commercially important developed and developing countries, to reduce or eliminate barriers to the supply of financial services, including barriers that deny national treatment or market access by restricting the establishment or operation of financial services providers, as the condition for the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0610fb26-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3555/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offering commitments to provide national treatment and market access in each of the financial services subsectors, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0610fb27-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3555/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making such commitments on a normal trade relations basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0610fb28-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3555/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trade in basic telecommunications services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The principal negotiating objective of the United States in the extended negotiations on basic telecommunications services to be conducted under the auspices of the WTO is to obtain the opening on nondiscriminatory terms and conditions of foreign markets for basic telecommunications services through facilities-based competition or through the resale of services on existing networks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0610fb29-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3555/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trade in civil aircraft","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0610fb2a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3555/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Negotiations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The principal negotiating objectives of the United States in the extended negotiations on trade in civil aircraft to be conducted under the auspices of the WTO are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0610fb2b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3555/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to obtain competitive opportunities for United States exports in foreign markets substantially equivalent to those afforded to foreign products in the United States,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0610fb2c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3555/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to obtain the reduction or elimination of specific tariff and nontariff barriers, including through expanded membership in the Agreement on Trade in Civil Aircraft and in the US–EC bilateral agreement for large civil aircraft,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0610fb2d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3555/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maintain vigorous and effective disciplines on subsidies practices with respect to civil aircraft products under the Agreement on Subsidies and Countervailing Measures referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3511/d/12"},"text":"section 3511(d)(12) of this title","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0610fb2e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3555/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maintain the scope and coverage on indirect support as specified in the US–EC bilateral agreement on large civil aircraft, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0610fb2f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3555/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to obtain increased transparency with respect to foreign subsidy programs in the civil aircraft sector, both through greater government disclosure with respect to the use of taxpayer moneys and higher financial disclosure standards for companies receiving government supports (including disclosure comparable to that required under United States securities laws).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0610fb30-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3555/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0610fb31-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3555/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “civil aircraft” means those products to which the Agreement on Trade in Civil Aircraft applies,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06136b32-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3555/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “large civil aircraft” has the meaning given that term in Annex II to the US–EC bilateral agreement,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06136b33-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3555/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “indirect support” means indirect government support as defined in Annex II to the US–EC bilateral agreement,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06136b34-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3555/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Agreement on Trade in Civil Aircraft” means the Agreement on Trade in Civil Aircraft approved by the Congress under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2503"},"text":"section 2503 of this title","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06136b35-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3555/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “US–EC bilateral agreement” means the Agreement Concerning the Application of the GATT Agreement on Trade in Civil Aircraft Between the European Economic Community and the Government of the United States of America on trade in large civil aircraft, entered into on ","children":[{"tag":"date","attrib":{"date":"1992-07-17"},"text":"July 17, 1992","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id06136b36-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/tI/s135"},"text":"Pub. L. 103–465, title I, § 135","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4840"},"text":"108 Stat. 4840","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/tV/s5003/b/5"},"text":"Pub. L. 105–206, title V, § 5003(b)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/790"},"text":"112 Stat. 790","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id06136b37-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id06136b38-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id06136b39-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206"},"text":"Pub. L. 105–206","children":[],"tail":" substituted “normal trade relations” for “most-favored-nation”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id06136b3a-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id06136b3b-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on date on which WTO Agreement enters into force with respect to United States (","children":[{"tag":"date","attrib":{"date":"1995-01-01"},"text":"Jan. 1, 1995","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/s138/b"},"text":"section 138(b) of Pub. L. 103–465","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3551"},"text":"section 3551 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
