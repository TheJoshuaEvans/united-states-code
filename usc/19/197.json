il":"; "},{"tag":"ref","attrib":{"href":"/us/act/1846-08-06/ch84/s1"},"text":"Aug. 6, 1846, ch. 84, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/9/53"},"text":"9 Stat. 53","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1862-02-25/ch33/s5"},"text":"Feb. 25, 1862, ch. 33, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/12/346"},"text":"12 Stat. 346","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 3473, formerly cited as a credit to this section, was repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598/tIII/s322/d"},"text":"Pub. L. 95–598, title III, § 322(d)","children":[],"tail":", title IV, § 402(a), "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2679"},"text":"92 Stat. 2679","children":[],"tail":", 2682, effective "},{"tag":"date","attrib":{"date":"1979-10-01"},"text":"Oct. 1, 1979","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Prior to its incorporation into the Code, R.S. § 3009, as amended by ","children":[{"tag":"ref","attrib":{"href":"/us/act/1877-02-27/ch69"},"text":"act Feb. 27, 1877, ch. 69","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/19/247"},"text":"19 Stat. 247","children":[],"tail":", read: "},{"tag":"quotedContent","attrib":{},"text":"“All duties upon imports shall be collected in ready money, and shall be paid in coin or coin certificates or in United States notes, payable on demand, authorized to be issued prior to the twenty-fifth day of February, one thousand eight hundred and sixty-two, and by law receivable in payment of public dues.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Its provisions were changed to conform to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s198"},"text":"section 198 of this title","children":[],"tail":" authorizing the receipt o