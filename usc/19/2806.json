{"tag":"section","attrib":{"id":"id0600592e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2806"},"text":null,"children":[{"tag":"num","attrib":{"value":"2806"},"text":"§ 2806.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States wine export promotion","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In order to develop, maintain, and expand foreign markets for United States wine, the President is encouraged to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0600592f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2806/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utilize, for the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1985-09-30"},"text":"September 30, 1985","children":[],"tail":", the authority provided under section 135 of the Omnibus Budget Reconciliation Act of 1982 ["},{"tag":"ref","attrib":{"href":"/us/usc/t7/s612c"},"text":"7 U.S.C. 612c","children":[],"tail":" note] to make available sufficient funds to initiate, in cooperation with nongovernmental trade associations representative of United States wineries, an export promotion program for United States; "},{"tag":"ref","attrib":{"idref":"fn002149"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002149"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “United States wine;”."}],"tail":" and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06005930-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2806/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" request, for each subsequent fiscal year, an appropriation for such a wine export promotion program that will not be at the expense of any appropriations requested for export promotion programs involving other agriculture commodities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id06005931-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/573/tIX/s907"},"text":"Pub. L. 98–573, title IX, § 907","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3050"},"text":"98 Stat. 3050","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id06005932-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id06005933-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id06005934-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 135 of the Omnibus Budget Reconciliation Act of 1982, referred to in par. (1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/253/s135"},"text":"section 135 of Pub. L. 97–253","children":[],"tail":", title I, "},{"tag":"date","attrib":{"date":"1982-09-08"},"text":"Sept. 8, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/772"},"text":"96 Stat. 772","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s612c"},"text":"section 612c of Title 7","children":[],"tail":", Agriculture."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
