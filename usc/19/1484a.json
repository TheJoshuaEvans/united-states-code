{"tag":"section","attrib":{"id":"id05419cac-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1484a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1484a"},"text":"§ 1484a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Articles returned from space not to be construed as importation","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The return of articles from space shall not be considered an importation, and an entry of such articles shall not be required, if:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05419cad-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1484a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such articles were previously launched into space from the customs territory of the United States aboard a spacecraft operated by, or under the control of, United States persons and owned—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0543e69e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1484a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" wholly by United States persons, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0543e69f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1484a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in substantial part by United States persons, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0543e6a0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1484a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the United States;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0543e6a1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1484a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such articles were maintained or utilized while in space solely on board such spacecraft or aboard another spacecraft which meets the requirements of paragraph (1)(A) through (C) of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0543e6a2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1484a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such articles were returned to the customs territory directly from space aboard such spacecraft or aboard another spacecraft which meets the requirements of paragraph (1)(A) through (C) of this section;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"without regard to whether such articles have been advanced in value or improved in condition by any process of manufacture or other means while in space.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0543e6a3-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title IV, § 484a, as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/573/tII/s209/a"},"text":"Pub. L. 98–573, title II, § 209(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2976"},"text":"98 Stat. 2976","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0543e6a4-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0543e6a5-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0543e6a6-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable with respect to articles launched into space from the customs territory of the United States on or after ","children":[{"tag":"date","attrib":{"date":"1985-01-01"},"text":"Jan. 1, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/573/s214/c/4"},"text":"section 214(c)(4) of Pub. L. 98–573","children":[],"tail":", set out as an Effective Date of 1984 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1304"},"text":"section 1304 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
