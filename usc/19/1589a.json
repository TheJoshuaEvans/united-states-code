{"tag":"section","attrib":{"id":"id056095b5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1589a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1589a"},"text":"§ 1589a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement authority of customs officers","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Subject to the direction of the Secretary of the Treasury, an officer of the customs may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id056095b6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1589a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry a firearm;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id056095b7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1589a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" execute and serve any order, warrant, subpena, summons, or other process issued under the authority of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id056095b8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1589a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make an arrest without a warrant for any offense against the United States committed in the officer’s presence or for a felony, cognizable under the laws of the United States committed outside the officer’s presence if the officer has reasonable grounds to believe that the person to be arrested has committed or is committing a felony; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id056095b9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1589a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform any other law enforcement duty that the Secretary of the Treasury may designate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id056095ba-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title IV, § 589, as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/573/tII/s213/a/17"},"text":"Pub. L. 98–573, title II, § 213(a)(17)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2988"},"text":"98 Stat. 2988","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id056095bb-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id056095bc-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id056095bd-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 589 of act ","children":[{"tag":"date","attrib":{"date":"1930-06-17"},"text":"June 17, 1930","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s320"},"text":"Pub. L. 98–473, title II, § 320","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2056"},"text":"98 Stat. 2056","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1589"},"text":"section 158