{"tag":"section","attrib":{"id":"id061a97c7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3741"},"text":null,"children":[{"tag":"num","attrib":{"value":"3741"},"text":"§ 3741.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of the Congress regarding efforts to combat desertification in Africa and other countries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id061a97c8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3741/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id061a97c9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3741/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" desertification affects approximately one-sixth of the world’s population and one-quarter of the total land area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id061a97ca-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3741/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" over 1,000,000 hectares of Africa are affected by desertification;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id061a97cb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3741/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dryland degradation is an underlying cause of recurrent famine in Africa;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id061a97cc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3741/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United Nations Environment Programme estimates that desertification costs the world $42,000,000,000 a year, not including incalculable costs in human suffering; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id061a97cd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3741/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States can strengthen its partnerships throughout Africa and other countries affected by desertification, help alleviate social and economic crises caused by misuse of natural resources, and reduce dependence on foreign aid, by taking a leading role to combat desertification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id061a97ce-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3741/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of the Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the sense of the Congress that the United States should expeditiously work with the international community, particularly Africa and other countries affected by desertification, to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id061a97cf-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3741/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strengthen international cooperation to combat desertification;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id061a97d0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3741/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote the development of national and regional strategies to address desertification and increase public awareness of this serious problem and its effects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id061a97d1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3741/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and implement national action programs that identify the causes of desertification and measures to address it; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id061a97d2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3741/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recognize the essential role of local governments and nongovernmental organizations in developing and implementing measures to address desertification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id061a97d3-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/200/tI/s131"},"text":"Pub. L. 106–200, title I, § 131","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-05-18"},"text":"May 18, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/274"},"text":"114 Stat. 274","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
