{"tag":"section","attrib":{"id":"id059031af-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1751"},"text":null,"children":[{"tag":"num","attrib":{"value":"1751"},"text":"§ 1751.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of fairs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id059031b0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1751/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice to Secretary of the Treasury","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"When the Secretary of Commerce is satisfied that the public interest in promoting trade will be served by allowance of the privileges provided for in this chapter to any fair to be held in the United States, he shall so advise the Secretary of the Treasury, designating (1) the name of the fair, (2) the place where the fair will be held, (3) the date when the fair will open and the date when it will close, and (4) the name of the operator of the fair.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id059031b1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1751/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id059031b2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1751/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “fair” means any fair, exhibition, or exposition designated by the Secretary of Commerce pursuant to this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id059031b3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1751/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “closing date” in the case of any fair means the date designated pursuant to subsection (a)(3) as the date when the fair will close, or (if earlier) the date on which such fair actually closes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id059031b4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1751/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce may prescribe such regulations as he deems necessary or appropriate to carry out the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id059031b5-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/14/s2"},"text":"Pub. L. 86–14, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-04-22"},"text":"Apr. 22, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/18"},"text":"73 Stat. 18","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id059031b6-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id059031b7-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id059031b8-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/86/14/s1"},"text":"Pub. L. 86–14, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-04-22"},"text":"Apr. 22, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/18"},"text":"73 Stat. 18","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/86/14/s1"},"text":"“This Act [enacting this chapter] may be cited as the ‘Trade Fair Act of 1959’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
