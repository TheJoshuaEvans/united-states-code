{"tag":"section","attrib":{"id":"id05a826e0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2117"},"text":null,"children":[{"tag":"num","attrib":{"value":"2117"},"text":"§ 2117.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International safeguard procedures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05a826e1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2117/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Harmonization, reduction, or elimination of barriers and distortions affecting international trade; use of temporary measures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A principal United States negotiating objective under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2112"},"text":"section 2112 of this title","children":[],"tail":" shall be to obtain internationally agreed upon rules and procedures, in the context of the harmonization, reduction, or elimination of barriers to, and other distortions of, international trade, which permit the use of temporary measures to ease adjustment to changes occurring in competitive conditions in the domestic markets of the parties to an agreement resulting from such negotiations due to the expansion of international trade."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05a826e2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2117/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permissible provisions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any agreement entered into under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2112"},"text":"section 2112 of this title","children":[],"tail":" may include provisions establishing procedures for—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id05a826e3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2117/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notification of affected exporting countries,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05a826e4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2117/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" international consultations,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05a826e5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2117/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" international review of changes in trade flows,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05a826e6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2117/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making adjustments in trade flows as the result of such changes, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05a826e7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2117/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" international mediation.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Such agreements may also include provisions which—","children":[],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05a826e8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2117/b/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exclude, under specified conditions, the parties thereto from compensation obligations and retaliation, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05a826e9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2117/b/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permit domestic public procedures through which interested parties have the right to participate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05a826ea-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/tI/s107"},"text":"Pub. L. 93–618, title I, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1985"},"text":"88 Stat. 1985","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
