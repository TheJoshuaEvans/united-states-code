{"tag":"section","attrib":{"id":"id06515fa2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4422"},"text":null,"children":[{"tag":"num","attrib":{"value":"4422"},"text":"§ 4422.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Committee on International Exchange Rate Policy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id06515fa3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4422/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id06515fa4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4422/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established an Advisory Committee on International Exchange Rate Policy (in this section referred to as the “Committee”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06515fa5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4422/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Committee shall be responsible for advising the Secretary of the Treasury with respect to the impact of international exchange rates and financial policies on the economy of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id06515fa6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4422/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id06515fa7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4422/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee shall be composed of 9 members as follows, none of whom shall be employees of the Federal Government:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id06515fa8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4422/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Three members shall be appointed by the President pro tempore of the Senate, upon the recommendation of the chairmen and ranking members of the Committee on Banking, Housing, and Urban Affairs and the Committee on Finance of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06515fa9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4422/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Three members shall be appointed by the Speaker of the House of Representatives, upon the recommendation of the chairmen and ranking members of the Committee on Financial Services and the Committee on Ways and Means of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06515faa-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4422/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Three members shall be appointed by the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06515fab-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4422/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members shall be selected under paragraph (1) on the basis of their objectivity and demonstrated expertise in finance, economics, or currency exchange.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06515fac-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4422/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id06515fad-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4422/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members shall be appointed for a term of 2 years or until the Committee terminates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06515fae-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4422/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reappointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member may be reappointed to the Committee for additional terms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06515faf-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4422/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any vacancy in the Committee shall not affect its powers, but shall be filled in the same manner as the original appointment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id06515fb0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4422/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of Committee","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id06515fb1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4422/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Committee shall terminate on the date that is 2 years after ","children":[{"tag":"date","attrib":{"date":"2016-02-24"},"text":"February 24, 2016","children":[],"tail":", unless renewed by the President for a subsequent 2-year period."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06515fb2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4422/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continued renewal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President may continue to renew the Committee for successive 2-year periods by taking appropriate action to renew the Committee prior to the date on which the Committee would otherwise terminate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id06515fb3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4422/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Committee shall hold not fewer than 2 meetings each calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id06515fb4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4422/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id06515fb5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4422/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Committee shall elect from among its members a chairperson for a term of 2 years or until the Committee terminates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06515fb6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4422/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reelection; subsequent terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A chairperson of the Committee may be reelected chairperson but is ineligible to serve consecutive terms as chairperson.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id06515fb7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4422/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury shall make available to the Committee such staff, information, personnel, administrative services, and assistance as the Committee may reasonably require to carry out the activities of the Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id06515fb8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4422/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of chapter 10 of title 5","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id06515fb9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4422/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), the provisions of chapter 10 of title 5 shall apply to the Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06515fba-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4422/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Meetings of the Committee shall be exempt from the requirements of subsections (a) and (b) of section 1009 and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s1010"},"text":"section 1010 of title 5","children":[],"tail":" (relating to open meetings, public notice, public participation, and public availability of documents), whenever and to the extent it is determined by the President or the Secretary of the Treasury that such meetings will be concerned with matters the disclosure of which—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id06515fbb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4422/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would seriously compromise the development by the Government of the United States of monetary or financial policy; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06515fbc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4422/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is likely to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id06515fbd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4422/g/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lead to significant financial speculation in currencies, securities, or commodities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id06515fbe-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4422/g/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" significantly endanger the stability of any financial institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id06515fbf-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4422/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary of the Treasury for each fiscal year in which the Committee is in effect $1,000,000 to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id06515fc0-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/125/tVII/s702"},"text":"Pub. L. 114–125, title VII, § 702","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-24"},"text":"Feb. 24, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/198"},"text":"130 Stat. 198","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/144"},"text":"Pub. L. 117–286, § 4(a)(144)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4321"},"text":"136 Stat. 4321","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id06515fc1-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id06515fc2-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id06515fc3-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/144/A"},"text":"Pub. L. 117–286, § 4(a)(144)(A)","children":[],"tail":", substituted “chapter 10 of title 5” for “the Federal Advisory Committee Act” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/144/B"},"text":"Pub. L. 117–286, § 4(a)(144)(B)","children":[],"tail":", substituted “chapter 10 of title 5” for “the Federal Advisory Committee Act (5 U.S.C. App.)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/144/C"},"text":"Pub. L. 117–286, § 4(a)(144)(C)","children":[],"tail":", substituted “section 1009 and "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1010"},"text":"section 1010 of title 5","children":[],"tail":"” for “section 10 and section 11 of the Federal Advisory Committee Act” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
