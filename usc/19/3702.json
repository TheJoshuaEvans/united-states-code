{"tag":"section","attrib":{"id":"id0615b54e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3702"},"text":null,"children":[{"tag":"num","attrib":{"value":"3702"},"text":"§ 3702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement of policy","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Congress supports—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0615b54f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3702/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encouraging increased trade and investment between the United States and sub-Saharan Africa;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0615b550-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3702/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reducing tariff and nontariff barriers and other obstacles to sub-Saharan African and United States trade;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0615b551-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3702/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expanding United States assistance to sub-Saharan Africa’s regional integration efforts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0615b552-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3702/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" negotiating reciprocal and mutually beneficial trade agreements, including the possibility of establishing free trade areas that serve the interests of both the United States and the countries of sub-Saharan Africa;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0615b553-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3702/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" focusing on countries committed to the rule of law, economic reform, and the eradication of poverty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0615b554-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3702/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strengthening and expanding the private sector in sub-Saharan Africa, especially enterprises owned by women and small businesses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0615b555-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3702/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitating the development of civil societies and political freedom in sub-Saharan Africa;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0615b556-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3702/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing a United States-Sub-Saharan Africa Trade and Economic Cooperation Forum;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0615b557-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3702/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the accession of the countries in sub-Saharan Africa to the Organization for Economic Cooperation and Development (OECD) Convention on Combating Bribery of Foreign Public Officials in International Business Transactions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0615b558-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3702/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoting the role of women in social, political, and economic development in sub-Saharan Africa.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0615b559-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/200/tI/s103"},"text":"Pub. L. 106–200, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-05-18"},"text":"May 18, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/253"},"text":"114 Stat. 253","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/27/tI/s106/a"},"text":"Pub. L. 114–27, title I, § 106(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-06-29"},"text":"June 29, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/368"},"text":"129 Stat. 368","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0615b55a-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0615b55b-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0615b55c-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Par. (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/27"},"text":"Pub. L. 114–27","children":[],"tail":" added par. (10)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
