{"tag":"section","attrib":{"id":"id05e15eee-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2461"},"text":null,"children":[{"tag":"num","attrib":{"value":"2461"},"text":"§ 2461.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to extend preferences","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The President may provide duty-free treatment for any eligible article from any beneficiary developing country in accordance with the provisions of this subchapter. In taking any such action, the President shall have due regard for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05e15eef-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2461/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effect such action will have on furthering the economic development of developing countries through the expansion of their exports;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05e15ef0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2461/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which other major developed countries are undertaking a comparable effort to assist developing countries by granting generalized preferences with respect to imports of products of such countries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05e15ef1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2461/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the anticipated impact of such action on United States producers of like or directly competitive products; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05e15ef2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2461/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent of the beneficiary developing country’s competitiveness with respect to eligible articles.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05e15ef3-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/tV/s501"},"text":"Pub. L. 93–618, title V, § 501","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1952/a"},"text":"Pub. L. 104–188, title I, § 1952(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1917"},"text":"110 Stat. 1917","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05e15ef4-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05e15ef5-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id05e15ef6-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2461, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/tV/s501"},"text":"Pub. L. 93–618, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2066"},"text":"88 Stat. 2066","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/573/tV/s502"},"text":"Pub. L. 98–573, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3018"},"text":"98 Stat. 3018","children":[],"tail":", related to authority to extend preferences, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/104/188"},"text":"Pub. L. 104–188","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id05e15ef7-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id05e15ef8-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1953"},"text":"Pub. L. 104–188, title I, § 1953","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1926"},"text":"110 Stat. 1926","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/188/tI/s1953"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this subtitle [subtitle J (§§ 1951–1954) of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188"},"text":"Pub. L. 104–188","children":[],"tail":", enacting this subchapter, amending sections 2702, 3011, 3202, 3331, and 3551 of this title, "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1444–2"},"text":"section 1444–2 of Title 7","children":[],"tail":", Agriculture, "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s4711"},"text":"section 4711 of Title 15","children":[],"tail":", Commerce and Trade, sections 262p–4p and 2191a of Title 22, Foreign Relations and Intercourse, and "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s871"},"text":"section 871 of Title 26","children":[],"tail":", Internal Revenue Code, and enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2101"},"text":"section 2101 of this title","children":[],"tail":"] apply to articles entered on or after "},{"tag":"date","attrib":{"date":"1996-10-01"},"text":"October 1, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retroactive Application.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General rule","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding section 514 of the Tariff Act of 1930 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1514"},"text":"19 U.S.C. 1514","children":[],"tail":"] or any other provision of law and subject to subsection (c)—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any article that was entered—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after ","children":[{"tag":"date","attrib":{"date":"1995-07-31"},"text":"July 31, 1995","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"January 1, 1996","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"  to which duty-free treatment under title V of the Trade Act of 1974 [this subchapter] would have applied if the entry had been made on ","children":[{"tag":"date","attrib":{"date":"1995-07-31"},"text":"July 31, 1995","children":[],"tail":", shall be liquidated or reliquidated as free of duty, and the Secretary of the Treasury shall refund any duty paid with respect to such entry, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any article that was entered—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after ","children":[{"tag":"date","attrib":{"date":"1995-12-31"},"text":"December 31, 1995","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before ","children":[{"tag":"date","attrib":{"date":"1996-10-01"},"text":"October 1, 1996","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"  to which duty-free treatment under title V of the Trade Act of 1974 [this subchapter] (as amended by this subtitle) would have applied if the entry had been made on or after ","children":[{"tag":"date","attrib":{"date":"1996-10-01"},"text":"October 1, 1996","children":[],"tail":", shall be liquidated or reliquidated as free of duty, and the Secretary of the Treasury shall refund any duty paid with respect to such entry."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on refunds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No refund shall be made pursuant to this subsection before ","children":[{"tag":"date","attrib":{"date":"1996-10-01"},"text":"October 1, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Entry","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"As used in this subsection, the term ‘entry’ includes a withdrawal from warehouse for consumption.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requests","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Liquidation or reliquidation may be made under subsection (b) with respect to an entry only if a request therefor is filed with the Customs Service, within 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":"], that contains sufficient information to enable the Customs Service—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to locate the entry; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reconstruct the entry if it cannot be located.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
