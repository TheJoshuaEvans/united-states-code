{"tag":"section","attrib":{"id":"id05144b18-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s233"},"text":null,"children":[{"tag":"num","attrib":{"value":"233"},"text":"§ 233.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Departure from prescribed forms","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In cases where the forms of official documents, as prescribed by title 34 of the Revised Statutes, shall be substantially complied with and observed, according to the true intent thereof, no penalty or forfeiture shall be incurred by a deviation therefrom.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id05144b19-3a70-11f1-8ace-823fb135378d"},"text":"(R.S. § 2769.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05144b1a-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05144b1b-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id05144b1c-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Title 34 of the Revised Statutes, referred to in text, was in the original “this Title”, meaning title 34 of the Revised Statutes, consisting of R.S. §§ 2517 to 3129. For complete classification of R.S. §§ 2517 to 3129 to the Code, see Tables.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id05144b1d-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 2769 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1799-03-02/ch22/s111"},"text":"act Mar. 2, 1799, ch. 22, § 111","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/1/704"},"text":"1 Stat. 704","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
