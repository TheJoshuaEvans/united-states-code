{"tag":"section","attrib":{"id":"id0565510f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1599"},"text":null,"children":[{"tag":"num","attrib":{"value":"1599"},"text":"§ 1599.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Officers not to be interested in vessels or cargo","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No person employed under the authority of the United States, in the collection of duties on imports or tonnage, shall own, either in whole or in part, any vessel (other than a yacht or other pleasure boat), or act as agent, attorney, or consignee for the owner or owners of any vessel, or of any cargo or lading on board the same; nor shall any such person import, or be concerned directly or indirectly in the importation of, any merchandise for sale into the United States. Every person who violates this section shall be liable to a penalty of $500.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id05655110-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title IV, § 599, "},{"tag":"ref","attrib":{"href":"/us/stat/46/753"},"text":"46 Stat. 753","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/410/tII/s212"},"text":"Pub. L. 95–410, title II, § 212","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-03"},"text":"Oct. 3, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/904"},"text":"92 Stat. 904","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05655111-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05655112-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id05655113-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Identical provisions were contained in R.S. § 2638, which was superseded by ","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-09-21/ch356/tIV/s599"},"text":"act Sept. 21, 1922, ch. 356, title IV, § 599","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/984"},"text":"42 Stat. 984","children":[],"tail":", and repealed by section 642 thereof. Section 599 of the 1922 act was superseded by section 599 of act "},{"tag":"date","attrib":{"date":"1930-06-17"},"text":"June 17, 1930","children":[],"tail":", comprising this section, and repealed by section 651(a)(1) of the 1930 act."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id05655114-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/410"},"text":"Pub. L. 95–410","children":[],"tail":" excepted from the interest prohibition ownership of a yacht or other pleasure boat."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
