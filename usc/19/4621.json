{"tag":"section","attrib":{"id":"id065d459f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4621"},"text":null,"children":[{"tag":"num","attrib":{"value":"4621"},"text":"§ 4621.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of USMCA","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id065d45a0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4621/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of USMCA country status","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"During any period in which a country ceases to be a USMCA country, this Act (other than this subsection and title IX) and the amendments made by this Act shall cease to have effect with respect to that country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id065d45a1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4621/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of USMCA","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On the date on which the USMCA ceases to be in force with respect to the United States, this Act and the amendments made by this Act (other than this subsection and title IX) shall cease to have effect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id065d45a2-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113/tVI/s621"},"text":"Pub. L. 116–113, title VI, § 621","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-01-29"},"text":"Jan. 29, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/80"},"text":"134 Stat. 80","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id065d45a3-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id065d45a4-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id065d45a5-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113"},"text":"Pub. L. 116–113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-01-29"},"text":"Jan. 29, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/11"},"text":"134 Stat. 11","children":[],"tail":", known as the United States-Mexico-Canada Agreement Implementation Act. Title IX of the Act ("},{"tag":"ref","attrib":{"href":"/us/stat/134/98"},"text":"134 Stat. 98","children":[],"tail":") provides for USMCA supplemental appropriations and is not classified to the Code. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s4501"},"text":"section 4501 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
