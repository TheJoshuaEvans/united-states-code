{"tag":"section","attrib":{"id":"id0592a2e5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1920"},"text":null,"children":[{"tag":"num","attrib":{"value":"1920"},"text":"§ 1920.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suits by and against Secretary of Commerce","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In providing technical and financial assistance under sections 1913 and 1914 ","children":[{"tag":"ref","attrib":{"idref":"fn002068"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002068"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title, the Secretary of Commerce may sue and be sued in any court of record of a State having general jurisdiction or in any United States district court, and jurisdiction is conferred upon such district court to determine such controversies without regard to the amount in controversy; but no attachment, injunction, garnishment, or other similar process, mesne or final, shall be issued against him or his property. Nothing in this section shall be construed to except the activities pursuant to sections 1913 and 1914 "},{"tag":"ref","attrib":{"idref":"fn002068"},"text":"1","children":[],"tail":" of this title from the application of sections 517, 519, and 2679 of title 28."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0592a2e6-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/794/tIII/s320"},"text":"Pub. L. 87–794, title III, § 320","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-11"},"text":"Oct. 11, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/892"},"text":"76 Stat. 892","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0592a2e7-3a70-11f1-8ace-823fb