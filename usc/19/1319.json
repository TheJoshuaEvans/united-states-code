{"tag":"section","attrib":{"id":"id0524ecce-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1319"},"text":null,"children":[{"tag":"num","attrib":{"value":"1319"},"text":"§ 1319.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duty on coffee imported into Puerto Rico","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Legislature of Puerto Rico is empowered to impose tariff duties upon coffee imported into Puerto Rico, including coffee grown in a foreign country coming into Puerto Rico from the United States. Such duties shall be collected and accounted for as now provided by law in the case of duties collected in Puerto Rico.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0524eccf-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title III, § 319, "},{"tag":"ref","attrib":{"href":"/us/stat/46/696"},"text":"46 Stat. 696","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1932-05-17/ch190"},"text":"May 17, 1932, ch. 190","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/47/158"},"text":"47 Stat. 158","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0524ecd0-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0524ecd1-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id0524ecd2-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Puerto Rico” substituted in text for “Porto Rico” pursuant to act ","children":[{"tag":"date","attrib":{"date":"1932-05-17"},"text":"May 17, 1932","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s731a"},"text":"section 731a of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0524ecd3-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Actions Under Caribbean Basin Economic Recovery Program Not To Affect Puerto Rican Duties on Imported Coffee","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/67/tII/s214/e"},"text":"Pub. L. 98–67, title II, § 214(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-05"},"text":"Aug. 5, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/393"},"text":"97 Stat. 393","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/67/tII/s214/e"},"text":"“No action pursuant to this title [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2701"},"text":"19 U.S.C. 2701","children":[],"tail":" et seq.] may affect any tariff duty imposed by the Legislature of Puerto Rico pursuant to section 319 of the Tariff Act of 1930 ("},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1319"},"text":"19 U.S.C. 1319","children":[],"tail":") on coffee imported into Puerto Rico.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
