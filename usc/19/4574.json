{"tag":"section","attrib":{"id":"id065afb92-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4574"},"text":null,"children":[{"tag":"num","attrib":{"value":"4574"},"text":"§ 4574.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action by President with respect to affirmative determination","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id065afb93-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4574/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than the date that is 30 days after the date on which the President receives a report of the Commission in which the Commission’s determination under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4572"},"text":"section 4572 of this title","children":[],"tail":" is affirmative or which contains a determination that the President may treat as affirmative in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1330/d/1"},"text":"section 1330(d)(1) of this title","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id065afb94-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4574/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President shall, subject to subsection (b), issue an order to the Secretary of Transportation specifying the relief to be provided, consistent with subsection (c), and directing the relief to be carried out; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065afb95-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4574/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Transportation shall carry out such relief.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id065afb96-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4574/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President is not required to provide relief under this section if the President determines that provision of such relief—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id065afb97-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4574/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not in the national economic interest of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065afb98-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4574/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would cause serious harm to the national security of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id065afb99-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4574/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nature of relief","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id065afb9a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4574/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The relief the President is authorized to provide under this subsection is as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id065afb9b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4574/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id065afb9c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4574/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to a determination relating to an investigation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4572/a/1"},"text":"section 4572(a)(1) of this title","children":[],"tail":", the denial or imposition of limitations on a request for a new grant of authority by the persons of Mexico that are the subject of the investigation."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id065afb9d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4574/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to a determination relating to an investigation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4572/a/1"},"text":"section 4572(a)(1) of this title","children":[],"tail":", the revocation of, or restrictions on, grants of authority issued to the persons of Mexico that are the subject of the investigation since the date of the petition, request, or resolution."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id065afb9e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4574/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to a determination relating to an investigation under section 4572(a)(2) or (3) of this title, the revocation or imposition of limitations on an existing grant of authority by the persons of Mexico that are the subject of the investigation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id065afb9f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4574/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to a determination relating to an investigation under section 4572(a)(1), (2), or (3) of this title, a cap on the number of grants of authority issued to persons of Mexico annually.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065afba0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4574/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline for relief","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 15 days after the date on which the President determines the relief to be provided under this subsection, the President shall direct the Secretary of Transportation to carry out the relief.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id065afba1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4574/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of relief","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id065afba2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4574/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), any relief that the President provides under this section may not be in effect for more than 2 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065afba3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4574/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id065afba4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4574/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraph (C), the President, after receiving a determination from the Commission under subparagraph (B) that is affirmative, or which contains a determination that the President may treat as affirmative in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1330/d/1"},"text":"section 1330(d)(1) of this title","children":[],"tail":", may extend the effective period of relief provided under this section by up to an additional 4 years, if the President determines that the provision of the relief continues to be necessary to remedy or prevent material harm."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id065afba5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4574/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action by Commission","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id065afba6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4574/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon request of the President, or upon the filing by an interested party described in subparagraph (A), (B), or (C) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4571/8"},"text":"section 4571(8) of this title","children":[],"tail":" which is representative of a United States long-haul trucking services industry that is filed with the Commission not earlier than the date that is 270 days, and not later than the date that is 240 days, before the date on which any action taken under this section is to terminate, the Commission shall conduct an investigation to determine whether action under this section continues to be necessary to remedy or prevent material harm."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id065afba7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4574/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice and hearing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id065afba8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4574/d/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish notice of the commencement of an investigation under clause (i) in the Federal Register; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id065afba9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4574/d/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within a reasonable time thereafter, hold a public hearing at which the Commission shall afford interested parties an opportunity to be present, to present evidence, and to respond to the presentations of other parties and consumers, and otherwise be heard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id065afbaa-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4574/d/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than the date that is 60 days before relief provided under subsection (a) is to terminate, or such other date as determined by the President, the Commission shall submit to the President a report on its investigation and determination under this subparagraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id065afbab-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4574/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of relief","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any relief provided under this section, including any extension thereof, may not, in the aggregate, be in effect for more than 6 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id065afbac-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4574/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id065afbad-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4574/d/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in clause (ii), the Commission may not conduct an investigation under subparagraph (B)(i) if—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id065afbae-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4574/d/2/D/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the subject matter of the investigation is the same as the subject matter of a previous investigation conducted under subparagraph (B)(i); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id065afbaf-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4574/d/2/D/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" less than 1 year has elapsed since the Commission made its report to the President of the results of such previous investigation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id065afbb0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4574/d/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Clause (i) shall not apply with respect to an investigation if the Commission determines good cause exists to conduct the investigation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id065afbb1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4574/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission and the Secretary of Transportation are authorized to promulgate such rules and regulations as may be necessary to carry out this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id065afbb2-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113/tIII/s324"},"text":"Pub. L. 116–113, title III, § 324","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-01-29"},"text":"Jan. 29, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/58"},"text":"134 Stat. 58","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id065afbb3-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id065afbb4-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id065afbb5-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This part, referred to in subsec. (e), was in the original “this subtitle”, meaning subtitle C (§§ 321–327) of title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113"},"text":"Pub. L. 116–113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-01-29"},"text":"Jan. 29, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/54"},"text":"134 Stat. 54","children":[],"tail":", which is classified principally to this subchapter. For complete classification of subtitle C to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id065afbb6-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id065afbb7-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Proc. No. 10053, par. (13), ","children":[{"tag":"date","attrib":{"date":"2020-06-29"},"text":"June 29, 2020","children":[],"tail":", 85 F.R. 39826, authorized the United States Trade Representative, after consultation with the Secretary of Transportation, to exercise the authority of the President under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
