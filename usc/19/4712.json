{"tag":"section","attrib":{"id":"id065fb691-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4712"},"text":null,"children":[{"tag":"num","attrib":{"value":"4712"},"text":"§ 4712.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id065fb692-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4712/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Interagency Environment Committee shall carry out an assessment of the environmental laws and policies of the USMCA countries—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id065fb693-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4712/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to determine if such laws and policies are sufficient to implement their environmental obligations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065fb694-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4712/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to identify any gaps between such laws and policies and their environmental obligations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id065fb695-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4712/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matters to be included","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The assessment required by subsection (a) shall identify the environmental laws and policies of the USMCA countries with respect to which enhanced cooperation, including the provision of technical assistance and capacity building assistance, monitoring actions, and enforcement actions, if appropriate, should be carried out on an enhanced and continuing basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id065fb696-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4712/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after the date on which the Interagency Environment Committee is established, or the date on which the USMCA enters into force, whichever occurs earlier, the Interagency Environment Committee shall submit a report that contains the assessment required by subsection (a) to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id065fb697-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4712/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriate congressional committees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065fb698-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4712/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Trade and Environment Policy Advisory Committee (or successor advisory committee) established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2155/c/1"},"text":"section 2155(c)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id065fb699-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4712/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Update","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Interagency Environment Committee shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id065fb69a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4712/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" update the assessment required by subsection (a) at the appropriate time prior to submission of the report required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4716/a"},"text":"section 4716(a) of this title","children":[],"tail":" that is to be submitted in the fifth year after the USMCA enters into force; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065fb69b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4712/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit the updated assessment to the Trade Representative for inclusion in such fifth annual report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id065fb69c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4712/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Interagency Environment Committee shall consult on a regular basis with the USMCA countries—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id065fb69d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4712/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in carrying out the assessment required by subsection (a) and the update to the assessment required by subsection (d); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065fb69e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4712/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in preparing the report required by subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id065fb69f-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113/tVIII/s812"},"text":"Pub. L. 116–113, title VIII, § 812","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-01-29"},"text":"Jan. 29, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/91"},"text":"134 Stat. 91","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
