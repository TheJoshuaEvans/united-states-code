{"tag":"section","attrib":{"id":"id05596a58-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1553–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1553–1"},"text":"§ 1553–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on in-bond cargo","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05596a59-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1553–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2007-06-30"},"text":"June 30, 2007","children":[],"tail":", the Commissioner shall submit a report to the Committee on Commerce, Science, and Transportation of the Senate, the Committee on Finance of the Senate, the Committee on Homeland Security and Governmental Affairs of the Senate, the Committee on Homeland Security of the House of Representatives, the Committee on Transportation and Infrastructure of the House of Representatives, and the Committee on Ways and Means of the House of Representatives that includes—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id05596a5a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1553–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan for closing in-bond entries at the port of arrival;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05596a5b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1553–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the personnel required to ensure 100 percent reconciliation of in-bond entries between the port of arrival and the port of destination or exportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05596a5c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1553–1/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the status of investigations of overdue in-bond shipments and an evaluation of the resources required to ensure adequate investigation of overdue in-bond shipments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05596a5d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1553–1/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan for tracking in-bond cargo within the Automated Commercial Environment (ACE);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05596a5e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1553–1/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of whether any particular technologies should be required in the transport of in-bond cargo;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05596a5f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1553–1/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of whether ports of arrival should require any additional information regarding shipments of in-bond cargo;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05596a60-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1553–1/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of the criteria for targeting and examining in-bond cargo; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05596a61-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1553–1/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the feasibility of reducing the transit time for in-bond shipments, including an assessment of the impact of such a change on domestic and international trade.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05596a62-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1553–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “Commissioner” means the Commissioner responsible for the United States Customs and Border Protection in the Department of Homeland Security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05596a63-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title IV, § 553A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/347/tIV/s406"},"text":"Pub. L. 109–347, title IV, § 406","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-13"},"text":"Oct. 13, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1931"},"text":"120 Stat. 1931","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05596a64-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05596a65-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id05596a66-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 553A of act ","children":[{"tag":"date","attrib":{"date":"1930-06-17"},"text":"June 17, 1930","children":[],"tail":", is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1553a"},"text":"section 1553a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
