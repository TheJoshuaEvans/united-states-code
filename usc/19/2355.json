{"tag":"section","attrib":{"id":"id05d30675-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2355"},"text":null,"children":[{"tag":"num","attrib":{"value":"2355"},"text":"§ 2355.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance to industries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05d30676-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2355/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide technical assistance, on such terms and conditions as the Secretary deems appropriate, for the establishment of industrywide programs for new product development, new process development, export development, or other uses consistent with the purposes of this part. Such technical assistance may be provided through existing agencies, private individuals, firms, universities and institutions, and by grants, contracts, or cooperative agreements to associations, unions, or other nonprofit industry organizations in which a substantial number of firms or workers have been certified as eligible to apply for adjustment assistance under section 2273 or 2341 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05d30677-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2355/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Expenditures for technical assistance under this section may be up to $10,000,000 annually per industry and shall be made under such terms and conditions as the Secretary deems appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05d30678-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/tII/s265"},"text":"Pub. L. 93–618, title II, § 265","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXXV/s2527"},"text":"Pub. L. 97–35, title XXV, § 2527","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/893"},"text":"95 Stat. 893","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dB/tVI/s2673"},"text":"Pub. L. 98–369, div. B, title VI, § 2673","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1172"},"text":"98 Stat. 1172","children":[],"tail":"; temporarily renumbered § 262, "},{"tag":"ref","attrib":{"href":"/us/pl/111/5/dB/tI/s1864/a/2"},"text":"Pub. L. 111–5, div. B, title I, § 1864(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/397"},"text":"123 Stat. 397","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/112/40/tII/s201/b"},"text":"Pub. L. 112–40, title II, § 201(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2011-10-21"},"text":"Oct. 21, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/403"},"text":"125 Stat. 403","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/114/27/tIV/s402/b"},"text":"Pub. L. 114–27, title IV, § 402(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2015-06-29"},"text":"June 29, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/374"},"text":"129 Stat. 374","children":[],"tail":".)"}],"tail":"\