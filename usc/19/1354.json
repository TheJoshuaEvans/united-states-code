{"tag":"section","attrib":{"id":"id0530d39d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1354"},"text":null,"children":[{"tag":"num","attrib":{"value":"1354"},"text":"§ 1354.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of intention to negotiate agreement; opportunity to be heard; President to seek information and advice","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Before any foreign trade agreement is concluded with any foreign government or instrumentality thereof under the provisions of this part, reasonable public notice of the intention to negotiate an agreement with such government or instrumentality shall be given in order that any interested person may have an opportunity to present his views to the President, or to such agency as the President may designate, under such rules and regulations as the President may prescribe; and before concluding such agreement the President shall request the International Trade Commission to make the investigation and report provided for by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1360"},"text":"section 1360 of this title","children":[],"tail":", and shall seek information and advice with respect to such agreement from the Departments of State, Agriculture, Commerce, and Defense, and from such other sources as he may deem appropriate."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0530d39e-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-12/ch474/s4"},"text":"June 12, 1934, ch. 474, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/945"},"text":"48 Stat. 945","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1945-07-05/ch269/s4"},"text":"July 5, 1945, ch. 269, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/59/411"},"text":"59 Stat. 411","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-08-10/ch412/s12/a"},"text":"Aug. 10, 1949, ch. 412, § 12(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/591"},"text":"63 Stat. 591","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-09-26/ch585/s5"},"text":"Sept. 26, 1949, ch. 585, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/698"},"text":"63 Stat. 698","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1951-06-16/ch141/s3/c"},"text":"June 16, 1951, ch. 141, § 3(c)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/65/73"},"text":"65 Stat. 73","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/618/tI/s171/b"},"text":"Pub. L. 93–618, title I, § 171(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2009"},"text":"88 Stat. 2009","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0530d39f-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0530d3a0-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0530d3a1-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1975—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618"},"text":"Pub. L. 93–618","children":[],"tail":" substituted “United States International Trade Commission” for “United States Tariff Commission”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1951—Act ","children":[{"tag":"date","attrib":{"date":"1951-06-16"},"text":"June 16, 1951","children":[],"tail":", provided that the President request the Tariff Commission to make the investigation and report."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1949—Act ","children":[{"tag":"date","attrib":{"date":"1949-09-26"},"text":"Sept. 26, 1949","children":[],"tail":", changed the Tariff Commission’s functions under these sections from investigatory to advisory functions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1945—Act ","children":[{"tag":"date","attrib":{"date":"1945-07-05"},"text":"July 5, 1945","children":[],"tail":", inserted “War, Navy,” after “Departments of State”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0530d3a2-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id0530d3a3-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"National Military Establishment changed to Department of Defense by act ","children":[{"tag":"date","attrib":{"date":"1949-08-10"},"text":"Aug. 10, 1949","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"repeals","id":"id0530d3a4-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeals","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1949-09-26"},"text":"Sept. 26, 1949","children":[],"tail":", § 2, repealed "},{"tag":"ref","attrib":{"href":"/us/act/1948-06-26/ch678/s3/c"},"text":"act June 26, 1948, ch. 678, § 3(c)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/1054"},"text":"62 Stat. 1054","children":[],"tail":", formerly cited as a credit to this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
