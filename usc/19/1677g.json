{"tag":"section","attrib":{"id":"id0589058e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677g"},"text":null,"children":[{"tag":"num","attrib":{"value":"1677g"},"text":"§ 1677g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest on certain overpayments and underpayments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0589058f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Interest shall be payable on overpayments and underpayments of amounts deposited on merchandise entered, or withdrawn from warehouse, for consumption on and after—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05890590-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677g/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of publication of a countervailing or antidumping duty order under this subtitle or section 1303 ","children":[{"tag":"ref","attrib":{"idref":"fn002055"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002055"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title, or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05890591-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677g/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of a finding under the Antidumping Act, 1921.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05890592-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The rate of interest payable under subsection (a) for any period of time is the rate of interest established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6621"},"text":"section 6621 of title 26","children":[],"tail":" for such period."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05890593-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title VII, § 778, as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/39/tI/s101"},"text":"Pub. L. 96–39, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/188"},"text":"93 Stat. 188","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/573/tVI/s621"},"text":"Pub. L. 98–573, title VI, § 621","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3039"},"text":"98 Stat. 3039","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05890594-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05890595-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id05890596-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1303"},"text":"Section 1303 of this title","children":[],"tail":", referred to in subsec. (a)(1), is defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1677/26"},"text":"section 1677(26) of this title","children":[],"tail":" to mean section 1330 as in effect on the day before "},{"tag":"date","attrib":{"date":"1995-01-01"},"text":"Jan. 1, 1995","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Antidumping Act, 1921, referred to in subsec. (a)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1921-05-27/ch14/tII"},"text":"act May 27, 1921, ch. 14, title II","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/11"},"text":"42 Stat. 11","children":[],"tail":", which was classified generally to sections 160 to 171 of this title, and was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/96/39/tI/s106/a"},"text":"Pub. L. 96–39, title I, § 106(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/193"},"text":"93 Stat. 193","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id05890597-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" substituted “Internal Revenue Code of 1986” for “Internal Revenue Code of 1954”, which for purposes of codification was translated as “title 26” thus requiring no change in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/573"},"text":"Pub. L. 98–573","children":[],"tail":" amended subsec. (a) generally, substituting provisions making interest payable on and after the date of publication of a countervailing or antidumping duty order under this subtitle or "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1303"},"text":"section 1303 of this title","children":[],"tail":" or the date of a finding under the Antidumping Act, 1921 for provisions making interest payable on and after the date on which notice of an affirmative determination by the Commission under section 1671d(b) or 1673d(b) of this title with respect to such merchandise was published."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/573"},"text":"Pub. L. 98–573","children":[],"tail":" amended subsec. (b) generally, substituting provisions that the rate of interest payable under subsec. (a) for any period of time is the rate of interest established under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6621"},"text":"section 6621 of title 26","children":[],"tail":" for such period for provision that the rate at which such interest was payable would be 8 percent per annum or, if higher, the rate in effect under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6621"},"text":"section 6621 of title 26","children":[],"tail":" on the date on which the rate or amount of the duty was finally determined."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id05890598-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id05890599-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/573"},"text":"Pub. L. 98–573","children":[],"tail":" applicable with respect to merchandise that is unliquidated on or after "},{"tag":"date","attrib":{"date":"1984-11-04"},"text":"Nov. 4, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/573/s626/b/4"},"text":"section 626(b)(4) of Pub. L. 98–573","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1671"},"text":"section 1671 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
