{"tag":"section","attrib":{"id":"id064f1582-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4348"},"text":null,"children":[{"tag":"num","attrib":{"value":"4348"},"text":"§ 4348.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International cooperation and information sharing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id064f1583-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4348/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Homeland Security shall coordinate with the competent law enforcement and customs authorities of foreign countries, including by sharing information relevant to enforcement actions, to enhance the efforts of the United States and such authorities to enforce intellectual property rights.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id064f1584-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4348/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Homeland Security shall provide technical assistance to competent law enforcement and customs authorities of foreign countries to enhance the ability of such authorities to enforce intellectual property rights.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id064f1585-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4348/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency collaboration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commissioner and the Director of U.S. Immigration and Customs Enforcement shall lead interagency efforts to collaborate with law enforcement and customs authorities of foreign countries to enforce intellectual property rights.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id064f1586-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/125/tIII/s309"},"text":"Pub. L. 114–125, title III, § 309","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-24"},"text":"Feb. 24, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/153"},"text":"130 Stat. 153","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
