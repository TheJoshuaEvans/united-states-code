{"tag":"section","attrib":{"id":"id05596a2b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1528"},"text":null,"children":[{"tag":"num","attrib":{"value":"1528"},"text":"§ 1528.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxes not to be construed as duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No tax or other charge imposed by or pursuant to any law of the United States shall be construed to be a customs duty for the purpose of any statute relating to the customs revenue, unless the law imposing such tax or charge designates it as a customs duty or contains a provision to the effect that it shall be treated as a duty imposed under the customs laws. Nothing in this section shall be construed to limit or restrict the jurisdiction of the United States Court of International Trade or the United States Court of Appeals for the Federal Circuit.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id05596a2c-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title IV, § 528, as added "},{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch679/s20"},"text":"June 25, 1938, ch. 679, § 20","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/1087"},"text":"52 Stat. 1087","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/417/tVI/s601/8"},"text":"Pub. L. 96–417, title VI, § 601(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-10"},"text":"Oct. 10, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1744"},"text":"94 Stat. 1744","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/164/tI/s163/a/3"},"text":"Pub. L. 97–164, title I, § 163(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-04-02"},"text":"Apr. 2, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/49"},"text":"96 Stat. 49","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05596a2d-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05596a2e-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id05596a2f-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/164"},"text":"Pub. L. 97–164","children":[],"tail":" substituted “Court of Appeals for the Federal Circuit” for “Court of Customs and Patent Appeals”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/417"},"text":"Pub. L. 96–417","children":[],"tail":" redesignated the United States Customs Court as the United States Court of International Trade."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id05596a30-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id05596a31-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1982 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/164"},"text":"Pub. L. 97–164","children":[],"tail":" effective "},{"tag":"date","