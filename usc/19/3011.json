{"tag":"section","attrib":{"id":"id060513e3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3011"},"text":null,"children":[{"tag":"num","attrib":{"value":"3011"},"text":"§ 3011.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transition to Harmonized Tariff Schedule","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id060513e4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3011/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing executive actions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id060513e5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3011/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The appropriate officers of the United States Government shall take whatever actions are necessary to conform, to the fullest extent practicable, with the tariff classification system of the Harmonized Tariff Schedule all proclamations, regulations, rulings, notices, findings, determinations, orders, recommendations, and other written actions that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id060513e6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3011/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are in effect on the day before ","children":[{"tag":"date","attrib":{"date":"1989-01-01"},"text":"January 1, 1989","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id060513e7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3011/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contain references to the tariff classification of articles under the old Schedules.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060513e8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3011/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Neither the repeal of the old Schedules, nor the failure of any officer of the United States Government to make the conforming changes required under paragraph (1), shall affect to any extent the validity or effect of the proclamation, regulation, ruling, notice, finding, determination, order, recommendation, or other action referred to in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id060513e9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3011/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Generalized System of Preferences conversion","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id060513ea-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3011/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The review of the proposed conversion of the Generalized System of Preferences program to the Convention tariff nomenclature, initiated by the Office of the United States Trade Representative by notice published in the Federal Register on ","children":[{"tag":"date","attrib":{"date":"1986-12-08"},"text":"December 8, 1986","children":[],"tail":" (at page 44,163 of volume 51 thereof), shall be treated as satisfying the requirements of sections 2463(a) and 2464(c)(3) of this title (as in effect on "},{"tag":"date","attrib":{"date":"1995-07-31"},"text":"July 31, 1995","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060513eb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3011/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In applying ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2464/c/1"},"text":"section 2464(c)(1) of this title","children":[],"tail":" (as in effect on "},{"tag":"date","attrib":{"date":"1995-07-31"},"text":"July 31, 1995","children":[],"tail":") for calendar year 1989, the reference in such section to July 1 shall be treated as a reference to September 1."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id060513ec-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3011/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Import restrictions under Agricultural Adjustment Act","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id060513ed-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3011/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Whenever the President determines that the conversion of an import restriction proclaimed under section 22 of the Agricultural Adjustment Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s624"},"text":"7 U.S.C. 624","children":[],"tail":") from part 3 of the Appendix to the old Schedules to subchapter IV of chapter 99 of the Harmonized Tariff Schedule results in—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id060513ee-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3011/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an article that was previously subject to the restriction being excluded from the restriction; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id060513ef-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3011/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an article not previously subject to the restriction being included within the restriction;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the President may proclaim changes in subchapter IV of chapter 99 of the Harmonized Tariff Schedule to conform that subchapter to the fullest extent possible to part 3 of the Appendix to the old Schedules.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060513f0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3011/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Whenever the President determines that the conversion from headnote 2 of subpart A of part 10 of schedule 1 of the old Schedules to Additional U.S. Note 2, chapter 17, of the Harmonized Tariff Schedule results in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id060513f1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3011/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an article that was previously covered by such headnote being excluded from coverage; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id060513f2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3011/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an article not previously covered by such headnote being included in coverage;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the President may proclaim changes in Additional U.S. Note 2, chapter 17 of the Harmonized Tariff Schedule to conform that note to the fullest extent possible to headnote 2 of subpart A of part 10 of schedule 1 of the old Schedules.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060513f3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3011/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No change to the Harmonized Tariff Schedule may be proclaimed under paragraph (1) or (2) after ","children":[{"tag":"date","attrib":{"date":"1990-06-30"},"text":"June 30, 1990","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id060513f4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3011/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain protests and petitions under customs law","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id060513f5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3011/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id060513f6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3011/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" This chapter may not be considered to divest the courts of jurisdiction over—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id060513f7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3011/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any protest filed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1514"},"text":"section 1514 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id060513f8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3011/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any petition by an American manufacturer, producer, or wholesaler under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1516"},"text":"section 1516 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"covering articles entered before ","children":[{"tag":"date","attrib":{"date":"1989-01-01"},"text":"January 1, 1989","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id060513f9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3011/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this chapter shall affect the jurisdiction of the courts with respect to articles entered after ","children":[{"tag":"date","attrib":{"date":"1989-01-01"},"text":"January 1, 1989","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060513fa-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3011/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id060513fb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3011/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If any protest or petition referred to in paragraph (1)(A) is sustained in whole or in part by a final judicial decision, the entries subject to that protest or petition and made before ","children":[{"tag":"date","attrib":{"date":"1989-01-01"},"text":"January 1, 1989","children":[],"tail":", shall be liquidated or reliquidated, as appropriate, in accordance with such final judicial decision under the old Schedules."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id060513fc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3011/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" At the earliest practicable date after ","children":[{"tag":"date","attrib":{"date":"1989-01-01"},"text":"January 1, 1989","children":[],"tail":", the Commission shall initiate an investigation under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1332"},"text":"section 1332 of this title","children":[],"tail":" of those final judicial decisions referred to in subparagraph (A) that—"}],"tail":null},{"tag":"clause","attrib":{"id":"id060513fd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3011/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are published during the 2-year period beginning on ","children":[{"tag":"date","attrib":{"date":"1988-02-01"},"text":"February 1, 1988","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id060513fe-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3011/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would have affected tariff treatment if they had been published during the period of the conversion of the old Schedules into the format of the Convention.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"No later than ","children":[{"tag":"date","attrib":{"date":"1990-09-01"},"text":"September 1, 1990","children":[],"tail":", the Commission shall report the results of the investigation to the President, the Committee on Ways and Means, and the Committee on Finance, and shall recommend those changes to the Harmonized Tariff Schedule that the Commission would have recommended if the final decisions concerned had been made before the conversion into the format of the Convention occurred."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060513ff-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3011/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The President shall review all changes recommended by the Commission under paragraph (2)(B) and shall, as soon as practicable, proclaim such of those changes, if any, which he decides are necessary or appropriate to conform such Schedule to the final judicial decisions. Any such change shall be effective with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id06051400-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3011/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entries made on or after the date of such proclamation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06051401-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3011/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entries made on or after ","children":[{"tag":"date","attrib":{"date":"1989-01-01"},"text":"January 1, 1989","children":[],"tail":", if, notwithstanding "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1514"},"text":"section 1514 of this title","children":[],"tail":", application for liquidation or reliquidation thereof is made by the importer to the customs officer concerned within 180 days after the effective date of such proclamation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06051402-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3011/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If any protest or petition referred to in paragraph (1)(A) is not sustained in whole or in part by a final judicial decision, the entries subject to that petition or protest and made before ","children":[{"tag":"date","attrib":{"date":"1989-01-01"},"text":"January 1, 1989","children":[],"tail":", shall be liquidated or reliquidated, as appropriate, in accordance with the final judicial decision under the old Schedules."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id06051403-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/tI/s1211"},"text":"Pub. L. 100–418, title I, § 1211","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1153"},"text":"102 Stat. 1153","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1954/a/1"},"text":"Pub. L. 104–188, title I, § 1954(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1927"},"text":"110 Stat. 1927","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id06051404-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id06051405-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id06051406-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Harmonized Tariff Schedule, referred to in subsecs. (a)(1), (c), and (d)(2)(B), (3), is not set out in the Code. See Publication of Harmonized Tariff Schedule note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1202"},"text":"section 1202 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (d)(1), was in the original “this subtitle”, meaning subtitle B (§§ 1201–1217) of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418"},"text":"Pub. L. 100–418","children":[],"tail":", which is classified principally to this chapter. For complete classification of this subtitle to the Code, see References in Text note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3001"},"text":"section 3001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id06051407-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188/s1954/a/1"},"text":"Pub. L. 104–188, § 1954(a)(1)","children":[],"tail":", inserted “(as in effect on "},{"tag":"date","attrib":{"date":"1995-07-31"},"text":"July 31, 1995","children":[],"tail":")” after “of this title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188/s1954/a/2"},"text":"Pub. L. 104–188, § 1954(a)(2)","children":[],"tail":", inserted “(as in effect on "},{"tag":"date","attrib":{"date":"1995-07-31"},"text":"July 31, 1995","children":[],"tail":")” after “of this title”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id06051408-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id06051409-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188"},"text":"Pub. L. 104–188","children":[],"tail":" applicable to articles entered on or after "},{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", with provisions relating to retroactive application, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/s1953"},"text":"section 1953 of Pub. L. 104–188","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2461"},"text":"section 2461 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0605140a-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1989-01-01"},"text":"Jan. 1, 1989","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/s1217/b/2"},"text":"section 1217(b)(2) of Pub. L. 100–418","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
