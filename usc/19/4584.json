{"tag":"section","attrib":{"id":"id065afc23-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4584"},"text":null,"children":[{"tag":"num","attrib":{"value":"4584"},"text":"§ 4584.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requests for review of determinations by competent investigating authorities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id065afc24-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4584/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id065afc25-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4584/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competent investigating authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “competent investigating authority” means the competent investigating authority, as defined in article 10.8, of a USMCA country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065afc26-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4584/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “United States Secretary” means that officer of the United States referred to in article 10.16.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id065afc27-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4584/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requests for review by United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a final determination of a competent investigating authority, requests by the United States for binational panel review of such determination under article 10.12 shall be made by the United States Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id065afc28-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4584/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requests for review by person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a final determination of a competent investigating authority, a person, within the meaning of paragraph 5 of article 10.12, may request a binational panel review of such determination by filing such a request with the United States Secretary within the time limit provided for in paragraph 4 of article 10.12. The receipt of such request by the United States Secretary shall be deemed to be a request for binational panel review within the meaning of article 10.12. The request for such panel review shall be without prejudice to any challenge before a binational panel of the basis for a particular request for review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id065afc29-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4584/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service of request for review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever binational panel review of a final determination made by a competent investigating authority is requested under this section, the United States Secretary shall serve a copy of the request on all persons who would otherwise be entitled under the law of the importing country to commence proceedings for judicial review of the determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id065afc2a-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113/tIV/s414"},"text":"Pub. L. 116–113, title IV, § 414","children":[],"tail":", formerly "},{"tag":"ref","attrib":{"href":"/us/pl/103/182/tIV/s404"},"text":"Pub. L. 103–182, title IV, § 404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-08"},"text":"Dec. 8, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2137"},"text":"107 Stat. 2137","children":[],"tail":"; renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/116/113/s414"},"text":"§ 414 of Pub. L. 116–113","children":[],"tail":" and amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/113/tV/s504/e"},"text":"Pub. L. 116–113, title V, § 504(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-01-29"},"text":"Jan. 29, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/75"},"text":"134 Stat. 75","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id065afc2b-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id065afc2c-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id065afc2d-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3434"},"text":"section 3434 of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/116/113"},"text":"Pub. L. 116–113","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id065afc2e-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113/s504/e/3/A"},"text":"Pub. L. 116–113, § 504(e)(3)(A)","children":[],"tail":", struck out “of NAFTA countries” after “authorities” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113/s504/e/3/B/i"},"text":"Pub. L. 116–113, § 504(e)(3)(B)(i)","children":[],"tail":", substituted “article 10.8, of a USMCA country.” for “article 1911, of a NAFTA country.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113/s504/e/3/B/ii"},"text":"Pub. L. 116–113, § 504(e)(3)(B)(ii)","children":[],"tail":", substituted “article 10.16” for “article 1908”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113/s504/e/3/C"},"text":"Pub. L. 116–113, § 504(e)(3)(C)","children":[],"tail":", substituted “article 10.12” for “article 1904”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113/s504/e/3/D"},"text":"Pub. L. 116–113, § 504(e)(3)(D)","children":[],"tail":", substituted “article 10.12” for “article 1904” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id065afc2f-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id065afc30-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2020 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Transfer to and amendment of this section by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113"},"text":"Pub. L. 116–113","children":[],"tail":" effective on the date on which the USMCA enters into force ("},{"tag":"date","attrib":{"date":"2020-07-01"},"text":"July 1, 2020","children":[],"tail":"), but not applicable to certain determinations under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1516a"},"text":"section 1516a of this title","children":[],"tail":" or binational panel reviews under NAFTA, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/113/s504/k"},"text":"section 504(k) of Pub. L. 116–113","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s4581"},"text":"section 4581 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
