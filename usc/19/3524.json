{"tag":"section","attrib":{"id":"id0610fa33-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3524"},"text":null,"children":[{"tag":"num","attrib":{"value":"3524"},"text":"§ 3524.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation and layover requirements for, and effective date of, proclaimed actions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"If a provision of this Act provides that the implementation of an action by the President by proclamation is subject to the consultation and layover requirements of this section, such action may be proclaimed only if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0610fa34-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3524/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the President has obtained advice regarding the proposed action from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0610fa35-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3524/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriate advisory committees established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2155"},"text":"section 2155 of this title","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0610fa36-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3524/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the International Trade Commission;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0610fa37-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3524/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the President has submitted a report to the Committee on Ways and Means of the House of Representatives and the Committee on Finance of the Senate that sets forth—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0610fa38-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3524/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the action proposed to be proclaimed and the reasons for such actions, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0610fa39-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3524/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the advice obtained under paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0610fa3a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3524/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a period of 60 calendar days, beginning with the first day on which the President has met the requirements of paragraphs (1) and (2) with respect to such action, has expired; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0610fa3b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3524/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President has consulted with such committees regarding the proposed action during the period referred to in paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0610fa3c-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/tI/s115"},"text":"Pub. L. 103–465, title I, § 115","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4828"},"text":"108 Stat. 4828","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0610fa3d-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0610fa3e-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0610fa3f-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465"},"text":"Pub. L. 103–465","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4809"},"text":"108 Stat. 4809","children":[],"tail":", known as the Uruguay Round Agreements Act. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3501"},"text":"section 3501 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id0610fa40-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0610fa41-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Authority","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of President under this section delegated to the United States Trade Representative by par. (4) of Proc. No. 6969, ","children":[{"tag":"date","attrib":{"date":"1997-01-27"},"text":"Jan. 27, 1997","children":[],"tail":", 62 F.R. 4417."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Authority of President to perform certain functions in order to fulfill consultation and layover requirements set forth in this section delegated to United States Trade Representative by Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"1995-09-29"},"text":"Sept. 29, 1995","children":[],"tail":", 60 F.R. 52061, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3311"},"text":"section 3311 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
