{"tag":"section","attrib":{"id":"id060513ac-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3006"},"text":null,"children":[{"tag":"num","attrib":{"value":"3006"},"text":"§ 3006.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presidential action on Commission recommendations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id060513ad-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3006/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President may proclaim modifications, based on the recommendations by the Commission under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3005"},"text":"section 3005 of this title","children":[],"tail":", to the Harmonized Tariff Schedule if the President determines that the modifications—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id060513ae-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3006/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are in conformity with United States obligations under the Convention; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060513af-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3006/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" do not run counter to the national economic interest of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id060513b0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3006/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lay-over period","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id060513b1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3006/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President may proclaim a modification under subsection (a) only after the expiration of the 60-day period beginning on the date on which the President submits a report to the Committee on Ways and Means of the House of Representatives and the Committee on Finance of the Senate that sets forth the proposed modification and the reasons therefor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060513b2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3006/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The 60-day period referred to in paragraph (1) shall be computed by excluding—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id060513b3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3006/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the days on which either House is not in session because of an adjournment of more than 3 days to a day certain or an adjournment of the Congress sine die; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id060513b4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3006/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any Saturday and Sunday, not excluded under subparagraph (A), when either House is not in session.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id060513b5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3006/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date of modifications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Modifications proclaimed by the President under subsection (a) may not take effect before the 30th day after the date on which the text of the proclamation is published in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id060513b6-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/tI/s1206"},"text":"Pub. L. 100–418, title I, § 1206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1151"},"text":"102 Stat. 1151","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/432/dD/tIII/s3012"},"text":"Pub. L. 109–432, div. D, title III, § 3012","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3177"},"text":"120 Stat. 3177","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id060513b7-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id060513b8-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id060513b9-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Harmonized Tariff Schedule, referred to in subsec. (a), is not set out in the Code. See Publication of Harmonized Tariff Schedule note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1202"},"text":"section 1202 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id060513ba-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432"},"text":"Pub. L. 109–432","children":[],"tail":" substituted “30"},{"tag":"sup","attrib":{},"text":"th","children":[],"tail":"” for “15"},{"tag":"sup","attrib":{},"text":"th","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id060513bb-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id060513bc-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Authority","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"1991-12-12"},"text":"Dec. 12, 1991","children":[],"tail":", 56 F.R. 65413, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum for the United States Trade Representative","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"By virtue of the authority vested in me by the Constitution and laws of the United States, including ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"section 301 of title 3","children":[],"tail":" of the United States Code and the Omnibus Trade and Competitiveness Act of 1988 ("},{"tag":"ref","attrib":{"href":"/us/pl/100/418"},"text":"Public Law 100–418","children":[],"tail":") (“the Act”) [see Tables for classification], you are hereby delegated the functions vested in me by section 1206(b) of the Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3006/b"},"text":"19 U.S.C. 3006(b)","children":[],"tail":"), to submit to the Committee on Ways and Means of the House of Representatives and the Committee on Finance of the Senate reports that set forth proposed modifications to the Harmonized Tariff Schedule [see "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1202"},"text":"19 U.S.C. 1202","children":[],"tail":"] and the reasons therefor."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The President shall retain the authority under section 1206 of the Act to proclaim modifications to the Harmonized Tariff Schedule after the layover period specified in section 1206(b) has expired.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"You are authorized and directed to publish this memorandum in the Federal Register.","children":[],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"text":"George Bush.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
