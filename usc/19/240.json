{"tag":"section","attrib":{"id":"id05144b22-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s240"},"text":null,"children":[{"tag":"num","attrib":{"value":"240"},"text":"§ 240.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Value at date of shipment","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"When the duty upon any imports shall be subject to be levied upon the true market value of such imports in the principal markets of the country from whence the importation has been made, or at the port of exportation, the duty shall be estimated and collected upon the value on the day of actual shipment, whenever a bill of lading shall be presented showing the date of shipment, and which shall be certified by a certificate of the United States consul or legally authorized deputy.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id05144b23-3a70-11f1-8ace-823fb135378d"},"text":"(R.S. § 2904.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05144b24-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05144b25-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id05144b26-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 2904 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1861-03-02/ch68/s28"},"text":"act Mar. 2, 1861, ch. 68, § 28","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/12/197"},"text":"12 Stat. 197","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
