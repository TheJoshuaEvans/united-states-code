{"tag":"section","attrib":{"id":"id06005905-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2803"},"text":null,"children":[{"tag":"num","attrib":{"value":"2803"},"text":"§ 2803.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of major wine trading countries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id06005906-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2803/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Trade Representative shall designate as a major wine trading country each foreign country, or group of foreign countries represented as an economic union, that, in the judgment of the Trade Representative—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id06005907-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2803/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a potential significant market for United States wine; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06005908-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2803/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintains tariff barriers or nontariff barriers to (or other distortions of) trade in United States wine.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id06005909-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2803/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In deciding, for purposes of subsection (a)(2), whether a foreign country or group of countries maintains nontariff barriers to (or other distortions of) trade in United States wine, the Trade Representative shall take into account—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0600590a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2803/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the review and report required under section 854(a) of the Trade Agreements Act of 1979 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2135"},"text":"19 U.S.C. 2135","children":[],"tail":" note);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0600590b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2803/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such relevant actions that may have been taken by that country or group since that review was conducted; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0600590c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2803/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such information as may be submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2805"},"text":"section 2805 of this title","children":[],"tail":" by representatives of the wine and grape products industries in the United States, as well as other sources."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0600590d-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/573/tIX/s904"},"text":"Pub. L. 98–573, title IX, § 904","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3048"},"text":"98 Stat. 3048","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0600590e-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0600590f-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id06005910-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 854(a) of the Trade Agreements Act of 1979, referred to in subsec. (b)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39/s854/a"},"text":"section 854(a) of Pub. L. 96–39","children":[],"tail":", title VIII, "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/294"},"text":"93 Stat. 294","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2135"},"text":"section 2135 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
