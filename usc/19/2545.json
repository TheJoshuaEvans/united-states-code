{"tag":"section","attrib":{"id":"id05f20024-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2545"},"text":null,"children":[{"tag":"num","attrib":{"value":"2545"},"text":"§ 2545.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts and grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05f20025-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2545/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of carrying out this subchapter, and otherwise encouraging compliance with the Agreement, the Trade Representative and the Secretary concerned may each, with respect to functions for which responsible under this subchapter, make grants to, or enter into contracts with, any other Federal agency, any State agency, or any private person, to assist such agency or person to implement appropriate programs and activities, including, but not limited to, programs and activities—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05f20026-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2545/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase awareness of proposed and adopted standards-related activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f20027-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2545/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to facilitate international trade through the appropriate international and domestic standards-related activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f20028-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2545/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide, if appropriate, and pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2543"},"text":"section 2543 of this title","children":[],"tail":", adequate United States representation in international standards-related activities; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f20029-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2545/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage United States exports through increased awareness of foreign standards-related activities that may affect United States exports.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"No contract entered into under this section shall be effective except to such extent, and in such amount, as is provided in advance in appropriation Acts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05f2002a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2545/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any contract entered into, or any grant made, under subsection (a) shall be subject to such terms and conditions as the Trade Representative or Secretary concerned shall by regulation prescribe as being necessary or appropriate to protect the interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05f2002b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2545/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Financial assistance extended under this section shall not exceed 75 percent of the total costs (as established by the Trade Representative or Secretary concerned, as the case may be) of the program or activity for which assistance is made available. The non-Federal share of such costs shall be made in cash or kind, consistent with the maintenance of the program or activity concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05f2002c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2545/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each recipient of a grant or contract under this section shall make available to the Trade Representative or the Secretary concerned, as the case may be, and to the Comptroller General of the United States, for purposes of audit and examination, any book, document, paper, and record that is pertinent to the funds received under such grant or contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05f2002d-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39/tIV/s415"},"text":"Pub. L. 96–39, title IV, § 415","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/246"},"text":"93 Stat. 246","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/182/tIII/s351/b/2/A"},"text":"Pub. L. 103–182, title III, § 351(b)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-08"},"text":"Dec. 8, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2122"},"text":"107 Stat. 2122","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/295/s21/b/1"},"text":"Pub. L. 104–295, § 21(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3529"},"text":"110 Stat. 3529","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05f2002e-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05f2002f-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id05f20030-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/295"},"text":"Pub. L. 104–295","children":[],"tail":" amended directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/103/182"},"text":"Pub. L. 103–182","children":[],"tail":". See 1993 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/182"},"text":"Pub. L. 103–182","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/104/295"},"text":"Pub. L. 104–295","children":[],"tail":", substituted “Trade Representative” for “Special Representative” wherever appearing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
