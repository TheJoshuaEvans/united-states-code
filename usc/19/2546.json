{"tag":"section","attrib":{"id":"id05f20031-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2546"},"text":null,"children":[{"tag":"num","attrib":{"value":"2546"},"text":"§ 2546.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Trade Representative and the Secretary concerned may each, with respect to functions for which responsible under this subchapter, make available, on a reimbursable basis or otherwise, to any other Federal agency, State agency, or private person such assistance, including, but not limited to, employees, services, and facilities, as may be appropriate to assist such agency or person in carrying out standards-related activities in a manner consistent with this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id05f20032-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39/tIV/s416"},"text":"Pub. L. 96–39, title IV, § 416","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/247"},"text":"93 Stat. 247","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/182/tIII/s351/b/2/A"},"text":"Pub. L. 103–182, title III, § 351(b)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-08"},"text":"Dec. 8, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2122"},"text":"107 Stat. 2122","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/295/s21/b/1"},"text":"Pub. L. 104–295, § 21(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3529"},"text":"110 Stat. 3529","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05f20033-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05f20034-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id05f20035-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/295"},"text":"Pub. L. 104–295","children":[],"tail":" amended directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/103/182"},"text":"Pub. L. 103–182","children":[],"tail":". See 1993 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/182"},"text":"Pub. L. 103–182","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/104/295"},"text":"Pub. L. 104–295","children":[],"tail":", substituted “Trade Representative” for “Special Representative”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
