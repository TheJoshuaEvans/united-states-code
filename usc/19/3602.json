{"tag":"section","attrib":{"id":"id06136bff-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3602"},"text":null,"children":[{"tag":"num","attrib":{"value":"3602"},"text":"§ 3602.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special agricultural safeguard authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id06136c00-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3602/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of trigger levels","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Consistent with Article 5 as determined by the President, the President shall cause to be published in the Federal Register—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id06136c01-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3602/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the list of special safeguard agricultural goods not later than the date of entry into force of the WTO Agreement with respect to the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06136c02-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3602/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for each special safeguard agricultural good—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id06136c03-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3602/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the trigger level specified in subparagraph 1(a) of Article 5, on an annual basis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06136c04-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3602/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the trigger price specified in subparagraph 1(b) of Article 5; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06136c05-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3602/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relevant period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id06136c06-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3602/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of safeguard","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the President determines with respect to a special safeguard agricultural good that it is appropriate to impose—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id06136c07-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3602/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the price-based safeguard in accordance with subparagraph 1(b) of Article 5; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06136c08-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3602/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the volume-based safeguard in accordance with subparagraph 1(a) of Article 5,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the President shall, consistent with Article 5 as determined by the President, determine the amount of the duty to be imposed, the period such duty shall be in effect, and any other terms and conditions applicable to the duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id06136c09-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3602/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of safeguard","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall direct the Secretary of the Treasury to impose a duty on a special safeguard agricultural good entered, or withdrawn from warehouse, for consumption in the United States in accordance with a determination made under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id06136c0a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3602/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No simultaneous safeguard","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A duty may not be in effect for a special safeguard agricultural good pursuant to this section during any period in which such good is the subject of any action proclaimed pursuant to section 2252 or 2253 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id06136c0b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3602/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion of originating goods of USMCA countries","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id06136c0c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3602/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall exempt from any duty imposed under this section any good that qualifies as an originating good under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4531"},"text":"section 4531 of this title","children":[],"tail":" of a USMCA country with respect to which preferential tariff treatment is provided under the USMCA."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06136c0d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3602/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subsection, the terms “preferential tariff treatment”, “USMCA”, and “USMCA country” have the meanings given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4502"},"text":"section 4502 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id06136c0e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3602/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advice of Secretary of Agriculture","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture shall advise the President on the implementation of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id06136c0f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3602/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall cease to be effective on the date, as determined by the President, that the special safeguard provisions of Article 5 are no longer in force with respect to the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0615b500-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3602/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0615b501-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3602/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Article 5” means Article 5 of the Agreement on Agriculture described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3511/d/2"},"text":"section 3511(d)(2) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0615b502-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3602/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “relevant period” means the period determined by the President to be applicable to a special safeguard agricultural good for purposes of applying this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0615b503-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3602/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “special safeguard agricultural good” means an agricultural good on which an additional duty may be imposed pursuant to the special safeguard provisions of Article 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0615b504-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/tIV/s405"},"text":"Pub. L. 103–465, title IV, § 405","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4961"},"text":"108 Stat. 4961","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/295/s11"},"text":"Pub. L. 104–295, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3520"},"text":"110 Stat. 3520","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/113/tII/s201/a"},"text":"Pub. L. 116–113, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-01-29"},"text":"Jan. 29, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/19"},"text":"134 Stat. 19","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0615b505-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0615b506-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0615b507-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113"},"text":"Pub. L. 116–113","children":[],"tail":" amended subsec. (e) generally. Prior to amendment, text read as follows: “The President may exempt from any duty imposed under this section any good originating in a NAFTA country (as determined in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3332"},"text":"section 3332 of this title","children":[],"tail":").”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/295/s11/1"},"text":"Pub. L. 104–295, § 11(1)","children":[],"tail":", substituted “1(b)” for “1(a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/295/s11/2"},"text":"Pub. L. 104–295, § 11(2)","children":[],"tail":", substituted “1(a)” for “1(b)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0615b508-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0615b509-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2020 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113/tII/s201/b"},"text":"Pub. L. 116–113, title II, § 201(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-01-29"},"text":"Jan. 29, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/19"},"text":"134 Stat. 19","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/113/tII/s201/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amendment made by subsection (a) [amending this section] shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take effect on the date on which the USMCA enters into force [","children":[{"tag":"date","attrib":{"date":"2020-07-01"},"text":"July 1, 2020","children":[],"tail":"]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" apply with respect to a good entered for consumption, or withdrawn from warehouse for consumption, on or after that date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transition from nafta treatment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a good entered for consumption, or withdrawn from warehouse for consumption, before the date on which the USMCA enters into force—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amendment made by subsection (a) to section 405(e) of the Uruguay Round Agreements Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3602/e"},"text":"19 U.S.C. 3602(e)","children":[],"tail":") shall not apply with respect to the good; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 405(e) of such Act, as in effect on the day before that date, shall continue to apply on and after that date with respect to the good.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definition of “USMCA” as used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113/s201/b"},"text":"section 201(b) of Pub. L. 116–113","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s4502"},"text":"section 4502 of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0615b50a-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date of entry into force of the WTO Agreement with respect to the United States (","children":[{"tag":"date","attrib":{"date":"1995-01-01"},"text":"Jan. 1, 1995","children":[],"tail":"), except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/s451"},"text":"section 451 of Pub. L. 103–465","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3601"},"text":"section 3601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id0615b50b-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0615b50c-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Uruguay Round Agreements: Entry Into Force","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Uruguay Round Agreements, including the World Trade Organization Agreement and agreements annexed to that Agreement, as referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3511/d"},"text":"section 3511(d) of this title","children":[],"tail":", entered into force with respect to the United States on "},{"tag":"date","attrib":{"date":"1995-01-01"},"text":"Jan. 1, 1995","children":[],"tail":". See note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3511"},"text":"section 3511 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0615b50d-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Authority","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Authority of President under subsec. (a) of this section delegated to Secretary of Agriculture by par. (4) of Proc. No. 6763, ","children":[{"tag":"date","attrib":{"date":"1994-12-23"},"text":"Dec. 23, 1994","children":[],"tail":", 60 F.R. 1010, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3511"},"text":"section 3511 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
