{"tag":"section","attrib":{"id":"id0595138f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2033"},"text":null,"children":[{"tag":"num","attrib":{"value":"2033"},"text":"§ 2033.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of antidumping provisions and antitrust laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing contained in this chapter shall be construed to affect or modify the provisions of subtitle B of title VII of the Tariff Act of 1930 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1673"},"text":"19 U.S.C. 1673","children":[],"tail":" et seq.] or of any of the antitrust laws as designated in "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s12"},"text":"section 12 of title 15","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id05951390-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/283/tV/s503"},"text":"Pub. L. 89–283, title V, § 503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-10-21"},"text":"Oct. 21, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1026"},"text":"79 Stat. 1026","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/39/tI/s106/b/2"},"text":"Pub. L. 96–39, title I, § 106(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/193"},"text":"93 Stat. 193","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05951391-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05951392-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"