{"tag":"section","attrib":{"id":"id0599ce4c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2079"},"text":null,"children":[{"tag":"num","attrib":{"value":"2079"},"text":"§ 2079.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments in foreign countries; claims for reimbursement","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The provisions of this Act shall not affect payments made for the United States Customs Service in foreign countries, nor the right of any customs officer or employee to claim reimbursement for personal funds expended in connection with the enforcement of the customs laws.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0599ce4d-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1928-03-28/ch266/s4"},"text":"Mar. 28, 1928, ch. 266, § 4","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1939-08-07/ch566/s1"},"text":"Aug. 7, 1939, ch. 566, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/1263"},"text":"53 Stat. 1263","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/91/513/tIII/s1102/n/3"},"text":"Pub. L. 91–513, title III, § 1102(n)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-27"},"text":"Oct. 27, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1293"},"text":"84 Stat. 1293","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0599ce4e-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0599ce4f-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"refer