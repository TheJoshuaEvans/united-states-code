{"tag":"section","attrib":{"id":"id060784b2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3109"},"text":null,"children":[{"tag":"num","attrib":{"value":"3109"},"text":"§ 3109.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of data; action to ensure compliance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id060784b3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3109/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of data","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal Communications Commission (hereafter in this section referred to as the “Commission”) shall periodically submit to appropriate committees of the House of Representatives and of the Senate any data collected and otherwise made public under Report No. DC–1105, “Information Reporting Requirements Established for Common Carriers”, adopted ","children":[{"tag":"date","attrib":{"date":"1988-02-25"},"text":"February 25, 1988","children":[],"tail":", relating to FCC Docket No. 86–494, adopted "},{"tag":"date","attrib":{"date":"1987-12-23"},"text":"December 23, 1987","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id060784b4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3109/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action to ensure compliance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id060784b5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3109/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id060784b6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3109/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any product of a foreign country that is subject to registration or approval by the Commission may be entered only if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id060784b7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3109/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such product conforms with all applicable rules and regulations of the Commission, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id060784b8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3109/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information which is required on Federal Communications Commission Form 740 on ","children":[{"tag":"date","attrib":{"date":"1988-08-23"},"text":"August 23, 1988","children":[],"tail":", is provided to the appropriate customs officer at the time of such entry in such form and manner as the Secretary of the Treasury may prescribe."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id060784b9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3109/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this paragraph, the term “entered” means entered, or withdrawn from warehouse for consumption, in the customs territory of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060784ba-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3109/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commission, the Secretary of Commerce, and the Trade Representative shall provide such assistance in the enforcement of paragraph (1) as the Secretary of the Treasury may request.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060784bb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3109/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Treasury shall compile the information collected under paragraph (1)(A)(ii) into a summary and shall annually submit such summary to the Congress until the authority to negotiate trade agreements under chapter 17 of this title expires. Such information shall also be made available to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id060784bc-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/tI/s1380"},"text":"Pub. L. 100–418, title I, § 1380","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1223"},"text":"102 Stat. 1223","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id060784bd-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id060784be-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id060784bf-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Chapter 17 of this title, referred to in subsec. (b)(3), was in the original “part 1 of subtitle A”, meaning part 1 (§§ 1101–1117) of subtitle A of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418"},"text":"Pub. L. 100–418","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1121"},"text":"102 Stat. 1121","children":[],"tail":", which enacted chapter 17 (§ 2901 et seq.) of this title and amended sections 2131, 2133, and 2191 of this title. For complete classification of part 1 to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
