{"tag":"section","attrib":{"id":"id0615b513-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3621"},"text":null,"children":[{"tag":"num","attrib":{"value":"3621"},"text":"§ 3621.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tobacco proclamation authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0615b514-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3621/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President, after consultation with the Committee on Ways and Means of the House of Representatives and with the Committee on Finance of the Senate, may proclaim the reduction or elimination of any duty with respect to cigar binder and filler tobacco, wrapper tobacco, or oriental tobacco set forth in Schedule XX.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0615b515-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3621/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall take effect on ","children":[{"tag":"date","attrib":{"date":"1994-12-08"},"text":"December 8, 1994","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0615b516-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/tIV/s423"},"text":"Pub. L. 103–465, title IV, § 423","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4965"},"text":"108 Stat. 4965","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0615b517-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0615b518-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0615b519-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date of entry into force of the WTO Agreement with respect to the United States (","children":[{"tag":"date","attrib":{"date":"1995-01-01"},"text":"Jan. 1, 1995","children":[],"tail":"), except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/s451"},"text":"section 451 of Pub. L. 103–465","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3601"},"text":"section 3601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
