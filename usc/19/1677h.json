{"tag":"section","attrib":{"id":"id0589059a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677h"},"text":null,"children":[{"tag":"num","attrib":{"value":"1677h"},"text":"§ 1677h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Drawback treatment","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For purposes of any law relating to the drawback of customs duties, countervailing duties and antidumping duties imposed by this subtitle shall not be treated as being regular customs duties.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0589059b-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title VII, § 779, as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/573/tVI/s622/a/2"},"text":"Pub. L. 98–573, title VI, § 622(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3039"},"text":"98 Stat. 3039","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tI/s1334/a"},"text":"Pub. L. 100–418, title I, § 1334(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1209"},"text":"102 Stat. 1209","children":[],"tail":", 1210.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0589059c-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0589059d-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic