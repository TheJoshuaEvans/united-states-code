{"tag":"section","attrib":{"id":"id06588b0c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4535"},"text":null,"children":[{"tag":"num","attrib":{"value":"4535"},"text":"§ 4535.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id06588b0d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4535/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary of the Treasury","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury shall prescribe such regulations as may be necessary to carry out this title ","children":[{"tag":"ref","attrib":{"idref":"fn002181"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002181"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and the amendments made by this title "},{"tag":"ref","attrib":{"idref":"fn002181"},"text":"1","children":[],"tail":" (except as provided by subsection (b))."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id06588b0e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4535/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary of Labor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Labor shall prescribe such regulations as may be necessary to carry out the labor value content determination under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4532"},"text":"section 4532 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0658