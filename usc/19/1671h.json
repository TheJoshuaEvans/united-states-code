{"tag":"section","attrib":{"id":"id0575f352-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1671h"},"text":null,"children":[{"tag":"num","attrib":{"value":"1671h"},"text":"§ 1671h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditional payment of countervailing duty","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0575f353-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1671h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For all entries, or withdrawals from warehouse, for consumption of merchandise subject to a countervailing duty order on or after the date of publication of such order, no customs officer may deliver merchandise of that class or kind to the person by whom or for whose account it was imported unless that person complies with the requirement of subsection (b) and deposits with the appropriate customs officer an estimated countervailing duty in an amount determined by the administering authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0575f354-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1671h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Importer requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to meet the requirements of this subsection, a person shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0575f355-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1671h/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" furnish, or arrange to have furnished, to the appropriate customs officer such information as the administering authority deems necessary for ascertaining any countervailing duty to be imposed under this part,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0575f356-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1671h/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain and furnish to the customs officer such records concerning such merchandise as the administering authority, by regulation, requires, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0575f357-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1671h/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay, or agree to pay on demand, to the customs officer the amount of countervailing duty imposed under this part on that merchandise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0575f358-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title VII, § 709, as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/573/tVI/s608"},"text":"Pub. L. 98–573, title VI, § 608","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3029"},"text":"98 Stat. 3029","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0575f359-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0575f35a-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0575f35b-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0575f35c-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/573/s626/a"},"text":"section 626(a) of Pub. L. 98–573","children":[],"tail":", set out as an Effective Date of 1984 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1671"},"text":"section 1671 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
