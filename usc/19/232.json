{"tag":"section","attrib":{"id":"id05144b13-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s232"},"text":null,"children":[{"tag":"num","attrib":{"value":"232"},"text":"§ 232.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Port” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The word “port”, as used in title 34 of the Revised Statutes, may include any place from which merchandise can be shipped for importation, or at which merchandise can be imported.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id05144b14-3a70-11f1-8ace-823fb135378d"},"text":"(R.S. § 2767.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05144b15-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05144b16-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id05144b17-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Title 34 of the Revised Statutes, referred to in text, was in the original “this Title”, meaning title 34 of the Revised Statutes, consisting of R.S. §§ 2517 to 3129. For complete classification of R.S. §§ 2517 to 3129 to the Code, see Tables.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
