{"tag":"section","attrib":{"id":"id058de834-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1683c"},"text":"§ 1683c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Export charge determination and publication","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id058de835-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Under Secretary for International Trade of the Department of Commerce shall determine, on a monthly basis, any export charges (expressed as a percentage of export price) to be collected by a country of export from exporters of softwood lumber or softwood lumber products described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1683b/a"},"text":"section 1683b(a) of this title","children":[],"tail":" in order to ensure compliance with any international agreement entered into by that country and the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id058de836-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Under Secretary for International Trade shall immediately publish any determination made under subsection (a) on the website of the International Trade Administration of the Department of Commerce, and in any other manner the Under Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id058de837-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title VIII, § 805, as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/tIII/s3301/a"},"text":"Pub. L. 110–246, title III, § 3301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1851"},"text":"122 Stat. 1851","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id058de838-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id058de839-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id058de83a-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 60 days after ","children":[{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s3301/b"},"text":"section 3301(b) of Pub. L. 110–246","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1683"},"text":"section 1683 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
