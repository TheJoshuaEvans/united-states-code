{"tag":"section","attrib":{"id":"id0653d002-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4435"},"text":null,"children":[{"tag":"num","attrib":{"value":"4435"},"text":"§ 4435.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery of initial U.S. Customs and Border Protection preclearance operations costs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0653d003-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4435/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost sharing agreements with relevant airport authorities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commissioner may enter into a cost sharing agreement with airport authorities in foreign countries at which preclearance operations are to be established or maintained if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0653d004-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4435/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an executive agreement to establish or maintain such preclearance operations pursuant to the authorities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1629"},"text":"section 1629 of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1103/a/7"},"text":"section 1103(a)(7) of title 8","children":[],"tail":" has been signed, but has not yet entered into force; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0653d005-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4435/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" U.S. Customs and Border Protection has incurred, or expects to incur, initial preclearance operations costs in order to establish or maintain preclearance operations under the agreement described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0653d006-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4435/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of cost sharing agreements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0653d007-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4435/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s58c/e"},"text":"section 58c(e) of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1356/g"},"text":"section 1356(g) of title 8","children":[],"tail":", any cost sharing agreement with an airport authority authorized under subsection (a) may provide for the airport authority’s payment to U.S. Customs and Border Protection of its initial preclearance operations costs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0653d008-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4435/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing of payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The airport authority’s payment to U.S. Customs and Border Protection for its initial preclearance operations costs may be made in advance of the incurrence of the costs or on a reimbursable basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0653d009-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4435/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Account","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0653d00a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4435/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"All amounts collected pursuant to any cost sharing agreement authorized under subsection (a)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0653d00b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4435/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be credited as offsetting collections to the currently applicable appropriation, account, or fund of U.S. Customs and Border Protection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0653d00c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4435/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall remain available, until expended, for the purposes for which such appropriation, account, or fund is authorized to be used; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0653d00d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4435/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be collected and shall be available only to the extent provided in appropriations Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0653d00e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4435/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Return of unused funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any advances or reimbursements not used by U.S. Customs and Border Protection may be returned to the relevant airport authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0653d00f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4435/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection may be construed to preclude the use of appropriated funds from sources other than the payments collected under this subchapter to pay initial preclearance operation costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0653d010-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4435/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Defined term","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0653d011-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4435/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “initial preclearance operations costs” means the costs incurred, or expected to be incurred, by U.S. Customs and Border Protection to establish or maintain preclearance operations at an airport in a foreign country, including costs relating to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0653d012-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4435/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hiring, training, and equipping new U.S. Customs and Border Protection officers who will be stationed at United States domestic ports of entry or other U.S. Customs and Border Protection facilities to backfill U.S. Customs and Border Protection officers to be stationed at an airport in a foreign country to conduct preclearance operations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0653d013-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4435/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" visits to the airport authority conducted by U.S. Customs and Border Protection personnel necessary to prepare for the establishment or maintenance of preclearance operations at such airport, including the compensation, travel expenses, and allowances payable to such personnel attributable to such visits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0653d014-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4435/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The costs described in paragraph (1)(A) shall not include the salaries and benefits of new U.S. Customs and Border Protection officers once such officers are permanently stationed at a domestic United States port of entry or other domestic U.S. Customs and Border Protection facility after being hired, trained, and equipped.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0653d015-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4435/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this section, nothing in this section may be construed as affecting the responsibilities, duties, or authorities of U.S. Customs and Border Protection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0653d016-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/125/tVIII/s817"},"text":"Pub. L. 114–125, title VIII, § 817","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-24"},"text":"Feb. 24, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/220"},"text":"130 Stat. 220","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0653d017-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0653d018-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0653d019-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in subsec. (c)(3), was in the original “this subtitle”, meaning subtitle B (§§ 811–819) of title VIII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/125"},"text":"Pub. L. 114–125","children":[],"tail":", which is classified principally to this subchapter. For complete classification of subtitle B to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s4301"},"text":"section 4301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
