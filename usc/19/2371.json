{"tag":"section","attrib":{"id":"id05d3068f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2371"},"text":null,"children":[{"tag":"num","attrib":{"value":"2371"},"text":"§ 2371.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community College and Career Training Grant Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05d30690-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2371/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants authorized","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05d30691-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2371/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning ","children":[{"tag":"date","attrib":{"date":"2009-08-01"},"text":"August 1, 2009","children":[],"tail":", the Secretary may award Community College and Career Training Grants to eligible institutions for the purpose of developing, offering, or improving educational or career training programs for workers eligible for training under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2296"},"text":"section 2296 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05d30692-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2371/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible institution may not be awarded—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05d30693-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2371/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" more than one grant under this section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05d30694-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2371/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a grant under this section in excess of $1,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05d30695-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2371/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05d30696-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2371/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible institution” means an institution of higher education (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1002"},"text":"section 1002 of title 20","children":[],"tail":"), but only with respect to a program offered by the institution that can be completed in not more than 2 years."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05d30697-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2371/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Labor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05d30698-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2371/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant proposals","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05d30699-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2371/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible institution seeking to receive a grant under this section shall submit a grant proposal to the Secretary at such time, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05d3069a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2371/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2009-06-01"},"text":"June 1, 2009","children":[],"tail":", the Secretary shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05d3069b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2371/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promulgate guidelines for the submission of grant proposals under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05d3069c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2371/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish and maintain such guidelines on the website of the Department of Labor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05d3069d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2371/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall offer assistance in preparing a grant proposal to any eligible institution that requests such assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05d3069e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2371/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General requirements for grant proposals","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05d3069f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2371/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grant proposal submitted to the Secretary under this section shall include a detailed description of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id05d306a0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2371/c/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the specific project for which the grant proposal is submitted, including the manner in which the grant will be used to develop, offer, or improve an educational or career training program that is suited to workers eligible for training under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2296"},"text":"section 2296 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05d306a1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2371/c/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the project for which the grant proposal is submitted will meet the educational or career training needs of workers in the community served by the eligible institution who are eligible for training under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2296"},"text":"section 2296 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05d306a2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2371/c/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any previous experience of the eligible institution in providing educational or career training programs to workers eligible for training under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2296"},"text":"section 2296 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05d306a3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2371/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Absence of experience","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The absence of any previous experience in providing educational or career training programs described in subparagraph (A)(iii) shall not automatically disqualify an eligible institution from receiving a grant under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05d306a4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2371/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community outreach required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to be considered by the Secretary, a grant proposal submitted by an eligible institution under this section shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05d306a5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2371/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" demonstrate that the eligible institution—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id05d306a6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2371/c/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" reached out to employers to identify—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id05d306a7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2371/c/5/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any shortcomings in existing educational and career training opportunities available to workers in the community; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id05d306a8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2371/c/5/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any future employment opportunities within the community and the educational and career training skills required for workers to meet the future employment demand; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05d306a9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2371/c/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reached out to other similarly situated institutions in an effort to benefit from any best practices that may be shared with respect to providing educational or career training programs to workers eligible for training under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2296"},"text":"section 2296 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05d306aa-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2371/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include a detailed description of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id05d306ab-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2371/c/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent and outcome of the outreach conducted under subparagraph (A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05d306ac-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2371/c/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the project for which the grant proposal is submitted will contribute to meeting any shortcomings identified under subparagraph (A)(i)(I) or any educational or career training needs identified under subparagraph (A)(i)(II); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05d306ad-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2371/c/5/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which employers, including small- and medium-sized firms within the community, have demonstrated a commitment to employing workers who would benefit from the project for which the grant proposal is submitted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05d306ae-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2371/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria for award of grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05d306af-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2371/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the appropriation of funds, the Secretary shall award a grant under this section based on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05d306b0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2371/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a determination of the merits of the grant proposal submitted by the eligible institution to develop, offer, or improve educational or career training programs to be made available to workers eligible for training under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2296"},"text":"section 2296 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05d306b1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2371/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of the likely employment opportunities available to workers who complete an educational or career training program that the eligible institution proposes to develop, offer, or improve; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05d306b2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2371/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of prior demand for training programs by workers eligible for training under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2296"},"text":"section 2296 of this title","children":[],"tail":" in the community served by the eligible institution, as well as the availability and capacity of existing training programs to meet future demand for training programs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05d306b3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2371/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant awarded under this section may not be used to satisfy any private matching requirement under any other provision of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05d306b4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2371/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2009-12-15"},"text":"December 15, 2009","children":[],"tail":", and annually thereafter, the Secretary shall submit to the Committee on Finance of the Senate and the Committee on Ways and Means of the House of Representatives a report—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id05d306b5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2371/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describing each grant awarded under this section during the preceding fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05d306b6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2371/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessing the impact of each award of a grant under this section in a fiscal year preceding the fiscal year referred to in paragraph (1) on workers receiving training under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2296"},"text":"section 2296 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05d306b7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2371/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" providing the following data relating to program performance and outcomes:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05d306b8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2371/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Of the grants awarded under this section, the amount of funds spent by grantees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05d306b9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2371/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The average dollar amount of grants awarded under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05d306ba-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2371/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The average duration of grants awarded under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05d306bb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2371/e/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The percentage of workers receiving benefits under part 2 that are served by programs developed, offered, or improved using grants awarded under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05d306bc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2371/e/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The percentage and number of workers receiving benefits under part 2 who obtained a degree through such programs and the average duration of the participation of such workers in training under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2296"},"text":"section 2296 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05d306bd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2371/e/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of workers receiving benefits under part 2 served by such programs who did not complete a degree and the average duration of the participation of such workers in training under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2296"},"text":"section 2296 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05d306be-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/tII/s271"},"text":"Pub. L. 93–618, title II, § 271","children":[],"tail":", formerly § 278, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/5/dB/tI/s1872/a"},"text":"Pub. L. 111–5, div. B, title I, § 1872(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/406"},"text":"123 Stat. 406","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/344/tI/s101/c/8"},"text":"Pub. L. 111–344, title I, § 101(c)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-29"},"text":"Dec. 29, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3614"},"text":"124 Stat. 3614","children":[],"tail":"; as added, renumbered § 271, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/40/tII"},"text":"Pub. L. 112–40, title II","children":[],"tail":", §§ 201(b), (c), 222(a)(3), (b)(1), (c)(1), "},{"tag":"date","attrib":{"date":"2011-10-21"},"text":"Oct. 21, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/403"},"text":"125 Stat. 403",