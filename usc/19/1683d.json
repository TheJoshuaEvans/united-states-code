{"tag":"section","attrib":{"id":"id058de83b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1683d"},"text":"§ 1683d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reconciliation","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Treasury shall conduct reconciliations to ensure the proper implementation and operation of international agreements entered into between a country of export of softwood lumber or softwood lumber products described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1683b/a"},"text":"section 1683b(a) of this title","children":[],"tail":" and the United States. The Secretary of Treasury shall reconcile the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id058de83c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The export price declared by a United States importer pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1683a/b/1"},"text":"section 1683a(b)(1) of this title","children":[],"tail":" with the export price reported to the United States by the country of export, if any."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id058de83d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The export price declared by a United States importer pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1683a/b/1"},"text":"section 1683a(b)(1) of this title","children":[],"tail":" with the revised export price reported to the United States by the country of export, if any."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id058de83e-3a70-1