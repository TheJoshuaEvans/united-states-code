{"tag":"section","attrib":{"id":"id0516953c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s508"},"text":null,"children":[{"tag":"num","attrib":{"value":"508"},"text":"§ 508.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persons making seizures pleading general issue and proving special matter","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If any officer, or other person, executing or aiding or assisting in the seizure of goods, under any Act providing for or regulating the collection of duties on imports or tonnage, is sued for anything done in virtue of the powers given thereby, or by virtue of a warrant granted by any judge, or justice, pursuant to law, he may plead the general issue and give such Act and the special matter in evidence.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0516953d-3a70-11f1-8ace-823fb135378d"},"text":"(R.S. § 3073.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0516953e-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0516953f-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id05169540-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 3073 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1799-03-02/ch22/s71"},"text":"act Mar. 2, 1799, ch. 22, § 71","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/1/678"},"text":"1 Stat. 678","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
