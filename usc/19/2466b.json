{"tag":"section","attrib":{"id":"id05e619d5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2466b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2466b"},"text":"§ 2466b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of benefits for sub-Saharan African countries","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In the case of a beneficiary sub-Saharan African country, as defined in section 2466a(c) ","children":[{"tag":"ref","attrib":{"idref":"fn002123"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002123"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title, duty-free treatment provided under this subchapter shall remain in effect through "},{"tag":"date","attrib":{"date":"2026-12-31"},"text":"December 31, 2026","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id05e619d6-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/tV/s506B"},"text":"Pub. L. 93–618, title V, § 506B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/200/tI/s114"},"text":"Pub. L. 106–200, title I, § 114","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-05-18"},"text":"May 18, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/266"},"text":"114 Stat. 266","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/274/s7/a/1"},"text":"Pub. L. 108–274, § 7(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-13"},"text":"July 13, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/823"},"text":"118 Stat. 823","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/27/tI/s103/a"},"text":"Pub. L. 114–27, title I, § 103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-06-29"},"text":"June 29, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/364"},"text":"129 Stat. 364","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/75/dI/s5019/a/1/A"},"text":"Pub. L. 119–75, div. I, § 5019(a)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2026-02-03"},"text":"Feb. 3, 2026","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/140/632"},"text":"140 Stat. 632","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05e619d7-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05e619d8-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id05e619d9-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2466a/c"},"text":"Section 2466a(c) of this title","children":[],"tail":", referred to in text, was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2466a/e"},"text":"section 2466a(e) of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/114/27/tI/s105/b"},"text":"Pub. L. 114–27, title I, § 105(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2015-06-29"},"text":"June 29, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/366"},"text":"129 Stat. 366","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id05e619da-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2026—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/75"},"text":"Pub. L. 119–75","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2026-12-31"},"text":"December 31, 2026","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2025-09-30"},"text":"September 30, 2025","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/27"},"text":"Pub. L. 114–27","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2025-09-30"},"text":"September 30, 2025","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2015-09-30"},"text":"September 30, 2015","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/274"},"text":"Pub. L. 108–274","children":[],"tail":" substituted “2015” for “2008”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id05e619db-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id05e619dc-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Retroactive Application of 2026 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/75/dI/s5019/a/2"},"text":"Pub. L. 119–75, div. I, § 5019(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2026-02-03"},"text":"Feb. 3, 2026","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/140/632"},"text":"140 Stat. 632","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/75/dI/s5019/a/2"},"text":"\n","children":[{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding section 514 of the Tariff Act of 1930 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1514"},"text":"19 U.S.C. 1514","children":[],"tail":") or any other provision of law, and subject to subparagraph (B), any entry of a covered article to which duty-free treatment or other preferential treatment under section 506A of the Trade Act of 1974 ("},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2466a"},"text":"19 U.S.C. 2466a","children":[],"tail":") or section 112 of the African Grown [sic] and Opportunity Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3721"},"text":"19 U.S.C. 3721","children":[],"tail":") would have applied if the entry had been made on "},{"tag":"date","attrib":{"date":"2025-09-30"},"text":"September 30, 2025","children":[],"tail":", that was made—"}],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after ","children":[{"tag":"date","attrib":{"date":"2025-09-30"},"text":"September 30, 2025","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2026-02-03"},"text":"Feb. 3, 2026","children":[],"tail":"],"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be liquidated or reliquidated as though such entry occurred on the date of the enactment of this Act.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requests","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A liquidation or reliquidation may be made under subparagraph (A) with respect to an entry only if a request therefor is filed with the Commissioner of U.S. Customs and Border Protection not later than 180 days after the date of the enactment of this Act that contains sufficient information to enable such Commissioner—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to locate the entry; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reconstruct the entry if it cannot be located.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment of amounts owed","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any amounts owed by the United States pursuant to the liquidation or reliquidation of an entry of a covered article under subparagraph (A) shall be paid, without interest of any kind, not later than 90 days after the date of the liquidation or reliquidation (as the case may be).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this paragraph:","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered article","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘covered article’ means an article from a country that is designated by the President as a beneficiary sub-Saharan African country under section 104 of the African Growth and Opportunity Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3703"},"text":"19 U.S.C. 3703","children":[],"tail":") as of the day before the date of the enactment of this Act."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Entry","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘entry’ includes a withdrawal from warehouse for consumption.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
