{"tag":"section","attrib":{"id":"id05d57882-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401e"},"text":null,"children":[{"tag":"num","attrib":{"value":"2401e"},"text":"§ 2401e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifying requirements for agricultural commodity producers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05d57883-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05d57884-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Payment of a ","children":[{"tag":"ref","attrib":{"idref":"fn002112"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002112"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “an”."}],"tail":" adjustment assistance under this part shall be made to an adversely affected agricultural commodity producer covered by a certification under this part who files an application for such assistance within 90 days after the date on which the Secretary makes a determination and issues a certification of eligibility under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2401b"},"text":"section 2401b of this title","children":[],"tail":", if the following conditions are met:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05d57885-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401e/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The producer submits to the Secretary sufficient information to establish the amount of agricultural commodity covered by the application filed under this subsection that was produced by the producer in the most recent year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05d57886-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401e/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The producer certifies that the producer has not received cash benefits under any provision of this subchapter other than this part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05d57887-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401e/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The producer’s net farm income (as determined by the Secretary) for the most recent year is less than the producer’s net farm income for the latest year in which no adjustment assistance was received by the producer under this part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05d57888-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401e/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The producer certifies that the producer has met with an Extension Service employee or agent to obtain, at no cost to the producer, information and technical assistance that will assist the producer in adjusting to import competition with respect to the adversely affected agricultural commodity, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id05d57889-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401e/a/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information regarding the feasibility and desirability of substituting 1 or more alternative commodities for the adversely affected agricultural commodity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05d5788a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401e/a/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical assistance that will improve the competitiveness of the production and marketing of the adversely affected agricultural commodity by the producer, including yield and marketing improvements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05d5788b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05d5788c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401e/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjusted gross income","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id05d5788d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401e/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this part, an agricultural commodity producer shall not be eligible for assistance under this part in any year in which the average adjusted gross income of the producer exceeds the level set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1308–3a"},"text":"section 1308–3a of title 7","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05d5788e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401e/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To comply with the limitation under subparagraph (A),","children":[{"tag":"ref","attrib":{"idref":"fn002113"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002113"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be a reference to clause (i)."}],"tail":" an individual or entity shall provide to the Secretary—"}],"tail":null},{"tag":"subclause","attrib":{"id":"id05d5788f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401e/a/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certification by a certified public accountant or another third party that is acceptable to the Secretary that the average adjusted gross income of the producer does not exceed the level set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1308–3a"},"text":"section 1308–3a of title 7","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id05d57890-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401e/a/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information and documentation regarding the adjusted gross income of the producer through other procedures established by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05d57891-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401e/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Counter-cyclical payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The total amount of payments made to an agricultural producer under this part during any crop year may not exceed the limitation on counter-cyclical payments set forth in section 1308(c) ","children":[{"tag":"ref","attrib":{"idref":"fn002114"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002114"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" See References in Text note below."}],"tail":" of title 7."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05d57892-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401e/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id05d57893-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401e/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjusted gross income","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “adjusted gross income” means adjusted gross income of an agricultural commodity producer—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id05d57894-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401e/a/2/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s62"},"text":"section 62 of title 26","children":[],"tail":" and implemented in accordance with procedures established by the Secretary; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id05d57895-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401e/a/2/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is earned directly or indirectly from all agricultural and nonagricultural sources of an individual or entity for a fiscal or corresponding crop year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05d57896-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401e/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Average adjusted gross income","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id05d57897-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401e/a/2/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “average adjusted gross income” means the average adjusted gross income of a producer for each of the 3 preceding taxable years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id05d57898-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401e/a/2/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective adjusted gross income","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a producer that does not have an adjusted gross income for each of the 3 preceding taxable years, the Secretary shall establish rules that provide the producer with an effective adjusted gross income for the applicable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05d57899-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of cash benefits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05d5789a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2401g"},"text":"section 2401g of this title","children":[],"tail":", an adversely affected agricultural commodity producer described in subsection (a) shall be entitled to adjustment assistance under this part in an amount equal to the product of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05d5789b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401e/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" one-half of the difference between—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id05d5789c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401e/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to 80 percent of the average of the national average price of the agricultural commodity covered by the application described in subsection (a) for the 5 marketing years preceding the most recent marketing year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05d5789d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401e/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the national average price of the agricultural commodity for the most recent marketing year, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05d5789e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401e/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the agricultural commodity produced by the agricultural commodity producer in the most recent marketing year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05d5789f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for subsequent qualified years","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of cash benefits for a qualified year shall be determined in the same manner as cash benefits are determined under paragraph (1), except that the average national price of the agricultural commodity shall be determined under paragraph (1)(A)(i) by using the 5-marketing-year period used to determine the amount of cash benefits for the first certification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05d578a0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum amount of cash assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The maximum amount of cash benefits an agricultural commodity producer may receive in any 12-month period shall not exceed $10,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05d578a1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on other assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An agricultural commodity producer entitled to receive a cash benefit under this part—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05d578a2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401e/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be eligible for any other cash benefit under this subchapter, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05d578a3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401e/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be entitled to employment services and training benefits under division II of subpart B of part 2.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05d578a4-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/tII/s296"},"text":"Pub. L. 93–618, title II, § 296","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/210/dA/tI/s141/a"},"text":"Pub. L. 107–210, div. A, title I, § 141(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-06"},"text":"Aug. 6, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/949"},"text":"116 Stat. 949","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/429/tII/s2004/a/9"},"text":"Pub. L. 108–429, title II, § 2004(a)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-03"},"text":"Dec. 3, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2590"},"text":"118 Stat. 2590","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/5/dB/tI/s1883/a"},"text":"Pub. L. 111–5, div. B, title I, § 1883(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/416"},"text":"123 Stat. 416","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/40/tII/s201/b"},"text":"Pub. L. 112–40, title II, § 201(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2011-10-21"},"text":"Oct. 21, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/403"},"text":"125 Stat. 403","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/27/tIV/s402/b"},"text":"Pub. L. 114–27, title IV, § 402(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2015-06-29"},"text":"June 29, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/374"},"text":"129 Stat. 374","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05d578a5-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id05d578a6-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Assistance","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination of assistance under this part after ","children":[{"tag":"date","attrib":{"date":"2022-06-30"},"text":"June 30, 2022","children":[],"tail":", see Termination Date note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05d578a7-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id05d578a8-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1308/c"},"text":"Section 1308(c) of title 7","children":[],"tail":", referred to in subsec. (a)(2)(B), was struck out, and new subsecs. (b) and (c) containing provisions relating to counter-cyclical payments were added, by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s1603/b/2"},"text":"Pub. L. 110–246, § 1603(b)(2)","children":[],"tail":". Those subsecs. (b) and (c) were subsequently struck out, and new subsecs. (b) and (c) relating to limitations on total amount of payments were added, by "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/s1603/a"},"text":"Pub. L. 113–79, § 1603(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id05d578a9-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section reflects the ","children":[{"tag":"date","attrib":{"date":"2021-07-01"},"text":"July 1, 2021","children":[],"tail":", reversion to provisions in effect on "},{"tag":"date","attrib":{"date":"2014-01-01"},"text":"Jan. 1, 2014","children":[],"tail":". See Effective and Termination Dates of 2015 Revival note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/40/s233"},"text":"Section 233 of Pub. L. 112–40","children":[],"tail":", which provided for the "},{"tag":"date","attrib":{"date":"2014-01-01"},"text":"Jan. 1, 2014","children":[],"tail":", revival of this section as in effect on "},{"tag":"date","attrib":{"date":"2011-02-13"},"text":"Feb. 13, 2011","children":[],"tail":", was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/114/27/tIV/s402/a"},"text":"Pub. L. 114–27, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-06-29"},"text":"June 29, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/374"},"text":"129 Stat. 374","children":[],"tail":", and the provisions of this section, as in effect on "},{"tag":"date","attrib":{"date":"2013-12-31"},"text":"Dec. 31, 2013","children":[],"tail":", were temporarily revived, effective "},{"tag":"date","attrib":{"date":"2015-06-29"},"text":"June 29, 2015","children":[],"tail":", until "},{"tag":"date","attrib":{"date":"2021-07-01"},"text":"July 1, 2021","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/pl/114/27"},"text":"Pub. L. 114–27","children":[],"tail":", §§ 402(b), (c), 406. See 2011 and 2015 Amendment notes, Effective and Termination Dates of 2011 Revival notes, and Effective and Termination Dates of 2015 Revival notes below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5/s1893"},"text":"Section 1893 of Pub. L. 111–5","children":[],"tail":", which provided for "},{"tag":"date","attrib":{"date":"2011-02-13"},"text":"Feb. 13, 2011","children":[],"tail":", termination of amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/111/5"},"text":"Pub. L. 111–5","children":[],"tail":", was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/112