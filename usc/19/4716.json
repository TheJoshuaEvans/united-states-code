{"tag":"section","attrib":{"id":"id065fb6d4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4716"},"text":null,"children":[{"tag":"num","attrib":{"value":"4716"},"text":"§ 4716.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id065fb6d5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4716/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Trade Representative, in consultation with the head of any Federal agency described in this part, shall submit to the appropriate congressional committees a report on the implementation of this part, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id065fb6d6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4716/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of efforts of the USMCA countries to implement their environmental obligations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065fb6d7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4716/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of additional efforts to be taken with respect to USMCA countries that are failing to implement their environmental obligations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id065fb6d8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4716/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing of report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report required by subsection (a) shall be submitted—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id065fb6d9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4716/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 1 year after the date on which the USMCA enters into force;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065fb6da-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4716/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" annually for each of the next 4 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065fb6db-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4716/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" biennially thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id065fb6dc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4716/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional matters to be included in the fifth annual report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report required by subsection (a) that is submitted in the fifth year after the USMCA enters into force shall also include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id065fb6dd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4716/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The updated assessment required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4712/d"},"text":"section 4712(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065fb6de-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4716/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A comprehensive determination regarding USMCA countries’ implementation of their environmental obligations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065fb6df-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4716/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An explanation of how compliance with environmental obligations will be taken into consideration during the “joint review” conducted pursuant to article 34.7.2 of the USMCA on the sixth anniversary of the entry into force of the USMCA.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id065fb6e0-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113/tVIII/s816"},"text":"Pub. L. 116–113, title VIII, § 816","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-01-29"},"text":"Jan. 29, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/95"},"text":"134 Stat. 95","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
