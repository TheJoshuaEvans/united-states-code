{"tag":"section","attrib":{"id":"id0592a275-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1872"},"text":null,"children":[{"tag":"num","attrib":{"value":"1872"},"text":"§ 1872.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency trade organization","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0592a276-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1872/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment; functions; membership and composition; participation of representatives of other agencies; meetings","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0592a277-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1872/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President shall establish an interagency organization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0592a278-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1872/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The functions of the organization are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0592a279-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1872/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist, and make recommendations to, the President in carrying out the functions vested in him by the trade laws and to advise the United States Trade Representative (hereinafter in this section referred to as the “Trade Representative”) in carrying out the functions set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2171"},"text":"section 2171 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0592a27a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1872/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist the President, and advise the Trade Representative, with respect to the development and implementation of the international trade policy objectives of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0592a27b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1872/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to advise the President and the Trade Representative with respect to the relationship between the international trade policy objectives of the United States and other major policy areas which may significantly affect the overall international trade policy and trade competitiveness of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0592a27c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1872/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The interagency organization shall be composed of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0592a27d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1872/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Trade Representative, who shall be chairperson.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0592a27e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1872/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0592a27f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1872/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0592a280-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1872/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0592a281-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1872/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0592a282-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1872/a/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Labor.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The Trade Representative may invite representatives from other agencies, as appropriate, to attend particular meetings if subject matters of specific functional interest to such agencies are under consideration. It shall meet at such times and with respect to such matters as the President or the Chairman shall direct.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0592a283-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1872/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In assisting the President, the organization shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0592a284-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1872/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make recommendations to the President on basic policy issues arising in the administration of the trade agreements program,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0592a285-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1872/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make recommendations to the President as to what action, if any, he should take on reports submitted to him by the United States International Trade Commission under section 2251(d) ","children":[{"tag":"ref","attrib":{"idref":"fn002065"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002065"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title,"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0592a286-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1872/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the President of the results of hearings held pursuant to section 2412(b)(2) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title, and recommend appropriate action with respect thereto, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0592a287-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1872/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform such other functions with respect to the trade agreements program as the President may from time to time designate.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"In carrying out its functions under this subsection, the organization shall take into account the advice of the congressional advisers and private sector advisory committees, as well as that of any committee or other body established to advise the department, agency, or office which a member of the organization heads.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0592a288-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1872/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of resources of agencies; procedures and committees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The organization shall, to the maximum extent practicable, draw upon the resources of the agencies represented in the organization, as well as such other agencies as it may determine, including the United States International Trade Commission. In addition, the President may establish by regulation such procedures and committees as he may determine to be necessary to enable the organization to provide for the conduct of hearings pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2412/b/2"},"text":"section 2412(b)(2) of this title","children":[],"tail":", and for the carrying out of other functions assigned to the organization pursuant to this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0592a289-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/794/tII/s242"},"text":"Pub. L. 87–794, title II, § 242","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-11"},"text":"Oct. 11, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/878"},"text":"76 Stat. 878","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/618/tI/s171/b"},"text":"Pub. L. 93–618, title I, § 171(b)","children":[],"tail":", title VI, § 602(b), "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2009"},"text":"88 Stat. 2009","children":[],"tail":", 2072; "},{"tag":"ref","attrib":{"href":"/us/pl/96/39/tIX/s902/c"},"text":"Pub. L. 96–39, title IX, § 902(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/300"},"text":"93 Stat. 300","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tI/s1621/a"},"text":"Pub. L. 100–418, title I, § 1621(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1263"},"text":"102 Stat. 1263","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0592a28a-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0592a28b-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0592a28c-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2251"},"text":"Section 2251 of this title","children":[],"tail":", referred to in subsec. (b)(2), was amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tI/s1401/a"},"text":"Pub. L. 100–418, title I, § 1401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1225"},"text":"102 Stat. 1225","children":[],"tail":", and as so amended does not contain a subsec. (d). See "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2252/f"},"text":"section 2252(f) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2412"},"text":"Section 2412 of this title","children":[],"tail":", referred to in subsec. (b)(3), was amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tI/s1301/a"},"text":"Pub. L. 100–418, title I, § 1301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1168"},"text":"102 Stat. 1168","children":[],"tail":", and as so amended the provisions of subsec. (b)(2) of section 2412 are contained in subsec. (a)(4)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0592a28d-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/s1621/a/1"},"text":"Pub. L. 100–418, § 1621(a)(1)","children":[],"tail":", amended subsec. (a) generally. Prior to amendment, subsec. (a) read as follows: “The President shall establish an interagency organization to assist him in carrying out the functions vested in him by this subchapter and sections 2251, 2252, and 2253 of this title. Such organization shall, in addition to the Special Representative for Trade Negotiations, be composed of the heads of such departments and of such other officers as the President shall designate. It shall meet at such times and with respect to such matters as the President or the chairman of the organization shall direct. The organization may invite the participation in its activities of any agency not represented in the organization when matters of interest to such agency are under consideration.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/s1621/a/2"},"text":"Pub. L. 100–418, § 1621(a)(2)","children":[],"tail":", inserted at end: “In carrying out its functions under this subsection, the organization shall take into account the advice of the congressional advisers and private sector advisory committees, as well as that of any committee or other body established to advise the department, agency, or office which a member of the organization heads.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Subsecs. (b)(3), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39"},"text":"Pub. L. 96–39","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2412/b/2"},"text":"section 2412(b)(2) of this title","children":[],"tail":"” for “section 2411(c) and (d) of this title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/s602/b/1"},"text":"Pub. L. 93–618, § 602(b)(1)","children":[],"tail":", substituted reference to sections 2251, 2252, and 2253 of this title for reference to sections 1981 and 1982 of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/s602/b/2"},"text":"Pub. L. 93–618, § 602(b)(2)","children":[],"tail":", (3), substituted “reports submitted to him” for “reports with respect to tariff adjustment submitted to him” and “"},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2251/d"},"text":"section 2251(d) of this title","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1901/e"},"text":"section 1901(e) of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/s602/b/4"},"text":"Pub. L. 93–618, § 602(b)(4)","children":[],"tail":", (5), substituted “hearings held pursuant to” for hearings concerning foreign import restrictions held pursuant to” and “section 2411(c) and (d) of this title” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1882/d"},"text":"section 1882(d) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/s602/b/5"},"text":"Pub. L. 93–618, § 602(b)(5)","children":[],"tail":", substituted “section 2411(c) and (d) of this title” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1882/d"},"text":"section 1882(d) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/s171/b"},"text":"Pub. L. 93–618, § 171(b)","children":[],"tail":", substituted “United States International Trade Commission” for “United States Tariff Commission”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0592a28e-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0592a28f-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1979 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39"},"text":"Pub. L. 96–39","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/39/s903"},"text":"section 903 of Pub. L. 96–39","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2411"},"text":"section 2411 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0592a290-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Establishment of Interagency Group","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions establishing an interagency group within the interagency organization established under this section, relating to the implementation of chapter 10 of the United States-Mexico-Canada Agreement, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4582/c/2"},"text":"section 4582(c)(2) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"For provisions establishing an interagency group within the interagency organization established under this section, relating to the implementation of chapters 18 and 19 of the United States-Canada Free-Trade Agreement, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/449/s405"},"text":"section 405 of Pub. L. 100–449","children":[],"tail":", set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2112"},"text":"section 2112 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0592a291-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Sense of Congress Respecting Role of Interagency Organization","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/tI/s1621/b"},"text":"Pub. L. 100–418, title I, § 1621(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1264"},"text":"102 Stat. 1264","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/418/tI/s1621/b"},"text":"“It is the sense of Congress that the interagency organization established under subsection (a) [amending this section] should be the principal interagency forum within the executive branch on international trade policy matters.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id0592a292-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id0592a293-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions From East-West Foreign Trade Board","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"East-West Foreign Trade Board, which was established by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/tIV/s411"},"text":"Pub. L. 93–618, title IV, § 411","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2065"},"text":"88 Stat. 2065","children":[],"tail":", and classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2441"},"text":"section 2441 of this title","children":[],"tail":", abolished by Reorg. Plan No. 3 of 1979, § 6, "},{"tag":"ref","attrib":{"href":"/us/stat/44/69275"},"text":"44 Stat. 69275","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/1381"},"text":"93 Stat. 1381","children":[],"tail":", eff. "},{"tag":"date","attrib":{"date":"1980-01-02"},"text":"Jan. 2, 1980","children":[],"tail":", as provided by section 1–107(a) of Ex. Ord. No. 12188, "},{"tag":"date","attrib":{"date":"1980-01-02"},"text":"Jan. 2, 1980","children":[],"tail":", 45 F.R. 993, set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2171"},"text":"section 2171 of this title","children":[],"tail":", and functions of Board under subsecs. (a) and (b) of "},{"tag":"ref","attrib":{"href":"/us/pl/93/618/s411"},"text":"section 411 of Pub. L. 93–618","children":[],"tail":" transferred to interagency organization established under this section by section 5(e) of Reorg. Plan No. 3 of 1979. See "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2441"},"text":"section 2441 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0592a294-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Trade Policy Committee","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to Trade Policy Committee, see section 3 of Ex. Ord. No. 11846, ","children":[{"tag":"date","attrib":{"date":"1975-03-27"},"text":"Mar. 27, 1975","children":[],"tail":", 40 F.R. 14291, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2111"},"text":"section 2111 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
