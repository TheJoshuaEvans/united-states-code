{"tag":"section","attrib":{"id":"id063e4c2c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3910"},"text":null,"children":[{"tag":"num","attrib":{"value":"3910"},"text":"§ 3910.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Kimberley Process Implementation Coordinating Committee","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The President shall establish a Kimberley Process Implementation Coordinating Committee to coordinate the implementation of this chapter. The Committee shall be composed of the following individuals or their designees:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id063e4c2d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3910/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Treasury and the Secretary of State, who shall be co-chairpersons.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id063e4c2e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3910/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id063e4c2f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3910/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Trade Representative.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id063e4c30-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3910/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Homeland Security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attri