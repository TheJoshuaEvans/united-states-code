{"tag":"section","attrib":{"id":"id06182731-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3723"},"text":null,"children":[{"tag":"num","attrib":{"value":"3723"},"text":"§ 3723.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Free trade agreements with sub-Saharan African countries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id06182732-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3723/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Declaration of policy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Congress declares that free trade agreements should be negotiated, where feasible, with interested countries in sub-Saharan Africa, in order to serve as the catalyst for increasing trade between the United States and sub-Saharan Africa and increasing private sector investment in sub-Saharan Africa.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id06182733-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3723/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan requirement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id06182734-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3723/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President, taking into account the provisions of the treaty establishing the African Economic Community and the willingness of the governments of sub-Saharan African countries to engage in negotiations to enter into free trade agreements, shall develop a plan for the purpose of negotiating and entering into one or more trade agreements with interested beneficiary sub-Saharan African countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06182735-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3723/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements of plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The plan shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id06182736-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3723/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The specific objectives of the United States with respect to negotiations described in paragraph (1) and a suggested timetable for achieving those objectives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06182737-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3723/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The benefits to both the United States and the relevant sub-Saharan African countries with respect to the applicable free trade agreement or agreements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06182738-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3723/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A mutually agreed-upon timetable for the negotiations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06182739-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3723/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The implications for and the role of regional and sub-regional organizations in sub-Saharan Africa with respect to such free trade agreement or agreements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0618273a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3723/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject matter anticipated to be covered by the negotiations and United States laws, programs, and policies, as well as the laws of participating eligible African countries and existing bilateral and multilateral and economic cooperation and trade agreements, that may be affected by the agreement or agreements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0618273b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3723/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Procedures to ensure the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0618273c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3723/b/2/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Adequate consultation with the Congress and the private sector during the negotiations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0618273d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3723/b/2/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Consultation with the Congress regarding all matters relating to implementation of the agreement or agreements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0618273e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3723/b/2/F/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Approval by the Congress of the agreement or agreements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0618273f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3723/b/2/F/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Adequate consultations with the relevant African governments and African regional and subregional intergovernmental organizations during the negotiation of the agreement or agreements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id06182740-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3723/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 12 months after ","children":[{"tag":"date","attrib":{"date":"2000-05-18"},"text":"May 18, 2000","children":[],"tail":", the President shall prepare and transmit to the Congress a report containing the plan developed pursuant to subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id06182741-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/200/tI/s116"},"text":"Pub. L. 106–200, title I, § 116","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-05-18"},"text":"May 18, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/266"},"text":"114 Stat. 266","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id06182742-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id06182743-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id06182744-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Coordination of Efforts To Develop Free Trade Agreements With Sub-Saharan African Countries","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tXII/s1293"},"text":"Pub. L. 114–328, div. A, title XII, § 1293","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2560"},"text":"130 Stat. 2560","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tXII/s1289"},"text":"Pub. L. 115–232, div. A, title XII, § 1289","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2081"},"text":"132 Stat. 2081","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/232/dA/tXII/s1289"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination Between the United States Trade Representative and Other Agencies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The United States Trade Representative shall consult and coordinate with other relevant Federal agencies to assist countries identified under paragraph (1) of section 110(b) of the Trade Preferences Extension Act of 2015 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/27"},"text":"Public Law 114–27","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/129/370"},"text":"129 Stat. 370","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3705"},"text":"19 U.S.C. 3705","children":[],"tail":" note) in the most recent report required by that section, including through the deployment of resources from those agencies to such countries and through trade capacity building, in addressing the plan developed under paragraph (3) of that section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination of USAID With Free Trade Agreement Policy.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of funds","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds made available to the United States Agency for International Development under section 496 of the Foreign Assistance Act of 1961 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2293"},"text":"22 U.S.C. 2293","children":[],"tail":") after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":"] may be used, in consultation with the United States Trade Representative—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist eligible countries, including by deploying resources to such countries, in addressing the plan developed under section 116(b) of the African Growth and Opportunity Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3723/b"},"text":"19 U.S.C. 3723(b)","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist eligible countries in the implementation of the commitments of those countries under agreements with the United States and under the WTO Agreement (as defined in section 2(9) of the Uruguay Round Agreements Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3501/9"},"text":"19 U.S.C. 3501(9)","children":[],"tail":")) and agreements annexed to the WTO Agreement."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible country","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term ‘eligible country’ means a sub-Saharan African country that receives—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" benefits under the African Growth and Opportunity Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3701"},"text":"19 U.S.C. 3701","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funding from the United States Agency for International Development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sub-saharan african country","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘sub-Saharan African country’ has the meaning given that term in section 107 of the African Growth and Opportunity Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3706"},"text":"19 U.S.C. 3706","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination With Millennium Challenge Corporation.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"After the date of the enactment of this subsection [","children":[{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":"], with respect to those countries identified under section 110(b)(1) of the Trade Preferences Extension Act of 2015 ("},{"tag":"ref","attrib":{"href":"/us/pl/114/27"},"text":"Public Law 114–27","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/129/370"},"text":"129 Stat. 370","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3705"},"text":"19 U.S.C. 3705","children":[],"tail":" note) that also meet the country description in paragraph (2), the United States Trade Representative shall consult and coordinate with the Millennium Challenge Corporation and the United States Agency for International Development for the purpose of developing and carrying out the plan required by section 116(b) of the African Growth and Opportunity Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3723/b"},"text":"19 U.S.C. 3723(b)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Country description","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A country is described in this paragraph if the country—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has entered into a Millennium Challenge Compact pursuant to section 609 of the Millennium Challenge Act of 2003 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7708"},"text":"22 U.S.C. 7708","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is selected by the Board of Directors of the Millennium Challenge Corporation under subsection (c) of section 607 of that Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7706"},"text":"22 U.S.C. 7706","children":[],"tail":") from among the countries determined to be eligible countries under subsection (a) of that section.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
