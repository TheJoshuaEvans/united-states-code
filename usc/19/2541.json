{"tag":"section","attrib":{"id":"id05ef8fe6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2541"},"text":null,"children":[{"tag":"num","attrib":{"value":"2541"},"text":"§ 2541.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions of Trade Representative","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05ef8fe7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2541/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Trade Representative shall coordinate the consideration of international trade policy issues that arise as a result of, and shall develop international trade policy as it relates to, the implementation of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05ef8fe8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2541/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Negotiating functions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Trade Representative has responsibility for coordinating United States discussions and negotiations with foreign countries for the purpose of establishing mutual arrangements with respect to standards-related activities. In carrying out this responsibility, the Trade Representative shall inform and consult with any Federal agency having expertise in the matters under discussion and negotiation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05ef8fe9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2541/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For provisions of law regarding general authority of the Trade Representative with respect to trade agreements, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2171"},"text":"section 2171 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05ef8fea-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39/tIV/s411"},"text":"Pub. L. 96–39, title IV, § 411","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/243"},"text":"93 Stat. 243","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/182/tIII/s351/b/2"},"text":"Pub. L. 103–182, title III, § 351(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-08"},"text":"Dec. 8, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2122"},"text":"107 Stat. 2122","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/295/s21/b/1"},"text":"Pub. L. 104–295, § 21(b)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3529"},"text":"110 Stat. 3529","children":[],"tail":", 3530.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05ef8feb-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05ef8fec-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id05ef8fed-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/295/s21/b/1"},"text":"Pub. L. 104–295, § 21(b)(1)","children":[],"tail":", amended directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/103/182/s351/b/2"},"text":"Pub. L. 103–182, § 351(b)(2)","children":[],"tail":". See 1993 Amendment notes below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/295/s21/b/2"},"text":"Pub. L. 104–295, § 21(b)(2)","children":[],"tail":", substituted “Trade Representative” for “Special Representatives”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/182/s351/b/2/B"},"text":"Pub. L. 103–182, § 351(b)(2)(B)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/104/295/s21/b/1"},"text":"Pub. L. 104–295, § 21(b)(1)","children":[],"tail":", substituted “Trade Representative” for “Special Representative” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/182/s351/b/2/A"},"text":"Pub. L. 103–182, § 351(b)(2)(A)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/104/295/s21/b/1"},"text":"Pub. L. 104–295, § 21(b)(1)","children":[],"tail":", substituted “Trade Representative” for “Special Representative” wherever appearing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
