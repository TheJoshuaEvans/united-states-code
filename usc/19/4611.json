{"tag":"section","attrib":{"id":"id065d4582-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4611"},"text":null,"children":[{"tag":"num","attrib":{"value":"4611"},"text":"§ 4611.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation in joint reviews with Canada and Mexico regarding extension of the term of the USMCA and other action regarding the USMCA","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id065d4583-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4611/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Pursuant to the requirements of this section, the President shall consult with the appropriate congressional committees and stakeholders before each joint review, including consultation with respect to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id065d4584-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4611/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any recommendation for action to be proposed at the review; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065d4585-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4611/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the decision whether or not to confirm that the United States wishes to extend the USMCA.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id065d4586-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4611/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultations with Congress and stakeholders","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id065d4587-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4611/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication and public hearing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At least 270 days before a joint review commences, the Trade Representative shall publish in the Federal Register a notice regarding the joint review and shall, as soon as possible following such publication, provide opportunity for the presentation of views relating to the operation of the USMCA, including a public hearing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065d4588-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4611/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"At least 180 days before a 6-year joint review under article 34.7 of the USMCA commences, the Trade Representative shall report to the appropriate congressional committees regarding—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id065d4589-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4611/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the assessment of the Trade Representative with respect to the operation of the USMCA;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id065d458a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4611/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the precise recommendation for action to be proposed at the review and the position of the United States with respect to whether to extend the term of the USMCA;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id065d458b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4611/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" what, if any, prior efforts have been made to resolve any concern that underlies that recommendation or position; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id065d458c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4611/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the views of the advisory committees established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2155"},"text":"section 2155 of this title","children":[],"tail":" regarding that recommendation or position."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id065d458d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4611/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequent action to address lack of agreement on term extension","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id065d458e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4611/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If, as part of a joint review, any USMCA country does not confirm that the country wishes to extend the term of the USMCA under article 34.7.3 of the USMCA, at least 70 days before any subsequent annual joint review meeting conducted as required under article 34.7 of the USMCA, the Trade Representative shall report to the appropriate congressional committees regarding—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id065d458f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4611/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any reason offered by a USMCA country regarding why the country is unable to agree to extend the term of the USMCA;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id065d4590-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4611/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the progress that has been made in efforts to achieve resolution of the concerns of that country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id065d4591-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4611/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any proposed action that the Trade Representative intends to raise during the meeting; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id065d4592-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4611/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the views of the advisory committees established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2155"},"text":"section 2155 of this title","children":[],"tail":" regarding the reasons described in subparagraph (A) and any proposed action under subparagraph (C)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065d4593-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4611/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Trade Representative shall also provide detailed and timely information in response to any questions posed by the appropriate congressional committees with respect to any meeting described in paragraph (1), including by submitting to those committees copies of any proposed text that the Trade Representative plans to submit to the other parties to the meeting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id065d4594-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4611/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional engagement after joint review","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id065d4595-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4611/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 20 days after the USMCA countries have met for a joint review, the Trade Representative shall brief the appropriate congressional committees regarding the positions expressed by the countries during the joint review and what, if any, actions were agreed to by the countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065d4596-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4611/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continued engagement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After a joint review, the Trade Representative shall keep the appropriate congressional committees timely apprised of any developments arising out of or related to the review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id065d4597-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4611/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id065d4598-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4611/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “joint review” means a review conducted under the process provided for in article 34.7 of the USMCA relating to extension of the term of the USMCA.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065d4599-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4611/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" USMCA country","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “USMCA country” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4531/a"},"text":"section 4531(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id065d459a-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113/tVI/s611"},"text":"Pub. L. 116–113, title VI, § 611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-01-29"},"text":"Jan. 29, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/79"},"text":"134 Stat. 79","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id065d459b-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id065d459c-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id065d459d-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Proc. No. 10053, par. (14), ","children":[{"tag":"date","attrib":{"date":"2020-06-29"},"text":"June 29, 2020","children":[],"tail":", 85 F.R. 39826, authorized the United States Trade Representative to exercise the function assigned to the President under subsec. (a) of this section to consult with the appropriate congressional committees and stakeholders regarding joint reviews under article 34.7 of the USMCA."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
