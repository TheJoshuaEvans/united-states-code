{"tag":"section","attrib":{"id":"id064a336a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4208"},"text":null,"children":[{"tag":"num","attrib":{"value":"4208"},"text":"§ 4208.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interests of small businesses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id064a336b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4208/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the sense of Congress that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id064a336c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4208/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Trade Representative should facilitate participation by small businesses in the trade negotiation process; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064a336d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4208/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the functions of the Office of the United States Trade Representative relating to small businesses should continue to be reflected in the title of the Assistant United States Trade Representative assigned the responsibility for small businesses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id064a336e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4208/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration of small business interests","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant United States Trade Representative for Small Business, Market Access, and Industrial Competitiveness shall be responsible for ensuring that the interests of small businesses are considered in all trade negotiations in accordance with the objective described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4201/a/8"},"text":"section 4201(a)(8) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id064a336f-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/26/tI/s109"},"text":"Pub. L. 114–26, title I, § 109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-06-29"},"text":"June 29, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/356"},"text":"129 Stat. 356","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
