{"tag":"section","attrib":{"id":"id056095c1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1590"},"text":null,"children":[{"tag":"num","attrib":{"value":"1590"},"text":"§ 1590.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aviation smuggling","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id056095c2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1590/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is unlawful for the pilot of any aircraft to transport, or for any individual on board any aircraft to possess, merchandise knowing, or intending, that the merchandise will be introduced into the United States contrary to law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id056095c3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1590/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sea transfers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is unlawful for any person to transfer merchandise between an aircraft and a vessel on the high seas or in the customs waters of the United States if such person has not been authorized by the Secretary to make such transfer and—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id056095c4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1590/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" either—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id056095c5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1590/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aircraft is owned by a citizen of the United States or is registered in the United States, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id056095c6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1590/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel is a vessel of the United States (within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1703/b"},"text":"section 1703(b) of this title","children":[],"tail":"), or"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id056095c7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1590/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regardless of the nationality of the vessel or aircraft, such transfer is made under circumstances indicating the intent to make it possible for such merchandise, or any part thereof, to be introduced into the United States unlawfully.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id056095c8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1590/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who violates any provision of this section is liable for a civil penalty equal to twice the value of the merchandise involved in the violation, but not less than $10,000. The value of any controlled substance included in the merchandise shall be determined in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1497/b"},"text":"section 1497(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id056095c9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1590/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal penalties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to being liable for a civil penalty under subsection (c), any person who intentionally commits, or attempts or conspires to commit, a violation of any provision of this section is, upon conviction—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id056095ca-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1590/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" liable for a fine of not more than $10,000 or imprisonment for not more than 5 years, or both, if none of the merchandise involved was a controlled substance; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id056095cb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1590/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" liable for a fine of not more than $250,000 or imprisonment for not more than 20 years, or both, if any of the merchandise involved was a controlled substance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id056095cc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1590/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Seizure and forfeiture","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id056095cd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1590/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), a vessel or aircraft used in connection with, or in aiding or facilitating, any violation of this section, whether or not any person is charged in connection with such violation, may be seized and forfeited in accordance with the customs laws.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id056095ce-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1590/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraph (1) does not apply to a vessel or aircraft operated as a common carrier.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id056095cf-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1590/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Merchandise” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As used in this section, the term “merchandise” means only merchandise the importation of which into the United States is prohibited or restricted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id056095d0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1590/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of aircraft","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “aircraft”—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id056095d1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1590/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s40102"},"text":"section 40102 of title 49","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id056095d2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1590/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes a vehicle described in section 103.1 of title 14, Code of Federal Regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id056095d3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1590/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intent of transfer of merchandise","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of imposing civil penalties under this section, any of the following acts, when performed within 250 miles of the territorial sea of the United States, shall be prima facie evidence that the transportation or possession of merchandise was unlawful and shall be presumed to constitute circumstances indicating that the purpose of the transfer is to make it possible for such merchandise, or any part thereof, to be introduced into the United States unlawfully, and for purposes of subsection (e) or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1595a"},"text":"section 1595a of this title","children":[],"tail":", shall be prima facie evidence that an aircraft or vessel was used in connection with, or to aid or facilitate, a violation of this section:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id056095d4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1590/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The operation of an aircraft or a vessel without lights during such times as lights are required to be displayed under applicable law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id056095d5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1590/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The presence on an aircraft of an auxiliary fuel tank which is not installed in accordance with applicable law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id056095d6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1590/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The failure to identify correctly—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id056095d7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1590/h/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel by name or country of registration, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id056095d8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1590/h/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aircraft by registration number and country of registration,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"when requested to do so by a customs officer or other government authority.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id056095d9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1590/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The external display of false registration numbers, false country of registration, or, in the case of a vessel, false vessel name.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id056095da-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1590/h/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The presence on board of unmanifested merchandise, the importation of which is prohibited or restricted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id056095db-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1590/h/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The presence on board of controlled substances which are not manifested or which are not accompanied by the permits or licenses required under Single Convention on Narcotic Drugs or other international treaty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id056095dc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1590/h/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The presence of any compartment or equipment which is built or fitted out for smuggling.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id056095dd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1590/h/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The failure of a vessel to stop when hailed by a customs officer or other government authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id056095de-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title IV, § 590, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/570/tIII/s3120"},"text":"Pub. L. 99–570, title III, § 3120","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-84"},"text":"100 Stat. 3207–84","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/93/s2/a"},"text":"Pub. L. 112–93, § 2(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2012-02-10"},"text":"Feb. 10, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/8"},"text":"126 Stat. 8","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id056095df-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id056095e0-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id056095e1-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1590, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497/tIV/s590"},"text":"act June 17, 1930, ch. 497, title IV, § 590","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/750"},"text":"46 Stat. 750","children":[],"tail":", related to false drawback claims, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645/s21"},"text":"act June 25, 1948, ch. 645, § 21","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/862"},"text":"62 Stat. 862","children":[],"tail":", eff. "},{"tag":"date","attrib":{"date":"1948-09-01"},"text":"Sept. 1, 1948","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s550"},"text":"section 550 of Title 18","children":[],"tail":", Crimes and Criminal Procedure."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id056095e2-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/93/s2/b"},"text":"Pub. L. 112–93, § 2(b)","children":[],"tail":", inserted “, or attempts or conspires to commit,” after “commits” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (g), (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/93/s2/a"},"text":"Pub. L. 112–93, § 2(a)","children":[],"tail":", added subsec. (g) and redesignated former subsec. (g) as (h)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id056095e3-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id056095e4-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/93/s2/c"},"text":"Pub. L. 112–93, § 2(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-10"},"text":"Feb. 10, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/8"},"text":"126 Stat. 8","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/93/s2/c"},"text":"“The amendments made by this section [amending this section] apply with respect to violations of any provision of section 590 of the Tariff Act of 1930 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1590"},"text":"19 U.S.C. 1590","children":[],"tail":"] on or after the 30th day after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2012-02-10"},"text":"Feb. 10, 2012","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id056095e5-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id056095e6-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Territorial Sea of United States","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For extension of territorial sea of United States, see Proc. No. 5928, set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1331"},"text":"section 1331 of Title 43","children":[],"tail":", Public Lands."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
