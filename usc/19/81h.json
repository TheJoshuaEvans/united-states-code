{"tag":"section","attrib":{"id":"id050f68e4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s81h"},"text":null,"children":[{"tag":"num","attrib":{"value":"81h"},"text":"§ 81h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Board shall prescribe such rules and regulations not inconsistent with the provisions of this chapter or the rules and regulations of the Secretary of the Treasury made hereunder and as may be necessary to carry out this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id050f68e5-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-18/ch590/s8"},"text":"June 18, 1934, ch. 590, § 8","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/1000"},"text":"48 Stat. 1000","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
