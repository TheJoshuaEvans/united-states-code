{"tag":"section","attrib":{"id":"id060eb129-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3522"},"text":null,"children":[{"tag":"num","attrib":{"value":"3522"},"text":"§ 3522.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liquidation or reliquidation and refund of duty paid on certain entries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id060eb12a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3522/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liquidation or reliquidation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1514"},"text":"section 1514 of this title","children":[],"tail":" or any other provision of law, and subject to subsection (b), the Secretary of the Treasury shall liquidate or reliquidate the entries listed or otherwise described in subsection (c) and refund any duty or excess duty that was paid, as provided in subsection (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id060eb12b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3522/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requests","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Liquidation or reliquidation may be made under subsection (a) with respect to an entry only if a request therefor is filed with the Customs Service, within 180 days after the date on which the WTO Agreement enters into force with respect to the United States, that contains sufficient information to enable the Customs Service—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id060eb12c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3522/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to locate the entry; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060eb12d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3522/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reconstruct the entry if it cannot be located.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id060eb12e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3522/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entries","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The entries referred to in subsection (a) are as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id060eb12f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3522/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agglomerated stone tiles","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any goods—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id060eb130-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3522/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which the importer claimed or would have claimed entry under subheading 6810.19.12 of the HTS on or after ","children":[{"tag":"date","attrib":{"date":"1990-10-01"},"text":"October 1, 1990","children":[],"tail":", and before the effective date of a proclamation issued by the President under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3513/a"},"text":"section 3513(a) of this title","children":[],"tail":" with respect to items under such subheading in order to carry out Schedule XX, or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id060eb131-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3522/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entered on or after ","children":[{"tag":"date","attrib":{"date":"1989-01-01"},"text":"January 1, 1989","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"1990-10-01"},"text":"October 1, 1990","children":[],"tail":", for which entry would have been claimed under subheading 6810.19.12 of the HTS on or after "},{"tag":"date","attrib":{"date":"1990-10-01"},"text":"October 1, 1990","children":[],"tail":","}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be liquidated or reliquidated as if the wording of that subheading were “Of stone agglomerated with binders other than cement”, and the Secretary of the Treasury shall refund any excess duties paid with respect to such entries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060eb132-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3522/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clomiphene citrate","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id060eb133-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3522/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any entry, or withdrawal from warehouse for consumption, of goods described in heading 9902.29.95 of the HTS (relating to clomiphene citrate) which was made after ","children":[{"tag":"date","attrib":{"date":"1988-12-31"},"text":"December 31, 1988","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"1993-01-01"},"text":"January 1, 1993","children":[],"tail":", and with respect to which there would have been no duty if the reference to subheading “2922.19.15” in such heading were a reference to subheading “2922.19.15 or any subheading of chapter 30” at the time of such entry or withdrawal, shall be liquidated or reliquidated as free of duty."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id060eb134-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3522/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Treasury shall refund any duties paid with respect to entries described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0610fa25-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/tI/s113"},"text":"Pub. L. 103–465, title I, § 113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4826"},"text":"108 Stat. 4826","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0610fa26-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0610fa27-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0610fa28-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date on which the WTO Agreement enters into force with respect to the United States (","children":[{"tag":"date","attrib":{"date":"1995-01-01"},"text":"Jan. 1, 1995","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/s116/a"},"text":"section 116(a) of Pub. L. 103–465","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3521"},"text":"section 3521 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id0610fa29-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions, personnel, assets, and liabilities of the United States Customs Service of the Department of the Treasury, including functions of the Secretary of the Treasury relating thereto, to the Secretary of Homeland Security, and for treatment of related references, see sections 203(1), 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":". For establishment of U.S. Customs and Border Protection in the Department of Homeland Security, treated as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" as of "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s211"},"text":"section 211 of Title 6","children":[],"tail":", as amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/114/125"},"text":"Pub. L. 114–125","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/114/125/s802/b"},"text":"section 802(b) of Pub. L. 114–125","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s211"},"text":"section 211 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id0610fa2a-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0610fa2b-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Uruguay Round Agreements: Entry Into Force","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Uruguay Round Agreements, including the World Trade Organization Agreement and agreements annexed to that Agreement, as referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3511/d"},"text":"section 3511(d) of this title","children":[],"tail":", entered into force with respect to the United States on "},{"tag":"date","attrib":{"date":"1995-01-01"},"text":"Jan. 1, 1995","children":[],"tail":". See note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3511"},"text":"section 3511 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
