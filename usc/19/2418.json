{"tag":"section","attrib":{"id":"id05da33da-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2418"},"text":null,"children":[{"tag":"num","attrib":{"value":"2418"},"text":"§ 2418.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Request for information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05da33db-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2418/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon receipt of written request therefor from any person, the Trade Representative shall make available to that person information (other than that to which confidentiality applies) concerning—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05da33dc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2418/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature and extent of a specific trade policy or practice of a foreign country with respect to particular goods, services, investment, or intellectual property rights, to the extent that such information is available to the Trade Representative or other Federal agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05da33dd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2418/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" United States rights under any trade agreement and the remedies which may be available under that agreement and under the laws of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05da33de-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2418/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" past and present domestic and international proceedings or actions with respect to the policy or practice concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05da33df-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2418/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" If information not available","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If information that is requested by a person under subsection (a) is not available to the Trade Representative or other Federal agencies, the Trade Representative shall, within 30 days after receipt of the request—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05da33e0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2418/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" request the information from the foreign government; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05da33e1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2418/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" decline to request the information and inform the person in writing of the reasons for refusal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05da33e2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2418/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain business information not made available","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05da33e3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2418/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in paragraph (2), and notwithstanding any other provision of law (including ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":"), no information requested and received by the Trade Representative in aid of any investigation under this subchapter shall be made available to any person if—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05da33e4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2418/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the person providing such information certifies that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id05da33e5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2418/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such information is business confidential,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05da33e6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2418/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the disclosure of such information would endanger trade secrets or profitability, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05da33e7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2418/c/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such information is not generally available;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05da33e8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2418/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Trade Representative determines that such certification is well-founded; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05da33e9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2418/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent required in regulations prescribed by the Trade Representative, the person providing such information provides an adequate nonconfidential summary of such information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05da33ea-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2418/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Trade Representative may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05da33eb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2418/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use such information, or make such information available (in his own discretion) to any employee of the Federal Government for use, in any investigation under this subchapter, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05da33ec-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2418/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may make such information available to any other person in a form which cannot be associated with, or otherwise identify, the person providing the information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05da33ed-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/tIII/s308"},"text":"Pub. L. 93–618, title III, § 308","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tI/s1301/a"},"text":"Pub. L. 100–418, title I, § 1301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1175"},"text":"102 Stat. 1175","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05da33ee-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id05da33ef-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id05da33f0-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to petitions filed, and investigations initiated, under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2412"},"text":"section 2412 of this title","children":[],"tail":" on or after "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", and petitions filed, and investigations initiated, before "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", if by such date no decision had been made under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2414"},"text":"section 2414 of this title","children":[],"tail":" regarding the petition or investigation, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/s1301/c"},"text":"section 1301(c) of Pub. L. 100–418","children":[],"tail":", set out as an Effective Date of 1988 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2411"},"text":"section 2411 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
