{"tag":"section","attrib":{"id":"id0602a287-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2902"},"text":null,"children":[{"tag":"num","attrib":{"value":"2902"},"text":"§ 2902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trade agreement negotiating authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0602a288-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2902/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements regarding tariff barriers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0602a289-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2902/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Whenever the President determines that one or more existing duties or other import restrictions of any foreign country or the United States are unduly burdening and restricting the foreign trade of the United States and that the purposes, policies, and objectives of this title will be promoted thereby, the President—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0602a28a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2902/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before ","children":[{"tag":"date","attrib":{"date":"1993-06-01"},"text":"June 1, 1993","children":[],"tail":", may enter into trade agreements with foreign countries; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0602a28b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2902/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may, subject to paragraphs (2) through (5), proclaim—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0602a28c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2902/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such modification or continuance of any existing duty,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0602a28d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2902/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such continuance of existing duty-free or excise treatment, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0602a28e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2902/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such additional duties;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"as he determines to be required or appropriate to carry out any such trade agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0602a28f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2902/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" No proclamation may be made under subsection (a) that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0602a290-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2902/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduces any rate of duty (other than a rate of duty that does not exceed 5 percent ad valorem on ","children":[{"tag":"date","attrib":{"date":"1988-08-23"},"text":"August 23, 1988","children":[],"tail":") to a rate which is less than 50 percent of the rate of such duty that applies on "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"August 23, 1988","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0602a291-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2902/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increases any rate of duty above the rate that applies on ","children":[{"tag":"date","attrib":{"date":"1988-08-23"},"text":"August 23, 1988","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0602a292-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2902/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0602a293-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2902/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subparagraph (B), the aggregate reduction in the rate of duty on any article which is in effect on any day pursuant to a trade agreement entered into under paragraph (1) shall not exceed the aggregate reduction which would have been in effect on such day if a reduction of 3 percent ad valorem or a reduction of one-tenth of the total reduction, whichever is greater, had taken effect on the effective date of the first reduction proclaimed in paragraph (1) to carry out such agreement with respect to such article.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0602a294-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2902/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No staging under subparagraph (A) is required with respect to a rate reduction that is proclaimed under paragraph (1) for an article of a kind that is not produced in the United States. The United States International Trade Commission shall advise the President of the identity of articles that may be exempted from staging under this subparagraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0602a295-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2902/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the President determines that such action will simplify the computation of reductions under paragraph (3), the President may round an annual reduction by the lesser of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0602a296-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2902/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the difference between the reduction without regard to this paragraph and the next lower whole number; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0602a297-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2902/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one-half of 1 percent ad valorem.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0602a298-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2902/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No reduction in a rate of duty under a trade agreement entered into under subsection (a) on any article may take effect more than 10 years after the effective date of the first reduction under paragraph (1) that is proclaimed to carry out the trade agreement with respect to such article.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0602a299-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2902/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A rate of duty reduction or increase that may not be proclaimed by reason of paragraph (2) may take effect only if a provision authorizing such reduction or increase is included within an implementing bill provided for under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2903"},"text":"section 2903 of this title","children":[],"tail":" and that bill is enacted into law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0602a29a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2902/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements regarding nontariff barriers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0602a29b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2902/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Whenever the President determines that any barrier to, or other distortion of, international trade—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0602a29c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2902/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unduly burdens or restricts the foreign trade of the United States or adversely affects the United States economy; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0602a29d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2902/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the imposition of any such barrier or distortion is likely to result in such a burden, restriction, or effect;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"and that the purposes, policies, and objectives of this title will be promoted thereby, the President may, before ","children":[{"tag":"date","attrib":{"date":"1993-06-01"},"text":"June 1, 1993","children":[],"tail":", enter into a trade agreement with foreign countries providing for—"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0602a29e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2902/b/1/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reduction or elimination of such barrier or other distortion; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0602a29f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2902/b/1/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the prohibition of, or limitations on the imposition of, such barrier or other distortion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0602a2a0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2902/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A trade agreement may be entered into under this subsection only if such agreement makes progress in meeting the applicable objectives described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2901"},"text":"section 2901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0602a2a1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2902/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bilateral agreements regarding tariff and nontariff barriers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0602a2a2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2902/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Before ","children":[{"tag":"date","attrib":{"date":"1993-06-01"},"text":"June 1, 1993","children":[],"tail":", the President may enter into bilateral trade agreements with foreign countries that provide for the elimination or reduction of any duty imposed by the United States. A trade agreement entered into under this paragraph may also provide for the reduction or elimination of barriers to, or other distortions of, the international trade of the foreign country or the United States."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0602a2a3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2902/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of law, no trade benefit shall be extended to any country by reason of the extension of any trade benefit to another country under a trade agreement entered into under paragraph (1) with such other country.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0602a2a4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2902/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A trade agreement may be entered into under paragraph (1) with any foreign country only if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0602a2a5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2902/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agreement makes progress in meeting the applicable objectives described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2901"},"text":"section 2901 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0602a2a6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2902/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such foreign country requests the negotiation of such an agreement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0602a2a7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2902/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the President, at least 60 days before the date notice is provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2903/a/1/A"},"text":"section 2903(a)(1)(A) of this title","children":[],"tail":"—"}],"tail":null},{"tag":"clause","attrib":{"id":"id0602a2a8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2902/c/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides written notice of such negotiations to the Committee on Finance of the Senate and the Committee on Ways and Means of the House of Representatives, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0602a2a9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2902/c/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consults with such committees regarding the negotiation of such agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0602a2aa-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2902/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The 60-day period of time described in paragraph (3)(C) shall be computed in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2903/e"},"text":"section 2903(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0602a2ab-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2902/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In any case in which there is an inconsistency between any provision of this Act and any bilateral free trade area agreement that entered into force and effect with respect to the United States before ","children":[{"tag":"date","attrib":{"date":"1987-01-01"},"text":"January 1, 1987","children":[],"tail":", the provision shall not apply with respect to the foreign country that is party to that agreement."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0602a2ac-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2902/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with Congress before agreements entered into","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0602a2ad-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2902/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Before the President enters into any trade agreement under subsection (b) or (c), the President shall consult with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0602a2ae-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2902/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Ways and Means of the House of Representatives and the Committee on Finance of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0602a2af-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2902/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each other committee of the House and the Senate, and each joint committee of the Congress, which has jurisdiction over legislation involving subject matters which would be affected by the trade agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0602a2b0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2902/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The consultation under paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0602a2b1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2902/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature of the agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0602a2b2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2902/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how and to what extent the agreement will achieve the applicable purposes, policies, and objectives of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0602a2b3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2902/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all matters relating to the implementation of the agreement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2903"},"text":"section 2903 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0602a2b4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2902/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If it is proposed to implement two or more trade agreements in a single implementing bill under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2903"},"text":"section 2903 of this title","children":[],"tail":", the consultation under paragraph (1) shall include the desirability and feasibility of such proposed implementation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0602a2b5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2902/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special provisions regarding Uruguay Round trade negotiations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0602a2b6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2902/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding the time limitations in subsections (a) and (b), if the Uruguay Round of multilateral trade negotiations under the auspices of the General Agreement on Tariffs and Trade has not resulted in trade agreements by ","children":[{"tag":"date","attrib":{"date":"1993-05-31"},"text":"May 31, 1993","children":[],"tail":", the President may, during the period after "},{"tag":"date","attrib":{"date":"1993-05-31"},"text":"May 31, 1993","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"1994-04-16"},"text":"April 16, 1994","children":[],"tail":", enter into, under subsections (a) and (b) of this section, trade agreements resulting from such negotiations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0602a2b7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2902/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of tariff proclamation authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No proclamation under subsection (a) to carry out the provisions regarding tariff barriers of a trade agreement that is entered into pursuant to paragraph (1) may take effect before the effective date of a bill that implements the provisions regarding nontariff barriers of a trade agreement that is entered into under such paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0602a2b8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2902/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of implementing and “fast track” procedures","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2903"},"text":"Section 2903 of this title","children":[],"tail":" applies to any trade agreement negotiated under subsection (b) pursuant to paragraph (1), except that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0602a2b9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2902/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in applying subsection (a)(1)(A) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2903"},"text":"section 2903 of this title","children":[],"tail":" to any such agreement, the phrase “at least 120 calendar days before the day on which he enters into the trade agreement (but not later than "},{"tag":"date","attrib":{"date":"1993-12-15"},"text":"December 15, 1993","children":[],"tail":"),” shall be substituted for the phrase “at least 90 calendar days before the day on which he enters into the trade agreement,”; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0602a2ba-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2902/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no provision of subsection (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2903"},"text":"section 2903 of this title","children":[],"tail":" other than paragraph (1)(A) applies to any such agreement and in applying such paragraph, “"},{"tag":"date","attrib":{"date":"1994-04-16"},"text":"April 16, 1994","children":[],"tail":";” shall be substituted for “"},{"tag":"date","attrib":{"date":"1991-06-01"},"text":"June 1, 1991","children":[],"tail":";”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0602a2bb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2902/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory committee reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The report required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2155/e/1"},"text":"section 2155(e)(1) of this title","children":[],"tail":" regarding any trade agreement provided for under paragraph (1) shall be provided to the President, the Congress, and the United States Trade Representative not later than 30 days after the date on which the President notifies the Congress under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2903/a/1/A"},"text":"section 2903(a)(1)(A) of this title","children":[],"tail":" of his intention to enter into the agreement (but before "},{"tag":"date","attrib":{"date":"1994-01-15"},"text":"January 15, 1994","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0602a2bc-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/tI/s1102"},"text":"Pub. L. 100–418, title I, § 1102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1126"},"text":"102 Stat. 1126","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/382/tI/s139/b"},"text":"Pub. L. 101–382, title I, § 139(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-20"},"text":"Aug. 20, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/653"},"text":"104 Stat. 653","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/49/s1"},"text":"Pub. L. 103–49, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-07-02"},"text":"July 2, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/239"},"text":"107 Stat. 239","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0602a2bd-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0602a2be-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0602a2bf-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This title, referred to in subsecs. (a)(1), (b)(1), and (d)(2)(B), is title I (§ 1001 et seq.) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418"},"text":"Pub. L. 100–418","children":[],"tail":", see note below. For complete classification of this title to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (c)(5), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418"},"text":"Pub. L. 100–418","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1107"},"text":"102 Stat. 1107","children":[],"tail":", known as the Omnibus Trade and Competitiveness Act of 1988. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0602a2c0-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/49"},"text":"Pub. L. 103–49","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/382"},"text":"Pub. L. 101–382","children":[],"tail":" substituted “paragraph (3)(C)” for “paragraph (3)(B)” and “2903(e)” for “2903(f)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
