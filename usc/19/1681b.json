{"tag":"section","attrib":{"id":"id058b76a6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1681b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1681b"},"text":"§ 1681b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id058b76a7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1681b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who violates a provision of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1681a"},"text":"section 1681a of this title","children":[],"tail":" shall, in addition to the tax and any other penalty provided by law, be liable for a civil penalty for each violation equal to the greater of $1,000 or 5 times the amount of the tax imposed by chapter 52 of the Internal Revenue Code of 1986 on all cigarettes or smokeless tobacco products that are the subject of such violation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id058b76a8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1681b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forfeitures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any tobacco product, cigarette papers, or tube, or any smokeless tobacco product, that was imported into the United States or is sought to be imported into the United States in violation of, or without meeting the requirements of, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1681a"},"text":"section 1681a of this title","children":[],"tail":" shall be forfeited to the United States, or to any State in which such tobacco product, cigarette papers, or tube is found. Notwithstanding any other provision of law, any product forfeited to the United States, or to any State, pursuant to this subtitle shall be destroyed."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id058b76a9-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title VIII, § 803, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/476/tIV/s4004/a"},"text":"Pub. L. 106–476, title IV, § 4004(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2180"},"text":"114 Stat. 2180","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/432/dC/tIV/s401/d"},"text":"Pub. L. 109–432, div. C, title IV, § 401(d)","children":[],"tail":", (e)(1), (3), "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3048"},"text":"120 Stat. 3048","children":[],"tail":", 3049.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id058b76aa-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id058b76ab-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id058b76ac-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Chapter 52 of the Internal Revenue Code of 1986, referred to in subsec. (a), is classified to section 5701 et seq. of Title 26, Internal Revenue Code.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id058b76ad-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 803 of act ","children":[{"tag":"date","attrib":{"date":"1930-06-17"},"text":"June 17, 1930","children":[],"tail":", is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1683a"},"text":"section 1683a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id058b76ae-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432/s401/e/1"},"text":"Pub. L. 109–432, § 401(e)(1)","children":[],"tail":", inserted “or smokeless tobacco products” after “cigarettes”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432/s401/d"},"text":"Pub. L. 109–432, § 401(d)","children":[],"tail":", (e)(3), in first sentence, inserted “, or any smokeless tobacco product,” before “that was imported” and “, or to any State in which such tobacco product, cigarette papers, or tube is found” before period at end and, in second sentence, inserted “, or to any State,” after “United States”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id058b76af-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id058b76b0-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attri