114/27"},"text":"Pub. L. 114–27","children":[],"tail":", §§ 402(b), (c), 406, temporarily revived the provisions of this section, as in effect on "},{"tag":"date","attrib":{"date":"2013-12-31"},"text":"Dec. 31, 2013","children":[],"tail":". See Codification note above and 2011 Amendment and Effective and Termination Dates of 2015 Revival notes below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/40"},"text":"Pub. L. 112–40","children":[],"tail":", §§ 201(b), (c), 233, temporarily revived the provisions of this section, as in effect on "},{"tag":"date","attrib":{"date":"2011-02-12"},"text":"Feb. 12, 2011","children":[],"tail":". See Codification note above and 2009 Amendment and Effective and Termination Dates of 2011 Revival notes below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5"},"text":"Pub. L. 111–5","children":[],"tail":", §§ 1803(1), 1893, temporarily substituted “before the worker’s application under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2291"},"text":"section 2291 of this title","children":[],"tail":" occurred more than one year before the date of the petition on which such certification was granted.” for “or appropriate subdivision of the firm before his application under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2291"},"text":"section 2291 of this title","children":[],"tail":" occurred—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) more than one year before the date of the petition on which such certification was granted, or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) more than 6 months before the effective date of this part.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"See Codification note above and Effective and Termination Dates of 2009 Amendment note below.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5"},"text":"Pub. L. 111–5","children":[],"tail":", §§ 1803(2), 1858(a), 1893, temporarily substituted “a determination” for “his determination” and “and on the website of the Department of Labor, together with the Secretary’s reasons” for “together with his reasons”. See Codification note above and Effective and Termination Dates of 2009 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5"},"text":"Pub. L. 111–5","children":[],"tail":", §§ 1803(3), 1893, temporarily substituted “, that total or partial separations from such firm are no longer attributable to the conditions specified in "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2272"},"text":"section 2272 of this title","children":[],"tail":", the Secretary shall” for “or subdivision of the firm, that total or partial separations from such firm or subdivision are no longer attributable to the conditions specified in "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2272"},"text":"section 2272 of this title","children":[],"tail":", he shall” and “and on the website of the Department of Labor, together with the Secretary’s reasons” for “together with his reasons”. See Codification note above and Effective and Termination Dates of 2009 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5"},"text":"Pub. L. 111–5","children":[],"tail":", §§ 1803(4), 1893, temporarily added subsec. (e). See Codification note above and Effective and Termination Dates of 2009 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/210"},"text":"Pub. L. 107–210","children":[],"tail":" substituted “40 days” for “60 days”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/182"},"text":"Pub. L. 103–182","children":[],"tail":" substituted “assistance under this subpart” for “assistance under this part”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id05bff445-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id05bff446-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective and Termination Dates of 2015 Revival","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For revival and applicability, beginning on ","children":[{"tag":"date","attrib":{"date":"2015-06-29"},"text":"June 29, 2015","children":[],"tail":", of the provisions of this section as in effect on "},{"tag":"date","attrib":{"date":"2013-12-31"},"text":"Dec. 31, 2013","children":[],"tail":", see section 402(b), (c) of "},{"tag":"ref","attrib":{"href":"/us/pl/114/27"},"text":"Pub. L. 114–27","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2271"},"text":"section 2271 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"For reversion, beginning on ","children":[{"tag":"date","attrib":{"date":"2021-07-01"},"text":"July 1, 2021","children":[],"tail":", to the provisions of this section as in effect on "},{"tag":"date","attrib":{"date":"2014-01-01"},"text":"Jan. 1, 2014","children":[],"tail":", with certain exceptions and subject to "},{"tag":"ref","attrib":{"href":"/us/pl/114/27/s406/b"},"text":"section 406(b) of Pub. L. 114–27","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/27/s406"},"text":"section 406 of Pub. L. 114–27","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2271"},"text":"section 2271 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id05bff447-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective and Termination Dates of 2011 Revival","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For revival and applicability, beginning on ","children":[{"tag":"date","attrib":{"date":"2011-10-21"},"text":"Oct. 21, 2011","children":[],"tail":", of the provisions of this section as in effect on "},{"tag":"date","attrib":{"date":"2011-02-12"},"text":"Feb. 12, 2011","children":[],"tail":", see section 201(b), (c) of "},{"tag":"ref","attrib":{"href":"/us/pl/112/40"},"text":"Pub. L. 112–40","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2271"},"text":"section 2271 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/40/s233"},"text":"Section 233 of Pub. L. 112–40","children":[],"tail":", formerly set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2271"},"text":"section 2271 of this title","children":[],"tail":", which provided for the reversion, beginning on "},{"tag":"date","attrib":{"date":"2014-01-01"},"text":"Jan. 1, 2014","children":[],"tail":", of the provisions of this section to those in effect on "},{"tag":"date","attrib":{"date":"2011-02-13"},"text":"Feb. 13, 2011","children":[],"tail":", subject to certain exceptions, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/114/27/tIV/s402/a"},"text":"Pub. L. 114–27, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-06-29"},"text":"June 29, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/374"},"text":"129 Stat. 374","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"2015-06-29"},"text":"June 29, 2015","children":[],"tail":". See Co