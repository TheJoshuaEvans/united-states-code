{"tag":"section","attrib":{"id":"id05bff437-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2273"},"text":null,"children":[{"tag":"num","attrib":{"value":"2273"},"text":"§ 2273.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determinations by Secretary of Labor","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05bff438-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2273/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification of eligibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As soon as possible after the date on which a petition is filed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2271"},"text":"section 2271 of this title","children":[],"tail":", but in any event not later than 40 days after that date, the Secretary shall determine whether the petitioning group meets the requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2272"},"text":"section 2272 of this title","children":[],"tail":" and shall issue a certification of eligibility to apply for assistance under this subpart covering workers in any group which meets such requirements. Each certification shall specify the date on which the total or partial separation began or threatened to begin."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05bff439-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2273/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Workers covered by certification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A certification under this section shall not apply to any worker whose last total or partial separation from the firm or appropriate subdivision of the firm before his application under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2291"},"text":"section 2291 of this title","children":[],"tail":" occurred—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id05bff43a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2273/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" more than one year before the date of the petition on which such certification was granted, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05bff43b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2273/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" more than 6 months before the effective date of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05bff43c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2273/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication of determination in Federal Register","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon reaching his determination on a petition, the Secretary shall promptly publish a summary of the determination in the Federal Register together with his reasons for making such determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05bff43d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2273/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of certification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever the Secretary determines, with respect to any certification of eligibility of the workers of a firm or subdivision of the firm, that total or partial separations from such firm or subdivision are no longer attributable to the conditions specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2272"},"text":"section 2272 of this title","children":[],"tail":", he shall terminate such certification and promptly have notice of such termination published in the Federal Register together with his reasons for making such determination. Such termination shall apply only with respect to total or partial separations occurring after the termination date specified by the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05bff43e-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/tII/s223"},"text":"Pub. L. 93–618, title II, § 223","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2019"},"text":"88 Stat. 2019","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/182/tV/s503/a"},"text":"Pub. L. 103–182, title V, § 503(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-08"},"text":"Dec. 8, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2151"},"text":"107 Stat. 2151","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/210/dA/tI/s112/b"},"text":"Pub. L. 107–210, div. A, title I, § 112(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-06"},"text":"Aug. 6, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/937"},"text":"116 Stat. 937","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/5/dB/tI"},"text":"Pub. L. 111–5, div. B, title I","children":[],"tail":", §§ 1803, 1858(a), "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":