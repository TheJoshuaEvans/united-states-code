{"tag":"section","attrib":{"id":"id065afb87-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4573"},"text":null,"children":[{"tag":"num","attrib":{"value":"4573"},"text":"§ 4573.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission recommendations and report","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id065afb88-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4573/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Commission makes an affirmative determination under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4572"},"text":"section 4572 of this title","children":[],"tail":", the Commission shall recommend the action that is necessary to address the material harm or threat of material harm found."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id065afb89-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4573/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Only those members of the Commission who agreed to the affirmative determination under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4572"},"text":"section 4572 of this title","children":[],"tail":" are eligible to vote on the recommendation required to be made under subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id065afb8a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4573/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than the date that is 60 days after the date on which the determination is made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4572"},"text":"section 4572 of this title","children":[],"tail":", the Commission shall submit to the President a report that includes—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id065afb8b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4573/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the determination and an explanation of the basis for the determination;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065afb8c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4573/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the determination is affirmative, recommendations for action and an explanation of the basis for the recommendation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065afb8d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4573/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any dissenting or separate views by members of the Commission regarding the determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id065afb8e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4573/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public notice","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon submitting a report to the President under subsection (c), the Commission shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id065afb8f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4573/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promptly make public the report (with the exception of information which the Commission determines to be confidential business information); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065afb90-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4573/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish a summary of the report in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id065afb91-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113/tIII/s323"},"text":"Pub. L. 116–113, title III, § 323","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-01-29"},"text":"Jan. 29, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/57"},"text":"134 Stat. 57","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
