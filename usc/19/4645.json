{"tag":"section","attrib":{"id":"id065d45e7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4645"},"text":null,"children":[{"tag":"num","attrib":{"value":"4645"},"text":"§ 4645.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendation for enforcement action","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id065d45e8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4645/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendation to initiate","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Interagency Labor Committee determines, pursuant to an assessment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4644"},"text":"section 4644 of this title","children":[],"tail":", as a result of monitoring activities described in "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s4642/1"},"text":"section 4642(1) of this title","children":[],"tail":", or pursuant to a report of the Independent Mexico Labor Expert Board that a USMCA country has failed to meets its labor obligations, including with respect to obligations under Annex 23–A of the USMCA, the Committee shall recommend that the Trade Representative initiate enforcement actions under—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id065d45e9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4645/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" article 23.13 or 23.17 of the USMCA (relating to cooperative labor dialogue and labor consultations);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065d45ea-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4645/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" articles 31.4 and 31.6 of the USMCA (relating to dispute settlement consultations); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065d45eb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4645/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Annex 31–A of the USMCA (relating to the rapid response labor mechanism).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id065d45ec-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4645/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trade Representative determinations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 60 days after the date on which the Trade Representative receives a recommendation pursuant to subsection (a), the Trade Representative shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id065d45ed-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4645/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine whether to initiate an enforcement action; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065d45ee-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4645/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if such determination is negative, submit to the appropriate congressional committees a report on the reasons for such negative determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id065d45ef-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113/tVII/s715"},"text":"Pub. L. 116–113, title VII, § 715","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-01-29"},"text":"Jan. 29, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/83"},"text":"134 Stat. 83","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
