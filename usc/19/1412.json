{"tag":"section","attrib":{"id":"id05358eee-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1412"},"text":null,"children":[{"tag":"num","attrib":{"value":"1412"},"text":"§ 1412.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program goals","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The goals of the Program are to ensure that all regulations and rulings that are administered or enforced by the Customs Service are administered and enforced in a manner that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05358eef-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1412/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is uniform and consistent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05358ef0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1412/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is as minimally intrusive upon the normal flow of business activity as practicable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05358ef1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1412/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improves compliance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05358ef2-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title IV, § 412, as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/182/tVI/s631/2"},"text":"Pub. L. 103–182, title VI, § 631(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-08"},"text":"Dec. 8, 1993","children":[