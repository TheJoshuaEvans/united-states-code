{"tag":"section","attrib":{"id":"id05ef8fe1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2533"},"text":null,"children":[{"tag":"num","attrib":{"value":"2533"},"text":"§ 2533.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State and private standards-related activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05ef8fe2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2533/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the sense of the Congress that no State agency and no private person should engage in any standards-related activity that creates unnecessary obstacles to the foreign commerce of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05ef8fe3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2533/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presidential action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall take such reasonable measures as may be available to promote the observance by State agencies and private persons, in carrying out standards-related activities, of requirements equivalent to those imposed on Federal agencies under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2532"},"text":"section 2532 of this title","children":[],"tail":", and of procedures that provide for notification, participation, and publication with respect to such activities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05ef8fe4-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39/tIV/s403"},"text":"Pub. L. 96–39, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/243"},"text":"93 Stat. 243","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
