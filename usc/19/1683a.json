{"tag":"section","attrib":{"id":"id058b76e2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1683a"},"text":"§ 1683a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of softwood lumber importer declaration program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id058b76e3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id058b76e4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall establish and maintain an importer declaration program with respect to the importation of softwood lumber and softwood lumber products described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1683b/a"},"text":"section 1683b(a) of this title","children":[],"tail":". The importer declaration program shall require importers of softwood lumber and softwood lumber products described in "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1683b/a"},"text":"section 1683b(a) of this title","children":[],"tail":" to provide the information required under subsection (b) and declare the information required by subsection (c), and require that such information accompany the entry summary documentation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id058de7e5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electronic record","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall establish an electronic record that includes the importer information required under subsection (b) and the declarations required under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id058de7e6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President shall require the following information to be submitted by any person seeking to import softwood lumber or softwood lumber products described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1683b/a"},"text":"section 1683b(a) of this title","children":[],"tail":":"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id058de7e7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The export price for each shipment of softwood lumber or softwood lumber products.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id058de7e8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The estimated export charge, if any, applicable to each shipment of softwood lumber or softwood lumber products as calculated by applying the percentage determined and published by the Under Secretary for International Trade of the Department of Commerce pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1683c"},"text":"section 1683c of this title","children":[],"tail":" to the export price provided in subsection (b)(1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id058de7e9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Importer declarations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Pursuant to procedures prescribed by the President, any person seeking to import softwood lumber or softwood lumber products described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1683b/a"},"text":"section 1683b(a) of this title","children":[],"tail":" shall declare that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id058de7ea-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person has made appropriate inquiry, including seeking appropriate documentation from the exporter and consulting the determinations published by the Under Secretary for International Trade of the Department of Commerce pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1683c/b"},"text":"section 1683c(b) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id058de7eb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to the best of the person’s knowledge and belief—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id058de7ec-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the export price provided pursuant to subsection (b)(1) is determined in accordance with the definition provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1683/5"},"text":"section 1683(5) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id058de7ed-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the export price provided pursuant to subsection (b)(1) is consistent with the export price provided on the export permit, if any, granted by the country of export; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id058de7ee-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683a/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the exporter has paid, or committed to pay, all export charges due—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id058de7ef-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683a/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in accordance with the volume, export price, and export charge rate or rates, if any, as calculated under an international agreement entered into by the country of export and the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id058de7f0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683a/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consistent with the export charge determinations published by the Under Secretary for International Trade pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1683c/b"},"text":"section 1683c(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id058de7f1-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title VIII, § 803, as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/tIII/s3301/a"},"text":"Pub. L. 110–246, title III, § 3301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1847"},"text":"122 Stat. 1847","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id058de7f2-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id058de7f3-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id058de7f4-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1683"},"text":"Section 1683 of this title","children":[],"tail":", referred to in subsec. (c)(2)(A), was in the original section “802”, and was translated as meaning the section 802 of act "},{"tag":"date","attrib":{"date":"1930-06-17"},"text":"June 17, 1930","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s3301/a"},"text":"section 3301(a) of Pub. L. 110–246","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id058de7f5-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 803 of act ","children":[{"tag":"date","attrib":{"date":"1930-06-17"},"text":"June 17, 1930","children":[],"tail":", is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1681b"},"text":"section 1681b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id058de7f6-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id058de7f7-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 60 days after ","children":[{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s3301/b"},"text":"section 3301(b) of Pub. L. 110–246","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1683"},"text":"section 1683 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
