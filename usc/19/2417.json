{"tag":"section","attrib":{"id":"id05da33c2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2417"},"text":null,"children":[{"tag":"num","attrib":{"value":"2417"},"text":"§ 2417.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modification and termination of actions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05da33c3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2417/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05da33c4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2417/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Trade Representative may modify or terminate any action, subject to the specific direction, if any, of the President with respect to such action, that is being taken under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2411"},"text":"section 2411 of this title","children":[],"tail":" if—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05da33c5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2417/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any of the conditions described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2411/a/2"},"text":"section 2411(a)(2) of this title","children":[],"tail":" exist,"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05da33c6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2417/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the burden or restriction on United States commerce of the denial rights, or of the acts, policies, and practices, that are the subject of such action has increased or decreased, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05da33c7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2417/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such action is being taken under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2411/b"},"text":"section 2411(b) of this title","children":[],"tail":" and is no longer appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05da33c8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2417/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Before taking any action under paragraph (1) to modify or terminate any action taken under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2411"},"text":"section 2411 of this title","children":[],"tail":", the Trade Representative shall consult with the petitioner, if any, and with representatives of the domestic industry concerned, and shall provide opportunity for the presentation of views by other interested persons affected by the proposed modification or termination concerning the effects of the modification or termination and whether any modification or termination of the action is appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05da33c9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2417/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice; report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Trade Representative shall promptly publish in the Federal Register notice of, and report in writing to the Congress with respect to, any modification or termination of any action taken under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2411"},"text":"section 2411 of this title","children":[],"tail":" and the reasons therefor."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05da33ca-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2417/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of necessity","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05da33cb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2417/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05da33cc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2417/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a particular action has been taken under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2411"},"text":"section 2411 of this title","children":[],"tail":" during any 4-year period, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05da33cd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2417/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" neither the petitioner nor any representative of the domestic industry which benefits from such action has submitted to the Trade Representative during the last 60 days of such 4-year period a written request for the continuation of such action,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"such action shall terminate at the close of such 4-year period.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05da33ce-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2417/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Trade Representative shall notify by mail the petitioner and representatives of the domestic industry described in paragraph (1)(B) of any termination of action by reason of paragraph (1) at least 60 days before the date of such termination.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05da33cf-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2417/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If a request is submitted to the Trade Representative under paragraph (1)(B) to continue taking a particular action under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2411"},"text":"section 2411 of this title","children":[],"tail":", or if a request is submitted to the Trade Representative under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2416/c/2"},"text":"section 2416(c)(2) of this title","children":[],"tail":" to reinstate action, the Trade Representative shall conduct a review of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05da33d0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2417/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the effectiveness in achieving the objectives of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2411"},"text":"section 2411 of this title","children":[],"tail":" of—"}],"tail":null},{"tag":"clause","attrib":{"id":"id05da33d1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2417/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such action, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05da33d2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2417/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other actions that could be taken (including actions against other products or services), and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05da33d3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2417/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effects of such actions on the United States economy, including consumers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05da33d4-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/tIII/s307"},"text":"Pub. L. 93–618, title III, § 307","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tI/s1301/a"},"text":"Pub. L. 100–418, title I, § 1301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1174"},"text":"102 Stat. 1174","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/125/tVI/s602/b/4"},"text":"Pub. L. 114–125, title VI, § 602(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-24"},"text":"Feb. 24, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/184"},"text":"130 Stat. 184","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05da33d5-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05da33d6-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id05da33d7-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/125"},"text":"Pub. L. 114–125","children":[],"tail":" inserted “or if a request is submitted to the Trade Representative under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2416/c/2"},"text":"section 2416(c)(2) of this title","children":[],"tail":" to reinstate action,” after “under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2411"},"text":"section 2411 of this title","children":[],"tail":",” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id05da33d8-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id05da33d9-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to petitions filed, and investigations initiated, under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2412"},"text":"section 2412 of this title","children":[],"tail":" on or after "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", and petitions filed, and investigations initiated, before "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", if by such date no decision had been made under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2414"},"text":"section 2414 of this title","children":[],"tail":" regarding the petition or investigation, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/s1301/c"},"text":"section 1301(c) of Pub. L. 100–418","children":[],"tail":", set out as an Effective Date of 1988 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2411"},"text":"section 2411 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
