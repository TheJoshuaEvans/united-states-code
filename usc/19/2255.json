{"tag":"section","attrib":{"id":"id05bb39e5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2255"},"text":null,"children":[{"tag":"num","attrib":{"value":"2255"},"text":"§ 2255.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trade monitoring","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05bb39e6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2255/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring tool for imports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05bb39e7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2255/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2016-02-24"},"text":"February 24, 2016","children":[],"tail":", the Commission shall make available on a website of the Commission an import monitoring tool to allow the public access to data on the volume and value of goods imported to the United States for the purpose of assessing whether such data has changed with respect to such goods over a period of time."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05bb39e8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2255/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data described","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of the monitoring tool under paragraph (1), the Commission shall use data compiled by the Department of Commerce and such other government data as the Commission considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05bb39e9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2255/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periods of time","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall ensure that data accessed through the monitoring tool under paragraph (1) includes data for the most recent quarter for which such data are available and previous quarters as the Commission considers practicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05bb39ea-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2255/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05bb39eb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2255/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 270 days after ","children":[{"tag":"date","attrib":{"date":"2016-02-24"},"text":"February 24, 2016","children":[],"tail":", and not less frequently than quarterly thereafter, the Secretary of Commerce shall publish on a website of the Department of Commerce, and notify the Committee on Finance of the Senate and the Committee on Ways and Means of the House of Representatives of the availability of, a monitoring report on changes in the volume and value of trade with respect to imports and exports of goods categorized based on the 6-digit subheading number of the goods under the Harmonized Tariff Schedule of the United States during the most recent quarter for which such data are available and previous quarters as the Secretary considers practicable."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05bb39ec-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2255/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requests for comment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than one year after ","children":[{"tag":"date","attrib":{"date":"2016-02-24"},"text":"February 24, 2016","children":[],"tail":", the Secretary of Commerce shall solicit through the Federal Register public comment on the monitoring reports described in paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05bb39ed-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2255/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sunset","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirements under this section terminate on the date that is seven years after ","children":[{"tag":"date","attrib":{"date":"2016-02-24"},"text":"February 24, 2016","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05bb39ee-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/tII/s205"},"text":"Pub. L. 93–618, title II, § 205","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/125/tVI/s603/a"},"text":"Pub. L. 114–125, title VI, § 603(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-24"},"text":"Feb. 24, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/185"},"text":"130 Stat. 185","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05bb39ef-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05bb39f0-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id05bb39f1-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Harmonized Tariff Schedule of the United States, referred to in subsec. (b)(1), is not set out in the Code. See Publication of Harmonized Tariff Schedule note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1202"},"text":"section 1202 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
