{"tag":"section","attrib":{"id":"id064f1527-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4332"},"text":null,"children":[{"tag":"num","attrib":{"value":"4332"},"text":"§ 4332.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint import safety rapid response plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id064f1528-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4332/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2016-12-31"},"text":"December 31, 2016","children":[],"tail":", the Secretary of Homeland Security, in consultation with the interagency Import Safety Working Group established under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s4331"},"text":"section 4331 of this title","children":[],"tail":", shall develop a plan (to be known as the “joint import safety rapid response plan”) that sets forth protocols and defines practices for U.S. Customs and Border Protection to use—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id064f1529-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4332/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in taking action in response to, and coordinating Federal responses to, an incident in which cargo destined for or merchandise entering the United States has been identified as posing a threat to the health or safety of consumers in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064f152a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4332/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in recovering from or mitigating the effects of actions and responses to an incident described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id064f152b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4332/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The joint import safety rapid response plan shall address—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id064f152c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4332/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the statutory and regulatory authorities and responsibilities of U.S. Customs and Border Protection and other Federal agencies in responding to an incident described in subsection (a)(1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064f152d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4332/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the protocols and practices to be used by U.S. Customs and Border Protection when taking action in response to, and coordinating Federal responses to, such an incident;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064f152e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4332/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the measures to be taken by U.S. Customs and Border Protection and other Federal agencies in recovering from or mitigating the effects of actions taken in response to such an incident after the incident to ensure the resumption of the entry of merchandise into the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064f152f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4332/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exercises that U.S. Customs and Border Protection may conduct in conjunction with Federal, State, and local agencies, and private sector entities, to simulate responses to such an incident.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id064f1530-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4332/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updates of plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Homeland Security shall review and update the joint import safety rapid response plan, as appropriate, after conducting exercises under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id064f1531-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4332/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Import health and safety exercises","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id064f1532-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4332/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Homeland Security and the Commissioner shall periodically engage in the exercises referred to in subsection (b)(4), in conjunction with Federal, State, and local agencies and private sector entities, as appropriate, to test and evaluate the protocols and practices identified in the joint import safety rapid response plan at United States ports of entry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064f1533-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4332/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for exercises","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conducting exercises under paragraph (1), the Secretary and the Commissioner shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id064f1534-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4332/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make allowance for the resources, needs, and constraints of United States ports of entry of different sizes in representative geographic locations across the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id064f1535-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4332/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" base evaluations on current risk assessments of merchandise entering the United States at representative United States ports of entry located across the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id064f1536-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4332/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that such exercises are conducted in a manner consistent with the National Incident Management System, the National Response Plan, the National Infrastructure Protection Plan, the National Preparedness Guidelines, the Maritime Transportation System Security Plan, and other such national initiatives of the Department of Homeland Security, as appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id064f1537-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4332/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop metrics with respect to the resumption of the entry of merchandise into the United States after an incident described in subsection (a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064f1538-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4332/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for testing and evaluation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary and the Commissioner shall ensure that the testing and evaluation carried out in conducting exercises under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id064f1539-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4332/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are performed using clear and objective performance measures; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id064f153a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4332/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" result in the identification of specific recommendations or best practices for responding to an incident described in subsection (a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064f153b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4332/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dissemination of recommendations and best practices","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary and the Commissioner shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id064f153c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4332/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" share the recommendations or best practices identified under paragraph (3)(B) among the members of the interagency Import Safety Working Group established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4331"},"text":"section 4331 of this title","children":[],"tail":" and with, as appropriate—"}],"tail":null},{"tag":"clause","attrib":{"id":"id064f153d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4332/d/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State, local, and tribal governments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id064f153e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4332/d/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foreign governments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id064f153f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4332/d/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" private sector entities; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id064f1540-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4332/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use such recommendations and best practices to update the joint import safety rapid response plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id064f1541-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/125/tII/s202"},"text":"Pub. L. 114–125, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-24"},"text":"Feb. 24, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/147"},"text":"130 Stat. 147","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
