{"tag":"section","attrib":{"id":"id06005926-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2805"},"text":null,"children":[{"tag":"num","attrib":{"value":"2805"},"text":"§ 2805.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required consultations","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Trade Representative shall consult with the Committees and with representatives of the wine and grape products industries in the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id06005927-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2805/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before identifying tariff barriers and nontariff barriers to (or other distortions of) trade in United States wine and designating major wine trading countries under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2803"},"text":"section 2803 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06005928-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2805/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in developing the reports required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2804/b"},"text":"section 2804(b) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06005929-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2805/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for purposes of determining whether action by the President is appropriate under any provision of the Trade Act of 1974 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2101"},"text":"19 U.S.C. 2101","children":[],"tail":" et seq.] with respect to any act, policy, or practice referred to in "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2804/b/1"},"text":"section 2804(b)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0600592a-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/573/tIX/s906"},"text":"Pub. L. 98–573, title IX, § 906","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3050"},"text":"98 Stat. 3050","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0600592b-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0600592c-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0600592d-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Trade Act of 1974, referred to in par. (3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618"},"text":"Pub. L. 93–618","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1978"},"text":"88 Stat. 1978","children":[],"tail":", which is classified principally to chapter 12 (§ 2101 et seq.) of this title. For complete classification of this Act to the Code, see References in Text note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2101"},"text":"section 2101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"ta