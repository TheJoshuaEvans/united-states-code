{"tag":"section","attrib":{"id":"id05e61a28-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2486"},"text":null,"children":[{"tag":"num","attrib":{"value":"2486"},"text":"§ 2486.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trade relations with North American countries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05e61a29-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2486/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Negotiations for free trade area with Canada","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the sense of the Congress that the United States should enter into a trade agreement with Canada which will guarantee continued stability to the economies of the United States and Canada. In order to promote such economic stability, the President may initiate negotiations for a trade agreement with Canada to establish a free trade area covering the United States and Canada. Nothing in this section shall be construed as prior approval of any legislation which may be necessary to implement such a trade agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05e61a2a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2486/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional study","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall study the desirability of entering into trade agreements with countries in the northern portion of the western hemisphere to promote the economic growth of the United States and such countries and the mutual expansion of market opportunities and report to the Committee on Ways and Means of the House of Representatives and the Committee on Finance of the Senate his findings and conclusions within 2 years after ","children":[{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":". The study shall include an examination of competitive opportunities and conditions of competition between such countries and the United States in the agricultural, energy, and other appropriate sectors."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05e61a2b-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/tVI/s612"},"text":"Pub. L. 93–618, title VI, § 612","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2076"},"text":"88 Stat. 2076","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/39/tXI/s1104/a"},"text":"Pub. L. 96–39, title XI, § 1104(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/310"},"text":"93 Stat. 310","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05e61a2c-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05e61a2d-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id05e61a2e-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1979—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39"},"text":"Pub. L. 96–39","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id05e61a2f-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id05e61a30-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1979 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39"},"text":"Pub. L. 96–39","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/39/s1114"},"text":"section 1114 of Pub. L. 96–39","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2581"},"text":"section 2581 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
