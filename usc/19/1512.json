{"tag":"section","attrib":{"id":"id054d8329-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1512"},"text":null,"children":[{"tag":"num","attrib":{"value":"1512"},"text":"§ 1512.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit of duty receipts","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All moneys paid to any customs officer for unascertained duties or for duties paid under protest against the rate or amount of duties charged shall be deposited to the credit of the Treasurer of the United States and shall not be held by the customs officers to await any ascertainment of duties or the result of any litigation in relation to the rate or amount of duties legally chargeable and collectible in any case where money is so paid.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id054d832a-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title IV, § 512, "},{"tag":"ref","attrib":{"href":"/us/stat/46/734"},"text":"46 Stat. 734","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/271/tIII/s301/q"},"text":"Pub. L. 91–271, title III, § 301(q)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-06-02"},"text":"June 2, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/290"},"text":"84 Stat. 290","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id054d832b-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id054d832c-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id054d832d-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in R.S. § 3010, which was superseded by ","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-09-21/ch356/tIV/s512"},"text":"act Sept. 21, 1922, ch. 356, title IV, § 512","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/969"},"text":"42 Stat. 969","children":[],"tail":", and was repealed by section 642 thereof. Section 512 of the 1922 act was superseded by section 512 of act "},{"tag":"date","attrib":{"date":"1930-06-17"},"text":"June 17, 1930","children":[],"tail":", comprising this section, and repealed by section 651(a)(1) of the 1930 act."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id054d832e-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/271"},"text":"Pub. L. 91–271","children":[],"tail":" substituted references to customs officers for references to collectors wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id054d832f-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id054d8330-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1970 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/271"},"text":"Pub. L. 91–271","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/271/s203"},"text":"section 203 of Pub. L. 91–271","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1500"},"text":"section 1500 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
