{"tag":"section","attrib":{"id":"id06136b7d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3572"},"text":null,"children":[{"tag":"num","attrib":{"value":"3572"},"text":"§ 3572.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of Subsidies Agreement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id06136b7e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3572/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General objectives","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The general objectives of the United States under this subchapter are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id06136b7f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3572/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that parts II and III of the Agreement on Subsidies and Countervailing Measures referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3511/d/12"},"text":"section 3511(d)(12) of this title","children":[],"tail":" (hereafter in this section referred to as the “Subsidies Agreement”) are effective in disciplining the use of subsidies and in remedying the adverse effects of subsidies, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06136b80-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3572/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that part IV of the Subsidies Agreement does not undermine the benefits derived from any other part of that Agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id06136b81-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3572/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific objective","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The specific objective of the United States under this subchapter shall be to create a mechanism which will provide for an ongoing review of the operation of part IV of the Subsidies Agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id06136b82-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3572/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sunset of noncountervailable subsidies provisions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id06136b83-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3572/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subparagraphs (B), (C), (D), and (E) of section 1677(5B) of this title shall cease to apply as provided in subparagraph (G)(i) of such section, unless, before the date referred to in such subparagraph (G)(i)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id06136b84-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3572/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Subsidies Committee determines to extend Articles 6.1, 8, and 9 of the Subsidies Agreement as in effect on the date on which the Subsidies Agreement enters into force or in a modified form, in accordance with Article 31 of such Agreement,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06136b85-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3572/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President consults with the Congress in accordance with paragraph (2), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06136b86-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3572/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an implementing bill is submitted and enacted into law in accordance with paragraphs (3) and (4).","children":[{"tag":"ref","attrib":{"idref":"fn002154"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002154"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Codification note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06136b87-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3572/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with Congress before Subsidies Committee agrees to extend","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before a determination is made by the Subsidies Committee to extend Articles 6.1, 8, and 9 of the Subsidies Agreement, the President shall consult with the Committee on Ways and Means of the House of Representatives and the Committee on Finance of the Senate regarding such extension.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06136b88-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3572/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation of extension","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id06136b89-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3572/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification and submission","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any extension of subparagraphs (B), (C), (D), and (E) of section 1677(5B) of this title shall take effect if (and only if)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id06136b8a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3572/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" after the Subsidies Committee determines to extend Articles 6.1, 8, and 9 of the Subsidies Agreement, the President submits to the committees referred to in paragraph (2) a copy of the document describing the terms of such extension, together with—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id06136b8b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3572/c/3/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a draft of an implementing bill,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id06136b8c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3572/c/3/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of any administrative action proposed to implement the extension, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id06136b8d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3572/c/3/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the supporting information described in subparagraph (C); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id06136b8e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3572/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the implementing bill is enacted into law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06136b8f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3572/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementing bill","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The implementing bill referred to in subparagraph (A) shall contain only those provisions that are necessary or appropriate to implement an extension of the provisions of section 1677(5B)(B), (C), (D), and (E) of this title as in effect on the day before the date of the enactment of the implementing bill or as modified to reflect the determination of the Subsidies Committee to extend Articles 6.1, 8, and 9 of the Subsidies Agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06136b90-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3572/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supporting information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The supporting information required under subparagraph (A)(i)(III) consists of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id06136b91-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3572/c/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an explanation as to how the implementing bill and proposed administrative action will change or affect existing law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id06136b92-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3572/c/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a statement regarding—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id06136b93-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3572/c/3/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the extension serves the interests of United States commerce, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id06136b94-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3572/c/3/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" why the implementing bill and proposed administrative action is required or appropriate to carry out the extension.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06136b95-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3572/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06136b96-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3572/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report by the Trade Representative","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than the date referred to in section 1677(5B)(G)(i) of this title, the Trade Representative shall submit to the Congress a report setting forth the provisions of law which were enacted to implement Articles 6.1, 8, and 9 of the Subsidies Agreement and should be repealed or modified if such provisions are not extended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id06136b97-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3572/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of operation of Subsidies Agreement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Commerce, in consultation with other appropriate departments and agencies of the Federal Government, shall undertake an ongoing review of the operation of the Subsidies Agreement. The review shall address—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id06136b98-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3572/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effectiveness of part II of the Subsidies Agreement in disciplining the use of subsidies which are prohibited under Article 3 of the Agreement,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06136b99-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3572/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effectiveness of part III and, in particular, Article 6.1 of the Subsidies Agreement, in remedying the adverse effects of subsidies which are actionable under the Agreement, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06136b9a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3572/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the extent to which the provisions of part IV of the Subsidies Agreement may have undermined the benefits derived from other parts of the Agreement, and, in particular—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id06136b9b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3572/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which WTO member countries have cooperated in reviewing and improving the operation of part IV of the Subsidies Agreement,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06136b9c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3572/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the provisions of Articles 8.4 and 8.5 of the Subsidies Agreement have been effective in identifying and remedying violations of the conditions and criteria described in Article 8.2 of the Agreement, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06136b9d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3572/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the provisions of Article 9 of the Subsidies Agreement have been effective in remedying the serious adverse effects of subsidy programs described in Article 8.2 of the Agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Not later than 4 years and 6 months after ","children":[{"tag":"date","attrib":{"date":"1994-12-08"},"text":"December 8, 1994","children":[],"tail":", the Secretary of Commerce shall submit to the Congress a report on the review required under this subsection."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id06136b9e-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/tII/s282"},"text":"Pub. L. 103–465, title II, § 282","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4927"},"text":"108 Stat. 4927","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/295/s20/b/16"},"text":"Pub. L. 104–295, § 20(b)(16)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3527"},"text":"110 Stat. 3527","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id06136b9f-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id06136ba0-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id06136ba1-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/s282"},"text":"section 282 of Pub. L. 103–465","children":[],"tail":". Subsec. (c)(4) of "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/s282"},"text":"section 282 of Pub. L. 103–465","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2191"},"text":"section 2191 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id06136ba2-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/295"},"text":"Pub. L. 104–295","children":[],"tail":" realigned margins."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id06136ba3-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id06136ba4-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Uruguay Round Agreements: Entry Into Force","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Uruguay Round Agreements, including the World Trade Organization Agreement and agreements annexed to that Agreement, as referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3511/d"},"text":"section 3511(d) of this title","children":[],"tail":", entered into force with respect to the United States on "},{"tag":"date","attrib":{"date":"1995-01-01"},"text":"Jan. 1, 1995","children":[],"tail":". See note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3511"},"text":"section 3511 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
