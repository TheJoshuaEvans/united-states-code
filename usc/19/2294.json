{"tag":"section","attrib":{"id":"id05c4aee4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2294"},"text":null,"children":[{"tag":"num","attrib":{"value":"2294"},"text":"§ 2294.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of State laws","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Except where inconsistent with the provisions of this part and subject to such regulations as the Secretary may prescribe, the availability and disqualification provisions of the State law—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05c4aee5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2294/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under which an adversely affected worker is entitled to unemployment insurance (whether or not he has filed a claim for such insurance), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05c4aee6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2294/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if he is not so entitled to unemployment insurance, of the State in which he was totally or partially separated,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall apply to any such worker who files a claim for trade readjustment allowances. The State law so determined with respect to a separation of a worker shall remain applicable, for purposes of the preceding sentence, with respect to such separation until such worker becomes entitled to unemployment insurance under another State law (whether or not he has filed a claim for such insurance).","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05c4aee7-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl