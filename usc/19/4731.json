{"tag":"section","attrib":{"id":"id065fb6e4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4731"},"text":null,"children":[{"tag":"num","attrib":{"value":"4731"},"text":"§ 4731.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Border water infrastructure improvement authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id065fb6e5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4731/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator of the Environmental Protection Agency shall, in coordination with eligible public entities, carry out the planning, design, construction, and operation and maintenance of high priority treatment works in the covered area to treat wastewater (including stormwater), nonpoint sources of pollution, and related matters resulting from international transboundary water flows originating in Mexico.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id065fb6e6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4731/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2020-01-29"},"text":"January 29, 2020","children":[],"tail":", and annually thereafter, the Administrator shall submit to Congress a report on activities carried out pursuant to this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id065fb6e7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4731/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id065fb6e8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4731/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered area” means the portion of the Tijuana River watershed that is in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065fb6e9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4731/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible public entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible public entities” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id065fb6ea-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4731/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Section of the International Boundary and Water Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id065fb6eb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4731/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Corps of Engineers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id065fb6ec-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4731/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the North American Development Bank;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id065fb6ed-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4731/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id065fb6ee-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4731/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other appropriate Federal agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id065fb6ef-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4731/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State of California; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id065fb6f0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4731/c/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any of the following entities with jurisdiction over any part of the covered area:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id065fb6f1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4731/c/2/G/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A local government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id065fb6f2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4731/c/2/G/ii"},"te