{"tag":"section","attrib":{"id":"id0599ce64-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2081"},"text":null,"children":[{"tag":"num","attrib":{"value":"2081"},"text":"§ 2081.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Undercover investigative operations of Customs Service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0599ce65-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2081/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification required for exemption of undercover operations from certain laws","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to any undercover investigative operation of the United States Customs Service (hereinafter in this section referred to as the “Service”) which is necessary for the detection and prosecution of offenses against the United States which are within the jurisdiction of the Secretary of the Treasury—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0599ce66-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2081/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" sums authorized to be appropriated for the Service may be used—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0599ce67-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2081/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to purchase property, buildings, and other facilities, and to lease space, within the United States, the District of Columbia, and the territories and possessions of the United States without regard to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0599ce68-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2081/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sections 1341 and 3324 of title 31,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0599ce69-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2081/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sections 6301(a) and (b)(1) to (3) and 6306 of title 41,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0599ce6a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2081/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 45 of title 41,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0599ce6b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2081/a/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s8141"},"text":"section 8141 of title 40","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0599ce6c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2081/a/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s3901"},"text":"section 3901 of title 41","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0599ce6d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2081/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish or to acquire proprietary corporations or business entities as part of the undercover operation, and to operate such corporations or business entities on a commercial basis, without regard to sections 9102 and 9103 of title 31;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0599ce6e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2081/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sums authorized to be appropriated for the Service and the proceeds from the undercover operation, may be deposited in banks or other financial institutions without regard to the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s648"},"text":"section 648 of title 18","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3302"},"text":"section 3302 of title 31","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0599ce6f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2081/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the proceeds from the undercover operation may be used to offset necessary and reasonable expenses incurred in such operation without regard to the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3302"},"text":"section 3302 of title 31","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"only upon the written certification of the Commissioner of Customs ","children":[{"tag":"ref","attrib":{"idref":"fn002079"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002079"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Change of Name note below."}],"tail":" (or, if designated by the Commissioner the Deputy or an Assistant Commissioner of Customs) "},{"tag":"ref","attrib":{"idref":"fn002079"},"text":"1","children":[],"tail":" that any action authorized by paragraph (1), (2), or (3) of this subsection is necessary for the conduct of such undercover operation."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0599ce70-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2081/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liquidation of corporations and business entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a corporation or business entity established or acquired as part of an undercover operation under paragraph (1)(B) of subsection (a) with a net value over $50,000 is to be liquidated, sold, or otherwise disposed of, the Service, as much in advance as the Commissioner or his designee determines is practicable, shall report the circumstances to the Secretary of the Treasury. The proceeds of the liquidation, sale, or other disposition, after obligations are met, shall be deposited in the Treasury of the United States as miscellaneous receipts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0599ce71-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2081/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit of proceeds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As soon as the proceeds from an undercover investigative operation with respect to which an action is authorized and carried out under paragraphs (2) and (3) of subsection (a) of this section are no longer necessary for the conduct of such operation, such proceeds or the balance of such proceeds remaining at the time shall be deposited into the Treasury of the United States as miscellaneous receipts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0599ce72-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2081/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0599ce73-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2081/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Service shall conduct a detailed financial audit of each undercover investigative operation which is closed in each fiscal year, and","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0599ce74-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2081/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit the results of the audit in writing to the Secretary of the Treasury; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0599ce75-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2081/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 180 days after such undercover operation is closed, submit a report to the Congress concerning such audit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0599ce76-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2081/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Service shall also submit a report annually to the Congress specifying as to its undercover investigative operations—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0599ce77-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2081/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number, by programs, of undercover investigative operations pending as of the end of the 1-year period for which such report is submitted;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0599ce78-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2081/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number, by programs, of undercover investigative operations commenced in the 1-year period preceding the period for which such report is submitted; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0599ce79-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2081/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number, by programs, of undercover investigative operations closed in the 1-year period preceding the period for which such report is submitted and, with respect to each such closed undercover operation, the results obtained and any civil claims made with respect thereto.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0599ce7a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2081/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (d) of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0599ce7b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2081/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “closed” refers to the earliest point in time at which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0599ce7c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2081/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all criminal proceedings (other than appeals) are concluded, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0599ce7d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2081/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" covert activities are concluded, whichever occurs later.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0599ce7e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2081/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “employees” means employees, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2105"},"text":"section 2105 of title 5","children":[],"tail":", of the Service."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0599ce7f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2081/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The terms “undercover investigative operation” and “undercover operation” mean any undercover investigative operation of the Service—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0599ce80-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2081/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0599ce81-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2081/e/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the gross receipts (excluding interest earned) exceed $50,000, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0599ce82-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2081/e/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expenditures (other than expenditures for salaries of employees) exceed $150,000; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0599ce83-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2081/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is exempt from section 3302 or 9102 of title 31;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"except that subparagraphs (A) and (B) shall not apply with respect to the report required under paragraph (2) of subsection (d) of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0599ce84-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570/tIII/s3131"},"text":"Pub. L. 99–570, title III, § 3131","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-90"},"text":"100 Stat. 3207–90","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tX/s1074/d/3"},"text":"Pub. L. 104–201, div. A, title X, § 1074(d)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2661"},"text":"110 Stat. 2661","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/316/tI/s110/b"},"text":"Pub. L. 104–316, title I, § 110(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3832"},"text":"110 Stat. 3832","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/125/tVIII/s802/d/2"},"text":"Pub. L. 114–125, title VIII, § 802(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-24"},"text":"Feb. 24, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/210"},"text":"130 Stat. 210","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0599ce85-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0599ce86-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0599ce87-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (a)(1)(A)(ii), “sections 6301(a) and (b)(1) to (3) and 6306 of title 41,” substituted for “sections 3732(a) and 3741 of the Revised Statutes of the United States (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s11/a"},"text":"41 U.S.C. 11(a)","children":[],"tail":" and 22),” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s6/c"},"text":"Pub. L. 111–350, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3854"},"text":"124 Stat. 3854","children":[],"tail":", which Act enacted Title 41, Public Contracts."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (a)(1)(A)(iii), “chapter 45 of title 41,” substituted for “","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-06-30/s305"},"text":"section 305 of the Act of June 30, 1949","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/63/396"},"text":"63 Stat. 396","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s255"},"text":"41 U.S.C. 255","children":[],"tail":"),” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s6/c"},"text":"Pub. L. 111–350, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3854"},"text":"124 Stat. 3854","children":[],"tail":", which Act enacted Title 41, Public Contracts."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (a)(1)(A)(iv), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s8141"},"text":"Section 8141 of title 40","children":[],"tail":"” substituted for “the third undesignated paragraph under the heading ‘Miscellaneous’ of the Act of "},{"tag":"date","attrib":{"date":"1877-03-03"},"text":"March 3, 1877","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/19/370"},"text":"19 Stat. 370","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s34"},"text":"40 U.S.C. 34","children":[],"tail":")” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/107/217/s5/c"},"text":"Pub. L. 107–217, § 5(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1303"},"text":"116 Stat. 1303","children":[],"tail":", which Act enacted Title 40, Public Buildings, Property, and Works."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (a)(1)(A)(v), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s3901"},"text":"section 3901 of title 41","children":[],"tail":", and” substituted for “section 304(a) of the Federal Property and Administrative Services Act of 1949 ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s254/a"},"text":"41 U.S.C. 254(a)","children":[],"tail":"), and” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s6/c"},"text":"Pub. L. 111–350, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3854"},"text":"124 Stat. 3854","children":[],"tail":", which Act enacted Title 41, Public Contracts."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0599ce88-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(1)(A)(v). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" struck out “and (c)” after “section 254(a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/316"},"text":"Pub. L. 104–316","children":[],"tail":" struck out “and the Comptroller General” after “the Secretary of the Treasury”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0599ce89-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id0599ce8a-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to Commissioner of Customs deemed to be reference to Commissioner of U.S. Customs and Border Protection pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/125/s802/d/2"},"text":"section 802(d)(2) of Pub. L. 114–125","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s211"},"text":"section 211 of Title 6","children":[],"tail":", Domestic Security."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id0599ce8b-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions, personnel, assets, and liabilities of the United States Customs Service of the Department of the Treasury, including functions of the Secretary of the Treasury relating thereto, to the Secretary of Homeland Security, and for treatment of related references, see sections 203(1), 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":". For establishment of U.S. Customs and Border Protection in the Department of Homeland Security, treated as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" as of "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s211"},"text":"section 211 of Title 6","children":[],"tai