{"tag":"section","attrib":{"id":"id0610faf4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3539"},"text":null,"children":[{"tag":"num","attrib":{"value":"3539"},"text":"§ 3539.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fund for WTO dispute settlements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0610faf5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3539/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Treasury a fund for the payment of settlements under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0610faf6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3539/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of USTR to pay settlements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts in the fund established under subsection (a) shall be available, as provided in appropriations Acts, only for the payment by the United States Trade Representative of the amount of the total or partial settlement of any dispute pursuant to proceedings under the auspices of the World Trade Organization, if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0610faf7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3539/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a total or partial settlement in an amount of not more than $10,000,000, the Trade Representative certifies to the Secretary of the Treasury that the settlement is in the best interests of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0610faf8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3539/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a total or partial settlement in an amount of more than $10,000,000, the Trade Representative certifies to the Congress that the settlement is in the best interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0610faf9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3539/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the fund established under subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0610fafa-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3539/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $50,000,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0610fafb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3539/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts equivalent to amounts recovered by the United States pursuant to the settlement of disputes pursuant to proceedings under the auspices of the World Trade Organization.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Amounts appropriated to the fund are authorized to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0610fafc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3539/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management of fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Sections 9601 and 9602(b) of title 26 shall apply to the fund established under subsection (a) to the same extent as such provisions apply to trust funds established under subchapter A of chapter 98 of such title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0610fafd-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/210/dE/tL/s5201"},"text":"Pub. L. 107–210, div. E, title L, § 5201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-06"},"text":"Aug. 6, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1047"},"text":"116 Stat. 1047","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0610fafe-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0610faff-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0610fb00-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Trade Act of 2002, and not as part of the Uruguay Round Agreements Act which enacted this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
