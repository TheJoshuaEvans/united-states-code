f this title","children":[],"tail":", enters into force with respect to the United States ("},{"tag":"date","attrib":{"date":"1995-01-01"},"text":"Jan. 1, 1995","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/s344/a"},"text":"section 344(a) of Pub. L. 103–465","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2512"},"text":"section 2512 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id05ed4678-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id05ed4679-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of President under this section delegated to United States Trade Representative, see section 1–201 of Ex. Ord. No. 12260, ","children":[{"tag":"date","attrib":{"date":"1980-12-31"},"text":"Dec. 31, 1980","children":[],"tail":", 46 F.R. 1653, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2511"},"text":"section 2511 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id05ed467a-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Agreement on Government Procurement: Entry Into Force","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Agreement on Government Procurement, as referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3511/d/17"},"text":"section 3511(d)(17) of this title","children":[],"tail":", entered into force with respect to the United States on "},{"tag":"date","attrib":{"date":