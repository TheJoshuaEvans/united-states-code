{"tag":"section","attrib":{"id":"id05f2003f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2552"},"text":null,"children":[{"tag":"num","attrib":{"value":"2552"},"text":"§ 2552.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Representations","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Any—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05f20040-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2552/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Party to the Agreement; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f20041-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2552/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foreign country that is not a Party to the Agreement but is found by the Trade Representative to extend rights and privileges to the United States that are substantially the same as those that would be so extended if that foreign country were a Party to the Agreement;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"may make a representation to the Trade Representative alleging that a standards-related activity engaged in within the United States violates the obligations of the United States under the Agreement. Any such representation must be made in accordance with procedures that the Trade Representative shall by regulation prescribe and must provide a reasonable indication that the standards-related activity concerned is having a significant trade effect. No person other than a Party to the Agreement or a foreign country described in paragraph (2) may make such a representation.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05f20042-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"ta