{"tag":"section","attrib":{"id":"id056eeeb5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1648"},"text":null,"children":[{"tag":"num","attrib":{"value":"1648"},"text":"§ 1648.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uncertified checks, United States notes, and national bank notes receivable for customs duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Customs officers may receive uncertified checks, United States notes, and circulating notes of national banking associations in payment of duties on imports, during such time and under such rules and regulations as the Secretary of the Treasury shall prescribe; but if a check so received is not paid the person by whom such check has been tendered shall remain liable for the payment of the duties and for all legal penalties and additions to the same extent as if such check had not been tendered.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id056eeeb6-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title IV, § 648, "},{"tag":"ref","attrib":{"href":"/us/stat/46/762"},"text":"46 Stat. 762","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/271/tIII/s301/kk"},"text":"Pub. L. 91–271, title III, § 301(kk)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-06-02"},"text":"June 2, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/291"},"text":"84 Stat. 291","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id056eeeb7-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id056eeeb8-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id056eeeb9-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/271"},"text":"Pub. L. 91–271","children":[],"tail":" substituted reference to customs officers for reference to collectors of customs."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id056eeeba-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id056eeebb-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1970 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/271"},"text":"Pub. L. 91–271","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/271/s203"},"text":"section 203 of Pub. L. 91–271","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1500"},"text":"section 1500 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
