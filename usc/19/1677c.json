{"tag":"section","attrib":{"id":"id05844ad8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1677c"},"text":"§ 1677c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hearings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05844ad9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigation hearings","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05844ada-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), the administering authority and the Commission shall each hold a hearing in the course of an investigation upon the request of any party to the investigation before making a final determination under section 1671d or 1673d of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05844adb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If investigations are initiated under part I and part II of this subtitle regarding the same merchandise from the same country within 6 months of each other (but before a final determination is made in either investigation), the holding of a hearing by the Commission in the course of one of the investigations shall be treated as compliance with paragraph (1) for both investigations, unless the Commission considers that special circumstances require that a hearing be held in the course of each of the investigations. During any investigation regarding which the holding of a hearing is waived under this paragraph, the Commission shall allow any party to submit such additional written comment as it considers relevant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05844adc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any hearing required or permitted under this subtitle shall be conducted after notice published in the Federal Register, and a transcript of the hearing shall be prepared and made available to the public. The hearing shall not be subject to the provisions of subchapter II of chapter 5 of title 5, or to section 702 of such title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05844add-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title VII, § 774, as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/39/tI/s101"},"text":"Pub. L. 96–39, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/186"},"text":"93 Stat. 186","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/573/tVI/s616"},"text":"Pub. L. 98–573, title VI, § 616","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3037"},"text":"98 Stat. 3037","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05844ade-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05844adf-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id05844ae0-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/573"},"text":"Pub. L. 98–573","children":[],"tail":" designated existing provisions as par. (1), inserted “Except as provided in paragraph (2),”, and added par. (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id05844ae1-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id05844ae2-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/573"},"text":"Pub. L. 98–573","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/573/s626/a"},"text":"section 626(a) of Pub. L. 98–573","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1671"},"text":"section 1671 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
