{"tag":"section","attrib":{"id":"id064f14bf-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4319"},"text":null,"children":[{"tag":"num","attrib":{"value":"4319"},"text":"§ 4319.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on oversight of revenue protection and enforcement measures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id064f14c0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4319/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2016-06-30"},"text":"June 30, 2016","children":[],"tail":", and not later than March 31 of each second year thereafter, the Inspector General of the Department of the Treasury shall submit to the Committee on Finance of the Senate and the Committee on Ways and Means of the House of Representatives a report assessing, with respect to the period covered by the report, as specified in subsection (b), the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id064f14c1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4319/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The effectiveness of the measures taken by U.S. Customs and Border Protection with respect to protection of revenue, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id064f14c2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4319/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the collection of countervailing duties assessed under subtitle A of title VII of the Tariff Act of 1930 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1671"},"text":"19 U.S.C. 1671","children":[],"tail":" et seq.) and antidumping duties assessed under subtitle B of title VII of the Tariff Act of 1930 ("},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1673"},"text":"19 U.S.C. 1673","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id064f14c3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4319/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the assessment, collection, and mitigation of commercial fines and penalties;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id064f14c4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4319/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of bonds, including continuous and single transaction bonds, to secure that revenue; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id064f14c5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4319/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adequacy of the policies of U.S. Customs and Border Protection with respect to the monitoring and tracking of merchandise transported in bond and collecting duties, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064f14c6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4319/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The effectiveness of actions taken by U.S. Customs and Border Protection to measure accountability and performance with respect to protection of revenue.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064f14c7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4319/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number and outcome of investigations instituted by U.S. Customs and Border Protection with respect to the underpayment of duties.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064f14c8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4319/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The effectiveness of training with respect to the collection of duties provided for personnel of U.S. Customs and Border Protection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id064f14c9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4319/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period covered by report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each report required by subsection (a) shall cover the period of 2 fiscal years ending on September 30 of the calendar year preceding the submission of the report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id064f14ca-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/125/tI/s112"},"text":"Pub. L. 114–125, title I, § 112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-24"},"text":"Feb. 24, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/140"},"text":"130 Stat. 140","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id064f14cb-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id064f14cc-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id064f14cd-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Tariff Act of 1930, referred to in subsec. (a)(1)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"act June 17, 1930, ch. 497","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/590"},"text":"46 Stat. 590","children":[],"tail":". Subtitles A and B of title VII of the Act are classified generally to parts I (§ 1671 et seq.) and II (§ 1673 et seq.), respectively, of subtitle IV of chapter 4 of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1654"},"text":"section 1654 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
