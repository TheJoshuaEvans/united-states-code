ren":[],"tail":", referred to in text, is "},{"tag":"ref","attrib":{"href":"/us/act/1934-06-12/ch474"},"text":"act June 12, 1934, ch. 474","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/943"},"text":"48 Stat. 943","children":[],"tail":", as amended, which is classified to sections 1351, 1352, 1353, and 1354 of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
