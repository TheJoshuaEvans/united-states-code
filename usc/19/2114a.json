{"tag":"section","attrib":{"id":"id05a82678-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2114a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2114a"},"text":"§ 2114a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Negotiating objectives with respect to trade in services, foreign direct investment, and high technology products","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05a82679-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2114a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trade in services","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05a8267a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2114a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Principal United States negotiating objectives under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2112"},"text":"section 2112 of this title","children":[],"tail":" shall be—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05a8267b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2114a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce or to eliminate barriers to, or other distortions of, international trade in services (particularly United States service sector trade in foreign markets), including barriers that deny national treatment and restrictions on the establishment and operation in such markets; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05a8267c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2114a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to develop internationally agreed rules, including dispute settlement procedures, which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id05a8267d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2114a/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are consistent with the commercial policies of the United States, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05a8267e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2114a/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will reduce or eliminate such barriers or distortions and help ensure open international trade in services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05a8267f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2114a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Domestic objectives","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In pursuing the objectives described in paragraph (1), United States negotiators shall take into account legitimate United States domestic objectives including, but not limited to, the protection of legitimate health or safety, essential security, environmental, consumer or employment opportunity interests and the laws and regulations related thereto.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05a82680-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2114a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign direct investment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05a82681-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2114a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Principal United States negotiating objectives under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2112"},"text":"section 2112 of this title","children":[],"tail":" shall be—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05a82682-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2114a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce or to eliminate artificial or trade-distorting barriers to foreign direct investment, to expand the principle of national treatment, and to reduce unreasonable barriers to establishment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05a82683-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2114a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to develop internationally agreed rules, including dispute settlement procedures, which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id05a82684-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2114a/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will help ensure a free flow of foreign direct investment, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05a82685-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2114a/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will reduce or eliminate the trade distortive effects of certain investment related measures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05a82686-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2114a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Domestic objectives","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In pursuing the objectives described in paragraph (1), United States negotiators shall take into account legitimate United States domestic objectives including, but not limited to, the protection of legitimate health or safety, essential security, environmental, consumer or employment opportunity interests and the laws and regulations related thereto.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05a82687-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2114a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" High technology products","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Principal United States negotiating objectives shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05a82688-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2114a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to obtain and preserve the maximum openness with respect to international trade and investment in high technology products and related services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05a82689-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2114a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to obtain the elimination or reduction of, or compensation for, the significantly distorting effects of foreign government acts, policies, or practices identified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2241"},"text":"section 2241 of this title","children":[],"tail":", with particular consideration given to the nature and extent of foreign government intervention affecting United States exports of high technology products or investments in high technology industries, including—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05a8268a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2114a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foreign industrial policies which distort international trade or investment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05a8268b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2114a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" measures which deny national treatment or otherwise discriminate in favor of domestic high technology industries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05a8268c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2114a/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" measures which fail to provide adequate and effective means for foreign nationals to secure, exercise, and enforce exclusive rights in intellectual property (including trademarks, patents, and copyrights);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05a8268d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2114a/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" measures which impair access to domestic markets for key commodity products; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05a8268e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2114a/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" measures which facilitate or encourage anticompetitive market practices or structures;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05a8268f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2114a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to obtain commitments that official policy of foreign countries or instrumentalities will not discourage government or private procurement of foreign high technology products and related services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05a82690-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2114a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to obtain the reduction or elimination of all tariffs on, and other barriers to, United States exports of high technology products and related services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05a82691-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2114a/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to obtain commitments to foster national treatment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05a82692-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2114a/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to obtain commitments to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05a82693-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2114a/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foster the pursuit of joint scientific cooperation between companies, institutions or governmental entities of the United States and those of the trading partners of the United States in areas of mutual interest through such measures as financial participation and technical and personnel exchanges, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05a82694-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2114a/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that access by all participants to the results of any such cooperative efforts should not be impaired; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05a82695-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2114a/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide effective minimum safeguards for the acquisition and enforcement of intellectual property rights and the property value of proprietary data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05a82696-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2114a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of barriers and other distortions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a), the term “barriers to, or other distortions of, international trade in services” includes, but is not limited to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05a82697-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2114a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" barriers to establishment in foreign markets, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05a82698-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2114a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" restrictions on the operation of enterprises in foreign markets, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05a82699-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2114a/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct or indirect restrictions on the transfer of information into, or out of, the country or instrumentality concerned, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05a8269a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2114a/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" restrictions on the use of data processing facilities within or outside of such country or instrumentality.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05a8269b-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/tI/s104A"},"text":"Pub. L. 93–618, title I, § 104A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/573/tIII/s305/a/1"},"text":"Pub. L. 98–573, title III, § 305(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3006"},"text":"98 Stat. 3006","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
