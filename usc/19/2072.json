{"tag":"section","attrib":{"id":"id05975db0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2072"},"text":null,"children":[{"tag":"num","attrib":{"value":"2072"},"text":"§ 2072.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Officers and employees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05975db1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2072/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment by Secretary of the Treasury","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury is authorized to appoint, in the service established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2071"},"text":"section 2071 of this title","children":[],"tail":", one assistant commissioner, three deputy commissioners, one chief clerk, and such attorneys and other officers and employees as he may deem necessary. One of the deputy commissioners of the United States Customs Service shall have charge of investigations. Appointments under this subsection shall be subject to the provisions of the civil service laws, and the salaries shall be fixed in accordance with chapter 51 and subchapter III of chapter 53 of title 5."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05975db2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2072/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Absence or disability of Commissioner","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury is authorized to designate an officer of the United States Customs Service to act as Commissioner of Customs,","children":[{"tag":"ref","attrib":{"idref":"fn002072"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002072"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Change of Name note below."}],"tail":" during the absence or disability of the Commissioner of Customs,"},{"tag":"ref","attrib":{"idref":"fn002072"},"text":"1","children":[],"tail":" or in the event that there is no Commissioner of Customs."},{"tag":"ref","attrib":{"idref":"fn002072"},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05975db3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2072/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of personnel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The personnel of the United States Customs Service shall perform such duties as the Secretary of the Treasury may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05975db4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2072/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International Trade Committee","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05975db5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2072/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commissioner shall establish an International Trade Committee, to be chaired by the Commissioner, and to include the Deputy Commissioner, the Assistant Commissioner in the Office of Field Operations, the Assistant Commissioner in the Office of Finance, the Assistant Commissioner in the Office of International Affairs, the Assistant Commissioner in the Office of International Trade, the Director of the Office of Trade Relations, and any other official determined by the Commissioner to be important to the work of the Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05975db6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2072/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The International Trade Committee shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05975db7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2072/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be responsible for advising the Commissioner with respect to the commercial customs and trade facilitation functions of the United States Customs and Border Protection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05975db8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2072/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist the Commissioner in coordinating with the Secretary regarding commercial customs and trade facilitation functions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05975db9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2072/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" oversee the operation of all programs and systems that are involved in the assessment and collection of duties, bonds, and other charges or penalties associated with the entry of cargo into the United States, or the export of cargo from the United States, including the administration of duty drawback and the collection of antidumping and countervailing duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05975dba-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2072/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 30 days after the end of each fiscal year, the International Trade Committee shall submit a report to the Committee on Finance of the Senate and the Committee on Ways and Means of the House of Representatives. The report shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05975dbb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2072/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" detail the activities of the International Trade Committee during the preceding fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05975dbc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2072/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify the priorities of the International Trade Committee for the fiscal year in which the report is filed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05975dbd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2072/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05975dbe-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2072/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commissioner","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Commissioner” means the Commissioner responsible for the United States Customs and Border Protection in the Department of Homeland Security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05975dbf-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2072/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commercial Operations Advisory Committee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Commercial Operations Advisory Committee” means the Advisory Committee established pursuant to section 9503(c) of the Omnibus Budget Reconciliation Act of 1987 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2071"},"text":"19 U.S.C. 2071","children":[],"tail":" note) "},{"tag":"ref","attrib":{"idref":"fn002073"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002073"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":" or any successor committee."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05975dc0-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1927-03-03/ch348/s2"},"text":"Mar. 3, 1927, ch. 348, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/1381"},"text":"44 Stat. 1381","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1930-05-27/ch342/s8"},"text":"May 27, 1930, ch. 342, § 8","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/430"},"text":"46 Stat. 430","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title IV, § 650, "},{"tag":"ref","attrib":{"href":"/us/stat/46/762"},"text":"46 Stat. 762","children":[],"tail":"; Ex. Ord. No. 6639, § 1a, "},{"tag":"date","attrib":{"date":"1934-03-10"},"text":"Mar. 10, 1934","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-10-28/ch782"},"text":"Oct. 28, 1949, ch. 782","children":[],"tail":", title XI, § 1106(a), "},{"tag":"ref","attrib":{"href":"/us/stat/63/972"},"text":"63 Stat. 972","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1954-09-03/ch1263/s9"},"text":"Sept. 3, 1954, ch. 1263, § 9","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/1228"},"text":"68 Stat. 1228","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/347/tIV/s402"},"text":"Pub. L. 109–347, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-13"},"text":"Oct. 13, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1924"},"text":"120 Stat. 1924","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/125/tVIII/s802/d/2"},"text":"Pub. L. 114–125, title VIII, § 802(d)(2)","children":[],"tail":", (h)(3), "},{"tag":"date","attrib":{"date":"2016-02-24"},"text":"Feb. 24, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/210"},"text":"130 Stat. 210","children":[],"tail":", 215.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05975dc1-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05975dc2-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id05975dc3-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 9503(c) of the Omnibus Budget Reconciliation Act of 1987, referred to in subsec. (e)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/s9503/c"},"text":"section 9503(c) of Pub. L. 100–203","children":[],"tail":", which was set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2071"},"text":"section 2071 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/114/125/tI/s109/g/1"},"text":"Pub. L. 114–125, title I, § 109(g)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-24"},"text":"Feb. 24, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/137"},"text":"130 Stat. 137","children":[],"tail":". For establishment of successor committee, see "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s4316/a"},"text":"section 4316(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id05975dc4-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s281a"},"text":"section 281a of Title 5","children":[],"tail":" prior to the general revision and enactment of Title 5 by "},{"tag":"ref","attrib":{"href":"/us/pl/89/554/s1"},"text":"Pub. L. 89–554, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/378"},"text":"80 Stat. 378","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Chapter 51 and subchapter III of chapter 53 of title 5” were substituted for “the Classification Act of 1949, as amended” on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554/s7/b"},"text":"Pub. L. 89–554, § 7(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/631"},"text":"80 Stat. 631","children":[],"tail":", the first section of which enacted Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id05975dc5-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsecs. (d) to (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/125/s802/h/3"},"text":"Pub. L. 114–125, § 802(h)(3)","children":[],"tail":", redesignated subsecs. (e) and (f) as (d) and (e), respectively, and struck out former subsec. (d) which established the Office of International Trade. Notwithstanding directory language amending this section “as added” by "},{"tag":"ref","attrib":{"href":"/us/pl/109/347/s402"},"text":"section 402 of Pub. L. 109–347","children":[],"tail":", amendment was executed to this section as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/109/347/s402"},"text":"section 402 of Pub. L. 109–347","children":[],"tail":", to reflect the probable intent of Congress. See 2006 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsecs. (d) to (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/347"},"text":"Pub. L. 109–347","children":[],"tail":" added subsecs. (d) to (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1954—Subsec. (c). Act ","children":[{"tag":"date","attrib":{"date":"1954-09-03"},"text":"Sept. 3, 1954","children":[],"tail":", struck out references to the National Prohibition Act."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1949—Subsec. (a). Act ","children":[{"tag":"date","attrib":{"date":"1949-10-28"},"text":"Oct. 28, 1949","children":[],"tail":", substituted “Classification Act of 1949” for “Classification Act of 1923”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id05975dc6-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id05975dc7-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Bureau of Prohibition and Commissioner of Prohibition redesignated Bureau of Industrial Alcohol and Commissioner of Industrial Alcohol, respectively, by act ","children":[{"tag":"date","attrib":{"date":"1930-05-27"},"text":"May 27, 1930","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to Commissioner of Customs deemed to be reference to Commissioner of U.S. Customs and Border Protection pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/125/s802/d/2"},"text":"section 802(d)(2) of Pub. L. 114–125","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s211"},"text":"section 211 of Title 6","children":[],"tail":", Domestic Security."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"repeals","id":"id05975dc8-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeals","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1949-10-28/ch782/tXI/s1106/a"},"text":"Act Oct. 28, 1949, ch. 782, title XI, § 1106(a)","children":[],"tail":", cited as a credit to this section, was repealed (subject to a savings clause) by "},{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", § 8, "},{"tag":"ref","attrib":{"href":"/us/stat/80/632"},"text":"80 Stat. 632","children":[],"tail":", 655."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id05975dc9-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions, personnel, assets, and liabilities of the United States Customs Service of the Department of the Treasury, including functions of the Secretary of the Treasury relating thereto, to the Secretary of Homeland Security, and for treatment of related references, see sections 203(1), 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":". For establishment of U.S. Customs and Border Protection in the Department of Homeland Security, treated as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" as of "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s211"},"text":"section 211 of Title 6","children":[],"tail":", as amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/114/125"},"text":"Pub. L. 114–125","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/114/125/s802/b"},"text":"section 802(b) of Pub. L. 114–125","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s211"},"text":"section 211 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id05975dca-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Deputy Commissioner of Customs","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1930-06-17"},"text":"June 17, 1930","children":[],"tail":", authorized the appointment of an additional deputy commissioner in the Bureau of Customs in addition to the two deputy commissioners then authorized by law."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id05975dcb-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id05975dcc-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“United States Customs Service” substituted for “Bureau of Customs” in subsecs. (a) to (c) pursuant to Treasury Department Order 165–23, ","children":[{"tag":"date","attrib":{"date":"1973-04-04"},"text":"Apr. 4, 1973","children":[],"tail":", eff. "},{"tag":"date","attrib":{"date":"1973-08-01"},"text":"Aug. 1, 1973","children":[],"tail":", 38 F.R. 13037. See, also, "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s308"},"text":"section 308 of Title 31","children":[],"tail":", Money and Finance."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id05975dcd-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of all officers of Department of the Treasury and functions of all agencies and employees of such Department transferred, with certain exceptions, to Secretary of the Treasury, with power vested in him to authorize their performance or performance of any of his functions by any of such officers, agencies, and employees, by Reorg. Plan No. 26 of 1950, §§ 1, 2, eff. ","children":[{"tag":"date","attrib":{"date":"1950-07-31"},"text":"July 31, 1950","children":[],"tail":", 15 F.R. 4935, "},{"tag":"ref","attrib":{"href":"/us/stat/64/1280"},"text":"64 Stat. 1280","children":[],"tail":", set out in the Appendix to Title 5, Government Organization and Employees."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Bureau of Industrial Alcohol and office of Commissioner of Industrial Alcohol abolished and Commissioner’s functions transferred to Commissioner of Internal Revenue by Ex. Ord. No. 6639.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
