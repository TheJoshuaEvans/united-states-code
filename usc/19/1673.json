{"tag":"section","attrib":{"id":"id0575f361-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673"},"text":null,"children":[{"tag":"num","attrib":{"value":"1673"},"text":"§ 1673.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Antidumping duties imposed","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0575f362-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the administering authority determines that a class or kind of foreign merchandise is being, or is likely to be, sold in the United States at less than its fair value, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0575f363-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Commission determines that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0575f364-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an industry in the United States—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0575f365-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is materially injured, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0575f366-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is threatened with material injury, or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0575f367-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment of an industry in the United States is materially retarded,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"by reason of imports of that merchandise or by reason of sales (or the likelihood of sales) of that merchandise for importation,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then there shall be imposed upon such merchandise an antidumping duty, in addition to any other duty imposed, in an amount equal to the amount by which the normal value exceeds the export price (or the constructed export price) for the merchandise. For purposes of this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1673d/b/1"},"text":"section 1673d(b)(1) of this title","children":[],"tail":", a reference to the sale of foreign merchandise includes the entering into of any leasing arrangement regarding the merchandise that is equivalent to the sale of the merchandise."}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0575f368-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title VII, § 731, as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/39/tI/s101"},"text":"Pub. L. 96–39, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/162"},"text":"93 Stat. 162","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/573/tVI/s602/b"},"text":"Pub. L. 98–573, title VI, § 602(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3024"},"text":"98 Stat. 3024","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/tII/s233/a/1/A"},"text":"Pub. L. 103–465, title II, § 233(a)(1)(A)","children":[],"tail":", (2)(A)(i), "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4898"},"text":"108 Stat. 4898","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0575f369-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0575f36a-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0575f36b-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465"},"text":"Pub. L. 103–465","children":[],"tail":" substituted “normal value exceeds the export price (or the constructed export price)” for “foreign market value exceeds the United States price” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/573"},"text":"Pub. L. 98–573","children":[],"tail":" inserted “or by reason of sales (or the likelihood of sales) of that merchandise for importation” after “by reason of imports of that merchandise” in par. (2), and inserted sentence at end providing that for purposes of this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1673d/b/1"},"text":"section 1673d(b)(1) of this title","children":[],"tail":", a reference to the sale of foreign merchandise includes the entering into of any leasing arrangement regarding the merchandise that is equivalent to the sale of the merchandise."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0575f36c-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0575f36d-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465"},"text":"Pub. L. 103–465","children":[],"tail":" effective, except as otherwise provided, on the date on which the WTO Agreement enters into force with respect to the United States ("},{"tag":"date","attrib":{"date":"1995-01-01"},"text":"Jan. 1, 1995","children":[],"tail":"), and applicable with respect to investigations, reviews, and inquiries initiated and petitions filed under specified provisions of this chapter after such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/s291"},"text":"section 291 of Pub. L. 103–465","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1671"},"text":"section 1671 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0575f36e-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/573"},"t