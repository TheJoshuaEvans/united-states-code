{"tag":"section","attrib":{"id":"id05d09649-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2351"},"text":null,"children":[{"tag":"num","attrib":{"value":"2351"},"text":"§ 2351.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For purposes of this part, the term “firm” includes an individual proprietorship, partnership, joint venture, association, corporation (including a development corporation), business trust, cooperative, trustee in bankruptcy, and receiver under decree of any court. A firm, together with any predecessor or successor firm, or any affiliated firm controlled or substantially beneficially owned by substantially the same persons, may be considered a single firm where necessary to prevent unjustifiable benefits.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id05d0964a-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/tII/s261"},"text":"Pub. L. 93–618, title II, § 261","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2034"},"text":"88 Stat. 2034","children":[],"tail":"; temporarily renumbered § 259 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/5/dB/tI"},"text":"Pub. L. 111–5, div. B, title I","children":[],"tail":", §§ 1861(b), 1864(a)(2), "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/396"},"text":"123 Stat. 396","children":[],"tail":", 397; "},{"tag":"ref","attrib":{"href":"/us/pl/112/40/tII/s201/b"},"text":"Pub. L. 112–40, title II, § 201(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2011-10-21"},"text":"Oct. 21, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/sta