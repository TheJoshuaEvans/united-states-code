{"tag":"section","attrib":{"id":"id05a826eb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2118"},"text":null,"children":[{"tag":"num","attrib":{"value":"2118"},"text":"§ 2118.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to supplies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05a826ec-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2118/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fair and equitable access","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A principal United States negotiating objective under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2112"},"text":"section 2112 of this title","children":[],"tail":" shall be to enter into trade agreements with foreign countries and instrumentalities to assure the United States of fair and equitable access at reasonable prices to supplies of articles of commerce which are important to the economic requirements of the United States and for which the United States does not have, or cannot easily develop, the necessary domestic productive capacity to supply its own requirements."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05a826ed-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2118/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continued availability; reciprocal concessions; comparable trade obligations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any agreement entered into under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2112"},"text":"section 2112 of this title","children":[],"tail":" may include provisions which—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id05a826ee-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2118/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assure to the United States the continued availability of important articles at reasonable prices, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05a826ef-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2118/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide reciprocal concessions or comparable trade obligations, or both, by the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05a826f0-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/tI/s108"},"text":"Pub. L. 93–618, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1985"},"text":"88 Stat. 1985","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
