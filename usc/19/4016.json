{"tag":"section","attrib":{"id":"id0640bcc0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4016"},"text":null,"children":[{"tag":"num","attrib":{"value":"4016"},"text":"§ 4016.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Arbitration of claims","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The United States is authorized to resolve any claim against the United States covered by article 10.16.1(a)(i)(C) or article 10.16.1(b)(i)(C) of the Agreement, pursuant to the Investor-State Dispute Settlement procedures set forth in section B of chapter 10 of the Agreement.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0640bcc1-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/53/tI/s106"},"text":"Pub. L. 109–53, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-02"},"text":"Aug. 2, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/466"},"text":"119 Stat. 466","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0640bcc2-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id0640bcc3-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination of section by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/53/s107/d"},"text":"section 107(d) of Pub. L. 109–53","children":[],"tail":", see Effective and Termination Dates note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0640bcc4-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0640bcc5-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective and Termination Dates","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date the Dominican Republic-Central America-United States Free Trade Agreement enters into force (","children":[{"tag":"date","attrib":{"date":"2006-03-01"},"text":"Mar. 1, 2006","children":[],"tail":") and to cease to have effect on the date the Agreement ceases to be in force with respect to the United States, and, during any period in which a country ceases to be a CAFTA–DR country, to cease to have effect with respect to such country, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/53/s107"},"text":"section 107 of Pub. L. 109–53","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s4001"},"text":"section 4001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
