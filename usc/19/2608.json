{"tag":"section","attrib":{"id":"id05f471fc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2608"},"text":null,"children":[{"tag":"num","attrib":{"value":"2608"},"text":"§ 2608.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary disposition of materials and articles subject to this chapter","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Pending a final determination as to whether any archaeological or ethnological material, or any article of cultural property, has been imported into the United States in violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2606"},"text":"section 2606 of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2607"},"text":"section 2607 of this title","children":[],"tail":", the Secretary shall, upon application by any museum or other cultural or scientific institution in the United States which is open to the public, permit such material or article to be retained at such institution if he finds that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id05f471fd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2608/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sufficient safeguards will be taken by the institution for the protection of such material or article; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f471fe-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2608/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sufficient bond is posted by the institution to ensure its return to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05f471ff-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/446/tIII/s309"},"text":"