{"tag":"section","attrib":{"id":"id050d1ea0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s70"},"text":null,"children":[{"tag":"num","attrib":{"value":"70"},"text":"§ 70.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Obstruction of revenue officers by masters of vessels","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If the master of any vessel shall obstruct or hinder, or shall intentionally cause any obstruction or hindrance to any officer in lawfully going on board such vessel, for the purpose of carrying into effect any of the revenue or navigation laws of the United States, he shall for every such offense be liable to a penalty of not more than $2,000 nor less than $500.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id050d1ea1-3a70-11f1-8ace-823fb135378d"},"text":"(R.S. § 3068; ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-05/ch438"},"text":"Aug. 5, 1935, ch. 438","children":[],"tail":", title III, § 307, "},{"tag":"ref","attrib":{"href":"/us/stat/49/528"},"text":"49 Stat. 528","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id050d1ea2-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id050d1ea3-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id050d1ea4-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 3068 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1799-03-02/ch22/s71"},"text":"act Mar. 2, 1799, ch. 22, § 71","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/1/678"},"text":"1 Stat. 678","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id050d1ea5-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1935—Act ","children":[{"tag":"date","attrib":{"date":"1935-08-05"},"text":"Aug. 5, 1935","children":[],"tail":", inserted reference to navigation laws, and increased penalty from $500 and $50 to $2,000 and $500, respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
