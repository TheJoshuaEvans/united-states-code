{"tag":"section","attrib":{"id":"id05da3366-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2414"},"text":null,"children":[{"tag":"num","attrib":{"value":"2414"},"text":"§ 2414.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determinations by Trade Representative","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05da3367-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2414/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05da3368-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2414/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" On the basis of the investigation initiated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2412"},"text":"section 2412 of this title","children":[],"tail":" and the consultations (and the proceedings, if applicable) under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2413"},"text":"section 2413 of this title","children":[],"tail":", the Trade Representative shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05da3369-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2414/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" determine whether—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id05da336a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2414/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rights to which the United States is entitled under any trade agreement are being denied, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05da336b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2414/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any act, policy, or practice described in subsection (a)(1)(B) or (b)(1) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2411"},"text":"section 2411 of this title","children":[],"tail":" exists, and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05da336c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2414/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the determination made under subparagraph (A) is affirmative, determine what action, if any, the Trade Representative should take under subsection (a) or (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2411"},"text":"section 2411 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05da336d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2414/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Trade Representative shall make the determinations required under paragraph (1) on or before—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05da336e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2414/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of an investigation involving a trade agreement, except an investigation initiated pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2412/b/2/A"},"text":"section 2412(b)(2)(A) of this title","children":[],"tail":" involving rights under the Agreement on Trade-Related Aspects of Intellectual Property Rights (referred to in "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3511/d/15"},"text":"section 3511(d)(15) of this title","children":[],"tail":") or the GATT 1994 (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3501/1/B"},"text":"section 3501(1)(B) of this title","children":[],"tail":") relating to products subject to intellectual property protection, the earlier of—"}],"tail":null},{"tag":"clause","attrib":{"id":"id05da336f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2414/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date that is 30 days after the date on which the dispute settlement procedure is concluded, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05da3370-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2414/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date that is 18 months after the date on which the investigation is initiated, or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05da3371-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2414/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in all cases not described in subparagraph (A) or paragraph (3), the date that is 12 months after the date on which the investigation is initiated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05da3372-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2414/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05da3373-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2414/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If an investigation is initiated under this subchapter by reason of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2412/b/2"},"text":"section 2412(b)(2) of this title","children":[],"tail":" and—"}],"tail":null},{"tag":"clause","attrib":{"id":"id05da3374-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2414/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Trade Representative considers that rights under the Agreement on Trade-Related Aspects of Intellectual Property Rights or the GATT 1994 relating to products subject to intellectual property protection are involved, the Trade Representative shall make the determination required under paragraph (1) not later than 30 days after the date on which the dispute settlement procedure is concluded; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05da3375-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2414/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Trade Representative does not consider that a trade agreement, including the Agreement on Trade-Related Aspects of Intellectual Property Rights, is involved or does not make a determination described in subparagraph (B) with respect to such investigation, the Trade Representative shall make the determinations required under paragraph (1) with respect to such investigation not later than the date that is 6 months after the date on which such investigation is initiated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05da3376-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2414/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the Trade Representative determines with respect to an investigation initiated by reason of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2412/b/2"},"text":"section 2412(b)(2) of this title","children":[],"tail":" (other than an investigation involving a trade agreement) that—"}],"tail":null},{"tag":"clause","attrib":{"id":"id05da3377-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2414/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complex or complicated issues are involved in the investigation that require additional time,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05da3378-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2414/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the foreign country involved in the investigation is making substantial progress in drafting or implementing legislative or administrative measures that will provide adequate and effective protection of intellectual property rights, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05da3379-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2414/a/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such foreign country is undertaking enforcement measures to provide adequate and effective protection of intellectual property rights,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Trade Representative shall publish in the Federal Register notice of such determination and shall make the determinations required under paragraph (1) with respect to such investigation by no later than the date that is 9 months after the date on which such investigation is initiated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05da337a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2414/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In any case in which a dispute is not resolved before the close of the minimum dispute settlement period provided for in a trade agreement, the Trade Representative, within 15 days after the close of such dispute settlement period, shall submit a report to Congress setting forth the reasons why the dispute was not resolved within the minimum dispute settlement period, the status of the case at the close of the period, and the prospects for resolution. For purposes of this paragraph, the minimum dispute settlement period provided for under any such trade agreement is the total period of time that results if all stages of the formal dispute settlement procedures are carried out within the time limitations specified in the agreement, but computed without regard to any extension authorized under the agreement at any stage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05da337b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2414/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation before determinations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05da337c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2414/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Before making the determinations required under subsection (a)(1), the Trade Representative, unless expeditious action is required—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05da337d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2414/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall provide an opportunity (after giving not less than 30 days notice thereof) for the presentation of views by interested persons, including a public hearing if requested by any interested person,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05da337e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2414/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall obtain advice from the appropriate committees established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2155"},"text":"section 2155 of this title","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05da337f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2414/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may request the views of the United States International Trade Commission regarding the probable impact on the economy of the United States of the taking of action with respect to any goods or service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05da3380-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2414/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Trade Representative does not comply with the requirements of subparagraphs (A) and (B) of paragraph (1) because expeditious action is required, the Trade Representative shall, after making the determinations under subsection (a)(1), comply with such subparagraphs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05da3381-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2414/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Trade Representative shall publish in the Federal Register any determination made under subsection (a)(1), together with a description of the facts on which such determination is based.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05da3382-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/tIII/s304"},"text":"Pub. L. 93–618, title III, § 304","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/39/tIX/s901"},"text":"Pub. L. 96–39, title IX, § 901","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/297"},"text":"93 Stat. 297","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/573/tIII"},"text":"Pub. L. 98–573, title III","children":[],"tail":", §§ 304(d)(2)(C), 306(c)(2)(C)(ii), "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3005"},"text":"98 Stat. 3005","children":[],"tail":", 3012; "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tI/s1301/a"},"text":"Pub. L. 100–418, title I, § 1301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1170"},"text":"102 Stat. 1170","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/tIII/s314/d"},"text":"Pub. L. 103–465, title III, § 314(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4940"},"text":"108 Stat. 4940","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/295/s20/c/6"},"text":"Pub. L. 104–295, § 20(c)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3528"},"text":"110 Stat. 3528","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/429/tII/s2201/a"},"text":"Pub. L. 108–429, title II, § 2201(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2004-12-03"},"text":"Dec. 3, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2598"},"text":"118 Stat. 2598","children":[],"tail":", 2599.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05da3383-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05da3384-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id05da3385-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/429/s2201/a"},"text":"Pub. L. 108–429, § 2201(a)","children":[],"tail":", in introductory provisions, inserted “except an investigation initiated pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2412/b/2/A"},"text":"section 2412(b)(2)(A) of this title","children":[],"tail":" involving rights under the Agreement on Trade-Related Aspects of Intellectual Property Rights (referred to in "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3511/d/15"},"text":"section 3511(d)(15) of this title","children":[],"tail":") or the GATT 1994 (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3501/1/B"},"text":"section 3501(1)(B) of this title","children":[],"tail":") relating to products subject to intellectual property protection,” after “agreement,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/429/s2201/b"},"text":"Pub. L. 108–429, § 2201(b)","children":[],"tail":", amended subpar. (A) generally. Prior to amendment, subpar. (A) read as follows: “If an investigation is initiated under this subchapter by reason of "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2412/b/2"},"text":"section 2412(b)(2) of this title","children":[],"tail":" and the Trade Representative does not consider that a trade agreement, including the Agreement on Trade-Related Aspects of Intellectual Property Rights (referred to in "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3511/d/15"},"text":"section 3511(d)(15) of this title","children":[],"tail":"), is involved or does not make a determination described in subparagraph (B) with respect to such investigation, the Trade Representative shall make the determinations required under paragraph (1) with respect to such investigation by no later than the date that is 6 months after the date on which such investigation is initiated.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/295"},"text":"Pub. L. 104–295","children":[],"tail":" inserted “Rights” after “Intellectual Property”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/s314/d/1"},"text":"Pub. L. 103–465, § 314(d)(1)","children":[],"tail":", struck out “(other than the agreement on subsidies and countervailing measures described in "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2503/c/5"},"text":"section 2503(c)(5) of this title","children":[],"tail":")” after “trade agreement”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/s314/d/2/A"},"text":"Pub. L. 103–465, § 314(d)(2)(A)","children":[],"tail":", inserted “does not consider that a trade agreement, including the Agreement on Trade-Related Aspects of Intellectual Property (referred to in "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3511/d/15"},"text":"section 3511(d)(15) of this title","children":[],"tail":"), is involved or” after “Trade Representative” the first place appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/s314/d/2/B"},"text":"Pub. L. 103–465, § 314(d)(2)(B)","children":[],"tail":", in introductory provisions, substituted “an investigation initiated by reason of "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2412/b/2"},"text":"section 2412(b)(2) of this title","children":[],"tail":" (other than an investigation involving a trade agreement)” for “any investigation initiated by reason of "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2412/b/2"},"text":"section 2412(b)(2) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/s314/d/3"},"text":"Pub. L. 103–465, § 314(d)(3)","children":[],"tail":", struck out “(other than the agreement on subsidies and countervailing measures described in "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2503/c/5"},"text":"section 2503(c)(5) of this title","children":[],"tail":")” after “in a trade agreement”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418"},"text":"Pub. L. 100–418","children":[],"tail":" am