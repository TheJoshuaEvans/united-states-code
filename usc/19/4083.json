{"tag":"section","attrib":{"id":"id064307ad-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4083"},"text":null,"children":[{"tag":"num","attrib":{"value":"4083"},"text":"§ 4083.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of relief","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id064307ae-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4083/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (b), any import relief that the President provides under subsection (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4082"},"text":"section 4082 of this title","children":[],"tail":" may not, in the aggregate, be in effect for more than 3 years."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id064307af-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4083/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the initial period for any import relief provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4082"},"text":"section 4082 of this title","children":[],"tail":" is less than 3 years, the President may extend the effective period of any import relief provided under that section, subject to the limitation set forth in subsection (a), if the President determines that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id064307b0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4083/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the import relief continues to be necessary to remedy or prevent serious damage and to facilitate adjustment by the domestic industry to import competition; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064307b1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4083/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is evidence that the industry is making a positive adjustment to import competition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id064307b2-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/53/tIII/s323"},"text":"Pub. L. 109–53, title III, § 323","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-02"},"text":"Aug. 2, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/493"},"text":"119 Stat. 493","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id064307b3-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id064307b4-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination of section by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/53/s107/d"},"text":"section 107(d) of Pub. L. 109–53","children":[],"tail":", see Effective and Termination Dates note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id064307b5-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id064307b6-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective and Termination Dates","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date the Dominican Republic-Central America-United States Free Trade Agreement enters into force (","children":[{"tag":"date","attrib":{"date":"2006-03-01"},"text":"Mar. 1, 2006","children":[],"tail":") and to cease to have effect on the date the Agreement ceases to be in force with respect to the United States, and, during any period in which a country ceases to be a CAFTA–DR country, to cease to have effect with respect to such country, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/53/s107"},"text":"section 107 of Pub. L. 109–53","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s4001"},"text":"section 4001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
