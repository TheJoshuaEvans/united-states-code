{"tag":"section","attrib":{"id":"id050f6901-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s81o"},"text":null,"children":[{"tag":"num","attrib":{"value":"81o"},"text":"§ 81o.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Residents of zone","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id050f6902-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s81o/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persons allowed to reside in zone","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No person shall be allowed to reside within the zone except Federal, State, or municipal officers or agents whose resident presence is deemed necessary by the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id050f6903-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s81o/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and regulations for employees entering and leaving zone","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall prescribe rules and regulations regarding employees and other persons entering and leaving the zone. All rules and regulations concerning the protection of the revenue shall be approved by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id050f6904-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s81o/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion from zone of goods or process of treatment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board may at any time order the exclusion from the zone of any goods or process of treatment that in its judgment is detrimental to the public interest, health, or safety.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id050f6905-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s81o/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retail trade within zone","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No retail trade shall be conducted within the zone except under permits issued by the grantee and approved by the Board. Such permittees shall sell no goods except such domestic or duty-paid or duty-free goods as are brought into the zone from customs territory.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id050f6906-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s81o/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption from State and local ad valorem taxation of tangible personal property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Tangible personal property imported from outside the United States and held in a zone for the purpose of storage, sale, exhibition, repackaging, assembly, distribution, sorting, grading, cleaning, mixing, display, manufacturing, or processing, and tangible personal property produced in the United States and held in a zone for exportation, either in its original form or as altered by any of the above processes, shall be exempt from State and local ad valorem taxation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id050f6907-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-18/ch590/s15"},"text":"June 18, 1934, ch. 590, § 15","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/1002"},"text":"48 Stat. 1002","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/573/tII/s231/b/1"},"text":"Pub. L. 98–573, title II, § 231(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2991"},"text":"98 Stat. 2991","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id050f6908-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id050f6909-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id050f690a-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/573"},"text":"Pub. L. 98–573","children":[],"tail":" added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id050f690b-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id050f690c-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/573/tII/s231/b/2"},"text":"Pub. L. 98–573, title II, § 231(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2991"},"text":"98 Stat. 2991","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/573/tII/s231/b/2"},"text":"“The amendment made by paragraph (1) [amending this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1983-01-01"},"text":"January 1, 1983","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
