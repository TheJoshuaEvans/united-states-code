{"tag":"section","attrib":{"id":"id05655115-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1600"},"text":null,"children":[{"tag":"num","attrib":{"value":"1600"},"text":"§ 1600.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of the customs laws to other seizures by customs officers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The procedures set forth in sections 1602 through 1619 of this title shall apply to seizures of any property effected by customs officers under any law enforced or administered by the Customs Service unless such law specifies different procedures.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id05655116-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title IV, § 600, as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s323"},"text":"Pub. L. 98–473, title II, § 323","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2057"},"text":"98 Stat. 2057","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05655117-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05655118-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id05655119-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 600 of ","children":[{"tag":"ref","at