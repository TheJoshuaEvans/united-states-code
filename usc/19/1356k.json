tag":"quotedContent","attrib":{"origin":"/us/pl/96/599/s1"},"text":"“This Act [enacting this section and sections 1356","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":" to 1356n of this title] may be cited as the ‘International Coffee Agreement Act of 1980’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
