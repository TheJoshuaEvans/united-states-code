"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"   6505.00.15","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6505.00.50","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"6506.99.60","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"   6505.00.20","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"6505.00.60","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"   6505.00.25","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"6505.00.80","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0653d08f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4454/c/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President determines, after receiving the advice of the United States International Trade Commission in accordance with section 503(e) of the Trade Act of 1974 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2463/e"},"text":"19 U.S.C. 2463(e)","children":[],"tail":"), that the article is not import-sensitive in the context of imports from Nepal; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0653d090-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4454/c/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to subparagraph (C), the sum of the cost or value of the materials produced in, and the direct costs of processing operations performed in, Nepal or the customs territory of the United States is not less than 35 percent of the appraised value of the article at the time it is entered.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0653d091-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4454/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An article shall not be treated as the growth, product, or manufacture of Nepal for purposes of subparagraph (A)(i)(I) by virtue of having merely undergone—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0653d092-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4454/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" simple combining or packaging operations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0653d093-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4454/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mere dilution with water or mere dilution with another substance that does not materially alter the characteristics of the article.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0653d094-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4454/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on United States cost","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subparagraph (A)(v), the cost or value of materials produced in, and the direct costs of processing operations performed in, the customs territory of the United States and attributed to the 35-percent requirement under that subparagraph may not exceed 15 percent of the appraised value of the article at the time it is entered.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0653d095-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4454/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Verification with respect to transshipment for textile and apparel articles","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0653d096-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4454/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than January 1, April 1, July 1, and October 1 of each calendar year, the Commissioner shall verify that textile and apparel articles imported from Nepal to which preferential treatment is extended under this section are not being unlawfully transshipped into the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0653d097-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4454/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to President","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Commissioner determines under subparagraph (A) that textile and apparel articles imported from Nepal to which preferential treatment is extended under this section are being unlawfully transshipped into the United States, the Commissioner shall report that determination to the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0653d098-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4454/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trade facilitation and capacity building","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0653d099-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4454/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress makes the following findings:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0653d09a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4454/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As a land-locked least-developed country, Nepal has severe challenges reaching markets and developing capacity to export goods. As of 2015, exports from Nepal are approximately $800,000,000 per year, with India the major market at $450,000,000 annually. The United States imports about $80,000,000 worth of goods from Nepal, or 10 percent of the total goods exported from Nepal.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0653d09b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4454/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The World Bank has found evidence that the overall export competitiveness of Nepal has been declining since 2005. Indices compiled by the World Bank and the Organization for Economic Co-operation and Development found that export costs in Nepal are high with respect to both air cargo and container shipments relative to other low-income countries. Such indices also identify particular weaknesses in Nepal with respect to automation of customs and other trade functions, involvement of local exporters and importers in preparing regulations and trade rules, and export finance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0653d09c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4454/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Implementation by Nepal of the Agreement on Trade Facilitation of the World Trade Organization could directly address some of the weaknesses described in subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0653d09d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4454/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of trade facilitation and capacity building program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2016-02-24"},"text":"February 24, 2016","children":[],"tail":", the President shall, in consultation with the Government of Nepal, establish a trade facilitation and capacity building program for Nepal—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0653d09e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4454/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enhance the central export promotion agency of Nepal to support successful exporters and to build awareness among potential exporters in Nepal about opportunities abroad and ways to manage trade documentation and regulations in the United States and other countries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0653d09f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4454/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide export finance training for financial institutions in Nepal and the Government of Nepal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0653d0a0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4454/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist the Government of Nepal in maintaining publication on the Internet of all trade regulations, forms for exporters and importers, tax and tariff rates, and other documentation relating to exporting goods and developing a robust public-private dialogue, through its National Trade Facilitation Committee, for Nepal to identify timelines for implementation of key reforms and solutions, as provided for under the Agreement on Trade Facilitation of the World Trade Organization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0653d0a1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4454/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase access to guides for importers and exporters, through publication of such guides on the Internet, including rules and documentation for United States tariff preference programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0653d0a2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4454/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than one year after ","children":[{"tag":"date","attrib":{"date":"2016-02-24"},"text":"February 24, 2016","children":[],"tail":", and annually thereafter, the President shall monitor, review, and report to Congress on the implementation of this section, the compliance of Nepal with subsection (b)(1), and the trade and investment policy of the United States with respect to Nepal."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0653d0a3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4454/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of preferential treatment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No preferential treatment extended under this section shall remain in effect after ","children":[{"tag":"date","attrib":{"date":"2025-12-31"},"text":"December 31, 2025","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0653d0a4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4454/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of this section shall take effect on the date that is 30 days after ","children":[{"tag":"date","attrib":{"date":"2016-02-24"},"text":"February 24, 2016","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0653d0a5-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/125/tIX/s915"},"text":"Pub. L. 114–125, title IX, § 915","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-24"},"text":"Feb. 24, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/276"},"text":"130 Stat. 276","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0653d0a6-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0653d0a7-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0653d0a8-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3703/a"},"text":"Section 3703(a) of this title","children":[],"tail":", referred to in subsec. (b)(1)(A), was amended and the subsection (a) designation struck out by "},{"tag":"ref","attrib":{"href":"/us/pl/114/27/tI/s111"},"text":"Pub. L. 114–27, title I, § 111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-06-29"},"text":"June 29, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/370"},"text":"129 Stat. 370","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Trade Act of 1974, referred to in subsec. (b)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618"},"text":"Pub. L. 93–618","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1978"},"text":"88 Stat. 1978","children":[],"tail":". Title V of the Act is classified generally to subchapter V (§ 2461 et seq.) of chapter 12 of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2101"},"text":"section 2101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Harmonized Tariff Schedule of the United States, referred to in subsec. (c)(2)(A)(iii), is not set out in the Code. See Publication of Harmonized Tariff Schedule note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1202"},"text":"section 1202 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id0653d0a9-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id0653d0aa-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail