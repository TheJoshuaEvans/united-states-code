{"tag":"section","attrib":{"id":"id0653d07c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4454"},"text":null,"children":[{"tag":"num","attrib":{"value":"4454"},"text":"§ 4454.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trade preferences for Nepal","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0653d07d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4454/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress makes the following findings:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0653d07e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4454/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nepal is among the least developed countries in the world, with a per capita gross national income of $730 in 2014.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0653d07f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4454/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nepal suffered a devastating earthquake in April 2015, with subsequent aftershocks. More than 9,000 people died and approximately 23,000 people were injured.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0653d080-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4454/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0653d081-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4454/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President may authorize the provision of preferential treatment under this section to articles that are imported directly from Nepal into the customs territory of the United States pursuant to subsection (c) if the President determines—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0653d082-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4454/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that Nepal meets the requirements set forth in paragraphs (1), (2), and (3) of section 3703(a) ","children":[{"tag":"ref","attrib":{"idref":"fn002174"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002174"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0653d083-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4454/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after taking into account the factors set forth in paragraphs (1) through (7) of subsection (c) of section 502 of the Trade Act of 1974 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2462"},"text":"19 U.S.C. 2462","children":[],"tail":"), that Nepal meets the eligibility requirements of such section 502."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0653d084-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4454/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal, suspension, or limitation of preferential treatment; mandatory graduation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of subsections (d) and (e) of section 502 of the Trade Act of 1974 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2462"},"text":"19 U.S.C. 2462","children":[],"tail":") shall apply with respect to Nepal to the same extent and in the same manner as such provisions apply with respect to beneficiary developing countries under title V of that Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2461"},"text":"19 U.S.C. 2461","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0653d085-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4454/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible articles","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0653d086-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4454/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An article described in paragraph (2) may enter the customs territory of the United States free of duty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0653d087-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4454/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Articles described","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0653d088-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4454/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An article is described in this paragraph if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0653d089-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4454/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0653d08a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4454/c/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the article is the growth, product, or manufacture of Nepal; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0653d08b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4454/c/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a textile or apparel article, Nepal is the country of origin of the article, as determined under section 102.21 of title 19, Code of Federal Regulations (as in effect on the day before ","children":[{"tag":"date","attrib":{"date":"2016-02-24"},"text":"February 24, 2016","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0653d08c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4454/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the article is imported directly from Nepal into the customs territory of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0653d08d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4454/c/2/A/iii"},"