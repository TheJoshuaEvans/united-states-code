{"tag":"section","attrib":{"id":"id05f200e6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2578"},"text":null,"children":[{"tag":"num","attrib":{"value":"2578"},"text":"§ 2578.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of United States participation in international standard-setting activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05f200e7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2578/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall designate an agency to be responsible for informing the public of the sanitary and phytosanitary standard-setting activities of each international standard-setting organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05f200e8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2578/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than June 1 of each year, the agency designated under subsection (a) with respect to each international standard-setting organization shall publish notice in the Federal Register of the information specified in subsection (c) with respect to that organization. The notice shall cover the period ending on June 1 of the year in which the notice is published, and beginning on the date of the preceding notice under this subsection, except that the first such notice shall cover the 1-year period ending on the date of the notice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05f200e9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2578/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The information to be provided in the notice under subsection (b) is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05f200ea-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2578/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sanitary or phytosanitary standards under consideration or planned for consideration by that organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f200eb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2578/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for each sanitary or phytosanitary standard specified in paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05f200ec-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2578/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the consideration or planned consideration of the standard;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05f200ed-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2578/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the United States is participating or plans to participate in the consideration of the standard;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05f200ee-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2578/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agenda for the United States participation, if any; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05f200ef-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2578/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agency responsible for representing the United States with respect to the standard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05f200f0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2578/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public comment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The agency specified in subsection (c)(2)(D) shall provide an opportunity for public comment with respect to the standards for which the agency is responsible and shall take the comments into account in participating in the consideration of the standards and in proposing matters to be considered by the organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05f200f1-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39/tIV/s491"},"text":"Pub. L. 96–39, title IV, § 491","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/tIV/s432"},"text":"Pub. L. 103–465, title IV, § 432","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4970"},"text":"108 Stat. 4970","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05f200f2-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id05f200f3-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id05f200f4-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date of entry into force of the WTO Agreement with respect to the United States (","children":[{"tag":"date","attrib":{"date":"1995-01-01"},"text":"Jan. 1, 1995","children":[],"tail":"), except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/s451"},"text":"section 451 of Pub. L. 103–465","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3601"},"text":"section 3601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id05f200f5-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id05f200f6-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Designation of Agency","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Secretary of Agriculture designated under this section as official responsible for informing public of sanitary and phytosanitary standard-setting activities of each international standard-setting organization, see par. (4) of Proc. No. 6780, ","children":[{"tag":"date","attrib":{"date":"1995-03-23"},"text":"Mar. 23, 1995","children":[],"tail":", 60 F.R. 15847, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3511"},"text":"section 3511 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
