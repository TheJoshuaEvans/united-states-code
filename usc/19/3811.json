{"tag":"section","attrib":{"id":"id063e4b98-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3811"},"text":null,"children":[{"tag":"num","attrib":{"value":"3811"},"text":"§ 3811.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on impact of trade promotion authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id063e4b99-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3811/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2002-08-06"},"text":"August 6, 2002","children":[],"tail":", the International Trade Commission shall report to the Committee on Finance of the Senate and the Committee on Ways and Means of the House of Representatives regarding the economic impact on the United States of the trade agreements described in subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id063e4b9a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3811/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The trade agreements described in this subsection are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id063e4b9b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3811/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States-Israel Free Trade Agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id063e4b9c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/