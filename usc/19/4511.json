{"tag":"section","attrib":{"id":"id0653d0c9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4511"},"text":null,"children":[{"tag":"num","attrib":{"value":"4511"},"text":"§ 4511.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval and entry into force of the USMCA","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0653d0ca-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4511/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of USMCA and statement of administrative action","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4205"},"text":"section 4205 of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2191"},"text":"section 2191 of this title","children":[],"tail":", Congress approves—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0653d0cb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4511/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Protocol Replacing the North American Free Trade Agreement with the Agreement between the United States of America, the United Mexican States, and Canada, done at Buenos Aires on ","children":[{"tag":"date","attrib":{"date":"2018-11-30"},"text":"November 30, 2018","children":[],"tail":", as submitted to Congress on "},{"tag":"date","attrib":{"date":"2019-12-13"},"text":"December 13, 2019","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0653d0cc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4511/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Agreement between the United States of America, the United Mexican States, and Canada, attached as an Annex to the Protocol, as amended by the Protocol of Amendment to the Agreement between the United States of America, the United Mexican States, and Canada, done at Mexico City on ","children":[{"tag":"date","attrib":{"date":"2019-12-10"},"text":"December 10, 2019","children":[],"tail":", as submitted to Congress on "},{"tag":"date","attrib":{"date":"2019-12-13"},"text":"December 13, 2019","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0653d0cd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4511/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the statement of administrative action proposed to implement that Agreement, as submitted to Congress on ","children":[{"tag":"date","attrib":{"date":"2019-12-13"},"text":"December 13, 2019","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0653d0ce-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4511/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions for entry into force of the agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President is authorized to provide for the USMCA to enter into force with respect to Canada and Mexico not earlier than 30 days after the date on which the President submits to Congress the written notice required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4205/a/1/G"},"text":"section 4205(a)(1)(G) of this title","children":[],"tail":", which shall include the date on which the USMCA will enter into force."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0653d0cf-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113/tI/s101"},"text":"Pub. L. 116–113, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-01-29"},"text":"Jan. 29, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/14"},"text":"134 Stat. 14","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
