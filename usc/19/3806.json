{"tag":"section","attrib":{"id":"id063c0264-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3806"},"text":null,"children":[{"tag":"num","attrib":{"value":"3806"},"text":"§ 3806.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of certain trade agreements for which negotiations have already begun","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id063c0265-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3806/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain agreements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding the prenegotiation notification and consultation requirement described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3804/a"},"text":"section 3804(a) of this title","children":[],"tail":", if an agreement to which "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3803/b"},"text":"section 3803(b) of this title","children":[],"tail":" applies—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id063c0266-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3806/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is entered into under the auspices of the World Trade Organization,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id063c0267-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3806/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is entered into with Chile,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id063c0268-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3806/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is entered into with Singapore, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id063c0269-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3806/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishes a Free Trade Area for the Americas,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"and results from negotiations that were commenced before ","children":[{"tag":"date","attrib":{"date":"2002-08-06"},"text":"August 6, 2002","children":[],"tail":", subsection (b) shall apply."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id063c026a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3806/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of agreements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any agreement to which subsection (a) applies—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id063c026b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3806/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicability of the trade authorities procedures to implementing bills shall be determined without regard to the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3804/a"},"text":"section 3804(a) of this title","children":[],"tail":" (relating only to 90 days notice prior to initiating negotiations), and any procedural disapproval resolution under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3805/b/1/B"},"text":"section 3805(b)(1)(B) of this title","children":[],"tail":" shall not be in order on the basis of a failure or refusal to comply with the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3804/a"},"text":"section 3804(a) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id063c026c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3806/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the President shall, as soon as feasible after ","children":[{"tag":"date","attrib":{"date":"2002-08-06"},"text":"August 6, 2002","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id063c026d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3806/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the Congress of the negotiations described in subsection (a), the specific United States objectives in the negotiations, and whether the President is seeking a new agreement or changes to an existing agreement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id063c026e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3806/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before and after submission of the notice, consult regarding the negotiations with the committees referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3804/a/2"},"text":"section 3804(a)(2) of this title","children":[],"tail":" and the Congressional Oversight Group convened under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3807"},"text":"section 3807 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id063c026f-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/210/dB/tXXI/s2106"},"text":"Pub. L. 107–210, div. B, title XXI, § 2106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-06"},"text":"Aug. 6, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1016"},"text":"116 Stat. 1016","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id063c0270-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id063c0271-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id063c0272-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of functions of President under this section, see section 1 of Ex. Ord. No. 13277, ","children":[{"tag":"date","attrib":{"date":"2002-11-19"},"text":"Nov. 19, 2002","children":[],"tail":", 67 F.R. 70305, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3801"},"text":"section 3801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
