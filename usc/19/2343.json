{"tag":"section","attrib":{"id":"id05ce4ca2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2343"},"text":null,"children":[{"tag":"num","attrib":{"value":"2343"},"text":"§ 2343.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05ce4ca3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2343/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discretion of Secretary; types of assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may provide a firm, on terms and conditions as the Secretary determines to be appropriate, with such technical assistance as in his judgment will carry out the purposes of this part with respect to the firm. The technical assistance furnished under this part may consist of one or more of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05ce4ca4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2343/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assistance to a firm in preparing its petition for certification of eligibility under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2341"},"text":"section 2341 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05ce4ca5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2343/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assistance to a certified firm in developing a proposal for its economic adjustment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05ce4ca6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2343/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assistance to a certified firm in the implementation of such a proposal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05ce4ca7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2343/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Utilization of existing agencies, private individuals, etc., in furnishing assistance; grants to intermediary organizations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05ce4ca8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2343/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall furnish technical assistance under this part through existing agencies and through private individuals, firms, or institutions (including private consulting services), or by grants to intermediary organizations (including Trade Adjustment Assistance Centers).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05ce4ca9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2343/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of assistance furnished through private individuals, firms, or institutions (including private consulting services), the Secretary may share the cost thereof (but not more than 75 percent of such cost for assistance described in paragraph (2) or (3) of subsection (a) may be borne by the United States).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05ce4caa-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2343/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may make grants to intermediary organizations in order to defray up to 100 percent of administrative expenses incurred in providing such technical assistance to a firm.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05ce4cab-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/tII/s253"},"text":"Pub. L. 93–618, title II, § 253","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2031"},"text":"88 Stat. 2031","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXXV/s2521"},"text":"Pub. L. 97–35, title XXV, § 2521","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/890"},"text":"95 Stat. 890","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/272/tXIII/s13006/a/3"},"text":"Pub. L. 99–272, title XIII, § 13006(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-04-07"},"text":"Apr. 7, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/304"},"text":"100 Stat. 304","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/5/dB/tI/s1867/b"},"text":"Pub. L. 111–5, div. B, title I, § 1867(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/400"},"text":"123 Stat. 400","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/40/tII/s201/b"},"text":"Pub. L. 112–40, title II, § 201(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2011-10-21"},"text":"Oct. 21, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/403"},"text":"125 Stat. 403","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/27/tIV/s402/b"},"text":"Pub. L. 114–27, title IV, § 402(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2015-06-29"},"text":"June 29, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/374"},"text":"129 Stat. 374","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05ce4cac-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id05ce4cad-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Assistance","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination of assistance under this part after ","children":[{"tag":"date","attrib":{"date":"2022-06-30"},"text":"June 30, 2022","children":[],"tail":", see Termination Date note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05ce4cae-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id05ce4caf-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section reflects the ","children":[{"tag":"date","attrib":{"date":"2021-07-01"},"text":"July 1, 2021","children":[],"tail":", reversion to provisions in effect on "},{"tag":"date","attrib":{"date":"2014-01-01"},"text":"Jan. 1, 2014","children":[],"tail":". See Effective and Termination Dates of 2015 Revival note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/40/s233"},"text":"Section 233 of Pub. L. 112–40","childr