{"tag":"section","attrib":{"id":"id051694cc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s391"},"text":null,"children":[{"tag":"num","attrib":{"value":"391"},"text":"§ 391.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ascertainment of duties on grain","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the purpose of estimating the duties on importations of grain, the number of bushels shall be ascertained by weight, instead of by measuring; and sixty pounds of wheat, fifty-six pounds of corn, fifty-six pounds of rye, forty-eight pounds of barley, thirty-two pounds of oats, sixty pounds of peas, and forty-two pounds of buckwheat, avoirdupois weight, shall respectively be estimated as a bushel.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id051694cd-3a70-11f1-8ace-823fb135378d"},"text":"(R.S. § 2919.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id051694ce-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id051694cf-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id051694d0-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 2919 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1866-07-18/ch201/s38"},"text":"act July 18, 1866, ch. 201, § 38","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/14/187"},"text":"14 Stat. 187","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
