{"tag":"section","attrib":{"id":"id06588b18-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4551"},"text":null,"children":[{"tag":"num","attrib":{"value":"4551"},"text":"§ 4551.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" USMCA article impact in import relief cases under Trade Act of 1974","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id06588b19-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4551/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If, in any investigation initiated under chapter 1 of title II of the Trade Act of 1974 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2251"},"text":"19 U.S.C. 2251","children":[],"tail":" et seq.], the International Trade Commission makes an affirmative determination (or a determination which the President may treat as an affirmative determination under such chapter by reason of "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1330/d"},"text":"section 1330(d) of this title","children":[],"tail":"), the International Trade Commission shall also find (and report to the President at the time such injury determination is submitted to the President) whether—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id06588b1a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4551/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" imports of the article from a USMCA country, considered individually, account for a substantial share of total imports; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06588b1b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4551/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" imports of the article from a USMCA country, considered individually or, in exceptional circumstances, imports from USMCA countries considered collectively, contribute importantly to the serious injury, or threat thereof, caused by imports.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id06588b1c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4551/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id06588b1d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4551/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Substantial import share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In determining whether imports from a USMCA country, considered individually, account for a substantial share of total imports, such imports normally shall not be considered to account for a substantial share of total imports if that country is not among the top 5 suppliers of the article subject to the investigation, measured in terms of import share during the most recent 3-year period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06588b1e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4551/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of “contribute importantly” standard","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In determining whether imports from a USMCA country or countries contribute importantly to the serious injury, or threat thereof, the International Trade Commission shall consider such factors as the change in the import share of the USMCA country or countries, and the level and change in the level of imports of such country or countries. In applying the preceding sentence, imports from a USMCA country or countries normally shall not be considered to contribute importantly to serious injury, or the threat thereof, if the growth rate of imports from such country or countries during the period in which an injurious increase in imports occurred is appreciably lower than the growth rate of total imports from all sources over the same period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id06588b1f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4551/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Contribute importantly” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4552/a"},"text":"section 4552(a) of this title","children":[],"tail":", the term “contribute importantly” refers to an important cause, but not necessarily the most important cause."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id06588b20-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113/tIII/s301"},"text":"Pub. L. 116–113, title III, § 301","children":[],"tail":", formerly "},{"tag":"ref","attrib":{"href":"/us/pl/103/182/tIII/s311"},"text":"Pub. L. 103–182, title III, § 311","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-08"},"text":"Dec. 8, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2106"},"text":"107 Stat. 2106","children":[],"tail":"; renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/116/113/s301"},"text":"§ 301 of Pub. L. 116–113","children":[],"tail":" and amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/113/tV/s502/b"},"text":"Pub. L. 116–113, title V, § 502(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-01-29"},"text":"Jan. 29, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/70"},"text":"134 Stat. 70","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id06588b21-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id06588b22-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id06588b23-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Trade Act of 1974, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618"},"text":"Pub. L. 93–618","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1978"},"text":"88 Stat. 1978","children":[],"tail":". Chapter 1 of title II of the Act is classified generally to part 1 (§ 2251 et seq.) of subchapter II of chapter 12 of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2101"},"text":"section 2101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id06588b24-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3371"},"text":"section 3371 of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/116/113"},"text":"Pub. L. 116–113","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id06588b25-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113/s502/b/4/A"},"text":"Pub. L. 116–113, § 502(b)(4)(A)","children":[],"tail":", (C), substituted “USMCA” for “NAFTA” in section catchline and wherever appearing in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113/s502/b/4/B"},"text":"Pub. L. 116–113, § 502(b)(4)(B)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t19/s4552/a"},"text":"section 4552(a) of this title","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3372/a"},"text":"section 3372(a) of this title","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id06588b26-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id06588b27-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2020 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113/tV/s502/e"},"text":"Pub. L. 116–113, title V, § 502(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-01-29"},"text":"Jan. 29, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/70"},"text":"134 Stat. 70","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/113/tV/s502/e"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each transfer, redesignation, and amendment made by this section [transferring sections 3371 and 3372 of this title, respectively, to and amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4552"},"text":"section 4552 of this title","children":[],"tail":"] shall—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take effect on the date on which the USMCA enters into force [","children":[{"tag":"date","attrib":{"date":"2020-07-01"},"text":"July 1, 2020","children":[],"tail":"]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" apply with respect to an investigation under chapter 1 of title II of the Trade Act of 1974 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2251"},"text":"19 U.S.C. 2251","children":[],"tail":" et seq.) initiated on or after that date."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transition from nafta","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of an investigation under chapter 1 of title II of the Trade Act of 1974 initiated before the date on which the USMCA enters into force—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transfers, redesignations, and amendments made by this section shall not apply with respect to the investigation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sections 311 and 312 of the North American Free Trade Agreement Implementation Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3371"},"text":"19 U.S.C. 3371","children":[],"tail":" and 3372), as in effect on the day before that date, shall continue to apply on and after that date with respect to the investigation.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definition of “USMCA” as used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113/s502/e"},"text":"section 502(e) of Pub. L. 116–113","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s4502"},"text":"section 4502 of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
