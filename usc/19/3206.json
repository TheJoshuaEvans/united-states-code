{"tag":"section","attrib":{"id":"id0609cece-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3206"},"text":null,"children":[{"tag":"num","attrib":{"value":"3206"},"text":"§ 3206.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of preferential treatment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0609cecf-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3206/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No duty-free treatment or other preferential treatment extended to beneficiary countries under this chapter shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0609ced0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3206/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" remain in effect—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0609ced1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3206/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to Colombia after ","children":[{"tag":"date","attrib":{"date":"2013-07-31"},"text":"July 31, 2013","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0609ced2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3206/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to Peru after ","children":[{"tag":"date","attrib":{"date":"2010-12-31"},"text":"December 31, 2010","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0609ced3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3206/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" remain in effect with respect to Ecuador after ","children":[{"tag":"date","attrib":{"date":"2009-06-30"},"text":"June 30, 2009","children":[],"tail":", except that duty-free treatment and other preferential treatment under this chapter shall remain in effect with respect to Ecuador during the period beginning on "},{"tag":"date","attrib":{"date":"2009-07-01"},"text":"July 1, 2009","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"2013-07-31"},"text":"July 31, 2013","children":[],"tail":", unless the President reviews the criteria set forth in "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3202"},"text":"section 3202 of this title","children":[],"tail":", and on or before "},{"tag":"date","attrib":{"date":"2009-06-30"},"text":"June 30, 2009","children":[],"tail":", reports to the Committee on Finance of the Senate and the Committee on Ways and Means of the House of Representatives pursuant to subsection (b) that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0609ced4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3206/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President has determined that Ecuador does not satisfy the requirements set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3202/c"},"text":"section 3202(c) of this title","children":[],"tail":" for being designated as a beneficiary country; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0609ced5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3206/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in making that determination, the President has taken into account each of the factors set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3202/d"},"text":"section 3202(d) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0609ced6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3206/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" remain in effect with respect to Bolivia after ","children":[{"tag":"date","attrib":{"date":"2009-06-30"},"text":"June 30, 2009","children":[],"tail":", except that duty-free treatment and other preferential treatment under this chapter shall remain in effect with respect to Bolivia during the period beginning on "},{"tag":"date","attrib":{"date":"2009-07-01"},"text":"July 1, 2009","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"2009-12-31"},"text":"December 31, 2009","children":[],"tail":", only if the President reviews the criteria set forth in "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3202"},"text":"section 3202 of this title","children":[],"tail":", and on or before "},{"tag":"date","attrib":{"date":"2009-06-30"},"text":"June 30, 2009","children":[],"tail":", reports to the Committee on Finance of the Senate and the Committee on Ways and Means of the House of Representatives pursuant to subsection (b) that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0609ced7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3206/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President has determined that Bolivia satisfies the requirements set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3202/c"},"text":"section 3202(c) of this title","children":[],"tail":" for being designated as a beneficiary country; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0609ced8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3206/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in making that determination, the President has taken into account each of the factors set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3202/d"},"text":"section 3202(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0609ced9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3206/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On or before ","children":[{"tag":"date","attrib":{"date":"2009-06-30"},"text":"June 30, 2009","children":[],"tail":", the President shall make determinations pursuant to subsections (a)(2)(A) and (a)(3)(A) and report to the Committee on Finance of the Senate and the Committee on Ways and Means of the House of Representatives on—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0609ceda-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3206/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such determinations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0609cedb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3206/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reasons for such determinations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0609cedc-3a70-11f1-8ace-823fb135378d"},"text":"(","children