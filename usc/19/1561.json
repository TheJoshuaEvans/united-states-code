{"tag":"section","attrib":{"id":"id055bdbf9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1561"},"text":null,"children":[{"tag":"num","attrib":{"value":"1561"},"text":"§ 1561.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public stores","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any premises owned or leased by the Government and used for the storage of merchandise for the final release of which from customs custody a permit has not been issued shall be known as a “public store.”","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id055bdbfa-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title IV, § 561, "},{"tag":"ref","attrib":{"href":"/us/stat/46/745"},"text":"46 Stat. 745","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id055bdbfb-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id055bdbfc-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id055bdbfd-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-09-21/ch356/tIV/s561"},"text":"act Sept. 21, 1922, ch. 356, title IV, § 561","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/978"},"text":"42 Stat. 978","children":[],"tail":". That section was superseded by section 561 of act "},{"tag":"date","attrib":{"date":"1930-06-17"},"text":"June 17, 1930","children":[],"tail":", comprising this section, and repealed by section 651(a)(1) of the 1930 act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
