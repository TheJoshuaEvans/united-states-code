{"tag":"section","attrib":{"id":"id05d57877-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401d"},"text":null,"children":[{"tag":"num","attrib":{"value":"2401d"},"text":"§ 2401d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benefit information to agricultural commodity producers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05d57878-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide full information to agricultural commodity producers about the benefit allowances, training, and other employment services available under this subchapter and about the petition and application procedures, and the appropriate filing dates, for such allowances, training, and services. The Secretary shall provide whatever assistance is necessary to enable groups to prepare petitions or applications for program benefits under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05d57879-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of benefits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05d5787a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall mail written notice of the benefits available under this part to each agricultural commodity producer that the Secretary has reason to believe is covered by a certification made under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05d5787b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall publish notice of the benefits available under this part to agricultural commodity producers that are covered by each certification made under this part in newspapers of general circulation in the areas in which such producers reside.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05d5787c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401d/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other Federal assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall also provide information concerning procedures for applying for and receiving all other Federal assistance and services available to workers facing economic distress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05d5787d-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/tII/s295"},"text":"Pub. L. 93–618, title II, § 295","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/210/dA/tI/s141/a"},"text":"Pub. L. 107–210, div. A, title I, § 141(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-06"},"text":"Aug. 6, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/949"},"text":"116 Stat. 949","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05d5787e-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id05d5787f-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Assistance","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination of assistance under this part after ","children":[{"tag":"date","attrib":{"date":"2022-06-30"},"text":"June 30, 2022","children":[],"tail":", see Termination Date note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id05d57880-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"terminationDate","id":"id05d57881-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Except as otherwise provided, technical assistance and financial assistance may not be provided under this part after ","children":[{"tag":"date","attrib":{"date":"2022-06-30"},"text":"June 30, 2022","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/618/s285"},"text":"section 285 of Pub. L. 93–618","children":[],"tail":", as modified by "},{"tag":"ref","attrib":{"href":"/us/pl/114/27/s406/a/7"},"text":"section 406(a)(7) of Pub. L. 114–27","children":[],"tail":", set out as notes preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2271"},"text":"section 2271 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
