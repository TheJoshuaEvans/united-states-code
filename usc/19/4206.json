{"tag":"section","attrib":{"id":"id064a3353-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4206"},"text":null,"children":[{"tag":"num","attrib":{"value":"4206"},"text":"§ 4206.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of certain trade agreements for which negotiations have already begun","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id064a3354-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4206/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain agreements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding the prenegotiation notification and consultation requirement described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4204/a"},"text":"section 4204(a) of this title","children":[],"tail":", if an agreement to which "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s4202/b"},"text":"section 4202(b) of this title","children":[],"tail":" applies—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id064a3355-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4206/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is entered into under the auspices of the World Trade Organization,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064a3356-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4206/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is entered into with the Trans-Pacific Partnership countries with respect to which notifications have been made in a manner consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4204/a/1/A"},"text":"section 4204(a)(1)(A) of this title","children":[],"tail":" as of "},{"tag":"date","attrib":{"date":"2015-06-29"},"text":"June 29, 2015","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064a3357-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4206/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is entered into with the European Union,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064a3358-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4206/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an agreement with respect to international trade in services entered into with WTO members with respect to which a notification has been made in a manner consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4204/a/1/A"},"text":"section 4204(a)(1)(A) of this title","children":[],"tail":" as of "},{"tag":"date","attrib":{"date":"2015-06-29"},"text":"June 29, 2015","children":[],"tail":", or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064a3359-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4206/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an agreement with respect to environmental goods entered into with WTO members with respect to which a notification has been made in a manner consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4204/a/1/A"},"text":"section 4204(a)(1)(A) of this title","children":[],"tail":" as of "},{"tag":"date","attrib":{"date":"2015-06-29"},"text":"June 29, 2015","children":[],"tail":","}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"and results from negotiations that were commenced before ","children":[{"tag":"date","attrib":{"date":"2015-06-29"},"text":"June 29, 2015","children":[],"tail":", subsection (b) shall apply."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id064a335a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4206/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of agreements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any agreement to which subsection (a) applies, the applicability of the trade authorities procedures to implementing bills shall be determined without regard to the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4204/a"},"text":"section 4204(a) of this title","children":[],"tail":" (relating only to notice prior to initiating negotiations), and any resolution under paragraph (1)(B), (3)(C), or (4)(C) of "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s4205/b"},"text":"section 4205(b) of this title","children":[],"tail":" shall not be in order on the basis of a failure or refusal to comply with the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s4204/a"},"text":"section 4204(a) of this title","children":[],"tail":", if (and only if) the President, as soon as feasible after "},{"tag":"date","attrib":{"date":"2015-06-29"},"text":"June 29, 2015","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id064a335b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4206/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notifies Congress of the negotiations described in subsection (a), the specific United States objectives in the negotiations, and whether the President is seeking a new agreement or changes to an existing agreement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064a335c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4206/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before and after submission of the notice, consults regarding the negotiations with the committees referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4204/a/1/B"},"text":"section 4204(a)(1)(B) of this title","children":[],"tail":" and the House and Senate Advisory Groups on Negotiations convened under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s4203/c"},"text":"section 4203(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id064a335d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4206/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002167"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002167"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Two subsecs. (c) have been enacted."}],"tail":" Agreement by Asia-Pacific Economic Cooperation members to reduce rates of duty on certain environmental goods"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding the notification requirement described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4202/a/2"},"text":"section 4202(a)(2) of this title","children":[],"tail":", the President may exercise the proclamation authority provided for in "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s4202/a/1/B"},"text":"section 4202(a)(1)(B) of this title","children":[],"tail":" to implement an agreement by members of the Asia-Pacific Economic Cooperation (APEC) to reduce any rate of duty on certain environmental goods included in Annex C of the APEC Leaders Declaration issued on "},{"tag":"date","attrib":{"date":"2012-09-09"},"text":"September 9, 2012","children":[],"tail":", if (and only if) the President, as soon as feasible after "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"December 18, 2015","children":[],"tail":", and before exercising proclamation authority under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s4202/a/1/B"},"text":"section 4202(a)(1)(B) of this title","children":[],"tail":", notifies Congress of the negotiations relating to the agreement and the specific United States objectives in the negotiations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id064a335e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4206/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" Agreement by Asia-Pacific Economic Cooperation members to reduce rates of duty on certain environmental goods"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding the notification requirement described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4202/a/2"},"text":"section 4202(a)(2) of this title","children":[],"tail":", the President may exercise the proclamation authority provided for in "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s4202/a/1/B"},"text":"section 4202(a)(1)(B) of this title","children":[],"tail":" to implement an agreement by members of the Asia-Pacific Economic Cooperation (APEC) to reduce any rate of duty on certain environmental goods included in Annex C of the APEC Leaders Declaration issued on "},{"tag":"date","attrib":{"date":"2012-09-09"},"text":"September 9, 2012","children":[],"tail":", if (and only if) the President, as soon as feasible after "},{"tag":"date","attrib":{"date":"2016-02-24"},"text":"February 24, 2016","children":[],"tail":", and before exercising proclamation authority under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s4202/a/1/B"},"text":"section 4202(a)(1)(B) of this title","children":[],"tail":", notifies Congress of the negotiations relating to the agreement and the specific United States objectives in the negotiations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id064a335f-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/26/tI/s107"},"text":"Pub. L. 114–26, title I, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-06-29"},"text":"June 29, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/355"},"text":"129 Stat. 355","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/113/dQ/tV/s502"},"text":"Pub. L. 114–113, div. Q, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/3127"},"text":"129 Stat. 3127","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/125/tIX/s916"},"text":"Pub. L. 114–125, title IX, § 916","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-24"},"text":"Feb. 24, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/279"},"text":"130 Stat. 279","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id064a3360-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id064a3361-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id064a3362-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tai