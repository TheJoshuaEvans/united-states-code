{"tag":"section","attrib":{"id":"id065d4563-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4588"},"text":null,"children":[{"tag":"num","attrib":{"value":"4588"},"text":"§ 4588.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of amendments to antidumping and countervailing duty law","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Any amendment enacted after the USMCA that is made to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id065d4564-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4588/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 303 ","children":[{"tag":"ref","attrib":{"idref":"fn002183"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002183"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" or title VII of the Tariff Act of 1930 ["},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1671"},"text":"19 U.S.C. 1671","children":[],"tail":" et seq.], or any successor statute, or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065d4565-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4588/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any other statute which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id065d4566-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4588/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides for judicial review of final determinations under such section, title, or successor statute, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id065d4567-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4588/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" indicates the standard of review to be applied,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall apply to goods from a USMCA country only to the extent specified in the amendment.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id065d4568-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113/tIV/s418"},"text":"Pub. L. 116–113, title IV, § 418","children":[],"tail":", formerly "},{"tag":"ref","attrib":{"href":"/us/pl/103/182/tIV/s408"},"text":"Pub. L. 103–182, title IV, § 408","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-08"},"text":"Dec. 8, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2140"},"text":"107 Stat. 2140","children":[],"tail":"; renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/116/113/s418"},"text":"§ 418 of Pub. L. 116–113","children":[],"tail":" and amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/113/tV/s504/i"},"text":"Pub. L. 116–113, title V, § 504(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-01-29"},"text":"Jan. 29, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/76"},"text":"134 Stat. 76","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id065d4569-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id065d456a-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id065d456b-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Tariff Act of 1930, referred to in par. (1), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"act June 17, 1930, ch. 497","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/590"},"text":"46 Stat. 590","children":[],"tail":". Title VII of the Act is classified generally to subtitle IV (§ 1671 et seq.) of chapter 4 of this title. Section 303 of the Act was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1303"},"text":"section 1303 of this title","children":[],"tail":" and was repealed, effective "},{"tag":"date","attrib":{"date":"1995-01-01"},"text":"Jan. 1, 1995","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/tII/s261/a"},"text":"Pub. L. 103–465, title II, § 261(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4908"},"text":"108 Stat. 4908","children":[],"tail":". For savings provisions and treatment of references to section 1303 in other laws, see section 261(b), (d)(1)(C) of "},{"tag":"ref","attrib":{"href":"/us/pl/103/465"},"text":"Pub. L. 103–465","children":[],"tail":", set out as notes under former "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1303"},"text":"section 1303 of this title","children":[],"tail":". For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1654"},"text":"section 1654 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id065d456c-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3438"},"text":"section 3438 of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/116/113"},"text":"Pub. L. 116–113","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id065d456d-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113/s504/i/3"},"text":"Pub. L. 116–113, § 504(i)(3)","children":[],"tail":", substituted “the USMCA” for “the Agreement enters into force with respect to the United States” in introductory provisions and “USMCA country” for “NAFTA country” in concluding provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id065d456e-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id065d456f-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2020 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Transfer to and amendment of this section by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113"},"text":"Pub. L. 116–113","children":[],"tail":" effective on the date on which the USMCA enters into force ("},{"tag":"date","attrib":{"date":"2020-07-01"},"text":"July 1, 2020","children":[],"tail":"), but not applicable to certain determinations under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1516a"},"text":"section 1516a of this title","children":[],"tail":" or binational panel reviews under NAFTA, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/113/s504/k"},"text":"section 504(k) of Pub. L. 116–113","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s4581"},"text":"section 4581 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id065d4570-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Application of Amendments by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/27"},"text":"Public Law 114–27","children":[],"tail":" to Goods From Canada and Mexico"}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/27/tV/s507"},"text":"Pub. L. 114–27, title V, § 507","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-06-29"},"text":"June 29, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/387"},"text":"129 Stat. 387","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/27/tV/s507"},"text":"“Pursuant to article 1902 of the North American Free Trade Agreement and section 408 of the North American Free Trade Agreement Implementation Act ([former] ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3438"},"text":"19 U.S.C. 3438","children":[],"tail":"), the amendments made by this title [see Short Title of 2015 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1654"},"text":"section 1654 of this title","children":[],"tail":"] shall apply with respect to goods from Canada and Mexico.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id065d4571-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Application of Amendments by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465"},"text":"Public Law 103–465","children":[],"tail":" to Goods From Canada and Mexico"}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":