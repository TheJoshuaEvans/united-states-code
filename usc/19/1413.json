{"tag":"section","attrib":{"id":"id05358ef6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1413"},"text":null,"children":[{"tag":"num","attrib":{"value":"1413"},"text":"§ 1413.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation and evaluation of Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05358ef7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1413/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Overall Program plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05358ef8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1413/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before the 180th day after ","children":[{"tag":"date","attrib":{"date":"1993-12-08"},"text":"December 8, 1993","children":[],"tail":", the Secretary shall develop and transmit to the Committees an overall plan for the Program. The overall Program plan shall set forth—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05358ef9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1413/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a general description of the ultimate configuration of the Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05358efa-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1413/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of each of the existing components of the Program listed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1411/a/1"},"text":"section 1411(a)(1) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05358efb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1413/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" estimates regarding the stages on which planned components of the Program listed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1411/a/2"},"text":"section 1411(a)(2) of this title","children":[],"tail":" will be brought on-line."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05358efc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1413/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to the information required under paragraph (1), the overall Program plan shall include a statement regarding—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05358efd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1413/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the existing components of the Program currently meet, and the planned components will meet, the Program goals set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1412"},"text":"section 1412 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05358efe-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1413/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the effects that the existing components are currently having, and the effects that the planned components will likely have, on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id05358eff-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1413/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" importers, brokers, and other users of the Program, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05358f00-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1413/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Customs Service occupations, operations, processes, and systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05358f01-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1413/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation plan, testing, and evaluation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05358f02-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1413/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each of the planned components of the Program listed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1411/a/2"},"text":"section 1411(a)(2) of this title","children":[],"tail":", the Secretary shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05358f03-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1413/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop an implementation plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05358f04-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1413/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" test the component in order to assess its viability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05358f05-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1413/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate the component in order to assess its contribution toward achieving the program goals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05358f06-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1413/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transmit to the Committees the implementation plan, the testing results, and an evaluation report.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"In developing an implementation plan under subparagraph (A) and evaluating components under subparagraph (C), the Secretary shall publish a request for comments in the Customs Bulletin and shall consult with the trade community, including importers, brokers, shippers, and other affected parties.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05358f07-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1413/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05358f08-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1413/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may implement on a permanent basis any Program component referred to in paragraph (1) on or after the date which is 30 days after paragraph (1)(D) is complied with.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05358f09-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1413/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of subparagraph (A), the 30 days shall be computed by excluding—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id05358f0a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1413/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the days either House is not in session because of an adjournment of more than 3 days to a day certain or an adjournment of the Congress sine die, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05358f0b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1413/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any Saturday and Sunday, not excluded under clause (i), when either House is not in session.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0537ff0c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1413/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation and report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0537ff0d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1413/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a user satisfaction survey of parties participating in the Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0537ff0e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1413/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate the results of the user satisfaction survey on a biennial basis (fiscal years) and transmit a report to the Committees on the evaluation by no later than the 90th day after the close of each 2d fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0537ff0f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1413/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to the existing Program component listed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1411/a/1/G"},"text":"section 1411(a)(1)(G) of this title","children":[],"tail":" transmit to the Committees—"}],"tail":null},{"tag":"clause","attrib":{"id":"id0537ff10-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1413/b/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a written evaluation of such component before the 180th day after ","children":[{"tag":"date","attrib":{"date":"1993-12-08"},"text":"December 8, 1993","children":[],"tail":", and before the implementation of the planned Program components listed in section 1411(a)(2)(B) and (C) of this title, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0537ff11-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1413/b/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a report on such component for each of the 3 full fiscal years occurring after ","children":[{"tag":"date","attrib":{"date":"1993-12-08"},"text":"December 8, 1993","children":[],"tail":", which report shall be transmitted not later than the 90th day after the close of each such year; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0537ff12-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1413/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than the 90th day after the close of fiscal year 1994, and annually thereafter through fiscal year 2000, transmit to the Committees a written evaluation with respect to the implementation and effect on users of each of the planned Program components listed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1411/a/2"},"text":"section 1411(a)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"In carrying out the provisions of this paragraph, the Secretary shall publish requests for comments in the Customs Bulletin and shall consult with the trade community, including importers, brokers, shippers, and other affected parties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0537ff13-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1413/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Committees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “Committees” means the Committee on Ways and Means of the House of Representatives and the Committee on Finance of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0537ff14-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title IV, § 413, as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/182/tVI/s631/2"},"text":"Pub. L. 103–182, title VI, § 631(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-08"},"text":"Dec. 8, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2189"},"text":"107 Stat. 2189","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/295/s21/e/15"},"text":"Pub. L. 104–295, § 21(e)(15)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3531"},"text":"110 Stat. 3531","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0537ff15-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0537ff16-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0537ff17-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/295"},"text":"Pub. L. 104–295","children":[],"tail":" made technical amendment to reference in original act which appears in text as reference to "},{"tag":"date","attrib":{"date":"1993-12-08"},"text":"December 8, 1993","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0537ff18-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id0537ff19-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions, personnel, assets, and liabilities of the United States Customs Service of the Department of the Treasury, including functions of the Secretary of the Treasury relating thereto, to the Secretary of Homeland Security, and for treatment of related references, see sections 203(1), 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":". For establishment of U.S. Customs and Border Protection in the Department of Homeland Security, treated as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" as of "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s211"},"text":"section 211 of Title 6","children":[],"tail":", as amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/114/125"},"text":"Pub. L. 114–125","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/114/125/s802/b"},"text":"section 802(b) of Pub. L. 114–125","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s211"},"text":"section 211 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
