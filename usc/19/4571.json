{"tag":"section","attrib":{"id":"id06588b4b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4571"},"text":null,"children":[{"tag":"num","attrib":{"value":"4571"},"text":"§ 4571.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this part:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id06588b4c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4571/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Border commercial zone","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “border commercial zone” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id06588b4d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4571/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the area of United States territory of the municipalities along the United States-Mexico international border and the commercial zones of such municipalities as described in subpart B of part 372 of title 49, Code of Federal Regulations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06588b4e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4571/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any additional border crossing and associated commercial zones listed in the Federal Motor Carrier Safety Administration OP–2 application instructions or successor documents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06588b4f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4571/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cargo originating in Mexico","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “cargo originating in Mexico” means any cargo that enters the United States by commercial motor vehicle from Mexico, including cargo that may have originated in a country other than Mexico.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06588b50-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4571/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Change in circumstances","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “change in circumstance” may include a substantial increase in services supplied by the grantee of a grant of authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065afb51-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4571/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commercial motor vehicle","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “commercial motor vehicle” means a commercial motor vehicle, as such term is defined in paragraph (1) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s31132"},"text":"section 31132 of title 49","children":[],"tail":", that meets the requirements of subparagraph (A) of such paragraph."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065afb52-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4571/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross-border long-haul trucking services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “cross-border long-haul trucking services” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id065afb53-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4571/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transportation by commercial motor vehicle of cargo originating in Mexico to a point in the United States outside of a border commercial zone; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id065afb54-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4571/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transportation by commercial motor vehicle of cargo originating in the United States from a point in the United States outside of a border commercial zone to a point in a border commercial zone or a point in Mexico.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065afb55-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4571/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Driver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “driver” means a person that drives a commercial motor vehicle in cross-border long-haul trucking services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065afb56-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4571/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant of authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “grant of authority” means registration granted pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s13902"},"text":"section 13902 of title 49","children":[],"tail":", or a successor provision, to persons of Mexico to conduct cross-border long-haul trucking services in the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065afb57-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4571/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interested party","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “interested party” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id065afb58-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4571/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" persons of the United States engaged in the provision of cross-border long-haul trucking services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id065afb59-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4571/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a trade or business association, a majority of whose members are part of the relevant United States long-haul trucking services industry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id065afb5a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4571/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certified or recognized union, or representative group of suppliers, operators, or drivers who are part of the United States long-haul trucking services industry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id065afb5b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4571/8/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Government of Mexico; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id065afb5c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4571/8/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" persons of Mexico.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065afb5d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4571/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Material harm","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “material harm” means a significant loss in the share of the United States market or relevant sub-market for cross-border long-haul trucking services held by persons of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065afb5e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4571/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operator or supplier","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “operator” or “supplier” means an entity that has been granted registration under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s13902"},"text":"section 13902 of title 49","children":[],"tail":" to provide cross-border long-haul trucking services."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065afb5f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4571/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persons of Mexico","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “persons of Mexico” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id065afb60-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4571/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entities domiciled in Mexico organized, or otherwise constituted under Mexican law, including subsidiaries of United States companies domiciled in Mexico, or entities owned or controlled by a Mexican national, which conduct cross-border long-haul trucking services, or employ drivers who are non-United States nationals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id065afb61-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4571/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" drivers who are Mexican nationals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065afb62-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4571/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persons of the United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “persons of the United States” includes entities domiciled in the United States, organized or otherwise constituted under United States law, and not owned or controlled by persons of Mexico, which provide cross-border long-haul trucking services and long-haul commercial motor vehicle drivers who are United States nationals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065afb63-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4571/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Threat of material harm","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “threat of material harm” means material harm that is likely to occur.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065afb64-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4571/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States long-haul trucking services industry","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “United States long-haul trucking services industry” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id065afb65-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4571/14/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" United States suppliers, operators, or drivers as a whole providing cross-border long-haul trucking services; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id065afb66-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4571/14/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" United States suppliers, operators, or drivers providing cross-border long-haul trucking services in a specific sub-market of the whole United States market.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id065afb67-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113/tIII/s321"},"text":"Pub. L. 116–113, title III, § 321","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-01-29"},"text":"Jan. 29, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/54"},"text":"134 Stat. 54","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id065afb68-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id065afb69-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id065afb6a-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This part, referred to in text, was in the original “this subtitle”, meaning subtitle C (§§ 321–327) of title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113"},"text":"Pub. L. 116–113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-01-29"},"text":"Jan. 29, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/54"},"text":"134 Stat. 54","children":[],"tail":", which is classified principally to this subchapter. For complete classification of subtitle C to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
