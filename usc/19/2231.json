{"tag":"section","attrib":{"id":"id05b40e2e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2231"},"text":null,"children":[{"tag":"num","attrib":{"value":"2231"},"text":"§ 2231.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Change of name","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05b40e2f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2231/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Former United States Tariff Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States Tariff Commission (established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1330"},"text":"section 1330 of this title","children":[],"tail":") is renamed as the United States International Trade Commission."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05b40e30-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2231/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" References in law and other documents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any reference in any law of the United States, or in any order, rule, regulation, or other document, to the United States Tariff Commission (or the Tariff Commission) shall be considered to refer to the United States International Trade Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05b65721-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/tI/s171"},"text":"Pub. L. 93–618, title I, § 171","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2009"},"text":"88 Stat. 2009","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
