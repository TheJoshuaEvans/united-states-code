{"tag":"section","attrib":{"id":"id057ad4bd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673g"},"text":null,"children":[{"tag":"num","attrib":{"value":"1673g"},"text":"§ 1673g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditional payment of antidumping duty","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id057ad4be-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For all entries, or withdrawals from warehouse, for consumption of merchandise subject to an antidumping duty order on or after the date of publication of such order, no customs officer may deliver merchandise of that class or kind to the person by whom or for whose account it was imported unless that person complies with the requirements of subsection (b) and deposits with the appropriate customs officer an estimated antidumping duty in an amount determined by the administering authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id057ad4bf-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Importer requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to meet the requirements of this subsection, a person shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id057ad4c0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673g/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" furnish, or arrange to have furnished, to the appropriate customs officer such information as the administering authority deems necessary for determining the export price (or the constructed export price) of the merchandise imported by or for the account of that person, and such other information as the administering authority deems necessary for ascertaining any antidumping duty to be imposed under this subtitle;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id057ad4c1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673g/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain and furnish to the customs officer such records concerning the sale of the merchandise as the administering authority, by regulation, requires;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id057ad4c2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673g/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" state under oath before the customs officer that he is not an exporter, or if he is an exporter, declare under oath at the time of entry the constructed export price of the merchandise to the customs officer if it is then known, or, if not, so declare within 30 days after the merchandise has been sold, or has been made the subject of an agreement to be sold, in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id057ad4c3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673g/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay, or agree to pay on demand, to the customs officer the amount of antidumping duty imposed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1673"},"text":"section 1673 of this title","children":[],"tail":" on that merchandise."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id057ad4c4-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title VII, § 738, as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/39/tI/s101"},"text":"Pub. L. 96–39, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/174"},"text":"93 Stat. 174","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/tII/s233/a/2/A/iv"},"text":"Pub. L. 103–465, title II, § 233(a)(2)(A)(iv)","children":[],"tail":", (B), "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4898"},"text":"108 Stat. 4898","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id057ad4c5-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id057ad4c6-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id057ad4c7-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/s233/a/2/A/iv"},"text":"Pub. L. 103–465, § 233(a)(2)(A)(iv)","children":[],"tail":", substituted “export price (or the constructed export price)” for “United States price”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/s233/a/2/B"},"text":"Pub. L. 103–465, § 233(a)(2)(B)","children":[],"tail":", substituted “constructed export price” for “exporter’s sales price”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id057ad4c8-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id057ad4c9-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465"},"text":"Pub. L. 103–465","children":[],"tail":" effective, except as otherwise provided, on the date on which the WTO Agreement enters into force with respect to the United States ("},{"tag":"date","attrib":{"date":"1995-01-01"},"text":"Jan. 1, 1995","children":[],"tail":"), and applicable with respect to investigations, reviews, and inquiries initiated and petitions filed under specified provisions of this chapter after such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/s291"},"text":"section 291 of Pub. L. 103–465","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1671"},"text":"section 1671 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
