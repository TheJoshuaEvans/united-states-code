{"tag":"section","attrib":{"id":"id061a97ae-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3739"},"text":null,"children":[{"tag":"num","attrib":{"value":"3739"},"text":"§ 3739.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of the Congress relating to HIV/AIDS crisis in sub-Saharan Africa","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id061a97af-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3739/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress finds the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id061a97b0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3739/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sustained economic development in sub-Saharan Africa depends in large measure upon successful trade with and foreign assistance to the countries of sub-Saharan Africa.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id061a97b1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3739/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The HIV/AIDS crisis has reached epidemic proportions in sub-Saharan Africa, where more than 21,000,000 men, women, and children are infected with HIV.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id061a97b2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3739/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Eighty-three percent of the estimated 11,700,000 deaths from HIV/AIDS worldwide have been in sub-Saharan Africa.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id061a97b3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3739/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The HIV/AIDS crisis in sub-Saharan Africa is weakening the structure of families and societies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id061a97b4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3739/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id061a97b5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3739/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The HIV/AIDS crisis threatens the future of the workforce in sub-Saharan Africa.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id061a97b6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3739/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Studies show that HIV/AIDS in sub-Saharan Africa most severely affects individuals between the ages of 15 and 49—the age group that provides the most support for the economies of sub-Saharan African countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id061a97b7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3739/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Clear evidence demonstrates that HIV/AIDS is destructive to the economies of sub-Saharan African countries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id061a97b8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3739/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sustained economic development is critical to creating the public and private sector resources in sub-Saharan Africa necessary to fight the HIV/AIDS epidemic.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id061a97b9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3739/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of the Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the sense of the Congress that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id061a97ba-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3739/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" addressing the HIV/AIDS crisis in sub-Saharan Africa should be a central component of United States foreign policy with respect to sub-Saharan Africa;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id061a97bb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3739/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" significant progress needs to be made in preventing and treating HIV/AIDS in sub-Saharan Africa in order to sustain a mutually beneficial trade relationship between the United States and sub-Saharan African countries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id061a97bc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3739/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the HIV/AIDS crisis in sub-Saharan Africa is a global threat that merits further attention through greatly expanded public, private, and joint public-private efforts, and through appropriate United States legislation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id061a97bd-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/200/tI/s129"},"text":"Pub. L. 106–200, title I, § 129","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-05-18"},"text":"May 18, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/273"},"text":"114 Stat. 273","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
