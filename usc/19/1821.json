{"tag":"section","attrib":{"id":"id059031ff-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1821"},"text":null,"children":[{"tag":"num","attrib":{"value":"1821"},"text":"§ 1821.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basic authority for trade agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05903200-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1821/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination by President; trade agreements; modification or continuance of existing duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whenever the president determines that any existing duties or other import restrictions of any foreign country or the United States are unduly burdening and restricting the foreign trade of the United States and that any of the purposes stated in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1801"},"text":"section 1801 of this title","children":[],"tail":" will be promoted thereby, the President may—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id05903201-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1821/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after ","children":[{"tag":"date","attrib":{"date":"1962-06-30"},"text":"June 30, 1962","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"1967-07-01"},"text":"July 1, 1967","children":[],"tail":", enter into trade agreements with foreign countries or instrumentalities thereof; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05903202-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1821/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proclaim such modification or continuance of any existing duty or other import restriction, such continuance of existing duty-free or excise treatment, or such additional import restrictions, as he determines to be required or appropriate to carry out any such trade agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05903203-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1821/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions on decrease or increase in rate of duty","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided in this subchapter, no proclamation pursuant to subsection (a) shall be made—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05903204-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1821/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" decreasing any rate of duty to a rate below 50 percent of the rate existing on ","children":[{"tag":"date","attrib":{"date":"1962-07-01"},"text":"July 1, 1962","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05903205-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1821/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing any rate of duty to (or imposing) a rate more than 50 percent above the rate existing on ","children":[{"tag":"date","attrib":{"date":"1934-07-01"},"text":"July 1, 1934","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05903206-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/794/tII/s201"},"text":"Pub. L. 87–794, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-11"},"text":"Oct. 11, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/872"},"text":"76 Stat. 872","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05903207-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id05903208-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id05903209-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wood-Wind and Parts of Wood-Wind Instruments","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/90/234/s2/b/2"},"text":"Pub. L. 90–234, § 2(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-12-30"},"text":"Dec. 30, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/752"},"text":"81 Stat. 752","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/90/234/s2/b/2"},"text":"“The amendments made by the first section of this Act, insofar as such amendments relate to items 725.24 and 726.70 of the Tariff Schedules of the United States, shall not affect the authority of the President contained in section 201(a)(2) of the Trade Expansion Act of 1962 [subsec. (a)(2) of this section].”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0590320a-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Dicyandiamide and Limestone: Duty-Free Entry","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Duty-free treatment pursuant to this chapter of dicyandiamide in item 425.40 and limestone when imported for use in manufacture of cement in item 513.34 of the Tariff Schedules of the United States, by provision for non-application of subsec. (b)(1) of this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1823"},"text":"section 1823 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
