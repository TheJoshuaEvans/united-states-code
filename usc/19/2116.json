{"tag":"section","attrib":{"id":"id05a826de-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2116"},"text":null,"children":[{"tag":"num","attrib":{"value":"2116"},"text":"§ 2116.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements with developing countries","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A United States negotiating objective under sections 2111 and 2112 of this title shall be to enter into trade agreements which promote the economic growth of both developing countries and the United States and the mutual expansion of market opportunities.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id05a826df-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/tI/s106"},"text":"Pub. L. 93–618, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1985"},"text":"88 Stat. 1985","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
