{"tag":"section","attrib":{"id":"id05f20094-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2575"},"text":null,"children":[{"tag":"num","attrib":{"value":"2575"},"text":"§ 2575.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Nothing in this subpart may be construed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05f20095-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2575/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prohibit a Federal agency or State agency from engaging in activity related to sanitary or phytosanitary measures to protect human, animal, or plant life or health; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f20096-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2575/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to limit the authority of a Federal agency or State agency to determine the level of protection of human, animal, or plant life or health the agency considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05f20097-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39/tIV/s461"},"text":"Pub. L. 96–39, title IV, § 461","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/182/tIII/s351/a"},"text":"Pub. L. 103–182, title III, § 351(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-08"},"text":"Dec. 8, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2118"},"text":"107 Stat. 2118","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
