{"tag":"section","attrib":{"id":"id065d45dc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4644"},"text":null,"children":[{"tag":"num","attrib":{"value":"4644"},"text":"§ 4644.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id065d45dd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4644/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ongoing assessments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the 10-year period beginning on ","children":[{"tag":"date","attrib":{"date":"2020-01-29"},"text":"January 29, 2020","children":[],"tail":", except as provided in subsection (b), the Interagency Labor Committee shall assess on a biannual basis the extent to which Mexico is in compliance with its obligations under Annex 23–A of the USMCA."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id065d45de-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4644/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation relating to annual assessment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On or after the date that is 5 years after ","children":[{"tag":"date","attrib":{"date":"2020-01-29"},"text":"January 29, 2020","children":[],"tail":", the Interagency Labor Committee may consult with the appropriate congressional committees with respect to the frequency of the assessment required under subsection (a) and, with the approval of both such committees, may conduct such assessment on an annual basis for the following 5 years."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id065d45df-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4644/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matters to be included","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The assessment required under subsection (a) shall also include each of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id065d45e0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4644/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Whether Mexico is providing adequate funding to implement and enforce Mexico’s labor reform, including specifically whether Mexico has provided funding consistent with commitments made to contribute the following amounts for the labor reform implementation budget:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id065d45e1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4644/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $176,000,000 for 2021.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id065d45e2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4644/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $325,000,000 for 2022.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id065d45e3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4644/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $328,000,000 for 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065d45e4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4644/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The extent to which any legal challenges to Mexico’s labor reform have succeeded in that court system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065d45e5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4644/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The extent to which Mexico has implemented the federal and state labor courts, registration entity, and federal and state conciliation centers consistent with the timeline set forth for Mexico’s labor reform, in the September 2019 policy statements by the Government of Mexico on a national strategy for implementation of the labor justice system, and in subsequent policy statements in accordance with Mexico’s labor reform.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id065d45e6-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113/tVII/s714"},"text":"Pub. L. 116–113, title VII, § 714","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-01-29"},"text":"Jan. 29, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/82"},"text":"134 Stat. 82","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
