{"tag":"section","attrib":{"id":"id0537ff1a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1414"},"text":null,"children":[{"tag":"num","attrib":{"value":"1414"},"text":"§ 1414.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remote location filing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0537ff1b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1414/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Core entry information","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0537ff1c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1414/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A Program participant may file electronically an entry of merchandise with the Customs Service from a location other than the district designated in the entry for examination (hereafter in this section referred to as a “remote location”) if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0537ff1d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1414/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Customs Service is satisfied that the participant has the capabilities referred to in paragraph (2)(A) regarding such method of filing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0537ff1e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1414/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the participant elects to file from the remote location.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0537ff1f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1414/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0537ff20-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1414/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to qualify for filing from a remote location, a Program participant must have the capability to provide, on an entry-by-entry basis, for the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0537ff21-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1414/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The electronic entry of merchandise.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0537ff22-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1414/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The electronic entry summary of required information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0537ff23-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1414/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The electronic transmission of invoice information (when required by the Customs Service).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0537ff24-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1414/a/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The electronic payment of duties, fees, and taxes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0537ff25-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1414/a/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other electronic capabilities within the existing or planned components of the Program as the Secretary shall by regulation require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0537ff26-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1414/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction on exemption from requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Customs Service may not permit any exemption or waiver from the requirements established by this section for participation in remote entry filing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0537ff27-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1414/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions on filing under this section","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may prohibit a Program participant from participating in remote location filing, and may remove a Program participant from participation in remote location filing, if the participant—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0537ff28-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1414/a/3/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fails to meet all the compliance requirements and operational standards of remote location filing; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0537ff29-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1414/a/3/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fails to adhere to all applicable laws and regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0537ff2a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1414/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternative filing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any Program participant that is eligible to file entry information electronically from a remote location but chooses not to do so in the case of any entry must file any paper documentation for the entry at the designated location referred to in subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0537ff2b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1414/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional entry information","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0537ff2c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1414/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Program participant that is eligible under subsection (a) to file entry information from a remote location may, if the Customs Service is satisfied that the participant meets the requirements under paragraph (2), also electronically file from the remote location additional information that is required by the Customs Service to be presented before the acceptance of entry summary information and at the time of acceptance of entry summary information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0537ff2d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1414/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall publish, and periodically update, a list of those capabilities within the existing and planned components of the Program that a Program participant must have for purposes of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0537ff2e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1414/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Filing of additional information","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0537ff2f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1414/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" If information electronically acceptable","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Program participant that is eligible under paragraph (1) to file additional information from a remote location shall electronically file all such information that the Customs Service can accept electronically.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0537ff30-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1414/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternative filing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Customs Service cannot accept additional information electronically, the Program participant shall file the paper documentation with respect to the information at the appropriate filing location.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0537ff31-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1414/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate location","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subparagraph (B), the “appropriate location” is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0537ff32-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1414/b/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before ","children":[{"tag":"date","attrib":{"date":"1999-01-01"},"text":"January 1, 1999","children":[],"tail":", a designated location; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0537ff33-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1414/b/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" after ","children":[{"tag":"date","attrib":{"date":"1998-12-31"},"text":"December 31, 1998","children":[],"tail":"—"}],"tail":null},{"tag":"subclause","attrib":{"id":"id0537ff34-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1414/b/3/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the paper documentation is required for release, a designated location; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0537ff35-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1414/b/3/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the paper documentation is not required for release, a remote location designated by the Customs Service or a designated location.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0537ff36-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1414/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Program participant that is eligible under paragraph (1) to file additional information electronically from a remote location but chooses not to do so must file the paper documentation with respect to the information at a designated location.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0537ff37-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1414/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Post-entry summary information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Program participant that is eligible to file electronically entry information under subsection (a) and additional information under subsection (b) from a remote location may file at any remote location designated by the Customs Service any information required by the Customs Service after entry summary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0537ff38-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1414/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0537ff39-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1414/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “designated location” means a customs office located in the customs district designated by the entry filer for purposes of customs examination of the merchandise.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0537ff3a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1414/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Program participant” means, with respect to an entry of merchandise, any party entitled to make the entry under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1484/a/2/B"},"text":"section 1484(a)(2)(B) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0537ff3b-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title IV, § 414, as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/182/tVI/s631/2"},"text":"Pub. L. 103–182, title VI, § 631(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-08"},"text":"Dec. 8, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2191"},"text":"107 Stat. 2191","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0537ff3c-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0537ff3d-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id0537ff3e-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions, personnel, assets, and liabilities of the United States Customs Service of the Department of the Treasury, including functions of the Secretary of the Treasury relating thereto, to the Secretary of Homeland Security, and for treatment of related references, see sections 203(1), 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":". For establishment of U.S. Customs and Border Protection in the Department of Homeland Security, treated as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" as of "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s211"},"text":"section 211 of Title 6","children":[],"tail":", as amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/114/125"},"text":"Pub. L. 114–125","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/114/125/s802/b"},"text":"section 802(b) of Pub. L. 114–125","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s211"},"text":"section 211 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
