{"tag":"section","attrib":{"id":"id05ef8f8b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2518"},"text":null,"children":[{"tag":"num","attrib":{"value":"2518"},"text":"§ 2518.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05ef8f8c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2518/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Agreement” means the Agreement on Government Procurement referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3511/d/17"},"text":"section 3511(d)(17) of this title","children":[],"tail":", as submitted to the Congress, but including rectifications, modifications, and amendments which are accepted by the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05ef8f8d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2518/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil aircraft","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “civil aircraft and related articles” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05ef8f8e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2518/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all aircraft other than aircraft to be purchased for use by the Department of Defense or the United States Coast Guard;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05ef8f8f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2518/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the engines (and parts and components for incorporation therein) of such aircraft;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05ef8f90-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2518/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other parts, components, and subassemblies for incorporation in such aircraft; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05ef8f91-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2518/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any ground flight simulators, and parts and components thereof, for use with respect to such aircraft,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"whether to be purchased for use as original or replacement equipment in the manufacture, repair, maintenance, rebuilding, modification, or conversion of such aircraft, and without regard to whether such aircraft or articles receive duty-free treatment pursuant to section 601(a)(2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05ef8f92-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2518/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Developed countries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “developed countries” means countries so designated by the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05ef8f93-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2518/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible product","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05ef8f94-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2518/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible product” means, with respect to any foreign country or instrumentality that is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id05ef8f95-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2518/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a party to the Agreement, a product or service of that country or instrumentality which is covered under the Agreement for procurement by the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05ef8f96-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2518/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Mexico, as a party to the USMCA (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4502"},"text":"section 4502 of this title","children":[],"tail":"), a product or service of that country or instrumentality which is covered under the USMCA for procurement by the United States;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05ef8f97-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2518/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a party to a free trade agreement that entered into force with respect to the United States after ","children":[{"tag":"date","attrib":{"date":"2003-12-31"},"text":"December 31, 2003","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"2005-01-02"},"text":"January 2, 2005","children":[],"tail":", a product or service of that country or instrumentality which is covered under the free trade agreement for procurement by the United States;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05ef8f98-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2518/4/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a party to the Dominican Republic-Central America-United States Free Trade Agreement, a product or service of that country or instrumentality which is covered under that Agreement for procurement by the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05ef8f99-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2518/4/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a party to a free trade agreement that entered into force with respect to the United States after ","children":[{"tag":"date","attrib":{"date":"2005-12-31"},"text":"December 31, 2005","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"2006-07-02"},"text":"July 2, 2006","children":[],"tail":", a product or service of that country or instrumentality which is covered under the free trade agreement for procurement by the United States;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05ef8f9a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2518/4/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a party to the United States-Oman Free Trade Agreement, a product or service of that country or instrumentality which is covered under that Agreement for procurement by the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05ef8f9b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2518/4/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a party to the United States-Peru Trade Promotion Agreement, a product or service of that country or instrumentality which is covered under that agreement for procurement by the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05ef8f9c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2518/4/A/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a party to the United States–Korea Free Trade Agreement, a product or service of that country or instrumentality which is covered under that agreement for procurement by the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05ef8f9d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2518/4/A/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a party to the United States–Colombia Trade Promotion Agreement, a product or service of that country or instrumentality which is covered under that agreement for procurement by the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05ef8f9e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2518/4/A/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a party to the United States–Panama Trade Promotion Agreement, a product or service of that country or instrumentality which is covered under that agreement for procurement by the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05ef8f9f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2518/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of origin","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An article is a product of a country or instrumentality only if (i) it is wholly the growth, product, or manufacture of that country or instrumentality, or (ii) in the case of an article which consists in whole or in part of materials from another country or instrumentality, it has been substantially transformed into a new and different article of commerce with a name, character, or use distinct from that of the article or articles from which it was so transformed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05ef8fa0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2518/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lowered threshold for certain products as a consequence of United States-Israel free trade area provisions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible product” includes a product or service of Israel for which the United States is obligated to waive Buy National restrictions under—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id05ef8fa1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2518/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Agreement on the Establishment of a Free Trade Area between the Government of the United States of America and the Government of Israel, regardless of the thresholds provided for in the Agreement (as defined in paragraph (1)), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05ef8fa2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2518/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any subsequent agreement between the United States and Israel which lowers on a reciprocal basis the applicable threshold for entities covered by the Agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05ef8fa3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2518/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lowered threshold for certain products as a consequence of United States-Canada Free-Trade Agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise agreed by the United States and Canada under paragraph 3 of article 1304 of the United States-Canada Free-Trade Agreement, the term “eligible product” includes a product or service of Canada having a contract value of $25,000 or more that would be covered for procurement by the United States under the Agreement (as defined in paragraph (1)), but for the thresholds provided for in the Agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05ef8fa4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2518/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Instrumentality","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “instrumentality” shall not be construed to include an agency or division of the government of a country, but may be construed to include such arrangements as the European Economic Community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05ef8fa5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2518/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Least developed country","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “least developed country” means any country on the United Nations General Assembly list of least developed countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05ef8fa6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2518/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Major industrial country","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “major industrial country” means any such country as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2136"},"text":"section 2136 of this title","children":[],"tail":" and any instrumentality of such a country."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05ef8fa7-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39/tIII/s308"},"text":"Pub. L. 96–39, title III, § 308","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/241"},"text":"93 Stat. 241","children":[],"