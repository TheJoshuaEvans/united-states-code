. 109–53, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-02"},"text":"Aug. 2, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/495"},"text":"119 Stat. 495","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/169/tIV/s401"},"text":"Pub. L. 109–169, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-11"},"text":"Jan. 11, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3599"},"text":"119 Stat. 3599","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/283/tIV/s401"},"text":"Pub. L. 109–283, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-09-26"},"text":"Sept. 26, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1209"},"text":"120 Stat. 1209","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/138/tIV/s401"},"text":"Pub. L. 110–138, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-14"},"text":"Dec. 14, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1486"},"text":"121 Stat. 1486","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/41/tIV/s401"},"text":"Pub. L. 112–41, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-10-21"},"text":"Oct. 21, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/459"},"text":"125 Stat. 459","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/42/tIV/s401"},"text":"Pub. L. 112–42, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-10-21"},"text":"Oct. 21, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/494"},"text":"125 Stat. 494","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/43/tIV/s401"},"text":"Pub. L. 112–43, title IV, § 401","children":[],"tail":", "},{"tag":"date","attri