{"tag":"section","attrib":{"id":"id05aa7019-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2133"},"text":null,"children":[{"tag":"num","attrib":{"value":"2133"},"text":"§ 2133.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05aa701a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2133/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New concessions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whenever—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05aa701b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2133/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any action taken under part 1 of subchapter II or subchapter III, or under part 2 of subchapter IV of this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05aa701c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2133/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any judicial or administrative tariff reclassification that becomes final after ","children":[{"tag":"date","attrib":{"date":"1988-08-23"},"text":"August 23, 1988","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"increases or imposes any duty or other import restriction, the President—","children":[],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05aa701d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2133/a/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may enter into trade agreements with foreign countries or instrumentalities for the purpose of granting new concessions as compensation in order to maintain the general level of reciprocal and mutually advantageous concessions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05aa701e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2133/a/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may proclaim such modification or continuance of any existing duty, or such continuance of existing duty-free or excise treatment, as he determines to be required or appropriate to carry out any such agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05aa701f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2133/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reductions in rates of duty","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05aa7020-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2133/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No proclamation shall be made pursuant to subsection (a) decreasing any rate of duty to a rate which is less than 70 percent of the existing rate of duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05aa7021-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2133/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Where the rate of duty in effect at any time is an intermediate stage under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2902/a"},"text":"section 2902(a) of this title","children":[],"tail":", the proclamation made pursuant to subsection (a) may provide for the reduction of each rate of duty at each such stage proclaimed under such "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2902/a"},"text":"section 2902(a) of this title","children":[],"tail":" by not more than 30 percent of such rate of duty, and may provide for a final rate of duty which is not less than 70 percent of the rate of duty proclaimed as the final stage under such "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2902/a"},"text":"section 2902(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05aa7022-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2133/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the President determines that such action will simplify the computation of the amount of duty imposed with respect to an article, he may exceed the limitations provided by paragraphs (1) and (2) of this subsection by not more than the lesser of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05aa7023-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2133/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the difference between such limitation and the next lower whole number, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05aa7024-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2133/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one-half of 1 percent ad valorem.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05aa7025-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2133/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any concessions granted under subsection (a)(1) shall be reduced and terminated according to substantially the same time schedule for reduction applicable to the relevant action under sections 2253(e) and 2254 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05aa7026-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2133/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration of past violations of trade concessions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before entering into any trade agreement under this section with any foreign country or instrumentality, the President shall consider whether such country or instrumentality has violated trade concessions of benefit to the United States and such violation has not been adequately offset by the action of the United States or by such country or instrumentality.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05aa7027-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2133/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basic authority for trade agreements as authority for granting new concessions as compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding the provisions of subsection (a), the authority delegated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2902"},"text":"section 2902 of this title","children":[],"tail":" shall be used for the purpose of granting new concessions as compensation within the meaning of this section until such authority terminates."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05aa7028-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2133/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International obligations determination prerequisite to application of authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of this section shall apply by reason of action taken under subchapter III only if the President determines that action authorized under this section is necessary or appropriate to meet the international obligations of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05aa7029-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/tI/s123"},"text":"Pub. L. 93–618, title I, § 123","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1989"},"text":"88 Stat. 1989","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tI"},"text":"Pub. L. 100–418, title I","children":[],"tail":", §§ 1104, 1401(b)(1)(A), "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1132"},"text":"102 Stat. 1132","children":[],"tail":", 1239; "},{"tag":"ref","attrib":{"href":"/us/pl/106/286/dA/tI/s104"},"text":"Pub. L. 106–286, div. A, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-10"},"text":"Oct. 10, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/891"},"text":"114 Stat. 891","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05aa702a-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05aa702b-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id05aa702c-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/286"},"text":"Pub. L. 106–286","children":[],"tail":" inserted “, or under part 2 of subchapter IV of this chapter” after “subchapter III of this chapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/s1104/1"},"text":"Pub. L. 100–418, § 1104(1)","children":[],"tail":", amended subsec. (a) generally. Prior to amendment, subsec. (a) read as follows: “Whenever any action has been taken under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2253"},"text":"section 2253 of this title","children":[],"tail":" to increase or impose any duty or other import restriction, the President—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) may enter into trade agreements with foreign countries or instrumentalities for the purpose of granting new concessions as compensation in order to maintain the general level of reciprocal and mutually advantageous concessions; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) may proclaim such modification or continuance of any existing duty, or such continuance of existing duty-free or excise treatment, as he determines to be required or appropriate to carry out any such agreement.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/s1104/2"},"text":"Pub. L. 100–418, § 1104(2)","children":[],"tail":", substituted “section 2902(a)” for “section 2119” and “such section 2902(a)” for “section 2111” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/s1401/b/1/A"},"text":"Pub. L. 100–418, § 1401(b)(1)(A)","children":[],"tail":", substituted “action under sections 2253(e) and 2254 of this title” for “import relief under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2253/h"},"text":"section 2253(h) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/s1104/3"},"text":"Pub. L. 100–418, § 1104(3)","children":[],"tail":", substituted “section 2902” for “section 2111”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/s1104/4"},"text":"Pub. L. 100–418, § 1104(4)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id05aa702d-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id05aa702e-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/s1401/b/1/A"},"text":"section 1401(b)(1)(A) of Pub. L. 100–418","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", and applicable with respect to investigations initiated under part 1 (§ 2251 et seq.) of subchapter III of this chapter on or after that date, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/s1401/c"},"text":"section 1401(c) of Pub. L. 100–418","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2251"},"text":"section 2251 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
