{"tag":"section","attrib":{"id":"id059031da-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1756"},"text":null,"children":[{"tag":"num","attrib":{"value":"1756"},"text":"§ 1756.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury may prescribe such regulations as may be necessary or appropriate to carry out the provisions of this chapter (other than section 1751 thereof).","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id059031db-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/14/s7"},"text":"Pub. L. 86–14, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-04-22"},"text":"Apr. 22, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/19"},"text":"73 Stat. 19","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
