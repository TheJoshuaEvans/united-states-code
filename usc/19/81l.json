{"tag":"section","attrib":{"id":"id050f68f4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s81l"},"text":null,"children":[{"tag":"num","attrib":{"value":"81l"},"text":"§ 81l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Facilities to be provided and maintained","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Each grantee shall provide and maintain in connection with the zone—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id050f68f5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s81l/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Adequate slips, docks, wharves, warehouses, loading and unloading and mooring facilities where the zone is adjacent to water; or, in the case of an inland zone, adequate loading, unloading, and warehouse facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id050f68f6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s81l/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Adequate transportation connections with the surrounding territory and with all parts of the United States, so arranged as to permit of proper guarding and inspection for the protection of the revenue;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id050f68f7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s81l/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Adequate facilities for coal or other fuel and for light and power;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id050f68f8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s81l/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Adequate water and sewer mains;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id050f68f9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s81l/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Adequate quarters and facilities for the officers and employees of the United States, State, and municipality whose duties may require their presence within the zone;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id050f68fa-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s81l/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Adequate enclosures to segregate the zone from customs territory for protection of the revenue, together with suitable provisions for ingress and egress of persons, conveyances, vessels, and merchandise;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id050f68fb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s81l/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other facilities as may be required by the Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id050f68fc-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-18/ch590/s12"},"text":"June 18, 1934, ch. 590, § 12","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/1001"},"text":"48 Stat. 1001","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
