{"tag":"section","attrib":{"id":"id063e4bec-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3903"},"text":null,"children":[{"tag":"num","attrib":{"value":"3903"},"text":"§ 3903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Measures for the importation and exportation of rough diamonds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id063e4bed-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3903/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall prohibit the importation into, or exportation from, the United States of any rough diamond, from whatever source, that has not been controlled through the Kimberley Process Certification Scheme.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id063e4bee-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3903/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President may waive the requirements set forth in subsection (a) with respect to a particular country for periods of not more than 1 year each, if, with respect to each such waiver—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id063e4bef-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3903/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President determines and reports to the appropriate congressional committees that such country is taking effective steps to implement the Kimberley Process Certification Scheme; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id063e4bf0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3903/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President determines that the waiver is in the national interests of the United States, and reports such determination to the appropriate congressional committees, together with the reasons therefor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id063e4bf1-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/19/s4"},"text":"Pub. L. 108–19, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-04-25"},"text":"Apr. 25, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/633"},"text":"117 Stat. 633","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id063e4bf2-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id063e4bf3-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id063e4bf4-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/19/s15"},"text":"section 15 of Pub. L. 108–19","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3901"},"text":"section 3901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id063e4bf5-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id063e4bf6-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For assignment of functions of President under subsec. (b) of this section, see section 2 of Ex. Ord. No. 13312, ","children":[{"tag":"date","attrib":{"date":"2003-07-29"},"text":"July 29, 2003","children":[],"tail":", 68 F.R. 45151, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3901"},"text":"section 3901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
