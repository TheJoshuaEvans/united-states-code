{"tag":"section","attrib":{"id":"id06588adb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4534"},"text":null,"children":[{"tag":"num","attrib":{"value":"4534"},"text":"§ 4534.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Drawback","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id06588adc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4534/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Good subject to USMCA drawback” defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this Act, the term “good subject to USMCA drawback” means any imported good other than the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id06588add-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4534/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A good entered under bond for transportation and exportation to a USMCA country.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06588ade-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4534/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A good exported to a USMCA country in the same condition as when imported into the United States. For purposes of this paragraph—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id06588adf-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4534/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" processes such as testing, cleaning, repacking, sorting, marking, or inspecting a good, or preserving it in its same condition, shall not be considered to change the condition of the good, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06588ae0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4534/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except for a good referred to in paragraph 11 of Annex 3–B of the USMCA that is exported to Mexico, if a good described in the first sentence of this paragraph is commingled with fungible goods and exported in the same condition, the origin of the good may be determined on the basis of the inventory methods provided for in the regulations implementing this title.","children":[{"tag":"ref","attrib":{"idref":"fn002180"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002180"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06588ae1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4534/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A good—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id06588ae2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4534/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id06588ae3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4534/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deemed to be exported from the United States,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id06588ae4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4534/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" used as a material in the production of another good that is deemed to be exported to a USMCA country, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id06588ae5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4534/a/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substituted for by a good of the same kind and quality that is used as a material in the production of another good that is deemed to be exported to a USMCA country, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06588ae6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4534/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that is delivered—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id06588ae7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4534/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to a duty-free shop,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id06588ae8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4534/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for ship’s stores or supplies for ships or aircraft, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id06588ae9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4534/a/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for use in a project undertaken jointly by the United States and a USMCA country and destined to become the property of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06588aea-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4534/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A good exported to a USMCA country for which a refund of customs duties is granted by reason of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id06588aeb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4534/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the failure of the good to conform to sample or specification, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06588aec-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4534/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the shipment of the good without the consent of the consignee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06588aed-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4534/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A good that qualifies under the rules of origin set out in section 202 ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" that is—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id06588aee-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4534/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exported to a USMCA country,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06588aef-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4534/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" used as a material in the production of another good that is exported to a USMCA country, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06588af0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4534/a/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substituted for by a good of the same kind and quality that is used as a material in the production of another good that is exported to a USMCA country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06588af1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4534/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A good provided for in subheading 1701.13.20 or 1701.14.20 of the HTS that is imported under any re-export program or any like program and that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id06588af2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4534/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" used as a material, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06588af3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4534/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substituted for by a good of the same kind and quality that is used as a material,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"in the production of a good provided for in existing Canadian tariff item 1701.99.00 or existing Mexican tariff item 1701.99.01, 1701.99.02, or 1701.99.99 (relating to refined sugar).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06588af4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4534/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A citrus product that is exported to Canada.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06588af5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4534/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A good used as a material, or substituted for by a good of the same kind and quality that is used as a material, in the production of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id06588af6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4534/a/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" apparel, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06588af7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4534/a/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a good provided for in subheading 6307.90.99 (insofar as it relates to furniture moving pads), 5811.00.20, or 5811.00.30 of the HTS,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"that is exported to Canada and that is subject to Canada’s most-favored-nation rate of duty upon importation into Canada.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Where in paragraph (6) a good referred to by an item is described in parentheses following the item, the description is provided for purposes of reference only.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id06588af8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4534/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Same kind and quality","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraphs (3)(A)(iii), (5)(C), (6)(B), and (8) of subsection (a), and for purposes of obtaining refunds, waivers, or reductions of customs duties with respect to a good subject to USMCA drawback under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1313/n/2"},"text":"section 1313(n)(2) of this title","children":[],"tail":", a good is a good of the same kind and quality as another good—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id06588af9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4534/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a good described in such paragraph (6)(B), if the good would have been considered of the same kind and quality as the other good on the day before the date on which the USMCA enters into force; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06588afa-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4534/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for other goods if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id06588afb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4534/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the good is classified under the same 8-digit HTS subheading number as the other good; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06588afc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4534/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" drawback would be allowed with respect to the goods under subsection (b)(4), (j)(1), or (p) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1313"},"text":"section 1313 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id06588afd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4534/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elimination of drawback for fees under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s624"},"text":"section 624 of title 7","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the Secretary of the Treasury may not, on condition of export, refund or reduce a fee applied pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s624"},"text":"section 624 of title 7","children":[],"tail":" with respect to goods included under subsection (a) that are exported to a USMCA country."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id06588afe-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4534/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inapplicability to countervailing and antidumping duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section or the amendments made by it shall be considered to authorize the refund, waiver, or reduction of countervailing duties or antidumping duties imposed on an imported good.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id06588aff-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4534/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action on claim","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id06588b00-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4534/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Commissioner of U.S. Customs and Border Protection determines that a claim of preferential tariff treatment has been made with respect to an article for which a claim described in paragraph (2) has been made, the Commissioner may make such adjustments regarding the previous customs treatment of the article as may be warranted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06588b01-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4534/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Claims described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A claim described in this paragraph is a claim for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id06588b02-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4534/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a refund, waiver, or reduction of duty, under any applicable provision of law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06588b03-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4534/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a credit against a bond under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1312/d/1"},"text":"section 1312(d)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id06588b04-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113/tII/s208"},"text":"Pub. L. 116–113, title II, § 208","children":[],"tail":", title V, § 501(a)–(d), "},{"tag":"date","attrib":{"date":"2020-01-29"},"text":"Jan. 29, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/52"},"text":"134 Stat. 52","children":[],"tail":", 67, 68; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dO/tVI/s601/c/1"},"text":"Pub. L. 116–260, div. O, title VI, § 601(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2150"},"text":"134 Stat. 2150","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id06588b05-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id06588b06-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id06588b07-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113"},"text":"Pub. L. 116–113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-01-29"},"text":"Jan. 29, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/11"},"text":"134 Stat. 11","children":[],"tail":", known as the United States-Mexico-Canada Agreement Implementation Act. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s4501"},"text":"section 4501 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This title, referred to in subsec. (a)(2)(B), is title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113"},"text":"Pub. L. 116–113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-01-29"},"text":"Jan. 29, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/19"},"text":"134 Stat. 19","children":[],"tail":", which enacted this subchapter and amended and enacted provisions set out as notes under several sections within this title. For complete classification of title II to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 202, referred to in subsec. (a)(5), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/182/s202"},"text":"section 202 of Pub. L. 103–182","children":[],"tail":", title II, "},{"tag":"date","attrib":{"date":"1993-12-08"},"text":"Dec. 8, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2069"},"text":"107 Stat. 2069","children":[],"tail":", which was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3332"},"text":"section 3332 of this title","children":[],"tail":" prior to repeal by "}