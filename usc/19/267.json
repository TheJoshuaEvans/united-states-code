{"tag":"section","attrib":{"id":"id05144b3f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s267"},"text":null,"children":[{"tag":"num","attrib":{"value":"267"},"text":"§ 267.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Overtime and premium pay for customs officers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05144b40-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s267/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Overtime pay","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05144b41-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s267/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2) and subsection (c), a customs officer who is officially assigned to perform work in excess of 40 hours in the administrative workweek of the officer or in excess of 8 hours in a day shall be compensated for that work at an hourly rate of pay that is equal to 2 times the hourly rate of the basic pay of the officer. For purposes of this paragraph, the hourly rate of basic pay for a customs officer does not include any premium pay provided for under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05144b42-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s267/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special provisions relating to overtime work on callback basis","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05144b43-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s267/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any work for which compensation is authorized under paragraph (1) and for which the customs officer is required to return to the officer’s place of work shall be treated as being not less than 2 hours in duration; but only if such work begins at least 1 hour after the end of any previous regularly scheduled work assignment and ends at least 1 hour before the beginning of the following regularly scheduled work assignment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05144b44-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s267/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation for commuting time","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id05144b45-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s267/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in clause (ii), in addition to the compensation authorized under paragraph (1) for work to which subparagraph (A) applies, the customs officer is entitled to be paid, as compensation for commuting time, an amount equal to 3 times the hourly rate of basic pay of the officer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05144b46-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s267/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Compensation for commuting time is not payable under clause (i) if the work for which compensation is authorized under paragraph (1)—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id05144b47-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s267/a/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not commence within 16 hours of the customs officer’s last regularly scheduled work assignment, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id05144b48-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s267/a/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commences within 2 hours of the next regularly scheduled work assignment of the customs officer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05144b49-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s267/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Premium pay for customs officers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05144b4a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s267/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Night work differential","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05144b4b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s267/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 3 p.m. to midnight shiftwork","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the majority of the hours of regularly scheduled work of a customs officer occurs during the period beginning at 3 p.m. and ending at 12 a.m., the officer is entitled to pay for work during such period (except for work to which paragraph (2) or (3) applies) at the officer’s hourly rate of basic pay plus premium pay amounting to 15 percent of that basic rate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05144b4c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s267/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 11 p.m. to 8 a.m. shiftwork","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the majority of the hours of regularly scheduled work of a customs officer occurs during the period beginning at 11 p.m. and ending at 8 a.m., the officer is entitled to pay for work during such period (except for work to which paragraph (2) or (3) applies) at the officer’s hourly rate of basic pay plus premium pay amounting to 20 percent of that basic rate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05144b4d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s267/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 7:30 p.m. to 3:30 a.m. shiftwork","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the regularly scheduled work assignment of a customs officer is 7:30 p.m. to 3:30 a.m., the officer is entitled to pay for work during such period (except for work to which paragraph (2) or (3) applies) at the officer’s hourly rate of basic pay plus premium pay amounting to 15 percent of that basic rate for the period from 7:30 p.m. to 11:30 p.m. and at the officer’s hourly rate of basic pay plus premium pay amounting to 20 percent of that basic rate for the period from 11:30 p.m. to 3:30 a.m.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05144b4e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s267/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sunday differential","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A customs officer who performs any regularly scheduled work on a Sunday that is not a holiday is entitled to pay for that work at the officer’s hourly rate of basic pay plus premium pay amounting to 50 percent of that basic rate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05144b4f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s267/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Holiday differential","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A customs officer who performs any regularly scheduled work on a holiday is entitled to pay for that work at the officer’s hourly rate of basic pay plus premium pay amounting to 100 percent of that basic rate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05144b50-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s267/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of premium pay","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Premium pay provided for under this subsection may not be treated as being overtime pay or compensation for any purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05144b51-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s267/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05144b52-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s267/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fiscal year cap","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The aggregate of overtime pay under subsection (a) (including commuting compensation under subsection (a)(2)(B)) and premium pay under subsection (b) that a customs officer may be paid in any fiscal year may not exceed $25,000; except that the Commissioner of U.S. Customs and Border Protection or his designee may waive this limitation in individual cases in order to prevent excessive costs or to meet emergency requirements of the Customs Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05144b53-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s267/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusivity of pay under this section","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A customs officer who receives overtime pay under subsection (a) or premium pay under subsection (b) for time worked may not receive pay or other compensation for that work under any other provision of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05144b54-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s267/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Treasury shall promulgate regulations to prevent—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05144b55-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s267/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" abuse of callback work assignments and commuting time compensation authorized under subsection (a)(2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05144b56-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s267/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the disproportionately more frequent assignment of overtime work to customs officers who are near to retirement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05144b57-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s267/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05144b58-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s267/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “customs officer” means an individual performing those functions specified by regulation by the Secretary of the Treasury for a customs inspector or canine enforcement officer. Such functions shall be consistent with such applicable standards as may be promulgated by the Office of Personnel Management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05144b59-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s267/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “holiday” means any day designated as a holiday under a Federal statute or Executive order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05144b5a-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-02-13/ch46/s5"},"text":"Feb. 13, 1911, ch. 46, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/901"},"text":"36 Stat. 901","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1920-02-07/ch61"},"text":"Feb. 7, 1920, ch. 61","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/402"},"text":"41 Stat. 402","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/271/tIII/s316"},"text":"Pub. L. 91–271, title III, § 316","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-06-02"},"text":"June 2, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/293"},"text":"84 Stat. 293","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXIII/s13811/a"},"text":"Pub. L. 103–66, title XIII, § 13811(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/668"},"text":"107 Stat. 668","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/125/tVIII/s802/d/2"},"text":"Pub. L. 114–125, title VIII, § 802(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-24"},"text":"Feb. 24, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/210"},"text":"130 Stat. 210","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05144b5b-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05144b5c-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id05144b5d-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section derived from R.S. § 2872, as amended by ","children":[{"tag":"ref","attrib":{"href":"/us/act/1884-06-26/ch121/s25"},"text":"act June 26, 1884, ch. 121, § 25","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/23/59"},"text":"23 Stat. 59","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Prior to the general revision of section 5 of act ","children":[{"tag":"date","attrib":{"date":"1911-02-13"},"text":"Feb. 13, 1911","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/s13811/a"},"text":"section 13811(a) of Pub. L. 103–66","children":[],"tail":", provisions of section 5 of act "},{"tag":"date","attrib":{"date":"1911-02-13"},"text":"Feb. 13, 1911","children":[],"tail":", relating to extra compensation for boarding officers performing services at night or on Sundays and holidays, were classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s261"},"text":"section 261 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id05144b5e-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66"},"text":"Pub. L. 103–66","children":[],"tail":" amended section generally, substituting provisions relating to overtime and premium pay for customs officers for provisions relating to fixing of working hours and overtime compensation by Secretary of the Treasury."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/271"},"text":"Pub. L. 91–271","children":[],"tail":" substituted references to the appropriate customs officer for references to the collector of customs wherever appearing, and struck out reference to inspectors, storekeepers, weighers, and other customs officers and employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id05144b5f-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id05144b60-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Commissioner of U.S. Customs and Border Protection” substituted for “Commissioner of Customs” in subsec. (c)(1) on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/125/s802/d/2"},"text":"section 802(d)(2) of Pub. L. 114–125","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s211"},"text":"section 211 of Title 6","children":[],"tail":", Domestic Security."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id05144b61-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXIII/s13811/c"},"text":"Pub. L. 103–66, title XIII, § 13811(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/670"},"text":"107 Stat. 670","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/66/tXIII/s13811/c"},"text":"“The amendments made by subsections (a) and (b) [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1450"},"text":"section 1450 of this title","children":[],"tail":", repealing "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1451a"},"text":"section 1451a of this title","children":[],"tail":", and omitting provisions formerly set out as "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s261"},"text":"section 261 of this title","children":[],"tail":"] apply to customs inspectional services provided on or after "},{"tag":"date","attrib":{"date":"1994-01-01"},"text":"January 1, 1994","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id05144b62-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1970 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/271"},"text":"Pub. L. 91–271","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/271/s203"},"text":"section 203 of Pub. L. 91–271","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1500"},"text":"section 1500 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id05144b63-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions, personnel, assets, and liabilities of the United States Customs Service of the Department of the Treasury, including functions of the Secretary of the Treasury relating thereto, to the Secretary of Homeland Security, and for treatment of related references, see sections 203(1), 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":". For establishment of U.S. Customs and Border Protection in the Department of Homeland Security, treated as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" as of "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s211"},"text":"section 211 of Title 6","children":[],"tail":", as amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/114/125"},"text":"Pub. L. 114–125","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/114/125/s802/b"},"text":"section 802(b) of Pub. L. 114–125","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s211"},"text":"section 211 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id05144b64-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id05144b65-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of all officers of Department of the Treasury and functions of all agencies and employees of such Department transferred, with certain exceptions, to Secretary of the Treasury, with power vested in him to authorize their performance or performance of any of his functions, by any of those officers, agencies, and employees, by Reorg. Plan No. 26 of 1950, §§ 1, 2, eff. ","children":[{"tag":"date","attrib":{"date":"1950-07-31"},"text":"July 31, 1950","children":[],"tail":", 15 F.R. 4935, "},{"tag":"ref","attrib":{"href":"/us/stat/64/1280"},"text":"64 Stat. 1280","children":[],"tail":", 1281, set out in the Appendix to Title 5, Government Organization and Employees. Customs officers, referred to in this section, were under Department of the Treasury."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
