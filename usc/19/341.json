{"tag":"section","attrib":{"id":"id05144bb8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s341"},"text":null,"children":[{"tag":"num","attrib":{"value":"341"},"text":"§ 341.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fraudulent practices; consul’s report","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All consuls of the United States having any knowledge or belief of any case or practice of any person who obtains verification of any invoice whereby the revenue of the United States is or may be defrauded, shall report the facts to the appropriate customs officer of the port where the revenue is or may be defrauded, or to the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id05144bb9-3a70-11f1-8ace-823fb135378d"},"text":"(R.S. § 2863; ","children":[{"tag":"ref","attrib":{"href":"/us/act/1906-04-05/ch1366/s3"},"text":"Apr. 5, 1906, ch. 1366, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/34/100"},"text":"34 Stat. 100","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/271/tIII/s319"},"text":"Pub. L. 91–271, title III, § 319","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-06-02"},"text":"June 2, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/293"},"text":"84 Stat. 293","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05144bba-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05144bbb-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id05144bbc-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 2863 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1862-07-14/ch163/s18"},"text":"act July 14, 1862, ch. 163, § 18","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/12/559"},"text":"12 Stat. 559","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id05144bbd-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/271"},"text":"Pub. L. 91–271","children":[],"tail":" substituted reference to the appropriate customs officer for reference to the collector."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id05144bbe-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id05144bbf-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1970 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/271"},"text":"Pub. L. 91–271","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/271/s203"},"text":"section 203 of Pub. L. 91–271","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1500"},"text":"section 1500 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id05144bc0-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id05144bc1-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of all officers of Department of the Treasury and functions of all agencies and employees of such Department transferred, with certain exceptions, to Secretary of the Treasury, with power vested in him to authorize their performance or performance of any of his functions, by any of those officers, agencies, and employees, by Reorg. Plan No. 26 of 1950, §§ 1, 2, eff. ","children":[{"tag":"date","attrib":{"date":"1950-07-31"},"text":"July 31, 1950","children":[],"tail":", 15 F.R. 4935, "},{"tag":"ref","attrib":{"href":"/us/stat/64/1280"},"text":"64 Stat. 1280","children":[],"tail":", 1281, set out in the Appendix to Title 5, Government Organization and Employees. Customs officers, referred to in this section, are under Department of the Treasury."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
