{"tag":"section","attrib":{"id":"id05ed465d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2513"},"text":null,"children":[{"tag":"num","attrib":{"value":"2513"},"text":"§ 2513.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver of discriminatory purchasing requirements with respect to purchases of civil aircraft","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President may waive the application of the provisions of chapter 83 of title 41 in the case of any procurement of civil aircraft and related articles of a country or instrumentality which is a party to the Agreement on Trade in Civil Aircraft referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2503/c"},"text":"section 2503(c) of this title","children":[],"tail":" and approved under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2503/a"},"text":"section 2503(a) of this title","children":[],"tail":". The President may modify or withdraw any waiver granted pursuant to this section."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id05ed465e-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39/tIII/s303"},"text":"Pub. L. 96–39, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/238"},"text":"93 Stat. 238","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/tIII/s342/a"},"text":"Pub. L. 103–465, title III, § 342(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4953"},"text":"108 Stat. 4953","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05ed465f-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"ro