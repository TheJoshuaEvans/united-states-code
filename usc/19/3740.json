{"tag":"section","attrib":{"id":"id061a97be-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3740"},"text":null,"children":[{"tag":"num","attrib":{"value":"3740"},"text":"§ 3740.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study on improving African agricultural practices","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id061a97bf-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3740/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Agriculture, in consultation with American Land Grant Colleges and Universities and not-for-profit international organizations, is authorized to conduct a 2-year study on ways to improve the flow of American farming techniques and practices to African farmers. The study shall include an examination of ways of improving or utilizing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id061a97c0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3740/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowledge of insect and sanitation procedures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id061a97c1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3740/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modern farming and soil conservation techniques;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id061a97c2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3740/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modern farming equipment (including maintaining the equipment);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id061a97c3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3740/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" marketing crop yields to prospective purchasers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id061a97c4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3740/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" crop maximization practices.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The Secretary of Agriculture shall submit the study to the Committee on Agriculture, Nutrition, and Forestry of the Senate and the Committee on Agriculture of the House of Representatives not later than ","children":[{"tag":"date","attrib":{"date":"2001-09-30"},"text":"September 30, 2001","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id061a97c5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3740/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land Grant Colleges and not-for-profit institutions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In conducting the study under subsection (a), the Secretary of Agriculture is encouraged to consult with American Land Grant Colleges and not-for-profit international organizations that have firsthand knowledge of current African farming practices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id061a97c6-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/200/tI/s130"},"text":"Pub. L. 106–200, title I, § 130","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-05-18"},"text":"May 18, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/274"},"text":"114 Stat. 274","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
