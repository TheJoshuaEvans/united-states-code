{"tag":"section","attrib":{"id":"id065d4625-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4672"},"text":null,"children":[{"tag":"num","attrib":{"value":"4672"},"text":"§ 4672.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership; term","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id065d4626-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4672/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall be composed of 12 members who shall be appointed as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id065d4627-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4672/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Four members to be appointed by the Labor Advisory Committee established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2155/c/1"},"text":"section 2155(c)(1) of this title","children":[],"tail":" (or successor advisory committee)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065d4628-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4672/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two members appointed by the Speaker of the House of Representatives, in consultation with the Chair of the Committee on Ways and Means of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065d4629-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4672/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two members appointed by the president pro tempore of the Senate from among individuals recommended by the majority leader of the Senate and in consultation with the Chair of the Committee on Finance of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065d462a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4672/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two members appointed by the minority leader of the House of Representatives, in consultation with the Ranking Member of the Committee on Ways and Means of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065d462b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4672/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two members appointed by the President pro tempore of the Senate from among individuals recommended by the minority leader of the Senate and in consultation with the Ranking Member of the Committee on Finance of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id065d462c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4672/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (c), members of the Board shall serve for a term of 6 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id065d462d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4672/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension of term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Board determines, at the end of the 6-year period beginning on the date of the appointment of the last member appointed in accordance with subsection (a), that Mexico is not fully in compliance with its labor obligations, a majority of the members of the Board may determine to extend its term for 4 additional years. A new Board shall be appointed in accordance with subsection (a) and shall serve for a single term of 4 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id065d462e-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113/tVII/s732"},"text":"Pub. L. 116–113, title VII, § 732","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-01-29"},"text":"Jan. 29, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/87"},"text":"134 Stat. 87","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
