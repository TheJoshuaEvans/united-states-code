{"tag":"section","attrib":{"id":"id06051468-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3105"},"text":null,"children":[{"tag":"num","attrib":{"value":"3105"},"text":"§ 3105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions to be taken if no agreement obtained","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id06051469-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0605146a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3105/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the President is unable, before the close of the negotiating period, to enter into an agreement under subtitle A with any priority foreign country identified under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3103"},"text":"section 3103 of this title","children":[],"tail":" which achieves the general negotiating objectives described in "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3104/b"},"text":"section 3104(b) of this title","children":[],"tail":" as defined by the specific objectives established by the President for that country, the President shall take whatever actions authorized under subsection (b) that are appropriate and most likely to achieve such general negotiating objectives."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0605146b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3105/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In taking actions under paragraph (1), the President shall first take those actions which most directly affect trade in telecommunications products and services with the priority foreign country referred to in paragraph (1), unless the President determines that actions against other economic sectors would be more effective in achieving the general negotiating objectives referred to in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0605146c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions authorized","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0605146d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3105/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The President is authorized to take any of the following actions under subsection (a) with respect to any priority foreign country:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0605146e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3105/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" termination, withdrawal, or suspension of any portion of any trade agreement entered into with such country under—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0605146f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3105/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Trade Act of 1974 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2101"},"text":"19 U.S.C. 2101","children":[],"tail":" et seq.],"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id06051470-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3105/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1821"},"text":"section 1821 of this title","children":[],"tail":", or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id06051471-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3105/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1351"},"text":"section 1351 of this title","children":[],"tail":","}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"with respect to any duty or import restriction imposed by the United States on any telecommunications product;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06051472-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3105/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actions described in section 301 of the Trade Act of 1974 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2411"},"text":"19 U.S.C. 2411","children":[],"tail":"];"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06051473-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3105/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prohibition of purchases by the Federal Government of telecommunications products of such country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06051474-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3105/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increases in domestic preferences under chapter 83 of title 41 for purchases by the Federal Government of telecommunications products of such country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06051475-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3105/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suspension of any waiver of domestic preferences under chapter 83 of title 41 which may have been extended to such country pursuant to the Trade Agreements Act of 1979 with respect to telecommunications products or any other products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06051476-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3105/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issuance of orders to appropriate officers and employees of the Federal Government to deny Federal funds or Federal credits for purchases of the telecommunications products of such country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06051477-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3105/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suspension, in whole or in part, of benefits accorded articles of such country under title V of the Trade Act of 1974 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2461"},"text":"19 U.S.C. 2461","children":[],"tail":", et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06051478-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3105/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding section 125 of the Trade Act of 1974 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2135"},"text":"19 U.S.C. 2135","children":[],"tail":"] and any other provision of law, if any portion of a trade agreement described in paragraph (1)(A) is terminated, withdrawn, or suspended under paragraph (1) with respect to any duty imposed by the United States on the products of a foreign country, the rate of such duty that shall apply to such products entered, or withdrawn from warehouse for consumption, after the date on which such termination, withdrawal, or suspension takes effect shall be a rate determined by the President."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id06051479-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3105/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Negotiating period","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0605147a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3105/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this section, the term “negotiating period” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0605147b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3105/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a priority foreign country identified in the investigation conducted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3103/a"},"text":"section 3103(a) of this title","children":[],"tail":", the 18-month period beginning on "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"August 23, 1988","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0605147c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3105/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to any foreign country identified as a priority foreign country after the conclusion of such investigation, the 1-year period beginning on the date on which such identification is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0605147d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3105/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0605147e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3105/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The negotiating period with respect to a priority foreign country may be extended for not more than two 1-year periods.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0605147f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3105/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" By no later than the date that is 15 days after the date on which the President extends the negotiating period with respect to any priority foreign country, the President shall submit to appropriate committees of the Congress a report on the status of negotiations with such country that includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id06051480-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3105/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a finding by the President that substantial progress is being made in negotiations with such country, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id06051481-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3105/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement detailing the reasons why an extension of such negotiating period is necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id06078482-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3105/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modification and termination authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President may modify or terminate any action taken under subsection (a) if, after taking into consideration the factors described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3103/b"},"text":"section 3103(b) of this title","children":[],"tail":", the President determines that changed circumstances warrant such modification or termination."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id06078483-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3105/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall promptly inform the appropriate committees of the Congress of any action taken under subsection (a) or of the modification or termination of any such action under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id06078484-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/tI/s1376"},"text":"Pub. L. 100–418, title I, § 1376","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1220"},"text":"102 Stat. 1220","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id06078485-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id06078486-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id06078487-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subtitle A, referred to in subsec. (a)(1), is subtitle A (§§ 1101–1125) of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418"},"text":"Pub. L. 100–418","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1121"},"text":"102 Stat. 1121","children":[],"tail":". For complete classification of subtitle A to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Trade Act of 1974, referred to in subsec. (b)(1)(A)(i), (G), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618"},"text":"Pub. L. 93–618","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1978"},"text":"88 Stat. 1978","children":[],"tail":", which is classified principally to chapter 12 (§ 2101 et seq.) of this title. Title V of the Trade Act of 1974 is classified generally to subchapter V (§ 2461 et seq.) of chapter 12 of this title. For complete classification of this Act to the Code, see References in Text note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2101"},"text":"section 2101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Trade Agreements Act of 1979, referred to in subsec. (b)(1)(E), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39"},"text":"Pub. L. 96–39","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/144"},"text":"93 Stat. 144","children":[],"tail":". For complete classification of this Act to the Code, see References in Text note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2501"},"text":"section 2501 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id06078488-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (b)(1)(D), (E), “chapter 83 of title 41” substituted for “title III of the Act of ","children":[{"tag":"date","attrib":{"date":"1933-03-03"},"text":"March 3, 1933","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s10a"},"text":"41 U.S.C. 10a","children":[],"tail":", et seq.)” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s6/c"},"text":"Pub. L. 111–350, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3854"},"text":"124 Stat. 3854","children":[],"tail":", which Act enacted Title 41, Public Contracts."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id06078489-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id0607848a-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of President under subsec. (e) relating to reports to Congressional committees delegated to United States Trade Representative, see section 1–401 of Ex. Ord. No. 21661, ","children":[{"tag":"date","attrib":{"date":"1988-12-27"},"text":"Dec. 27, 1988","children":[],"tail":", 54 F.R. 779, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2901"},"text":"section 2901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
