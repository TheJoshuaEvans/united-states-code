{"tag":"section","attrib":{"id":"id0511d96f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s126"},"text":null,"children":[{"tag":"num","attrib":{"value":"126"},"text":"§ 126.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imports from Canal Zone","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All laws affecting imports of articles, goods, wares, and merchandise and entry of persons into the United States from foreign countries shall apply to articles, goods, wares, and merchandise and persons coming from the Canal Zone, Isthmus of Panama, and seeking entry into any State or Territory of the United States or the District of Columbia.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0511d970-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1905-03-02/ch1311"},"text":"Mar. 2, 1905, ch. 1311","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/33/843"},"text":"33 Stat. 843","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0511d971-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0511d972-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0511d973-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For definition of Canal Zone, referred to in text, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3602/b"},"text":"section 3602(b) of Title 22","children":[],"tail":", Foreign Relations and Intercourse."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
