{"tag":"section","attrib":{"id":"id056a0c62-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1622"},"text":null,"children":[{"tag":"num","attrib":{"value":"1622"},"text":"§ 1622.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign landing certificates","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury may by regulations require the production of landing certificates in respect of merchandise exported from the United States, or in respect of residue cargo, in cases in which he deems it necessary for the protection of the revenue, or to comply with international obligations.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id056a0c63-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title IV, § 622, "},{"tag":"ref","attrib":{"href":"/us/stat/46/759"},"text":"46 Stat. 759","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/570/tIII/s3126"},"text":"Pub. L. 99–570, title III, § 3126","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-89"},"text":"100 Stat. 3207–89","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id056a0c64-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id056a0c65-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id056a0c66-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570"},"text":"Pub. L. 99–570","children":[],"tail":" inserted “, or to comply with international obligations” before period at end."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
