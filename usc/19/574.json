{"tag":"section","attrib":{"id":"id05169585-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s574"},"text":null,"children":[{"tag":"num","attrib":{"value":"574"},"text":"§ 574.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption from taking other oaths","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing contained in title 34 of the Revised Statutes shall be construed to exempt the masters or owners of vessels from making and subscribing any oaths required by any laws of the United States not immediately relating to the collection of the duties on the importation of merchandise into the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id05169586-3a70-11f1-8ace-823fb135378d"},"text":"(R.S. § 3094.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05169587-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05169588-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id05169589-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Title 34 of the Revised Statutes, referred to in text, was in the original “this Title”, meaning title 34 of the Revised Statutes, consisting of R.S. §§ 2517 to 3129. For complete classification of R.S. §§ 2517 to 3129 to the Code, see Tables.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0516958a-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 3094 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1799-03-02/ch22/s110"},"text":"act Mar. 2, 1799, ch. 22, § 110","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/1/703"},"text":"1 Stat. 703","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
