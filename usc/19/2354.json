{"tag":"section","attrib":{"id":"id05d09664-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2354"},"text":null,"children":[{"tag":"num","attrib":{"value":"2354"},"text":"§ 2354.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study by Secretary of Commerce when International Trade Commission begins investigation; action where there is affirmative finding","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05d09665-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2354/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subject matter of study","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whenever the Commission begins an investigation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2252"},"text":"section 2252 of this title","children":[],"tail":" with respect to an industry, the Commission shall immediately notify the Secretary of such investigation, and the Secretary shall immediately begin a study of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id05d09666-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2354/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of firms in the domestic industry producing the like or directly competitive article which have been or are likely to be certified as eligible for adjustment assistance, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05d09667-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2354/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the orderly adjustment of such firms to the import competition may be facilitated through the use of existing programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05d09668-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2354/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report; publication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The report of the Secretary of the study under subsection (a) shall be made to the President not later than 15 days after the day on which the Commission makes its report under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2252/f"},"text":"section 2252(f) of this title","children":[],"tail":". Upon making its report to the President, the Secretary shall also promptly make it public (with the exception of information which the Secretary determines to be confidential) and shall have a summary of it published in the Federal Register."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05d09669-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2354/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information to firms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever the Commission makes an affirmative finding under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2252/b"},"text":"section 2252(b) of this title","children":[],"tail":" that increased imports are a substantial cause of serious injury or threat thereof with respect to an industry, the Secretary shall make available, to the extent feasible, full information to the firms in such industry about programs which may facilitate the orderly adjustment to import competition of such firms, and he shall provide assistance in the preparation and processing of petitions and applications of such firms for program benefits."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05d0966a-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/tII/s264"},"text":"Pub. L. 93–618, title II, § 264","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2035"},"text":"88 Stat. 2035","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tI/s1401/b/1/B"},"text":"Pub. L. 100–418, title I, § 1401(b)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1239"},"text":"102 Stat. 1239","children":[],"tail":"; temporarily renumbered § 261, "},{"tag":"ref","attrib":{"href":"/us/pl/111/5/dB/tI/s1864/a/2"},"text":"Pub. L. 111–5, div. B, title I, § 1864(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/397"},"text":"123 Stat. 397","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/112/40/tII/s201/b"},"text":"Pub. L. 112–40, title II, § 201(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2011-10-21"},"text":"Oct. 21, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/403"},"text":"125 Stat. 403","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/114/27/tIV/s402/b"},"text":"Pub. L. 114–27, title IV, § 402(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2015-06-29"},"text":"June 29, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/374"},"text":"129 Stat. 374","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05d0966b-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","