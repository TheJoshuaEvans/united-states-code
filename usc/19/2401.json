{"tag":"section","attrib":{"id":"id05d5782d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401"},"text":null,"children":[{"tag":"num","attrib":{"value":"2401"},"text":"§ 2401.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this part:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05d5782e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agricultural commodity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “agricultural commodity” means any agricultural commodity (including livestock) in its raw or natural state.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05d5782f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agricultural commodity producer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “agricultural commodity producer” has the same meaning as the term “person” as prescribed by regulations promulgated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1308/e"},"text":"section 1308(e) of title 7","children":[],"tail":" (before the amendment made by section 1703(a) "},{"tag":"ref","attrib":{"idref":"fn002111"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002111"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of the Food, Conservation, and Energy Act of 2008)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05d57830-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contributed importantly","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05d57831-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “contributed importantly” means a cause which is important but not necessarily more important than any other cause.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05d57832-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of contributed importantly","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The determination of whether imports of articles like or directly competitive with an agricultural commodity with respect to which a petition under this part was filed contributed importantly to a decline in the price of the agricultural commodity shall be made by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05d57833-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duly authorized representative","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “duly authorized representative” means an association of agricultural commodity producers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05d57834-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National average price","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “national average price” means the national average price paid to an agricultural commodity producer for an agricultural commodity in a marketing year as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05d57835-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05d57836-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/tII/s291"},"text":"Pub. L. 93–618, title II, § 291","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/210/dA/tI/s141/a"},"text":"Pub. L. 107–210, div. A, title I, § 141(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-06"},"text":"Aug. 6, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/946"},"text":"116 Stat. 946","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/280/tXIV/s1635/f/4"},"text":"Pub. L. 109–280, title XIV, § 1635(f)(4)","children":[],"tail":", "},{"tag":"d