:{"date":"2015-06-29"},"text":"June 29, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/374"},"text":"129 Stat. 374","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05d57837-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id05d57838-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Assistance","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination of assistance under this part after ","children":[{"tag":"date","attrib":{"date":"2022-06-30"},"text":"June 30, 2022","children":[],"tail":", see Termination Date note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05d57839-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id05d5783a-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 1703(a) of the Food, Conservation, and Energy Act of 2008, referred to in par. (2), probably should be a reference to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s1603"},"text":"section 1603 of Pub. L. 110–246","children":[],"tail":", because "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" does not contain a section 1703, and subsec. (b)(3) of "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s1603"},"text":"section 1603 of Pub. L. 110–246","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1308"},"text":"section 1308 of Title 7","children":[],"tail":", Agriculture, by striking out subsec. (e), which had related to issuance of regulations defining “person”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id05d5783b-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section reflects the ","children":[{"tag":"date","attrib":{"date":"2021-07-01"},"text":"July 1, 2021","children":[],"tail":", reversion to provisions in effect on "},{"tag":"date","attrib":{"date":"2014-01-01"},"text":"Jan. 1, 2014","children":[],"tail":". See Effective and Termination Dates of 2015 Revival note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/40/s233"},"text":"Section 233 of Pub. L. 112–40","children":[],"tail":", which provided for the "},{"tag":"date","attrib":{"date":"2014-01-01"},"text":"Jan. 1, 2014","children":[],"tail":", revival of this section as in effect on "},{"tag":"date","attrib":{"date":"2011-02-13"},"text":"Feb. 13, 2011","children":[],"tail":", was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/114/27/tIV/s402/a"},"text":"Pub. L. 114–27, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-06-29"},"text":"June 29, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/374"},"text":"129 Stat. 374","children":[],"tail":", and the provisions of this section, as in effect on "},{"tag":"date","attrib":{"date":"2013-12-31"},"text":"Dec. 31, 2013","children":[],"tail":", were temporarily revived, effective "},{"tag":"date","attrib":{"date":"2015-06-29"},"text":"June 29, 2015","children":[],"tail":", until "},{"tag":"date","attrib":{"date":"2021-07-01"},"text":"July 1, 2021","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/pl/114/27"},"text":"Pub. L. 114–27","children":[],"tail":", §§ 402(b), (c), 406. See 2011 and 2015 Amendment notes, Effective and Termination Dates of 2011 Revival notes, and Effective and Termination Dates of 2015 Revival notes below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5/s1893"},"text":"Section 1893 of Pub. L. 111–5","children":[],"tail":", which provided for "},{"tag":"date","attrib":{"date":"2011-02-13"},"text":"Feb. 13, 2011","children":[],"tail":", termination of amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/111/5"},"text":"Pub. L. 111–5","children":[],"tail":", was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/112/40/tII/s201/a"},"text":"Pub. L. 112–40, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-10-21"},"text":"Oct. 21, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/403"},"text":"125 Stat. 403","children":[],"tail":", and the provisions of this section, as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/5"},"text":"Pub. L. 111–5","children":[],"tail":" and as in effect on "},{"tag":"date","attrib":{"date":"2011-02-12"},"text":"Feb. 12, 2011","children":[],"tail":", were temporarily revived, effective "},{"tag":"date","attrib":{"date":"2011-10-21"},"text":"Oct. 21, 2011","children":[],"tail":", until "},{"tag":"date","attrib":{"date":"2014-01-01"},"text":"Jan. 1, 2014","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/pl/112/40"},"text":"Pub. L. 112–40","children":[],"tail":", §§ 201(b), (c), 233. See 2009 and 2011 Amendment notes, Effective and Termination Dates of 2009 Amendment notes, and Effective and Termination Dates of 2011 Revival notes below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","c