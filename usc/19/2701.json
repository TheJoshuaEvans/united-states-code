{"tag":"section","attrib":{"id":"id05f6bc2f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2701"},"text":null,"children":[{"tag":"num","attrib":{"value":"2701"},"text":"§ 2701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to grant duty-free treatment","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President may proclaim duty-free treatment (or other preferential treatment) for all eligible articles from any beneficiary country in accordance with the provisions of this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id05f6bc30-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/67/tII/s211"},"text":"Pub. L. 98–67, title II, § 211","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-05"},"text":"Aug. 5, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/384"},"text":"97 Stat. 384","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/200/tII/s211/e/1/A"},"text":"Pub. L. 106–200, title II, § 211(e)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-05-18"},"text":"May 18, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/287"},"text":"114 Stat. 287","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05f6bc31-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05f6bc32-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id05f6bc33-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this title”, meaning title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/67"},"text":"Pub. L. 98–67","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-05"},"text":"Aug. 5, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/384"},"text":"97 Stat. 384","children":[],"tail":", which is classified principally to this chapter. For complete classification of title II to the Code, see Short Title note set out below and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id05f6bc34-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/200"},"text":"Pub. L. 106–200","children":[],"tail":" inserted “(or other preferential treatment)” after “treatment”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id05f6bc35-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id05f6bc36-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2020 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/164/s1"},"text":"Pub. L. 116–164, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-10"},"text":"Oct. 10, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/758"},"text":"134 Stat. 758","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/164/s1"},"text":"“This Act [amending sections 58c and 2703 of this title and amending provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3805"},"text":"section 3805 of this title","children":[],"tail":"] may be cited as the ‘Extension of the Caribbean Basin Economic Recovery Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id05f6bc37-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/171/s1"},"text":"Pub. L. 111–171, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-05-24"},"text":"May 24, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1194"},"text":"124 Stat. 1194","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/171/s1"},"text":"“This Act [amending sections 58c, 2703, and 2703a of this title and enacting provisions set out as notes under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2703a"},"text":"section 2703a of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6655"},"text":"section 6655 of Title 26","children":[],"tail":", Internal Revenue Code] may be cited as the ‘Haiti Economic Lift Program Act of 2010’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id05f6bc38-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXV/s15401"},"text":"Pub. L. 110–234, title XV, § 15401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1527"},"text":"122 Stat. 1527","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title XV, § 15401, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2289, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/246/s4/a"},"text":"“This part [part I (§§ 15401–15412) of subtitle D of title XV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":", amending sections 2703 and 2703a of this title and enacting provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2703a"},"text":"section 2703a of this title","children":[],"tail":"] may be cited as the ‘Haitian Hemispheric Opportunity through Partnership Encouragement Act of 2008’ or the ‘HOPE II Act’.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" enacted identical provisions. "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of Title 7","children":[],"tail":", Agriculture.]"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id05f6bc39-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432/dD/tV/s5001"},"text":"Pub. L. 109–432, div. D, title V, § 5001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3181"},"text":"120 Stat. 3181","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/432/dD/tV/s5001"},"text":"“This title [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2703a"},"text":"section 2703a of this title","children":[],"tail":", amending sections 2703 and 3203 of this title, and enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2703"},"text":"section 2703 of this title","children":[],"tail":"] may be cited as the ‘Haitian Hemispheric Opportunity through Partnership Encouragement Act of 2006’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id05f6bc3a-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/200/tII/s201"},"text":"Pub. L. 106–200, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-05-18"},"text":"May 18, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/275"},"text":"114 Stat. 275","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/200/tII/s201"},"text":"“This title [amending this section and sections 2702 to 2704, 3202, and 3204 of this title and enacting provisions set out as notes under this section] may be cited as the ‘United States-Caribbean Basin Trade Partnership Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id05f6bc3b-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/382/tII/s201"},"text":"Pub. L. 101–382, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-20"},"text":"Aug. 20, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/655"},"text":"104 Stat. 655","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/382/tII/s201"},"text":"“This title [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s226"},"text":"section 226 of Title 20","children":[],"tail":", Education, amending sections 1677, 2463, 2702, 2703, and 2706 of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s936"},"text":"section 936 of Title 26","children":[],"tail":", Internal Revenue Code, enacting provisions set out as notes under this section and sections 1677, 2071, and 2703 of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s936"},"text":"section 936 of Title 26","children":[],"tail":", and amending provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2703"},"text":"section 2703 of this title","children":[],"tail":"] may be cited as the ‘Caribbean Basin Economic Recovery Expansion Act of 1990’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id05f6bc3c-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/67/tII/s201"},"text":"Pub. L. 98–67, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-05"},"text":"Aug. 5, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/384"},"text":"97 Stat. 384","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/67/tII/s201"},"text":"“This title [enacting this chapter, amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1202"},"text":"section 1202 of this title","children":[],"tail":" and sections 274 and 7652 of Title 26, Internal Revenue Code, repealing "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2582"},"text":"section 2582 of this title","children":[],"tail":", and enacting provisions set out as notes under sections 1319, 2251, and 2703 of this title, sections 274 and 7652 of Title 26, and "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1311"},"text":"section 1311 of Title 33","children":[],"tail":", Navigation and Navigable Waters] may be cited as the ‘Caribbean Basin Economic Recovery Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id05f6bc3d-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Findings and Policy","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/200/tII/s202"},"text":"Pub. L. 106–200, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-05-18"},"text":"May 18, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/275"},"text":"114 Stat. 275","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/200/tII/s202"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Findings","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress makes the following findings:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Caribbean Basin Economic Recovery Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2701"},"text":"19 U.S.C. 2701","children":[],"tail":" et seq.] (in this title [see Short Title of 2000 Amendment note above] referred to as ‘CBERA’) represents a permanent commitment by the United States to encourage the development of strong democratic governments and revitalized economies in neighboring countries in the Caribbean Basin."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In 1998, Hurricane Mitch and Hurricane Georges devastated areas in the Caribbean Basin region, killing more than 10,000 people and leaving 3,000,000 homeless.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The total direct impact of Hurricanes Mitch and Georges on Honduras, Nicaragua, the Dominican Republic, El Salvador, and Guatemala amounts to $4,200,000,000, representing a severe loss to income levels in this underdeveloped region.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In addition to short term disaster assistance, United States policy toward the region should focus on expanding international trade with the Caribbean Basin region as an enduring solution for successful economic growth and recovery.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Thirty-four democratically elected leaders agreed at the 1994 Summit of the Americas to conclude negotiation of a Free Trade Area of the Americas (in this title referred to as ‘FTAA’) by the year 2005.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The economic security of the countries in the Caribbean Basin will be enhanced by the completion of the FTAA.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Offering temporary benefits to Caribbean Basin countries will preserve the United States commitment to Caribbean Basin beneficiary countries, promote the growth of free enterprise and economic opportunity in these neighboring countries, and thereby enhance the national security interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"“(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Given the greater propensity of countries located in the Western Hemisphere to use United States components and to purchase United States products compared to other countries, increased trade and economic activity between the United States and countries in the Western Hemisphere will create new jobs in the United States as a result of expanding export opportunities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Policy","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the policy of the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to offer Caribbean Basin beneficiary countries willing to prepare to become a party to the FTAA or another free trade agreement, tariff treatment essentially equivalent to that accorded to products of NAFTA countries for certain products not currently eligible for duty-free treatment under the CBERA; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to seek the participation of Caribbean Basin beneficiary countries in the FTAA or another free trade agreement at the earliest possible date, with the goal of achieving full participation in such agreement not later than 2005.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id05f6bc3e-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Meetings of Trade Ministers and USTR","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/200/tII/s213"},"text":"Pub. L. 106–200, title II, § 213","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-05-18"},"text":"May 18, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/288"},"text":"114 Stat. 288","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/200/tII/s213"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Schedule of Meetings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President shall take the necessary steps to convene a meeting with the trade ministers of the CBTPA beneficiary countries in order to establish a schedule of regular meetings, to commence as soon as is practicable, of the trade ministers and the Trade Representative, for the purpose set forth in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The purpose of the meetings scheduled under subsection (a) is to reach agreement between the United States and CBTPA beneficiary countries on the likely timing and procedures for initiating negotiations for CBTPA beneficiary countries to enter into mutually advantageous free trade agreements with the United States that contain provisions comparable to those in the NAFTA and would make substantial progress in achieving the negotiating objectives set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/182/s108/b/5"},"text":"section 108(b)(5) of Public Law 103–182","children":[],"tail":" ([former] "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3317/b/5"},"text":"19 U.S.C. 3317(b)(5)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term ‘CBTPA beneficiary country’ has the meaning given that term in section 213(b)(5)(B) of the Caribbean Basin Economic Recovery Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2703/b/5/B"},"text":"19 U.S.C. 2703(b)(5)(B)","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id05f6bc3f-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Congressional Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/382/tII/s202"},"text":"Pub. L. 101–382, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-20"},"text":"Aug. 20, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/655"},"text":"104 Stat. 655","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/382/tII/s202"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Congress finds that—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a stable political and economic climate in the Caribbean region is necessary for the development of the countries in that region and for the security and economic interests of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Caribbean Basin Economic Recovery Act [this chapter] was enacted in 1983 to assist in the achievement of such a climate by stimulating the development of the export potential of the region; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the commitment of the United States to the successful development of the region, as evidenced by the enactment of the Caribbean Basin Economic Recovery Act, should be reaffirmed, and further strengthened, by amending that Act to improve its operation.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id05f6bc40-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/200/tII/s203"},"text":"Pub. L. 106–200, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-05-18"},"text":"May 18, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/276"},"text":"114 Stat. 276","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/200/tII/s203"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“In this title [see Short Title of 2000 Amendment note above]:","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"NAFTA","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘NAFTA’ means the North American Free Trade Agreement entered into between the United States, Mexico, and Canada on ","children":[{"tag":"date","attrib":{"date":"1992-12-17"},"text":"December 17, 1992","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"NAFTA country","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘NAFTA country’ means any country with respect to which the NAFTA is in force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"WTO and wto member","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The terms ‘WTO’ and ‘WTO member’ have the meanings given those terms in section 2 of the Uruguay Round Agreements Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3501"},"text":"19 U.S.C. 3501","children":[],"tail":").”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
