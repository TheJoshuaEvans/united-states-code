{"tag":"section","attrib":{"id":"id06515f17-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4401"},"text":null,"children":[{"tag":"num","attrib":{"value":"4401"},"text":"§ 4401.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion of interest in certain distributions of antidumping duties and countervailing duties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id06515f18-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4401/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Homeland Security shall deposit all interest described in subsection (c) into the special account established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1675c/e"},"text":"section 1675c(e) of this title","children":[],"tail":" (repealed by subtitle F of title VII of the Deficit Reduction Act of 2005 ("},{"tag":"ref","attrib":{"href":"/us/pl/109/171"},"text":"Public Law 109–171","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/120/154"},"text":"120 Stat. 154","children":[],"tail":")) for inclusion in distributions described in subsection (b) made on or after "},{"tag":"date","attrib":{"date":"2016-02-24"},"text":"February 24, 2016","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id06515f19-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4401/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distributions described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Distributions described in this subsection are distributions of antidumping duties and countervailing duties assessed on or after ","children":[{"tag":"date","attrib":{"date":"2000-10-01"},"text":"October 1, 2000","children":[],"tail":", that are made under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1675c"},"text":"section 1675c of this title","children":[],"tail":" (repealed by subtitle F of title VII of the Deficit Reduction Act of 2005 ("},{"tag":"ref","attrib":{"href":"/us/pl/109/171"},"text":"Public Law 109–171","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/120/154"},"text":"120 Stat. 154","children":[],"tail":")), with respect to entries of merchandise that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id06515f1a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4401/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" were made on or before ","children":[{"tag":"date","attrib":{"date":"2007-09-30"},"text":"September 30, 2007","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06515f1b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4401/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" were, in accordance with section 822 of the Claims Resolution Act of 2010 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1675c"},"text":"19 U.S.C. 1675c","children":[],"tail":" note), unliquidated, not in litigation, and not under an order of liquidation from the Department of Commerce on "},{"tag":"date","attrib":{"date":"2010-12-08"},"text":"December 8, 2010","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id06515f1c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4401/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest described","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id06515f1d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4401/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest realized","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Interest described in this subsection is interest earned on antidumping duties or countervailing duties described in subsection (b) that is realized through application of a payment received on or after ","children":[{"tag":"date","attrib":{"date":"2014-10-01"},"text":"October 1, 2014","children":[],"tail":", by U.S. Customs and Border Protection under, or in connection with—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id06515f1e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4401/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a customs bond pursuant to a court order or judgment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06515f1f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4401/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a settlement with respect to a customs bond, including any payment made to U.S. Customs and Border Protection with respect to that bond by a surety.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06515f20-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4401/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Types of interest","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Interest described in paragraph (1) includes the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id06515f21-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4401/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Interest accrued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1677g"},"text":"section 1677g of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06515f22-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4401/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Interest accrued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1505/d"},"text":"section 1505(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06515f23-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4401/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Equitable interest under common law and interest under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s580"},"text":"section 580 of this title","children":[],"tail":" awarded by a court against a surety under its bond for late payment of antidumping duties, countervailing duties, or interest described in subparagraph (A) or (B)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id06515f24-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4401/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id06515f25-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4401/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Antidumping duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “antidumping duties” means antidumping duties imposed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1673"},"text":"section 1673 of this title","children":[],"tail":" or under the Antidumping Act, 1921 (title II of the Act of "},{"tag":"date","attrib":{"date":"1921-05-27"},"text":"May 27, 1921","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/42/11"},"text":"42 Stat. 11","children":[],"tail":", chapter 14)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06515f26-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4401/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Countervailing duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “countervailing duties” means countervailing duties imposed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1671"},"text":"section 1671 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id06515f27-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/125/tVI/s605"},"text":"Pub. L. 114–125, title VI, § 605","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-24"},"text":"Feb. 24, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/187"},"text":"130 Stat. 187","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id06515f28-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id06515f29-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id06515f2a-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1675c"},"text":"Section 1675c of this title","children":[],"tail":" (repealed by subtitle F of title VII of the Deficit Reduction Act of 2005), referred to in subsecs. (a) and (b), means "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1675c"},"text":"section 1675c of this title","children":[],"tail":", which was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/109/171/tVII/s7601/a"},"text":"Pub. L. 109–171, title VII, § 7601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-02-08"},"text":"Feb. 8, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/154"},"text":"120 Stat. 154","children":[],"tail":", and which related to an annual distribution to certain domestic producers known as the “continued dumping and subsidy offset”. Subsec. (e) of section 1675c related to special accounts established in the Treasury of the United States for certain antidumping and countervailing duty orders and findings."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 822 of the Claims Resolution Act of 2010, referred to in subsec. (b)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/291/s822"},"text":"section 822 of Pub. L. 111–291","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1675c"},"text":"section 1675c of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Antidumping Act, 1921, referred to in subsec. (d)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1921-05-27/ch14/tII"},"text":"act May 27, 1921, ch. 14, title II","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/11"},"text":"42 Stat. 11","children":[],"tail":", which was classified generally to sections 160 to 171 of this title, and was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/96/39/tI/s106/a"},"text":"Pub. L. 96–39, title I, § 106(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/193"},"text":"93 Stat. 193","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
