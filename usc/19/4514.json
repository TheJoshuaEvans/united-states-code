{"tag":"section","attrib":{"id":"id0653d10d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4514"},"text":null,"children":[{"tag":"num","attrib":{"value":"4514"},"text":"§ 4514.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation and layover provisions for, and effective date of, proclaimed actions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"If a provision of this Act provides that the implementation of an action by the President by proclamation is subject to the consultation and layover requirements of this section, that action may be proclaimed only if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0653d10e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4514/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the President has obtained advice regarding the proposed action from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0653d10f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4514/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriate advisory committees established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2155"},"text":"section 2155 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0653d110-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4514/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the International Trade Commission, which shall hold a public hearing on the proposed action before providing advice regarding the proposed action;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0653d111-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4514/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the President has submitted to the Committee on Finance of the Senate and the Committee on Ways and Means of the House of Representatives a report that sets forth—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0653d112-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4514/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the proposed action and the reasons therefor; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0653d113-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4514/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the advice obtained under paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0653d114-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4514/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a period of 60 calendar days, beginning on the first day on which the requirements set forth in paragraphs (1) and (2) have been met, has expired; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0653d115-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4514/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President has consulted with the committees referred to in paragraph (2) regarding the proposed action during the period referred to in paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0653d116-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113/tI/s104"},"text":"Pub. L. 116–113, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-01-29"},"text":"Jan. 29, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/17"},"text":"134 Stat. 17","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0653d117-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0653d118-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0653d119-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113"},"text":"Pub. L. 116–113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-01-29"},"text":"Jan. 29, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/11"},"text":"134 Stat. 11","children":[],"tail":", known as the United States-Mexico-Canada Agreement Implementation Act. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s4501"},"text":"section 4501 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id0653d11a-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id0653d11b-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Proc. No. 10053, par. (7), ","children":[{"tag":"date","attrib":{"date":"2020-06-29"},"text":"June 29, 2020","children":[],"tail":", 85 F.R. 39826, authorized the United States Trade Representative to fulfill the obligations of the President to obtain advice from the appropriate advisory committees and the International Trade Commission on the proposed implementation of an action by Presidential proclamation; to submit a report on such proposed action to the appropriate congressional committees; and to consult with those congressional committees regarding the proposed action."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
