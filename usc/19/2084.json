{"tag":"section","attrib":{"id":"id0599ceb3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2084"},"text":null,"children":[{"tag":"num","attrib":{"value":"2084"},"text":"§ 2084.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Trade","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0599ceb4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2084/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in U.S. Customs and Border Protection an Office of Trade.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0599ceb5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2084/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Executive Assistant Commissioner","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be at the head of the Office of Trade an Executive Assistant Commissioner, who shall report to the Commissioner of U.S. Customs and Border Protection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0599ceb6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2084/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Office of Trade shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0599ceb7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2084/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct the development and implementation, pursuant to the customs and trade laws of the United States, of policies and regulations administered by U.S. Customs and Border Protection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0599ceb8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2084/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the Commissioner of U.S. Customs and Border Protection with respect to the impact on trade facilitation and trade enforcement of any policy or regulation otherwise proposed or administered by U.S. Customs and Border Protection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0599ceb9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2084/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate with the Executive Assistant Commissioner for the Office of Field Operations with respect to the trade facilitation and trade enforcement activities of U.S. Customs and Border Protection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0599ceba-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2084/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct the development and implementation of matters relating to the priority trade issues identified by the Commissioner of U.S. Customs and Border Protection in the joint strategic plan for trade facilitation and trade enforcement required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4314"},"text":"section 4314 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0599cebb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2084/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise advise the Commissioner of U.S. Customs and Border Protection with respect to the development and implementation of the joint strategic plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0599cebc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2084/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct the trade enforcement activities of U.S. Customs and Border Protection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0599cebd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2084/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" oversee the trade modernization activities of U.S. Customs and Border Protection, including the development and implementation of the Automated Commercial Environment computer system authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s58c/f/4"},"text":"section 58c(f)(4) of this title","children":[],"tail":" and support for the establishment of the International Trade Data System under the oversight of the Department of the Treasury pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1411/d"},"text":"section 1411(d) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0599cebe-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2084/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct the administration of customs revenue functions as otherwise provided by law or delegated by the Commissioner of U.S. Customs and Border Protection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0599cebf-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2084/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" prepare an annual report to be submitted to the Committee on Finance of the Senate and the Committee on Ways and Means of the House of Representatives not later than ","children":[{"tag":"date","attrib":{"date":"2016-06-01"},"text":"June 1, 2016","children":[],"tail":", and March 1 of each calendar year thereafter that includes—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0599cec0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2084/c/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the changes to customs policies and regulations adopted by U.S. Customs and Border Protection during the preceding calendar year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0599cec1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2084/c/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the public vetting and interagency consultation that occurred with respect to each such change.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0599cec2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2084/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of assets, functions, personnel, or liabilities; elimination of offices","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0599cec3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2084/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of International Trade","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0599cec4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2084/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after ","children":[{"tag":"date","attrib":{"date":"2016-02-24"},"text":"February 24, 2016","children":[],"tail":", the Commissioner of U.S. Customs and Border Protection shall transfer the assets, functions, personnel, and liabilities of the Office of International Trade to the Office of Trade established under subsection (b)."},{"tag":"ref","attrib":{"idref":"fn002082"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002082"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “subsection (a).”"}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0599cec5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2084/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elimination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after ","children":[{"tag":"date","attrib":{"date":"2016-02-24"},"text":"February 24, 2016","children":[],"tail":", the Office of International Trade shall be abolished."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0599cec6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2084/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No funds appropriated to U.S. Customs and Border Protection or the Department of Homeland Security may be used to transfer the assets, functions, personnel, or liabilities of the Office of International Trade to an office other than the Office of Trade established under subsection (a), unless the Commissioner of U.S. Customs and Border Protection notifies the Committee on Homeland Security and the Committee on Ways and Means of the House of Representatives and the Committee on Homeland Security and Governmental Affairs and the Committee on Finance of the Senate of the specific assets, functions, personnel, or liabilities to be transferred, and the reason for the transfer, not less than 90 days prior to the transfer of such assets, functions, personnel, or liabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0599cec7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2084/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of International Trade defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this paragraph, the term “Office of International Trade” means the Office of International Trade established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2072"},"text":"section 2072 of this title","children":[],"tail":" and as in effect on the day before "},{"tag":"date","attrib":{"date":"2016-02-24"},"text":"February 24, 2016","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0599cec8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2084/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other transfers","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0599cec9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2084/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commissioner of U.S. Customs and Border Protection is authorized to transfer any other assets, functions, or personnel within U.S. Customs and Border Protection to the Office of Trade established under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0599ceca-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2084/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less than 90 days prior to the transfer of assets, functions, personnel, or liabilities under subparagraph (A), the Commissioner of U.S. Customs and Border Protection shall notify the Committee on Homeland Security and the Committee on Ways and Means of the House of Representatives and the Committee on Homeland Security and Governmental Affairs and the Committee on Finance of the Senate of the specific assets, functions, personnel, or liabilities to be transferred, and the reason for such transfer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0599cecb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2084/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the terms “customs and trade laws of the United States”, “trade enforcement”, and “trade facilitation” have the meanings given such terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4301"},"text":"section 4301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0599cecc-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1927-03-03/ch348/s4"},"text":"Mar. 3, 1927, ch. 348, § 4","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/125/tVIII/s802/h/1"},"text":"Pub. L. 114–125, title VIII, § 802(h)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-24"},"text":"Feb. 24, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/213"},"text":"130 Stat. 213","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0599cecd-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0599cece-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0599cecf-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 4 of act ","children":[{"tag":"date","attrib":{"date":"1927-03-03"},"text":"March 3, 1927","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s281c"},"text":"section 281c of Title 5","children":[],"tail":" prior to the general revision and enactment of Title 5, Government Organization and Employees, by "},{"tag":"ref","attrib":{"href":"/us/pl/89/554/s1"},"text":"Pub. L. 89–554, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/378"},"text":"80 Stat. 378","children":[],"tail":". Subsection (a) of section 4 was transferred to "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s163"},"text":"section 163 of Title 21","children":[],"tail":", Food and Drugs, prior to the omission of section 163 from the Code on the authority of Reorg. Plan No. 1 of 1968, eff. "},{"tag":"date","attrib":{"date":"1968-04-08"},"text":"Apr. 8, 1968","children":[],"tail":", 33 F.R. 5611, "},{"tag":"ref","attrib":{"href":"/us/stat/82/1367"},"text":"82 Stat. 1367","children":[],"tail":", set out in the Appendix to Title 5."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0599ced0-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0599ced1-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Continuation in Office","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/125/tVIII/s802/h/2"},"text":"Pub. L. 114–125, title VIII, § 802(h)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-24"},"text":"Feb. 24, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/215"},"text":"130 Stat. 215","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/125/tVIII/s802/h/2"},"text":"“The individual serving as the Assistant Commissioner of the Office of International Trade on the day before the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2016-02-24"},"text":"Feb. 24, 2016","children":[],"tail":"] may serve as the Executive Assistant Commissioner of Trade on and after such date of enactment, at the discretion of the Commissioner of U.S. Customs and Border Protection.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
