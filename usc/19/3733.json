{"tag":"section","attrib":{"id":"id061a976d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3733"},"text":null,"children":[{"tag":"num","attrib":{"value":"3733"},"text":"§ 3733.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Overseas Private Investment Corporation initiatives","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id061a976e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3733/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initiation of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the sense of the Congress that the Overseas Private Investment Corporation ","children":[{"tag":"ref","attrib":{"idref":"fn002160"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002160"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Transfer of Functions note below."}],"tail":" should exercise the authorities it has to initiate an equity fund or equity funds in support of projects in the countries in sub-Saharan Africa, in addition to the existing equity fund for sub-Saharan Africa created by the Corporation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id061a976f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3733/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Structure and types of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id061a9770-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3733/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Structure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each fund initiated under subsection (a) should be structured as a partnership managed by professional private sector fund managers and monitored on a continuing basis by the Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id061a9771-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3733/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capitalization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each fund should be capitalized with a combination of private equity capital, which is not guaranteed by the Corporation, and debt for which the Corporation provides guaranties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id061a9772-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3733/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Infrastructure fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"One or more of the funds, with combined assets of up to $500,000,000, should be used in support of infrastructure projects in countries of sub-Saharan Africa.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id061a9773-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3733/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emphasis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation shall ensure that the funds are used to provide support in particular to women entrepreneurs and to innovative investments that expand opportunities for women and maximize employment opportunities for poor individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id061a9774-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3733/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Overseas Private Investment Corporation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id061a9775-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3733/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id061a9776-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3733/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within 6 months after ","children":[{"tag":"date","attrib":{"date":"2000-05-18"},"text":"May 18, 2000","children":[],"tail":", and annually for each of the 4 years thereafter, the Board of Directors of the Overseas Private Investment Corporation "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" shall submit to Congress a report on the steps that the Board has taken to implement section 2193(e) "},{"tag":"ref","attrib":{"idref":"fn002161"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002161"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":" of title 22 and any recommendations of the investment advisory council established pursuant to such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id061a9777-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/200/tI/s123"},"text":"Pub. L. 106–200, title I, § 123","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-05-18"},"text":"May 18, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/269"},"text":"114 Stat. 269","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id061a9778-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id061a9779-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id061a977a-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2193/e"},"text":"Section 2193(e) of title 22","children":[],"tail":", referred to in subsec. (c)(2), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dF/tVI/s1464/2"},"text":"Pub. L. 115–254, div. F, title VI, § 1464(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3513"},"text":"132 Stat. 3513","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id061a977b-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/200/s123"},"text":"section 123 of Pub. L. 106–200","children":[],"tail":". Subsec. (c)(1) of "},{"tag":"ref","attrib":{"href":"/us/pl/106/200/s123"},"text":"section 123 of Pub. L. 106–200","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2193"},"text":"section 2193 of Title 22","children":[],"tail":", Foreign Relations and Intercourse."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id061a977c-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id061a977d-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions, personnel, assets, and liabilities of the Overseas Private Investment Corporation to the United States International Development Finance Corporation and treatment of related references, see sections 9683 and 9686(d) of Title 22, Foreign Relations and Intercourse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
