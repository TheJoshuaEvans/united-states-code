{"tag":"section","attrib":{"id":"id055e2548-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1582"},"text":null,"children":[{"tag":"num","attrib":{"value":"1582"},"text":"§ 1582.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Search of persons and baggage; regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury may prescribe regulations for the search of persons and baggage and he is authorized to employ female inspectors for the examination and search of persons of their own sex; and all persons coming into the United States from foreign countries shall be liable to detention and search by authorized officers or agents of the Government under such regulations.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id055e2549-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title IV, § 582, "},{"tag":"ref","attrib":{"href":"/us/stat/46/748"},"text":"46 Stat. 748","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id055e254a-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id055e254b-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id055e254c-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in R.S. § 3064, which was superseded by ","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-09-21/ch356/tIV/s582"},"text":"act Sept. 21, 1922, ch. 356, title IV, § 582","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/979"},"text":"42 Stat. 979","children":[],"tail":", and was repealed by section 642 thereof. Section 582 of the 1922 act was superseded by section 582 of act "},{"tag":"date","attrib":{"date":"1930-06-17"},"text":"June 17, 1930","children":[],"tail":", comprising this section, and repealed by section 651(a)(1) of the 1930 act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
