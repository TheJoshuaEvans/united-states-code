{"tag":"section","attrib":{"id":"id05ce4c78-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2341"},"text":null,"children":[{"tag":"num","attrib":{"value":"2341"},"text":"§ 2341.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Petitions and determinations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05ce4c79-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2341/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Filing of petition; receipt of petition; initiation of investigation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A petition for a certification of eligibility to apply for adjustment assistance under this part may be filed with the Secretary of Commerce (hereinafter in this part referred to as the “Secretary”) by a firm (including any agricultural firm) or its representative. Upon receipt of the petition, the Secretary shall promptly publish notice in the Federal Register that he has received the petition and initiated an investigation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05ce4c7a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2341/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public hearing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the petitioner, or any other person, organization, or group found by the Secretary to have a substantial interest in the proceedings, submits not later than 10 days after the date of the Secretary’s publication under subsection (a) a request for a hearing, the Secretary shall provide for a public hearing and afford such interested persons an opportunity to be present, to produce evidence, and to be heard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05ce4c7b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2341/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05ce4c7c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2341/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall certify a firm (including any agricultural firm) as eligible to apply for adjustment assistance under this part if the Secretary determines—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05ce4c7d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2341/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that a significant number or proportion of the workers in such firm have become totally or partially separated, or are threatened to become totally or partially separated,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05ce4c7e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2341/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id05ce4c7f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2341/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sales or production, or both, of such firm have decreased absolutely, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05ce4c80-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2341/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sales or production, or both, of an article that accounted for not less than 25 percent of the total production or sales of the firm during the 12-month period preceding the most recent 12-month period for which data are available have decreased absolutely, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05ce4c81-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2341/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increases of imports of articles like or directly competitive with articles which are produced by such firm contributed importantly to such total or partial separation, or threat thereof, and to such decline in sales or production.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05ce4c82-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2341/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of paragraph (1)(C)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05ce4c83-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2341/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “contributed importantly” means a cause which is important but not necessarily more important than any other cause.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05ce4c84-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2341/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id05ce4c85-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2341/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any firm which engages in exploration or drilling for oil or natural gas shall be considered to be a firm producing oil or natural gas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05ce4c86-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2341/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any firm that engages in exploration or drilling for oil or natural gas, or otherwise produces oil or natural gas, shall be considered to be producing articles directly competitive with imports of oil and with imports of natural gas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05ce4c87-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2341/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowable period for determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A determination shall be made by the Secretary as soon as possible after the date on which the petition is filed under this section, but in any event not later than 60 days after that date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05ce4c88-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/tII/s251"},"text":"Pub. L. 93–618, title II, § 251","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2030"},"text":"88 Stat. 2030","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/272/tXIII/s13002/b"},"text":"Pub. L. 99–272, title XIII, § 13002(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-04-07"},"text":"Apr. 7, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/300"},"text":"100 Stat. 300","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tI/s1421/a/2"},"text":"Pub. L. 100–418, title I, § 1421(a)(2)","children":[],"tail":", (b)(2), "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1243"},"text":"102 Stat. 1243","children":[],"tail":", 1244; "},{"tag":"ref","attrib":{"href":"/us/pl/111/5/dB/tI"},"text":"Pub. L. 111–5, div. B, title I","children":[],"tail":", §§ 1861(a), (c), 1862, 1863, 1867(a), "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/396"},"text":"123 Stat. 396","children":[],"tail":", 397, 400; "},{"tag":"ref","attrib":{"href":"/us/pl/112/40/tII/s201/b"},"text":"Pub. L. 112–40, title II, § 201(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2011-10-21"},"text":"Oct. 21, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/403"},"text":"125 Stat. 403","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/27/tIV/s402/b"},"text":"Pub. L. 114–27, title IV, § 402(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2015-06-29"},"text":"June 29, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/374"},"text":"129 Stat. 374","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05ce4c89-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id05ce4c8a-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Assistance","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination of assistance under this part after ","children":[{"tag":"date","attrib":{"date":"2022-06-30"},"text":"June 30, 2022","children":[],"tail":", see Termination Date note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05ce4c8b-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id05ce4c8c-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section reflects the ","children":[{"tag":"date","attrib":{"date":"2021-07-01"},"text":"July 1, 2021","children":[],"tail":", reversion to provisions in effect on "},{"tag":"date","attrib":{"date":"2014-01-01"},"text":"Jan. 1, 2014","children":[],"tail":". See Effective and Termination Dates of 2015 Revival note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/40/s233"},"text":"Section 233 of Pub. L. 112–40","children":[],"tail":", which provided for the "},{"tag":"date","attrib":{"date":"2014-01-01"},"text":"Jan. 1, 2014","children":[],"tail":", revival of this section as in effect on "},{"tag":"date","attrib":{"date":"2011-02-13"},"text":"Feb. 13, 2011","children":[],"tail":", was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/114/27/tIV/s402/a"},"text":"Pub. L. 114–27, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-06-29"},"text":"June 29, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/374"},"text":"129 Stat. 374","children":[],"tail":", and the provisions of this section, as in effect on "},{"tag":"date","attrib":{"date":"2013-12-31"},"text":"Dec. 31, 2013","children":[],"tail":", were temporarily revived, effective "},{"tag":"date","attrib":{"date":"2015-06-29"},"text":"June 29, 2015","children":[],"tail":", until "},{"tag":"date","attrib":{"date":"2021-07-01"},"text":"July 1, 2021","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/pl/114/27"},"text":"Pub. L. 114–27","children":[],"tail":", §§ 402(b), (c), 406. See 2011 and 2015 Amendment notes, Effective and Termination Dates of 2011 Revival notes, and Effective and Termination Dates of 2015 Revival notes below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5/s1893"},"text":"Section 1893 of Pub. L. 111–5","children":[],"tail":", which provided for "},{"tag":"date","attrib":{"date":"2011-02-13"},"text":"Feb. 13, 2011","children":[],"tail":", termination of amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/111/5"},"text":"Pub. L. 111–5","children":[],"tail":", was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/112/40/tII/s201/a"},"text":"Pub. L. 112–40, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-10-21"},"text":"Oct. 21, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/403"},"text":"125 Stat. 403","children":[],"tail":", and the provisions of this section, as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/5"},"text":"Pub. L. 111–5","children":[],"tail":" and as in effect on "},{"tag":"date","attrib":{"date":"2011-02-12"},"text":"Feb. 12, 2011","children":[],"tail":", were temporarily revived, effective "},{"tag":"date","attrib":{"date":"2011-10-21"},"text":"Oct. 21, 2011","children":[],"tail":", until "},{"tag":"date","attrib":{"date":"2014-01-01"},"text":"Jan. 1, 2014","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/pl/112/40"},"text":"Pub. L. 112–40","children":[],"tail":", §§ 201(b), (c), 233. See 2009 and 2011 Amendment notes, Effective and Termination Dates of 2009 Amendment notes, and Effective and Termination Dates of 2011 Revival notes below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id05ce4c8d-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/27"},"text":"Pub. L. 114–27","children":[],"tail":", §§ 402(b), (c), 406, temporarily revived the provisions of this section, as in effect on "},{"tag":"date","attrib":{"date":"2013-12-31"},"text":"Dec. 31, 2013","children":[],"tail":". See Codification note above and 2011 Amendment and Effective and Termination Dates of 2015 Revival notes below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/40"},"text":"Pub. L. 112–40","children":[],"tail":", §§ 201(b), (c), 233, temporarily revived the provisions of this section, as in effect on "},{"tag":"date","attrib":{"date":"2011-02-12"},"text":"Feb. 12, 2011","children":[],"tail":". See Codification note above and 2009 Amendment and Effective and Termination Dates of 2011 Revival notes below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5"},"text":"Pub. L. 111–5","children":[],"tail":", §§ 1861(a), 1867(a)(1), 1893, temporarily inserted “or service sector firm” after “agricultural firm” and substituted “the Secretary has” for “he has”. See Codification note above and Effective and Termination Dates of 2009 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5"},"text":"Pub. L. 111–5","children":[],"tail":", §§ 1861(a), 1893, temporarily inserted “or service sector firm” after “agricultural firm” in introductory provisions. See Codification note above and Effective and Termination Dates of 2009 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5"},"text":"Pub. L. 111–5","children":[],"tail":", §§ 1862, 1893, temporarily amended subpar. (B) generally. Prior to amendment, subpar. (B) read as follows: “that—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) sales or production, or both, of such firm have decreased absolutely, or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) sales or production, or both, of an article that accounted for not less than 25 percent of the total production or sales of the firm during the 12-month period preceding the most recent 12-month period for which data are available have decreased absolutely, and”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"See Codification note above and Effective and Termination Dates of 2009 Amendment note below.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5"},"text":"Pub. L. 111–5","children":[],"tail":", §§ 1861(c)(1), 1893, temporarily inserted “or services” after “imports of articles” and “or services which are supplied” after “produced”. See Codification note above and Effective and Termination Dates of 2009 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5"},"text":"Pub. L. 111–5","children":[],"tail":", §§ 1861(c)(2), 1893, temporarily amended cl. (ii) generally. Prior to amendment, cl. (ii) read as follows: “Any firm that engages in exploration or drilling for oil or natural gas, or otherwise produces oil or natural gas, shall be considered to be producing articles directly competitive with imports of oil and with imports of natural gas.” See Codification note above and Effective and Termination Dates of 2009 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5"},"text":"Pub. L. 111–5","children":[],"tail":", §§ 1867(a)(2), 1893, temporarily substituted “40 days” for “60 days”. See Codification note above and Effective and Termination Dates of 2009 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5"},"text":"Pub. L. 111–5","children":[],"tail":", §§ 1863, 1893, temporarily added subsecs. (e) and (f). See Codification note above and Effective and Termination Dates of 2009 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/s1421/a/2"},"text":"Pub. L. 100–418, § 1421(a)(2)","children":[],"tail":", amended subsec. (c) generally. Prior to amendment, subsec. (c) read as follows: “The Secretary shall certify a firm (including any agricultural firm) as eligible to apply for adjustment assistance under this part if he determines—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) that a significant number or proportion of the workers in such firm have become totally or partially separated, or are threatened to become totally or partially separated.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) that—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) sales or production, or both, of the firm have decreased absolutely, or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) sales or production, or both, of an article that accounted for not less than 25 percent of the total production or sales of the firm during the 12-month period preceding the most recent 12-month period for which data are available have decreased absolutely, and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) that increases of imports of articles like or directly competitive with articles produced by such firm contributed importantly to such total or partial separation, or threat thereof, and to such decline in sales or production.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For purposes of paragraph (3), the term ‘contributed importantly’ means a cause which is important but not necessarily more important than any other cause.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/s1421/b/2"},"text":"Pub. L. 100–418, § 1421(b)(2)","children":[],"tail":", directed the general amendment of subpar. (C) adding provisions relating to provision of essential goods or services by such firm, which amendment did not become effective pursuant to "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/s1430/d"},"text":"section 1430(d) of Pub. L. 100–418","children":[],"tail":", as amended, set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2397"},"text":"section 2397 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsecs. (a), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/272/s13002/b/1"},"text":"Pub. L. 99–272, § 13002(b)(1)","children":[],"tail":", inserted “(including any agricultural firm)” after “firm”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/272/s13002/b/2"},"text":"Pub. L. 99–272, § 13002(b)(2)","children":[],"tail":", amended par. (2) generally, designating existing provisions as subpar. (A), substituting “of the firm have decreased absolutely, or” for “of such firm have decreased absolutely, and”, and adding subpar. (B)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id05ce4c8e-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id05ce4c8f-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective and Termination Dates of 2015 Revival","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For revival and applicability, beginning on ","children":[{"tag":"date","attrib":{"date":"2015-06-29"},"text":"June 29, 2015","children":[],"tail":", of the provisions of this section as in effect on "},{"tag":"date","attrib":{"date":"2013-12-31"},"text":"Dec. 31, 2013","children":[],"tail":", see section 402(b), (c) of "},{"tag":"ref","attrib":{"href":"/us/pl/114/27"},"text":"Pub. L. 114–27","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2271"},"text":"section 2271 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"For reversion, beginning on ","children":[{"tag":"date","attrib":{"date":"2021-07-01"},"text":"July 1, 2021","children":[],"tail":", to the provisions of this section as in effect on "},{"tag":"date","attrib":{"date":"2014-01-01"},"text":"Jan. 1, 2014","children":[],"tail":", with certain exceptions and subject to "},{"tag":"ref","attrib":{"href":"/us/pl/114/27/s406/b"},"text":"section 406(b) of Pub. L. 114–27","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/27/s406"},"text":"section 406 of Pub. L. 114–27","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2271"},"text":"section 2271 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id05ce4c90-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective and Termination Dates of 2011 Revival","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For revival and applicability, beginning on ","children":[{"tag":"d