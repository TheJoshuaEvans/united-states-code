{"tag":"section","attrib":{"id":"id0575f34a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1671g"},"text":null,"children":[{"tag":"num","attrib":{"value":"1671g"},"text":"§ 1671g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of derogation of Export-Import Bank financing","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this subtitle shall be interpreted as superseding the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s635a–3"},"text":"section 635a–3 of title 12","children":[],"tail":", except that in the event of an assessment of duty based on a derogation under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1671e"},"text":"section 1671e of this title","children":[],"tail":" or action under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1671b/d/1/B"},"text":"section 1671b(d)(1)(B) of this title","children":[],"tail":", the Secretary of the Treasury shall not authorize the Bank to provide guarantees, insurance and credits to competing United States sellers pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s635a–3"},"text":"section 635a–3 of title 12","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0575f34b-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title VII, § 708, as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/181/tI"},"text":"Pub. L. 98–181, title I","children":[],"tail":" [title VI, § 650(c)], "},{"tag":"date","attrib":{"date":"1983-11-30"},"text":"Nov. 30, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1266"},"text":"97 Stat. 1266","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXVIII/s1886/a/6/A"},"text":"Pub. L. 99–514, title XVIII, § 1886(a)(6)(A)","children":[],"tail":", "},{"tag":"da