{"tag":"section","attrib":{"id":"id05465758-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1497"},"text":null,"children":[{"tag":"num","attrib":{"value":"1497"},"text":"§ 1497.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties for failure to declare","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05465759-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1497/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0546575a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1497/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any article which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0546575b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1497/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not included in the declaration and entry as made or transmitted; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0546575c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1497/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is not mentioned before examination of the baggage begins—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0546575d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1497/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in writing by such person, if written declaration and entry was required, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0546575e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1497/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" orally, if written declaration and entry was not required;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be subject to forfeiture and such person shall be liable for a penalty determined under paragraph (2) with respect to such article.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0546575f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1497/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The amount of the penalty imposed under paragraph (1) with respect to any article is equal to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05465760-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1497/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the article is a controlled substance, either $500 or an amount equal to 1,000 percent of the value of the article, whichever amount is greater; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05465761-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1497/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the article is not a controlled substance, the value of the article.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05465762-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1497/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Value of controlled substances","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05465763-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1497/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of this chapter, the value of any controlled substance shall, for purposes of this section, be equal to the amount determined by the Secretary in consultation with the Attorney General of the United States, to be equal to the price at which such controlled substance is likely to be illegally sold to the consumer of such controlled substance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05465764-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1497/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary and the Attorney General of the United States shall establish a method of determining the price at which each controlled substance is likely to be illegally sold to the consumer of such controlled substance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05465765-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title IV, § 497, "},{"tag":"ref","attrib":{"href":"/us/stat/46/728"},"text":"46 Stat. 728","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/570/tIII/s3116"},"text":"Pub. L. 99–570, title III, § 3116","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-83"},"text":"100 Stat. 3207–83","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII/s7367/a"},"text":"Pub. L. 100–690, title VII, § 7367(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4479"},"text":"102 Stat. 4479","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/182/tVI/s612"},"text":"Pub. L. 103–182, title VI, § 612","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-08"},"text":"Dec. 8, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2170"},"text":"107 Stat. 2170","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05465766-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05465767-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id05465768-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-09-21/ch356/tIV/s497"},"text":"act Sept. 21, 1922, ch. 356, title IV, § 497","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/964"},"text":"42 Stat. 964","children":[],"tail":". That section was superseded by section 497 of act "},{"tag":"date","attrib":{"date":"1930-06-17"},"text":"June 17, 1930","children":[],"tail":", comprising this section, and repealed by section 651(a)(1) of the 1930 act."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior provision for forfeiture of any article subject to duty found in baggage, and not mentioned to the collector before whom entry was made, and for a penalty of treble the value of the article, was contained in R.S. § 2802, prior to repeal by ","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-09-21/ch356/tIV/s642"},"text":"act Sept. 21, 1922, ch. 356, title IV, § 642","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/989"},"text":"42 Stat. 989","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id05465769-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/182/s612/1"},"text":"Pub. L. 103–182, § 612(1)","children":[],"tail":", inserted “or transmitted” after “made”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/182/s612/2"},"text":"Pub. L. 103–182, § 612(2)","children":[],"tail":", amended subpar. (A) generally. Prior to amendment, subpar. (A) read as follows: “if the article is a controlled substance, 1,000 percent of the value of the article; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" substituted “1,000 percent” for “200 percent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570"},"text":"Pub. L. 99–570","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “Any article not included in the declaration and entry as made, and, before examination of the baggage was begun, not mentioned in writing by such person, if written declaration and entry was required, or orally if written declaration and entry was not required, shall be subject to forfeiture and such person shall be liable to a penalty equal to the value of such article.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
