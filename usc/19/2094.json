{"tag":"section","attrib":{"id":"id059c18d6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2094"},"text":null,"children":[{"tag":"num","attrib":{"value":"2094"},"text":"§ 2094.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe such rules and regulations as are necessary and appropriate to carry out the provisions of this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id059c18d7-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/587/tII/s204"},"text":"Pub. L. 92–587, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-27"},"text":"Oct. 27, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1297"},"text":"86 Stat. 1297","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
