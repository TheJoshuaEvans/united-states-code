{"tag":"section","attrib":{"id":"id05ce4cb7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2344"},"text":null,"children":[{"tag":"num","attrib":{"value":"2344"},"text":"§ 2344.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05ce4cb8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2344/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direct loans and guarantees of loans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide to a firm, on such terms and conditions as he determines to be appropriate, such financial assistance in the form of direct loans or guarantees of loans as in his judgment will materially contribute to the economic adjustment of the firm. The assumption of an outstanding indebtedness of the firm, with or without recourse, shall be considered to be the making of a loan for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05ce4cb9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2344/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowable purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Loans or guarantees of loans shall be made under this part only for the purpose of making funds available to the firm—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05ce4cba-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2344/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for acquisition, construction, installation, modernization, development, conversion, or expansion of land, plant, buildings, equipment, facilities, or machinery, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05ce4cbb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2344/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to supply such working capital as may be necessary to enable the firm to implement its adjustment proposal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05ce4cbc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2344/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on direct loans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No direct loan may be provided to a firm under this part if the firm can obtain loan funds from private sources (with or without a guarantee) at a rate no higher than the maximum interest per annum that a participating financial institution may establish on guaranteed loans made pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s636/a"},"text":"section 636(a) of title 15","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05ce4cbd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2344/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on loans and guarantees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this part, no direct loans or guarantees of loans may be made under this part after ","children":[{"tag":"date","attrib":{"date":"1986-04-07"},"text":"April 7, 1986","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05ce4cbe-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/tII/s254"},"text":"Pub. L. 93–618, title II, § 254","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2031"},"text":"88 Stat. 2031","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXXV/s2522"},"text":"Pub. L. 97–35, title XXV, § 2522","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/891"},"text":"95 Stat. 891","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/272/tXIII/s13006/b"},"text":"Pub. L. 99–272, title XIII, § 13006(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-04-07"},"text":"Apr. 7, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/304"},"text":"100 Stat. 304","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05ce4cbf-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id05ce4cc0-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Assistance","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination of assistance under this part after ","children":[{"tag":"date","attrib":{"date":"2022-06-30"},"text":"June 30, 2022","children":[],"tail":", see Termination Date note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05ce4cc1-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id05ce4cc2-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section reflects the ","children":[{"tag":"date","attrib":{"date":"2021-07-01"},"text":"July 1, 2021","children":[],"tail":", reversion to provisions in effect on "},{"tag":"date","attrib":{"date":"2014-01-01"},"text":"Jan. 1, 2014","children":[],"tail":". See Effective and Termination Dates note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id05ce4cc3-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2344, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/tII/s254"},"text":"Pub. L. 93–618, title II, § 254","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/5/dB/tI/s1864/a/3"},"text":"Pub. L. 111–5, div. B, title I, § 1864(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/397"},"text":"123 Stat. 397","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/112/40/tII/s201/b"},"text":"Pub. L. 112–40, title II, § 201(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2011-10-21"},"text":"Oct. 21, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/403"},"text":"125 Stat. 403","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/114/27/tIV/s402/b"},"text":"Pub. L. 114–27, title IV, § 402(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2015-06-29"},"text":"June 29, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/374"},"text":"129 Stat. 374","children":[],"tail":", ceased to be effective after the reversion, effective "},{"tag":"date","attrib":{"date":"2021-07-01"},"text":"July 1, 2021","children":[],"tail":", of this section to provisions in effect on "},{"tag":"date","attrib":{"date":"2014-01-01"},"text":"Jan. 1, 2014","children":[],"tail":", pursuant to "},{"tag":"ref","attrib":{"href":"/us/pl/114/27/s406"},"text":"section 406 of Pub. L. 114–27","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2271"},"text":"section 2271 of this title","children":[],"tail":". Prior to reversion, section 2344 read as follows:"},{"tag":"quotedContent","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"“§ 2344. Oversight and administration","children":[],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall, to such extent and in such amounts as are provided in appropriations Acts, provide grants to intermediary organizations (referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2343/b/1"},"text":"section 2343(b)(1) of this title","children":[],"tail":") throughout the United States pursuant to agreements with such intermediary organizations. Each such agreement shall require the intermediary organization to provide benefits to firms certified under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2341"},"text":"section 2341 of this title","children":[],"tail":". The Secretary shall, to the maximum extent practicable, provide by "},{"tag":"date","attrib":{"date":"2010-10-01"},"text":"October 1, 2010","children":[],"tail":", that contracts entered into with intermediary organizations be for a 12-month period and that all such contracts have the same beginning date and the same ending date."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Distribution of Funds.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2009-02-17"},"text":"February 17, 2009","children":[],"tail":", the Secretary shall develop a methodology for the distribution of funds among the intermediary organizations described in subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prompt initial distribution","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The methodology described in paragraph (1) shall ensure the prompt initial distribution of funds and establish additional criteria governing the apportionment and distribution of the remainder of such funds among the intermediary organizations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criteria","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The methodology described in paragraph (1) shall include criteria based on the data in the annual report on the trade adjustment assistance for firms program described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2356"},"text":"section 2356 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements for Contracts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An agreement with an intermediary organization described in subsection (a) shall require the intermediary organization to contract for the supply of services to carry out grants under this part in accordance with terms and conditions that are consistent with guidelines established by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultations regarding methodology","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall consult with the Committee on Finance of the Senate and the Committee on Ways and Means of the House of Representatives—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 30 days before finalizing the methodology described in subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 60 days before adopting any changes to such methodology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultations regarding guidelines","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall consult with the Committee on Finance of the Senate and the Committee on Ways and Means of the House of Representatives not less than 60 days before finalizing the guidelines described in subsection (c) or adopting any subsequent changes to such guidelines.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id05ce4cc4-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/272"},"text":"Pub. L. 99–272","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":" substituted provisions relating to limitation on direct loans on the basis of interest rates on loans under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s636/a"},"text":"section 636(a) of title 15","children":[],"tail":" for provisions relating to limitation on direct loans on the basis of interest rates under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2345/b"},"text":"section 2345(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id05ce4cc5-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id05ce4cc6-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1981 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", except as otherwise provided with respect to applications for adjustment assistance, see "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/s2529"},"text":"section 2529 of Pub. L. 97–35","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2343"},"text":"section 2343 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"terminationDate","id":"id05ce4cc7-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Except as otherwise provided, technical assistance and grants may not be provided under this part after ","children":[{"tag":"date","attrib":{"date":"2022-06-30"},"text":"June 30, 2022","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/618/s285"},"text":"section 285 of Pub. L. 93–618","children":[],"tail":", as modified by "},{"tag":"ref","attrib":{"href":"/us/pl/114/27/s406/a/7"},"text":"section 406(a)(7) of Pub. L. 114–27","children":[],"tail":", set out as notes preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2271"},"text":"section 2271 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id05ce4cc8-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Residual Authority","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5/dB/tI/s1864/b"},"text":"Pub. L. 111–5, div. B, title I, § 1864(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/398"},"text":"123 Stat. 398","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/5/dB/tI/s1864/b"},"text":"“The Secretary of Commerce shall have the authority to modify, terminate, resolve, liquidate, or take any other action with respect to a loan, guarantee, contract, or any other financial assistance that was extended under section 254, 255, 256, or 257 of the Trade Act of 1974 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2344"},"text":"19 U.S.C. 2344","children":[],"tail":", 2345, 2346, and 2347), as in effect on the day before the effective date set forth in section 1891 [set out as an Effective and Termination Dates of 2009 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2271"},"text":"section 2271 of this title","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
