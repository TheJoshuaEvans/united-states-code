{"tag":"section","attrib":{"id":"id050d1e70-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s60"},"text":null,"children":[{"tag":"num","attrib":{"value":"60"},"text":"§ 60.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty for extortion","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Every officer of the customs who demands or receives any other or greater fee, compensation, or reward than is allowed by law, for performing any duty or service required from him by law, shall be liable to a penalty of $200 for each offense, recoverable to the use of the party aggrieved.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id050d1e71-3a70-11f1-8ace-823fb135378d"},"text":"(R.S. § 2636.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id050d1e72-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id050d1e73-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id050d1e74-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 2636 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1799-03-02/ch22/s73"},"text":"act Mar. 2, 1799, ch. 22, § 73","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/1/680"},"text":"1 Stat. 680","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
