{"tag":"section","attrib":{"id":"id05f200ba-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2576"},"text":null,"children":[{"tag":"num","attrib":{"value":"2576"},"text":"§ 2576.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05f200bb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2576/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No bar to engaging in standards activity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this subpart shall be construed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05f200bc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2576/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prohibit a Federal agency from engaging in activity related to standards-related measures, including any such measure relating to safety, the protection of human, animal, or plant life or health, the environment or consumers; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f200bd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2576/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to limit the authority of a Federal agency to determine the level it considers appropriate of safety or of protection of human, animal, or plant life or health, the environment or consumers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05f200be-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2576/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This subpart does not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05f200bf-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2576/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical specifications prepared by a Federal agency for production or consumption requirements of the agency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f200c0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2576/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sanitary or phytosanitary measures under subpart 1.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05f200c1-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39/tIV/s471"},"text":"Pub. L. 96–39, title IV, § 471","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/182/tIII/s351/a"},"text":"Pub. L. 103–182, title III, § 351(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-08"},"text":"Dec. 8, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2120"},"text":"107 Stat. 2120","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
