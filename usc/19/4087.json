{"tag":"section","attrib":{"id":"id064307cf-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4087"},"text":null,"children":[{"tag":"num","attrib":{"value":"4087"},"text":"§ 4087.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For purposes of section 123 of the Trade Act of 1974 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2133"},"text":"19 U.S.C. 2133","children":[],"tail":"), any import relief provided by the President under this part shall be treated as action taken under chapter 1 of title II of that Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2251"},"text":"19 U.S.C. 2251","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id064307d0-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/53/tIII/s327"},"text":"Pub. L. 109–53, title III, § 327","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-02"},"text":"Aug. 2, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/494"},"text":"119 Stat. 494","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id064307d1-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id064307d2-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination of section by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/53/s107/d"},"text":"section 107(d) of Pub. L. 109–53","children":[],"tail":", see Effective and Termination Dates note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id064307d3-3a70-11f1-8ace-823fb135378d"},"text":null,"chi