{"tag":"section","attrib":{"id":"id0610fa55-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3532"},"text":null,"children":[{"tag":"num","attrib":{"value":"3532"},"text":"§ 3532.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation of Uruguay Round Agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0610fa56-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3532/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Decisionmaking","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the implementation of the Uruguay Round Agreements and the functioning of the World Trade Organization, it is the objective of the United States to ensure that the Ministerial Conference and the General Council continue the practice of decisionmaking by consensus followed under the GATT 1947, as required by paragraph 1 of article IX of the WTO Agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0610fa57-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3532/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultations with congressional committees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In furtherance of the objective set forth in subsection (a), the Trade Representative shall consult with the appropriate congressional committees before any vote is taken by the Ministerial Conference or the General Council relating to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0610fa58-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3532/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adoption of an interpretation of the WTO Agreement or another multilateral trade agreement,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0610fa59-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3532/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amendment of any such agreement,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0610fa5a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3532/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the granting of a waiver of any obligation under any such agreement,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0610fa5b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3532/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adoption of any amendment to the rules or procedures of the Ministerial Conference or the General Council,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0610fa5c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3532/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the accession of a state or separate customs territory to the WTO Agreement, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0610fa5d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3532/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adoption of any other decision,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"if the action described in paragraph (1), (2), (3), (4), (5), or (6) would substantially affect the rights or obligations of the United States under the WTO Agreement or another multilateral trade agreement or potentially entails a change in Federal or State law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0610fa5e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3532/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on decisions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0610fa5f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3532/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 30 days after the end of any calendar year in which the Ministerial Conference or the General Council adopts by vote any decision to take any action described in paragraph (1), (2), (4), or (6) of subsection (b), the Trade Representative shall submit a report to the appropriate congressional committees describing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0610fa60-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3532/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature of the decision;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0610fa61-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3532/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the efforts made by the United States to have the matter decided by consensus pursuant to paragraph 1 of article IX of the WTO Agreement, and the results of those efforts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0610fa62-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3532/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which countries voted for, and which countries voted against, the decision;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0610fa63-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3532/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rights or obligations of the United States affected by the decision and any Federal or State law that would be amended or repealed, if the President after consultation with the Congress determined that such amendment or repeal was an appropriate response; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0610fa64-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3532/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the action the President intends to take in response to the decision or, if the President does not intend to take any action, the reasons therefor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0610fa65-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3532/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional reporting requirements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0610fa66-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3532/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant of waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a decision to grant a waiver described in subsection (b)(3), the report under paragraph (1) shall describe the terms and conditions of the waiver and the rights and obligations of the United States that are affected by the waiver.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0610fa67-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3532/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accession","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a decision on accession described in subsection (b)(5), the report under paragraph (1) shall state whether the United States intends to invoke Article XIII of the WTO Agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0610fa68-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3532/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation on report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Promptly after the submission of a report under subsection (c), the Trade Representative shall consult with the appropriate congressional committees with respect to the report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0610fa69-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/tI/s122"},"text":"Pub. L. 103–465, title I, § 122","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4829"},"text":"108 Stat. 4829","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0610fa6a-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0610fa6b-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0610fa6c-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date on which the WTO Agreement enters into force with respect to the United States (","children":[{"tag":"date","attrib":{"date":"1995-01-01"},"text":"Jan. 1, 1995","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/s130"},"text":"section 130 of Pub. L. 103–465","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3531"},"text":"section 3531 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
