{"tag":"section","attrib":{"id":"id058de851-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683f"},"text":null,"children":[{"tag":"num","attrib":{"value":"1683f"},"text":"§ 1683f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id058de852-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall be unlawful for any person to import into the United States softwood lumber or softwood lumber products in knowing violation of this subtitle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id058de853-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who commits an unlawful act as set forth in subsection (a) shall be liable for a civil penalty not to exceed $10,000 for each knowing violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id058de854-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to the penalties provided for in subsection (b), any violation of this subtitle that violates any other customs law of the United States shall be subject to any applicable civil and criminal penalty, including seizure and forfeiture, that may be imposed under such custom law or title 18, with respect to the importation of softwood lumber and softwood lumber products described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1683b/a"},"text":"section 1683b(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id058de855-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683f/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors to consider in assessing penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In determining the amount of civil penalties to be assessed under this section, consideration shall be given to any history of prior violations of this subtitle by the person, the ability of the person to pay the penalty, the seriousness of the violation, and such other matters as fairness may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id058de856-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683f/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No penalty may be assessed under this section against a person for violating a provision of this subtitle unless the person is given notice and opportunity to make statements, both oral and written, with respect to such violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id058de857-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683f/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of this subtitle, and without limitation, an importer shall not be found to have violated subsection ","children":[{"tag":"ref","attrib":{"idref":"fn002060"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002060"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “section”."}],"tail":" 1683a(c) of this title if—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id058de858-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683f/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the importer made an appropriate inquiry in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1683a/c/1"},"text":"section 1683a(c)(1) of this title","children":[],"tail":" with respect to the declaration;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id058de859-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683f/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the importer produces records maintained pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1683e/b"},"text":"section 1683e(b) of this title","children":[],"tail":" that substantiate the declaration; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id058de85a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683f/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is not substantial evidence indicating that the importer knew that the fact to which the importer made the declaration was false.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id058de85b-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title VIII, § 808, as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/tIII/s3301/a"},"text":"Pub. L. 110–246, title III, § 3301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1852"},"text":"122 Stat. 1852","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id058de85c-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id058de85d-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id058de85e-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1683a"},"text":"Section 1683a of this title","children":[],"tail":", referred to in subsec. (f), was in the original section “803”, and was translated as meaning the section 803 of act "},{"tag":"date","attrib":{"date":"1930-06-17"},"text":"June 17, 1930","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s3301/a"},"text":"section 3301(a) of Pub. L. 110–246","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id058de85f-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id058de860-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 60 days after ","children":[{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s3301/b"},"text":"section 3301(b) of Pub. L. 110–246","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1683"},"text":"section 1683 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
