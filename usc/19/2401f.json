{"tag":"section","attrib":{"id":"id05d578b0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401f"},"text":null,"children":[{"tag":"num","attrib":{"value":"2401f"},"text":"§ 2401f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fraud and recovery of overpayments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05d578b1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05d578b2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401f/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary, or a court of competent jurisdiction, determines that any person has received any payment under this part to which the person was not entitled, such person shall be liable to repay such amount to the Secretary, except that the Secretary may waive such repayment if the Secretary determines, in accordance with guidelines prescribed by the Secretary, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05d578b3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401f/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the payment was made without fault on the part of such person; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05d578b4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401f/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requiring such repayment would be contrary to equity and good conscience.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05d578b5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401f/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery of overpayment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Unless an overpayment is otherwise recovered, or waived under paragraph (1), the Secretary shall recover the overpayment by deductions from any sums payable to such person under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05d578b6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" False statement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person shall, in addition to any other penalty provided by law, be ineligible for any further payments under this part—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05d578b7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401f/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the Secretary, or a court of competent jurisdiction, determines that the person—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05d578b8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401f/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly has made, or caused another to make, a false statement or representation of a material fact; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05d578b9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401f/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly has failed, or caused another to fail, to disclose a material fact; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05d578ba-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401f/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a result of such false statement or representation, or of such nondisclosure, such person has received any payment under this part to which the person was not entitled.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05d578bb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice and determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except for overpayments determined by a court of competent jurisdiction, no repayment may be required, and no deduction may be made, under this section until a determination under subsection (a)(1) by the Secretary has been made, notice of the determination and an opportunity for a fair hearing thereon has been given to the person concerned, and the determination has become final.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05d578bc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401f/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment to Treasury","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amount recovered under this section shall be returned to the Treasury of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05d578bd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2401f/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whoever makes a false statement of a material fact knowing it to be false, or knowingly fails to disclose a material fact, for the purpose of obtaining or increasing for himself or for any other person any payment authorized to be furnished under this part shall be fined not more than $10,000 or imprisoned for not more than 1 year, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05d578be-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/tII/s297"},"text":"Pub. L. 93–618, title II, § 297","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/210/dA/tI/s141/a"},"text":"Pub. L. 107–210, div. A, title I, § 141(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-06"},"text":"Aug. 6, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/952"},"text":"116 Stat. 952","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/5/dB/tI/s1885"},"text":"Pub. L. 111–5, div. B, title I, § 1885","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/419"},"text":"123 Stat. 419","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/40/tII/s201/b"},"text":"Pub. L. 112–40, title II, § 201