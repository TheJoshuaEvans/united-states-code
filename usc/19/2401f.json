:", and that this section be applied and administered beginning "},{"tag":"date","attrib":{"date":"2011-02-13"},"text":"Feb. 13, 2011","children":[],"tail":", as if amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/111/5"},"text":"Pub. L. 111–5","children":[],"tail":" had never been enacted, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/112/40/tII/s201/a"},"text":"Pub. L. 112–40, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-10-21"},"text":"Oct. 21, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/403"},"text":"125 Stat. 403","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"2011-10-21"},"text":"Oct. 21, 2011","children":[],"tail":". See Codification note above."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"terminationDate","id":"id05d7c1b8-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Except as otherwise provided, technical assistance and financial assistance may not be provided under this part after ","children":[{"tag":"date","attrib":{"date":"2022-06-30"},"text":"June 30, 2022","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/618/s285"},"text":"section 285 of Pub. L. 93–618","children":[],"tail":", as modified by "},{"tag":"ref","attrib":{"href":"/us/pl/114/27/s406/a/7"},"text":"section 406(a)(7) of Pub. L. 114–27","children":[],"tail":", set out as notes preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2271"},"text":"section 2271 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
