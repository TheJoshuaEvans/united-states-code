{"tag":"section","attrib":{"id":"id065d45cf-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4643"},"text":null,"children":[{"tag":"num","attrib":{"value":"4643"},"text":"§ 4643.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement priorities","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Interagency Labor Committee shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id065d45d0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4643/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the list of priority sectors under Annex 31–A of the USMCA and suggest to USTR additional sectors for review by the USMCA countries as appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065d45d1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4643/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish and annually update a list of priority subsectors within such priority sectors to be the focus of the enforcement efforts of the Committee, the first of which shall consist of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id065d45d2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4643/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" auto assembly;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id065d45d3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4643/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" auto parts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id065d45d4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4643/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aerospace;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id065d45d5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4643/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" industrial bakeries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id065d45d6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4643/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" electronics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id065d45d7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4643/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" call centers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id065d45d8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4643/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mining; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id065d45d9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4643/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" steel and aluminum; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065d45da-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4643/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"