{"tag":"section","attrib":{"id":"id05144b94-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s293"},"text":null,"children":[{"tag":"num","attrib":{"value":"293"},"text":"§ 293.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Documented vessels touching at foreign ports","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any United States documented vessel with a registry or coastwise endorsement, or both, may engage in trade between one port in the United States and one or more ports within the same, with the privilege of touching at one or more foreign ports during the voyage, and land and take in thereat merchandise, passengers and their baggage, and letters, and mails.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id05144b95-3a70-11f1-8ace-823fb135378d"},"text":"(R.S. § 3126; ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/271/tIII/s318"},"text":"Pub. L. 91–271, title III, § 318","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-06-02"},"text":"June 2, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/293"},"text":"84 Stat. 293","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/182/tVI/s686/a/2"},"text":"Pub. L. 103–182, title VI, § 686(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-08"},"text":"Dec. 8, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2220"},"text":"107 Stat. 2220","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/295/s21/e/1"},"text":"Pub. L. 104–295, § 21(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3530"},"text":"110 Stat. 3530","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05144b96-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05144b97-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id05144b98-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 3126 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1848-05-27/ch48/s1"},"text":"act May 27, 1848, ch. 48, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/9/232"},"text":"9 Stat. 232","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id05144b99-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/295"},"text":"Pub. L. 104–295","children":[],"tail":" inserted comma after “or both”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/182"},"text":"Pub. L. 103–182","children":[],"tail":" substituted “Any United States documented vessel with a registry or coastwise endorsement, or both” for “Any vessel, on being duly registered in pursuance of the laws of the United States,” and struck out at end “All such vessels shall be furnished by the appropriate customs officers of the ports at which they shall take in their cargoes in the United States, with certified manifests, setting forth the particulars of the cargoes, the marks, number of packages, by whom shipped, to whom consigned, at what port to be delivered; designating such merchandise as is entitled to drawback, or to the privilege of being placed in warehouse; and the masters of all such vessels shall, on their arrival at any port of the United States from any foreign port at which such vessel may have touched, as herein provided, conform to the laws providing for the delivery of manifests of cargo and passengers taken on board at such foreign port, and all other laws regulating the report and entry of vessels from foreign ports, and be subject to all the penalties therein prescribed.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/271"},"text":"Pub. L. 91–271","children":[],"tail":" substituted reference to appropriate customs officers for reference to collectors."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id05144b9a-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id05144b9b-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1970 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/271"},"text":"Pub. L. 91–271","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/271/s203"},"text":"section 203 of Pub. L. 91–271","children":[],"tail":", set out as an Effective Date of 1970 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1500"},"text":"section 1500 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
