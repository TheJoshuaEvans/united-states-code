{"tag":"section","attrib":{"id":"id065d45bb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4642"},"text":null,"children":[{"tag":"num","attrib":{"value":"4642"},"text":"§ 4642.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The duties of the Interagency Labor Committee shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id065d45bc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4642/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Coordinating the activities of departments and agencies of the Committee in monitoring implementation of and compliance with labor obligations, including by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id065d45bd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4642/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requesting and reviewing relevant information from the governments of USMCA countries and from the public;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id065d45be-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4642/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinating visits to Mexico as necessary to assess implementation of Mexico’s labor reform and compliance with the labor obligations of Mexico;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id065d45bf-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4642/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receiving and reviewing quarterly assessments from the labor attachés with respect to the implementation of and compliance with Mexico’s labor reform; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id065d45c0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4642/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinating with the Secretary of Treasury with respect to support relating to labor issues provided to Mexico by the Inter-American Development Bank.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065d45c1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4642/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Establishing an ongoing dialogue with appropriate officials of the Government of Mexico regarding the implementation of Mexico’s labor reform and compliance with its labor obligations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065d45c2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4642/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Coordinating with other institutions and governments with respect to support relating to labor issues, such as the International Labour Organization and the Government of Canada.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065d45c3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4642/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Identifying priority issues for capacity-building activities in Mexico to be funded by the United States, drawing primarily on the expertise of the Department of Labor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065d45c4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4642/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Meeting, at least biannually during the 5-year period beginning on ","children":[{"tag":"date","attrib":{"date":"2020-01-29"},"text":"January 29, 2020","children":[],"tail":", and at least annually for 5 years thereafter, with the Labor Advisory Committee for Trade Negotiations and Trade Policy established under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2155/c/1"},"text":"section 2155(c)(1) of this title","children":[],"tail":" (or any successor advisory committee) to consult and provide opportunities for input with respect to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id065d45c5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4642/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the implementation of Mexico’s labor reform;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id065d45c6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4642/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" labor capacity-building activities in Mexico funded by the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id065d45c7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4642/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" labor monitoring efforts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id065d45c8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4642/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" labor enforcement priorities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id065d45c9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4642/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other relevant issues.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065d45ca-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4642/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Based on the assessments required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4644"},"text":"section 4644 of this title","children":[],"tail":", making recommendations relating to dispute settlement actions to the Trade Representative, in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s4645"},"text":"section 4645 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065d45cb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4642/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Based on reports provided by the Forced Labor Enforcement Task Force under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4683"},"text":"section 4683 of this title","children":[],"tail":", developing recommendations for appropriate enforcement actions by the Trade Representative."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065d45cc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4642/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reviewing reports submitted by the labor experts appointed in accordance with Annex 31–A of the USMCA, with respect to the functioning of that Annex.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065d45cd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4642/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reviewing reports submitted by the Independent Mexico Labor Expert Board under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4674"},"text":"section 4674 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id065d45ce-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113/tVII/s712"},"text":"Pub. L. 116–113, title VII, § 712","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-01-29"},"text":"Jan. 29, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/81"},"text":"134 Stat. 81","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
