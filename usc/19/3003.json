{"tag":"section","attrib":{"id":"id06051369-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3003"},"text":null,"children":[{"tag":"num","attrib":{"value":"3003"},"text":"§ 3003.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional approval of United States accession to the Convention","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0605136a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3003/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional approval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Congress approves the accession by the United States of America to the Convention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0605136b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3003/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance of final legal text of Convention by President","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President may accept for the United States the final legal instruments embodying the Convention. The President shall submit a copy of each final instrument to the Congress on the date it becomes available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0605136c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3003/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unspecified private remedies not created","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Neither the entry into force with respect to the United States of the Convention nor the enactment of this chapter may be construed as creating any private right of action or remedy for which provision is not explicitly made under this chapter or under other laws of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0605136d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3003/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2135/a"},"text":"section 2135(a) of this title","children":[],"tail":" do not apply to the Convention."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0605136e-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/tI/s1203"},"text":"Pub. L. 100–418, title I, § 1203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1148"},"text":"102 Stat. 1148","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0605136f-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id06051370-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id06051371-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (c), was in the original “this subtitle”, meaning subtitle B (§§ 1201 to 1217) of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418"},"text":"Pub. L. 100–418","children":[],"tail":", which is classified principally to this chapter. For complete classification of this subtitle to the Code, see References in Text note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3001"},"text":"section 3001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
