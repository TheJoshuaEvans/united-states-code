{"tag":"section","attrib":{"id":"id05ce4c93-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2342"},"text":null,"children":[{"tag":"num","attrib":{"value":"2342"},"text":"§ 2342.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of adjustment proposals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05ce4c94-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2342/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application for adjustment assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A firm certified under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2341"},"text":"section 2341 of this title","children":[],"tail":" as eligible to apply for adjustment assistance may, at any time within 2 years after the date of such certification, file an application with the Secretary for adjustment assistance under this part. Such application shall include a proposal for the economic adjustment of such firm."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05ce4c95-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2342/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05ce4c96-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2342/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Adjustment assistance under this part consists of technical assistance. The Secretary shall approve a firm’s application for adjustment assistance only if the Secretary determines that the firm’s adjustment proposal—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05ce4c97-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2342/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is reasonably calculated to materially contribute to the economic adjustment of the firm,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05ce4c98-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2342/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gives adequate consideration to the interests of the workers of such firm, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05ce4c99-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2342/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrates that the firm will make all reasonable efforts to use its own resources for economic development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05ce4c9a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2342/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall make a determination as soon as possible after the date on which an application is filed under this section, but in no event later than 60 days after such date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05ce4c9b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2342/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of certification of eligibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever the Secretary determines that any firm no longer requires assistance under this part, he shall terminate the certification of eligibility of such firm and promptly have notice of such termination published in the Federal Register. Such termination shall take effect on the termination date specified by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05ce4c9c-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/tII/s252"},"text":"Pub. L. 93–618, title II, § 252","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2030"},"text":"88 Stat. 2030","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/272/tXIII/s13006/a/1"},"text":"Pub. L. 99–272, title XIII, § 13006(a)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"1986-04-07"},"text":"Apr. 7, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/304"},"text":"100 Stat. 304","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05ce4c9d-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05ce4c9e-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id05ce4c9f-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/272/s13006/a/1"},"text":"Pub. L. 99–272, § 13006(a)(1)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) read as follows: “Adjustment assistance under this part consists of technical assistance and financial assistance, which may be furnished singly or in combination. The Secretary shall approve a firm’s application for adjustment assistance only if he determines—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) that the firm has no reasonable access to financing through the private capital market, and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) that the firm’s adjustment proposal—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) is reasonably calculated materially to contribute to the economic adjustment of the firm,","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) gives adequate consideration to the interests of the workers of such firm, and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(iii) demonstrates that the firm will make all reasonable efforts to use its own resources for economic development.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/272/s13006/a/2"},"text":"Pub. L. 99–272, § 13006(a)(2)","children":[],"tail":", redesignated subsec. (d) as (c) and struck out former subsec. (c) which authorized the Secretary to assist an eligible firm in the preparation of a viable adjustment proposal."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id05ce4ca0-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"terminationDate","id":"id05ce4ca1-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Except as otherwise provided, technical assistance and grants may not be provided under this part after ","children":[{"tag":"date","attrib":{"date":"2022-06-30"},"text":"June 30, 2022","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/618/s285"},"text":"section 285 of Pub. L. 93–618","children":[],"tail":", as modified by "},{"tag":"ref","attrib":{"href":"/us/pl/114/27/s406/a/7"},"text":"section 406(a)(7) of Pub. L. 114–27","children":[],"tail":", set out as notes preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2271"},"text":"section 2271 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
