{"tag":"section","attrib":{"id":"id065fb6a0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4713"},"text":null,"children":[{"tag":"num","attrib":{"value":"4713"},"text":"§ 4713.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring actions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id065fb6a1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4713/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Interagency Environment Committee shall carry out monitoring actions, which shall include the monitoring actions described in subsections (b), (c), and (d), with respect to the implementation and maintenance of the environmental obligations of the USMCA countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id065fb6a2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4713/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of CEC Secretariat submissions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id065fb6a3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4713/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 30 days after the date on which the Secretariat of the Commission for Environmental Cooperation prepares a factual record under article 24.28 of the USMCA relating to a submission filed under article 24.27 of the USMCA with respect to a USMCA country, the Interagency Environment Committee—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id065fb6a4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4713/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall review the factual record; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id065fb6a5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4713/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may, based on findings of the review under subparagraph (A) that the USMCA country is not in compliance with its environmental obligations, request enforcement actions under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4714"},"text":"section 4714 of this title","children":[],"tail":" with respect to the USMCA country."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065fb6a6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4713/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Written justification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Interagency Environment Committee finds that a USMCA country is not in compliance with its environmental obligations under paragraph (1)(B) and determines not to request enforcement actions under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4714"},"text":"section 4714 of this title","children":[],"tail":" with respect to the USMCA country, the Committee shall, not later than 30 days after the date on which it makes the determination, provide to the appropriate congressional committees a written explanation and justification of the determination."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id065fb6a7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4713/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of reports of United States environment attachés to Mexico","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Interagency Environment Committee shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id065fb6a8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4713/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review each report submitted to the Committee under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4732/b/2"},"text":"section 4732(b)(2) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065fb6a9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4713/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" based on the findings of each such report, assess the efforts of Mexico to comply with its environmental obligations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id065fb6aa-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4713/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States implementation of Environment Cooperation and Customs Verification Agreement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id065fb6ab-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4713/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Verification of shipments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Interagency Environment Committee—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id065fb6ac-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4713/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may request verification of particular shipments of Mexico under the Environment Cooperation and Customs Verification Agreement between the United States and Mexico, done at Mexico City on ","children":[{"tag":"date","attrib":{"date":"2019-12-10"},"text":"December 10, 2019","children":[],"tail":", in response to—"}],"tail":null},{"tag":"clause","attrib":{"id":"id065fb6ad-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4713/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comments submitted by the public to request verification of particular shipments of Mexico under such Agreement; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id065fb6ae-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4713/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on its own motion; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id065fb6af-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4713/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" upon receipt of comments described in subparagraph (A)(i)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id065fb6b0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4713/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall review the comments not later than 30 days after the date on which the comments are submitted to the Trade Representative; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id065fb6b1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4713/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may request the Trade Representative to, within a reasonable period of time, request Mexico to provide relevant information for purposes of verification of particular shipments of Mexico described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065fb6b2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4713/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of relevant information and request for additional steps","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Interagency Environment Committee—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id065fb6b3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4713/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall review relevant information provided by Mexico as described in paragraph (1)(B)(ii) to determine if the Trade Representative should request additional steps to verify information provided or related to a particular shipment of Mexico; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id065fb6b4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4713/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may request the Trade Representative to, within a reasonable period of time, request Mexico to take such additional steps with respect to the particular shipment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065fb6b5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4713/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Trade Representative, on behalf of the Interagency Environment Committee, shall, on a quarterly basis, consult with the appropriate congressional committees and the Trade and Environment Policy Advisory Committee (or successor advisory committee) established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2155/c/1"},"text":"section 2155(c)(1) of this title","children":[],"tail":" regarding the public comments and relevant information described in paragraph (1) and the actions taken under paragraph (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id065fb6b6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4713/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsections (c) and (d) shall apply with respect to Mexico for such time as the USMCA is in force with respect to, and the United States applies the USMCA to, Mexico.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id065fb6b7-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113/tVIII/s813"},"text":"Pub. L. 116–113, title VIII, § 813","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-01-29"},"text":"Jan. 29, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/92"},"text":"134 Stat. 92","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
