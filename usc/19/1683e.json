{"tag":"section","attrib":{"id":"id058de844-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683e"},"text":null,"children":[{"tag":"num","attrib":{"value":"1683e"},"text":"§ 1683e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Verification","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id058de845-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Treasury shall periodically verify the declarations made by a United States importer pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1683a/c"},"text":"section 1683a(c) of this title","children":[],"tail":", including by determining whether—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id058de846-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the export price declared by a United States importer pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1683a/b/1"},"text":"section 1683a(b)(1) of this title","children":[],"tail":" is the same as the export price provided on the export permit, if any, issued by the country of export; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id058de847-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estimated export charge declared by a United States importer pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1683a/b/2"},"text":"section 1683a(b)(2) of this title","children":[],"tail":" is consistent with the determination published by the Under Secretary for International Trade pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1683c/b"},"text":"section 1683c(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id058de848-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Examination of books and records","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id058de849-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any record relating to the importer declaration program required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1683a"},"text":"section 1683a of this title","children":[],"tail":" shall be treated as a record required to be maintained and produced under title V of this Act."},{"tag":"ref","attrib":{"idref":"fn002059"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002059"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id058de84a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Examination of records","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury is authorized to take such action, and examine such records, under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1509"},"text":"section 1509 of this title","children":[],"tail":", as the Secretary determines necessary to verify the declarations made pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1683a/c"},"text":"section 1683a(c) of this title","children":[],"tail":" are true and accurate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id058de84b-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title VIII, § 807, as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/tIII/s3301/a"},"text":"Pub. L. 110–246, title III, § 3301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1851"},"text":"122 Stat. 1851","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id058de84c-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id058de84d-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id058de84e-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 1683a, referred to in text, was in the original section “803”, and was translated as meaning the section 803 of act ","children":[{"tag":"date","attrib":{"date":"1930-06-17"},"text":"June 17, 1930","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s3301/a"},"text":"section 3301(a) of Pub. L. 110–246","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (b)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"act June 17, 1930, ch. 497","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/590"},"text":"46 Stat. 590","children":[],"tail":", known as the Tariff Act of 1930, which is classified generally to this chapter. The Act does not contain a title V. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1654"},"text":"section 1654 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id058de84f-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id058de850-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 60 days after ","children":[{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s3301/b"},"text":"section 3301(b) of Pub. L. 110–246","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1683"},"text":"section 1683 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
