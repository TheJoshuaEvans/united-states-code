{"tag":"section","attrib":{"id":"id063e4c11-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3907"},"text":null,"children":[{"tag":"num","attrib":{"value":"3907"},"text":"§ 3907.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id063e4c12-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3907/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to the enforcement provisions set forth in subsection (b)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id063e4c13-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3907/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a civil penalty of not to exceed $10,000 may be imposed on any person who violates, or attempts to violate, any license, order, or regulation issued under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id063e4c14-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3907/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whoever willfully violates, or willfully attempts to violate, any license, order, or regulation issued under this chapter shall, upon conviction, be fined not more than $50,000, or, if a natural person, may be imprisoned for not more than 10 years, or both; and any officer, director, or agent of any corporation who willfully participates in such violation may be punished by a like fine, imprisonment, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id063e4c15-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3907/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Import violations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Those customs laws of the United States, both civil and criminal, including those laws relating to seizure and forfeiture, that apply to articles imported in violation of such laws shall apply with respect to rough diamonds imported in violation of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id063e4c16-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3907/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to enforce","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States Bureau of Customs and Border Protection and the United States Bureau of Immigration and Customs Enforcement are authorized, as appropriate, to enforce the provisions of subsection (a) and to enforce the laws and regulations governing exports of rough diamonds, including with respect to the validation of the Kimberley Process Certificate by the exporting authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id063e4c17-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/19/s8"},"text":"Pub. L. 108–19, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-04-25"},"text":"Apr. 25, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/634"},"text":"117 Stat. 634","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id063e4c18-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id063e4c19-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id063e4c1a-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/19/s15"},"text":"section 15 of Pub. L. 108–19","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3901"},"text":"section 3901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
