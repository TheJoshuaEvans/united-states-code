{"tag":"section","attrib":{"id":"id055969fa-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1524"},"text":null,"children":[{"tag":"num","attrib":{"value":"1524"},"text":"§ 1524.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit of reimbursable charges","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Receipts for any reimbursable charges or expenses which have been paid for out of any appropriation for collecting the revenue from customs shall be deposited as a refund to such appropriation instead of being covered into the Treasury as miscellaneous receipts, as provided by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s527"},"text":"section 527 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id055969fb-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title IV, § 524, "},{"tag":"ref","attrib":{"href":"/us/stat/46/741"},"text":"46 Stat. 741","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch679/s19/b"},"text":"June 25, 1938, ch. 679, § 19(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/1087"},"text":"52 Stat. 1087","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id055969fc-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id055969fd-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id055969fe-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","child