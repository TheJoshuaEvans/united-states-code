{"tag":"section","attrib":{"id":"id0511d97b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s129"},"text":null,"children":[{"tag":"num","attrib":{"value":"129"},"text":"§ 129.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discriminating duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No part of the additional or discriminating duty imposed by law on merchandise on account of its importation in foreign vessels shall be allowed to be drawback, but the whole shall be retained.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0511d97c-3a70-11f1-8ace-823fb135378d"},"text":"(R.S. § 3027.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0511d97d-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0511d97e-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0511d97f-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 3027 derived from acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1800-05-13/ch64/s2"},"text":"May 13, 1800, ch. 64, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/2/83"},"text":"2 Stat. 83","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1842-08-30/ch270/s15"},"text":"Aug. 30, 1842, ch. 270, § 15","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/5/563"},"text":"5 Stat. 563","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
