{"tag":"section","attrib":{"id":"id064ca46f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4316"},"text":null,"children":[{"tag":"num","attrib":{"value":"4316"},"text":"§ 4316.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commercial Customs Operations Advisory Committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id064ca470-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4316/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than the date that is 60 days after ","children":[{"tag":"date","attrib":{"date":"2016-02-24"},"text":"February 24, 2016","children":[],"tail":", the Secretary of the Treasury and the Secretary of Homeland Security shall jointly establish a Commercial Customs Operations Advisory Committee (in this section referred to as the “Advisory Committee”)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id064ca471-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4316/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id064ca472-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4316/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Advisory Committee shall be comprised of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id064ca473-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4316/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 20 individuals appointed under paragraph (2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id064ca474-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4316/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Assistant Secretary for Tax Policy of the Department of the Treasury and the Commissioner, who shall jointly co-chair meetings of the Advisory Committee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id064ca475-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4316/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Assistant Secretary for Policy and the Director of U.S. Immigration and Customs Enforcement, who shall serve as deputy co-chairs of meetings of the Advisory Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064ca476-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4316/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id064ca477-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4316/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury and the Secretary of Homeland Security shall jointly appoint 20 individuals from the private sector to the Advisory Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id064ca478-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4316/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making appointments under subparagraph (A), the Secretary of the Treasury and the Secretary of Homeland Security shall appoint members—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id064ca479-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4316/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that the membership of the Advisory Committee is representative of the individuals and firms affected by the commercial operations of U.S. Customs and Border Protection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id064ca47a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4316/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without regard to political affiliation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id064ca47b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4316/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each individual appointed to the Advisory Committee under this paragraph shall be appointed for a term of not more than 3 years, and may be reappointed to subsequent terms, but may not serve more than 2 terms sequentially.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064ca47c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4316/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of membership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury and the Secretary of Homeland Security may transfer members serving on the Advisory Committee on Commercial Operations of the United States Customs Service established under section 9503(c) of the Omnibus Budget Reconciliation Act of 1987 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2071"},"text":"19 U.S.C. 2071","children":[],"tail":" note) "},{"tag":"ref","attrib":{"idref":"fn002170"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002170"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" on the day before "},{"tag":"date","attrib":{"date":"2016-02-24"},"text":"February 24, 2016","children":[],"tail":", to the Advisory Committee established under subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id064ca47d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4316/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Advisory Committee established under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id064ca47e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4316/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the Secretary of the Treasury and the Secretary of Homeland Security on all matters involving the commercial operations of U.S. Customs and Border Protection, including advising with respect to significant changes that are proposed with respect to regulations, policies, or practices of U.S. Customs and Border Protection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064ca47f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4316/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide recommendations to the Secretary of the Treasury and the Secretary of Homeland Security on improvements to the commercial operations of U.S. Customs and Border Protection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064ca480-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4316/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collaborate in developing the agenda for Advisory Committee meetings; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064ca481-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4316/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform such other functions relating to the commercial operations of U.S. Customs and Border Protection as prescribed by law or as the Secretary of the Treasury and the Secretary of Homeland Security jointly direct.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id064ca482-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4316/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s1009/f"},"text":"section 1009(f) of title 5","children":[],"tail":", the Advisory Committee shall meet at the call of the Secretary of the Treasury and the Secretary of Homeland Security, or at the call of not less than ⅔ of the membership of the Advisory Committee. The Advisory Committee shall meet at least 4 times each calendar year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id064ca483-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4316/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2016-12-31"},"text":"December 31, 2016","children":[],"tail":", and annually thereafter, the Advisory Committee shall submit to the Committee on Finance of the Senate and the Committee on Ways and Means of the House of Representatives a report that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id064ca484-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4316/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the activities of the Advisory Committee during the preceding fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064ca485-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4316/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sets forth any recommendations of the Advisory Committee regarding the commercial operations of U.S. Customs and Border Protection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id064ca486-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4316/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013/a"},"text":"Section 1013(a) of title 5","children":[],"tail":" shall not apply to the Advisory Committee."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id064ca487-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4316/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conforming amendment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id064ca488-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4316/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064ca489-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4316/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any reference in law to the Advisory Committee on Commercial Operations of the United States Customs Service established under section 9503(c) of the Omnibus Budget Reconciliation Act of 1987 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2071"},"text":"19 U.S.C. 2071","children":[],"tail":" note) made on or after the date on which the Advisory Committee is established under subsection (a), shall be deemed a reference to the Commercial Customs Operations Advisory Committee established under subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id064ca48a-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/125/tI/s109"},"text":"Pub. L. 114–125, title I, § 109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-24"},"text":"Feb. 24, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/136"},"text":"130 Stat. 136","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/143"},"text":"Pub. L. 117–286, § 4(a)(143)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4321"},"text":"136 Stat. 4321","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id064ca48b-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id064ca48c-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id064ca48d-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 9503(c) of the Omnibus Budget Reconciliation Act of 1987, referred to in subsecs. (b)(3) and (g)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/tIX/s9503/c"},"text":"section 9503(c) of title IX of Pub. L. 100–203","children":[],"tail":", which was set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2071"},"text":"section 2071 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/114/125/tI/s109/g/1"},"text":"Pub. L. 114–125, title I, § 109(g)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-24"},"text":"Feb. 24, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/137"},"text":"130 Stat. 137","children":[],"tail":". See Codification note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id064ca48e-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/125/s109"},"text":"section 109 of Pub. L. 114–125","children":[],"tail":". Subsec. (g)(1) of "},{"tag":"ref","attrib":{"href":"/us/pl/114/125/s109"},"text":"section 109 of Pub. L. 114–125","children":[],"tail":" repealed section 9503(c) of the Omnibus Budget Reconciliation Act of 1987 ("},{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":"), formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2071"},"text":"section 2071 of this title","children":[],"tail":", effective on the date on which the Advisory Committee was established under subsection (a) of this section. Notice of the establishment of the Advisory Committee on "},{"tag":"date","attrib":{"date":"2016-03-29"},"text":"Mar. 29, 2016","children":[],"tail":", was published at 81 F.R. 18865."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id064ca48f-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/143/A"},"text":"Pub. L. 117–286, § 4(a)(143)(A)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1009/f"},"text":"section 1009(f) of title 5","children":[],"tail":",” for “section 10(f) of the Federal Advisory Committee Act (5 U.S.C. App.),”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/143/B"},"text":"Pub. L. 117–286, § 4(a)(143)(B)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013/a"},"text":"Section 1013(a) of title 5","children":[],"tail":"” for “Section 14(a)(2) of the Federal Advisory Committee Act (5 U.S.C. App.; relating to the termination of advisory committees)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
