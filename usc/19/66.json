{"tag":"section","attrib":{"id":"id050d1e82-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s66"},"text":null,"children":[{"tag":"num","attrib":{"value":"66"},"text":"§ 66.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and forms prescribed by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury shall prescribe forms of entries, oaths, bonds, and other papers, and rules and regulations not inconsistent with law, to be used in carrying out the provisions of law relating to raising revenue from imports, or to duties on imports, or to warehousing, and shall give such directions to customs officers and prescribe such rules and forms to be observed by them as may be necessary for the proper execution of the law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id050d1e83-3a70-11f1-8ace-823fb135378d"},"text":"(R.S. § 251 (part); ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/271/tIII/s308"},"text":"Pub. L. 91–271, title III, § 308","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-06-02"},"text":"June 2, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/292"},"text":"84 Stat. 292","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id050d1e84-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id050d1e85-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id050d1e86-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 251 derived 