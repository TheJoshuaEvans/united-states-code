:"Pub. L. 91–271","children":[],"tail":" substituted reference to customs officers for reference to collectors."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id050d1e88-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id050d1e89-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1970 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/271"},"text":"Pub. L. 91–271","children":[],"tail":" effective with respect to articles entered, or withdrawn from warehouse for consumption on or after "},{"tag":"date","attrib":{"date":"1970-10-01"},"text":"Oct. 1, 1970","children":[],"tail":", and such other articles entered or withdrawn from warehouse for consumption prior to such date, or with respect to which a protest has not been disallowed in whole or in part before "},{"tag":"date","attrib":{"date":"1970-10-01"},"text":"Oct. 1, 1970","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/271/s203"},"text":"section 203 of Pub. L. 91–271","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1500"},"text":"section 1500 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id050d1e8a-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id050d1e8b-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"All offices of collector of customs, comptroller of customs, surveyor of customs, and appraiser of merchandise in Bureau of Customs of Department of the Treasury to which appointments were required to be made by President with advice and consent of Senate ordered abolished, with such offices to be terminated not later than ","children":[{"tag":"date","attrib":{"date":"1966-12-31"},"text":"December 31, 1966","children":[],"tail":", by Reorg. Plan No. 1 of 1965, eff. "},{"tag":"date","attrib":{"date":"1965-05-25"},"text":"May 25, 1965","children":[],"tail":", 30 F.R. 7035, "},{"tag":"ref","attrib":{"href":"/us/stat/79/1317"},"text":"79 Stat. 1317","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1"},"text":"section 1 of this title","children":[],"tail":". All functions of offices eliminated were already vested in Secretary of the Treasury by Reorg. Plan No. 26 of 1950, eff. "},{"tag":"date","attrib":{"date":"1950-07-31"},"text":"July 31, 1950","children":[],"tail":", 15 F.R. 4935, "},{"tag":"ref","attrib":{"href":"/us/stat/64/1280"},"text":"64 Stat. 1280","children":[],"tail":", set out in the Appendix to Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
