{"tag":"section","attrib":{"id":"id0610fb02-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3551"},"text":null,"children":[{"tag":"num","attrib":{"value":"3551"},"text":"§ 3551.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Working party on worker rights","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0610fb03-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3551/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall seek the establishment in the GATT 1947, and, upon entry into force of the WTO Agreement with respect to the United States, in the WTO, of a working party to examine the relationship of internationally recognized worker rights, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2467/4"},"text":"section 2467(4) of this title","children":[],"tail":", to the articles, objectives, and related instruments of the GATT 1947 and of the WTO, respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0610fb04-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3551/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Objectives of working party","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The objectives of the United States for the working party described in subsection (a) are to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0610fb05-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3551/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" explore the linkage between international trade and internationally recognized worker rights, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2467/4"},"text":"section 2467(4) of this title","children":[],"tail":", taking into account differences in the level of development among countries;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0610fb06-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3551/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" examine the effects on international trade of the systematic denial of such rights;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0610fb07-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3551/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider ways to address such effects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0610fb08-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3551/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop methods to coordinate the work program of the working party with the International Labor Organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0610fb09-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3551/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall report to the Congress, not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"1994-12-08"},"text":"December 8, 1994","children":[],"tail":", on the progress made in establishing the working party under this section, and on United States objectives with respect to the working party’s work program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0610fb0a-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/tI/s131"},"text":"Pub. L. 103–465, title I, § 131","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4839"},"text":"108 Stat. 4839","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1954/a/6"},"text":"Pub. L. 104–188, title I, § 1954(a)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1928"},"text":"110 Stat. 1928","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0610fb0b-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0610fb0c-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0610fb0d-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsecs. (a), (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188"},"text":"Pub. L. 104–188","children":[],"tail":" substituted “2467(4)” for “2462(a)(4)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0610fb0e-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":