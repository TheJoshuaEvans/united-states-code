{"tag":"section","attrib":{"id":"id05c96ab4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2314"},"text":null,"children":[{"tag":"num","attrib":{"value":"2314"},"text":"§ 2314.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liabilities of certifying and disbursing officers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05c96ab5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2314/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certifying officer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No person designated by the Secretary, or designated pursuant to an agreement under this subpart, as a certifying officer, shall, in the absence of gross negligence or intent to defraud the United States, be liable with respect to any payment certified by him under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05c96ab6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2314/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disbursing officer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No disbursing officer shall, in the absence of gross negligence or intent to defraud the United States, be liable with respect to any payment by him under this part if it was based upon a voucher signed by a certifying officer designated as provided in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05c96ab7-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/tII/s242"},"text":"Pub. L. 93–618, title II, § 242","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2026"},"text":"88 Stat. 2026","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05c96ab8-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id05c96ab9-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"terminationDate","id":"id05c96aba-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"No trade adjustment assistance, vouchers, allowances, or other payments or benefits may be provided under this part after ","children":[{"tag":"date","attrib":{"date":"2022-06-30"},"text":"June 30, 2022","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/93/618/s285"},"text":"section 285 of Pub. L. 93–618","children":[],"tail":", as modified by "},{"tag":"ref","attrib":{"href":"/us/pl/114/27/s406/a/7"},"text":"section 406(a)(7) of Pub. L. 114–27","children":[],"tail":", set out as notes preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2271"},"text":"section 2271 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
