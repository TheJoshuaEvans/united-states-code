{"tag":"section","attrib":{"id":"id0562e070-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1593a"},"text":"§ 1593a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties for false drawback claims","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0562e071-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0562e072-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No person, by fraud, or negligence—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0562e073-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may seek, induce or affect, or attempt to seek, induce, or affect, the payment or credit to that person or others of any drawback claim by means of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0562e074-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any document, written or oral statement, or electronically transmitted data or information, or act which is material and false, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0562e075-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any omission which is material; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0562e076-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may aid or abet any other person to violate subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0562e077-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Clerical errors or mistakes of fact are not violations of paragraph (1) unless they are part of a pattern of negligent conduct. The mere nonintentional repetition by an electronic system of an initial clerical error does not constitute a pattern of negligent conduct.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0562e078-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0562e079-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prepenalty notice","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0562e07a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Customs Service has reasonable cause to believe that there has been a violation of subsection (a) and determines that further proceedings are warranted, the Customs Service shall issue to the person concerned a written notice of intent to issue a claim for a monetary penalty. Such notice shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0562e07b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify the drawback claim;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0562e07c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set forth the details relating to the seeking, inducing, or affecting, or the attempted seeking, inducing, or affecting, or the aiding or procuring of, the drawback claim;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0562e07d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify all laws and regulations allegedly violated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0562e07e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/b/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disclose all the material facts which establish the alleged violation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0562e07f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/b/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" state whether the alleged violation occurred as a result of fraud or negligence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0562e080-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/b/1/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" state the estimated actual or potential loss of revenue due to the drawback claim, and, taking into account all circumstances, the amount of the proposed monetary penalty; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0562e081-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/b/1/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inform such person that he shall have a reasonable opportunity to make representations, both oral and written, as to why a claim for a monetary penalty should not be issued in the amount stated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0562e082-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Customs Service may not issue a prepenalty notice if the amount of the penalty in the penalty claim issued under paragraph (2) is $1,000 or less. In such cases, the Customs Service may proceed directly with a penalty claim.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0562e083-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prior approval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No prepenalty notice in which the alleged violation occurred as a result of fraud shall be issued without the prior approval of Customs Headquarters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0562e084-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty claim","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After considering representations, if any, made by the person concerned pursuant to the notice issued under paragraph (1), the Customs Service shall determine whether any violation of subsection (a), as alleged in the notice, has occurred. If the Customs Service determines that there was no violation, the Customs Service shall promptly issue a written statement of the determination to the person to whom the notice was sent. If the Customs Service determines that there was a violation, Customs shall issue a written penalty claim to such person. The written penalty claim shall specify all changes in the information provided under clauses (i) through (vii) of paragraph (1)(A). Such person shall have a reasonable opportunity under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1618"},"text":"section 1618 of this title","children":[],"tail":" to make representations, both oral and written, seeking remission or mitigation of the monetary penalty. At the conclusion of any proceeding under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1618"},"text":"section 1618 of this title","children":[],"tail":", the Customs Service shall provide to the person concerned a written statement which sets forth the final determination, and the findings of fact and conclusions of law on which such determination is based."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0562e085-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum penalties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0562e086-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fraud","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A fraudulent violation of subsection (a) of this section is punishable by a civil penalty in an amount not to exceed 3 times the actual or potential loss of revenue.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0562e087-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Negligence","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0562e088-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A negligent violation of subsection (a) is punishable by a civil penalty in an amount not to exceed 20 percent of the actual or potential loss of revenue for the 1st violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0562e089-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repetitive violations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Customs Service determines that a repeat negligent violation occurs relating to the same issue, the penalty amount for the 2d violation shall be in an amount not to exceed 50 percent of the total actual or potential loss of revenue. The penalty amount for each succeeding repetitive negligent violation shall be in an amount not to exceed the actual or potential loss of revenue. If the same party commits a nonrepetitive violation, that violation shall be subject to a penalty not to exceed 20 percent of the actual or potential loss of revenue.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0562e08a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prior disclosure","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0562e08b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subparagraph (B), if the person concerned discloses the circumstances of a violation of subsection (a) before, or without knowledge of the commencement of, a formal investigation of such violation, the monetary penalty assessed under this subsection may not exceed—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0562e08c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the violation resulted from fraud, an amount equal to the actual or potential revenue of which the United States is or may be deprived as a result of overpayment of the claim; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0562e08d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the violation resulted from negligence, an amount equal to the interest computed on the basis of the prevailing rate of interest applied under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6621"},"text":"section 6621 of title 26","children":[],"tail":" on the amount of actual revenue of which the United States is or may be deprived during the period that—"}],"tail":null},{"tag":"subclause","attrib":{"id":"id0562e08e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/c/3/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" begins on the date of the overpayment of the claim; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0562e08f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/c/3/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ends on the date on which the person concerned tenders the amount of the overpayment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0562e090-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Condition affecting penalty limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The limitations in subparagraph (A) on the amount of the monetary penalty to be assessed under this subsection apply only if the person concerned tenders the amount of the overpayment made on the claim at the time of disclosure, or within 30 days (or such longer period as the Customs Service may provide), after notice by the Customs Service of its calculation of the amount of the overpayment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0562e091-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Burden of proof","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The person asserting lack of knowledge of the commencement of a formal investigation has the burden of proof in establishing such lack of knowledge.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0562e092-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commencement of investigation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, a formal investigation of a violation is considered to be commenced with regard to the disclosing party and the disclosed information on the date recorded in writing by the Customs Service as the date on which facts and circumstances were discovered or information was received which caused the Customs Service to believe that a possibility of a violation of subsection (a) existed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0562e093-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusivity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Penalty claims under this section shall be the exclusive civil remedy for any drawback related violation of subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0562e094-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deprivation of lawful revenue","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1514"},"text":"section 1514 of this title","children":[],"tail":", if the United States has been deprived of lawful duties and taxes resulting from a violation of subsection (a), the Customs Service shall require that such duties and taxes be restored whether or not a monetary penalty is assessed."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0562e095-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Drawback compliance program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0562e096-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After consultation with the drawback trade community, the Customs Service shall establish a drawback compliance program in which claimants and other parties in interest may participate after being certified by the Customs Service under paragraph (2). Participation in the drawback compliance program is voluntary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0562e097-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A party may be certified as a participant in the drawback compliance program after meeting the general requirements established under the program or after negotiating an alternative program suited to the needs of the party and the Customs Service. Certification requirements shall take into account the size and nature of the party’s drawback program and the volume of claims. In order to be certified, the participant must be able to demonstrate that it—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0562e098-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" understands the legal requirements for filing claims, including the nature of the records required to be maintained and produced and the time periods involved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0562e099-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has in place procedures to explain the Customs Service requirements to those employees that are involved in the preparation of claims, and the maintenance and production of required records;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0562e09a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has in place procedures regarding the preparation of claims and maintenance of required records, and the production of such records to the Customs Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0562e09b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has designated a dependable individual or individuals to be responsible for compliance under the program and whose duties include maintaining familiarity with the drawback requirements of the Customs Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0562e09c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/e/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a record maintenance procedure approved by the Customs Service for original records, or, if approved by the Customs Service, for alternate records or recordkeeping formats other than the original records; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0562e09d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/e/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has procedures for notifying the Customs Service of variances to, and violations of, the requirements of the drawback compliance program or any negotiated alternative programs, and for taking corrective action when notified by the Customs Service for violations or problems regarding such program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0562e09e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternatives to penalties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0562e09f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"When a party that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0562e0a0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been certified as a participant in the drawback compliance program under subsection (e); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0562e0a1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is generally in compliance with the appropriate procedures and requirements of the program;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"commits a violation of subsection (a), the Customs Service, shall, in the absence of fraud or repeated violations, and in lieu of a monetary penalty, issue a written notice of the violation to the party. Repeated violations by a party may result in the issuance of penalties and removal of certification under the program until corrective action, satisfactory to the Customs Service, is taken.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0562e0a2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of notice","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A notice of violation issued under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0562e0a3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" state that the party has violated subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0562e0a4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" explain the nature of the violation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0562e0a5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" warn the party that future violations of subsection (a) may result in the imposition of monetary penalties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0562e0a6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Response to notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within a reasonable time after receiving written notice under paragraph (1), the party shall notify the Customs Service of the steps it has taken to prevent a recurrence of the violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0562e0a7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repetitive violations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0562e0a8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A party who has been issued a written notice under subsection (f)(1) and subsequently commits a repeat negligent violation involving the same issue is subject to the following monetary penalties:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0562e0a9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 2d violation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An amount not to exceed 20 percent of the loss of revenue.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0562e0aa-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 3rd violation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An amount not to exceed 50 percent of the loss of revenue.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0562e0ab-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/g/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 4th and subsequent violations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An amount not to exceed 100 percent of the loss of revenue.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0562e0ac-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a party that has been certified as a participant in the drawback compliance program under subsection (e) commits an alleged violation which was not repetitive, the party shall be issued a “warning letter”, and, for any subsequent violation, shall be subject to the same maximum penalty amounts stated in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0562e0ad-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall promulgate regulations and guidelines to implement this section. Such regulations shall specify that for purposes of subsections (c) and (g), a repeat negligent violation involving the same issue shall be treated as a repetitive violation for a maximum period of 3 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0562e0ae-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Court of International Trade proceedings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, in any proceeding commenced by the United States in the Court of International Trade for the recovery of any monetary penalty claimed under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0562e0af-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all issues, including the amount of the penalty, shall be tried de novo;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0562e0b0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the monetary penalty is based on fraud, the United States shall have the burden of proof to establish the alleged violation by clear and convincing evidence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0562e0b1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1593a/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the monetary penalty is based on negligence, the United States shall have the burden of proof to establish the act or omission constituting the violation, and the alleged violator shall have the burden of providing evidence that the act or omission did not occur as a result of negligence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0562e0b2-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title IV, § 593A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/182/tVI/s622/a"},"text":"Pub. L. 103–182, title VI, § 622(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-08"},"text":"Dec. 8, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2181"},"text":"107 Stat. 2181","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/429/tI/s1563/f"},"text":"Pub. L. 108–429, title I, § 1563(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-03"},"text":"Dec. 3, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2587"},"text":"118 Stat. 2587","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0562e0b3-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0562e0b4-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0562e0b5-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/429"},"text":"Pub. L. 108–429","children":[],"tail":" substituted “subsections (c) and (g)” for “subsection (g)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0562e0b6-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0562e0b7-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/429"},"text":"Pub. L. 108–429","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2004-12-03"},"text":"Dec. 3, 2004","children":[],"tail":", and applicable to drawback entries filed on or after "},{"tag":"date","attrib":{"date":"2004-12-03"},"text":"Dec. 3, 2004","children":[],"tail":", and to those filed before "},{"tag":"date","attrib":{"date":"2004-12-03"},"text":"Dec. 3, 2004","children":[],"tail":", if liquidation of the drawback entry is not final on "},{"tag":"date","attrib":{"date":"2004-12-03"},"text":"Dec. 3, 2004","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/429/s1563/g/1"},"text":"section 1563(g)(1) of Pub. L. 108–429","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1313"},"text":"section 1313 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0562e0b8-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/182/tVI/s622/b"},"text":"Pub. L. 103–182, title VI, § 622(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-08"},"text":"Dec. 8, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2186"},"text":"107 Stat. 2186","children":[],"tail":", which provided that the enactment of this section would apply to drawback claims filed on and after the nationwide operational implementation of an automated drawback selectivity program by the Customs Service, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/116/113/tVI/s601"},"text":"Pub. L. 116–113, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-01-29"},"text":"Jan. 29, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/78"},"text":"134 Stat. 78","children":[],"tail":", effective on the date the USMCA entered into force ("},{"tag":"date","attrib":{"date":"2020-07-01"},"text":"July 1, 2020","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id0562e0b9-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions, personnel, assets, and liabilities of the United States Customs Service of the Department of the Treasury, including functions of the Secretary of the Treasury relating thereto, to the Secretary of Homeland Security, and for treatment of related references, see sections 203(1), 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":". For establishment of U.S. Customs and Border Protection in the Department of Homeland Security, treated as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" as of "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s211"},"text":"section 211 of Title 6","children":[],"tail":", as amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/114/125"},"text":"Pub. L. 114–125","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/114/125/s802/b"},"text":"section 802(b) of Pub. L. 114–125","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s211"},"text":"section 211 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
