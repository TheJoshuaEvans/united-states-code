{"tag":"section","attrib":{"id":"id055bdbd6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1558"},"text":null,"children":[{"tag":"num","attrib":{"value":"1558"},"text":"§ 1558.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No remission or refund after release of merchandise","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id055bdbd7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1558/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No remission, abatement, refund, or drawback of estimated or liquidated duty shall be allowed because of the exportation or destruction of any merchandise after its release from the custody of the Government, except in the following cases:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id055bdbd8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1558/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When articles are exported with respect to which a drawback of duties is expressly provided for by law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id055bdbd9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1558/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When prohibited articles have been regularly entered in good faith and are subsequently exported or destroyed pursuant to a law of the United States and under such regulations as the Secretary of the Treasury may prescribe; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id055bdbda-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1558/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When articles entered under bond, under any provision of law, are destroyed within the bonded period as provided for in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1557"},"text":"section 1557 of this title","children":[],"tail":", or are destroyed within the bonded period by death, accidental fire, or other casualty, and proof of such destruction is furnished which shall be satisfactory to the Secretary of the Treasury, in which case any accrued duties shall be remitted or refunded and any condition in the bond that the articles shall be exported shall be deemed to have been satisfied."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id055bdbdb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1558/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of duties required notwithstanding export or destruction of articles; exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"When articles are exported or destroyed under customs supervision after once having been released from customs custody, as provided for in subsection (h) ","children":[{"tag":"ref","attrib":{"idref":"fn002036"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002036"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1304"},"text":"section 1304 of this title","children":[],"tail":", such exportation or destruction shall not exempt such articles from the payment of duties other than the marking duty provided for in such subsection (h)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id055bdbdc-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title IV, § 558, "},{"tag":"ref","attrib":{"href":"/us/stat/46/744"},"text":"46 Stat. 744","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch679/s24"},"text":"June 25, 1938, ch. 679, § 24","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/1088"},"text":"52 Stat. 1088","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/36/tI/s1001/b/9"},"text":"Pub. L. 106–36, title I, § 1001(b)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-06-25"},"text":"June 25, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/132"},"text":"113 Stat. 132","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id055bdbdd-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id055bdbde-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id055bdbdf-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsection (h) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1304"},"text":"section 1304 of this title","children":[],"tail":", referred to in subsec. (b), was redesignated subsection (i) and a new subsection (h) of section 1304 was added by "},{"tag":"ref","attrib":{"href":"/us/pl/106/36/tII/s2423/a"},"text":"Pub. L. 106–36, title II, § 2423(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-06-25"},"text":"June 25, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/180"},"text":"113 Stat. 180","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id055bdbe0-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in R.S. § 2978, as amended by ","children":[{"tag":"ref","attrib":{"href":"/us/act/1877-02-27/ch69/s1"},"text":"act Feb. 27, 1877, ch. 69, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/19/247"},"text":"19 Stat. 247","children":[],"tail":", and in R.S. § 3025, both of which were superseded by "},{"tag":"ref","attrib":{"href":"/us/act/1922-09-21/ch356/tIV/s558"},"text":"act Sept. 21, 1922, ch. 356, title IV, § 558","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/977"},"text":"42 Stat. 977","children":[],"tail":", and were repealed by section 642 thereof. Section 558 of the 1922 act was superseded by section 558 of act "},{"tag":"date","attrib":{"date":"1930-06-17"},"text":"June 17, 1930","children":[],"tail":", comprising this section, and repealed by section 651(a)(1) of the 1930 act."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id055bdbe1-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/36"},"text":"Pub. L. 106–36","children":[],"tail":" substituted “subsection (h)” for “subsection (c)” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1938—Act ","children":[{"tag":"date","attrib":{"date":"1938-06-25"},"text":"June 25, 1938","children":[],"tail":", amended section generally. Prior to amendment, section disallowed remission or refund of estimated or liquidated duty on the exportation of merchandise after its release from Government control or custody, with exceptions for articles made from imported materials or not conforming to specifications, on which drawback was provided by law."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id055bdbe2-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id055bdbe3-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1938 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by act ","children":[{"tag":"date","attrib":{"date":"1938-06-25"},"text":"June 25, 1938","children":[],"tail":", effective on thirtieth day following "},{"tag":"date","attrib":{"date":"1938-06-25"},"text":"June 25, 1938","children":[],"tail":", except as otherwise specifically provided, see section 37 of act "},{"tag":"date","attrib":{"date":"1938-06-25"},"text":"June 25, 1938","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1401"},"text":"section 1401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
