{"tag":"section","attrib":{"id":"id0615b524-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3624"},"text":null,"children":[{"tag":"num","attrib":{"value":"3624"},"text":"§ 3624.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional program funding","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0615b525-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3624/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of additional funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Consistent, as determined by the President, with the obligations undertaken by the United States set forth in the Uruguay Round Agreements, the Commodity Credit Corporation shall use, in addition to any other funds appropriated or made available for such purposes, any funds made available under subsection (b) for authorized export promotion, foreign market development, export credit financing, and promoting the development, commercialization, and marketing of products resulting from alternative uses of agricultural commodities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0615b526-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3624/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of additional funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts shall be credited to the Commodity Credit Corporation in fiscal year 1995 equal to the lesser of the dollar amount of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0615b527-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3624/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fiscal year 1995 Pay-As-You-Go savings; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0615b528-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3624/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 5-year Pay-As-You-Go savings;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s902"},"text":"section 902 of title 2","children":[],"tail":", resulting from the enactment of the Federal Crop Insurance Reform Act of 1994."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0615b529-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3624/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall take effect on ","children":[{"tag":"date","attrib":{"date":"1994-12-08"},"text":"December 8, 1994","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0615b52a-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/tIV/s426"},"text":"Pub. L. 103–465, title IV, § 426","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4966"},"text":"108 Stat. 4966","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0615b52b-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0615b52c-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading",