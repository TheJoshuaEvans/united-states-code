{"tag":"section","attrib":{"id":"id061a975c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3732"},"text":null,"children":[{"tag":"num","attrib":{"value":"3732"},"text":"§ 3732.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Executive branch initiatives","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id061a975d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3732/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement of the Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Congress recognizes that the stated policy of the executive branch in 1997, the “Partnership for Growth and Opportunity in Africa” initiative, is a step toward the establishment of a comprehensive trade and development policy for sub-Saharan Africa. It is the sense of the Congress that this Partnership is a companion to the policy goals set forth in this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id061a975e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3732/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance to promote economic reforms and development","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to continuing bilateral and multilateral economic and development assistance, the President shall target technical assistance toward—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id061a975f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3732/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing relationships between United States firms and firms in sub-Saharan Africa through a variety of business associations and networks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id061a9760-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3732/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" providing assistance to the governments of sub-Saharan African countries to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id061a9761-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3732/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" liberalize trade and promote exports;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id061a9762-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3732/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bring their legal regimes into compliance with the standards of the World Trade Organization in conjunction with membership in that Organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id061a9763-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3732/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make financial and fiscal reforms; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id061a9764-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3732/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote greater agribusiness linkages;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id061a9765-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3732/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" addressing such critical agricultural policy issues as market liberalization, agricultural export development, and agribusiness investment in processing and transporting agricultural commodities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id061a9766-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3732/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing the number of reverse trade missions to growth-oriented countries in sub-Saharan Africa;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id061a9767-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3732/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing trade in services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id061a9768-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3732/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encouraging greater sub-Saharan African participation in future negotiations in the World Trade Organization on services and making further commitments in their schedules to the General Agreement on Trade in Services in order to encourage the removal of tariff and nontariff barriers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id061a9769-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/200/tI/s122"},"text":"Pub. L. 106–200, title I, § 122","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-05-18"},"text":"May 18, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/268"},"text":"114 Stat. 268","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id061a976a-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id061a976b-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id061a976c-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a), was in the original “this title”, meaning title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/200"},"text":"Pub. L. 106–200","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-05-18"},"text":"May 18, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/252"},"text":"114 Stat. 252","children":[],"tail":", which is classified principally to this chapter. For complete classification of title I to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3701"},"text":"section 3701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
