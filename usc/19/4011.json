{"tag":"section","attrib":{"id":"id063e4c76-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4011"},"text":null,"children":[{"tag":"num","attrib":{"value":"4011"},"text":"§ 4011.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval and entry into force of the Agreement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id063e4c77-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4011/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of Agreement and statement of administrative action","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3805"},"text":"section 3805 of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2191"},"text":"section 2191 of this title","children":[],"tail":", the Congress approves—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id063e4c78-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4011/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Dominican Republic-Central America-United States Free Trade Agreement entered into on ","children":[{"tag":"date","attrib":{"date":"2004-08-05"},"text":"August 5, 2004","children":[],"tail":", with the Governments of Costa Rica, the Dominican Republic, El Salvador, Guatemala, Honduras, and Nicaragua, and submitted to the Congress on "},{"tag":"date","attrib":{"date":"2005-06-23"},"text":"June 23, 2005","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id063e4c79-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4011/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the statement of administrative action proposed to implement the Agreement that was submitted to the Congress on ","children":[{"tag":"date","attrib":{"date":"2005-06-23"},"text":"June 23, 2005","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id063e4c7a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4011/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions for entry into force of the Agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At such time as the President determines that countries listed in subsection (a)(1) have taken measures necessary to comply with the provisions of the Agreement that are to take effect on the date on which the Agreement enters into force, the President is authorized to provide for the Agreement to enter into force with respect to those countries that provide for the Agreement to enter into force for them.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id063e4c7b-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/53/tI/s101"},"text":"Pub. L. 109–53, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-02"},"text":"Aug. 2, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/464"},"text":"119 Stat. 464","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id063e4c7c-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id063e4c7d-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination of section by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/53/s107/d"},"text":"section 107(d) of Pub. L. 109–53","children":[],"tail":", see Effective and Termination Dates note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id063e4c7e-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id063e4c7f-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective and Termination Dates","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date the Dominican Republic-Central America-United States Free Trade Agreement enters into force (","children":[{"tag":"date","attrib":{"date":"2006-03-01"},"text":"Mar. 1, 2006","children":[],"tail":") and to cease to have effect on the date the Agreement ceases to be in force with respect to the United States, and, during any period in which a country ceases to be a CAFTA–DR country, to cease to have effect with respect to such country, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/53/s107"},"text":"section 107 of Pub. L. 109–53","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s4001"},"text":"section 4001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
