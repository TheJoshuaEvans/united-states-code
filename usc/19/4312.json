{"tag":"section","attrib":{"id":"id064ca409-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4312"},"text":null,"children":[{"tag":"num","attrib":{"value":"4312"},"text":"§ 4312.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priorities and performance standards for customs modernization, trade facilitation, and trade enforcement functions and programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id064ca40a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4312/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priorities and performance standards","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id064ca40b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4312/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commissioner, in consultation with the appropriate congressional committees, shall establish priorities and performance standards to measure the development and levels of achievement of the customs modernization, trade facilitation, and trade enforcement functions and programs described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064ca40c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4312/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum priorities and standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such priorities and performance standards shall, at a minimum, include priorities and standards relating to efficiency, outcome, output, and other types of applicable measures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id064ca40d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4312/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions and programs described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The functions and programs referred to in subsection (a) are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id064ca40e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4312/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Automated Commercial Environment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064ca40f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4312/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each of the priority trade issues described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4322"},"text":"section 4322 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064ca410-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4312/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Centers of Excellence and Expertise described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4317"},"text":"section 4317 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064ca411-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4312/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Drawback for exported merchandise under section 313 of the Tariff Act of 1930 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1313"},"text":"19 U.S.C. 1313","children":[],"tail":"), as amended by section 906 of this Act."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064ca412-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4312/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Transactions relating to imported merchandise in bond.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064ca413-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4312/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Collection of countervailing duties assessed under subtitle A of title VII of the Tariff Act of 1930 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1671"},"text":"19 U.S.C. 1671","children":[],"tail":" et seq.) and antidumping duties assessed under subtitle B of title VII of the Tariff Act of 1930 ("},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1673"},"text":"19 U.S.C. 1673","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064ca414-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4312/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The expedited clearance of cargo.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064ca415-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4312/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The issuance of regulations and rulings.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064ca416-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4312/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The issuance of Regulatory Audit Reports.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id064ca417-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4312/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultations and notification","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id064ca418-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4312/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The consultations required by subsection (a)(1) shall occur, at a minimum, on an annual basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064ca419-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4312/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commissioner shall notify the appropriate congressional committees of any changes to the priorities or performance standards referred to in subsection (a) not later than 30 days before such changes are to take effect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id064ca41a-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/125/tI/s103"},"text":"Pub. L. 114–125, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-24"},"text":"Feb. 24, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/129"},"text":"130 Stat. 129","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id064ca41b-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id064ca41c-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id064ca41d-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Tariff Act of 1930, referred to in subsec. (b)(4), (6), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"act June 17, 1930, ch. 497","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/590"},"text":"46 Stat. 590","children":[],"tail":". Section 313 of the Tariff Act of 1930, as amended by section 906 of this Act, is "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1313"},"text":"section 1313 of this title","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/114/125/s906"},"text":"section 906 of Pub. L. 114–125","children":[],"tail":". Subtitles A and B of title VII of the Act are classified generally to parts I (§ 1671 et seq.) and II (§ 1673 et seq.), respectively, of subtitle IV of chapter 4 of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1654"},"text":"section 1654 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
