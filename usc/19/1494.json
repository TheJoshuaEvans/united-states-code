{"tag":"section","attrib":{"id":"id0546573a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1494"},"text":null,"children":[{"tag":"num","attrib":{"value":"1494"},"text":"§ 1494.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expense of weighing and measuring","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In all cases in which the invoice or entry does not state the weight, quantity, or measure of the merchandise, the expense of ascertaining the same shall be collected from the importer of record before its release from customs custody.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0546573b-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title IV, § 494, "},{"tag":"ref","attrib":{"href":"/us/stat/46/727"},"text":"46 Stat. 727","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/446/tII/s201/e"},"text":"Pub. L. 97–446, title II, § 201(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2350"},"text":"96 Stat. 2350","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0546573c-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0546573d-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0546573e-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-09-21/ch356/tIV/s494"},"text":"act Sept. 21, 1922, ch. 356, title IV, § 494","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/964"},"text":"42 Stat. 964","children":[],"tail":". That section was superseded by section 494 of act "},{"tag":"date","attrib":{"date":"1930-06-17"},"text":"June 17, 1930","children":[],"tail":", comprising this section, and repealed by section 651(a)(1) of the 1930 act."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior provision requiring merchandise to be weighed, gauged or measured at the expense of the owner, agent or consignee, in cases in which the invoice or entry did not contain the weight, quantity or measure was contained in R.S. § 2920, prior to repeal by ","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-09-21/ch356/tIV/s642"},"text":"act Sept. 21, 1922, ch. 356, title IV, § 642","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/989"},"text":"42 Stat. 989","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0546573f-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1983—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/446"},"text":"Pub. L. 97–446","children":[],"tail":" substituted “importer of record” for “consignee” after “collected from the”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id05465740-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id05465741-3a70-11f1-8ace-823fb135378d"},"t