{"tag":"section","attrib":{"id":"id063e4c0c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3906"},"text":null,"children":[{"tag":"num","attrib":{"value":"3906"},"text":"§ 3906.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement of policy","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Congress supports the policy that the President shall take appropriate steps to promote and facilitate the adoption by the international community of the Kimberley Process Certification Scheme implemented under this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id063e4c0d-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/19/s7"},"text":"Pub. L. 108–19, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-04-25"},"text":"Apr. 25, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/634"},"text":"117 Stat. 634","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id063e4c0e-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id063e4c0f-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id063e4c10-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/19/s15"},"text":"section 15 of Pub. L. 108–19","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3901"},"text":"section 3