{"tag":"section","attrib":{"id":"id053cbab5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1452"},"text":null,"children":[{"tag":"num","attrib":{"value":"1452"},"text":"§ 1452.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lading on Sundays, holidays, or at night","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No merchandise or baggage entered for transportation under bond or for exportation with the benefit of drawback, or other merchandise or baggage required to be laden under customs supervision, shall be laden on any vessel or vehicle at night or on Sunday or a holiday, except under special license therefor to be issued by the appropriate customs officer under the same conditions and limitations as pertain to the unlading of imported merchandise or merchandise being transported in bond.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id053cbab6-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title IV, § 452, "},{"tag":"ref","attrib":{"href":"/us/stat/46/715"},"text":"46 Stat. 715","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/271/tIII/s301/b"},"text":"Pub. L. 91–271, title III, § 301(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-06-02"},"text":"June 2, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/287"},"text":"84 Stat. 287","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id053cbab7-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id053cbab8-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":n