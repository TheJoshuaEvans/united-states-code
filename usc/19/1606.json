{"tag":"section","attrib":{"id":"id0565514a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1606"},"text":null,"children":[{"tag":"num","attrib":{"value":"1606"},"text":"§ 1606.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Seizure; appraisement","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The appropriate customs officer shall determine the domestic value, at the time and place of appraisement, of any vessel, vehicle, aircraft, merchandise, or baggage seized under the customs laws.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0565514b-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title IV, § 606, "},{"tag":"ref","attrib":{"href":"/us/stat/46/754"},"text":"46 Stat. 754","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/271/tIII/s301/dd"},"text":"Pub. L. 91–271, title III, § 301(dd)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-06-02"},"text":"June 2, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/291"},"text":"84 Stat. 291","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s321"},"text":"Pub. L. 98–473, title II, § 321","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2056"},"text":"98 Stat. 2056","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/573/tII/s213/a/3"},"text":"Pub. L. 98–573, title II, § 213(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2984"},"text":"98 Stat. 2984","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05655