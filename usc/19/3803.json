{"tag":"section","attrib":{"id":"id061ce16e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803"},"text":null,"children":[{"tag":"num","attrib":{"value":"3803"},"text":"§ 3803.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trade agreements authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id061ce16f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements regarding tariff barriers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id061ce170-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whenever the President determines that one or more existing duties or other import restrictions of any foreign country or the United States are unduly burdening and restricting the foreign trade of the United States and that the purposes, policies, priorities, and objectives of this chapter will be promoted thereby, the President—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id061ce171-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may enter into trade agreements with foreign countries before—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id061ce172-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"date","attrib":{"date":"2005-07-01"},"text":"July 1, 2005","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id061ce173-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"date","attrib":{"date":"2007-07-01"},"text":"July 1, 2007","children":[],"tail":", if trade authorities procedures are extended under subsection (c); and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id061ce174-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may, subject to paragraphs (2) and (3), proclaim—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id061ce175-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such modification or continuance of any existing duty,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id061ce176-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such continuance of existing duty-free or excise treatment, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id061ce177-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such additional duties,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"as the President determines to be required or appropriate to carry out any such trade agreement.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The President shall notify the Congress of the President’s intention to enter into an agreement under this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id061ce178-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No proclamation may be made under paragraph (1) that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id061ce179-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduces any rate of duty (other than a rate of duty that does not exceed 5 percent ad valorem on ","children":[{"tag":"date","attrib":{"date":"2002-08-06"},"text":"August 6, 2002","children":[],"tail":") to a rate of duty which is less than 50 percent of the rate of such duty that applies on "},{"tag":"date","attrib":{"date":"2002-08-06"},"text":"August 6, 2002","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id061ce17a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduces the rate of duty below that applicable under the Uruguay Round Agreements, on any import sensitive agricultural product; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id061ce17b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increases any rate of duty above the rate that applied on ","children":[{"tag":"date","attrib":{"date":"2002-08-06"},"text":"August 6, 2002","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id061ce17c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aggregate reduction; exemption from staging","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id061ce17d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aggregate reduction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subparagraph (B), the aggregate reduction in the rate of duty on any article which is in effect on any day pursuant to a trade agreement entered into under paragraph (1) shall not exceed the aggregate reduction which would have been in effect on such day if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id061ce17e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a reduction of 3 percent ad valorem or a reduction of one-tenth of the total reduction, whichever is greater, had taken effect on the effective date of the first reduction proclaimed under paragraph (1) to carry out such agreement with respect to such article; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id061ce17f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a reduction equal to the amount applicable under clause (i) had taken effect at 1-year intervals after the effective date of such first reduction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id061ce180-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption from staging","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No staging is required under subparagraph (A) with respect to a duty reduction that is proclaimed under paragraph (1) for an article of a kind that is not produced in the United States. The United States International Trade Commission shall advise the President of the identity of articles that may be exempted from staging under this subparagraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id061ce181-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rounding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the President determines that such action will simplify the computation of reductions under paragraph (3), the President may round an annual reduction by an amount equal to the lesser of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id061ce182-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the difference between the reduction without regard to this paragraph and the next lower whole number; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id061ce183-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one-half of 1 percent ad valorem.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id061ce184-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A rate of duty reduction that may not be proclaimed by reason of paragraph (2) may take effect only if a provision authorizing such reduction is included within an implementing bill provided for under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3805"},"text":"section 3805 of this title","children":[],"tail":" and that bill is enacted into law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id061ce185-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other tariff modifications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraphs (1)(B), (2)(A), (2)(C), and (3) through (5), and subject to the consultation and layover requirements of section 115 of the Uruguay Round Agreements Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3524"},"text":"19 U.S.C. 3524","children":[],"tail":"], the President may proclaim the modification of any duty or staged rate reduction of any duty set forth in Schedule XX, as defined in section 2(5) of that Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3501/5"},"text":"19 U.S.C. 3501(5)","children":[],"tail":"], if the United States agrees to such modification or staged rate reduction in a negotiation for the reciprocal elimination or harmonization of duties under the auspices of the World Trade Organization."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id061ce186-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority under Uruguay Round Agreements Act not affected","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection shall limit the authority provided to the President under section 111(b) of the Uruguay Round Agreements Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3521/b"},"text":"19 U.S.C. 3521(b)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id061ce187-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements regarding tariff and nontariff barriers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id061ce188-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id061ce189-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Whenever the President determines that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id061ce18a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more existing duties or any other import restriction of any foreign country or the United States or any other barrier to, or other distortion of, international trade unduly burdens or restricts the foreign trade of the United States or adversely affects the United States economy, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id061ce18b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the imposition of any such barrier or distortion is likely to result in such a burden, restriction, or effect,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"and that the purposes, policies, priorities, and objectives of this chapter will be promoted thereby, the President may enter into a trade agreement described in subparagraph (B) during the period described in subparagraph (C).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id061ce18c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The President may enter into a trade agreement under subparagraph (A) with foreign countries providing for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id061ce18d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reduction or elimination of a duty, restriction, barrier, or other distortion described in subparagraph (A); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id061ce18e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the prohibition of, or limitation on the imposition of, such barrier or other distortion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id061ce18f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The President may enter into a trade agreement under this paragraph before—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id061ce190-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"date","attrib":{"date":"2005-07-01"},"text":"July 1, 2005","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id061ce191-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"date","attrib":{"date":"2007-07-01"},"text":"July 1, 2007","children":[],"tail":", if trade authorities procedures are extended under subsection (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id061ce192-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A trade agreement may be entered into under this subsection only if such agreement makes progress in meeting the applicable objectives described in section 3802(a) and (b) of this title and the President satisfies the conditions set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3804"},"text":"section 3804 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id061ce193-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bills qualifying for trade authorities procedures","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id061ce194-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2191"},"text":"section 2191 of this title","children":[],"tail":" (in this chapter referred to as “trade authorities procedures”) apply to a bill of either House of Congress which contains provisions described in subparagraph (B) to the same extent as such "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2191"},"text":"section 2191 of this title","children":[],"tail":" applies to implementing bills under that section. A bill to which this paragraph applies shall hereafter in this chapter be referred to as an “implementing bill”."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id061ce195-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The provisions referred to in subparagraph (A) are—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id061ce196-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a provision approving a trade agreement entered into under this subsection and approving the statement of administrative action, if any, proposed to implement such trade agreement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id061ce197-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if changes in existing laws or new statutory authority are required to implement such trade agreement or agreements, provisions, necessary or appropriate to implement such trade agreement or agreements, either repealing or amending existing laws or providing new statutory authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id061ce198-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension disapproval process for Congressional trade authorities procedures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id061ce199-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3805/b"},"text":"section 3805(b) of this title","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id061ce19a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the trade authorities procedures apply to implementing bills submitted with respect to trade agreements entered into under subsection (b) before ","children":[{"tag":"date","attrib":{"date":"2005-07-01"},"text":"July 1, 2005","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id061ce19b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the trade authorities procedures shall be extended to implementing bills submitted with respect to trade agreements entered into under subsection (b) after ","children":[{"tag":"date","attrib":{"date":"2005-06-30"},"text":"June 30, 2005","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"2007-07-01"},"text":"July 1, 2007","children":[],"tail":", if (and only if)—"}],"tail":null},{"tag":"clause","attrib":{"id":"id061ce19c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President requests such extension under paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id061ce19d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" neither House of the Congress adopts an extension disapproval resolution under paragraph (5) before ","children":[{"tag":"date","attrib":{"date":"2005-07-01"},"text":"July 1, 2005","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id061ce19e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress by the President","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the President is of the opinion that the trade authorities procedures should be extended to implementing bills described in paragraph (1)(B), the President shall submit to the Congress, not later than ","children":[{"tag":"date","attrib":{"date":"2005-04-01"},"text":"April 1, 2005","children":[],"tail":", a written report that contains a request for such extension, together with—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id061ce19f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of all trade agreements that have been negotiated under subsection (b) and the anticipated schedule for submitting such agreements to the Congress for approval;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id061ce1a0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the progress that has been made in negotiations to achieve the purposes, policies, priorities, and objectives of this chapter, and a statement that such progress justifies the continuation of negotiations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id061ce1a1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of the reasons why the extension is needed to complete the negotiations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id061ce1a2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other reports to Congress","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id061ce1a3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report by the Advisory Committee","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President shall promptly inform the Advisory Committee for Trade Policy and Negotiations established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2155"},"text":"section 2155 of this title","children":[],"tail":" of the President’s decision to submit a report to the Congress under paragraph (2). The Advisory Committee shall submit to the Congress as soon as practicable, but not later than "},{"tag":"date","attrib":{"date":"2005-06-01"},"text":"June 1, 2005","children":[],"tail":", a written report that contains—"}],"tail":null},{"tag":"clause","attrib":{"id":"id061ce1a4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" its views regarding the progress that has been made in negotiations to achieve the purposes, policies, priorities, and objectives of this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id061ce1a5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of its views, and the reasons therefor, regarding whether the extension requested under paragraph (2) should be approved or disapproved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id061ce1a6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report by ITC","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall promptly inform the International Trade Commission of the President’s decision to submit a report to the Congress under paragraph (2). The International Trade Commission shall submit to the Congress as soon as practicable, but not later than ","children":[{"tag":"date","attrib":{"date":"2005-06-01"},"text":"June 1, 2005","children":[],"tail":", a written report that contains a review and analysis of the economic impact on the United States of all trade agreements implemented between "},{"tag":"date","attrib":{"date":"2002-08-06"},"text":"August 6, 2002","children":[],"tail":", and the date on which the President decides to seek an extension requested under paragraph (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id061ce1a7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status of reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The reports submitted to the Congress under paragraphs (2) and (3), or any portion of such reports, may be classified to the extent the President determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id061ce1a8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension disapproval resolutions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id061ce1a9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of paragraph (1), the term “extension disapproval resolution” means a resolution of either House of the Congress, the sole matter after the resolving clause of which is as follows: “That the __ disapproves the request of the President for the extension, under section 2103(c)(1)(B)(i) of the Bipartisan Trade Promotion Authority Act of 2002, of the trade authorities procedures under that Act to any implementing bill submitted with respect to any trade agreement entered into under section 2103(b) of that Act after ","children":[{"tag":"date","attrib":{"date":"2005-06-30"},"text":"June 30, 2005","children":[],"tail":".”, with the blank space being filled with the name of the resolving House of the Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id061ce1aa-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Extension disapproval resolutions—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id061ce1ab-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/c/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be introduced in either House of the Congress by any member of such House; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id061ce1ac-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/c/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be referred, in the House of Representatives, to the Committee on Ways and Means and, in addition, to the Committee on Rules.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id061ce1ad-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/c/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of section 2192(d) and (e) of this title (relating to the floor consideration of certain resolutions in the House and Senate) apply to extension disapproval resolutions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id061ce1ae-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/c/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" It is not in order for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id061ce1af-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/c/5/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Senate to consider any extension disapproval resolution not reported by the Committee on Finance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id061ce1b0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/c/5/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the House of Representatives to consider any extension disapproval resolution not reported by the Committee on Ways and Means and, in addition, by the Committee on Rules; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id061ce1b1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/c/5/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" either House of the Congress to consider an extension disapproval resolution after ","children":[{"tag":"date","attrib":{"date":"2005-06-30"},"text":"June 30, 2005","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id061ce1b2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3803/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commencement of negotiations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to contribute to the continued economic expansion of the United States, the President shall commence negotiations covering tariff and nontariff barriers affecting any industry, product, or service sector, and expand existing sectoral agreements to countries that are not parties to those agreements, in cases where the President determines that such negotiations are feasible and timely and would benefit the United States. Such sectors include agriculture, commercial services, intellectual property rights, industrial and capital goods, government procurement, information technology products, environmental technology and services, medical equipment and services, civil aircraft, and infrastructure products. In so doing, the President shall take into account all of the principal negotiating objectives set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3802/b"},"text":"section 3802(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id061ce1b3-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/210/dB/tXXI/s2103"},"text":"Pub. L. 107–210, div. B, title XXI, § 2103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-06"},"text":"Aug. 6, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1004"},"text":"116 Stat. 1004","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/429/tII/s2004/a/17"},"text":"Pub. L. 108–429, title II, § 2004(a)(17)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-03"},"text":"Dec. 3, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2591"},"text":"118 Stat. 2591","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id061ce1b4-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id061ce1b5-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id061ce1b6-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Bipartisan Trade Promotion Authority Act of 2002, referred to in subsec. (c)(5)(A), is title XXI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/210/dB"},"text":"Pub. L. 107–210, div. B","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-06"},"text":"Aug. 6, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/993"},"text":"116 Stat. 993","children":[],"tail":", which is classified principally to this chapter. Section 2103 of the Act is classified to this section. For complete classification of title XXI to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3801/a"},"text":"section 3801(a) of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id061ce1b7-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/429/s2004/a/17/A"},"text":"Pub. L. 108–429, § 2004(a)(17)(A)","children":[],"tail":", substituted “July 1” for “June 1” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/429/s2004/a/17/B"},"text":"Pub. L. 108–429, § 2004(a)(17)(B)","children":[],"tail":", substituted “July 1” for “June 1” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/429/s2004/a/17/C/i"},"text":"Pub. L. 108–429, § 2004(a)(17)(C)(i)","children":[],"tail":", substituted “July 1” for “June 1”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/429/s2004/a/17/C/ii"},"text":"Pub. L. 108–429, § 2004(a)(17)(C)(ii)","children":[],"tail":", substituted “April 1” for “March 1” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/429/s2004/a/17/C/iii"},"text":"Pub. L. 108–429, § 2004(a)(17)(C)(iii)","children":[],"tail":", substituted “June 1” for “May 1” in two places."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id061ce1b8-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id061ce1b9-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of functions of President under this section, see section 1 of Ex. Ord. No. 13277, ","children":[{"tag":"date","attrib":{"date":"2002-11-19"},"text":"Nov. 19, 2002","children":[],"tail":", 67 F.R. 70305, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3801"},"text":"section 3801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
