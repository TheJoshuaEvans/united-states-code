{"tag":"section","attrib":{"id":"id064f159e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4361"},"text":null,"children":[{"tag":"num","attrib":{"value":"4361"},"text":"§ 4361.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id064f159f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4361/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id064f15a0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4361/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Finance and the Committee on Appropriations of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id064f15a1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4361/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Ways and Means and the Committee on Appropriations of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064f15a2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4361/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered merchandise","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered merchandise” means merchandise that is subject to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id064f15a3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4361/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a countervailing duty order issued under section 706 of the Tariff Act of 1930 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1671e"},"text":"19 U.S.C. 1671e","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id064f15a4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4361/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an antidumping duty order issued under section 736 of the Tariff Act of 1930 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1673e"},"text":"19 U.S.C. 1673e","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064f15a5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4361/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible small business","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id064f15a6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4361/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible small business” means any business concern that, in the judgment of the Commissioner, due to its small size, has neither adequate internal resources nor financial ability to obtain qualified outside assistance in preparing and submitting for consideration allegations of evasion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id064f15a7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4361/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonreviewability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any agency decision regarding whether a business concern is an eligible small business for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4371/b/4/E"},"text":"section 4371(b)(4)(E) of this title","children":[],"tail":" is not reviewable by any other agency or by any court."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064f15a8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4361/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enter; entry","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “enter” and “entry” refer to the entry, or withdrawal from warehouse for consumption, of merchandise in the customs territory of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064f15a9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4361/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evade; evasion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “evade” and “evasion” refer to entering covered merchandise into the customs territory of the United States by means of any document or electronically transmitted data or information, written or oral statement, or act that is material and false, or any omission that is material, and that results in any cash deposit or other security or any amount of applicable antidumping or countervailing duties being reduced or not being applied with respect to the merchandise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064f15aa-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4361/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064f15ab-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4361/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trade remedy laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “trade remedy laws” means title VII of the Tariff Act of 1930 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1671"},"text":"19 U.S.C. 1671","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id064f15ac-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/125/tIV/s402"},"text":"Pub. L. 114–125, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-24"},"text":"Feb. 24, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/155"},"text":"130 Stat. 155","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id064f15ad-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id064f15ae-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id064f15af-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in text, was in the original “this title”, meaning title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/125"},"text":"Pub. L. 114–125","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-24"},"text":"Feb. 24, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/155"},"text":"130 Stat. 155","children":[],"tail":", which is classified principally to this subchapter. For complete classification of title IV to the Code, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/125/s401"},"text":"section 401 of Pub. L. 114–125","children":[],"tail":", set out as a Short Title note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s4301"},"text":"section 4301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Tariff Act of 1930, referred to in par. (7), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"act June 17, 1930, ch. 497","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/590"},"text":"46 Stat. 590","children":[],"tail":". Title VII of the Act is classified generally to subtitle IV (§ 1671 et seq.) of chapter 4 of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1654"},"text":"section 1654 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
