{"tag":"section","attrib":{"id":"id05f20036-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2547"},"text":null,"children":[{"tag":"num","attrib":{"value":"2547"},"text":"§ 2547.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultations with representatives of domestic interests","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In carrying out the functions for which responsible under this subchapter, the Trade Representative and the Secretary concerned shall solicit technical and policy advice from the committees, established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2155"},"text":"section 2155 of this title","children":[],"tail":", that represent the interests concerned, and may solicit advice from appropriate State agencies and private persons."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id05f20037-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39/tIV/s417"},"text":"Pub. L. 96–39, title IV, § 417","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/247"},"text":"93 Stat. 247","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/182/tIII/s351/b/2/A"},"text":"Pub. L. 103–182, title III, § 351(b)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-08"},"text":"Dec. 8, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2122"},"text":"107 Stat. 2122","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/295/s21/b/1"},"text":"Pub. L. 104–295, § 21(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3529"},"text":"110 Stat. 3529","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05f20038-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05f20039-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id05f2003a-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/295"},"text":"Pub. L. 104–295","children":[],"tail":" amended directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/103/182"},"text":"Pub. L. 103–182","children":[],"tail":". See 1993 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/182"},"text":"Pub. L. 103–182","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/104/295"},"text":"Pub. L. 104–295","children":[],"tail":", substituted “Trade Representative” for “Special Representative”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
