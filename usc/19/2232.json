{"tag":"section","attrib":{"id":"id05b65722-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2232"},"text":null,"children":[{"tag":"num","attrib":{"value":"2232"},"text":"§ 2232.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Independent budget and authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Effective with respect to the fiscal year beginning ","children":[{"tag":"date","attrib":{"date":"1976-10-01"},"text":"October 1, 1976","children":[],"tail":", for purposes of chapter 11 of title 31, estimated expenditures and proposed appropriations for the United States International Trade Commission shall be transmitted to the President on or before October 15 of the year preceding the beginning of each fiscal year and shall be included by him in the Budget without revision, and the Commission shall not be considered to be a department or establishment for purposes of such chapter."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id05b65723-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/tI/s175/a/1"},"text":"Pub. L. 93–618, title I, § 175(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2011"},"text":"88 Stat. 2011","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05b65724-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05b65725-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id05b65726-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Chapter 11 of title 31” and “such chapter” substituted in text for “the Budget and Accounting Act, 1921 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1"},"text":"31 U.S.C. 1","children":[],"tail":" et seq.)” and “such Act”, respectively, on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s4/b"},"text":"Pub. L. 97–258, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1067"},"text":"96 Stat. 1067","children":[],"tail":", the first section of which enacted Title 31, Money and Finance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
