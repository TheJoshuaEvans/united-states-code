{"tag":"section","attrib":{"id":"id0653d0b5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4502"},"text":null,"children":[{"tag":"num","attrib":{"value":"4502"},"text":"§ 4502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this Act:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0653d0b6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4502/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “appropriate congressional committees” means the Committee on Finance of the Senate and the Committee on Ways and Means of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0653d0b7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4502/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" HTS","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “HTS” means the Harmonized Tariff Schedule of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0653d0b8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4502/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identical goods","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “identical goods” means goods that are the same in all respects relevant to the rule of origin that qualifies the goods as originating goods.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0653d0b9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4502/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International Trade Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “International Trade Commission” means the United States International Trade Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0653d0ba-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4502/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mexico","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Mexico” means the United Mexican States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0653d0bb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4502/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" NAFTA","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “NAFTA” means the North American Free Trade Agreement approved by Congress under section 101(a)(1) of the North American Free Trade Agreement Implementation Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3311/a/1"},"text":"19 U.S.C. 3311(a)(1)","children":[],"tail":")."},{"tag":"ref","attrib":{"idref":"fn002175"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002175"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0653d0bc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4502/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preferential tariff treatment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “preferential tariff treatment” means the customs duty rate that is applicable to an originating good (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4531/a"},"text":"section 4531(a) of this title","children":[],"tail":") under the USMCA."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0653d0bd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4502/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trade Representative","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Trade Representative” means the United States Trade Representative.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0653d0be-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4502/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" USMCA","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “USMCA” means the Agreement between the United States of America, the United Mexican States, and Canada, which is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0653d0bf-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4502/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" attached as an Annex to the Protocol Replacing the North American Free Trade Agreement with the Agreement between the United States of America, the United Mexican States, and Canada, done at Buenos Aires on ","children":[{"tag":"date","attrib":{"date":"2018-11-30"},"text":"November 30, 2018","children":[],"tail":", as amended by the Protocol of Amendment to the Agreement Between the United States of America, the United Mexican States, and Canada, done at Mexico City on "},{"tag":"date","attrib":{"date":"2019-12-10"},"text":"December 10, 2019","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0653d0c0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4502/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approved by Congress under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4511/a/1"},"text":"section 4511(a)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0653d0c1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4502/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" USMCA country","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided, the term “USMCA country” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0653d0c2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4502/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Canada for such time as the USMCA is in force with respect to, and the United States applies the USMCA to, Canada; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0653d0c3-3a70-11f1-8ace-823fb135378d","i