{"tag":"section","attrib":{"id":"id05e88a85-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2495"},"text":null,"children":[{"tag":"num","attrib":{"value":"2495"},"text":"§ 2495.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05e88a86-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2495/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continuity of a session of Congress is broken only by an adjournment of the Congress sine die, and the days on which either House is not in session because of an adjournment of more than three days to a day certain are excluded in the computation of the period indicated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05e88a87-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2495/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “major drug producing country” means a country that illicitly produces during a fiscal year 5 metric tons or more of opium or opium derivative, 500 metric tons or more of coca, or 500 metric tons or more of marijuana;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05e88a88-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2495/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “major drug-transit country” means a country—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05e88a89-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2495/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is a significant direct source of illicit narcotic or psychotropic drugs or other controlled substances significantly affecting the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05e88a8a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2495/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through which are transported such drugs or substances; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05e88a8b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2495/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through which significant sums of drug-related profits or monies are laundered with the knowledge or complicity of the government; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05e88a8c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2495/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “narcotic and psychotropic drugs and other controlled substances” has the same meaning as is given by any applicable international narcotics control agreement or domestic law of the country or countries concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05e88a8d-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/tVIII/s805"},"text":"Pub. L. 93–618, title VIII, § 805","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/570/tIX/s9001"},"text":"Pub. L. 99–570, title IX, § 9001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-166"},"text":"100 Stat. 3207–166","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/231/s17/h/5"},"text":"Pub. L. 101–231, § 17(h)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-13"},"text":"Dec. 13, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1965"},"text":"103 Stat. 1965","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/36/tI/s1001/a/10"},"text":"Pub. L. 106–36, title I, § 1001(a)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-06-25"},"text":"June 25, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/131"},"text":"113 Stat. 131","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05e88a8e-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05e88a8f-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id05e88a90-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/36"},"text":"Pub. L. 106–36","children":[],"tail":" struck out “and” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/231"},"text":"Pub. L. 101–231","children":[],"tail":" amended par. (2) generally. Prior to amendment, par. (2) read as follows: “the term ‘major drug producing country’ means a country producing five metric tons or more of opium or opium derivative during a fiscal year or producing five hundred metric tons or more of coca or marijuana (as the case may be) during a fiscal year; and”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
