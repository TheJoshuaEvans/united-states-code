{"tag":"section","attrib":{"id":"id055969ef-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1523"},"text":null,"children":[{"tag":"num","attrib":{"value":"1523"},"text":"§ 1523.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Examination of accounts","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Treasury or such officer or employee as he shall designate, shall, under regulations and instructions prescribed by the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id055969f0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1523/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" examine the customs officers’ accounts of receipts and disbursements of money and receipts and disposition of merchandise; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id055969f1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1523/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" verify, to such extent as the Secretary of the Treasury shall direct, assessments of duties and taxes and allowances of drawback.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id055969f2-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title IV, § 523, "},{"tag":"ref","attrib":{"href":"/us/stat/46/740"},"text":"46 Stat. 740","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1953-08-08/ch397/s2/d"},"text":"Aug. 8, 1953, ch. 397, § 2(d)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/67/508"},"text":"67 Stat. 508","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/271/tIII/s301/s"},"text":"Pub. L. 91–271, title III, § 301(s)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-06-02"},"text":"June 2, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/290"},"text":"84 Stat. 290","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id055969f3-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id055969f4-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id055969f5-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-09-21/ch356/tIV/s523"},"text":"act Sept. 21, 1922, ch. 356, title IV, § 523","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/974"},"text":"42 Stat. 974","children":[],"tail":". That section was superseded by section 523 of act "},{"tag":"date","attrib":{"date":"1930-06-17"},"text":"June 17, 1930","children":[],"tail":", comprising this section, and repealed by section 651(a)(1) of the 1930 act."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id055969f6-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/271"},"text":"Pub. L. 91–271","children":[],"tail":" substituted reference to customs officers for reference to collectors."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1953—Act ","children":[{"tag":"date","attrib":{"date":"1953-08-08"},"text":"Aug. 8, 1953","children":[],"tail":", amended section generally by eliminating the provision continuing “naval officers of customs” as “Comptrollers of Customs”; by substituting the reference to “The Secretary of the Treasury or such officer or employee as he shall designate” for references to the comptrollers of customs; and, among other changes, substituting the provision that the verification of assessments of duties and allowances of drawbacks should be to such extent as the Secretary of the Treasury directs, for the former provision requiring such verification in all cases."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id055969f7-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id055969f8-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1970 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/271"},"text":"Pub. L. 91–271","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/271/s203"},"text":"section 203 of Pub. L. 91–271","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1500"},"text":"section 1500 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id055969f9-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1953 Amendment; Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by act ","children":[{"tag":"date","attrib":{"date":"1953-08-08"},"text":"Aug. 8, 1953","children":[],"tail":", effective on and after thirtieth day following "},{"tag":"date","attrib":{"date":"1953-08-08"},"text":"Aug. 8, 1953","children":[],"tail":", and savings provision, see notes set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1304"},"text":"section 1304 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
