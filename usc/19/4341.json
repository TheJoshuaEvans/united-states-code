{"tag":"section","attrib":{"id":"id064f1545-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4341"},"text":null,"children":[{"tag":"num","attrib":{"value":"4341"},"text":"§ 4341.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of intellectual property rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In this subchapter, the term “intellectual property rights” refers to copyrights, trademarks, and other forms of intellectual property rights that are enforced by U.S. Customs and Border Protection or U.S. Immigration and Customs Enforcement.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id064f1546-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/125/tIII/s301"},"text":"Pub. L. 114–125, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-24"},"text":"Feb. 24, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/149"},"text":"130 Stat. 149","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id064f1547-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id064f1548-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id064f1549-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in text, was in the original “this title”, meaning title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/125"},"text":"Pub. L. 114–125","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-24"},"text":"Feb. 24, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/149"},"text":"130 Stat. 149","children":[],"tail":", which is classified principally to this subchapter. For complete classification of title III to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
