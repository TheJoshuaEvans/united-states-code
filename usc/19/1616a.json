{"tag":"section","attrib":{"id":"id056a0c05-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1616a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1616a"},"text":"§ 1616a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of forfeited property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id056a0c06-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1616a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State proceedings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury may discontinue forfeiture proceedings under this chapter in favor of forfeiture under State law. If a complaint for forfeiture is filed under this chapter, the Attorney General may seek dismissal of the complaint in favor of forfeiture under State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id056a0c07-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1616a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of seized property; notice","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If forfeiture proceedings are discontinued or dismissed under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id056a0c08-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1616a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States may transfer the seized property to the appropriate State or local official; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id056a0c09-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1616a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notice of the discontinuance or dismissal shall be provided to all known interested parties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id056a0c0a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1616a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retention or transfer of forfeited property","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id056a0c0b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1616a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of the Treasury may apply property forfeited under this chapter in accordance with subparagraph (A) or (B), or both:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id056a0c0c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1616a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Retain any of the property for official use.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id056a0c0d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1616a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Transfer any of the property to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id056a0c0e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1616a/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other Federal agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id056a0c0f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1616a/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any State or local law enforcement agency that participated directly or indirectly in the seizure or forfeiture of the property; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id056a0c10-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1616a/c/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Civil Air Patrol.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id056a0c11-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1616a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may transfer any forfeited personal property or the proceeds of the sale of any forfeited personal or real property to any foreign country which participated directly or indirectly in the seizure or forfeiture of the property, if such a transfer—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id056a0c12-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1616a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been agreed to by the Secretary of State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id056a0c13-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1616a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is authorized in an international agreement between the United States and the foreign country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id056a0c14-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1616a/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is made to a country which, if applicable, has been certified under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2291j/b"},"text":"section 2291j(b) of title 22","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id056a0c15-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1616a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Aircraft may be transferred to the Civil Air Patrol under paragraph (1)(B)(iii) in support of air search and rescue and other emergency services and, pursuant to a memorandum of understanding entered into with a Federal agency, illegal drug traffic surveillance. Jet-powered aircraft may not be transferred to the Civil Air Patrol under the authority of paragraph (1)(B)(iii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id056a0c16-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1616a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability of United States after transfer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States shall not be liable in any action relating to property transferred under this section if such action is based on an act or omission occurring after the transfer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id056a0c17-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title IV, § 616, as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/573/tII/s213/a/14"},"text":"Pub. L. 98–573, title II, § 213(a)(14)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2987"},"text":"98 Stat. 2987","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/570/tI/s1863/a"},"text":"Pub. L. 99–570, title I, § 1863(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-54"},"text":"100 Stat. 3207–54","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII/s7366/a"},"text":"Pub. L. 100–690, title VII, § 7366(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4478"},"text":"102 Stat. 4478","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/207/s3/e"},"text":"Pub. L. 101–207, § 3(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-07"},"text":"Dec. 7, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1834"},"text":"103 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/447/tI/s102/c"},"text":"Pub. L. 103–447, title I, § 102(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4693"},"text":"108 Stat. 4693","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id056a0c18-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id056a0c19-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id056a0c1a-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 616 of act ","children":[{"tag":"date","attrib":{"date":"1930-06-17"},"text":"June 17, 1930","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s318"},"text":"Pub. L. 98–473, title II, § 318","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2055"},"text":"98 Stat. 2055","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1616"},"text":"section 1616 of this title","children":[],"tail":" and subsequently repealed."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id056a0c1b-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (c)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/447"},"text":"Pub. L. 103–447","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2291j/b"},"text":"section 2291j(b) of title 22","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2291/h"},"text":"section 2291(h) of title 22","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (c)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/207/s3/e/1"},"text":"Pub. L. 101–207, § 3(e)(1)","children":[],"tail":", amended subpar. (B) generally. Prior to amendment, subpar. (B) read as follows: “Transfer any of the property to any—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) other Federal agency; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) State or local law enforcement agency that participated directly or indirectly in the seizure or forfeiture of the property.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/207/s3/e/2"},"text":"Pub. L. 101–207, § 3(e)(2)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" amended subsec. (c) generally. Prior to amendment, subsec. (c) read as follows: “The Secretary of the Treasury may transfer any property forfeited under this chapter to any other Federal agency or to any State or local law enforcement agency which participated directly in the seizure or forfeiture of the property.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570"},"text":"Pub. L. 99–570","children":[],"tail":" inserted “any other Federal agency or to” after “property forfeited under this chapter to”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id056a0c1c-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id056a0c1d-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII/s7366/b"},"text":"Pub. L. 100–690, title VII, § 7366(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4479"},"text":"102 Stat. 4479","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/690/tVII/s7366/b"},"text":"“The amendment made by subsection (a) [amending this section] applies with respect to property forfeited under the Tariff Act of 1930 [this chapter] on or after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id056a0c1e-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1984-10-15"},"text":"Oct. 15, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/573/s214/e"},"text":"section 214(e) of Pub. L. 98–573","children":[],"tail":", set out as an Effective Date of 1984 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1304"},"text":"section 1304 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
