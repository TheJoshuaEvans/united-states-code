{"tag":"section","attrib":{"id":"id058905ca-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j"},"text":null,"children":[{"tag":"num","attrib":{"value":"1677j"},"text":"§ 1677j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prevention of circumvention of antidumping and countervailing duty orders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id058905cb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Merchandise completed or assembled in United States","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id058905cc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id058905cd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" merchandise sold in the United States is of the same class or kind as any other merchandise that is the subject of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id058905ce-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an antidumping duty order issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1673e"},"text":"section 1673e of this title","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id058905cf-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a finding issued under the Antidumping Act, 1921, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id058905d0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a countervailing duty order issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1671e"},"text":"section 1671e of this title","children":[],"tail":" or section 1303 "},{"tag":"ref","attrib":{"idref":"fn002057"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002057"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title,"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id058905d1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such merchandise sold in the United States is completed or assembled in the United States from parts or components produced in the foreign country with respect to which such order or finding applies,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id058905d2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the process of assembly or completion in the United States is minor or insignificant, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id058905d3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the value of the parts or components referred to in subparagraph (B) is a significant portion of the total value of the merchandise,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the administering authority, after taking into account any advice provided by the Commission under subsection (e), may include within the scope of such order or finding the imported parts or components referred to in subparagraph (B) that are used in the completion or assembly of the merchandise in the United States at any time such order or finding is in effect.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id058905d4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of whether process is minor or insignificant","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining whether the process of assembly or completion is minor or insignificant under paragraph (1)(C), the administering authority shall take into account—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id058905d5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the level of investment in the United States,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id058905d6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the level of research and development in the United States,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id058905d7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature of the production process in the United States,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id058905d8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent of production facilities in the United States, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id058905d9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the value of the processing performed in the United States represents a small proportion of the value of the merchandise sold in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id058905da-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors to consider","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining whether to include parts or components in a countervailing or antidumping duty order or finding under paragraph (1), the administering authority shall take into account such factors as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id058905db-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the pattern of trade, including sourcing patterns,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id058905dc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the manufacturer or exporter of the parts or components is affiliated with the person who assembles or completes the merchandise sold in the United States from the parts or components produced in the foreign country with respect to which the order or finding described in paragraph (1) applies, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id058905dd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether imports into the United States of the parts or components produced in such foreign country have increased after the initiation of the investigation which resulted in the issuance of such order or finding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id058905de-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Merchandise completed or assembled in other foreign countries","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id058905df-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id058905e0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" merchandise imported into the United States is of the same class or kind as any merchandise produced in a foreign country that is the subject of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id058905e1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an antidumping duty order issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1673e"},"text":"section 1673e of this title","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id058905e2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a finding issued under the Antidumping Act, 1921, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id058905e3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a countervailing duty order issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1671e"},"text":"section 1671e of this title","children":[],"tail":" or section 1303 "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title,"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id058905e4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" before importation into the United States, such imported merchandise is completed or assembled in another foreign country from merchandise which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id058905e5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is subject to such order or finding, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id058905e6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is produced in the foreign country with respect to which such order or finding applies,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id058905e7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the process of assembly or completion in the foreign country referred to in subparagraph (B) is minor or insignificant,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id058905e8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the value of the merchandise produced in the foreign country to which the antidumping duty order applies is a significant portion of the total value of the merchandise exported to the United States, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id058905e9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the administering authority determines that action is appropriate under this paragraph to prevent evasion of such order or finding,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the administering authority, after taking into account any advice provided by the Commission under subsection (e), may include such imported merchandise within the scope of such order or finding at any time such order or finding is in effect.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id058905ea-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of whether process is minor or insignificant","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining whether the process of assembly or completion is minor or insignificant under paragraph (1)(C), the administering authority shall take into account—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id058905eb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the level of investment in the foreign country,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id058905ec-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the level of research and development in the foreign country,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id058905ed-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature of the production process in the foreign country,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id058905ee-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent of production facilities in the foreign country, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id058905ef-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the value of the processing performed in the foreign country represents a small proportion of the value of the merchandise imported into the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id058905f0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors to consider","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining whether to include merchandise assembled or completed in a foreign country in a countervailing duty order or an antidumping duty order or finding under paragraph (1), the administering authority shall take into account such factors as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id058905f1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the pattern of trade, including sourcing patterns,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id058905f2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the manufacturer or exporter of the merchandise described in paragraph (1)(B) is affiliated with the person who uses the merchandise described in paragraph (1)(B) to assemble or complete in the foreign country the merchandise that is subsequently imported into the United States, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id058905f3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether imports into the foreign country of the merchandise described in paragraph (1)(B) have increased after the initiation of the investigation which resulted in the issuance of such order or finding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id058905f4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minor alterations of merchandise","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id058905f5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The class or kind of merchandise subject to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id058905f6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an investigation under this subtitle,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id058905f7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an antidumping duty order issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1673e"},"text":"section 1673e of this title","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id058905f8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a finding issued under the Antidumping Act, 1921, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id058905f9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a countervailing duty order issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1671e"},"text":"section 1671e of this title","children":[],"tail":" or section 1303 "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title,"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall include articles altered in form or appearance in minor respects (including raw agricultural products that have undergone minor processing), whether or not included in the same tariff classification.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id058905fa-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall not apply with respect to altered merchandise if the administering authority determines that it would be unnecessary to consider the altered merchandise within the scope of the investigation, order, or finding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id058905fb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Later-developed merchandise","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id058905fc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of determining whether merchandise developed after an investigation is initiated under this subtitle or section 1303 ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title (hereafter in this paragraph referred to as the “later-developed merchandise”) is within the scope of an outstanding antidumping or countervailing duty order issued under this subtitle or section 1303 "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title as a result of such investigation, the administering authority shall consider whether—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id058905fd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the later-developed merchandise has the same general physical characteristics as the merchandise with respect to which the order was originally issued (hereafter in this paragraph referred to as the “earlier product”),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id058905fe-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expectations of the ultimate purchasers of the later-developed merchandise are the same as for the earlier product,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id058905ff-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ultimate use of the earlier product and the later-developed merchandise are the same,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05890600-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the later-developed merchandise is sold through the same channels of trade as the earlier product, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05890601-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the later-developed merchandise is advertised and displayed in a manner similar to the earlier product.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The administering authority shall take into account any advice provided by the Commission under subsection (e) before making a determination under this subparagraph.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05890602-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion from orders","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The administering authority may not exclude a later-developed merchandise from a countervailing or antidumping duty order merely because the merchandise—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05890603-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is classified under a tariff classification other than that identified in the petition or the administering authority’s prior notices during the proceeding, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05890604-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permits the purchaser to perform additional functions, unless such additional functions constitute the primary use of the merchandise and the cost of the additional functions constitute more than a significant proportion of the total cost of production of the merchandise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05890605-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission advice","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05890606-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification to Commission of proposed action","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before making a determination—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05890607-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under subsection (a) with respect to merchandise completed or assembled in the United States (other than minor completion or assembly),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05890608-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under subsection (b) with respect to merchandise completed or assembled in other foreign countries, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05890609-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under subsection (d) with respect to any later-developed merchandise which incorporates a significant technological advance or significant alteration of an earlier product,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"with respect to an antidumping or countervailing duty order or finding as to which the Commission has made an affirmative injury determination, the administering authority shall notify the Commission of the proposed inclusion of such merchandise in such countervailing or antidumping order or finding. Notwithstanding any other provision of law, a decision by the administering authority regarding whether any merchandise is within a category for which notice is required under this paragraph is not subject to judicial review.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0589060a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Request for consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After receiving notice under paragraph (1), the Commission may request consultations with the administering authority regarding the inclusion. Upon the request of the Commission, the administering authority shall consult with the Commission and any such consultation shall be completed within 15 days after the date of the request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0589060b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission advice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Commission believes, after consultation under paragraph (2), that a significant injury issue is presented by the proposed inclusion, the Commission may provide written advice to the administering authority as to whether the inclusion would be inconsistent with the affirmative determination of the Commission on which the order or finding is based. If the Commission decides to provide such written advice, it shall promptly notify the administering authority of its intention to do so, and must provide such advice within 60 days after the date of notification under paragraph (1). For purposes of formulating its advice with respect to merchandise completed or assembled in the United States from parts or components produced in a foreign country, the Commission shall consider whether the inclusion of such parts or components taken as a whole would be inconsistent with its prior affirmative determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0589060c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677j/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time limits for administering authority determinations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The administering authority shall, to the maximum extent practicable, make the determinations under this section within 300 days from the date of the initiation of a countervailing duty or antidumping circumvention inquiry under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0589060d-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title VII, § 781, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tI/s1321/a"},"text":"Pub. L. 100–418, title I, § 1321(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1192"},"text":"102 Stat. 1192","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/tII/s230"},"text":"Pub. L. 103–465, title II, § 230","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4891"},"text":"108 Stat. 4891","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0589060e-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0589060f-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id05890610-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Antidumping Act, 1921, referred to in subsecs. (a)(1)(A)(ii), (b)(1)(A)(ii), and (c)(1)(C), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1921-05-27/ch14/tII"},"text":"act May 27, 1921, ch. 14, title II","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/11"},"text":"42 Stat. 11","children":[],"tail":", which was classified generally to sections 160 to 171 of this title, and was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/96/39/tI/s106/a"},"text":"Pub. L. 96–39, title I, § 106(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/193"},"text":"93 Stat. 193","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1303"},"text":"Section 1303 of this title","children":[],"tail":", referred to in subsecs. (a)(1)(A)(iii), (b)(1)(A)(iii), (c)(1)(D), and (d)(1), is defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1677/26"},"text":"section 1677(26) of this title","children":[],"tail":" to mean section 1330 as in effect on the day before "},{"tag":"date","attrib":{"date":"1995-01-01"},"text":"Jan. 1, 1995","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id05890611-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/s230/a"},"text":"Pub. L. 103–465, § 230(a)","children":[],"tail":", amended subsecs. (a) and (b) generally, to include provisions relating to whether process of assembly or completion of merchandise in United States or foreign countries is minor or insignificant."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/s230/b"},"text":"Pub. L. 103–465, § 230(b)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id05890612-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id05890613-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465"},"text":"Pub. L. 103–465","children":[],"tail":" effective, except as otherwise provided, on the date on which the WTO Agreement enters into force with respect to the United States ("},{"tag":"date","attrib":{"date":"1995-01-01"},"text":"Jan. 1, 1995","children":[],"tail":"), and applicable with respect to investigations, reviews, and inquiries initiated and petitions filed under specified provisions of this chapter after such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/s291"},"text":"section 291 of Pub. L. 103–465","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1671"},"text":"section 1671 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id05890614-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable with respect to articles entered, or withdrawn from warehouse for consumption, on or after ","children":[{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/s1337/d"},"text":"section 1337(d) of Pub. L. 100–418","children":[],"tail":", set out as an Effective Date of 1988 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1671"},"text":"section 1671 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
