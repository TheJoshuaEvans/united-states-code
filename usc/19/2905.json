{"tag":"section","attrib":{"id":"id0602a313-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2905"},"text":null,"children":[{"tag":"num","attrib":{"value":"2905"},"text":"§ 2905.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accession of state trading regimes to General Agreement on Tariffs and Trade or WTO","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0602a314-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2905/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before any major foreign country accedes, after ","children":[{"tag":"date","attrib":{"date":"1988-08-23"},"text":"August 23, 1988","children":[],"tail":", to the GATT 1947, or to the WTO Agreement, the President shall determine—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0602a315-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2905/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" whether state trading enterprises account for a significant share of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0602a316-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2905/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the exports of such major foreign country, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0602a317-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2905/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the goods of such major foreign country that are subject to competition from goods imported into such foreign country; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0602a318-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2905/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" whether such state trading enterprises—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0602a319-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2905/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unduly burden and restrict, or adversely affect, the foreign trade of the United States or the United States economy, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0602a31a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2905/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are likely to result in such a burden, restriction, or effect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0602a31b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2905/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effects of affirmative determination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If both of the determinations made under paragraphs (1) and (2) of subsection (a) with respect to a major foreign country are affirmative—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0602a31c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2905/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President shall reserve the right of the United States to withhold extension of the application of the GATT 1947 or the WTO Agreement, between the United States and such major foreign country, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0602a31d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2905/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the GATT 1947 or the WTO Agreement shall not apply between the United States and such major foreign country until—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0602a31e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2905/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such foreign country enters into an agreement with the United States providing that the state trading enterprises of such foreign country—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0602a31f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2905/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" will—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0602a320-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2905/b/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make purchases which are not for the use of such foreign country, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0602a321-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2905/b/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make sales in international trade,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":" in accordance with commercial considerations (including price, quality, availability, marketability, and transportation), and","children":[],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0602a322-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2905/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will afford United States business firms adequate opportunity, in accordance with customary practice, to compete for participation in such purchases or sales; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0602a323-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2905/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a bill submitted under subsection (c) which approves of the extension of the application of the GATT 1947 or the WTO Agreement between the United States and such major foreign country is enacted into law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0602a324-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2905/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expedited consideration of bill to approve extension","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0602a325-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2905/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President may submit to the Congress any draft of a bill which approves of the extension of the application of the GATT 1947 or the WTO Agreement between the United States and a major foreign country.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0602a326-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2905/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any draft of a bill described in paragraph (1) that is submitted by the President to the Congress shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0602a327-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2905/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be introduced by the majority leader of each House of the Congress (by request) on the first day on which such House is in session after the date such draft is submitted to the Congress; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0602a328-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2905/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be treated as an implementing bill for purposes of subsections (d), (e), (f), and (g) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2191"},"text":"section 2191 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0602a329-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2905/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall publish in the Federal Register each determination made under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0602a32a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2905/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0602a32b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2905/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “GATT 1947” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3501/1/A"},"text":"section 3501(1)(A) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0602a32c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2905/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “WTO Agreement” means the Agreement Establishing the World Trade Organization entered into on ","children":[{"tag":"date","attrib":{"date":"1994-04-15"},"text":"April 15, 1994","children":[],"tail":" and the multilateral trade agreements (as such term is defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3501/4"},"text":"section 3501(4) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0602a32d-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/tI/s1106"},"text":"Pub. L. 100–418, title I, § 1106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1133"},"text":"102 Stat. 1133","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/tVI/s621/a/4"},"text":"Pub. L. 103–465, title VI, § 621(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4993"},"text":"108 Stat. 4993","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/295/s20/f/3"},"text":"Pub. L. 104–295, § 20(f)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3529"},"text":"110 Stat. 3529","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0602a32e-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0602a32f-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0602a330-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/295"},"text":"Pub. L. 104–295","children":[],"tail":" substituted “or WTO” for “for WTO” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/s621/a/4/D"},"text":"Pub. L. 103–465, § 621(a)(4)(D)","children":[],"tail":", inserted “for WTO” after “Trade” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/s621/a/4/A"},"text":"Pub. L. 103–465, § 621(a)(4)(A)","children":[],"tail":", substituted “the GATT 1947, or to the WTO Agreement,” for “the GATT” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/s621/a/4/B"},"text":"Pub. L. 103–465, § 621(a)(4)(B)","children":[],"tail":", inserted “1947 or the WTO Agreement” after “the GATT” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/s621/a/4/C"},"text":"Pub. L. 103–465, § 621(a)(4)(C)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0602a331-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0602a332-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465"},"text":"Pub. L. 103–465","children":[],"tail":" effective on the date on which the WTO Agreement enters into force with respect to the United States ("},{"tag":"date","attrib":{"date":"1995-01-01"},"text":"Jan. 1, 1995","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/s621/b"},"text":"section 621(b) of Pub. L. 103–465","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1677k"},"text":"section 1677k of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id0602a333-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id0602a334-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of certain functions of President under this section to United States Trade Representative, see section 1–101 of Ex. Ord. No. 12661, ","children":[{"tag":"date","attrib":{"date":"1988-12-27"},"text":"Dec. 27, 1988","children":[],"tail":", 54 F.R. 779, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2901"},"text":"section 2901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0602a335-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Presidential Documents Regarding State Trading Enterprises","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The following presidential documents related to determinations under subsec. (a) of this section:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"China","children":[],"tail":".—Memorandum of President of the United States, "},{"tag":"date","attrib":{"date":"2001-11-09"},"text":"Nov. 9, 2001","children":[],"tail":", 66 F.R. 57357."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Russia","children":[],"tail":".—Memorandum of President of the United States, "},{"tag":"date","attrib":{"date":"2011-12-15"},"text":"Dec. 15, 2011","children":[],"tail":", 76 F.R. 79023."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Saudi Arabia","children":[],"tail":".—Memorandum of President of the United States, "},{"tag":"date","attrib":{"date":"2005-11-10"},"text":"Nov. 10, 2005","children":[],"tail":", 70 F.R. 69419."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Taiwan, Penghu, Kinmen, and Matsu","children":[],"tail":".—Memorandum of President of the United States, "},{"tag":"date","attrib":{"date":"2001-11-09"},"text":"Nov. 9, 2001","children":[],"tail":", 66 F.R. 57359."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Ukraine","children":[],"tail":".—Determination of President of the United States, No. 2008–17, "},{"tag":"date","attrib":{"date":"2008-03-28"},"text":"Mar. 28, 2008","children":[],"tail":", 73 F.R. 17879."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Vietnam","children":[],"tail":".—Memorandum of President of the United States, "},{"tag":"date","attrib":{"date":"2006-11-06"},"text":"Nov. 6, 2006","children":[],"tail":", 71 F.R. 66223."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
