{"tag":"section","attrib":{"id":"id05013851-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s58a"},"text":null,"children":[{"tag":"num","attrib":{"value":"58a"},"text":"§ 58a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees for services of customs officers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary may charge such fees as may be necessary to cover the costs of providing services similar to or the same as services furnished by customs officers under the sections repealed by subsection (a).","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id05013852-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/410/tII/s214/b"},"text":"Pub. L. 95–410, title II, § 214(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-03"},"text":"Oct. 3, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/904"},"text":"92 Stat. 904","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05013853-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05013854-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id05013855-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The sections repealed by subsection (a), referred to in text, means the sections repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/410/s214/a"},"text":"Pub. L. 95–410, § 214(a)","children":[],"tail":", which provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/410/s214/a"},"text":"“Sections 2654, 4381, 4382, and 4383 of the Revised Statutes of the United States (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s58"},"text":"19 U.S.C. 58","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s329"},"text":"46 U.S.C. 329","children":[],"tail":", 330, and 333) are each repealed.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
