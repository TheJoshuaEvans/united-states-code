{"tag":"section","attrib":{"id":"id05144bae-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s339"},"text":null,"children":[{"tag":"num","attrib":{"value":"339"},"text":"§ 339.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction on consular certificates","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No consular officer of the United States shall grant a certificate for merchandise shipped from countries adjacent to the United States, which have passed a consulate after purchase for shipment.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id05144baf-3a70-11f1-8ace-823fb135378d"},"text":"(R.S. § 2861.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05144bb0-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05144bb1-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id05144bb2-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 2861 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1873-02-22/ch184/s3"},"text":"act Feb. 22, 1873, ch. 184, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/17/474"},"text":"17 Stat. 474","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
