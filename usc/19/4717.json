{"tag":"section","attrib":{"id":"id065fb6e1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4717"},"text":null,"children":[{"tag":"num","attrib":{"value":"4717"},"text":"§ 4717.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The head of any Federal agency described in this part, in consultation with the Interagency Environment Committee, may prescribe such regulations as are necessary to carry out the authorities of the Federal agency as provided for under this part.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id065fb6e2-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113/tVIII/s817"},"text":"Pub. L. 116–113, title VIII, § 817","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-01-29"},"text":"Jan. 29, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/95"},"text":"134 Stat. 95","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
