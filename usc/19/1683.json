{"tag":"section","attrib":{"id":"id058b76b6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683"},"text":null,"children":[{"tag":"num","attrib":{"value":"1683"},"text":"§ 1683.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subtitle:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id058b76b7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “appropriate congressional committees” means the Committee on Finance of the Senate and the Committee on Ways and Means of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id058b76b8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Country of export","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “country of export” means the country (including any political subdivision of the country) from which softwood lumber or a softwood lumber product is exported before entering the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id058b76b9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Customs laws of the United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “customs laws of the United States” means any law or regulation enforced or administered by U.S. Customs and Border Protection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id058b76ba-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Export charges","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “export charges” means any tax, charge, or other fee collected by the country from which softwood lumber or a softwood lumber product, described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1683b/a"},"text":"section 1683b(a) of this title","children":[],"tail":", is exported pursuant to an international agreement entered into by that country and the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id058b76bb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Export price","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id058b76bc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “export price” means one of the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id058b76bd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of softwood lumber or a softwood lumber product that has undergone only primary processing, the value that would be determined F.O.B. at the facility where the product underwent the last primary processing before export.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id058b76be-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id058b76bf-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683/5/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of softwood lumber or a softwood lumber product described in subclause (II), the value that would be determined F.O.B. at the facility where the lumber or product underwent the last primary processing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id058b76c0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683/5/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Softwood lumber or a softwood lumber product described in this subclause is lumber or a product that underwent the last remanufacturing before export by a manufacturer who—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id058b76c1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683/5/A/ii/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not hold tenure rights provided by the country of export;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id058b76c2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683/5/A/ii/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" did not acquire standing timber directly from the country of export; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id058b76c3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683/5/A/ii/II/cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"cc"},"text":"(cc)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not related to the person who holds tenure rights or acquired standing timber directly from the country of export.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id058b76c4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683/5/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id058b76c5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683/5/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of softwood lumber or a softwood lumber product described in subclause (II), the value that would be determined F.O.B. at the facility where the product underwent the last processing before export.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id058b76c6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683/5/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Softwood lumber or a softwood lumber product described in this subclause is lumber or a product that undergoes the last remanufacturing before export by a manufacturer who—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id058b76c7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683/5/A/iii/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" holds tenure rights provided by the country of export;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id058b76c8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683/5/A/iii/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquired standing timber directly from the country of export; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id058b76c9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683/5/A/iii/II/cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"cc"},"text":"(cc)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is related to a person who holds tenure rights or acquired standing timber directly from the country of export.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id058b76ca-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Related persons","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this paragraph, a person is related to another person if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id058b76cb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person bears a relationship to such other person described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s152/a"},"text":"section 152(a) of title 26","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id058b76cc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person bears a relationship to such other person described in section 267(b) of such title, except that “5 percent” shall be substituted for “50 percent” each place it appears;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id058b76cd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683/5/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person and such other person are part of a controlled group of corporations, as that term is defined in section 1563(a) of such title, except that “5 percent” shall be substituted for “80 percent” each place it appears;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id058b76ce-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683/5/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person is an officer or director of such other person; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id058b76cf-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683/5/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person is the employer of such other person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id058b76d0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tenure rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this paragraph, the term “tenure rights” means rights to harvest timber from public land granted by the country of export.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id058b76d1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Export price where F.O.B. value cannot be determined","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id058b76d2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683/5/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of softwood lumber or a softwood lumber product described in clause (i), (ii), or (iii) of subparagraph (A) for which an F.O.B. value cannot be determined, the export price shall be the market price for the identical lumber or product sold in an arm’s-length transaction in the country of export at approximately the same time as the exported lumber or product. The market price shall be determined in the following order of preference:","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id058b76d3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683/5/D/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The market price for the lumber or a product sold at substantially the same level of trade as the exported lumber or product but in different quantities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id058b76d4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683/5/D/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The market price for the lumber or a product sold at a different level of trade than the exported lumber or product but in similar quantities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id058b76d5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683/5/D/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The market price for the lumber or a product sold at a different level of trade than the exported lumber or product and in different quantities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id058b76d6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683/5/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Level of trade","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of clause (i), “level of trade” shall be determined in the same manner as provided under section 351.412(c) of title 19, Code of Federal Regulations (as in effect on ","children":[{"tag":"date","attrib":{"date":"2008-01-01"},"text":"January 1, 2008","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id058b76d7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" F.O.B.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “F.O.B.” means a value consisting of all charges payable by a purchaser, including those charges incurred in the placement of merchandise on board of a conveyance for shipment, but does not include the actual shipping charges or any applicable export charges.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id058b76d8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" HTS","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “HTS” means the Harmonized Tariff Schedule of the United States (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1202"},"text":"19 U.S.C. 1202","children":[],"tail":") (as in effect on "},{"tag":"date","attrib":{"date":"2008-01-01"},"text":"January 1, 2008","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id058b76d9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “person” includes any individual, partnership, corporation, association, organization, business trust, government entity, or other entity subject to the jurisdiction of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id058b76da-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “United States” means the customs territory of the United States, as defined in General Note 2 of the HTS.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id058b76db-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title VIII, § 802, as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/tIII/s3301/a"},"text":"Pub. L. 110–246, title III, § 3301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1844"},"text":"122 Stat. 1844","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id058b76dc-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id058b76dd-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id058b76de-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Harmonized Tariff Schedule of the United States, referred to in par. (7), is not set out in the Code. See Publication of Harmonized Tariff Schedule note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1202"},"text":"section 1202 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id058b76df-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 802 of act ","children":[{"tag":"date","attrib":{"date":"1930-06-17"},"text":"June 17, 1930","children":[],"tail":", is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1681a"},"text":"section 1681a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id058b76e0-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id058b76e1-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/tIII/s3301/b"},"text":"Pub. L. 110–246, title III, § 3301(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1853"},"text":"122 Stat. 1853","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/246/tIII/s3301/b"},"text":"“The amendments made by this section [enacting this subtitle] shall take effect on the date that is 60 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
