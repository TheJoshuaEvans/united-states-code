{"tag":"section","attrib":{"id":"id0610fb1b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3553"},"text":null,"children":[{"tag":"num","attrib":{"value":"3553"},"text":"§ 3553.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership in WTO of boycotting countries","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It is the sense of the Congress that the Trade Representative should vigorously oppose the admission into the World Trade Organization of any country which, through its laws, regulations, official policies, or governmental practices, fosters, imposes, complies with, furthers, or supports any boycott described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4607/a"},"text":"section 4607(a) of title 50","children":[],"tail":" (as in effect on "},{"tag":"date","attrib":{"date":"1994-08-20"},"text":"August 20, 1994","children":[],"tail":"), including requiring or encouraging entities within that country to refuse to do business with persons who do not comply with requests to take any action prohibited under that section."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0610fb1c-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/tI/s133"},"text":"Pub. L. 103–465, title I, § 133","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4839"},"text":"108 Stat. 4839","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0610fb1d-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0610fb1e-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0610fb1f-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4607/a"},"text":"Section 4607(a) of title 50","children":[],"tail":" (as in effect on "},{"tag":"date","attrib":{"date":"1994-08-20"},"text":"August 20, 1994","children":[],"tail":"), referred to in text, means "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4607/a"},"text":"section 4607(a) of Title 50","children":[],"tail":", War and National Defense, prior to its repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tXVII/s1766/a"},"text":"Pub. L. 115–232, div. A, title XVII, § 1766(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2232"},"text":"132 Stat. 2232","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
