{"tag":"section","attrib":{"id":"id0640bcc7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4031"},"text":null,"children":[{"tag":"num","attrib":{"value":"4031"},"text":"§ 4031.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tariff modifications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0640bcc8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4031/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tariff modifications provided for in the Agreement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0640bcc9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4031/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proclamation authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President may proclaim—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0640bcca-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4031/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such modifications or continuation of any duty,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0640bccb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4031/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such continuation of duty-free or excise treatment, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0640bccc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4031/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such additional duties,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"as the President determines to be necessary or appropriate to carry out or apply articles 3.3, 3.5, 3.6, 3.21, 3.26, 3.27, and 3.28, and Annexes 3.3, 3.27, and 3.28 of the Agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0640bccd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4031/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on GSP status","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding section 502(a)(1) of the Trade Act of 1974 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2462/a/1"},"text":"19 U.S.C. 2462(a)(1)","children":[],"tail":"), the President shall terminate the designation of each CAFTA–DR country as a beneficiary developing country for purposes of title V of the Trade Act of 1974 ["},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2461"},"text":"19 U.S.C. 2461","children":[],"tail":" et seq.] on the date the Agreement enters into force with respect to that country."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0640bcce-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4031/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on CBERA status","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0640bccf-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4031/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding section 212(a) of the Caribbean Basin Economic Recovery Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2702/a"},"text":"19 U.S.C. 2702(a)","children":[],"tail":"), the President shall terminate the designation of each CAFTA–DR country as a beneficiary country for purposes of that Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2701"},"text":"19 U.S.C. 2701","children":[],"tail":" et seq.] on the date the Agreement enters into force with respect to that country."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0640bcd0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4031/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding subparagraph (A), each such country shall be considered a beneficiary country under section 212(a) of the Caribbean Basin Economic Recovery Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2702/a"},"text":"19 U.S.C. 2702(a)","children":[],"tail":"], for purposes of—"}],"tail":null},{"tag":"clause","attrib":{"id":"id0640bcd1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4031/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sections 1677(7)(G)(ii)(III) and 1677(7)(H) of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0640bcd2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4031/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the duty-free treatment provided under paragraph 12 of Appendix I of the General Notes to the Schedule of the United States to Annex 3.3 of the Agreement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0640bcd3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4031/a/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s274/h/6/B"},"text":"section 274(h)(6)(B) of title 26","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0640bcd4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4031/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other tariff modifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the consultation and layover provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4014"},"text":"section 4014 of this title","children":[],"tail":", the President may proclaim—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0640bcd5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4031/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such modifications or continuation of any duty,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0640bcd6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4031/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such modifications as the United States may agree to with a CAFTA–DR country regarding the staging of any duty treatment set forth in Annex 3.3 of the Agreement,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0640bcd7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4031/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such continuation of duty-free or excise treatment, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0640bcd8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4031/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such additional duties,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"as the President determines to be necessary or appropriate to maintain the general level of reciprocal and mutually advantageous concessions provided for by the Agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0640bcd9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4031/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conversion to ad valorem rates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subsections (a) and (b), with respect to any good for which the base rate in the Schedule of the United States to Annex 3.3 of the Agreement is a specific or compound rate of duty, the President may substitute for the base rate an ad valorem rate that the President determines to be equivalent to the base rate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0640bcda-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/53/tII/s201"},"text":"Pub. L. 109–53, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-02"},"text":"Aug. 2, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/467"},"text":"119 Stat. 467","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0640bcdb-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id0640bcdc-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination of section by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/53/s107/d"},"text":"section 107(d) of Pub. L. 109–53","children":[],"tail":", see Effective and Termination Dates note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0640bcdd-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0640bcde-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Trade Act of 1974, referred to in subsec. (a)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618"},"text":"Pub. L. 93–618","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1978"},"text":"88 Stat. 1978","children":[],"tail":". Title V of the Act is classified generally to subchapter V (§ 2461 et seq.) of chapter 12 of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2101"},"text":"section 2101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Caribbean Basin Economic Recovery Act, referred to in subsec. (a)(3)(A), is title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/67"},"text":"Pub. L. 98–67","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-05"},"text":"Aug. 5, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/384"},"text":"97 Stat. 384","children":[],"tail":", which is classified principally to chapter 15 (§ 2701 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2701"},"text":"section 2701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0640bcdf-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0640bce0-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective and Termination Dates","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date the Dominican Republic-Central America-United States Free Trade Agreement enters into force (","children":[{"tag":"date","attrib":{"date":"2006-03-01"},"text":"Mar. 1, 2006","children":[],"tail":") and to cease to have effect on the date the Agreement ceases to be in force with respect to the United States, and, during any period in which a country ceases to be a CAFTA–DR country, to cease to have effect with respect to such country, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/53/s107"},"text":"section 107 of Pub. L. 109–53","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s4001"},"text":"section 4001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
