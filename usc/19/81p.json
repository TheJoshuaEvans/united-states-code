{"tag":"section","attrib":{"id":"id050f690d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s81p"},"text":null,"children":[{"tag":"num","attrib":{"value":"81p"},"text":"§ 81p.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accounts and recordkeeping","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id050f690e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s81p/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manner of keeping accounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The form and manner of keeping the accounts of each zone shall be prescribed by the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id050f690f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s81p/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report by grantee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each grantee shall make to the Board annually, and at such other times as it may prescribe, reports on zone operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id050f6910-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s81p/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall make a report to Congress annually containing a summary of zone operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id050f6911-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-18/ch590/s16"},"text":"June 18, 1934, ch. 590, § 16","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/1002"},"text":"48 Stat. 1002","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/609/tII/s204"},"text":"Pub. L. 96–609, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-28"},"text":"Dec. 28, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3561"},"text":"94 Stat. 3561","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/386/tII/s203/b"},"text":"Pub. L. 99–386, title II, § 203(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-22"},"text":"Aug. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/823"},"text":"100 Stat. 823","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id050f6912-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id050f6913-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id050f6914-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/386/s203/b/1"},"text":"Pub. L. 99–386, § 203(b)(1)","children":[],"tail":", substituted “reports on zone operations” for “reports containing a full statement of all the operations, receipts, and expenditures, and such other information as the Board may require”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/386/s203/b/2"},"text":"Pub. L. 99–386, § 203(b)(2)","children":[],"tail":", added subsec. (c) and struck out former subsec. (c) which required the Board to make an annual report to Congress containing a summary of the operation and fiscal condition of each zone, and transmit copies of the annual report of each grantee."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/609"},"text":"Pub. L. 96–609","children":[],"tail":" substituted “by April 1 of each year” for “on the first day of each regular session”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
