{"tag":"section","attrib":{"id":"id05275dfa-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1322"},"text":null,"children":[{"tag":"num","attrib":{"value":"1322"},"text":"§ 1322.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International traffic and rescue work; United States-Mexico Boundary Treaty of 1970","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05275dfb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1322/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vehicles and other instruments of international traffic except communications satellites","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Vehicles and other instruments of international traffic, of any class specified by the Secretary of the Treasury, shall be excepted from the application of the customs laws to such extent and subject to such terms and conditions as may be prescribed in regulations or instructions of the Secretary of the Treasury. The authority delegated to the Secretary by this subsection shall not extend to communications satellites and components and parts thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05275dfc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1322/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rescue and relief equipment; personal property related to use of land under United States-Mexico Boundary Treaty of 1970; forfeit of articles to United States","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Treasury may provide by regulation or instruction for the admission, without entry and without the payment of any duty or tax imposed upon or by reason of importation, of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05275dfd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1322/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aircraft, equipment, supplies, and spare parts for use in searches, rescues, investigations, repairs, and salvage in connection with accidental damage to aircraft;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05275dfe-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1322/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fire-fighting and rescue and relief equipment and supplies for emergent temporary use in connection with conflagrations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05275dff-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1322/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rescue and relief equipment and supplies for emergent temporary use in connection with floods and other disasters; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05275e00-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1322/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" personal property related to the use and enjoyment of a separated tract of land as described in article III of the Treaty To Resolve Pending Boundary Differences and Maintain the Rio Grande and Colorado Rivers as the International Boundary between the United States of America and the United Mexican States signed on ","children":[{"tag":"date","attrib":{"date":"1970-11-23"},"text":"November 23, 1970","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Any articles admitted under the authority of this subsection and used otherwise than for a purpose herein expressed, or not exported in such time and manner as may be prescribed in the regulations or instructions herein authorized, shall be forfeited to the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05275e01-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title III, § 322, as added "},{"tag":"ref","attrib":{"href":"/us/act/1953-08-08/ch397/s14"},"text":"Aug. 8, 1953, ch. 397, § 14","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/67/516"},"text":"67 Stat. 516","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/92/549/tI/s107"},"text":"Pub. L. 92–549, title I, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-25"},"text":"Oct. 25, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1162"},"text":"86 Stat. 1162","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/573/tI"},"text":"Pub. L. 98–573, title I","children":[],"tail":", §§ 124(c), 127(b), "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2959"},"text":"98 Stat. 2959","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05275e02-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05275e03-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id05275e04-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/573/s127/b"},"text":"Pub. L. 98–573, § 127(b)","children":[],"tail":", substituted “excepted” for “granted the customary exceptions”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/573/s124/c"},"text":"Pub. L. 98–573, § 124(c)","children":[],"tail":", inserted “The authority delegated to the Secretary by this subsection shall not extend to communications satellites and components and parts thereof.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/549/s107/a"},"text":"Pub. L. 92–549, § 107(a)","children":[],"tail":", inserted “United States-Mexico Boundary Treaty of 1970” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/549/s107/b"},"text":"Pub. L. 92–549, § 107(b)","children":[],"tail":", added cl. (4)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id05275e05-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id05275e06-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/573/tI/s195/a"},"text":"Pub. L. 98–573, title I, § 195(a)","children":[],"tail":", (b), (d), "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2972"},"text":"98 Stat. 2972","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/573/tI/s195/a"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in section 126 and in subsections (b) and (c), the amendments made by subtitles B, C, and D [amending this section and sections 1202 and 1504 of this title] shall apply with respect to articles entered on or after the 15th day after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amendment made by sections 117 and 124 [amending this section] shall apply with respect to articles entered on or after ","children":[{"tag":"date","attrib":{"date":"1985-01-01"},"text":"January 1, 1985","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amendments made by section 127 [amending this section] shall apply with respect to articles entered on or after a date to be proclaimed by the President which shall be consonant with the entering into force for the United States of the Customs Convention on Containers, 1972.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘entered’ means entered, or withdrawn from warehouse for consumption in the customs territory of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘entry’ includes any withdrawal from warehouse.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id05275e07-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on and after thirtieth day following ","children":[{"tag":"date","attrib":{"date":"1953-08-08"},"text":"Aug. 8, 1953","children":[],"tail":", see note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1304"},"text":"section 1304 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
