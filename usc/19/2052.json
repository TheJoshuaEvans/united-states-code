{"tag":"section","attrib":{"id":"id059513a5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2052"},"text":null,"children":[{"tag":"num","attrib":{"value":"2052"},"text":"§ 2052.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance from other Federal agencies; facilities and personnel","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Agencies of the Federal Government are authorized to furnish facilities and personnel for the purpose of assisting the agency or agencies designated by the President in carrying out the provisions of the Agreement.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id05975d96-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/634/s2"},"text":"Pub. L. 89–634, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-08"},"text":"Oct. 8, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/879"},"text":"80 Stat. 879","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
