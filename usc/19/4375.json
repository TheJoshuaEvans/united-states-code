{"tag":"section","attrib":{"id":"id06515ef2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4375"},"text":null,"children":[{"tag":"num","attrib":{"value":"4375"},"text":"§ 4375.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trade negotiating objectives","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The principal negotiating objectives of the United States shall include obtaining the objectives of the bilateral agreements described under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4374/a"},"text":"section 4374(a) of this title","children":[],"tail":" for any trade agreements under negotiation as of "},{"tag":"date","attrib":{"date":"2016-02-24"},"text":"February 24, 2016","children":[],"tail":", or future trade agreement negotiations."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id06515ef3-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/125/tIV/s415"},"text":"Pub. L. 114–125, title IV, § 415","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-24"},"text":"Feb. 24, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/161"},"text":"130 Stat. 161","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
