{"tag":"section","attrib":{"id":"id050f68d9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s81f"},"text":null,"children":[{"tag":"num","attrib":{"value":"81f"},"text":"§ 81f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application for establishment and expansion of zone","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id050f68da-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s81f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application for establishment; requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each application shall state in detail—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id050f68db-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s81f/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The location and qualifications of the area in which it is proposed to establish a zone, showing (A) the land and water or land or water area or land area alone if the application is for its establishment in or adjacent to an interior port; (B) the means of segregation from customs territory; (C) the fitness of the area for a zone; and (D) the possibilities of expansion of the zone area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id050f68dc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s81f/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The facilities and appurtenances which it is proposed to provide and the preliminary plans and estimate of the cost thereof, and the existing facilities and appurtenances which it is proposed to utilize;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id050f68dd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s81f/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The time within which the applicant proposes to commence and complete the construction of the zone and facilities and appurtenances;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id050f68de-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s81f/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The methods proposed to finance the undertaking;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id050f68df-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s81f/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other information as the Board may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id050f68e0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s81f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendment of application; expansion of zone","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board may upon its own initiative or upon request permit the amendment of the application. Any expansion of the area of an established zone shall be made and approved in the same manner as an original application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id050f68e1-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-18/ch590/s6"},"text":"June 18, 1934, ch. 590, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/1000"},"text":"48 Stat. 1000","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
