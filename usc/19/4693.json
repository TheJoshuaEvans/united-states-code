{"tag":"section","attrib":{"id":"id065d4660-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4693"},"text":null,"children":[{"tag":"num","attrib":{"value":"4693"},"text":"§ 4693.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final remedies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id065d4661-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4693/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a rapid response labor panel constituted in accordance with Annex 31–A of the USMCA determines with respect to a case that there has been a denial of rights within the meaning of such Annex, the Trade Representative may, in consultation with the appropriate congressional committees—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id065d4662-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4693/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" direct the Secretary of the Treasury, until the date of the notification described in subsection (b) and in accordance with Annex 31–A of the USMCA—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id065d4663-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4693/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id065d4664-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4693/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deny entry to goods, produced wholly or in part, from any covered facility involved in such case; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id065d4665-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4693/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow for the release of goods, produced wholly or in part, from such covered facilities only upon payment of duties and any penalty; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id065d4666-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4693/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to apply any duties or penalties to customs entries for which liquidation was suspended pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4692"},"text":"section 4692 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065d4667-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4693/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" apply other remedies that are appropriate and available under Annex 31–A of the USMCA, until the denial of rights with respect to the case has been remedied.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id065d4668-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4693/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remediation notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Trade Representative shall promptly notify the Secretary when the denial of rights with respect to a case described in subsection (a) has been remedied.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id065d4669-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113/tVII/s753"},"text":"Pub. L. 116–113, title VII, § 753","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-01-29"},"text":"Jan. 29, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/90"},"text":"134 Stat. 90","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
