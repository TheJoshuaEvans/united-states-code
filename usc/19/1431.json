{"tag":"section","attrib":{"id":"id0537ff8e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1431"},"text":null,"children":[{"tag":"num","attrib":{"value":"1431"},"text":"§ 1431.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manifests","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0537ff8f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1431/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Every vessel required to make entry under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1434"},"text":"section 1434 of this title","children":[],"tail":" or obtain clearance under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s60105"},"text":"section 60105 of title 46","children":[],"tail":" shall have a manifest that complies with the requirements prescribed under subsection (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0537ff90-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1431/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Production of manifest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any manifest required by the Customs Service shall be signed, produced, delivered or electronically transmitted by the master or person in charge of the vessel, aircraft, or vehicle, or by any other authorized agent of the owner or operator of the vessel, aircraft, or vehicle in accordance with the requirements prescribed under subsection (d). A manifest may be supplemented by bill of lading data supplied by the issuer of such bill. If any irregularity of omission or commission occurs in any way in respect to any manifest or bill of lading data, the owner or operator of the vessel, aircraft or vehicle, or any party responsible for such irregularity, shall be liable for any fine or penalty prescribed by law with respect to such irregularity. The Customs Service may take appropriate action against any of the parties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0537ff91-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1431/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public disclosure of certain manifest information","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0537ff92-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1431/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in subparagraph (2), the following information, when contained in a vessel vessel ","children":[{"tag":"ref","attrib":{"idref":"fn002014"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002014"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" or aircraft manifest, shall be available for public disclosure:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0537ff93-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1431/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The name and address of each importer or consignee and the name and address of the shipper to such importer or consignee, unless the importer or consignee has made a biennial certification, in accordance with procedures adopted by the Secretary of the Treasury, claiming confidential treatment of such information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0537ff94-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1431/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The general character of the cargo.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0537ff95-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1431/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of packages and gross weight.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0537ff96-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1431/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The name of the vessel, aircraft, or carrier.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0537ff97-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1431/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The seaport or airport of loading.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0537ff98-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1431/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The seaport or airport of discharge.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0537ff99-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1431/c/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The country of origin of the shipment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0537ff9a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1431/c/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The trademarks appearing on the goods or packages.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0537ff9b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1431/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0537ff9c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1431/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The information listed in paragraph (1) shall not be available for public disclosure if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0537ff9d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1431/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Treasury makes an affirmative finding on a shipment-by-shipment basis that disclosure is likely to pose a threat of personal injury or property damage; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0537ff9e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1431/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information is exempt under the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b/1"},"text":"section 552(b)(1) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0537ff9f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1431/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall ensure that any personally identifiable information, including Social Security numbers and passport numbers, is removed from any manifest signed, produced, delivered, or electronically transmitted under this section before access to the manifest is provided to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0537ffa0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1431/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Treasury, in order to allow for the timely dissemination and publication of the information listed in paragraph (1), shall establish procedures to provide access to manifests. Such procedures shall include provisions for adequate protection against the public disclosure of information not available for public disclosure from such manifests.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0537ffa1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1431/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0537ffa2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1431/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall by regulation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0537ffa3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1431/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify the form for, and the information and data that must be contained in, the manifest required by subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0537ffa4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1431/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow, at the option of the individual producing the manifest and subject to paragraph (2), letters and documents shipments to be accounted for by summary manifesting procedures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0537ffa5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1431/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribe the manner of production for, and the delivery for electronic transmittal of, the manifest required by subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0537ffa6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1431/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribe the manner for supplementing manifests with bill of lading data under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0537ffa7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1431/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Letters and documents shipments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1)(B)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0537ffa8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1431/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Customs Service may require with respect to letters and documents shipments—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0537ffa9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1431/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that they be segregated by country of origin, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0537ffaa-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1431/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" additional examination procedures that are not necessary for individually manifested shipments;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0537ffab-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1431/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" standard letter envelopes and standard document packs shall be segregated from larger document shipments for purposes of customs inspections; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0537ffac-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1431/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “letters and documents” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0537ffad-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1431/d/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data described in General Headnote 4(c) of the Harmonized Tariff Schedule of the United States,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0537ffae-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1431/d/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" securities and similar evidences of value described in heading 4907 of such Schedule, but not monetary instruments defined pursuant to chapter 53 of title 31, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0537ffaf-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1431/d/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" personal correspondence, whether on paper, cards, photographs, tapes, or other media.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0537ffb0-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title IV, § 431, "},{"tag":"ref","attrib":{"href":"/us/stat/46/710"},"text":"46 Stat. 710","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1953-08-08/ch397/s15"},"text":"Aug. 8, 1953, ch. 397, § 15","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/67/516"},"text":"67 Stat. 516","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/573/tII/s203"},"text":"Pub. L. 98–573, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2974"},"text":"98 Stat. 2974","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII/s7367/c/1"},"text":"Pub. L. 100–690, title VII, § 7367(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4479"},"text":"102 Stat. 4479","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/182/tVI/s635"},"text":"Pub. L. 103–182, title VI, § 635","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-08"},"text":"Dec. 8, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2199"},"text":"107 Stat. 2199","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/153/s11"},"text":"Pub. L. 104–153, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-07-02"},"text":"July 2, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1389"},"text":"110 Stat. 1389","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/295/s3/a/3"},"text":"Pub. L. 104–295, § 3(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3515"},"text":"110 Stat. 3515","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/39/s2/a"},"text":"Pub. L. 118–39, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-02-09"},"text":"Feb. 9, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/16"},"text":"138 Stat. 16","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0537ffb1-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0537ffb2-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0537ffb3-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Harmonized Tariff Schedule of the United States, referred to in subsec. (d)(2)(C)(i), (ii), is not set out in the Code. See Publication of Harmonized Tariff Schedule note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1202"},"text":"section 1202 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0537ffb4-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (a), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s60105"},"text":"section 60105 of title 46","children":[],"tail":"” substituted for “section 4197 of the Revised Statutes of the United States (46 U.S.C. App. 91)” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/109/304/s18/c"},"text":"Pub. L. 109–304, § 18(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1709"},"text":"120 Stat. 1709","children":[],"tail":", which Act enacted "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s60105"},"text":"section 60105 of Title 46","children":[],"tail":", Shipping."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0537ffb5-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"R.S. §§ 2806, 2807 (as amended by ","children":[{"tag":"ref","attrib":{"href":"/us/act/1902-06-03/ch86/s1"},"text":"act June 3, 1902, ch. 86, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/27/41"},"text":"27 Stat. 41","children":[],"tail":"), and 2808, requiring manifests, and prescribing their contents, were superseded by "},{"tag":"ref","attrib":{"href":"/us/act/1922-09-21/ch356/tIV/s431"},"text":"act Sept. 21, 1922, ch. 356, title IV, § 431","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/950"},"text":"42 Stat. 950","children":[],"tail":", and repealed by section 642 thereof. Section 431 of the 1922 act was superseded by section 431 of act "},{"tag":"date","attrib":{"date":"1930-06-17"},"text":"June 17, 1930","children":[],"tail":", comprising this section, and repealed by section 651(a)(1) of the 1930 act."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 2805, relative to the administration of oaths required by that chapter, was superseded to a great extent by the Customs Administrative ","children":[{"tag":"ref","attrib":{"href":"/us/act/1890-06-10/ch407/s22"},"text":"Act of June 10, 1890, ch. 407, § 22","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/26/140"},"text":"26 Stat. 140","children":[],"tail":", amended by the Payne-Aldrich Tariff "},{"tag":"ref","attrib":{"href":"/us/act/1909-08-05/ch6/s28"},"text":"Act of Aug. 5, 1909, ch. 6, § 28","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/102"},"text":"36 Stat. 102","children":[],"tail":", and by the Underwood Tariff "},{"tag":"ref","attrib":{"href":"/us/act/1913-10-03/ch16"},"text":"Act of Oct. 3, 1913, ch. 16","children":[],"tail":", § IV, S., "},{"tag":"ref","attrib":{"href":"/us/stat/38/201"},"text":"38 Stat. 201","children":[],"tail":", which abolished all oaths administered by officers of the customs, except as provided in those acts and repealed by "},{"tag":"ref","attrib":{"href":"/us/act/1922-09-21/ch356/tIV/s642"},"text":"act Sept. 21, 1922, ch. 356, title IV, § 642","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/989"},"text":"42 Stat. 989","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0537ffb6-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/39"},"text":"Pub. L. 118–39","children":[],"tail":" amended par. (2) generally. Prior to amendment, par. (2) read as follows: “The information listed in paragraph (1) shall not be available for public disclosure if—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) the Secretary of the Treasury makes an affirmative finding on a shipment-by-shipment basis that disclosure is likely to pose a threat of personal injury or property damage; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) the information is exempt under the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b/1"},"text":"section 552(b)(1) of title 5","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/295"},"text":"Pub. L. 104–295","children":[],"tail":" substituted “a vessel manifest” for “such manifest” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/153"},"text":"Pub. L. 104–153","children":[],"tail":" inserted “vessel or aircraft” before “manifest” in introductory provisions, amended subpars. (D) to (F) generally, substituting “vessel, aircraft, or carrier” for “vessel or carrier” in subpar. (D) and “seaport or airport” for “port” in subpars. (E) and (F), and added subpar. (H)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsecs. (a) and (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/182/s635/1"},"text":"Pub. L. 103–182, § 635(1)","children":[],"tail":", amended subsecs. (a) and (b) generally, substituting present provisions for provisions relating to, in subsec. (a), the requirement, form, and contents of manifests and, in subsec. (b), the signing and delivery of manifests."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/182/s635/2"},"text":"Pub. L. 103–182, § 635(2)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (c)(1)(G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" substituted “country of origin” for “country or origin”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/573/s203/1"},"text":"Pub. L. 98–573, § 203(1)","children":[],"tail":", inserted “; and the names of the shippers of such merchandise” in par. Third."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/573/s203/2"},"text":"Pub. L. 98–573, § 203(2)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1953—Act ","children":[{"tag":"date","attrib":{"date":"1953-08-08"},"text":"Aug. 8, 1953","children":[],"tail":", designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0537ffb7-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0537ffb8-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2024 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/39/s2/b"},"text":"Pub. L. 118–39, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-02-09"},"text":"Feb. 9, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/16"},"text":"138 Stat. 16","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/39/s2/b"},"text":"“The amendment made by subsection (a) [amending this section] shall take effect on the date that is 30 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2024-02-09"},"text":"Feb. 9, 2024","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0537ffb9-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/295"},"text":"Pub. L. 104–295","children":[],"tail":" applicable as of "},{"tag":"date","attrib":{"date":"1993-12-08"},"text":"Dec. 8, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/295/s3/b"},"text":"section 3(b) of Pub. L. 104–295","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1321"},"text":"section 1321 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0537ffba-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/573"},"text":"Pub. L. 98–573","children":[],"tail":" effective on 15th day after "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", see section 214(a), (b) of "},{"tag":"ref","attrib":{"href":"/u