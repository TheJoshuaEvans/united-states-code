{"tag":"section","attrib":{"id":"id06515f2f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4403"},"text":null,"children":[{"tag":"num","attrib":{"value":"4403"},"text":"§ 4403.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Honey transshipment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id06515f30-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4403/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commissioner shall direct appropriate personnel and the use of resources of U.S. Customs and Border Protection to address concerns that honey is being imported into the United States in violation of the customs and trade laws of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id06515f31-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4403/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Country of origin","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id06515f32-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4403/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commissioner shall compile a database of the individual characteristics of honey produced in foreign countries to facilitate the verification of country of origin markings of imported honey.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06515f33-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4403/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Engagement with foreign governments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commissioner shall seek to engage the customs agencies of foreign governments for assistance in compiling the database described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06515f34-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4403/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with industry","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In compiling the database described in paragraph (1), the Commissioner shall consult with entities in the honey industry regarding the development of industry standards for honey identification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06515f35-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4403/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with Food and Drug Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In compiling the database described in paragraph (1), the Commissioner shall consult with the Commissioner of Food and Drugs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id06515f36-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4403/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2016-02-24"},"text":"February 24, 2016","children":[],"tail":", the Commissioner shall submit to Congress a report that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id06515f37-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4403/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes and assesses the limitations in the existing analysis capabilities of laboratories with respect to determining the country of origin of honey samples or the percentage of honey contained in a sample; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06515f38-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4403/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes any recommendations of the Commissioner for improving such capabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id06515f39-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4403/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the sense of Congress that the Commissioner of Food and Drugs should promptly establish a national standard of identity for honey for the Commissioner of U.S. Customs and Border Protection to use to ensure that imports of honey are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id06515f3a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4403/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" classified accurately for purposes of assessing duties; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06515f3b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4403/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" denied entry into the United States if such imports pose a threat to the health or safety of consumers in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id06515f3c-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/125/tVI/s608"},"text":"Pub. L. 114–125, title VI, § 608","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-24"},"text":"Feb. 24, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/189"},"text":"130 Stat. 189","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
