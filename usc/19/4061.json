{"tag":"section","attrib":{"id":"id0643073d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4061"},"text":null,"children":[{"tag":"num","attrib":{"value":"4061"},"text":"§ 4061.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commencing of action for relief","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0643073e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4061/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Filing of petition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A petition requesting action under this part for the purpose of adjusting to the obligations of the United States under the Agreement may be filed with the Commission by an entity, including a trade association, firm, certified or recognized union, or group of workers, that is representative of an industry. The Commission shall transmit a copy of any petition filed under this subsection to the United States Trade Representative.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0643073f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4061/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigation and determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon the filing of a petition under subsection (a), the Commission, unless subsection (d) applies, shall promptly initiate an investigation to determine whether, as a result of the reduction or elimination of a duty provided for under the Agreement, a CAFTA–DR article is being imported into the United States in such increased quantities, in absolute terms or relative to domestic production, and under such conditions that imports of the CAFTA–DR article constitute a substantial cause of serious injury or threat thereof to the domestic industry producing an article that is like, or directly competitive with, the imported article.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id06430740-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4061/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable provisions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2252"},"text":"section 2252 of this title","children":[],"tail":" apply with respect to any investigation initiated under subsection (b):"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id06430741-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4061/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraphs (1)(B) and (3) of subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06430742-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4061/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06430743-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4061/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsection (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id06430744-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4061/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Articles exempt from investigation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No investigation may be initiated under this section with respect to any CAFTA–DR article if, after the date that the Agreement enters into force, import relief has been provided with respect to that CAFTA–DR article under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id06430745-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/53/tIII/s311"},"text":"Pub. L. 109–53, title III, § 311","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-02"},"text":"Aug. 2, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/488"},"text":"119 Stat. 488","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id06430746-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id06430747-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination of section by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/53/s107/d"},"text":"section 107(d) of Pub. L. 109–53","children":[],"tail":", see Effective and Termination Dates note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id06430748-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id06430749-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This part, referred to in subsecs. (a) and (d), was in the original “this subtitle”, meaning subtitle A (§§ 311–316) of title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/53"},"text":"Pub. L. 109–53","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-02"},"text":"Aug. 2, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/488"},"text":"119 Stat. 488","children":[],"tail":", which enacted this part and amended "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2252"},"text":"section 2252 of this title","children":[],"tail":". For complete classification of subtitle A to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0643074a-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0643074b-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective and Termination Dates","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date the Dominican Republic-Central America-United States Free Trade Agreement enters into force (","children":[{"tag":"date","attrib":{"date":"2006-03-01"},"text":"Mar. 1, 2006","children":[],"tail":") and to cease to have effect on the date the Agreement ceases to be in force with respect to the United States, and, during any period in which a country ceases to be a CAFTA–DR country, to cease to have effect with respect to such country, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/53/s107"},"text":"section 107 of Pub. L. 109–53","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s4001"},"text":"section 4001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
