{"tag":"section","attrib":{"id":"id05951365-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2014"},"text":null,"children":[{"tag":"num","attrib":{"value":"2014"},"text":"§ 2014.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of proclamations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President is authorized at any time to terminate, in whole or in part, any proclamation issued pursuant to section 2011 or 2012 of this title.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id05951366-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/283/tII/s204"},"text":"Pub. L. 89–283, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-10-21"},"text":"Oct. 21, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1018"},"text":"79 Stat. 1018","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
