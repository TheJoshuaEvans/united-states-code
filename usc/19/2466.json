{"tag":"section","attrib":{"id":"id05e3a99d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2466"},"text":null,"children":[{"tag":"num","attrib":{"value":"2466"},"text":"§ 2466.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agricultural exports of beneficiary developing countries","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The appropriate agencies of the United States shall assist beneficiary developing countries to develop and implement measures designed to assure that the agricultural sectors of their economies are not directed to export markets to the detriment of the production of foodstuffs for their citizenry.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id05e3a99e-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/tV/s506"},"text":"Pub. L. 93–618, title V, § 506","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1952/a"},"text":"Pub. L. 104–188, title I, § 1952(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1925"},"text":"110 Stat. 1925","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05e3a99f-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05e3a9a0-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id05e3a9a1-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2466, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/tV/s506"},"text":"Pub. L. 93–618, title V, § 506","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/573/tV/s507/a"},"text":"Pub. L. 98–573, title V, § 507(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3023"},"text":"98 Stat. 3023","children":[],"tail":", related to agricultural exports of beneficiary developing countries, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/104/188"},"text":"Pub. L. 104–188","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id05e3a9a2-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id05e3a9a3-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to articles entered on or after ","children":[{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", with provisions relating to retroactive application, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/s1953"},"text":"section 1953 of Pub. L. 104–188","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2461"},"text":"section 2461 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
