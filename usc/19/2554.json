{"tag":"section","attrib":{"id":"id05f20051-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2554"},"text":null,"children":[{"tag":"num","attrib":{"value":"2554"},"text":"§ 2554.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedure after finding by international forum","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05f20052-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2554/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an appropriate international forum finds that a standards-related activity being engaged in within the United States conflicts with the obligations of the United States under the Agreement, the interagency trade organization established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1872/a"},"text":"section 1872(a) of this title","children":[],"tail":" shall review the finding and the matters related thereto with a view to recommending appropriate action."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05f20053-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2554/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For provisions of law regarding remedies available to domestic persons alleging that standards activities engaged in by Parties to the Agreement (other than the United States) violate the obligations of the Agreement, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2411"},"text":"section 2411 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05f20054-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39/tIV/s424"},"text":"Pub. L. 96–39, title IV, § 424","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/248"},"text":"93 Stat. 248","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
