{"tag":"section","attrib":{"id":"id060058ea-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2801"},"text":null,"children":[{"tag":"num","attrib":{"value":"2801"},"text":"§ 2801.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional findings and purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id060058eb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2801/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id060058ec-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2801/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a substantial imbalance in international wine trade resulting, in part, from the relative accessibility enjoyed by foreign wines to the United States market while the United States wine industry faces restrictive tariff and nontariff barriers in virtually every existing or potential foreign market;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060058ed-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2801/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the restricted access to foreign markets and the continued low prices for United States wine and grape products adversely affect the economic position of our Nation’s winemakers and grape growers, as well as all other domestic sectors that depend upon wine production;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060058ee-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2801/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the competitive position of United States wine in international trade has been weakened by foreign trade practices, high domestic interest rates, and unfavorable foreign exchange rates;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060058ef-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2801/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" wine consumption per capita is very low in many major non-wine producing markets and the demand potential for United States wine is significant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060058f0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2801/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States winemaking industry has the capacity and the ability to export substantial volumes of wine and an increase in United States wine exports will create new jobs, improve this Nation’s balance of trade, and otherwise strengthen the national economy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id060058f1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2801/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The purposes of this chapter are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id060058f2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2801/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide wine consumers with the greatest possible choice of wines from wine-producing countries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060058f3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2801/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage the initiation of an export promotion program to develop, maintain, and expand foreign markets for United States wine; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060058f4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2801/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to achieve greater access to foreign markets for United States wine and grape products through the reduction or elimination of tariff barriers and nontariff barriers to (or other distortions of) trade in wine.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id060058f5-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/573/tIX/s902"},"text":"Pub. L. 98–573, title IX, § 902","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3047"},"text":"98 Stat. 3047","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id060058f6-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id060058f7-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id060058f8-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/573/tIX/s901"},"text":"Pub. L. 98–573, title IX, § 901","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3047"},"text":"98 Stat. 3047","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/573/tIX/s901"},"text":"“This title [enacting this chapter] may be cited as the ‘Wine Equity and Export Expansion Act of 1984’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
