{"tag":"section","attrib":{"id":"id0530d38b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1352"},"text":null,"children":[{"tag":"num","attrib":{"value":"1352"},"text":"§ 1352.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equalization of costs of production","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0530d38c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1352/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application to importation of articles under foreign-trade agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1336"},"text":"section 1336 of this title","children":[],"tail":" shall not apply to any article with respect to the importation of which into the United States a foreign-trade agreement has been concluded pursuant to this part or the Trade Expansion Act of 1962 ["},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1801"},"text":"19 U.S.C. 1801","children":[],"tail":" et seq.] or the Trade Act of 1974 ["},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2101"},"text":"19 U.S.C. 2101","children":[],"tail":" et seq.] or to any provision of any such agreement. The third paragraph of "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1311"},"text":"section 1311 of this title","children":[],"tail":" shall apply to any agreement concluded pursuant to this part or the Trade Expansion Act of 1962 or the Trade Act of 1974 to the extent only that such agreement assures to the United States a rate of duty on wheat flour produced in the United States which is preferential in respect to the lowest rate of duty imposed by the country with which such agreement has been concluded on like flour produced in any other country; and upon the withdrawal of wheat flour from bonded manufacturing warehouses for exportation to the country with which such agreement has been concluded, there shall be levied, collected, and paid on the imported wheat used, a duty equal to the amount of such assured preference."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0530d38d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1352/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of foreign trade agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Every foreign trade agreement concluded pursuant to this part shall be subject to termination, upon due notice to the foreign government concerned, at the end of not more than three years from the date on which the agreement comes into force, and, if not then terminated, shall be subject to termination there­after upon not more than six months’ notice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0530d38e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1352/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of authority of President","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority of the President to enter into foreign trade agreements under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1351"},"text":"section 1351 of this title","children":[],"tail":" "},{"tag":"ref","attrib":{"idref":"fn002011"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002011"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" shall terminate on the expiration of three years from "},{"tag":"date","attrib":{"date":"1934-06-12"},"text":"June 12, 1934","children":[],"tail":"."},{"tag":"ref","attrib":{"idref":"fn002012"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002012"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See Extension of Presidential Authority notes below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0530d38f-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-12/ch474/s2"},"text":"June 12, 1934, ch. 474, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/944"},"text":"48 Stat. 944","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1951-06-16/ch141/s9/a"},"text":"June 16, 1951, ch. 141, § 9(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/65/75"},"text":"65 Stat. 75","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/794/tII/s257/d"},"text":"Pub. L. 87–794, title II, § 257(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-11"},"text":"Oct. 11, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/882"},"text":"76 Stat. 882","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/618/tVI/s602/a"},"text":"Pub. L. 93–618, title VI, § 602(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2072"},"text":"88 Stat. 2072","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/39/tXI/s1106/h/2"},"text":"Pub. L. 96–39, title XI, § 1106(h)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/313"},"text":"93 Stat. 313","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0530d390-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0530d391-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0530d392-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Trade Expansion Act of 1962, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/794"},"text":"Pub. L. 87–794","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-11"},"text":"Oct. 11, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/872"},"text":"76 Stat. 872","children":[],"tail":", which is classified generally to chapter 7 (§ 1801 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1801"},"text":"section 1801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Trade Act of 1974, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618"},"text":"Pub. L. 93–618","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1978"},"text":"88 Stat. 1978","children":[],"tail":", which is classified principally to chapter 12 (§ 2101 et seq.) of this title. For complete classification of this Act to the Code, see References in Text note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2101"},"text":"section 2101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1351"},"text":"Section 1351 of this title","children":[],"tail":", referred to in subsec. (c), was in the original “section 1 of this Act”, meaning section 1 of act "},{"tag":"date","attrib":{"date":"1934-06-12"},"text":"June 12, 1934","children":[],"tail":", and was translated as referring to section 350 of act "},{"tag":"date","attrib":{"date":"1930-06-17"},"text":"June 17, 1930","children":[],"tail":", which was enacted by section 1 of act "},{"tag":"date","attrib":{"date":"1934-06-12"},"text":"June 12, 1934","children":[],"tail":", and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1351"},"text":"section 1351 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0530d393-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1979—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39"},"text":"Pub. L. 96–39","children":[],"tail":" amended directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/93/618/s602/a"},"text":"Pub. L. 93–618, § 602(a)","children":[],"tail":", to correct a typographical error, and did not involve any change in text. See 1975 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618"},"text":"Pub. L. 93–618","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/96/39"},"text":"Pub. L. 96–39","children":[],"tail":", inserted “or the Trade Act of 1974” after “Act of 1962” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1962—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/794"},"text":"Pub. L. 87–794","children":[],"tail":" inserted “or the Trade Expansion Act of 1962” after “this part” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1951—Subsec. (a). Act ","children":[{"tag":"date","attrib":{"date":"1951-06-16"},"text":"June 16, 1951","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1336"},"text":"section 1336 of this title","children":[],"tail":"” for “sections 1336 and 1516(b) of this title”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0530d394-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0530d395-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Extension of Presidential Authority","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Extensions of authority of the President to enter into foreign trade agreements under section 350 of the Tariff Act of 1930 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1351"},"text":"section 1351 of this title","children":[],"tail":") were contained in the following:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/87/794/tII/s257/c"},"text":"Pub. L. 87–794, title II, § 257(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-11"},"text":"Oct. 11, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/882"},"text":"76 Stat. 882","children":[],"tail":", from close of "},{"tag":"date","attrib":{"date":"1962-06-30"},"text":"June 30, 1962","children":[],"tail":", until close of "},{"tag":"date","attrib":{"date":"1962-12-31"},"text":"Dec. 31, 1962","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/85/686/s2"},"text":"Pub. L. 85–686, § 2","children":[],"tail":", "},{"tag":"