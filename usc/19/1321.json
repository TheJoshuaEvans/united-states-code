{"tag":"section","attrib":{"id":"id0524ecdf-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1321"},"text":null,"children":[{"tag":"num","attrib":{"value":"1321"},"text":"§ 1321.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative exemptions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0524ece0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1321/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of the Treasury, in order to avoid expense and inconvenience to the Government disproportionate to the amount of revenue that would otherwise be collected, is authorized, under such regulations as he shall prescribe, to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0524ece1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1321/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disregard a difference of an amount specified by the Secretary by regulation, but not less than $20, between the total estimated duties, fees, and taxes deposited, or the total duties, fees, and taxes tentatively assessed, with respect to any entry of merchandise and the total amount of duties, fees, taxes, and interest actually accruing thereon;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0524ece2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1321/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" admit articles free of duty and of any tax imposed on or by reason of importation, but the aggregate fair retail value in the country of shipment of articles imported by one person on one day and exempted from the payment of duty shall not exceed an amount specified by the Secretary by regulation, but not less than—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0524ece3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1321/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $100 in the case of articles sent as bona fide gifts from persons in foreign countries to persons in the United States ($200 in the case of articles sent as bona fide gifts from persons in the Virgin Islands, Guam, and American Samoa), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0524ece4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1321/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $200 in the case of articles accompanying, and for the personal or household use of, persons arriving in the United States who are not entitled to any exemption from duty under subheading 9804.00.30, 9804.00.65, or 9804.00.70 of title I of this Act,","children":[{"tag":"ref","attrib":{"idref":"fn002006"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002006"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0524ece5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1321/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $800 in any other case.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The privilege of this subdivision (2) shall not be granted in any case in which merchandise covered by a single order or contract is forwarded in separate lots to secure the benefit of this subdivision (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0524ece6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1321/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" waive the collection of duties, fees, taxes, and interest due on entered merchandise when such duties, fees, taxes, or interest are less than $20 or such greater amount as may be specified by the Secretary by regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0524ece7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1321/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Treasury is authorized by regulations to prescribe exceptions to any exemption provided for in subsection (a) whenever he finds that such action is consistent with the purpose of subsection (a) or is necessary for any reason to protect the revenue or to prevent unlawful importations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0524ece8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1321/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person who enters, introduces, facilitates, or attempts to introduce an article into the United States using the privilege of this section, the importation of which violates any other provision of United States customs law, shall be assessed, in addition to any other penalty permitted by law, a civil penalty of up to $5,000 for the first violation and up to $10,000 for each subsequent violation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0524ece9-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title III, § 321, as added "},{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch679/s7"},"text":"June 25, 1938, ch. 679, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/1081"},"text":"52 Stat. 1081","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/act/1953-08-08/ch397/s13"},"text":"Aug. 8, 1953, ch. 397, § 13","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/67/515"},"text":"67 Stat. 515","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/261/s2/c"},"text":"Pub. L. 87–261, § 2(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-21"},"text":"Sept. 21, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/541"},"text":"75 Stat. 541","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/62/s2"},"text":"Pub. L. 89–62, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-06-30"},"text":"June 30, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/208"},"text":"79 Stat. 208","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/618/tVI/s610/a"},"text":"Pub. L. 93–618, title VI, § 610(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2075"},"text":"88 Stat. 2075","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/410/tII/s205"},"text":"Pub. L. 95–410, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-03"},"text":"Oct. 3, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/900"},"text":"92 Stat. 900","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/446/tI/s115/b"},"text":"Pub. L. 97–446, title I, § 115(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2335"},"text":"96 Stat. 2335","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tI/s1214/h/2"},"text":"Pub. L. 100–418, title I, § 1214(h)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1157"},"text":"102 Stat. 1157","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/182/tVI/s651"},"text":"Pub. L. 103–182, title VI, § 651","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-08"},"text":"Dec. 8, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2209"},"text":"107 Stat. 2209","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/295/s3/a/8"},"text":"Pub. L. 104–295, § 3(a)(8)","children":[],"tail":", (12), "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3516"},"text":"110 Stat. 3516","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/125/tIX/s901/c"},"text":"Pub. L. 114–125, title IX, § 901(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-24"},"text":"Feb. 24, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/223"},"text":"130 Stat. 223","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70531/a/1"},"text":"Pub. L. 119–21, title VII, § 70531(a)(1)","children":[],"tail":", (b)(1), (2), "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/283"},"text":"139 Stat. 283","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0524ecea-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id0524eceb-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendment of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70531/b"},"text":"Pub. L. 119–21, title VII, § 70531(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/283"},"text":"139 Stat. 283","children":[],"tail":", provided that, effective on "},{"tag":"date","attrib":{"date":"2027-07-01"},"text":"July 1, 2027","children":[],"tail":", this section is amended as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(1) in subsection (a)(2), by striking “of this Act, or” and all that follows through “subdivision (2); and” and inserting “of this Act; and”; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(2) by striking subsection (c).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"See 2025 Amendment notes below.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0524ecec-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0524eced-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Title I of this Act, referred to in subsec. (a)(2)(B), means title I of act ","children":[{"tag":"date","attrib":{"date":"1930-06-17"},"text":"June 17, 1930","children":[],"tail":", which contained the Tariff Schedules of the United States and which formerly were set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1202"},"text":"section 1202 of this title","children":[],"tail":". The Tariff Schedules of the United States were replaced by the Harmonized Tariff Schedule of the United States. See Publication of Harmonized Tariff Schedule note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1202"},"text":"section 1202 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0524ecee-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70531/b/1"},"text":"Pub. L. 119–21, § 70531(b)(1)","children":[],"tail":", substituted “of this Act; and” for “of this Act, or” in subpar. (B) and struck out subpar. (C) and concluding provisions which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) $800 in any other case.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“The privilege of this subdivision (2) shall not be granted in any case in which merchandise covered by a single order or contract is forwarded in separate lots to secure the benefit of this subdivision (2); and”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70531/b/2"},"text":"Pub. L. 119–21, § 70531(b)(2)","children":[],"tail":", struck out subsec. (c) which read as follows: “Any person who enters, introduces, facilitates, or attempts to introduce an article into the United States using the privilege of this section, the importation of which violates any other provision of United States customs law, shall be assessed, in addition to any other penalty permitted by law, a civil penalty of up to $5,000 for the first violation and up to $10,000 for each subsequent violation.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70531/a/1"},"text":"Pub. L. 119–21, § 70531(a)(1)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (a)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/125"},"text":"Pub. L. 114–125","children":[],"tail":" substituted “$800” for “$200”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/295/s3/a/12/A"},"text":"Pub. L. 104–295, § 3(a)(12)(A)","children":[],"tail":", substituted “duties, fees, taxes, and interest actually accruing” for “duties, fees, and taxes actually accruing”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/295/s3/a/8"},"text":"Pub. L. 104–295, § 3(a)(8)","children":[],"tail":", inserted “, 9804.00.65,” after “9804.00.30”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/295/s3/a/12/B"},"text":"Pub. L. 104–295, § 3(a)(12)(B)","children":[],"tail":", substituted “taxes, and interest” for “and taxes” and “taxes, or interest” for “or taxes”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/182/s651/1"},"text":"Pub. L. 103–182, § 651(1)","children":[],"tail":", substituted “of an amount specified by the Secretary by regulation, but not less than $20,” for “of less than $10”, inserted “, fees,” after “duties” wherever appearing, and struck out “and” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/182/s651/2"},"text":"Pub. L. 103–182, § 651(2)","children":[],"tail":", substituted “shall not exceed an amount specified by the Secretary by regulation, but not less than—” for “shall not exceed—” in introductory provisions, substituted “$100” and “$200” for “$50” and “$100”, respectively, in subpar. (A), substituted “$200” for “$25” in subpar. (B), substituted “$200” for “$5” in subpar. (C), and substituted “; and” for period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/182/s651/3"},"text":"Pub. L. 103–182, § 651(3)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/182/s651/4"},"text":"Pub. L. 103–182, § 651(4)","children":[],"tail":", struck out “to diminish any dollar amount specified in subsection (a) and” after “authorized by regulations” and substituted “subsection (a)” for “such subsection” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418"},"text":"Pub. L. 100–418","children":[],"tail":" substituted “subheading 9804.00.30 or 9804.00.70” for “item 812.25 or 813.31”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/446"},"text":"Pub. L. 97–446","children":[],"tail":" substituted “$50” for “$25” and “$100” for “$40”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/410/s205/a"},"text":"Pub. L. 95–410, § 205(a)","children":[],"tail":", substituted “$10” for “$3” and “duties and taxes” for “duties or taxes” in three places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/410/s205/b/1"},"text":"Pub. L. 95–410, § 205(b)(1)","children":[],"tail":"–(3), substituted in: subpar. (A), “$25” and “$40” for “$10” and “$20”; subpar. (B), “$25” for “$10”; and subpar. (C), “$5” for “$1”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618"},"text":"Pub. L. 93–618","children":[],"tail":" inserted “($20, in the case of articles sent as bona fide gifts from persons in the Virgin Islands, Guam, and American Samoa)” after “United States”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1965—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/62"},"text":"Pub. L. 89–62","children":[],"tail":" substituted “fair retail value in the country of shipment” for “value” in the material preceding subpar. (A) and “item 812.25 or 813.31 of "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1202"},"text":"section 1202 of this title","children":[],"tail":"” for “paragraph 1798(b)(2) or (c)(2) of "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1201"},"text":"section 1201 of this title","children":[],"tail":"” in subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1961—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/261"},"text":"Pub. L. 87–261","children":[],"tail":" inserted “(b)(2) or” after “paragraph 1798”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1953—Act ","children":[{"tag":"date","attrib":{"date":"1953-08-08"},"text":"Aug. 8, 1953","children":[],"tail":", amended section generally. Prior to amendment, section read as follows: “Collectors of customs are hereby authorized, under such regulations as the Secretary of the Treasury may prescribe, to disregard a difference of less than $1 between the total estimated duties or taxes deposited, or the total duties or taxes tentatively assessed, with respect to any entry of merchandise and the total amount of duties or taxes actually accruing thereon, and to admit articles free of duty when the expense and inconvenience of collecting the duty accruing thereon would be disproportionate to the amount of such duty, but the aggregate value of articles imported by one person on one day and exempted from the payment of duty under the authority of this section shall not exceed $5 in the case of articles accompanying, and for the personal or household use of, persons arriving in the United States, or $1 in any other case.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0524ecef-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0524ecf0-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2025 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70531/a/2"},"text":"Pub. L. 119–21, title VII, § 70531(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/283"},"text":"139 Stat. 283","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/21/tVII/s70531/a/2"},"text":"“The amendment made by paragraph (1) [amending this section] shall take effect 30 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70531/b/3"},"text":"Pub. L. 119–21, title VII, § 70531(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/283"},"text":"139 Stat. 283","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/21/tVII/s70531/b/3"},"text":"“The amendments made by this subsection [amending this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"2027-07-01"},"text":"July 1, 2027","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"