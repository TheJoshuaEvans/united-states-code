{"tag":"section","attrib":{"id":"id065d4613-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4649"},"text":null,"children":[{"tag":"num","attrib":{"value":"4649"},"text":"§ 4649.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultations on appointment and funding of rapid response labor panelists","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id065d4614-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4649/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Interagency Labor Committee shall consult with the Labor Advisory Committee established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2155/c/1"},"text":"section 2155(c)(1) of this title","children":[],"tail":" and the Advisory Committee for Trade Policy and Negotiations established under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2155/b"},"text":"section 2155(b) of this title","children":[],"tail":" (or successor advisory committees) and the appropriate congressional committees with respect to the selection and appointment of candidates for the rapid response labor panelists described in Annex 31–A of the USMCA."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id065d4615-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4649/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States, in consultation with Mexico, shall provide adequate funding for rapid response labor panelists to carry out the responsibilities under the USMCA promptly and fully.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id065d4616-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113/tVII/s719"},"text":"Pub. L. 116–113, title VII, § 719","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-01-29"},"text":"Jan. 29, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/86"},"text":"134 Stat. 86","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
