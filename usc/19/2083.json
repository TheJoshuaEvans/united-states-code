{"tag":"section","attrib":{"id":"id0599ce9b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2083"},"text":null,"children":[{"tag":"num","attrib":{"value":"2083"},"text":"§ 2083.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual national trade and customs law violation estimates and enforcement strategy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0599ce9c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2083/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violation estimates","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 30 days before the beginning of each fiscal year after fiscal year 1991, the Commissioner of Customs ","children":[{"tag":"ref","attrib":{"idref":"fn002081"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002081"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Change of Name note below."}],"tail":" shall submit to the Committee on Ways and Means of the House of Representatives and the Committee on Finance of the Senate (hereafter in this section referred to as the “Committees”) a report that contains estimates of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0599ce9d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2083/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and extent of violations of the trade, customs, and illegal drug control laws listed under subsection (b) that will likely occur during the fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0599ce9e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2083/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relative incidence of the violations estimated under paragraph (1) among the various ports of entry and customs regions within the customs territory.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0599ce9f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2083/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable statutory provisions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commissioner of Customs,","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" after consultation with the Committees—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0599cea0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2083/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall, within 60 days after ","children":[{"tag":"date","attrib":{"date":"1990-08-20"},"text":"August 20, 1990","children":[],"tail":", prepare a list of those provisions of the trade, customs, and illegal drug control laws of the United States for which the United States Customs Service has enforcement responsibility and to which the reports required under subsection (a) will apply; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0599cea1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2083/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may from time-to-time amend the listing developed under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0599cea2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2083/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement strategy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Within 90 days after submitting a report under subsection (a) for any fiscal year, the Commissioner of Customs ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0599cea3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2083/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a nationally uniform enforcement strategy for dealing during that year with the violations estimated in the report; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0599cea4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2083/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Committees a report setting forth the details of the strategy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0599cea5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2083/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commissioner of Customs ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0599cea6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2083/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" devise and implement a methodology for estimating the level of compliance with the laws administered by the Customs Service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0599cea7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2083/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include as an additional part of the report required to be submitted under subsection (a) for each of fiscal years 1994, 1995, and 1996, an evaluation of the extent to which such compliance was obtained during the 12-month period preceding the 60th day before each such fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0599cea8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2083/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The contents of any report submitted to the Committees under subsection (a) or (c)(2) are confidential and disclosure of all or part of the contents is restricted to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0599cea9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2083/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" officers and employees of the United States designated by the Commissioner of Customs; ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0599ceaa-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2083/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the chairman of each of the Committees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0599ceab-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2083/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" those members of each of the Committees and staff persons of each of the Committees who are authorized by the chairman thereof to have access to the contents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0599ceac-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/382/tI/s123"},"text":"Pub. L. 101–382, title I, § 123","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-20"},"text":"Aug. 20, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/642"},"text":"104 Stat. 642","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/182/tVI/s691/c"},"text":"Pub. L. 103–182, title VI, § 691(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-08"},"text":"Dec. 8, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2224"},"text":"107 Stat. 2224","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/125/tVIII/s802/d/2"},"text":"Pub. L. 114–125, title VIII, § 802(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-24"},"text":"Feb. 24, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/210"},"text":"130 Stat. 210","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0599cead-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0599ceae-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0599ceaf-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/182"},"text":"Pub. L. 103–182","children":[],"tail":" added subsec. (d) and redesignated former subsec. (d) as (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0599ceb0-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id0599ceb1-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to Commissioner of Customs deemed to be reference to Commissioner of U.S. Customs and Border Protection pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/125/s802/d/2"},"text":"section 802(d)(2) of Pub. L. 114–125","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s211"},"text":"section 211 of Title 6","children":[],"tail":", Domestic Security."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id0599ceb2-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions, personnel, assets, and liabilities of the United States Customs Service of the Department of the Treasury, including functions of the Secretary of the Treasury relating thereto, to the Secretary of Homeland Security, and for treatment of related references, see sections 203(1), 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":". For establishment of U.S. Customs and Border Protection in the Department of Homeland Security, treated as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" as of "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s211"},"text":"section 211 of Title 6","children":[],"tail":", as amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/114/125"},"text":"Pub. L. 114–125","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/114/125/s802/b"},"text":"section 802(b) of Pub. L. 114–125","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s211"},"text":"section 211 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
