{"tag":"section","attrib":{"id":"id058de7f8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1683b"},"text":"§ 1683b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope of softwood lumber importer declaration program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id058de7f9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Products included in program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following products shall be subject to the importer declaration program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1683a"},"text":"section 1683a of this title","children":[],"tail":":"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id058de7fa-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"All softwood lumber and softwood lumber products classified under subheading 4407.10.00, 4409.10.10, 4409.10.20, or 4409.10.90 of the HTS, including the following softwood lumber, flooring, and siding:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id058de7fb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683b/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Coniferous wood, sawn or chipped lengthwise, sliced or peeled, whether or not planed, sanded, or finger-jointed, of a thickness exceeding 6 millimeters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id058de7fc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683b/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Coniferous wood siding (including strips and friezes for parquet flooring, not assembled) continuously shaped (tongued, grooved, rabbeted, chamfered, v-jointed, beaded, molded, rounded, or the like) along any of its edges or faces, whether or not planed, sanded, or finger-jointed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id058de7fd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683b/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other coniferous wood (including strips and friezes for parquet flooring, not assembled) continuously shaped (tongued, grooved, rabbeted, chamfered, v-jointed, beaded, molded, rounded, or the like) along any of its edges or faces (other than wood moldings and wood dowel rods) whether or not planed, sanded, or finger-jointed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id058de7fe-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683b/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Coniferous wood flooring (including strips and friezes for parquet flooring, not assembled) continuously shaped (tongued, grooved, rabbeted, chamfered, v-jointed, beaded, molded, rounded, or the like) along any of its edges or faces, whether or not planed, sanded, or finger-jointed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id058de7ff-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683b/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Coniferous drilled and notched lumber and angle cut lumber.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id058de800-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Products continually shaped","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any product classified under subheading 4409.10.05 of the HTS that is continually shaped along its end or side edges.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id058de801-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other lumber products","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in subsection (b) or (c), softwood lumber products that are stringers, radius-cut box-spring frame components, fence pickets, truss components, pallet components, and door and window frame parts classified under subheading 4418.90.46.95, 4421.90.70.40, or 4421.90.97.40 of the HTS.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id058de802-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Products excluded from program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following products shall be excluded from the importer declaration program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1683a"},"text":"section 1683a of this title","children":[],"tail":":"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id058de803-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Trusses and truss kits, properly classified under subheading 4418.90 of the HTS.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id058de804-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" I-joist beams.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id058de805-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assembled box-spring frames.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id058de806-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683b/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Pallets and pallet kits, properly classified under subheading 4415.20 of HTS.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id058de807-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683b/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Garage doors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id058de808-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683b/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Edge-glued wood, properly classified under subheading 4421.90.97.40 of the HTS.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id058de809-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683b/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Complete door frames.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id058de80a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683b/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Complete window frames.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id058de80b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683b/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Furniture.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id058de80c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683b/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Articles brought into the United States temporarily and for which an exemption from duty is claimed under subchapter XIII of chapter 98 of the HTS.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id058de80d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683b/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Household and personal effects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id058de80e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions for certain products","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following softwood lumber products shall not be subject to the importer declaration program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1683a"},"text":"section 1683a of this title","children":[],"tail":":"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id058de80f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stringers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Stringers (pallet components used for runners), if the stringers—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id058de810-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683b/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have at least 2 notches on the side, positioned at equal distance from the center, to properly accommodate forklift blades; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id058de811-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683b/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are properly classified under subheading 4421.90.97.40 of the HTS.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id058de812-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Box-spring frame kits","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id058de813-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683b/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Box-spring frame kits, if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id058de814-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683b/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the kits contain—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id058de815-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683b/c/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 wooden side rails;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id058de816-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683b/c/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 wooden end (or top) rails; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id058de817-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683b/c/2/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" varying numbers of wooden slats; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id058de818-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683b/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the side rails and the end rails are radius-cut at both ends.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id058de819-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683b/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Packaging","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any kit described in subparagraph (A) shall be individually packaged, and contain the exact number of wooden components needed to make the box-spring frame described on the entry documents, with no further processing required. None of the components contained in the package may exceed 1 inch in actual thickness or 83 inches in length.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id058de81a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683b/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Radius-cut box-spring frame components","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Radius-cut box-spring frame components, not exceeding 1 inch in actual thickness or 83 inches in length, ready for assembly without further processing, if radius cuts are present on both ends of the boards and are substantial cuts so as to completely round 1 corner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id058de81b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683b/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fence pickets","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Fence pickets requiring no further processing and properly classified under subheading 4421.90.70 of the HTS, 1 inch or less in actual thickness, up to 8 inches wide, and 6 feet or less in length, and having finials or decorative cuttings that clearly identify them as fence pickets. In the case of dog-eared fence pickets, the corners of the boards shall be cut off so as to remove pieces of wood in the shape of isosceles right angle triangles with sides measuring ¾ of an inch or more.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id058de81c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683b/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States-origin lumber","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Lumber originating in the United States that is exported to another country for minor processing and imported into the United States if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id058de81d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683b/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the processing occurring in another country is limited to kiln drying, planing to create smooth-to-size board, and sanding; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id058de81e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683b/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the importer establishes to the satisfaction of U.S. Customs and Border Protection upon entry that the lumber originated in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id058de81f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683b/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Softwood lumber","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any softwood lumber or softwood lumber product that originated in the United States, if the importer, exporter, foreign processor, or original United States producer establishes to the satisfaction of U.S. Customs and Border Protection upon entry that the softwood lumber entered and documented as originating in the United States was first produced in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id058de820-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683b/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Home packages or kits","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id058de821-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683b/c/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Softwood lumber or softwood lumber products contained in a single family home package or kit, regardless of the classification under the HTS, if the importer declares that the following requirements have been met:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id058de822-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683b/c/7/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The package or kit constitutes a full package of the number of wooden pieces specified in the plan, design, or blueprint necessary to produce a home of at least 700 square feet produced to a specified plan, design, or blueprint.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id058de823-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683b/c/7/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The package or kit contains—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id058de824-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683b/c/7/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all necessary internal and external doors and windows, nails, screws, glue, subfloor, sheathing, beams, posts, and connectors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id058de825-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683b/c/7/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if included in the purchase contract, the decking, trim, drywall, and roof shingles specified in the plan, design, or blueprint.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id058de826-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683b/c/7/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Prior to importation, the package or kit is sold to a United States retailer that sells complete home packages or kits pursuant to a valid purchase contract referencing the particular home design, plan, or blueprint, and the contract is signed by a customer not affiliated with the importer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id058de827-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683b/c/7/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Softwood lumber products entered as part of the package or kit, whether in a single entry or multiple entries on multiple days, are to be used solely for the construction of the single family home specified by the home design, plan, or blueprint matching the U.S. Customs and Border Protection import entry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id058de828-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683b/c/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional documentation required for home packages and kits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of each entry of products described in clauses (i) through (iv) of subparagraph (A) the following documentation shall be retained by the importer and made available to U.S. Customs and Border Protection upon request:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id058de829-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683b/c/7/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A copy of the appropriate home design, plan, or blueprint matching the customs entry in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id058de82a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683b/c/7/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A purchase contract from a retailer of home kits or packages signed by a customer not affiliated with the importer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id058de82b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683b/c/7/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A listing of all parts in the package or kit being entered into the United States that conforms to the home design, plan, or blueprint for which such parts are being imported.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id058de82c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683b/c/7/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a single contract involves multiple entries, an identification of all the items required to be listed under clause (iii) that are included in each individual shipment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id058de82d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1683b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Products covered","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of determining if a product is covered by the importer declaration program, the President shall be guided by the article descriptions provided in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id058de82e-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title VIII, § 804, as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/tIII/s3301/a"},"text":"Pub. L. 110–246, title III, § 3301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1848"},"text":"122 Stat. 1848","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id058de82f-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id058de830-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id058de831-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1683a"},"text":"Section 1683a of this title","children":[],"tail":", referred to in subsecs. (a) to (c), was in the original section “803”, and was translated as meaning the section 803 of act "},{"tag":"date","attrib":{"date":"1930-06-17"},"text":"June 17, 1930","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s3301/a"},"text":"section 3301(a) of Pub. L. 110–246","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id058de832-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id058de833-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 60 days after ","children":[{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s3301/b"},"text":"section 3301(b) of Pub. L. 110–246","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1683"},"text":"section 1683 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
