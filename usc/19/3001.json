{"tag":"section","attrib":{"id":"id06051350-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3001"},"text":null,"children":[{"tag":"num","attrib":{"value":"3001"},"text":"§ 3001.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of this chapter are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id06051351-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3001/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to approve the International Convention on the Harmonized Commodity Description and Coding System;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06051352-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3001/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to implement in United States law the nomenclature established internationally by the Convention; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06051353-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3001/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide that the Convention shall be treated as a trade agreement obligation of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id06051354-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/tI/s1201"},"text":"Pub. L. 100–418, title I, § 1201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1147"},"text":"102 Stat. 1147","children":[],"tail":".)"}],"tail":"\n