{"tag":"section","attrib":{"id":"id05d306fe-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2394"},"text":null,"children":[{"tag":"num","attrib":{"value":"2394"},"text":"§ 2394.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Firms relocating in foreign countries","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Before moving productive facilities from the United States to a foreign country, every firm should—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05d306ff-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2394/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide notice of the move to its employees who are likely to be totally or partially separated as a result of the move at least 60 days before the date of such move, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05d30700-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2394/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide notice of the move to the Secretary of Labor and the Secretary of Commerce on the same day it notifies employees under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05d30701-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2394/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002109"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002109"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The first paragraph was not designated subsec. (a)."}],"tail":" It is the sense of the Congress that every such firm should—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id05d30702-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2394/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" apply for and use all adjustment assistance for which it is eligible under this subchapter,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05d30703-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2394/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offer employment opportunities in the United States, if any exist, to its employees who are totally or partially separated workers as a result of the move, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05d30704-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2394/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist in relocating employees to other locations in the United States where employment opportunities exist.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05d30705-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/tII/s283"},"text":"Pub. L. 93–618, title II, § 283","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2041"},"text":"88 Stat. 2041","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
