{"tag":"section","attrib":{"id":"id065afbba-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4581"},"text":null,"children":[{"tag":"num","attrib":{"value":"4581"},"text":"§ 4581.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" References in part","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any reference in this part to an Annex, chapter, or article shall be considered to be a reference to the respective Annex, chapter, or article of the USMCA.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id065afbbb-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113/tIV/s411"},"text":"Pub. L. 116–113, title IV, § 411","children":[],"tail":", formerly "},{"tag":"ref","attrib":{"href":"/us/pl/103/182/tIV/s401"},"text":"Pub. L. 103–182, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-08"},"text":"Dec. 8, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2129"},"text":"107 Stat. 2129","children":[],"tail":"; renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/116/113/s411"},"text":"§ 411 of Pub. L. 116–113","children":[],"tail":" and amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/113/tV/s504/b"},"text":"Pub. L. 116–113, title V, § 504(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-01-29"},"text":"Jan. 29, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/72"},"text":"134 Stat. 72","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id065afbbc-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id065afbbd-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id065afbbe-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3431"},"text":"section 3431 of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/116/113"},"text":"Pub. L. 116–113","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id065afbbf-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113/s504/b/3"},"text":"Pub. L. 116–113, § 504(b)(3)","children":[],"tail":", substituted “the USMCA” for “the Agreement”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id065afbc0-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id065afbc1-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2020 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113/tV/s504/k"},"text":"Pub. L. 116–113, title V, § 504(k)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-01-29"},"text":"Jan. 29, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/76"},"text":"134 Stat. 76","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/113/tV/s504/k"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each transfer, redesignation, and amendment made by this section [transferring sections 3431 to 3438 of this title, respectively, to and amending sections 4581 to 4588 of this title] shall take effect on the date on which the USMCA enters into force [","children":[{"tag":"date","attrib":{"date":"2020-07-01"},"text":"July 1, 2020","children":[],"tail":"], but shall not apply—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to any final determination described in paragraph (1)(B) or clause (i), (ii), or (iii) of paragraph (2)(B) of section 516A(a) of the Tariff Act of 1930 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1516a/a"},"text":"19 U.S.C. 1516a(a)","children":[],"tail":") notice of which is published in the Federal Register before such date, or to a determination described in paragraph (2)(B)(vi) of that section notice of which is received by the Government of Canada or Mexico before such date; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to any binational panel review under NAFTA, or any extraordinary challenge arising out of any such review, that was commenced before such date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transition from nafta","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The transfers, redesignations, and amendments made by this section shall not apply, and the provisions of title IV of the North American Free Trade Agreement Implementation Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3431"},"text":"19 U.S.C. 3431","children":[],"tail":" et seq.], as in effect on the day before the date on which the USMCA enters into force, shall continue to apply on and after that date with respect—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to any final determination described in paragraph (1)(B) or clause (i), (ii), or (iii) of paragraph (2)(B) of section 516A(a) of the Tariff Act of 1930 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1516a/a"},"text":"19 U.S.C. 1516a(a)","children":[],"tail":") notice of which is published in the Federal Register before such date, or to a determination described in paragraph (2)(B)(vi) of that section notice of which is received by the Government of Canada or Mexico before the date on which the USMCA enters into force; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to any binational panel review under NAFTA, or any extraordinary challenge arising out of any such review, that was commenced before the date on which the USMCA enters into force.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definition of “USMCA” as used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113/s504/k"},"text":"section 504(k) of Pub. L. 116–113","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s4502"},"text":"section 4502 of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
