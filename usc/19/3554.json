{"tag":"section","attrib":{"id":"id0610fb20-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3554"},"text":null,"children":[{"tag":"num","attrib":{"value":"3554"},"text":"§ 3554.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Africa trade and development policy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0610fb21-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3554/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development of policy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President should develop and implement a comprehensive trade and development policy for the countries of Africa.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0610fb22-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3554/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall, not later than 12 months after ","children":[{"tag":"date","attrib":{"date":"1994-12-08"},"text":"December 8, 1994","children":[],"tail":", and annually thereafter for a period of 4 years, submit to the Committee on Ways and Means and the Committee on Foreign Affairs of the House of Representatives, the Committee on Finance and the Committee on Foreign Relations of the Senate, and other appropriate committees of the Congress, a report on the steps taken to carry out subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0610fb23-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/tI/s134"},"text":"Pub. L. 103–465, title I, § 134","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4840"},"text":"108 Stat. 4840","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
