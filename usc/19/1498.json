{"tag":"section","attrib":{"id":"id0546576a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1498"},"text":null,"children":[{"tag":"num","attrib":{"value":"1498"},"text":"§ 1498.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entry under regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0546576b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1498/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized for certain merchandise","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Treasury is authorized to prescribe rules and regulations for the declaration and entry of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0546576c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1498/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Merchandise, when—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0546576d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1498/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate value of the shipment does not exceed an amount specified by the Secretary by regulation, but not more than $2,500; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0546576e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1498/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" different commercial facilitation and risk considerations that may vary for different classes or kinds of merchandise or different classes of transactions may dictate;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0546576f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1498/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Products of the United States, when the aggregate value of the shipment does not exceed such amounts as the Secretary may prescribe and the products are imported.","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05465770-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1498/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the purposes of repair or alteration prior to reexportation, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05465771-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1498/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after having been either rejected or returned by the foreign purchaser to the United States for credit;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05465772-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1498/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Merchandise damaged on the voyage of importation, by fire or through marine casualty or any other cause, without fault on the part of the shipper;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05465773-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1498/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Merchandise recovered from a wrecked or stranded vessel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05465774-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1498/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Household effects used abroad and personal effects, not imported in pursuance of a purchase or agreement for purchase and not intended for sale;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05465775-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1498/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Articles sent by persons in foreign countries as gifts to persons in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05465776-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1498/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Articles carried on the person or contained in the baggage of a person arriving in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05465777-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1498/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Tools of trade of a person arriving in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05465778-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1498/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Personal effects of citizens of the United States who have died in a foreign country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05465779-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1498/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Merchandise within the provisions of sections 1465 ","children":[{"tag":"ref","attrib":{"idref":"fn002026"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002026"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and 1466 of this title (relating to supplies, repairs, and equipment on vessels and railway cars) at the first port of arrival;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0546577a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1498/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Merchandise when in the opinion of the Secretary of the Treasury the value thereof cannot be declared; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0546577b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1498/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Merchandise within the provisions of paragraph 1631 of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1201"},"text":"section 1201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0546577c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1498/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of general provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury is authorized to include in such rules and regulations any of the provisions of section 1484 or 1485 of this title (relating, respectively, to entry and to declaration of merchandise generally).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0546577d-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title IV, § 498, "},{"tag":"ref","attrib":{"href":"/us/stat/46/728"},"text":"46 Stat. 728","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1953-08-08/ch397/s16/d"},"text":"Aug. 8, 1953, ch. 397, § 16(d)","children":[],"tail":", (e), "},{"tag":"ref","attrib":{"href":"/us/stat/67/517"},"text":"67 Stat. 517","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/609/tII/s202"},"text":"Pub. L. 96–609, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-28"},"text":"Dec. 28, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3561"},"text":"94 Stat. 3561","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/573/tII/s206"},"text":"Pub. L. 98–573, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2975"},"text":"98 Stat. 2975","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tI/s1214/h/5"},"text":"Pub. L. 100–418, title I, § 1214(h)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1157"},"text":"102 Stat. 1157","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/182/tVI/s662"},"text":"Pub. L. 103–182, title VI, § 662","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-08"},"text":"Dec. 8, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2214"},"text":"107 Stat. 2214","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0546577e-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0546577f-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id05465780-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1465"},"text":"Section 1465 of this title","children":[],"tail":", referred to in subsec. (a)(10), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/103/182/tVI/s690/b/7"},"text":"Pub. L. 103–182, title VI, § 690(b)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-08"},"text":"Dec. 8, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2223"},"text":"107 Stat. 2223","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1201"},"text":"Section 1201 of this title","children":[],"tail":", referred to in subsec. (a)(12), which comprised the free list for articles imported into the United States, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/87/456/tI/s101/a"},"text":"Pub. L. 87–456, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-05-24"},"text":"May 24, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/72"},"text":"76 Stat. 72","children":[],"tail":", which act also revised the Tariff Schedules of the United States. See notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1202"},"text":"section 1202 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id05465781-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-09-21/ch356/tIV/s498"},"text":"act Sept. 21, 1922, ch. 356, title IV, § 498","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/964"},"text":"42 Stat. 964","children":[],"tail":". That section was superseded by section 498 of act "},{"tag":"date","attrib":{"date":"1930-06-17"},"text":"June 17, 1930","children":[],"tail":", comprising this section, and repealed by section 651(a)(1) of the 1930 act."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provision for an entry, separate from that of other merchandise, of wearing apparel, personal baggage, and tools and implements of a mechanical trade, was made by R.S. § 2799, which also prescribed the contents of such entry, and of the accompanying oath. R.S. § 2800 provided for a bond when the person making entry was not the owner. R.S. § 2801 provided for a landing permit, and for an examination of baggage when deemed proper by the collector and naval officer, and for entry of articles not exempt from duty. All of these sections were repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-09-21/ch356/tIV/s642"},"text":"act Sept. 21, 1922, ch. 356, title IV, § 642","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/989"},"text":"42 Stat. 989","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id05465782-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/182/s662/1"},"text":"Pub. L. 103–182, § 662(1)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) read as follows: “Merchandise, imported in the mails or otherwise, when the aggregate value of the shipment does not exceed such amount, not greater than $1,250 as the Secretary of the Treasury shall specify in the regulations, and the specified amount may vary for different classes or kinds of merchandise or different classes of transactions, except that this paragraph does not apply to articles valued in excess of $250 classified in—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) chapters 50 through 63;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) chapters 39 through 43, 61 through 65, 67 and 95; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) subchapters III and IV of chapter 99;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"of the Harmonized Tariff Schedule of the United States, or to any other article for which formal entry is required without regard to value.;”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/182/s662/2"},"text":"Pub. L. 103–182, § 662(2)","children":[],"tail":", substituted “such amounts as the Secretary may prescribe” for “$10,000” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418"},"text":"Pub. L. 100–418","children":[],"tail":", substituted “the Harmonized Tariff Schedule of the United States” for “the Tariff Schedules of the United States” in closing provisions, added subpars. (A) to (C), and struck out former subpars. (A) to (C) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) schedule 3,","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) parts 1, 4A, 7B, 12A, 12D, and 13B of schedule 7, and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) parts 2 and 3 of the Appendix,”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/573"},"text":"Pub. L. 98–573","children":[],"tail":" substituted “$1,250” for “$250” and inserted provision that this paragraph does not apply to articles valued in excess of $250 classified in schedule 3, parts 1, 4A, 7B, 12A, 12D, and 13B of schedule 7, and parts 2 and 3 of the Appendix, of the Tariff Schedules, or to any other article for which formal entry is required without regard to value."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/609"},"text":"Pub. L. 96–609","children":[],"tail":" added par. (2) and redesignated former pars. (2) to (11) as (3) to (12), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1953—Subsec. (a)(1). Act ","children":[{"tag":"date","attrib":{"date":"1953-08-08"},"text":"Aug. 8, 1953","children":[],"tail":", § 16(d), increased valuation figure with respect to informal entries from $100 to $250, and inserted provisions with respect to possible variation for different classes or kinds of merchandise and different classes of transactions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(11). Act ","children":[{"tag":"date","attrib":{"date":"1953-08-08"},"text":"Aug. 8, 1953","children":[],"tail":", § 16(e), substituted “paragraph 1631 of "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1201"},"text":"section 1201 of this title","children":[],"tail":"” for “sections 472 to 574 of this title”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id05465783-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id05465784-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418"},"text":"Pub. L. 100–418","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1989-01-01"},"text":"Jan. 1, 1989","children":[],"tail":", and applicable with respect to articles entered on or after such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/s1217/b/1"},"text":"section 1217(b)(1) of Pub. L. 100–418","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id05465785-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/573"},"text":"Pub. L. 98–573","children":[],"tail":" effective on 15th day after "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", see section 214(a), (b) of "},{"tag":"ref","attrib":{"href":"/us/pl/98/573"},"text":"Pub. L. 98–573","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1304"},"text":"section 1304 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id05465786-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1953 Amendment; Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by act ","children":[{"tag":"date","attrib":{"date":"1953-08-08"},"text":"Aug. 8, 1953","children":[],"tail":", effective on and after thirtieth day following "},{"tag":"date","attrib":{"date":"1953-08-08"},"text":"Aug. 8, 1953","children":[],"tail":", and savings provision, see notes set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1304"},"text":"section 1304 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id05465787-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Customs Declarations; Proximity of Livestock","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/90/tV/s513"},"text":"Pub. L. 108–90, title V, § 513","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-10-01"},"text":"Oct. 1, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1154"},"text":"117 Stat. 1154","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/90/tV/s513"},"text":"“For fiscal year 2004 and thereafter, none of the funds appropriated or otherwise made available to the Department of Homeland Security may be used for the production of customs declarations that do not inquire whether the passenger had been in the proximity of livestock.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
