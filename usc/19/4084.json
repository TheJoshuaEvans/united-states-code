{"tag":"section","attrib":{"id":"id064307b7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4084"},"text":null,"children":[{"tag":"num","attrib":{"value":"4084"},"text":"§ 4084.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Articles exempt from relief","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The President may not provide import relief under this part with respect to any article if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id064307b8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4084/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" import relief previously has been provided under this part with respect to that article; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064307b9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4084/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the article is subject to import relief under—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id064307ba-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4084/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" part A; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id064307bb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4084/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 1 of title II of the Trade Act of 1974 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2251"},"text":"19 U.S.C. 2251","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id064307bc-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/53/tIII/s324"},"text":"Pub. L. 109–53, title III, § 324","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-02"},"text":"Aug. 2, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/494"},"text":"119 Stat. 494","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id064307bd-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id064307be-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination of section by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/53/s107/d"},"text":"section 107(d) of Pub. L. 109–53","children":[],"tail":", see Effective and Termination Dates note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id064307bf-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id064307c0-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Part A, referred to in par. (2)(A), was in the original “subtitle A”, meaning subtitle A (§§ 311–316) of title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/53"},"text":"Pub. L. 109–53","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-02"},"text":"Aug. 2, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/488"},"text":"119 Stat. 488","children":[],"tail":", which enacted part A of this subchapter and amended "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2252"},"text":"section 2252 of this title","children":[],"tail":". For complete classification of subtitle A to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Trade Act of 1974, referred to in par. (2)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618"},"text":"Pub. L. 93–618","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1978"},"text":"88 Stat. 1978","children":[],"tail":". Chapter 1 of title II of the Act is classified generally to part 1 (§ 2251 et seq.) of subchapter II of chapter 12 of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2101"},"text":"section 2101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id064307c1-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id064307c2-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective and Termination Dates","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date the Dominican Republic-Central America-United States Free Trade Agreement enters into force (","children":[{"tag":"date","attrib":{"date":"2006-03-01"},"text":"Mar. 1, 2006","children":[],"tail":") and to cease to have effect on the date the Agreement ceases to be in force with respect to the United States, and, during any period in which a country ceases to be a CAFTA–DR country, to cease to have effect with respect to such country, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/53/s107"},"text":"section 107 of Pub. L. 109–53","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s4001"},"text":"section 4001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
