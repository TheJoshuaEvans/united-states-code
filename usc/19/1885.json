{"tag":"section","attrib":{"id":"id0592a2a4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1885"},"text":null,"children":[{"tag":"num","attrib":{"value":"1885"},"text":"§ 1885.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of proclamations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0592a2a5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1885/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/tVI/s602/d"},"text":"Pub. L. 93–618, title VI, § 602(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2072"},"text":"88 Stat. 2072","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0592a2a6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1885/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President may at any time terminate, in whole or in part, any proclamation made under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0592a2a7-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/794/tII/s255"},"text":"Pub. L. 87–794, title II, § 255","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-11"},"text":"Oct. 11, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/880"},"text":"76 Stat. 880","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/618/tVI/s602/d"},"text":"Pub. L. 93–618, title VI, § 602(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"hr