{"tag":"section","attrib":{"id":"id0653d0d0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4512"},"text":null,"children":[{"tag":"num","attrib":{"value":"4512"},"text":"§ 4512.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship of the USMCA to United States and State law","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0653d0d1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4512/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship of USMCA to United States law","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0653d0d2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4512/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States law to prevail in conflict","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No provision of the USMCA, nor the application of any such provision to any person or circumstance, which is inconsistent with any law of the United States, shall have effect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0653d0d3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4512/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this Act shall be construed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0653d0d4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4512/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to amend or modify any law of the United States, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0653d0d5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4512/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to limit any authority conferred under any law of the United States,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"unless specifically provided for in this Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0653d0d6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4512/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship of USMCA to State law","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0653d0d7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4512/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Legal challenge","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No State law, or the application thereof, may be declared invalid as to any person or circumstance on the ground that the provision or application is inconsistent with the USMCA, except in an action brought by the United States for the purpose of declaring such law or application invalid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0653d0d8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4512/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of State law","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, the term “State law” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0653d0d9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4512/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any law of a political subdivision of a State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0653d0da-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4512/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any State law regulating or taxing the business of insurance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0653d0db-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4512/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of USMCA with respect to private remedies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No person other than the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0653d0dc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4512/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall have any cause of action or defense under the USMCA or by virtue of congressional approval thereof; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0653d0dd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4512/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may challenge, in any action brought under any provision of law, any action or inaction by any department, agency, or other instrumentality of the United States, any State, or any political subdivision of a State, on the ground that such action or inaction is inconsistent with the USMCA.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0653d0de-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113/tI/s102"},"text":"Pub. L. 116–113, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-01-29"},"text":"Jan. 29, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/15"},"text":"134 Stat. 15","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0653d0df-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0653d0e0-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0653d0e1-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (a)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113"},"text":"Pub. L. 116–113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-01-29"},"text":"Jan. 29, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/11"},"text":"134 Stat. 11","children":[],"tail":", known as the United States-Mexico-Canada Agreement Implementation Act. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s4501"},"text":"section 4501 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
