{"tag":"section","attrib":{"id":"id058905a2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677i"},"text":null,"children":[{"tag":"num","attrib":{"value":"1677i"},"text":"§ 1677i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Downstream product monitoring","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id058905a3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Petition requesting monitoring","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id058905a4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677i/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A domestic producer of an article that is like a component part or a downstream product may petition the administering authority to designate a downstream product for monitoring under subsection (b). The petition shall specify—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id058905a5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677i/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the downstream product,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id058905a6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677i/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the component product incorporated into such downstream product, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id058905a7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677i/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reasons for suspecting that the imposition of antidumping or countervailing duties has resulted in a diversion of exports of the component part into increased production and exportation to the United States of such downstream product.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id058905a8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677i/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination regarding petition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Within 14 days after receiving a petition submitted under paragraph (1), the administering authority shall determine—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id058905a9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677i/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether there is a reasonable likelihood that imports into the United States of the downstream product will increase as an indirect result of any diversion with respect to the component part, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id058905aa-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677i/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" whether—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id058905ab-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677i/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the component part is already subject to monitoring to aid in the enforcement of a bilateral arrangement (within the meaning of section 804 of the Trade and Tariff Act of 1984),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id058905ac-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677i/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" merchandise related to the component part and manufactured in the same foreign country in which the component part is manufactured has been the subject of a significant number of investigations suspended under section 1671c or 1673c of this title or countervailing or antidumping duty orders issued under this subtitle or section 1303 ","children":[{"tag":"ref","attrib":{"idref":"fn002056"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002056"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title, or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id058905ad-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677i/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" merchandise manufactured or exported by the manufacturer or exporter of the component part that is similar in description and use to the component part has been the subject of at least 2 investigations suspended under section 1671c or 1673c of this title or countervailing or antidumping duty orders issued under this subtitle or section 1303 ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id058905ae-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677i/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors to take into account","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making a determination under paragraph (2)(A), the administering authority may, if appropriate, take into account such factors as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id058905af-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677i/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the value of the component part in relation to the value of the downstream product,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id058905b0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677i/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the component part has been substantially transformed as a result of its incorporation into the downstream product, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id058905b1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677i/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relationship between the producers of component parts and producers of downstream products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id058905b2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677i/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication of determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The administering authority shall publish in the Federal Register notice of each determination made under paragraph (2) and, if the determination made under paragraph (2)(A) and a determination made under any subparagraph of paragraph (2)(B) are affirmative, shall transmit a copy of such determinations and the petition to the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id058905b3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677i/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determinations not subject to judicial review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, any determination made by the administering authority under paragraph (2) shall not be subject to judicial review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id058905b4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring by Commission","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id058905b5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677i/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the determination made under subsection (a)(2)(A) and a determination made under any clause of subsection (a)(2)(B) with respect to a petition are affirmative, the Commission shall immediately commence monitoring of trade in the downstream product that is the subject of the determination made under subsection (a)(2)(A). If the Commission finds that imports of a downstream product being monitored increased during any calendar quarter by 5 percent or more over the preceding quarter, the Commission shall analyze that increase in the context of overall economic conditions in the product sector.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id058905b6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677i/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall make quarterly reports to the administering authority regarding the monitoring and analyses conducted under paragraph (1). The Commission shall make the reports available to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id058905b7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677i/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action on basis of monitoring reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The administering authority shall review the information in the reports submitted by the Commission under subsection (b)(2) and shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id058905b8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677i/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider the information in determining whether to initiate an investigation under section 1671a(a) or 1673a(a) of this title regarding any downstream product, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id058905b9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677i/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" request the Commission to cease monitoring any downstream product if the information indicates that imports into the United States are not increasing and there is no reasonable likelihood of diversion with respect to component parts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id058905ba-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677i/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id058905bb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677i/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “component part” means any imported article that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id058905bc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677i/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" during the 5-year period ending on the date on which the petition is filed under subsection (a), has been subject to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id058905bd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677i/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a countervailing or antidumping duty order issued under this subtitle or section 1303 ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title that requires the deposit of estimated countervailing or antidumping duties imposed at a rate of at least 15 percent ad valorem, or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id058905be-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677i/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agreement entered into under section 1671c, 1673c, or 1303 ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title after a preliminary affirmative determination under section 1671b(b), 1673b(b)(1), or 1303 "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title was made by the administering authority which included a determination that the estimated net countervailable subsidy was at least 15 percent ad valorem or that the estimated average amount by which the normal value exceeded the export price (or the constructed export price) was at least 15 percent ad valorem, and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id058905bf-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677i/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" because of its inherent characteristics, is routinely used as a major part, component, assembly, subassembly, or material in a downstream product.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id058905c0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677i/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “downstream product” means any manufactured article—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id058905c1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677i/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is imported into the United States, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id058905c2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677i/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" into which is incorporated any component part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id058905c3-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title VII, § 780, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tI/s1320/a"},"text":"Pub. L. 100–418, title I, § 1320(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1189"},"text":"102 Stat. 1189","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/tII"},"text":"Pub. L. 103–465, title II","children":[],"tail":", §§ 233(a)(1)(E), (2)(A)(vi), 261(d)(1)(B)(iv), 270(a)(1)(M), "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4898"},"text":"108 Stat. 4898","children":[],"tail":", 4910, 4917.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id058905c4-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id058905c5-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id058905c6-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 804 of the Trade and Tariff Act of 1984, referred to in subsec. (a)(2)(B)(i), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/573/s804"},"text":"section 804 of Pub. L. 98–573","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2253"},"text":"section 2253 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1303"},"text":"Section 1303 of this title","children":[],"tail":", referred to in subsecs. (a)(2)(B)(ii), (iii) and (d)(1)(A)(i), (ii), is defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1677/26"},"text":"section 1677(26) of this title","children":[],"tail":" to mean section 1330 as in effect on the day before "},{"tag":"date","attrib":{"date":"1995-01-01"},"text":"Jan. 1, 1995","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id058905c7-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/s261/d/1/B/iv"},"text":"Pub. L. 103–465, § 261(d)(1)(B)(iv)","children":[],"tail":", substituted “or 1673a(a)” for “, 1673a(a), or 1303”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/s270/a/1/M"},"text":"Pub. L. 103–465, § 270(a)(1)(M)","children":[],"tail":", inserted “countervailable” before “subsidy”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/s233/a/1/E"},"text":"Pub. L. 103–465, § 233(a)(1)(E)","children":[],"tail":", (2)(A)(vi), substituted “normal value” for “foreign market value” and “export price (or the constructed export price)” for “United States price”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id058905c8-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id058905c9-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by sections 233(a)(1)(E), (2)(A)(vi) and 270(a)(1)(M) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465"},"text":"Pub. L. 103–465","children":[],"tail":" effective, except as otherwise provided, on the date on which the WTO Agreement enters into force with respect to the United States ("},{"tag":"date","attrib":{"date":"1995-01-01"},"text":"Jan. 1, 1995","children":[],"tail":"), and applicable with respect to investigations, reviews, and inquiries initiated and petitions filed under specified provisions of this chapter after such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/s291"},"text":"section 291 of Pub. L. 103–465","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1671"},"text":"section 1671 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/s261/d/1/B/iv"},"text":"section 261(d)(1)(B)(iv) of Pub. L. 103–465","children":[],"tail":" effective on the effective date of title II of "},{"tag":"ref","attrib":{"href":"/us/pl/103/465"},"text":"Pub. L. 103–465","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-01-01"},"text":"Jan. 1, 1995","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/s261/d/2"},"text":"section 261(d)(2) of Pub. L. 103–465","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1315"},"text":"section 1315 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
