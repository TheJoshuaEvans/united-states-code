{"tag":"section","attrib":{"id":"id05844aee-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677e"},"text":null,"children":[{"tag":"num","attrib":{"value":"1677e"},"text":"§ 1677e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determinations on basis of facts available","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05844aef-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05844af0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" necessary information is not available on the record, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05844af1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an interested party or any other person—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05844af2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677e/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" withholds information that has been requested by the administering authority or the Commission under this subtitle,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05844af3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677e/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fails to provide such information by the deadlines for submission of the information or in the form and manner requested, subject to subsections (c)(1) and (e) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1677m"},"text":"section 1677m of this title","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0586bbf4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677e/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" significantly impedes a proceeding under this subtitle, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0586bbf5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677e/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides such information but the information cannot be verified as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1677m/i"},"text":"section 1677m(i) of this title","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the administering authority and the Commission shall, subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1677m/d"},"text":"section 1677m(d) of this title","children":[],"tail":", use the facts otherwise available in reaching the applicable determination under this subtitle."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0586bbf6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adverse inferences","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0586bbf7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the administering authority or the Commission (as the case may be) finds that an interested party has failed to cooperate by not acting to the best of its ability to comply with a request for information from the administering authority or the Commission, the administering authority or the Commission (as the case may be), in reaching the applicable determination under this subtitle—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0586bbf8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677e/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may use an inference that is adverse to the interests of that party in selecting from among the facts otherwise available; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0586bbf9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677e/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not required to determine, or make any adjustments to, a countervailable subsidy rate or weighted average dumping margin based on any assumptions about information the interested party would have provided if the interested party had complied with the request for information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0586bbfa-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Potential sources of information for adverse inferences","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An adverse inference under paragraph (1)(A) may include reliance on information derived from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0586bbfb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677e/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the petition,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0586bbfc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677e/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a final determination in the investigation under this subtitle,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0586bbfd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677e/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any previous review under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1675"},"text":"section 1675 of this title","children":[],"tail":" or determination under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1675b"},"text":"section 1675b of this title","children":[],"tail":", or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0586bbfe-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677e/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other information placed on the record.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0586bbff-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corroboration of secondary information","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0586bc00-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677e/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), when the administering authority or the Commission relies on secondary information rather than on information obtained in the course of an investigation or review, the administering authority or the Commission, as the case may be, shall, to the extent practicable, corroborate that information from independent sources that are reasonably at their disposal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0586bc01-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677e/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The administrative authority and the Commission shall not be required to corroborate any dumping margin or countervailing duty applied in a separate segment of the same proceeding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0586bc02-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsidy rates and dumping margins in adverse inference determinations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0586bc03-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677e/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the administering authority uses an inference that is adverse to the interests of a party under subsection (b)(1)(A) in selecting among the facts otherwise available, the administering authority may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0586bc04-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677e/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a countervailing duty proceeding—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0586bc05-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677e/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use a countervailable subsidy rate applied for the same or similar program in a countervailing duty proceeding involving the same country; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0586bc06-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677e/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if there is no same or similar program, use a countervailable subsidy rate for a subsidy program from a proceeding that the administering authority considers reasonable to use; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0586bc07-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677e/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an antidumping duty proceeding, use any dumping margin from any segment of the proceeding under the applicable antidumping order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0586bc08-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677e/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discretion to apply highest rate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out paragraph (1), the administering authority may apply any of the countervailable subsidy rates or dumping margins specified under that paragraph, including the highest such rate or margin, based on the evaluation by the administering authority of the situation that resulted in the administering authority using an adverse inference in selecting among the facts otherwise available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0586bc09-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677e/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No obligation to make certain estimates or address certain claims","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the administering authority uses an adverse inference under subsection (b)(1)(A) in selecting among the facts otherwise available, the administering authority is not required, for purposes of subsection (c) or for any other purpose—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0586bc0a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677e/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to estimate what the countervailable subsidy rate or dumping margin would have been if the interested party found to have failed to cooperate under subsection (b)(1) had cooperated; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0586bc0b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677e/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to demonstrate that the countervailable subsidy rate or dumping margin used by the administering authority reflects an alleged commercial reality of the interested party.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0586bc0c-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title VII, § 776, as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/39/tI/s101"},"text":"Pub. L. 96–39, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/186"},"text":"93 Stat. 186","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/573/tVI/s618"},"text":"Pub. L. 98–573, title VI, § 618","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3037"},"text":"98 Stat. 3037","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tI"},"text":"Pub. L. 100–418, title I","children":[],"tail":", §§ 1326(d)(1), 1331, "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1204"},"text":"102 Stat. 1204","children":[],"tail":", 1207; "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/tII/s231/c"},"text":"Pub. L. 103–465, title II, § 231(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4896"},"text":"108 Stat. 4896","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/27/tV/s502"},"text":"Pub. L. 114–27, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-06-29"},"text":"June 29, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/383"},"text":"129 Stat. 383","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0586bc0d-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0586bc0e-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0586bc0f-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/27/s502/1"},"text":"Pub. L. 114–27, § 502(1)","children":[],"tail":", inserted par. (1) designation and heading before “If the administering”, substituted “under this subtitle—” for “under this subtitle, may use”, inserted “(A) may use” before “an inference that is adverse”, substituted “facts otherwise available; and” for “facts otherwise available. Such adverse inference may include”, added subpar. (B), inserted par. (2) designation, heading, and “An adverse inference under paragraph (1)(A) may include” before “reliance on information”, and redesignated former pars. (1) to (4) as subpars. (A) to (D), respectively, of par. (2) and realigned margins."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/27/s502/2"},"text":"Pub. L. 114–27, § 502(2)","children":[],"tail":", designated existing provisions as par. (1) and inserted heading, substituted “Except as provided in paragraph (2), when the” for “When the”, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/27/s502/3"},"text":"Pub. L. 114–27, § 502(3)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465"},"text":"Pub. L. 103–465","children":[],"tail":" amended section generally, substituting present provisions for provisions relating to verification of information, certification of submissions, and determinations required to be made on best information available."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/s1331/1"},"text":"Pub. L. 100–418, § 1331(1)","children":[],"tail":", (3), added subsec. (a). Former subsec. (a) redesignated (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/s1331/1"},"text":"Pub. L. 100–418, § 1331(1)","children":[],"tail":", (2), redesignated former subsec. (a) as (b) and in heading substituted “Verification” for “General rule”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/s1326/d/1"},"text":"Pub. L. 100–418, § 1326(d)(1)","children":[],"tail":", which directed the amendment of this subtitle by substituting “subparagraph (C), (D), (E), (F), or (G) of "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1677/9"},"text":"section 1677(9) of this title","children":[],"tail":"” for “subparagraph (C), (D), (E), or (F), of "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1677/9"},"text":"section 1677(9) of this title","children":[],"tail":"” was executed to subsec. (b)(3)(A) of this section by substituting “section 1677(9)(C), (D), (E), (F), or (G) of this title” for “section 1677(9)(C), (D), (E), or (F) of this title” to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/s1331/1"},"text":"Pub. L. 100–418, § 1331(1)","children":[],"tail":", redesignated former subsec. (b) as (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/573"},"text":"Pub. L. 98–573","children":[],"tail":" amended subsec. (a) generally, which prior to amendment read as follows: “Except with respect to information the verification of which is waived under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1673b/b/2"},"text":"section 1673b(b)(2) of this title","children":[],"tail":", the administering authority shall verify all information relied upon in making a final determination in an investigation. In publishing such a determination, the administering authority shall report the methods and procedures used to verify such information. If the administering authority is unable to verify the accuracy of the information submitted, it shall use the best information available to it as the basis for its determination, which may include the information submitted in support of the petition.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0586bc10-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0586bc11-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465"},"text":"Pub. L. 103–465","children":[],"tail":" effective, except as otherwise provided, on the date on which the WTO Agreement enters into force with respect to the United States ("},{"tag":"date","attrib":{"date":"1995-01-01"},"text":"Jan. 1, 1995","children":[],"tail":"), and applicable with respect to investigations, reviews, and inquiries initiated and petitions filed under specified provisions of this chapter after such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/s291"},"text":"section 291 of Pub. L. 103–465","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1671"},"text":"section 1671 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0586bc12-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418"},"text":"Pub. L. 100–418","children":[],"tail":" applicable with respect to investigations initiated after "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", and to reviews initiated under section 1673e(c) or 1675 of this title after "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/s1337/b"},"text":"section 1337(b) of Pub. L. 100–418","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1671"},"text":"section 1671 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0586bc13-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendmen