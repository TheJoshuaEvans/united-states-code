{"tag":"section","attrib":{"id":"id065d4618-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4661"},"text":null,"children":[{"tag":"num","attrib":{"value":"4661"},"text":"§ 4661.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of Labor shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id065d4619-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4661/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hire and fix the compensation of up to 5 additional full-time officers or employees of the Department of Labor; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065d461a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4661/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" detail or assign such officers or employees to the United States Embassy or a United States Consulate in Mexico to carry out the duties described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4662"},"text":"section 4662 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id065d461b-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113/tVII/s721"},"text":"Pub. L. 116–113, title VII, § 721","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-01-29"},"text":"Jan. 29, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/86"},"text":"134 Stat. 86","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
