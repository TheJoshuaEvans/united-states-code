{"tag":"section","attrib":{"id":"id06515ede-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4374"},"text":null,"children":[{"tag":"num","attrib":{"value":"4374"},"text":"§ 4374.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation with foreign countries on preventing evasion of trade remedy laws","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id06515edf-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4374/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bilateral agreements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id06515ee0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4374/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall seek to negotiate and enter into bilateral agreements with the customs authorities or other appropriate authorities of foreign countries for purposes of cooperation on preventing evasion of the trade remedy laws of the United States and the trade remedy laws of the other country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06515ee1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4374/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provisions and authorities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall seek to include in each such bilateral agreement the following provisions and authorities:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id06515ee2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4374/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" On the request of the importing country, the exporting country shall provide, consistent with its laws, regulations, and procedures, production, trade, and transit documents and other information necessary to determine whether an entry or entries exported from the exporting country are subject to the importing country’s trade remedy laws.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06515ee3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4374/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" On the written request of the importing country, the exporting country shall conduct a verification for purposes of enabling the importing country to make a determination described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06515ee4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4374/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The exporting country may allow the importing country to participate in a verification described in subparagraph (B), including through a site visit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06515ee5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4374/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the exporting country does not allow participation of the importing country in a verification described in subparagraph (B), the importing country may take this fact into consideration in its trade enforcement and compliance assessment activities regarding the compliance of the exporting country’s exports with the importing country’s trade remedy laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id06515ee6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4374/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commissioner is authorized to take into consideration whether a country is a signatory to a bilateral agreement described in subsection (a) or a party to the USMCA (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4502"},"text":"section 4502 of this title","children":[],"tail":") and the extent to which the country is cooperating under the bilateral agreement or the USMCA, as the case may be, for purposes of trade enforcement and compliance assessment activities of U.S. Customs and Border Protection that concern evasion by such country’s exports."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id06515ee7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4374/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than December 31 of each calendar year beginning after ","children":[{"tag":"date","attrib":{"date":"2016-02-24"},"text":"February 24, 2016","children":[],"tail":", the Secretary shall submit to the appropriate congressional committees a report summarizing—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id06515ee8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4374/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status of any ongoing negotiations of bilateral agreements described in subsection (a), including the identities of the countries involved in such negotiations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06515ee9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4374/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms of any completed bilateral agreements described in subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06515eea-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4374/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bilateral cooperation and other activities conducted pursuant to or enabled by any completed bilateral agreements described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id06515eeb-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/125/tIV/s414"},"text":"Pub. L. 114–125, title IV, § 414","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-24"},"text":"Feb. 24, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/160"},"text":"130 Stat. 160","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/113/tIV/s401"},"text":"Pub. L. 116–113, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-01-29"},"text":"Jan. 29, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/61"},"text":"134 Stat. 61","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id06515eec-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id06515eed-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id06515eee-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113"},"text":"Pub. L. 116–113","children":[],"tail":" inserted “or a party to the USMCA (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s4502"},"text":"section 4502 of this title","children":[],"tail":")” after “subsection (a)” and “or the USMCA, as the case may be,” after “the bilateral agreement”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id06515eef-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id06515ef0-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2020 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113"},"text":"Pub. L. 116–113","children":[],"tail":" effective on the date on which the USMCA enters into force ("},{"tag":"date","attrib":{"date":"2020-07-01"},"text":"July 1, 2020","children":[],"tail":"), but not applicable to certain determinations under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1516a"},"text":"section 1516a of this title","children":[],"tail":" or binational panel reviews under NAFTA, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/113/s432"},"text":"section 432 of Pub. L. 116–113","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1516a"},"text":"section 1516a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id06515ef1-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effect of Termination of USMCA Country Status","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to effect of termination of USMCA country status on sections 401 to 432 of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113"},"text":"Pub. L. 116–113","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s4601"},"text":"section 4601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
