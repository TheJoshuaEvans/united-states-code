{"tag":"section","attrib":{"id":"id065d4600-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4647"},"text":null,"children":[{"tag":"num","attrib":{"value":"4647"},"text":"§ 4647.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hotline","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Interagency Labor Committee shall establish a web-based hotline, monitored by the Department of Labor, to receive confidential information regarding labor issues among USMCA countries directly from interested parties, including Mexican workers.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id065d4601-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113/tVII/s717"},"text":"Pub. L. 116–113, title VII, § 717","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-01-29"},"text":"Jan. 29, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/85"},"text":"134 Stat. 85","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
