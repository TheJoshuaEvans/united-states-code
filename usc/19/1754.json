{"tag":"section","attrib":{"id":"id059031cc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1754"},"text":null,"children":[{"tag":"num","attrib":{"value":"1754"},"text":"§ 1754.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Marking, packaging, and labeling requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id059031cd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1754/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Marking requirements of the customs laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Articles entered under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1752"},"text":"section 1752 of this title","children":[],"tail":" shall not be subject to any marking requirements of the customs laws, except that when any such article is entered for consumption under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1753"},"text":"section 1753 of this title","children":[],"tail":" it shall not be released from customs custody until the marking requirements of the customs laws have been complied with."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id059031ce-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1754/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Packaging, marking, or labeling requirements of the internal-revenue laws or the Federal Alcohol Administration Act","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Articles entered under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1752"},"text":"section 1752 of this title","children":[],"tail":" shall not be subject to the packaging, marking, or labeling requirements of the internal-revenue laws or of the Federal Alcohol Administration Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t27/s201"},"text":"27 U.S.C. 201","children":[],"tail":" et seq.], except that any such article failing to comply with such requirements—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id059031cf-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1754/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be conspicuously marked prior to exhibition “Not labeled or packaged as required by law—not for sale”, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id059031d0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1754/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when entered for consumption under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1753"},"text":"section 1753 of this title","children":[],"tail":", shall not be released from customs custody until such packaging, marking, and labeling requirements have been complied with."}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The application of the permit requirements of the Federal Alcohol Administration Act and the occupational taxes prescribed by chapter 51 of the Internal Revenue Code of 1986 shall be determined without regard to this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id059031d1-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/14/s5"},"text":"Pub. L. 86–14, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-04-22"},"text":"Apr. 22, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/19"},"text":"73 Stat. 19","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id059031d2-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id059031d3-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id059031d4-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Alcohol Administration Act, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-29/ch814"},"text":"act Aug. 29, 1935, ch. 814","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/977"},"text":"49 Stat. 977","children":[],"tail":", which is classified generally to subchapter I (§ 201 et seq.) of chapter 8 of Title 27, Intoxicating Liquors. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t27/s201"},"text":"section 201 of Title 27","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Chapter 51 of the Internal Revenue Code of 1986, referred to in subsec. (b), is classified to section 5001 et seq. of Title 26, Internal Revenue Code.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id059031d5-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" substituted “Internal Revenue Code of 1986” for “Internal Revenue Code of 1954”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
