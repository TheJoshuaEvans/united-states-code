{"tag":"section","attrib":{"id":"id0599ce5a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2080"},"text":null,"children":[{"tag":"num","attrib":{"value":"2080"},"text":"§ 2080.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advances from available appropriations; rules and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Advances pursuant to this Act, in connection with the enforcement of the customs laws may be made, notwithstanding the provisions of section 3324(a) and (b) of title 31, from the appropriations available for the enforcement of such laws. The Secretary of the Treasury is authorized to prescribe such rules and regulations concerning advances made pursuant to this Act as are necessary or appropriate for the protection of the interests of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0599ce5b-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1928-03-28/ch266/s5"},"text":"Mar. 28, 1928, ch. 266, § 5","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1939-08-07/ch566/s1"},"text":"Aug. 7, 1939, ch. 566, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/1263"},"text":"53 Stat. 1263","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/91/513/tIII/s1102/n/4"},"text":"Pub. L. 91–513, title III, § 1102(n)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-27"},"text":"Oct. 27, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1293"},"text":"84 Stat. 1293","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0599ce5c-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0599ce5d-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"ta