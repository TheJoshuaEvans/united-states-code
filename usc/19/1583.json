{"tag":"section","attrib":{"id":"id055e254d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1583"},"text":null,"children":[{"tag":"num","attrib":{"value":"1583"},"text":"§ 1583.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Examination of outbound mail","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id055e254e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1583/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Examination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id055e254f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1583/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of ensuring compliance with the Customs laws of the United States and other laws enforced by the Customs Service, including the provisions of law described in paragraph (2), a Customs officer may, subject to the provisions of this section, stop and search at the border, without a search warrant, mail of domestic origin transmitted for export by the United States Postal Service and foreign mail transiting the United States that is being imported or exported by the United States Postal Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id055e2550-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1583/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provisions of law described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The provisions of law described in this paragraph are the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id055e2551-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1583/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s5316"},"text":"Section 5316 of title 31","children":[],"tail":" (relating to reports on exporting and importing monetary instruments)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id055e2552-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1583/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sections 1461, 1463, 1465, and 1466, and chapter 110 of title 18 (relating to obscenity and child pornography).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id055e2553-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1583/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s953"},"text":"Section 953 of title 21","children":[],"tail":" (relating to exportation of controlled substances)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id055e2554-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1583/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Export Administration Act of 1979 (50 U.S.C. App. 2401 et seq.).","children":[{"tag":"ref","attrib":{"idref":"fn002037"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002037"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id055e2555-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1583/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2778"},"text":"Section 2778 of title 22","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id055e2556-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1583/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The International Emergency Economic Powers Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"50 U.S.C. 1701","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id055e2557-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1583/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Search of mail not sealed against inspection and other mail","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Mail not sealed against inspection under the postal laws and regulations of the United States, mail which bears a Customs declaration, and mail with respect to which the sender or addressee has consented in writing to search, may be searched by a Customs officer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id055e2558-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1583/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Search of mail sealed against inspection weighing in excess of 16 ounces","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id055e2559-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1583/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Mail weighing in excess of 16 ounces sealed against inspection under the postal laws and regulations of the United States may be searched by a Customs officer, subject to paragraph (2), if there is reasonable cause to suspect that such mail contains one or more of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id055e255a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1583/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Monetary instruments, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1956"},"text":"section 1956 of title 18","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id055e255b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1583/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A weapon of mass destruction, as defined in section 2332a(b) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of title 18."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id055e255c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1583/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A drug or other substance listed in schedule I, II, III, or IV in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s812"},"text":"section 812 of title 21","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id055e255d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1583/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" National defense and related information transmitted in violation of any of sections 793 through 798 of title 18.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id055e255e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1583/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Merchandise mailed in violation of section 1715 or 1716 of title 18.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id055e255f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1583/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Merchandise mailed in violation of any provision of chapter 71 (relating to obscenity) or chapter 110 (relating to sexual exploitation and other abuse of children) of title 18.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id055e2560-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1583/c/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Merchandise mailed in violation of the Export Administration Act of 1979 (50 U.S.C. App. 2401 et seq.).","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id055e2561-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1583/c/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Merchandise mailed in violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2778"},"text":"section 2778 of title 22","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id055e2562-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1583/c/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Merchandise mailed in violation of the International Emergency Economic Powers Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"50 U.S.C. 1701","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id055e2563-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1583/c/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Merchandise mailed in violation of the Trading with the Enemy Act (50 U.S.C. App. 1 et seq.).","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id055e2564-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1583/c/1/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Merchandise subject to any other law enforced by the Customs Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id055e2565-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1583/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No person acting under the authority of paragraph (1) shall read, or authorize any other person to read, any correspondence contained in mail sealed against inspection unless prior to so reading—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id055e2566-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1583/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a search warrant has been issued pursuant to rule 41 of the Federal Rules of Criminal Procedure; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id055e2567-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1583/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sender or addressee has given written authorization for such reading.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id055e2568-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1583/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Search of mail sealed against inspection weighing 16 ounces or less","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this section, subsection (a)(1) shall not apply to mail weighing 16 ounces or less sealed against inspection under the postal laws and regulations of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id055e2569-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title IV, § 583, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/210/dA/tIII/s344/a"},"text":"Pub. L. 107–210, div. A, title III, § 344(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-06"},"text":"Aug. 6, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/986"},"text":"116 Stat. 986","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/429/tII/s2004/a/12"},"text":"Pub. L. 108–429, title II, § 2004(a)(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-03"},"text":"Dec. 3, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2590"},"text":"118 Stat. 2590","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id055e256a-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id055e256b-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id055e256c-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Export Administration Act of 1979, referred to in subsecs. (a)(2)(D) and (c)(1)(G), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/72"},"text":"Pub. L. 96–72","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-09-29"},"text":"Sept. 29, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/503"},"text":"93 Stat. 503","children":[],"tail":", which was classified principally to section 2401 et seq. of the former Appendix to Title 50, War and National Defense, prior to editorial reclassification and renumbering as chapter 56 (§ 4601 et seq.) of Title 50, and was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tXVII/s1766/a"},"text":"Pub. L. 115–232, div. A, title XVII, § 1766(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2232"},"text":"132 Stat. 2232","children":[],"tail":", except for sections 11A, 11B, and 11C thereof ("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4611"},"text":"50 U.S.C. 4611","children":[],"tail":", 4612, 4613)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The International Emergency Economic Powers Act, referred to in subsecs. (a)(2)(F) and (c)(1)(I), is title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/223"},"text":"Pub. L. 95–223","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-12-28"},"text":"Dec. 28, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1626"},"text":"91 Stat. 1626","children":[],"tail":", which is classified generally to chapter 35 (§ 1701 et seq.) of Title 50, War and National Defense. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"section 1701 of Title 50","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2332a/b"},"text":"Section 2332a(b) of title 18","children":[],"tail":", referred to in subsec. (c)(1)(B), does not define the term “weapon of mass destruction”. However, that term is defined elsewhere in that section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Trading with the Enemy Act, referred to in subsec. (c)(1)(J), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1917-10-06/ch106"},"text":"act Oct. 6, 1917, ch. 106","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/40/411"},"text":"40 Stat. 411","children":[],"tail":", which was classified to sections 1 to 6, 7 to 39, and 41 to 44 of the former Appendix to Title 50, War and National Defense, prior to editorial reclassification and renumbering as chapter 53 (§ 4301 et seq.) of Title 50. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Rule 41 of the Federal Rules of Criminal Procedure, referred to in subsec. (c)(2)(A), is set out in the Appendix to Title 18, Crimes and Criminal Procedure.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id055e256d-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1583, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title IV, § 583, "},{"tag":"ref","attrib":{"href":"/us/stat/46/748"},"text":"46 Stat. 748","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1956-08-02/ch887/s4/c"},"text":"Aug. 2, 1956, ch. 887, § 4(c)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/948"},"text":"70 Stat. 948","children":[],"tail":", related to delivery and certification of manifest, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/182/tVI/s690/b/9"},"text":"Pub. L. 103–182, title VI, § 690(b)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-08"},"text":"Dec. 8, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2223"},"text":"107 Stat. 2223","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id055e256e-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/429"},"text":"Pub. L. 108–429","children":[],"tail":" realigned margins."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id055e256f-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id055e2570-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/210/dA/tIII/s344/c"},"text":"Pub. L. 107–210, div. A, title III, § 344(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-06"},"text":"Aug. 6, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/987"},"text":"116 Stat. 987","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/210/dA/tIII/s344/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), this section [enacting this section and provisions set out as a note under this section] and the amendments made by this section shall take effect on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2002-08-06"},"text":"Aug. 6, 2002","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certification with respect to foreign mail","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The provisions of section 583 of the Tariff Act of 1930 [this section] relating to foreign mail transiting the United States that is imported or exported by the United States Postal Service shall not take effect until the Secretary of State certifies to Congress, pursuant to subsection (b) [set out as a note below], that the application of such section 583 is consistent with international law and any international obligation of the United States.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id055e2571-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions, personnel, assets, and liabilities of the United States Customs Service of the Department of the Treasury, including functions of the Secretary of the Treasury relating thereto, to the Secretary of Homeland Security, and for treatment of related references, see sections 203(1), 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":". For establishment of U.S. Customs and Border Protection in the Department of Homeland Security, treated as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" as of "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s211"},"text":"section 211 of Title 6","children":[],"tail":", as amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/114/125"},"text":"Pub. L. 114–125","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/114/125/s802/b"},"text":"section 802(b) of Pub. L. 114–125","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s211"},"text":"section 211 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id055e2572-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Certification by Secretary","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/210/dA/tIII/s344/b"},"text":"Pub. L. 107–210, div. A, title III, § 344(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-06"},"text":"Aug. 6, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/987"},"text":"116 Stat. 987","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/210/dA/tIII/s344/b"},"text":"“Not later than 3 months after the date of enactment of this section [","children":[{"tag":"date","attrib":{"date":"2002-08-06"},"text":"Aug. 6, 2002","children":[],"tail":"], the Secretary of State shall determine whether the application of section 583 of the Tariff Act of 1930 [this section] to foreign mail transiting the United States that is imported or exported by the United States Postal Service is being handled in a manner consistent with international law and any international obligation of the United States. Section 583 of such Act shall not apply to such foreign mail unless the Secretary certifies to Congress that the application of such section 583 is consistent with international law and any international obligation of the United States.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
