{"tag":"section","attrib":{"id":"id064f15d8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4372"},"text":null,"children":[{"tag":"num","attrib":{"value":"4372"},"text":"§ 4372.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection of information on evasion of trade remedy laws","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id064f15d9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4372/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to collect information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To determine whether covered merchandise is being entered into the customs territory of the United States through evasion, the Secretary, acting through the Commissioner—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id064f15da-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4372/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall exercise all existing authorities to collect information needed to make the determination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064f15db-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4372/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may collect such additional information as is necessary to make the determination through such methods as the Commissioner considers appropriate, including by issuing questionnaires with respect to the entry or entries at issue to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id064f15dc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4372/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person who filed an allegation with respect to the covered merchandise;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id064f15dd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4372/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person who is alleged to have entered the covered merchandise into the customs territory of the United States through evasion; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06515ece-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4372/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other person who is determined to have information relevant to the allegation of entry of covered merchandise into the customs territory of the United States through evasion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id06515ecf-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4372/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adverse inference","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id06515ed0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4372/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of adverse inference","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id06515ed1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4372/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary finds that a person described in subparagraph (B) has failed to cooperate by not acting to the best of the person’s ability to comply with a request for information under subsection (a), the Secretary may, in making a determination whether an entry or entries of covered merchandise may constitute merchandise that is entered into the customs territory of the United States through evasion, use an inference that is adverse to the interests of that person in selecting from among the facts otherwise available to determine whether evasion has occurred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06515ed2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4372/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person described in this subparagraph is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id06515ed3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4372/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person who filed an allegation with respect to covered merchandise;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id06515ed4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4372/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person alleged to have entered covered merchandise into the customs territory of the United States through evasion; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id06515ed5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4372/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a foreign producer or exporter of covered merchandise that is alleged to have entered into the customs territory of the United States through evasion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06515ed6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4372/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An inference described in subparagraph (A) may be used under that subparagraph with respect to a person described in clause (ii) or (iii) of subparagraph (B) without regard to whether another person involved in the same transaction or transactions under examination has provided the information sought by the Secretary, such as import or export documentation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06515ed7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4372/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adverse inference described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An adverse inference used under paragraph (1)(A) may include reliance on information derived from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id06515ed8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4372/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the allegation of evasion of the trade remedy laws, if any, submitted to U.S. Customs and Border Protection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06515ed9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4372/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a determination by the Commissioner in another investigation, proceeding, or other action regarding evasion of the unfair trade laws; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06515eda-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4372/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other available information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id06515edb-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/125/tIV/s412"},"text":"Pub. L. 114–125, title IV, § 412","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-24"},"text":"Feb. 24, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/158"},"text":"130 Stat. 158","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
