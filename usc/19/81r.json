{"tag":"section","attrib":{"id":"id050f6917-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s81r"},"text":null,"children":[{"tag":"num","attrib":{"value":"81r"},"text":"§ 81r.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revocation of grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id050f6918-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s81r/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedure for revocation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the event of repeated willful violations of any of the provisions of this chapter by the grantee, the Board may revoke the grant after four months’ notice to the grantee and affording it an opportunity to be heard. The testimony taken before the Board shall be reduced to writing and filed in the records of the Board together with the decision reached thereon.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id050f6919-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s81r/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attendance of witnesses and production of evidence","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the conduct of any proceeding under this section for the revocation of a grant the Board may compel the attendance of witnesses and the giving of testimony and the production of documentary evidence, and for such purpose may invoke the aid of the district courts of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id050f691a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s81r/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nature of order of revocation; appeal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An order under the provisions of this section revoking the grant issued by the Board shall be final and conclusive, unless within ninety days after its service the grantee appeals to the court of appeals for the circuit in which the zone is located by filing with the clerk of said court a written petition praying that the order of the Board be set aside. Such order shall be stayed pending the disposition of appellate proceedings by the court. The clerk of the court in which such a petition is filed shall immediately cause a copy thereof to be delivered to the Board and it shall thereupon file in the court the record in the proceedings held before it under this section, as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s2112"},"text":"section 2112 of title 28","children":[],"tail":". The testimony and evidence taken or submitted before the Board, duly certified and filed as a part of the record, shall be considered by the court as the evidence in the case."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id050f691b-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-18/ch590/s18"},"text":"June 18, 1934, ch. 590, § 18","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/1002"},"text":"48 Stat. 1002","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646/s32/a"},"text":"June 25, 1948, ch. 646, § 32(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/991"},"text":"62 Stat. 991","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-05-24/ch139/s127"},"text":"May 24, 1949, ch. 139, § 127","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/107"},"text":"63 Stat. 107","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/791/s11"},"text":"Pub. L. 85–791, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-28"},"text":"Aug. 28, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/945"},"text":"72 Stat. 945","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id050f691c-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id050f691d-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id050f691e-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1958—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/791"},"text":"Pub. L. 85–791","children":[],"tail":" substituted “thereupon file in the court” for “forthwith prepare, certify, and file in the court a full and accurate transcript of” and “as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s2112"},"text":"section 2112 of title 28","children":[],"tail":"” for “the charges, the evidence, and the order revoking the grant” in third sentence."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id050f691f-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id050f6920-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1948-06-25"},"text":"June 25, 1948","children":[],"tail":", eff. "},{"tag":"date","attrib":{"date":"1948-09-01"},"text":"Sept. 1, 1948","children":[],"tail":", as amended by act "},{"tag":"date","attrib":{"date":"1949-05-24"},"text":"May 24, 1949","children":[],"tail":", substituted “court of appeals” for “circuit court of appeals”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
