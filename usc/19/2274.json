{"tag":"section","attrib":{"id":"id05bff44c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2274"},"text":null,"children":[{"tag":"num","attrib":{"value":"2274"},"text":"§ 2274.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study by Secretary of Labor when International Trade Commission begins investigation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05bff44d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2274/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subject matter of study","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whenever the International Trade Commission (hereafter referred to in this part as the “Commission”) begins an investigation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2252"},"text":"section 2252 of this title","children":[],"tail":" with respect to an industry, the Commission shall immediately notify the Secretary of such investigation, and the Secretary shall immediately begin a study of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id05bff44e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2274/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of workers in the domestic industry producing the like or directly competitive article who have been or are likely to be certified as eligible for adjustment assistance, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05bff44f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2274/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the adjustment of such workers to the import competition may be facilitated through the use of existing programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05bff450-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2274/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report; publication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The report of the Secretary of the study under subsection (a) of this section shall be made to the President not later than 15 days after the day on which the Commission makes its report under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2252/f"},"text":"section 2252(f) of this title","children":[],"tail":". Upon making his report to the President, the Secretary shall also promptly make it public (with the exception of information which the Secretary determines to be confidential) and shall have a summary of it published in the Federal Register."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05bff451-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/tII/s224"},"text":"Pub. L. 93–618, title II, § 224","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2020"},"text":"88 Stat. 2020","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXXV/s2513/a"},"text":"Pub. L. 97–35, title XXV, § 2513(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/889"},"text":"95 Stat. 889","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tI/s1401/b/1/B"},"text":"Pub. L. 100–418, title I, § 1401(b)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","c