{"tag":"section","attrib":{"id":"id05bb39c4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2254"},"text":null,"children":[{"tag":"num","attrib":{"value":"2254"},"text":"§ 2254.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring, modification, and termination of action","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05bb39c5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2254/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05bb39c6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2254/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" So long as any action taken under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2253"},"text":"section 2253 of this title","children":[],"tail":" remains in effect, the Commission shall monitor developments with respect to the domestic industry, including the progress and specific efforts made by workers and firms in the domestic industry to make a positive adjustment to import competition."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05bb39c7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2254/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the initial period during which the action taken under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2253"},"text":"section 2253 of this title","children":[],"tail":" is in effect exceeds 3 years, or if an extension of such action exceeds 3 years, the Commission shall submit a report on the results of the monitoring under paragraph (1) to the President and to the Congress not later than the date that is the mid-point of the initial period, and of each such extension, during which the action is in effect."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05bb39c8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2254/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the course of preparing each report under paragraph (2), the Commission shall hold a hearing at which interested persons shall be given a reasonable opportunity to be present, to produce evidence, and to be heard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05bb39c9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2254/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon request of the President, the Commission shall advise the President of its judgment as to the probable economic effect on the industry concerned of any reduction, modification, or termination of the action taken under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2253"},"text":"section 2253 of this title","children":[],"tail":" which is under consideration."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05bb39ca-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2254/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction, modification, and termination of action","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05bb39cb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2254/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Action taken under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2253"},"text":"section 2253 of this title","children":[],"tail":" may be reduced, modified, or terminated by the President (but not before the President receives the report required under subsection (a)(2)(A)) if the President—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05bb39cc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2254/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" after taking into account any report or advice submitted by the Commission under subsection (a) and after seeking the advice of the Secretary of Commerce and the Secretary of Labor, determines, on the basis that either—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id05bb39cd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2254/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the domestic industry has not made adequate efforts to make a positive adjustment to import competition, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05bb39ce-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2254/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effectiveness of the action taken under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2253"},"text":"section 2253 of this title","children":[],"tail":" has been impaired by changed economic circumstances,"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"that changed circumstances warrant such reduction, or termination; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05bb39cf-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2254/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determines, after a majority of the representatives of the domestic industry submits to the President a petition requesting such reduction, modification, or termination on such basis, that the domestic industry has made a positive adjustment to import competition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05bb39d0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2254/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding paragraph (1), the President is authorized to take such additional action under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2253"},"text":"section 2253 of this title","children":[],"tail":" as may be necessary to eliminate any circumvention of any action previously taken under such section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05bb39d1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2254/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding paragraph (1), the President may, after receipt of a Commission determination under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3538/a/4"},"text":"section 3538(a)(4) of this title","children":[],"tail":" and consulting with the Committee on Ways and Means of the House of Representatives and the Committee on Finance of the Senate, reduce, modify, or terminate action taken under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2253"},"text":"section 2253 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05bb39d2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2254/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension of action","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05bb39d3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2254/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon request of the President, or upon petition on behalf of the industry concerned filed with the Commission not earlier than the date which is 9 months, and not later than the date which is 6 months, before the date any action taken under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2253"},"text":"section 2253 of this title","children":[],"tail":" is to terminate, the Commission shall investigate to determine whether action under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2253"},"text":"section 2253 of this title","children":[],"tail":" continues to be necessary to prevent or remedy serious injury and whether there is evidence that the industry is making a positive adjustment to import competition."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05bb39d4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2254/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commission shall publish notice of the commencement of any proceeding under this subsection in the Federal Register and shall, within a reasonable time thereafter, hold a public hearing at which the Commission shall afford interested parties and consumers an opportunity to be present, to present evidence, and to respond to the presentations of other parties and consumers, and otherwise to be heard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05bb39d5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2254/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commission shall transmit to the President a report on its investigation and determination under this subsection not later than 60 days before the action under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2253"},"text":"section 2253 of this title","children":[],"tail":" is to terminate, unless the President specifies a different date."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05bb39d6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2254/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation of effectiveness of action","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05bb39d7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2254/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" After any action taken under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2253"},"text":"section 2253 of this title","children":[],"tail":" has terminated, the Commission shall evaluate the effectiveness of the actions in facilitating positive adjustment by the domestic industry to import competition, consistent with the reasons set out by the President in the report submitted to the Congress under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2253/b"},"text":"section 2253(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05bb39d8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2254/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" During the course of the evaluation conducted under paragraph (1), the Commission shall, after reasonable public notice, hold a hearing on the effectiveness of the action. All interested persons shall have the opportunity to attend such hearing and to present evidence or testimony at such hearing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05bb39d9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2254/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A report on the evaluation made under paragraph (1) and the hearings held under paragraph (2) shall be submitted by the Commission to the President and to the Congress by no later than the 180th day after the day on which the actions taken under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2253"},"text":"section 2253 of this title","children":[],"tail":" terminated."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05bb39da-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2254/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other provisions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05bb39db-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2254/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Action by the President under this part may be taken without regard to the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2136/a"},"text":"section 2136(a) of this title","children":[],"tail":" but only after consideration of the relation of such actions to the international obligations of the United States."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05bb39dc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2254/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Commission treats as the domestic industry production located in a major geographic area of the United States under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2252/c/4/C"},"text":"section 2252(c)(4)(C) of this title","children":[],"tail":", then the President shall take into account the geographic concentration of domestic production and of imports in that area in taking any action authorized under paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05bb39dd-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/tII/s204"},"text":"Pub. L. 93–618, title II, § 204","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tI/s1401/a"},"text":"Pub. L. 100–418, title I, § 1401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1238"},"text":"102 Stat. 1238","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tIX/s9001/a/8"},"text":"Pub. L. 100–647, title IX, § 9001(a)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3807"},"text":"102 Stat. 3807","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/tI/s129/a/7"},"text":"Pub. L. 103–465, title I, § 129(a)(7)","children":[],"tail":", title III, § 302(c), (d), "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4837"},"text":"108 Stat. 4837","children":[],"tail":", 4936.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05bb39de-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05bb39df-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id05bb39e0-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/s302/c/1"},"text":"Pub. L. 103–465, § 302(c)(1)","children":[],"tail":", amended par. (2) generally. Prior to amendment, par. (2) read as follows: “The Commission shall submit a report on the results of the monitoring under paragraph (1) to the President and to the Congress not later than—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) the 2nd-anniversary of the day on which the action under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2253"},"text":"section 2253 of this title","children":[],"tail":" first took effect; and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) the last day of each 2-year period occurring after the 2-year period referred to in subparagraph (A).”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/s302/c/2"},"text":"Pub. L. 103–465, § 302(c)(2)","children":[],"tail":", struck out “extension,” before “reduction,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/s129/a/7"},"text":"Pub. L. 103–465, § 129(a)(7)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/s302/d"},"text":"Pub. L. 103–465, § 302(d)","children":[],"tail":", added subsec. (c) and redesignated former subsecs. (c) and (d) as (d) and (e), respectivley."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsecs. (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" redesignated subsecs. (d) and (e) as (c) and (d), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id05bb39e1-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id05bb39e2-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/s129/a/7"},"text":"section 129(a)(7) of Pub. L. 103–465","children":[],"tail":" effective on the date on which the WTO Agreement enters into force with respect to the United States ("},{"tag":"date","attrib":{"date":"1995-01-01"},"text":"Jan. 1, 1995","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/s130"},"text":"section 130 of Pub. L. 103–465","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3531"},"text":"section 3531 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by section 302(c), (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465"},"text":"Pub. L. 103–465","children":[],"tail":" effective on the date on which the WTO Agreement enters into force with respect to the United States ["},{"tag":"date","attrib":{"date":"1995-01-01"},"text":"Jan. 1, 1995","children":[],"tail":"], see "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/s304/a"},"text":"section 304(a) of Pub. L. 103–465","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2252"},"text":"section 2252 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id05bb39e3-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" applicable as if such amendment took effect on "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s9001/b"},"text":"section 9001(b) of Pub. L. 100–647","children":[],"tail":", set out as an Effective and Termination Dates of 1988 Amendments note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s58c"},"text":"section 58c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id05bb39e4-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", and applicable with respect to investigations initiated under this part on or after that date, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/s1401/c"},"text":"section 1401(c) of Pub. L. 100–418","children":[],"tail":", set out as an Effective Date of 1988 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2251"},"text":"section 2251 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
