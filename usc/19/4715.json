{"tag":"section","attrib":{"id":"id065fb6be-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4715"},"text":null,"children":[{"tag":"num","attrib":{"value":"4715"},"text":"§ 4715.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other monitoring and enforcement actions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id065fb6bf-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4715/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Marine Mammal Protection Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce has authority to take appropriate monitoring or enforcement actions under the Marine Mammal Protection Act of 1972 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1361"},"text":"16 U.S.C. 1361","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id065fb6c0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4715/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Magnuson-Stevens Fishery Conservation and Management Act","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Commerce has authority to take appropriate monitoring or enforcement actions under the following provisions of law:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id065fb6c1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4715/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Magnuson-Stevens Fishery Conservation and Management Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1801"},"text":"16 U.S.C. 1801","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065fb6c2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4715/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Magnuson-Stevens Fishery Conservation and Management Reauthorization Act of 2006 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1891"},"text":"16 U.S.C. 1891","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065fb6c3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4715/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The High Seas Driftnet Fishing Moratorium Protection Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1826d"},"text":"16 U.S.C. 1826d","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065fb6c4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4715/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Shark Conservation Act of 2010 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1826k"},"text":"16 U.S.C. 1826k","children":[],"tail":" note; 1857 note)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065fb6c5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4715/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Shark Finning Prohibition Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1822"},"text":"16 U.S.C. 1822","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id065fb6c6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4715/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fishermen’s Protective Act of 1967","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce and Secretary of the Interior have authority to take appropriate monitoring or enforcement actions under section 8 of the Fishermen’s Protective Act of 1967 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s1978"},"text":"22 U.S.C. 1978","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id065fb6c7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4715/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreement on Port State Measures To Prevent, Deter and Eliminate Illegal, Unreported and Unregulated Fishing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce has authority to take appropriate monitoring or enforcement actions under the Port State Measures Agreement Act of 2015 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s7401"},"text":"16 U.S.C. 7401","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id065fb6c8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4715/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Endangered Species Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture, the Secretary of the Interior, the Secretary of Homeland Security, the Secretary of Commerce, and the Secretary of the Treasury have authority to take appropriate monitoring or enforcement actions under the Endangered Species Act of 1973 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1531"},"text":"16 U.S.C. 1531","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id065fb6c9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4715/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lacey Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture, the Secretary of Commerce, the Secretary of the Interior, the Secretary of Homeland Security, and the Secretary of the Treasury have authority to take appropriate monitoring or enforcement actions under the Lacey Act Amendments of 1981 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3371"},"text":"16 U.S.C. 3371","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id065fb6ca-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4715/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Migratory Bird Treaty Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior has authority to take appropriate monitoring or enforcement actions under the Migratory Bird Treaty Act of 1918 ","children":[{"tag":"ref","attrib":{"idref":"fn002189"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002189"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s703"},"text":"16 U.S.C. 703","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id065fb6cb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4715/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eliminate, Neutralize, and Disrupt Wildlife Trafficking Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State, the Secretary of the Interior, the Attorney General, and Administrator of the United States Agency for International Development have authority to take appropriate monitoring or enforcement actions under the Eliminate, Neutralize, and Disrupt Wildlife Trafficking Act of 2016 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s7601"},"text":"16 U.S.C. 7601","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id065fb6cc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4715/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wild Bird Conservation Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior has authority to take appropriate monitoring or enforcement actions under the Wild Bird Conservation Act of 1992 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s4901"},"text":"16 U.S.C. 4901","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id065fb6cd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4715/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Customs seizure and other authorities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Homeland Security has authority to take appropriate monitoring or enforcement actions under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1499"},"text":"section 1499 of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1595a"},"text":"section 1595a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id065fb6ce-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4715/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other relevant provisions of law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Interagency Environment Committee may request the heads of other Federal agencies to take appropriate monitoring or enforcement actions under other relevant provisions of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id065fb6cf-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4715/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section may be construed to supersede or otherwise limit in any manner the functions or authority of the head of any Federal agency described in this section under any other provision of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id065fb6d0-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113/tVIII/s815"},"text":"Pub. L. 116–113, title VIII, § 815","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-01-29"},"text":"Jan. 29, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"hre