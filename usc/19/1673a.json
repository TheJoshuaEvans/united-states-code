{"tag":"section","attrib":{"id":"id0575f370-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1673a"},"text":"§ 1673a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures for initiating an antidumping duty investigation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0575f371-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initiation by administering authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0575f372-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An antidumping duty investigation shall be initiated whenever the administering authority determines, from information available to it, that a formal investigation is warranted into the question of whether the elements necessary for the imposition of a duty under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1673"},"text":"section 1673 of this title","children":[],"tail":" exist."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0575f373-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cases involving persistent dumping","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0575f374-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The administering authority may establish a monitoring program with respect to imports of a class or kind of merchandise from any additional supplier country for a period not to exceed one year if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0575f375-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673a/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" more than one antidumping order is in effect with respect to that class or kind of merchandise;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0575f376-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673a/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the judgment of the administering authority there is reason to believe or suspect an extraordinary pattern of persistent injurious dumping from one or more additional supplier countries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0575f377-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673a/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the judgment of the administering authority this extraordinary pattern is causing a serious commercial problem for the domestic industry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0575f378-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initiation of investigation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If during the period of monitoring referred to in subparagraph (A), the administering authority determines that there is sufficient information to initiate a formal investigation under this subsection regarding an additional supplier country, the administering authority shall immediately initiate such an investigation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0575f379-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673a/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this paragraph, the term “additional supplier country” means a country regarding which no antidumping investigation is currently pending, and no antidumping duty order is currently in effect, with respect to imports of the class or kind of merchandise covered by subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0575f37a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673a/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expeditious action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The administering authority and the Commission, to the extent practicable, shall expedite proceedings under this part undertaken as a result of a formal investigation initiated under subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0575f37b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initiation by petition","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0575f37c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Petition requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An antidumping proceeding shall be initiated whenever an interested party described in subparagraph (C), (D), (E), (F), or (G) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1677/9"},"text":"section 1677(9) of this title","children":[],"tail":" files a petition with the administering authority, on behalf of an industry, which alleges the elements necessary for the imposition of the duty imposed by "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1673"},"text":"section 1673 of this title","children":[],"tail":", and which is accompanied by information reasonably available to the petitioner supporting those allegations. The petition may be amended at such time, and upon such conditions, as the administering authority and the Commission may permit."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0575f37d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Simultaneous filing with Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The petitioner shall file a copy of the petition with the Commission on the same day as it is filed with the administering authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0575f37e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action with respect to petitions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0575f37f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673a/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of governments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon receipt of a petition filed under paragraph (1), the administering authority shall notify the government of any exporting country named in the petition by delivering a public version of the petition to an appropriate representative of such country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0575f380-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673a/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance of communications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The administering authority shall not accept any unsolicited oral or written communication from any person other than an interested party described in section 1677(9)(C), (D), (E), (F), or (G) of this title before the administering authority makes its decision whether to initiate an investigation, except as provided in subsection (c)(4)(D), and except for inquiries regarding the status of the administering authority’s consideration of the petition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0575f381-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673a/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nondisclosure of certain information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The administering authority and the Commission shall not disclose information with regard to any draft petition submitted for review and comment before it is filed under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0575f382-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Petition determination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0575f383-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0575f384-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for initial determination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subparagraph (B), within 20 days after the date on which a petition is filed under subsection (b), the administering authority shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0575f385-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673a/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after examining, on the basis of sources readily available to the administering authority, the accuracy and adequacy of the evidence provided in the petition, determine whether the petition alleges the elements necessary for the imposition of a duty under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1673"},"text":"section 1673 of this title","children":[],"tail":" and contains information reasonably available to the petitioner supporting the allegations, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0575f386-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673a/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine if the petition has been filed by or on behalf of the industry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0575f387-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension of time","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any case in which the administering authority is required to poll or otherwise determine support for the petition by the industry under paragraph (4)(D), the administering authority may, in exceptional circumstances, apply subparagraph (A) by substituting “a maximum of 40 days” for “20 days”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0575f388-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673a/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time limits where petition involves same merchandise as an order that has been revoked","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a petition is filed under this section with respect to merchandise that was the subject merchandise of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0575f389-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673a/c/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an antidumping duty order or finding that was revoked under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1675/d"},"text":"section 1675(d) of this title","children":[],"tail":" in the 24 months preceding the date the petition is filed, or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0575f38a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673a/c/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a suspended investigation that was terminated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1675/d"},"text":"section 1675(d) of this title","children":[],"tail":" in the 24 months preceding the date the petition is filed,"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the administering authority and the Commission shall, to the maximum extent practicable, expedite any investigation initiated under this section with respect to the petition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0575f38b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Affirmative determinations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the determinations under clauses (i) and (ii) of paragraph (1)(A) are affirmative, the administering authority shall initiate an investigation to determine whether the subject merchandise is being, or is likely to be, sold in the United States at less than its fair value.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0575f38c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Negative determinations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the determination under clause (i) or (ii) of paragraph (1)(A) is negative, the administering authority shall dismiss the petition, terminate the proceeding, and notify the petitioner in writing of the reasons for the determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0575f38d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of industry support","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0575f38e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673a/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, the administering authority shall determine that the petition has been filed by or on behalf of the industry, if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0575f38f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673a/c/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the domestic producers or workers who support the petition account for at least 25 percent of the total production of the domestic like product, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0575f390-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673a/c/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the domestic producers or workers who support the petition account for more than 50 percent of the production of the domestic like product produced by that portion of the industry expressing support for or opposition to the petition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0575f391-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673a/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain positions disregarded","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0575f392-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673a/c/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Producers related to foreign producers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In determining industry support under subparagraph (A), the administering authority shall disregard the position of domestic producers who oppose the petition, if such producers are related to foreign producers, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1677/4/B/ii"},"text":"section 1677(4)(B)(ii) of this title","children":[],"tail":", unless such domestic producers demonstrate that their interests as domestic producers would be adversely affected by the imposition of an antidumping duty order."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0575f393-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673a/c/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Producers who are importers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The administering authority may disregard the position of domestic producers of a domestic like product who are importers of the subject merchandise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0575f394-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673a/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for regional industries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the petition alleges the industry is a regional industry, the administering authority shall determine whether the petition has been filed by or on behalf of the industry by applying subparagraph (A) on the basis of production in the region.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0575f395-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673a/c/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Polling the industry","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the petition does not establish support of domestic producers or workers accounting for more than 50 percent of the total production of the domestic like product, the administering authority shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0575f396-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673a/c/4/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" poll the industry or rely on other information in order to determine if there is support for the petition as required by subparagraph (A), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0575f397-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673a/c/4/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if there is a large number of producers in the industry, the administering authority may determine industry support for the petition by using any statistically valid sampling method to poll the industry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0575f398-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673a/c/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comments by interested parties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before the administering authority makes a determination with respect to initiating an investigation, any person who would qualify as an interested party under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1677/9"},"text":"section 1677(9) of this title","children":[],"tail":" if an investigation were initiated, may submit comments or information on the issue of industry support. After the administering authority makes a determination with respect to initiating an investigation, the determination regarding industry support shall not be reconsidered."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0575f399-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673a/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Domestic producers or workers” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, the term “domestic producers or workers” means those interested parties who are eligible to file a petition under subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0575f39a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification to Commission of determination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The administering authority shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0575f39b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the Commission immediately of any determination it makes under subsection (a) or (c), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0575f39c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the determination is affirmative, make available to the Commission such information as it may have relating to the matter under investigation, under such procedures as the administering authority and the Commission may establish to prevent disclosure, other than with the consent of the party providing it or under protective order, of any information to which confidential treatment has been given by the administering authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0575f39d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information regarding critical circumstances","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If, at any time after the initiation of an investigation under this part, the administering authority finds a reasonable basis to suspect that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0575f39e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a history of dumping in the United States or elsewhere of the subject merchandise, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0575f39f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1673a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person by whom, or for whose account, the merchandise was imported knew, or should have known, that the exporter was selling the subject merchandise at less than its fair value,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the administering authority may request the Commissioner of U.S. Customs and Border Protection to compile information on an expedited basis regarding entries of the subject merchandise. Upon receiving such request, the Commissioner of U.S. Customs and Border Protection shall collect information regarding the volume and value of entries of the subject merchandise and shall transmit such information to the administering authority at such times as the administering authority shall direct (at least once every 30 days), until a final determination is made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1673d/a"},"text":"section 1673d(a) of this title","children":[],"tail":", the investigation is terminated, or the administering authority withdraws the request."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0575f3a0-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title VII, § 732, as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/39/tI/s101"},"text":"Pub. L. 96–39, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/162"},"text":"93 Stat. 162","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/573/tVI/s609"},"text":"Pub. L. 98–573, title VI, § 609","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3030"},"text":"98 Stat. 3030","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXVIII/s1886/a/2"},"text":"Pub. L. 99–514, title XVIII, § 1886(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2921"},"text":"100 Stat. 2921","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tI"},"text":"Pub. L. 100–418, title I","children":[],"tail":", §§ 1324(b)(1), 1326(d)(1), "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1200"},"text":"102 Stat. 1200","children":[],"tail":", 1204; "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/tII"},"text":"Pub. L. 103–465, title II","children":[],"tail":", §§ 211(b), 212(a)(2), 233(a)(5)(P)–(R), (6)(A)(v)–(vii), (C), "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4843"},"text":"108 Stat. 4843","children":[],"tail":", 4845, 4900, 4901; "},{"tag":"ref","attrib":{"href":"/us/pl/104/295/s20/b/4"},"text":"Pub. L. 104–295, § 20(b)(4)","children":[],"tail":", (8), (9), "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3527"},"text":"110 Stat. 3527","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/125/tVIII/s802/d/2"},"text":"Pub. L. 114–125, title VIII, § 802(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-24"},"text":"Feb. 24, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/210"},"text":"130 Stat. 210","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0575f3a1-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0575f3a2-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0575f3a3-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/295/s20/b/9"},"text":"Pub. L. 104–295, § 20(b)(9)","children":[],"tail":", amended directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/s233/a/6/C"},"text":"Pub. L. 103–465, § 233(a)(6)(C)","children":[],"tail":". See 1994 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/295/s20/b/4"},"text":"Pub. L. 104–295, § 20(b)(4)","children":[],"tail":", substituted “(b)(1)” for “(b)(1)(A)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/295/s20/b/8"},"text":"Pub. L. 104–295, § 20(b)(8)","children":[],"tail":", substituted “the” for “the the” before “subject merchandise”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/s233/a/6/A/v"},"text":"Pub. L. 103–465, § 233(a)(6)(A)(v)","children":[],"tail":", substituted “initiated” for “commenced”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/s233/a/6/C"},"text":"Pub. L. 103–465, § 233(a)(6)(C)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/104/295/s20/b/9"},"text":"Pub. L. 104–295, § 20(b)(9)","children":[],"tail":", substituted “initiate” for “commerce” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/s233/a/6/A/vi"},"text":"Pub. L. 103–465, § 233(a)(6)(A)(vi)","children":[],"tail":", substituted “initiated” for “commenced”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/s233/a/6/A/vii"},"text":"Pub. L. 103–465, § 233(a)(6)(A)(vii)","children":[],"tail":", substituted “initiated” for “commenced”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/s211/b"},"text":"Pub. L. 103–465, § 211(b)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/s212/a/2"},"text":"Pub. L. 103–465, § 212(a)(2)","children":[],"tail":", amended heading and text of subsec. (c) generally. Prior to amendment, text read as follows: “Within 20 days after the date on which a petition is filed under subsection (b) of this section, the administering authority shall—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) determine whether the petition alleges the elements necessary for the imposition of a duty under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1673"},"text":"section 1673 of this title","children":[],"tail":" and contains information reasonably available to the petitioner supporting the allegations,"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) if the determination is affirmative, commence an investigation to determine whether the class or kind of merchandise described in the petition is being, or is likely to be, sold in the United States at less than its fair value, and provide for the publication of notice of the determination in the Federal Register, and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) if the determination is negative, dismiss the petition, terminate the proceeding, notify the petitioner in writing of the reasons for the determination, and provide for the publication of notice of the determination in the Federal Register.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/s233/a/5/R"},"text":"Pub. L. 103–465, § 233(a)(5)(R)","children":[],"tail":", in concluding provisions, substituted “subject merchandise” for “class or kind of merchandise that is the subject of the investigation” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/s233/a/5/P"},"text":"Pub. L. 103–465, § 233(a)(5)(P)","children":[],"tail":", substituted “the subject merchandise” for “class or kind of the merchandise which is the subject of the investigation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/s233/a/5/Q"},"text":"Pub. L. 103–465, § 233(a)(5)(Q)","children":[],"tail":", substituted “subject merchandise” for “merchandise which is the subject of the investigation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/s1326/d/1"},"text":"Pub. L. 100–418, § 1326(d)(1)","children":[],"tail":", substituted “(F), or (G)” for “or (F)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/s1324/b/1"},"text":"Pub. L. 100–418, § 1324(b)(1)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" inserted reference to subpar. (F) of "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1677/9"},"text":"section 1677(9) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/573"},"text":"Pub. L. 98–573","children":[],"tail":" designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0575f3a4-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id0575f3a5-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Commissioner of U.S. Customs and Border Protection” substituted for “Commissioner of Customs” in two places in subsec. (e) on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/125/s802/d/2"},"text":"section 802(d)(2) of Pub. L. 114–125","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s211"},"text":"section 211 of Title 6","children":[],"tail":", Domestic Security."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0575f3a6-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465"},"text":"Pub. L. 103–465","children":[],"tail":" effective, except as otherwise provided, on the date on which the WTO Agreement enters into force with respect to the United States ("},{"tag":"date","attrib":{"date":"1995-01-01"},"text":"Jan. 1, 1995","children":[],"tail":"), and applicable with respect to investigations, reviews, and inquiries initiated and petitions filed under specified provisions of this chapter after such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/s291"},"text":"section 291 of Pub. L. 103–465","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1671"},"text":"section 1671 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0575f3a7-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/s1324/b/1"},"text":"section 1324(b)(1) of Pub. L. 100–418","children":[],"tail":" applicable with respect to investigations initiated after "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", and amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/s1326/d/1"},"text":"section 1326(d)(1) of Pub. L. 100–418","children":[],"tail":" applicable with respect to investigations initiated after "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", and to reviews initiated under section 1673e(c) or 1675 of this title after "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", see section 1337(b), (c) of "},{"tag":"ref","attrib":{"href":"/us/pl/100/418"},"text":"Pub. L. 100–418","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1671"},"text":"section 1671 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0575f3a8-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/573"},"text":"Pub. L. 98–573","children":[],"tail":" applicable with respect to investigations initiated by petition or by the administering authority under parts I and II of this subtitle, and to reviews begun under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1675"},"text":"section 1675 of this title","children":[],"tail":", on or after "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/573/s626/b/1"},"text":"section 626(b)(1) of Pub. L. 98–573","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1671"},"text":"section 1671 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id0575f3a9-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions, personnel, assets, and liabilities of the United States Customs Service of the Department of the Treasury, including functions of the Secretary of the Treasury relating thereto, to the Secretary of Homeland Security, and for treatment of related references, see sections 203(1), 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":". For establishment of U.S. Customs and Border Protection in the Department of Homeland Security, treated as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" as of "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s211"},"text":"section 211 of Title 6","children":[],"tail":", as amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/114/125"},"text":"Pub. L. 114–125","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/114/125/s802/b"},"text":"section 802(b) of Pub. L. 114–125","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s211"},"text":"section 211 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0575f3aa-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Plan Amendments Not Required Until January 1, 1989","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions directing that if any amendments made by subtitle A or subtitle C of title XI [§§ 1101–1147 and 1171–1177] or title XVIII [§§ 1801–1899A] of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" require an amendment to any plan, such plan amendment shall not be required to be made before the first plan year beginning on or after "},{"tag":"date","attrib":{"date":"1989-01-01"},"text":"Jan. 1, 1989","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1140"},"text":"section 1140 of Pub. L. 99–514","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s401"},"text":"section 401 of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
