{"tag":"section","attrib":{"id":"id0548c7f2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1503"},"text":null,"children":[{"tag":"num","attrib":{"value":"1503"},"text":"§ 1503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dutiable value","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Except as provided in section 1520(c) ","children":[{"tag":"ref","attrib":{"idref":"fn002027"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002027"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title (relating to reliquidations on the basis of authorized corrections of errors) or "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1562"},"text":"section 1562 of this title","children":[],"tail":" (relating to withdrawal from manip­ulating warehouses), the basis for the assessment of duties on imported merchandise subject to ad valorem rates of duty or rates based upon or regulated in any manner by the value of the merchandise, shall be the appraised value determined upon liquidation, in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1500"},"text":"section 1500 of this title","children":[],"tail":" or any adjustment thereof made pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1501"},"text":"section 1501 of this title","children":[],"tail":". "},{"tag":"i","attrib":{},"text":"Provided, however","children":[],"tail":", That if reliquidation is required pursuant to a final judgment or order of the United States Court of International Trade which includes a reappraisement of imported merchandise, the basis for such assessment shall be the final appraised value determined by such court."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0548c7f3-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title IV, § 503, "},{"tag":"ref","attrib":{"href":"/us/stat/46/731"},"text":"46 Stat. 731","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1953-08-08/ch397/s18/d"},"text":"Aug. 8, 1953, ch. 397, § 18(d)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/67/518"},"text":"67 Stat. 518","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/271/tII/s206"},"text":"Pub. L. 91–271, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-06-02"},"text":"June 2, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/284"},"text":"84 Stat. 284","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/417/tVI/s601/4"},"text":"Pub. L. 96–417, title VI, § 601(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-10"},"text":"Oct. 10, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1744"},"text":"94 Stat. 1744","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0548c7f4-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0548c7f5-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0548c7f6-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1520/c"},"text":"Section 1520(c) of this title","children":[],"tail":", referred to in text, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/108/429/tII/s2105"},"text":"Pub. L. 108–429, title II, § 2105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-03"},"text":"Dec. 3, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2598"},"text":"118 Stat. 2598","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0548c7f7-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions somewhat similar to those in subsecs. (a) and (b) were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-09-21/ch356/tIV/s503"},"text":"act Sept. 21, 1922, ch. 356, title IV, § 503","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/967"},"text":"42 Stat. 967","children":[],"tail":". Provisions similar to former subsec. (b) relating to entries pending reappraisement were contained in "},{"tag":"ref","attrib":{"href":"/us/act/1922-09-21/ch356/tIV/s489"},"text":"act Sept. 21, 1922, ch. 356, title IV, § 489","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/962"},"text":"42 Stat. 962","children":[],"tail":". Both of the acts of 1922 were in part superseded by act "},{"tag":"date","attrib":{"date":"1930-06-17"},"text":"June 17, 1930","children":[],"tail":", comprising this section, and repealed by section 651(a)(1) of the 1930 act."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A provision for assessment of duty on merchandise of different values when invoiced at an average price, was contained in R.S. § 2910, prior to repeal by ","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-09-21/ch356/tIV/s642"},"text":"act Sept. 21, 1922, ch. 356, title IV, § 642","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/989"},"text":"42 Stat. 989","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0548c7f8-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/417"},"text":"Pub. L. 96–417","children":[],"tail":" redesignated the United States Customs Court as the United States Court of International Trade."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/271"},"text":"Pub. L. 91–271","children":[],"tail":" substituted provisions that, except as provided in section 1520(c) or 1562 of this title, the basis for the assessment of duties on imported merchandise be the appraised value determined upon liquidation, in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1500"},"text":"section 1500 of this title","children":[],"tail":" or any adjustment thereof pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1501"},"text":"section 1501 of this title","children":[],"tail":", and be the final appraised value where reliquidation is required pursuant to a final judgment or order of the United States Customs Court, for provisions that, except as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1562"},"text":"section 1562 of this title","children":[],"tail":", the basis for the assessment of duties on imported merchandise subject to ad valorem rates of duty be the final appraised value, and provisions that for the purpose of determining the rate of duty assessed upon any merchandise when the rate is based upon or regulated in any manner by the value of the merchandise, the final appraised value, except as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1562"},"text":"section 1562 of this title","children":[],"tail":", be taken as the value of merchandise."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1953—Subsec. (a). Act ","children":[{"tag":"date","attrib":{"date":"1953-08-08"},"text":"Aug. 8, 1953","children":[],"tail":", struck out “and in subdivision (b) of this section” after reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1562"},"text":"section 1562 of this title","children":[],"tail":", “the entered value or” after “shall be”, and “whichever is higher” at the end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). Act ","children":[{"tag":"date","attrib":{"date":"1953-08-08"},"text":"Aug. 8, 1953","children":[],"tail":", redesignated subsec. (c) as (b). Former subsec. (b), which related to entries pending reappraisement, was repealed by act "},{"tag":"date","attrib":{"date":"1953-08-08"},"text":"Aug. 8, 1953","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0548c7f9-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0548c7fa-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/417"},"text":"Pub. L. 96–417","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-11-01"},"text":"Nov. 1, 1980","children":[],"tail":", and applicable with respect to civil actions pending on or commenced on or after such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/96/417/s701/a"},"text":"section 701(a) of Pub. L. 96–417","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s251"},"text":"section 251 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0548c7fb-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1970 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/271"},"text":"Pub. L. 91–271","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/271/s203"},"text":"section 203 of Pub. L. 91–271","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1500"},"text":"section 1500 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0548c7fc-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1953 Amendment; Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by act ","children":[{"tag":"date","attrib":{"date":"1953-08-08"},"text":"Aug. 8, 1953","children":[],"tail":", effective on and after the thirtieth day following "},{"tag":"date","attrib":{"date":"1953-08-08"},"text":"Aug. 8, 1953","children":[],"tail":", and savings provision, see notes set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1304"},"text":"section 1304 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
