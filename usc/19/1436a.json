{"tag":"section","attrib":{"id":"id053a713a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1436a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1436a"},"text":"§ 1436a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on violations of arrival, reporting, entry, and clearance requirements and falsity or lack of manifest","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id053a713b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1436a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commissioner of U.S. Customs and Border Protection shall submit to the appropriate congressional committees an annual report that contains the information described in subsection (b) with respect to each violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1436"},"text":"section 1436 of this title","children":[],"tail":", as amended by section 8007, and "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1584"},"text":"section 1584 of this title","children":[],"tail":" that occurred during the previous year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id053a713c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1436a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The information described in this subsection is the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id053a713d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1436a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The name and address of the violator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id053a713e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1436a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The specific violation that was committed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id053a713f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1436a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The location or port of entry through which the items were transported.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id053a7140-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1436a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An inventory of the items seized, including a description of the items and the quantity seized.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id053a7141-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1436a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The location from which the items originated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id053a7142-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1436a/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The entity responsible for the apprehension or seizure, organized by location or port of entry.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id053a7143-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1436a/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of penalties assessed by U.S. Customs and Border Protection, organized by name of the violator and location or port of entry.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id053a7144-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1436a/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of penalties that U.S. Customs and Border Protection could have levied, organized by name of the violator and location or port of entry.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id053a7145-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1436a/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The rationale for negotiating lower penalties, organized by name of the violator and location or port of entry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id053a7146-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1436a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id053a7147-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1436a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Finance and the Committee on Homeland Security and Governmental Affairs of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id053a7148-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1436a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Ways and Means, the Committee on Oversight and Government Reform, and the Committee on Homeland Security of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id053a7149-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/tVIII/s8008"},"text":"Pub. L. 115–271, title VIII, § 8008","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-24"},"text":"Oct. 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4081"},"text":"132 Stat. 4081","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id053a714a-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id053a714b-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id053a714c-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1436"},"text":"Section 1436 of this title","children":[],"tail":", as amended by section 8007, referred to in subsec. (a), is "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1436"},"text":"section 1436 of this title","children":[],"tail":" as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/115/271/s8007"},"text":"section 8007 of Pub. L. 115–271","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id053a714d-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Synthetics Trafficking and Overdose Prevention Act of 2018, also known as the STOP Act of 2018, and also as part of the Substance Use–Disorder Prevention that Promotes Opioid Recovery and Treatment for Patients and Communities Act, also known as the SUPPORT for Patients and Communities Act, and not as part of the Tariff Act of 1930 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id053a714e-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id053a714f-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Oversight and Government Reform of House of Representatives changed to Committee on Oversight and Reform of House of Representatives by House Resolution No. 6, One Hundred Sixteenth Congress, ","children":[{"tag":"date","attrib":{"date":"2019-01-09"},"text":"Jan. 9, 2019","children":[],"tail":". Committee on Oversight and Reform of House of Representatives changed to Committee on Oversight and Accountability of House of Representatives by House Resolution No. 5, One Hundred Eighteenth Congress, "},{"tag":"date","attrib":{"date":"2023-01-09"},"text":"Jan. 9, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
