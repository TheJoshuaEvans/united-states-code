{"tag":"section","attrib":{"id":"id060058b9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2705"},"text":null,"children":[{"tag":"num","attrib":{"value":"2705"},"text":"§ 2705.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Impact study by Secretary of Labor","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Labor, in consulation ","children":[{"tag":"ref","attrib":{"idref":"fn002146"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002146"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “consultation”."}],"tail":" with other appropriate Federal agencies, shall undertake a continuing review and analysis of the impact which the implementation of the provisions of this chapter have with respect to United States labor; and shall make an annual written report to Congress on the results of such review and analysis."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id060058ba-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/67/tII/s216"},"text":"Pub. L. 98–67, title II, § 216","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-05"},"text":"Aug. 5, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/394"},"text":"97 Stat. 394","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id060058bb-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id060058bc-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id060058bd-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this title”, meaning title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/67"},"text":"Pub. L. 98–67","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-05"},"text":"Aug. 5, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/384"},"text":"97 Stat. 384","children":[],"tail":", which is classified principally to this chapter. For complete classification of title II to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2701"},"text":"section 2701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id060058be-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id060058bf-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", of provisions in this section relating to making an annual written report to Congress, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance, and page 123 of House Document No. 103–7."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
