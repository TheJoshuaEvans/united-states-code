{"tag":"section","attrib":{"id":"id05f20064-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2571"},"text":null,"children":[{"tag":"num","attrib":{"value":"2571"},"text":"§ 2571.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05f20065-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2571/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Agreement” means the Agreement on Technical Barriers to Trade referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3511/d/5"},"text":"section 3511(d)(5) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f20066-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2571/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conformity assessment procedure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “conformity assessment procedure” means any procedure used, directly or indirectly, to determine that relevant requirements in technical regulations or standards are fulfilled.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f20067-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2571/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal agency","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Federal agency” means any of the following within the meaning of chapter 2 of part I of title 5:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05f20068-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2571/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any executive department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05f20069-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2571/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any military department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05f2006a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2571/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any Government corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05f2006b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2571/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any Government-controlled corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05f2006c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2571/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any independent establishment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f2006d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2571/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International conformity assessment procedure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “international conformity assessment procedure” means a conformity assessment procedure that is adopted by an international standards organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f2006e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2571/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International standard","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “international standard” means any standard that is promulgated by an international standards organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f2006f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2571/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International standards organization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “international standards organization” means any organization—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05f20070-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2571/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the membership of which is open to representatives, whether public or private, of the United States and at least all Members; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05f20071-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2571/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is engaged in international standards-related activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f20072-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2571/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International standards-related activity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “international standards-related activity” means the negotiation, development, or promulgation of, or any amendment or change to, an international standard, or an international conformity assessment procedure, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f20073-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2571/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Member","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Member” means a WTO member as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3501/10"},"text":"section 3501(10) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f20074-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2571/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private person","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “private person” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05f20075-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2571/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any individual who is a citizen or national of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05f20076-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2571/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any corporation, partnership, association, or other legal entity organized or existing under the law of any State, whether for profit or not for profit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f20077-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2571/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Product","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “product” means any natural or manufactured item.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f20078-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2571/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary concerned","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary concerned” means the Secretary of Commerce with respect to functions under this subchapter relating to non­agricultural products, and the Secretary of Agriculture with respect to functions under this subchapter relating to agricultural products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f20079-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2571/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trade Representative","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Trade Representative” means the United States Trade Representative.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f2007a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2571/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standard","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “standard” means a document approved by a recognized body, that provides, for common and repeated use, rules, guidelines, or characteristics for products or related processes and production methods, with which compliance is not mandatory. Such term may also include or deal exclusively with terminology, symbols, packaging, marking, or labeling requirements as they apply to a product, process, or production method.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f2007b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2571/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards-related activity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “standards-related activity” means the development, adoption, or application of any standard, technical regulation, or conformity assessment procedure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f2007c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2571/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means any of the several States, the District of Columbia, the Commonwealth of Puerto Rico, the Virgin Islands, American Samoa, Guam and any other Commonwealth, territory, or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f2007d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2571/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State agency” means any department, agency, or other instrumentality of the government of any State or of any political subdivision of any State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f2007e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2571/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical regulation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “technical regulation” means a document which lays down product characteristics or their related processes and production methods, including the applicable administrative provisions, with which compliance is mandatory. Such term may also include or deal exclusively with terminology, symbols, packaging, marking, or labeling requirements as they apply to a product, process, or production method.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f2007f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2571/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “United States”, when used in a geographical context, means all States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05f20080-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39/tIV/s451"},"text":"Pub. L. 96–39, title IV, § 451","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/249"},"text":"93 Stat. 249","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/182/tIII/s351/b/1"},"text":"Pub. L. 103–182, title III, § 351(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-08"},"text":"Dec. 8, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2122"},"text":"107 Stat. 2122","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/tIII/s351/e"},"text":"Pub. L. 103–465, title III, § 351(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4956"},"text":"108 Stat. 4956","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/295/s20/c/16"},"text":"Pub. L. 104–295, § 20(c)(16)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3529"},"text":"110 Stat. 3529","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05f20081-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05f20082-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id05f20083-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Chapter 2 of part I of title 5, referred to in par. (3), probably means chapter 1 of part I of title 5, which is classified to section 101 et seq. of Title 5, Government Organization and Employees, and which relates to organization of agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id05f20084-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Par. (6)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/295"},"text":"Pub. L. 104–295","children":[],"tail":" substituted “; and” for period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/s351/e/1"},"text":"Pub. L. 103–465, § 351(e)(1)","children":[],"tail":", amended par. (1) generally, substituting “referred to in "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3511/d/5"},"text":"section 3511(d)(5) of this title","children":[],"tail":"” for “approved under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2503/a"},"text":"section 2503(a) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/s351/e/2"},"text":"Pub. L. 103–465, § 351(e)(2)","children":[],"tail":", amended heading and text of par. (2) generally. Prior to amendment, text read as follows: “The term ‘certification system’ means a system—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) for determining whether a product conforms with product standards applicable to that product; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) if a product so conforms, for attesting, by means of a document, mark, or other appropriate evidence of conformity, to that conformity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Such term also includes any modification of, or change to, any such system.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/s351/e/3"},"text":"Pub. L. 103–465, § 351(e)(3)","children":[],"tail":", substituted “conformity assessment procedure” for “certification system” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (6)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/s351/e/4"},"text":"Pub. L. 103–465, § 351(e)(4)","children":[],"tail":", amended subpar. (A) generally. Prior to amendment, subpar. (A) read as follows: “the membership of which is open to representatives, whether public or private, of the United States and—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) all Parties to the Agreement, or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) some but not all Parties of the Agreement; and”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/s351/e/5"},"text":"Pub. L. 103–465, § 351(e)(5)","children":[],"tail":", substituted “conformity assessment procedure” for “certification system”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/s351/e/6"},"text":"Pub. L. 103–465, § 351(e)(6)","children":[],"tail":", amended heading and text of par. (8) generally. Prior to amendment, text read as follows: “The term ‘Party to the Agreement’ means any foreign country or instrumentality determined by the President to have assumed, and to be applying, the obligations of the Agreement with respect to the United States.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (13). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/s351/e/7"},"text":"Pub. L. 103–465, § 351(e)(7)","children":[],"tail":", amended heading and text of par. (13) generally. Prior to amendment, text read as follows: “The term ‘standard’ means any of the following, and any amendment or change to any of the following:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) The specification of the characteristics of a product, including, but not limited to, levels of quality, performance, safety, or dimensions.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) Specifications relating to the terminology, symbols, testing and test methods, packaging, or marking or labeling requirements applicable to a product.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) Administrative procedures related to the application of any specification referred to in paragraph (A) or (B).”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (14). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/s351/e/8"},"text":"Pub. L. 103–465, § 351(e)(8)","children":[],"tail":", substituted “, technical regulation, or conformity assessment procedure” for “or any certification system”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (17), (18). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/s351/e/9"},"text":"Pub. L. 103–465, § 351(e)(9)","children":[],"tail":", added par. (17) and redesignated former par. (17) as (18)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Par. (12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/182"},"text":"Pub. L. 103–182","children":[],"tail":" amended par. (12) generally. Prior to amendment, par. (12) read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(12) ","children":[{"tag":"inline","attrib":{},"text":"Special representative","children":[],"tail":".—The term ‘Special Representative’ means the Special Representative for Trade Negotiations.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id05f20085-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id05f20086-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465"},"text":"Pub. L. 103–465","children":[],"tail":" effective on the date on which the WTO Agreement enters into force with respect to the United States ("},{"tag":"date","attrib":{"date":"1995-01-01"},"text":"Jan. 1, 1995","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/s352"},"text":"section 352 of Pub. L. 103–465","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2531"},"text":"section 2531 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
