{"tag":"section","attrib":{"id":"id056a0c1f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1617"},"text":null,"children":[{"tag":"num","attrib":{"value":"1617"},"text":"§ 1617.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compromise of Government claims by Secretary of the Treasury","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Upon a report by a customs officer, United States attorney, or any special attorney, having charge of any claim arising under the customs laws, showing the facts upon which such claim is based, the probabilities of a recovery and the terms upon which the same may be compromised, the Secretary of the Treasury is authorized to compromise such claim, if such action shall be recommended by the General Counsel for the Department of the Treasury.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id056a0c20-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title IV, § 617, "},{"tag":"ref","attrib":{"href":"/us/stat/46/757"},"text":"46 Stat. 757","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1934-05-10/ch277/s512/b"},"text":"May 10, 1934, ch. 277, § 512(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/759"},"text":"48 Stat. 759","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646/s1"},"text":"June 25, 1948, ch. 646, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/869"},"text":"62 Stat. 869","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/271/tIII/s301/gg"},"text":"Pub. L. 91–271, title III, § 301(gg)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-06-02"},"text":"June 2, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/291"},"text":"84 Stat. 291","c