{"tag":"section","attrib":{"id":"id05c72071-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2298"},"text":null,"children":[{"tag":"num","attrib":{"value":"2298"},"text":"§ 2298.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relocation allowances","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05c72072-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2298/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relocation allowance authorized","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05c72073-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2298/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any adversely affected worker covered by a certification issued under subpart A of this part may file an application for a relocation allowance with the Secretary, and the Secretary may grant the relocation allowance, subject to the terms and conditions of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05c72074-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2298/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions for granting allowance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A relocation allowance may be granted if all of the following terms and conditions are met:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05c72075-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2298/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assist an adversely affected worker","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The relocation allowance will assist an adversely affected worker in relocating within the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05c72076-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2298/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local employment not available","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary determines that the worker cannot reasonably be expected to secure suitable employment in the commuting area in which the worker resides.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05c72077-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2298/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Total separation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The worker is totally separated from employment at the time relocation commences.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05c72078-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2298/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suitable employment obtained","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The worker—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id05c72079-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2298/a/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has obtained suitable employment affording a reasonable expectation of long-term duration in the area in which the worker wishes to relocate; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05c96a6a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2298/a/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has obtained a bona fide offer of such employment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05c96a6b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2298/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The worker filed an application with the Secretary before—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id05c96a6c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2298/a/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the later of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id05c96a6d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2298/a/2/E/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 425th day after the date of the certification under subpart A of this part; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id05c96a6e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2298/a/2/E/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 425th day after the date of the worker’s last total separation; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05c96a6f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2298/a/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date that is the 182d day after the date on which the worker concluded training, unless the worker received a waiver under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2291/c"},"text":"section 2291(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05c96a70-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2298/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of allowance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The relocation allowance granted to a worker under subsection (a) includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05c96a71-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2298/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 90 percent of the reasonable and necessary expenses (including, but not limited to, subsistence and transportation expenses at levels not exceeding those allowable under section 2296(b)(1) and (2) of this title specified in regulations prescribed by the Secretary) incurred in transporting the worker, the worker’s family, and household effects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05c96a72-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2298/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a lump sum equivalent to 3 times the worker’s average weekly wage, up to a maximum payment of $1,250.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05c96a73-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2298/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A relocation allowance may not be granted to a worker unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05c96a74-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2298/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relocation occurs within 182 days after the filing of the application for relocation assistance; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05c96a75-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2298/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relocation occurs within 182 days after the conclusion of training, if the worker entered a training program approved by the Secretary under section 2296(b)(1) and (2) of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05c96a76-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/tII/s238"},"text":"Pub. L. 93–618, title II, § 238","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2024"},"text":"88 Stat. 2024","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXXV/s2508"},"text":"Pub. L. 97–35, title XXV, § 2508","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/886"},"text":"95 Stat. 886","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dB/tVI/s2672/b"},"text":"Pub. L. 98–369, div. B, title VI, § 2672(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1172"},"text":"98 Stat. 1172","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/210/dA/tI/s122"},"text":"Pub. L. 107–210, div. A, title I, § 122","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-06"},"text":"Aug. 6, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/943"},"text":"116 Stat. 943","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/429/tII/s2004/a/6"},"text":"Pub. L. 108–429, title II, § 2004(a)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-03"},"text":"Dec. 3, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2590"},"text":"118 Stat. 2590","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/5/dB/tI/s1833/b"},"text":"Pub. L. 111–5, div. B, title I, § 1833(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/386"},"text":"123 Stat. 386","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/40/tII"},"text":"Pub. L. 112–40, title II","children":[],"tail":", §§ 201(b), (c), 214(e), "},{"tag":"date","attrib":{"date":"2011-10-21"},"text":"Oct. 21, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/403"},"text":"125 Stat. 403","children":[],"tail":", 406; "},{"tag":"ref","attrib":{"href":"/us/pl/114/27/tIV/s402/b"},"text":"Pub. L. 114–27, title IV, § 402(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2015-06-29"},"text":"June 29, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/374"},"text":"129 Stat. 374","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05c96a77-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id05c96a78-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Assistance","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination of assistance under this part after ","children":[{"tag":"date","attrib":{"date":"2022-06-30"},"text":"June 30, 2022","children":[],"tail":", see Termination Date note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05c96a79-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id05c96a7a-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section reflects the ","children":[{"tag":"date","attrib":{"date":"2021-07-01"},"text":"July 1, 2021","children":[],"tail":", reversion to provisions in effect on "},{"tag":"date","attrib":{"date":"2014-01-01"},"text":"Jan. 1, 2014","children":[],"tail":". See Effective and Termination Dates of 2015 Revival note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/40/s233"},"text":"Section 233 of Pub. L. 112–40","children":[],"tail":", which provided for the "},{"tag":"date","attrib":{"date":"2014-01-01"},"text":"Jan. 1, 2014","children":[],"tail":", revival of this section as in effect on "},{"tag":"date","attrib":{"date":"2011-02-13"},"text":"Feb. 13, 2011","children":[],"tail":", was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/114/27/tIV/s402/a"},"text":"Pub. L. 114–27, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-06-29"},"text":"June 29, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/374"},"text":"129 Stat. 374","children":[],"tail":", and the provisions of this section, as in effect on "},{"tag":"date","attrib":{"date":"2013-12-31"},"text":"Dec. 31, 2013","children":[],"tail":", were temporarily revived, effective "},{"tag":"date","attrib":{"date":"2015-06-29"},"text":"June 29, 2015","children":[],"tail":", until "},{"tag":"date","attrib":{"date":"2021-07-01"},"text":"July 1, 2021","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/pl/114/27"},"text":"Pub. L. 114–27","children":[],"tail":", §§ 402(b), (c), 406. See 2011 and 2015 Amendment notes, Effective and Termination Dates of 2011 Revival notes, and Effective and Termination Dates of 2015 Revival notes below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5/s1893"},"text":"Section 1893 of Pub. L. 111–5","children":[],"tail":", which provided for "},{"tag":"date","attrib":{"date":"2011-02-13"},"text":"Feb. 13, 2011","children":[],"tail":", termination of amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/111/5"},"text":"Pub. L. 111–5","children":[],"tail":", was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/112/40/tII/s201/a"},"text":"Pub. L. 112–40, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-10-21"},"text":"Oct. 21, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/403"},"text":"125 Stat. 403","children":[],"tail":", and the provisions of this section, as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/5"},"text":"Pub. L. 111–5","children":[],"tail":" and as in effect on "},{"tag":"date","attrib":{"date":"2011-02-12"},"text":"Feb. 12, 2011","children":[],"tail":", were temporarily revived, effective "},{"tag":"date","attrib":{"date":"2011-10-21"},"text":"Oct. 21, 2011","children":[],"tail":", until "},{"tag":"date","attrib":{"date":"2014-01-01"},"text":"Jan. 1, 2014","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/pl/112/40"},"text":"Pub. L. 112–40","children":[],"tail":", §§ 201(b), (c), 233. See 2009 and 2011 Amendment notes, Effective and Termination Dates of 2009 Amendment notes, and Effective and Termination Dates of 2011 Revival notes below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id05c96a7b-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/27"},"text":"Pub. L. 114–27","children":[],"tail":", §§ 402(b), (c), 406, temporarily revived the provisions of this section, as in effect on "},{"tag":"date","attrib":{"date":"2013-12-31"},"text":"Dec. 31, 2013","children":[],"tail":". See Codification note above and 2011 Amendment and Effective and Termination Dates of 2015 Revival notes below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/40"},"text":"Pub. L. 112–40","children":[],"tail":", §§ 201(b), (c), 233, temporarily revived the provisions of this section, as in effect on "},{"tag":"date","attrib":{"date":"2011-02-12"},"text":"Feb. 12, 2011","children":[],"tail":". See Codification note above and 2009 Amendment and Effective and Termination Dates of 2011 Revival notes below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/40"},"text":"Pub. L. 112–40","children":[],"tail":", §§ 214(e)(1), 233, temporarily substituted “Each State may use funds made available to the State to carry out sections 2295 through 2298 of this title to allow an adversely affected worker” for “Any adversely affected worker” and “to file” for “may file”. See Codification note above and Effective and Termination Dates of 2011 Revival note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/40"},"text":"Pub. L. 112–40","children":[],"tail":", §§ 214(e)(2)(A), 233, in introductory provisions, temporarily substituted “Any” for “The” and “shall include” for “includes”. See Codification note above and Effective and Termination Dates of 2011 Revival note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/40"},"text":"Pub. L. 112–40","children":[],"tail":", §§ 214(e)(2)(B), 233, temporarily substituted “not more than 90 percent of the” for “all”. See Codification note above and Effective and Termination Dates of 2011 Revival note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/40"},"text":"Pub. L. 112–40","children":[],"tail":", §§ 214(e)(2)(C), 233, temporarily substituted “$1,250” for “$1,500”. See Codification note above and Effective and Termination Dates of 2011 Revival note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (a)(2)(E)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5"},"text":"Pub. L. 111–5","children":[],"tail":", §§ 1833(b)(1), 1893, temporarily struck out “, unless the worker received a waiver under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2291/c"},"text":"section 2291(c) of this title","children":[],"tail":"” before period. See Codification note above and Effective and Termination Dates of 2009 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5"},"text":"Pub. L. 111–5","children":[],"tail":", §§ 1833(b)(2)(A), 1893, temporarily substituted “all” for “90 percent of the”. See Codification note above and Effective and Termination Dates of 2009 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5"},"text":"Pub. L. 111–5","children":[],"tail":", §§ 1833(b)(2)(B), 1893, temporarily substituted “$1,500” for “$1,250”. See Codification note above and Effective and Termination Dates of 2009 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/429"},"text":"Pub. L. 108–429","children":[],"tail":" substituted “Secretary)” for “Secretary,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/210"},"text":"Pub. L. 107–210","children":[],"tail":" amended section generally. Prior to amendment, section consisted of subsecs. (a) to (d) authorizing relocation allowances, specifying the conditions for granting them, and defining “relocation allowance”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" substituted “$800” for “$600”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/s2508/1"},"text":"Pub. L. 97–35, § 2508(1)","children":[],"tail":", inserted provisions relating to time for filing application and struck out provisions respecting total separation."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/s2508/2"},"text":"Pub. L. 97–35, § 2508(2)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/s2508/3"},"text":"