{"tag":"section","attrib":{"id":"id065d461c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4662"},"text":null,"children":[{"tag":"num","attrib":{"value":"4662"},"text":"§ 4662.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The duties described in this section are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id065d461d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4662/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assisting the Interagency Labor Committee to monitor and enforce the labor obligations of Mexico.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065d461e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4662/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Submitting to the Interagency Labor Committee on a quarterly basis reports on the efforts undertaken by Mexico to comply with its labor obligations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id065d461f-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113/tVII/s722"},"text":"Pub. L. 116–113, title VII, § 722","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-01-29"},"text":"Jan. 29, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/86"},"text":"134 Stat. 86","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
