{"tag":"section","attrib":{"id":"id0610fb13-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3552"},"text":null,"children":[{"tag":"num","attrib":{"value":"3552"},"text":"§ 3552.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation of Rules of Origin work program","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If the President enters into an agreement developed under the work program described in Article 9 of the Agreement on Rules of Origin referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3511/d/10"},"text":"section 3511(d)(10) of this title","children":[],"tail":", the President may implement United States obligations under such an agreement under United States law only pursuant to authority granted to the President for that purpose by law enacted after the effective date of this section."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0610fb14-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/tI/s132"},"text":"Pub. L. 103–465, title I, § 132","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4839"},"text":"108 Stat. 4839","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/295/s20/a/2"},"text":"Pub. L. 104–295, § 20(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3527"},"text":"110 Stat. 3527","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0610fb15-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0610fb16-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":n