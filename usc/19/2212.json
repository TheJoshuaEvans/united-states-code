{"tag":"section","attrib":{"id":"id05b40dda-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2212"},"text":null,"children":[{"tag":"num","attrib":{"value":"2212"},"text":"§ 2212.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transmission of agreements to Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05b40ddb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2212/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of copy and reasons","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As soon as practicable after a trade agreement entered into under section 2133 or 2134 of this title or under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4202"},"text":"section 4202 of this title","children":[],"tail":" has entered into force with respect to the United States, the President shall, if he has not previously done so, transmit a copy of such trade agreement to each House of the Congress together with a statement, in the light of the advice of the International Trade Commission under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2151/b"},"text":"section 2151(b) of this title","children":[],"tail":", if any, and of other relevant considerations, of his reasons for entering into the agreement."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05b40ddc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2212/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission to each member","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall transmit to each Member of the Congress a summary of the information required to be transmitted to each House under subsection (a). For purposes of this subsection, the term “Member” includes any Delegate or Resident Commissioner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05b40ddd-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/tI/s162"},"text":"Pub. L. 93–618, title I, § 162","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2008"},"text":"88 Stat. 2008","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tIX/s9001/a/10"},"text":"Pub. L. 100–647, title IX, § 9001(a)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3807"},"text":"102 Stat. 3807","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/210/dB/tXXI/s2110/a/6"},"text":"Pub. L. 107–210, div. B, title XXI, § 2110(a)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-06"},"text":"Aug. 6, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1020"},"text":"116 Stat. 1020","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/26/tI/s110/a/7"},"text":"Pub. L. 114–26, title I, § 110(a)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-06-29"},"text":"June 29, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/358"},"text":"129 Stat. 358","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05b40dde-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05b40ddf-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":n