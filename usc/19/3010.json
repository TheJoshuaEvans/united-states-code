{"tag":"section","attrib":{"id":"id060513ce-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3010"},"text":null,"children":[{"tag":"num","attrib":{"value":"3010"},"text":"§ 3010.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States participation on Customs Cooperation Council regarding Convention","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id060513cf-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3010/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Principal United States agencies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id060513d0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3010/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to the policy direction of the Office of the United States Trade Representative under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3009"},"text":"section 3009 of this title","children":[],"tail":", the Department of the Treasury, the Department of Commerce, and the Commission shall, with respect to the activities of the Customs Cooperation Council relating to the Convention—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id060513d1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3010/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be primarily responsible for formulating United States Government positions on technical and procedural issues; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id060513d2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3010/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" represent the United States Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060513d3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3010/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Agriculture and other interested Federal agencies shall provide to the Department of the Treasury, the Department of Commerce, and the Commission technical advice and assistance relating to the functions referred to in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id060513d4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3010/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development of technical proposals","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id060513d5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3010/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In connection with responsibilities arising from the implementation of the Convention and under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1484/f"},"text":"section 1484(f) of this title","children":[],"tail":" regarding United States programs for the development of adequate and comparable statistical information on merchandise trade, the Secretary of the Treasury, the Secretary of Commerce, and the Commission shall prepare technical proposals that are appropriate or required to assure that the United States contribution to the development of the Convention recognizes the needs of the United States business community for a Convention which reflects sound principles of commodity identification, modern producing methods, and current trading patterns and practices."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060513d6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3010/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In carrying out this subsection, the Secretary of the Treasury, the Secretary of Commerce, and the Commission shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id060513d7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3010/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" solicit and consider the views of interested parties in the private sector (including a functional advisory committee) and of interested Federal agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id060513d8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3010/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish procedures for reviewing, and developing appropriate responses to, inquiries and complaints from interested parties concerning articles produced in and exported from the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id060513d9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3010/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" where appropriate, establish procedures for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id060513da-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3010/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring that the dispute settlement provisions and other relevant procedures available under the Convention are utilized to promote United States export interests, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id060513db-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3010/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submitting classification questions to the Harmonized System Committee of the Customs Cooperation Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id060513dc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3010/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of Customs Cooperation Council publications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As soon as practicable after ","children":[{"tag":"date","attrib":{"date":"1988-08-23"},"text":"August 23, 1988","children":[],"tail":", and periodically thereafter as appropriate, the Commission shall see to the publication of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id060513dd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3010/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" summary records of the Harmonized System Committee of the Customs Cooperation Council; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060513de-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3010/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to applicable copyright laws, the Explanatory Notes, Classification Opinions, and other instruments of the Customs Cooperation Council relating to the Convention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id060513df-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/tI/s1210"},"text":"Pub. L. 100–418, title I, § 1210","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1152"},"text":"102 Stat. 1152","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/295/s21/e/10"},"text":"Pub. L. 104–295, § 21(e)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3531"},"text":"110 Stat. 3531","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id060513e0-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id060513e1-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id060513e2-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/295"},"text":"Pub. L. 104–295","children":[],"tail":" substituted “1484(f)” for “1484(e)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
