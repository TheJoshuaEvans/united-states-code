{"tag":"section","attrib":{"id":"id059c18d0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2093"},"text":null,"children":[{"tag":"num","attrib":{"value":"2093"},"text":"§ 2093.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forfeiture of unlawful imports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id059c18d1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2093/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Seizure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any pre-Columbian monumental or architectural sculpture or mural imported into the United States in violation of this chapter shall be seized and subject to forfeiture under the customs laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id059c18d2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2093/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of articles","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any pre-Columbian monumental or architectural sculpture or mural which is forfeited to the United States shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id059c18d3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2093/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" first be offered for return to the country of origin and shall be returned if that country bears all expenses incurred incident to such return and complies with such other requirements relating to the return as the Secretary shall prescribe; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id059c18d4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2093/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if not returned to the country of origin, be disposed of in the manner prescribed by law for articles forfeited for violation of the customs laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id059c18d5-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/587/tII/s203"},"text":"Pub. L. 92–587, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-27"},"text":"Oct. 27, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1297"},"text":"86 Stat. 1297","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
