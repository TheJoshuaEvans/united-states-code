{"tag":"section","attrib":{"id":"id05f20056-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2561"},"text":null,"children":[{"tag":"num","attrib":{"value":"2561"},"text":"§ 2561.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings of reciprocity required in administrative proceedings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05f20057-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2561/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided under subpart 1, no Federal agency may consider a complaint or petition against any standards-related activity regarding an imported product, if that activity is engaged in within the United States and is covered by the Agreement, unless the Trade Representative finds, and informs the agency concerned in writing, that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05f20058-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2561/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the country of origin of the imported product is a Party to the Agreement or a foreign country described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2552/2"},"text":"section 2552(2) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f20059-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2561/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the dispute settlement procedures provided under the Agreement are not appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05f2005a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2561/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section does not apply with respect to causes of action arising under—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05f2005b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2561/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the antitrust laws as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s12/a"},"text":"section 12(a) of title 15","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f2005c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2561/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" statutes administered by the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"This section does not apply with respect to petitions and proceedings that are provided for under the practices of any Federal agency for the purpose of ensuring, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":", that interested persons are given an opportunity to participate in agency rulemaking or to seek the issuance, amendment, or repeal of a rule."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05f2005d-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39/tIV/s441"},"text":"Pub. L. 96–39, title IV, § 441","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/248"},"text":"93 Stat. 248","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/182/tIII/s351/b/2/A"},"text":"Pub. L. 103–182, title III, § 351(b)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-08"},"text":"Dec. 8, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2122"},"text":"107 Stat. 2122","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/295/s21/b/1"},"text":"Pub. L. 104–295, § 21(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3529"},"text":"110 Stat. 3529","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05f2005e-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05f2005f-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id05f20060-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/295"},"text":"Pub. L. 104–295","children":[],"tail":" amended directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/103/182"},"text":"Pub. L. 103–182","children":[],"tail":". See 1993 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/182"},"text":"Pub. L. 103–182","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/104/295"},"text":"Pub. L. 104–295","children":[],"tail":", substituted “Trade Representative” for “Special Representative”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
