{"tag":"section","attrib":{"id":"id053a70e0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1433"},"text":null,"children":[{"tag":"num","attrib":{"value":"1433"},"text":"§ 1433.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report of arrival of vessels, vehicles, and aircraft","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id053a70e1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1433/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vessel arrival","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id053a70e2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1433/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Immediately upon the arrival at any port or place within the United States or the Virgin Islands of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id053a70e3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1433/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any vessel from a foreign port or place;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id053a70e4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1433/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any foreign vessel from a domestic port;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id053a70e5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1433/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any vessel of the United States carrying foreign merchandise for which entry has not been made; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id053a70e6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1433/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any vessel which has visited a hovering vessel or received merchandise while outside the territorial sea;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the master of the vessel shall report the arrival at the nearest customs facility or such other place as the Secretary may prescribe by regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id053a70e7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1433/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may by regulation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id053a70e8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1433/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribe the manner in which arrivals are to be reported under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id053a70e9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1433/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" extend the time in which reports of arrival must be made, but not later than 24 hours after arrival.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id053a70ea-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1433/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vehicle arrival","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id053a70eb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1433/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Vehicles may arrive in the United States only at border crossing points designated by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id053a70ec-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1433/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as otherwise authorized by the Secretary, immediately upon the arrival of any vehicle in the United States at a border crossing point, the person in charge of the vehicle shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id053a70ed-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1433/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report the arrival; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id053a70ee-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1433/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" present the vehicle, and all persons and merchandise (including baggage) on board, for inspection;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"to the customs officer at the customs facility designated for that crossing point.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id053a70ef-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1433/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aircraft arrival","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The pilot of any aircraft arriving in the United States or the Virgin Islands from any foreign airport or place shall comply with such advance notification, arrival reporting, and landing requirements as the Secretary may by regulation prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id053a70f0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1433/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presentation of documentation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The master, person in charge of a vehicle, or aircraft pilot shall present, or transmit pursuant to an electronic data interchange system, to the Customs Service such information, data, documents, papers, or manifests as the Secretary may by regulation prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id053a70f1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1433/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on departures and discharge","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Unless otherwise authorized by law, a vessel, aircraft or vehicle after arriving in the United States or Virgin Islands may, but only in accordance with regulations prescribed by the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id053a70f2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1433/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" depart from the port, place, or airport of arrival; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id053a70f3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1433/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" discharge any passenger or merchandise (including baggage).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id053a70f4-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title IV, § 433, "},{"tag":"ref","attrib":{"href":"/us/stat/46/711"},"text":"46 Stat. 711","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/570/tIII/s3112"},"text":"Pub. L. 99–570, title III, § 3112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-80"},"text":"100 Stat. 3207–80","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/182/tVI/s652"},"text":"Pub. L. 103–182, title VI, § 652","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-08"},"text":"Dec. 8, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2209"},"text":"107 Stat. 2209","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/476/tI/s1452/a/1"},"text":"Pub. L. 106–476, title I, § 1452(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2167"},"text":"114 Stat. 2167","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id053a70f5-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id053a70f6-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id053a70f7-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-09-21/ch356/tIV/s433"},"text":"act Sept. 21, 1922, ch. 356, title IV, § 433","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/951"},"text":"42 Stat. 951","children":[],"tail":". That section was superseded by section 433 of act "},{"tag":"date","attrib":{"date":"1930-06-17"},"text":"June 17, 1930","children":[],"tail":", comprising this section, and repealed by section 651(a)(1) of the 1930 act."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 2774, requiring a report of arrival, and a further report in the form of a manifest, and imposing a penalty for violations was superseded by ","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-09-21/ch356/tIV/s433"},"text":"act Sept. 21, 1922, ch. 356, title IV, § 433","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/951"},"text":"42 Stat. 951","children":[],"tail":", and repealed by section 642 of that act."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 2772, relative to report and entry by the master of every vessel, bound to a port of delivery; section 2775, requiring a special report by the master of any vessel having on board distilled spirits or wines; and section 2832, relative to report of arrival of vessels proceeding to the ports of Natchez or Vicksburg, were also repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-09-21/ch356/s642"},"text":"section 642 of the act of Sept. 21, 1922, ch. 356","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id053a70f8-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (a)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/476"},"text":"Pub. L. 106–476","children":[],"tail":" struck out “bonded merchandise, or” before “foreign merchandise”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (a)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/182/s652/1"},"text":"Pub. L. 103–182, § 652(1)","children":[],"tail":", added subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/182/s652/2"},"text":"Pub. L. 103–182, § 652(2)","children":[],"tail":", substituted “present, or transmit pursuant to an electronic data interchange system, to the Customs Service such information, data,” for “present to customs officers such”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/182/s652/3"},"text":"Pub. L. 103–182, § 652(3)","children":[],"tail":", amended subsec. (e) generally. Prior to amendment, subsec. (e) read as follows: “Unless otherwise authorized by law, a vessel, aircraft, or vehicle may, after arriving in the United States or the Virgin Islands—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) depart from the port, place, or airport of arrival; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) discharge any passenger or merchandise (including baggage);","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"only in accordance with regulations prescribed by the Secretary.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570"},"text":"Pub. L. 99–570","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “Within twenty-four hours after the arrival of any vessel from a foreign port or place, or of a foreign vessel from a domestic port, or of a vessel of the United States carrying bonded merchandise, or foreign merchandise for which entry has not been made, at any port or place within the United States at which such vessel shall come to, the master shall, unless otherwise provided by law, report the arrival of the vessel at the nearest customhouse, under such regulations as the Commissioner of Customs may prescribe.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id053a70f9-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id053a70fa-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/476"},"text":"Pub. L. 106–476","children":[],"tail":", except as otherwise provided, applicable with respect to goods entered, or withdrawn from warehouse, for consumption, on or after the 15th day after "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/476/s1471"},"text":"section 1471 of Pub. L. 106–476","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s58c"},"text":"section 58c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id053a70fb-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions, personnel, assets, and liabilities of the United States Customs Service of the Department of the Treasury, including functions of the Secretary of the Treasury relating thereto, to the Secretary of Homeland Security, and for treatment of related references, see sections 203(1), 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":". For establishment of U.S. Customs and Border Protection in the Department of Homeland Security, treated as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" as of "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s211"},"text":"section 211 of Title 6","children":[],"tail":", as amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/114/125"},"text":"Pub. L. 114–125","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/114/125/s802/b"},"text":"section 802(b) of Pub. L. 114–125","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s211"},"text":"section 211 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
