,"children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/570/tIX/s9002/a"},"text":"Pub. L. 99–570, title IX, § 9002(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-166"},"text":"100 Stat. 3207–166","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/179/tIII/s301"},"text":"Pub. L. 101–179, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-28"},"text":"Nov. 28, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1311"},"text":"103 Stat. 1311","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/382/tI/s131"},"text":"Pub. L. 101–382, title I, § 131","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-20"},"text":"Aug. 20, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/643"},"text":"104 Stat. 643","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXIII/s13802/a"},"text":"Pub. L. 103–66, title XIII, § 13802(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/667"},"text":"107 Stat. 667","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/149/s4/b/9"},"text":"Pub. L. 103–149, § 4(b)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-23"},"text":"Nov. 23, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1506"},"text":"107 Stat. 1506","children":[],"tail":", related to beneficiary developing countries, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/104/188"},"text":"Pub. L. 104–188","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id05e3a927-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (b)(2)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/210"},"text":"Pub. L. 107–210","children":[],"tail":" inserted “or such country has not taken steps to support the efforts of the United States to combat terrorism” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/200/s412/a/2"},"text":"Pub. L. 106–200, § 412(a)(2)","children":[],"tail":", in concluding provisions substituted “(G), and (H) (to the extent described in "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2467/6/D"},"text":"section 2467(6)(D) of this title","children":[],"tail":")” for “and (G)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(H). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/200/s412/a/1"},"text":"Pub. L. 106–200, § 412(a)(1)","children":[],"tail":", added subpar. (H)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(2)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/295"},"text":"Pub. L. 104–295","children":[],"tail":", amended subpar. (F) generally. Prior to amendment, subpar. (F) read as follows: “Such country aids or abets, by granting sanctuary from prosecution to, any individual or group which has committed an act of international terrorism.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id05e3a928-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id05e3a929-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/295/s35/b"},"text":"Pub. L. 104–295, § 35(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3538"},"text":"110 Stat. 3538","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/295/s35/b"},"text":"“The amendment made by subsection (a) [amending this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1996-10-01"},"text":"October 1, 1996","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id05e3a92a-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to articles entered on or after ","children":[{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", with provisions relating to retroactive application, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/s1953"},"text":"section 1953 of Pub. L. 104–188","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2461"},"text":"section 2461 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id05e3a92b-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id05e3a92c-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Proc. No. 6942, ","children":[{"tag":"date","attrib":{"date":"1996-10-17"},"text":"Oct. 17, 1996","children":[],"tail":", 61 F.R. 54719, provided in par. (5) that powers of the President granted in subsec. (f)(2) of this section to notify a country of the President’s intention to terminate that country’s status as a beneficiary developing country for purposes of the Generalized System of Preferences were delegated to the United States Trade Representative."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
