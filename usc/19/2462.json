{"tag":"section","attrib":{"id":"id05e15ef9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2462"},"text":null,"children":[{"tag":"num","attrib":{"value":"2462"},"text":"§ 2462.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of beneficiary developing countries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05e15efa-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2462/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to designate countries","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05e15efb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2462/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Beneficiary developing countries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President is authorized to designate countries as beneficiary developing countries for purposes of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05e15efc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2462/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Least-developed beneficiary developing countries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President is authorized to designate any beneficiary developing country as a least-developed beneficiary developing country for purposes of this subchapter, based on the considerations in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2461"},"text":"section 2461 of this title","children":[],"tail":" and subsection (c) of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05e15efd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2462/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Countries ineligible for designation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05e15efe-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2462/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific countries","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following countries may not be designated as beneficiary developing countries for purposes of this subchapter:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05e15eff-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2462/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Australia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05e15f00-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2462/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Canada.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05e15f01-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2462/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" European Union member states.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05e15f02-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2462/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Iceland.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05e15f03-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2462/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Japan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05e15f04-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2462/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Monaco.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05e15f05-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2462/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" New Zealand.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05e15f06-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2462/b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Norway.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05e15f07-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2462/b/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Switzerland.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05e15f08-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2462/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other bases for ineligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President shall not designate any country a beneficiary developing country under this subchapter if any of the following applies:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05e15f09-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2462/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Such country is a Communist country, unless—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id05e15f0a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2462/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the products of such country receive nondiscriminatory treatment,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05e15f0b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2462/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such country is a WTO Member (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3501/10"},"text":"section 3501(10) of this title","children":[],"tail":") and a member of the International Monetary Fund, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05e15f0c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2462/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such country is not dominated or controlled by international communism.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05e15f0d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2462/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Such country is a party to an arrangement of countries and participates in any action pursuant to such arrangement, the effect of which is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id05e15f0e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2462/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to withhold supplies of vital commodity resources from international trade or to raise the price of such commodities to an unreasonable level, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05e15f0f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2462/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to cause serious disruption of the world economy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05e15f10-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2462/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such country affords preferential treatment to the products of a developed country, other than the United States, which has, or is likely to have, a significant adverse effect on United States commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05e15f11-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2462/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id05e15f12-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2462/b/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Such country—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id05e15f13-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2462/b/2/D/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has nationalized, expropriated, or otherwise seized ownership or control of property, including patents, trademarks, or copyrights, owned by a United States citizen or by a corporation, partnership, or association which is 50 percent or more beneficially owned by United States citizens,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id05e15f14-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2462/b/2/D/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has taken steps to repudiate or nullify an existing contract or agreement with a United States citizen or a corporation, partnership, or association which is 50 percent or more beneficially owned by United States citizens, the effect of which is to nationalize, expropriate, or otherwise seize ownership or control of property, including patents, trademarks, or copyrights, so owned, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id05e15f15-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2462/b/2/D/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has imposed or enforced taxes or other exactions, restrictive maintenance or operational conditions, or other measures with respect to property, including patents, trademarks, or copyrights, so owned, the effect of which is to nationalize, expropriate, or otherwise seize ownership or control of such property,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"unless clause (ii) applies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05e15f16-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2462/b/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" This clause applies if the President determines that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id05e15f17-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2462/b/2/D/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prompt, adequate, and effective compensation has been or is being made to the citizen, corporation, partnership, or association referred to in clause (i),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id05e15f18-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2462/b/2/D/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" good faith negotiations to provide prompt, adequate, and effective compensation under the applicable provisions of international law are in progress, or the country described in clause (i) is otherwise taking steps to discharge its obligations under international law with respect to such citizen, corporation, partnership, or association, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id05e15f19-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2462/b/2/D/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a dispute involving such citizen, corporation, partnership, or association over compensation for such a seizure has been submitted to arbitration under the provisions of the Convention for the Settlement of Investment Disputes, or in another mutually agreed upon forum,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"and the President promptly furnishes a copy of such determination to the Senate and House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05e15f1a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2462/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such country fails to act in good faith in recognizing as binding or in enforcing arbitral awards in favor of United States citizens or a corporation, partnership, or association which is 50 percent or more beneficially owned by United States citizens, which have been made by arbitrators appointed for each case or by permanent arbitral bodies to which the parties involved have submitted their dispute.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05e15f1b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2462/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such country aids or abets, by granting sanctuary from prosecution to, any individual or group which has committed an act of international terrorism or the Secretary of State makes a determination with respect to such country under section 4605(j)(1)(A) ","children":[{"tag":"ref","attrib":{"idref":"fn002120"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002120"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 50 or such country has not taken steps to support the efforts of the United States to combat terrorism."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05e15f1c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2462/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such country has not taken or is not taking steps to afford internationally recognized worker rights to workers in the country (including any designated zone in that country).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05e15f1d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2462/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such country has not implemented its commitments to eliminate the worst forms of child labor.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Subparagraphs (D), (E), (F), (G), and (H) (to the extent described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2467/6/D"},"text":"section 2467(6)(D) of this title","children":[],"tail":") shall not prevent the designation of any country as a beneficiary developing country under this subchapter if the President determines that such designation will be in the national economic interest of the United States and reports such determination to the Congress with the reasons therefor."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05e15f1e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2462/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors affecting country designation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining whether to designate any country as a beneficiary developing country under this subchapter, the President shall take into account—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05e15f1f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2462/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an expression by such country of its desire to be so designated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05e15f20-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2462/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the level of economic development of such country, including its per capita gross national product, the living standards of its inhabitants, and any other economic factors which the President deems appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05e15f21-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2462/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether or not other major developed countries are extending generalized preferential tariff treatment to such country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05e15f22-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2462/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which such country has assured the United States that it will provide equitable and reasonable access to the markets and basic commodity resources of such country and the extent to which such country has assured the United States that it will refrain from engaging in unreasonable export practices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05e15f23-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2462/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which such country is providing adequate and effective protection of intellectual property rights;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05e15f24-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2462/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the extent to which such country has taken action to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05e15f25-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2462/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce trade distorting investment practices and policies (including export performance requirements); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05e15f26-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2462/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce or eliminate barriers to trade in services; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05e15f27-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2462/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether or not such country has taken or is taking steps to afford to workers in that country (including any designated zone in that country) internationally recognized worker rights.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05e15f28-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2462/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal, suspension, or limitation of country designation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05e15f29-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2462/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President may withdraw, suspend, or limit the application of the duty-free treatment accorded under this subchapter with respect to any country. In taking any action under this subsection, the President shall consider the factors set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2461"},"text":"section 2461 of this title","children":[],"tail":" and subsection (c) of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05e15f2a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2462/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Changed circumstances","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall, after complying with the requirements of subsection (f)(2), withdraw or suspend the designation of any country as a beneficiary developing country if, after such designation, the President determines that as the result of changed circumstances such country would be barred from designation as a beneficiary developing country under subsection (b)(2). Such country shall cease to be a beneficiary developing country on the day on which the President issues an Executive order or Presidential proclamation revoking the designation of such country under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05e3a91b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2462/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advice to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall, as necessary, advise the Congress on the application of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2461"},"text":"section 2461 of this title","children":[],"tail":" and subsection (c) of this section, and the actions the President has taken to withdraw, to suspend, or to limit the application of duty-free treatment with respect to any country which has failed to adequately take the actions described in subsection (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05e3a91c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2462/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory graduation of beneficiary developing countries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the President determines that a beneficiary developing country has become a “high income” country, as defined by the official statistics of the International Bank for Reconstruction and Development, then the President shall terminate the designation of such country as a beneficiary developing country for purposes of this subchapter, effective on January 1 of the second year following the year in which such determination is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05e3a91d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2462/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional notification","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05e3a91e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2462/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of designation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05e3a91f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2462/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before the President designates any country as a beneficiary developing country under this subchapter, the President shall notify the Congress of the President’s intention to make such designation, together with the considerations entering into such decision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05e3a920-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2462/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation as least-developed beneficiary developing country","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At least 60 days before the President designates any country as a least-developed beneficiary developing country, the President shall notify the Congress of the President’s intention to make such designation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05e3a921-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2462/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the President has designated any country as a beneficiary developing country under this subchapter, the President shall not terminate such designation unless, at least 60 days before such termination, the President has notified the Congress and has notified such country of the President’s intention to terminate such designation, together with the considerations entering into such decision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05e3a922-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/tV/s502"},"text":"Pub. L. 93–618, title V, § 502","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1952/a"},"text":"Pub. L. 104–188, title I, § 1952(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1917"},"text":"110 Stat. 1917","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/295/s35/a"},"text":"Pub. L. 104–295, § 35(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3538"},"text":"110 Stat. 3538","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/200/tIV/s412/a"},"text":"Pub. L. 106–200, title IV, § 412(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-05-18"},"text":"May 18, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/298"},"text":"114 Stat. 298","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/210/dD/tXLI/s4102/a"},"text":"Pub. L. 107–210, div. D, title XLI, § 4102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-06"},"text":"Aug. 6, 