{"tag":"section","attrib":{"id":"id05aa7084-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2153"},"text":null,"children":[{"tag":"num","attrib":{"value":"2153"},"text":"§ 2153.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public hearings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05aa7085-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2153/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Opportunity for presentation of views","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In connection with any proposed trade agreement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2133"},"text":"section 2133 of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s4202"},"text":"section 4202 of this title","children":[],"tail":", the President shall afford an opportunity for any interested person to present his views concerning any article on a list published under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2151"},"text":"section 2151 of this title","children":[],"tail":", any matter or article which should be so listed, any concession which should be sought by the United States, or any other matter relevant to such proposed trade agreement. For this purpose, the President shall designate an agency or an interagency committee which shall, after reasonable notice, hold public hearings and prescribe regulations governing the conduct of such hearings. When appropriate, such procedures shall apply to the development of trade policy and priorities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05aa7086-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2153/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Summary of hearings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The organization holding such hearing shall furnish the President with a summary thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05aa7087-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/tI/s133"},"text":"Pub. L. 93–618, title I, § 133","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1995"},"text":"88 Stat. 1995","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tI/s1111/a"},"text":"Pub. L. 100–418, title I, § 1111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1137"},"text":"102 Stat. 1137","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/210/dB/tXXI/s2110/a/3"},"text":"Pub. L. 107–210, div. B, title XXI, § 2110(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-06"},"text":"Aug. 6, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1020"},"text":"116 Stat. 1020","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/26/tI/s110/a/3"},"text":"Pub. L. 114–26, title I, § 110(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-06-29"},"text":"June 29, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/357"},"text":"129 Stat. 357","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05aa7088-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05aa7089-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading"