{"tag":"section","attrib":{"id":"id06136ba7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3581"},"text":null,"children":[{"tag":"num","attrib":{"value":"3581"},"text":"§ 3581.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Objectives in intellectual property","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It is the objective of the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id06136ba8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3581/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to accelerate the implementation of the Agreement on Trade-Related Aspects of Intellectual Property Rights referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3511/d/15"},"text":"section 3511(d)(15) of this title","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06136ba9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3581/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to seek enactment and effective implementation by foreign countries of laws to protect and enforce intellectual property rights that supplement and strengthen the standards of the Agreement on Trade-Related Aspects of Intellectual Property Rights referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3511/d/15"},"text":"section 3511(d)(15) of this title","children":[],"tail":" and the North American Free Trade Agreement and, in particular—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id06136baa-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3581/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conclude bilateral and multilateral agreements that create obligations to protect and enforce intellectual property rights that cover new and emerging technologies and new methods of transmission and distribution, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06136bab-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3581/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prevent or eliminate discrimination with respect to matters affecting the availability, acquisition, scope, maintenance, use, and enforcement of intellectual property rights,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06136bac-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3581/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to secure fair, equitable, and nondiscriminatory market access opportunities for United States persons that rely upon intellectual property protection,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06136bad-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3581/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to take an active role in the development of the intellectual property regime under the World Trade Organization to ensure that it is consistent with other United States objectives, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06136bae-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3581/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to take an active role in the World Intellectual Property Organization (WIPO) to develop a cooperative and mutually supportive relationship between the World Trade Organization and WIPO.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id06136baf-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/tIII/s315"},"text":"Pub. L. 103–465, title III, § 315","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4942"},"text":"108 Stat. 4942","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id06136bb0-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id06136bb1-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id06136bb2-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/tIII/s316"},"text":"Pub. L. 103–465, title III, § 316","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4943"},"text":"108 Stat. 4943","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/465/tIII/s316"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (b), this subtitle [subtitle B (§§ 311–316) of title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465"},"text":"Pub. L. 103–465","children":[],"tail":", enacting this section and amending sections 2241, 2242, 2411, 2414, 2416, and 2420 of this title] and the amendments made by this subtitle take effect on the date on which the WTO Agreement enters into force with respect to the United States ["},{"tag":"date","attrib":{"date":"1995-01-01"},"text":"Jan. 1, 1995","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Section","children":[],"tail":" 314(f).—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendment made by section 314(f) [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2420"},"text":"section 2420 of this title","children":[],"tail":"] takes effect on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
