{"tag":"section","attrib":{"id":"id05cbdaf5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2318"},"text":null,"children":[{"tag":"num","attrib":{"value":"2318"},"text":"§ 2318.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration project for alternative trade adjustment assistance for older workers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05cbdaf6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2318/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05cbdaf7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2318/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2002-08-06"},"text":"August 6, 2002","children":[],"tail":", the Secretary shall establish an alternative trade adjustment assistance program for older workers that provides the benefits described in paragraph (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05cbdaf8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2318/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benefits","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05cbdaf9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2318/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State shall use the funds provided to the State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2313"},"text":"section 2313 of this title","children":[],"tail":" to pay, for a period not to exceed 2 years, to a worker described in paragraph (3)(B), 50 percent of the difference between—"}],"tail":null},{"tag":"clause","attrib":{"id":"id05cbdafa-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2318/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the wages received by the worker from reemployment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05cbdafb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2318/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the wages received by the worker at the time of separation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05cbdafc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2318/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health insurance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A worker described in paragraph (3)(B) participating in the program established under paragraph (1) is eligible to receive, for a period not to exceed 2 years, a credit for health insurance costs under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s35"},"text":"section 35 of title 26","children":[],"tail":", as added by section 201 of the Trade Act of 2002."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05cbdafd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2318/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05cbdafe-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2318/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Firm eligibility","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id05cbdaff-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2318/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide the opportunity for a group of workers on whose behalf a petition is filed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2271"},"text":"section 2271 of this title","children":[],"tail":" to request that the group of workers be certified for the alternative trade adjustment assistance program under this section at the time the petition is filed."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05cbdb00-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2318/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining whether to certify a group of workers as eligible for the alternative trade adjustment assistance program, the Secretary shall consider the following criteria:","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id05cbdb01-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2318/a/3/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether a significant number of workers in the workers’ firm are 50 years of age or older.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id05cbdb02-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2318/a/3/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether the workers in the workers’ firm possess skills that are not easily transferable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id05cbdb03-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2318/a/3/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The competitive conditions within the workers’ industry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05cbdb04-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2318/a/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall determine whether the workers in the group are eligible for the alternative trade adjustment assistance program by the date specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2273/a"},"text":"section 2273(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05cbdb05-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2318/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Individual eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A worker in the group that the Secretary has certified as eligible for the alternative trade adjustment assistance program may elect to receive benefits under the alternative trade adjustment assistance program if the worker—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id05cbdb06-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2318/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is covered by a certification under subpart A of this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05cbdb07-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2318/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtains reemployment not more than 26 weeks after the date of separation from the adversely affected employment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05cbdb08-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2318/a/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is at least 50 years of age;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05cbdb09-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2318/a/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" earns not more than $50,000 a year in wages from reemployment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05cbdb0a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2318/a/3/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is employed on a full-time basis as defined by State law in the State in which the worker is employed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05cbdb0b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2318/a/3/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not return to the employment from which the worker was separated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05cbdb0c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2318/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Total amount of payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The payments described in paragraph (2)(A) made to a worker may not exceed $10,000 per worker during the 2-year eligibility period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05cbdb0d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2318/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on other benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2)(B), if a worker is receiving payments pursuant to the program established under paragraph (1), the worker shall not be eligible to receive any other benefits under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05cbdb0e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2318/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05cbdb0f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2318/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), no payments may be made by a State under the program established under subsection (a)(1) after the date that is 5 years after the date on which such program is implemented by the State.","children":[{"tag":"ref","attrib":{"idref":"fn002105"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002105"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Application of Subsection (b)(1) note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05cbdb10-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2318/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraph (1), a worker receiving payments under the program established under subsection (a)(1) on the termination date described in paragraph (1) shall continue to receive such payments if the worker meets the criteria described in subsection (a)(3)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05cbdb11-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/tII/s246"},"text":"Pub. L. 93–618, title II, § 246","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/210/dA/tI/s124/a"},"text":"Pub. L. 107–210, div. A, title I, § 124(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-06"},"text":"Aug. 6, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/944"},"text":"116 Stat. 944","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/429/tII/s2004/a/7"},"text":"Pub. L. 108–429, title II, § 2004(a)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-03"},"text":"Dec. 3, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2590"},"text":"118 Stat. 2590","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/5/dB/tI/s1841/a"},"text":"Pub. L. 111–5, div. B, title I, § 1841(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/386"},"text":"123 Stat. 386","children":[],"tail":", 389; "},{"tag":"ref","attrib":{"href":"/us/pl/111/344/tI/s101/c/3"},"text":"Pub. L. 111–344, title I, § 101(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-29"},"text":"Dec. 29, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3613"},"text":"124 Stat. 3613","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/40/tII"},"text":"Pub. L. 112–40, title II","children":[],"tail":", §§ 201(b), (c), 215, "},{"tag":"date","attrib":{"date":"2011-10-21"},"text":"Oct. 21, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/403"},"text":"125 Stat. 403","children":[],"tail":", 407; "},{"tag":"ref","attrib":{"href":"/us/pl/114/27/tIV"},"text":"Pub. L. 114–27, title IV","children":[],"tail":", §§ 402(b), (c), 403(c), "},{"tag":"date","attrib":{"date":"2015-06-29"},"text":"June 29, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/374"},"text":"129 Stat. 374","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type"