{"tag":"section","attrib":{"id":"id05ead4a3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2497a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2497a"},"text":"§ 2497a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agricultural Disaster Relief Trust Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05ead4a4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2497a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Creation of Trust Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Treasury of the United States a trust fund to be known as the “Agricultural Disaster Relief Trust Fund”, consisting of such amounts as may be appropriated or credited to such Trust Fund as provided in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05ead4a5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2497a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer to Trust Fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05ead4a6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2497a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are appropriated to the Agricultural Disaster Relief Trust Fund amounts equivalent to 3.08 percent of the amounts received in the general fund of the Treasury of the United States during fiscal years 2008 through 2011 attributable to the duties collected on articles entered, or withdrawn from warehouse, for consumption under the Harmonized Tariff Schedule of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05ead4a7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2497a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amounts based on estimates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amounts appropriated under this section shall be transferred at least monthly from the general fund of the Treasury of the United States to the Agricultural Disaster Relief Trust Fund on the basis of estimates made by the Secretary of the Treasury. Proper adjustments shall be made in the amounts subsequently transferred to the extent prior estimates were in excess of or less than the amounts required to be transferred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05ead4a8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2497a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on transfers to Agricultural Disaster Relief Trust Fund","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No amount may be appropriated to the Agricultural Disaster Relief Trust Fund on and after the date of any expenditure from the Agricultural Disaster Relief Trust Fund which is not permitted by this section. The determination of whether an expenditure is so permitted shall be made without regard to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05ead4a9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2497a/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any provision of law which is not contained or referenced in this subchapter or in a revenue Act, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05ead4aa-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2497a/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether such provision of law is a subsequently enacted provision or directly or indirectly seeks to waive the application of this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05ead4ab-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2497a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05ead4ac-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2497a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury shall be the trustee of the Agricultural Disaster Relief Trust Fund and shall submit an annual report to Congress each year on the financial condition and the results of the operations of such Trust Fund during the preceding fiscal year and on its expected condition and operations during the 4 fiscal years succeeding such fiscal year. Such report shall be printed as a House document of the session of Congress to which the report is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05ead4ad-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2497a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05ead4ae-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2497a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Treasury shall invest such portion of the Agricultural Disaster Relief Trust Fund as is not in his judgment required to meet current withdrawals. Such investments may be made only in interest bearing obligations of the United States. For such purpose, such obligations may be acquired—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id05ead4af-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2497a/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on original issue at the issue price, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05ead4b0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2497a/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by purchase of outstanding obligations at the market price.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05ead4b1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2497a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale of obligations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any obligation acquired by the Agricultural Disaster Relief Trust Fund may be sold by the Secretary of the Treasury at the market price.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05ead4b2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2497a/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest on certain proceeds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The interest on, and the proceeds from the sale or redemption of, any obligations held in the Agricultural Disaster Relief Trust Fund shall be credited to and form a part of such Trust Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05ead4b3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2497a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditures from Trust Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts in the Agricultural Disaster Relief Trust Fund shall be available for the purposes of making expenditures to meet those obligations of the United States incurred under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2497"},"text":"section 2497 of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1531"},"text":"section 1531 of title 7","children":[],"tail":" (as such sections are in effect on the date of the enactment of the Food, Conservation, and Energy Act of 2008)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05ead4b4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2497a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to borrow","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05ead4b5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2497a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated, and are appropriated, to the Agricultural Disaster Relief Trust Fund, as repayable advances, such sums as may be necessary to carry out the purposes of such Trust Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05ead4b6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2497a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment of advances","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05ead4b7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2497a/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Advances made to the Agricultural Disaster Relief Trust Fund shall be repaid, and interest on such advances shall be paid, to the general fund of the Treasury when the Secretary determines that moneys are available for such purposes in such Trust Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05ead4b8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2497a/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rate of interest","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Interest on advances made pursuant to this subsection shall be—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id05ead4b9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2497a/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at a rate determined by the Secretary of the Treasury (as of the close of the calendar month preceding the month in which the advance is made) to be equal to the current average market yield on outstanding marketable obligations of the United States with remaining periods to maturity comparable to the anticipated period during which the advance will be outstanding, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id05ead4ba-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2497a/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compounded annually.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05ead4bb-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/tIX/s902"},"text":"Pub. L. 93–618, title IX, § 902","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXV/s15101/a"},"text":"Pub. L. 110–234, title XV, § 15101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1498"},"text":"122 Stat. 1498","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title XV, § 15101(a), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2260.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05ead4bc-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05ead4bd-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id05ead4be-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Harmonized Tariff Schedule of the United States, referred to in subsec. (b)(1), is not set out in the Code. See Publication of Harmonized Tariff Schedule note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1202"},"text":"section 1202 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of the enactment of the Food, Conservation, and Energy Act of 2008, referred to in subsec. (d), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id05ead4bf-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" enacted identical sections. "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id05ead4c0-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id05ead4c1-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Enactment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of Title 7","children":[],"tail":", Agriculture."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
