{"tag":"section","attrib":{"id":"id065afc42-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4586"},"text":null,"children":[{"tag":"num","attrib":{"value":"4586"},"text":"§ 4586.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsidy negotiations","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In the case of any trade agreement which may be entered into by the President with a USMCA country, the negotiating objectives of the United States with respect to subsidies shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id065afc43-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4586/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" achievement of increased discipline on domestic subsidies provided by a foreign government, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id065afc44-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4586/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of capital, loans, or loan guarantees on terms inconsistent with commercial considerations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id065afc45-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4586/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of goods or services at preferential rates;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id065afc46-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4586/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the granting of funds or forgiveness of debt to cover operating losses sustained by a specific industry; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id065afc47-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4586/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the assumption of any costs or expenses of manufacture, production, or distribution;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065afc48-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4586/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" achievement of increased discipline on export subsidies provided by a foreign government, particularly with respect to agricultural products; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065afc49-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4586/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintenance of effective remedies against subsidized imports, including, where appropriate, countervailing duties.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id065afc4a-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113/tIV/s416"},"text":"Pub. L. 116–113, title IV, § 416","children":[],"tail":", formerly "},{"tag":"ref","attrib":{"href":"/us/pl/103/182/tIV/s406"},"text":"Pub. L. 103–182, title IV, § 406","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-08"},"text":"Dec. 8, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2138"},"text":"107 Stat. 2138","children":[],"tail":"; renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/116/113/s416"},"text":"§ 416 of Pub. L. 116–113","children":[],"tail":" and amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/113/tV/s504/g"},"text":"Pub. L. 116–113, title V, § 504(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-01-29"},"text":"Jan. 29, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/75"},"text":"134 Stat. 75","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id065afc4b-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id065afc4c-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id065afc4d-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3436"},"text":"section 3436 of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/116/113"},"text":"Pub. L. 116–113","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id065afc4e-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113/s504/g/3"},"text":"Pub. L. 116–113, § 504(g)(3)","children":[],"tail":", substituted “USMCA country” for “NAFTA country” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id065afc4f-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id065afc50-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2020 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Transfer to and amendment of this section by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113"},"text":"Pub. L. 116–113","children":[],"tail":" effective on the date on which the USMCA enters into force ("},{"tag":"date","attrib":{"date":"2020-07-01"},"text":"July 1, 2020","children":[],"tail":"), but not applicable to certain determinations under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1516a"},"text":"section 1516a of this title","children":[],"tail":" or binational panel reviews under NAFTA, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/113/s504/k"},"text":"section 504(k) of Pub. L. 116–113","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s4581"},"text":"section 4581 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
