{"tag":"section","attrib":{"id":"id0595137d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2031"},"text":null,"children":[{"tag":"num","attrib":{"value":"2031"},"text":"§ 2031.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorities; delegation of functions; rules and regulations","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The head of any agency performing functions authorized by this chapter may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0595137e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2031/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorize the head of any other agency to perform any of such functions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0595137f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2031/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribe such rules and regulations as may be necessary to perform such functions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05951380-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/283/tV/s501"},"text":"Pub. L. 89–283, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-10-21"},"text":"Oct. 21, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1025"},"text":"79 Stat. 1025","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05951381-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05951382-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id05951383-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/283"},"text":"Pub. L. 89–283","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-10-21"},"text":"Oct. 21, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1016"},"text":"79 Stat. 1016","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2001"},"text":"section 2001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
