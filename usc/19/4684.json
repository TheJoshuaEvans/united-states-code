{"tag":"section","attrib":{"id":"id065d464f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4684"},"text":null,"children":[{"tag":"num","attrib":{"value":"4684"},"text":"§ 4684.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties related to Mexico","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Task Force shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id065d4650-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4684/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop, in consultation with the appropriate congressional committees, an enforcement plan regarding goods produced by or with forced labor in Mexico; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id065d4651-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4684/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report to the Interagency Labor Committee with respect to any concerns relating to the enforcement of the prohibition under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1307"},"text":"section 1307 of this title","children":[],"tail":" with respect to Mexico, including any allegations that may be filed with respect to forced labor in Mexico."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id065d4652-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113/tVII/s744"},"text":"Pub. L. 116–113, title VII, § 744","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-01-29"},"text":"Jan. 29, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/89"},"text":"134 Stat. 89","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id065d4653-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id065d4654-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id065d4655-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1307"},"text":"Section 1307 of this title","children":[],"tail":", referred to in par. (2), was in the original “section 307 of the Tariff Act”, and was translated as reading “section 307 of the Tariff Act of 1930”, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
