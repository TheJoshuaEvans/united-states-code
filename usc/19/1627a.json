{"tag":"section","attrib":{"id":"id056a0c97-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1627a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1627a"},"text":"§ 1627a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unlawful importation or exportation of certain vehicles; inspections","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id056a0c98-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1627a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violations; penalties; seizures and forfeitures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id056a0c99-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1627a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Whoever knowingly imports, exports, or attempts to import or export—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id056a0c9a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1627a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any ","children":[{"tag":"ref","attrib":{"idref":"fn002044"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002044"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should not be capitalized."}],"tail":" stolen self-propelled vehicle, vessel, aircraft, or part of a self-propelled vehicle, vessel, or aircraft; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id056a0c9b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1627a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any self-propelled vehicle or part of a self-propelled vehicle from which the identification number has been removed, obliterated, tampered with, or altered;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be subject to a civil penalty in an amount determined by the Secretary, not to exceed $10,000 for each violation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id056a0c9c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1627a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any violation of this subsection shall make such self-propelled vehicle, vessel, aircraft, or part thereof subject to seizure and forfeiture under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id056a0c9d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1627a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations; violations; penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person attempting to export a used self-propelled vehicle shall present, pursuant to regulations prescribed by the Secretary, to the appropriate customs officer both the vehicle and a document describing such vehicle which includes the vehicle identification number, before lading if the vehicle is to be transported by vessel or aircraft, or before export if the vehicle is to be transported by rail, highway, or under its own power. Failure to comply with the regulations of the Secretary shall subject such person to a civil penalty of not more than $500 for each violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id056a0c9e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1627a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id056a0c9f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1627a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “self-propelled vehicle” includes any automobile, truck, tractor, bus, motorcycle, motor home, self-propelled agricultural machinery, self-propelled construction equipment, self-propelled special use equipment, and any other self-propelled vehicle used or designed for running on land but not on rail;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id056a0ca0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1627a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “aircraft” has the meaning given it in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s40102/a/6"},"text":"section 40102(a)(6) of title 49","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id056a0ca1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1627a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “used” refers to any self-propelled vehicle the equitable or legal title to which has been transferred by a manufacturer, distributor, or dealer to an ultimate purchaser; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id056a0ca2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1627a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “ultimate purchaser” means the first person, other than a dealer purchasing in his capacity as a dealer, who in good faith purchases a self-propelled vehicle for purposes other than resale.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id056a0ca3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1627a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation of law enforcement and governmental authorities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Customs officers may cooperate and exchange information concerning motor vehicles, off-highway mobile equipment, vessels, or aircraft, either before exportation or after exportation or importation, with such Federal, State, local, and foreign law enforcement or governmental authorities, and with such organizations engaged in theft prevention activities, as may be designated by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id056a0ca4-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title IV, § 627, as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/573/tII/s205"},"text":"Pub. L. 98–573, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2974"},"text":"98 Stat. 2974","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id056a0ca5-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id056a0ca6-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id056a0ca7-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (c)(2), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s40102/a/6"},"text":"section 40102(a)(6) of title 49","children":[],"tail":"” substituted for “section 101(5) of the Federal Aviation Act of 1958 ("},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301/5"},"text":"49 U.S.C. 1301(5)","children":[],"tail":")” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/103/272/s6/b"},"text":"Pub. L. 103–272, § 6(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1378"},"text":"108 Stat. 1378","children":[],"tail":", the first section of which enacted subtitles II, III, and V to X of Title 49, Transportation."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 627 of act ","children":[{"tag":"date","attrib":{"date":"1930-06-17"},"text":"June 17, 1930","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/98/547/tIII/s302"},"text":"Pub. L. 98–547, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-25"},"text":"Oct. 25, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2771"},"text":"98 Stat. 2771","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1627"},"text":"section 1627 of this title","children":[],"tail":" and subsequently repealed."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id056a0ca8-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id056a0ca9-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on 15th day after ","children":[{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", see section 214(a), (b) of "},{"tag":"ref","attrib":{"href":"/us/pl/98/573"},"text":"Pub. L. 98–573","children":[],"tail":", set out as an Effective Date of 1984 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1304"},"text":"section 1304 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
