{"tag":"section","attrib":{"id":"id05e619dd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2467"},"text":null,"children":[{"tag":"num","attrib":{"value":"2467"},"text":"§ 2467.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05e619de-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2467/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Beneficiary developing country","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “beneficiary developing country” means any country with respect to which there is in effect an Executive order or Presidential proclamation by the President designating such country as a beneficiary developing country for purposes of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05e619df-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2467/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Country","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “country” means any foreign country or territory, including any overseas dependent territory or possession of a foreign country, or the Trust Territory of the Pacific Islands. In the case of an association of countries which is a free trade area or customs union, or which is contributing to comprehensive regional economic integration among its members through appropriate means, including, but not limited to, the reduction of duties, the President may by Executive order or Presidential proclamation provide that all members of such association other than members which are barred from designation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2462/b"},"text":"section 2462(b) of this title","children":[],"tail":" shall be treated as one country for purposes of this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05e619e0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2467/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entered","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “entered” means entered, or withdrawn from warehouse for consumption, in the customs territory of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05e619e1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2467/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Internationally recognized worker rights","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “internationally recognized worker rights” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05e619e2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2467/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the right of association;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05e619e3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2467/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the right to organize and bargain collectively;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05e619e4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2467/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a prohibition on the use of any form of forced or compulsory labor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05e619e5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2467/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a minimum age for the employment of children, and a prohibition on the worst forms of child labor, as defined in paragraph (6); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05e619e6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2467/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acceptable conditions of work with respect to minimum wages, hours of work, and occupational safety and health.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05e619e7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2467/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Least-developed beneficiary developing country","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “least-developed beneficiary developing country” means a beneficiary developing country that is designated as a least-developed beneficiary developing country under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2462/a/2"},"text":"section 2462(a)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05e619e8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2467/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Worst forms of child labor","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “worst forms of child labor” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05e619e9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2467/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all forms of slavery or practices similar to slavery, such as the sale or trafficking of children, debt bondage and serfdom, or forced or compulsory labor, including forced or compulsory recruitment of children for use in armed conflict;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05e619ea-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2467/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use, procuring, or offering of a child for prostitution, for the production of pornography or for pornographic purposes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05e619eb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2467/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use, procuring, or offering of a child for illicit activities in particular for the production and trafficking of drugs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05e619ec-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2467/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work which, by its nature or the circumstances in which it is carried out, is likely to harm the health, safety, or morals of children.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The work referred to in subparagraph (D) shall be determined by the laws, regulations, or competent authority of the beneficiary developing country involved.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05e619ed-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/tV/s507"},"text":"Pub. L. 93–618, title V, § 507","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1952/a"},"text":"Pub. L. 104–188, title I, § 1952(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1926"},"text":"110 Stat. 1926","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/200/tIV/s412/b"},"text":"Pub. L. 106–200, title IV, § 412(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-05-18"},"text":"May 18, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/298"},"text":"114 Stat. 298","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/210/dD/tXLI/s4102/b"},"text":"Pub. L. 107–210, div. D, title XLI, § 4102(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-06"},"text":"Aug. 6, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1041"},"text":"116 Stat. 1041","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05e619ee-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05e619ef-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id05e619f0-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Par. (4)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/210"},"text":"Pub. L. 107–210","children":[],"tail":" amended subpar. (D) generally. Prior to amendment, subpar. (D) read as follows: “a minimum age for the employment of children; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Par. (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/200"},"text":"Pub. L. 106–200","children":[],"tail":" added par. (6)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id05e619f1-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id05e619f2-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to articles entered on or after ","children":[{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", with provisions relating to retroactive application, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/s1953"},"text":"section 1953 of Pub. L. 104–188","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2461"},"text":"section 2461 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id05e619f3-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id05e619f4-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Trust Territory of the Pacific Islands","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination of Trust Territory of the Pacific Islands, see note set out preceding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1681"},"text":"section 1681 of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
