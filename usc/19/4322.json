{"tag":"section","attrib":{"id":"id064f14f4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4322"},"text":null,"children":[{"tag":"num","attrib":{"value":"4322"},"text":"§ 4322.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority trade issues","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id064f14f5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4322/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commissioner shall establish the following as priority trade issues:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id064f14f6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4322/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Agriculture programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064f14f7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4322/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Antidumping and countervailing duties.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064f14f8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4322/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Import safety.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064f14f9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4322/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Intellectual property rights.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064f14fa-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4322/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Revenue.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064f14fb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4322/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Textiles and wearing apparel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064f14fc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4322/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Trade agreements and preference programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id064f14fd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4322/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commissioner is authorized to establish new priority trade issues and eliminate, consolidate, or otherwise modify the priority trade issues described in subsection (a) if the Commissioner—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id064f14fe-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4322/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determines it necessary and appropriate to do so; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064f14ff-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4322/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id064f1500-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4322/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of new priority trade issues, submits to the appropriate congressional committees a summary of proposals to establish such new priority trade issues not later than 30 days after such new priority trade issues are to take effect; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id064f1501-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4322/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of existing priority trade issues, submits to the appropriate congressional committees a summary of proposals to eliminate, consolidate, or otherwise modify such existing priority trade issues not later than 60 days before such changes are to take effect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id064f1502-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/125/tI/s117"},"text":"Pub. L. 114–125, title I, § 117","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-24"},"text":"Feb. 24, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/145"},"text":"130 Stat. 145","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
