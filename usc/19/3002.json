{"tag":"section","attrib":{"id":"id0605135a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3002"},"text":null,"children":[{"tag":"num","attrib":{"value":"3002"},"text":"§ 3002.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0605135b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3002/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Commission” means the United States International Trade Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0605135c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3002/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Convention” means the International Convention on the Harmonized Commodity Description and Coding System, done at Brussels on ","children":[{"tag":"date","attrib":{"date":"1983-06-14"},"text":"June 14, 1983","children":[],"tail":", and the Protocol thereto, done at Brussels on "},{"tag":"date","attrib":{"date":"1986-06-24"},"text":"June 24, 1986","children":[],"tail":", submitted to the Congress on "},{"tag":"date","attrib":{"date":"1987-06-15"},"text":"June 15, 1987","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0605135d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3002/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “entered” means entered, or withdrawn from warehouse for consumption, in the customs territory of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0605135e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3002/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Federal agency” means any establishment in the executive branch of the United States Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0605135f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3002/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “old Schedules” means title I of the Tariff Act of 1930 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1202"},"text":"19 U.S.C. 1202","children":[],"tail":") as in effect on the day before the effective date of the amendment to such title under section 1204(a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06051360-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3002/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “technical rectifications” means rectifications of an editorial character or minor technical or clerical changes which do not affect the substance or meaning of the text, such as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id06051361-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3002/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" errors in spelling, numbering, or punctuation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06051362-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3002/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" errors in indentation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06051363-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3002/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" errors (including inadvertent omissions) in cross-references to headings or subheadings or notes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06051364-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3002/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other clerical or typographical errors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id06051365-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/tI/s1202"},"text":"Pub. L. 100–418, title I, § 1202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1147"},"text":"102 Stat. 1147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id06051366-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id06051367-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id06051368-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this subtitle”, meaning subtitle B (§§ 1201 to 1217) of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418"},"text":"Pub. L. 100–418","children":[],"tail":", which is classified principally to this chapter. For complete classification of this subtitle to the Code, see References in Text note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3001"},"text":"section 3001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Title I of the Tariff Act of 1930 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1202"},"text":"19 U.S.C. 1202","children":[],"tail":") as in effect on the day before the effective date of the amendment to such title under section 1204(a), referred to in par. (5), is title I of "},{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"act June 17, 1930, ch. 497","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/590"},"text":"46 Stat. 590","children":[],"tail":", as in effect on the day before "},{"tag":"date","attrib":{"date":"1989-01-01"},"text":"Jan. 1, 1989","children":[],"tail":". Title I of the Tariff Act of 1930 which comprised the Tariff Schedules of the United States was not set out in the Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
