{"tag":"section","attrib":{"id":"id05c96aa2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2312"},"text":null,"children":[{"tag":"num","attrib":{"value":"2312"},"text":"§ 2312.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration absent State agreement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05c96aa3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2312/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promulgation of regulations; fair hearing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any State where there is no agreement in force between a State or its agency under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2311"},"text":"section 2311 of this title","children":[],"tail":", the Secretary shall arrange under regulations prescribed by him for performance of all necessary functions under subpart B of this part, including provision for a fair hearing for any worker whose application for payments is denied."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05c96aa4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2312/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of final determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A final determination under subsection (a) with respect to entitlement to program benefits under subpart B of this part is subject to review by the courts in the same manner and to the same extent as is provided by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s405/g"},"text":"section 405(g) of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourc