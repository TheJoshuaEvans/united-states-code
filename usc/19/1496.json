{"tag":"section","attrib":{"id":"id05465747-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1496"},"text":null,"children":[{"tag":"num","attrib":{"value":"1496"},"text":"§ 1496.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Examination of baggage","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The appropriate customs officer may cause an examination to be made of the baggage of any person arriving in the United States in order to ascertain what articles are contained therein and whether subject to duty, free of duty, or prohibited notwithstanding a declaration and entry therefor has been made.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id05465748-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title IV, § 496, "},{"tag":"ref","attrib":{"href":"/us/stat/46/727"},"text":"46 Stat. 727","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/271/tIII/s301/b"},"text":"Pub. L. 91–271, title III, § 301(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-06-02"},"text":"June 2, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/287"},"text":"84 Stat. 287","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05465749-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0546574a-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0546574b-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","childr