{"tag":"section","attrib":{"id":"id064307e9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4111"},"text":null,"children":[{"tag":"num","attrib":{"value":"4111"},"text":"§ 4111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic reports and meetings on labor obligations and labor capacity-building provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id064307ea-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4111/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id064307eb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4111/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than the end of the 2-year period beginning on the date the Agreement enters into force, and not later than the end of each 2-year period thereafter during the succeeding 14-year period, the President shall report to the Congress on the progress made by the CAFTA–DR countries in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id064307ec-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4111/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implementing Chapter Sixteen and Annex 16.5 of the Agreement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id064307ed-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4111/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implementing the White Paper.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064307ee-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4111/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" White Paper","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “White Paper” means the report of April 2005 of the Working Group of the Vice Ministers Responsible for Trade and Labor in the Countries of Central America and the Dominican Republic entitled “The Labor Dimension in Central America and the Dominican Republic - Building on Progress: Strengthening Compliance and Enhancing Capacity”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064307ef-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4111/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report under paragraph (1) shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id064307f0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4111/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the progress made by the Labor Cooperation and Capacity Building Mechanism established by article 16.5 and Annex 16.5 of the Agreement, and the Labor Affairs Council established by article 16.4 of the Agreement, in achieving their stated goals, including a description of the capacity-building projects undertaken, funds received, and results achieved, in each CAFTA–DR country.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id064307f1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4111/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Recommendations on how the United States can facilitate full implementation of the recommendations contained in the White Paper.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id064307f2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4111/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the work done by the CAFTA–DR countries with the International Labor Organization to implement the recommendations contained in the White Paper, and the efforts of the CAFTA–DR countries with international organizations, through the Labor Cooperation and Capacity Building Mechanism referred to in subparagraph (A), to advance common commitments regarding labor matters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id064307f3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4111/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A summary of public comments received on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id064307f4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4111/a/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" capacity-building efforts by the United States envisaged by article 16.5 and Annex 16.5 of the Agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id064307f5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4111/a/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" efforts by the United States to facilitate full implementation of the White Paper recommendations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id064307f6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4111/a/3/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the efforts made by the CAFTA–DR countries to comply with article 16.5 and Annex 16.5 of the Agreement and to fully implement the White Paper recommendations, including the progress made by the CAFTA–DR countries in affording to workers internationally-recognized worker rights through improved capacity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064307f7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4111/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Solicitation of public comments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall establish a mechanism to solicit public comments for purposes of paragraph (3)(D).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id064307f8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4111/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic meetings of Secretary of Labor with labor ministers of CAFTA–DR countries","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id064307f9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4111/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic meetings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Labor should take the necessary steps to meet periodically with the labor ministers of the CAFTA–DR countries to discuss—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id064307fa-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4111/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the operation of the labor provisions of the Agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id064307fb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4111/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" progress on the commitments made by the CAFTA–DR countries to implement the recommendations contained in the White Paper;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id064307fc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4111/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the work of the International Labor Organization in the CAFTA–DR countries, and other cooperative efforts, to afford to workers internationally-recognized worker rights; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id064307fd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4111/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other matters as the Secretary of Labor and the labor ministers consider appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064307fe-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4111/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion in biennial reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall include in each report under subsection (a), as the President deems appropriate, summaries of the meetings held pursuant to paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id064577ff-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/53/tIV/s403"},"text":"Pub. L. 109–53, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-02"},"text":"Aug. 2, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/496"},"text":"119 Stat. 496","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id06457800-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id06457801-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination of section by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/53/s107/d"},"text":"section 107(d) of Pub. L. 109–53","children":[],"tail":", see Effective and Termination Dates note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id06457802-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id06457803-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective and Termination Dates","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date the Dominican Republic-Central America-United States Free Trade Agreement enters into force (","children":[{"tag":"date","attrib":{"date":"2006-03-01"},"text":"Mar. 1, 2006","children":[],"tail":") and to cease to have effect on the date the Agreement ceases to be in force with respect to the United States, and, during any period in which a country ceases to be a CAFTA–DR country, to cease to have effect with respect to such country, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/53/s107"},"text":"section 107 of Pub. L. 109–53","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s4001"},"text":"section 4001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id06457804-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id06457805-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Proc. No. 8272, ","children":[{"tag":"date","attrib":{"date":"2008-06-30"},"text":"June 30, 2008","children":[],"tail":", 73 F.R. 38300, provided in pars. (17) and (18) that the reporting function under subsecs. (a) and (b)(2) of this section and the solicitation of public comments under subsec. (a)(4) of this section were delegated to the Secretary of Labor, in consultation with the United States Trade Representative."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
