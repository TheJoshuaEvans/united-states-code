{"tag":"section","attrib":{"id":"id05844a37-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"1677–2"},"text":"§ 1677–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Calculation of countervailable subsidies on certain processed agricultural products","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In the case of an agricultural product processed from a raw agricultural product in which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05844a38-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677–2/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the demand for the prior stage product is substantially dependent on the demand for the latter stage product, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05844a39-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677–2/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the processing operation adds only limited value to the raw commodity,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"countervailable subsidies found to be provided to either producers or processors of the product shall be deemed to be provided with respect to the manufacture, production, or exportation of the processed product.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05844a3a-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title VII, § 771B, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tI/s1313/a"},"text":"Pub. L. 100–418, title I, § 1313(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1185"},"text":"102 Stat. 1185","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tIX/s9001/a/4"},"text":"Pub. L. 100–647, title IX, § 9001(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3806"},"text":"102 Stat. 3806","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/tII/s270/b/1/D"},"text":"Pub. L. 103–465, title II, § 270(b)(1)(D)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4917"},"text":"108 Stat. 4917","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05844a3b-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05844a3c-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id05844a3d-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465"},"text":"Pub. L. 103–465","children":[],"tail":" inserted “countervailable” before “subsidies” in section catchline and concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “In the case of an agricultural product processed from a raw agricultural product in which (1) the demand for the prior stage product is substantially dependent on the demand for the latter stage product, and (2) the processing operation adds only limited value to the raw commodity, subsidies found to be provided to either producers or processors of the product shall be deemed to be provided with respect to the manufacture, production, or exportation of the processed product.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id05844a3e-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id05844a3f-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465"},"text":"Pub. L. 103–465","children":[],"tail":" effective, except as otherwise provided, on the date on which the WTO Agreement enters into force with respect to the United States ("},{"tag":"date","attrib":{"date":"1995-01-01"},"text":"Jan. 1, 1995","children":[],"tail":"), and applicable with respect to investigations, reviews, and inquiries initiated and petitions filed under specified provisions of this chapter after such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/s291"},"text":"section 291 of Pub. L. 103–465","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1671"},"text":"section 1671 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id05844a40-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" applicable as if such amendment took effect on "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s9001/b"},"text":"section 9001(b) of Pub. L. 100–647","children":[],"tail":", set out as an Effective and Termination Dates of 1988 Amendments note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s58c"},"text":"section 58c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
