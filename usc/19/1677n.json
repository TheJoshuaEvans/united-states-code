{"tag":"section","attrib":{"id":"id058b765c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677n"},"text":null,"children":[{"tag":"num","attrib":{"value":"1677n"},"text":"§ 1677n.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Antidumping petitions by third countries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id058b765d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677n/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Filing of petition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The government of a WTO member may file with the Trade Representative a petition requesting that an investigation be conducted to determine if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id058b765e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677n/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" imports from another country are being sold in the United States at less than fair value, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id058b765f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677n/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an industry in the petitioning country is materially injured by reason of those imports.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id058b7660-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677n/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initiation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Trade Representative, after consultation with the administering authority and the Commission and obtaining the approval of the WTO Council for Trade in Goods, shall determine whether to initiate an investigation described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id058b7661-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677n/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determinations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon initiation of an investigation under this section, the Trade Representative shall request the following determinations be made according to substantive and procedural requirements specified by the Trade Representative, notwithstanding any other provision of this subtitle:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id058b7662-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677n/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The administering authority shall determine whether imports into the United States of the subject merchandise are being sold at less than fair value.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id058b7663-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677n/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commission shall determine whether an industry in the petitioning country is materially injured by reason of imports of the subject merchandise into the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id058b7664-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677n/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public comment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An opportunity for public comment shall be provided, as appropriate—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id058b7665-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677n/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the Trade Representative, in making the determination required by subsection (b), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id058b7666-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677n/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the administering authority and the Commission, in making the determination required by subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id058b7667-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677n/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance of order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the administering authority makes an affirmative determination under paragraph (1) of subsection (c), and the Commission makes an affirmative determination under paragraph (2) of subsection (c), the administering authority shall issue an antidumping duty order in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1673e"},"text":"section 1673e of this title","children":[],"tail":" and take such other actions as are required by "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1673e"},"text":"section 1673e of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id058b7668-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677n/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reviews of determinations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of review under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1516a"},"text":"section 1516a of this title","children":[],"tail":" or review under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1675"},"text":"section 1675 of this title","children":[],"tail":", if an order is issued under subsection (e), the final determinations of the administering authority and the Commission under this section shall be treated as final determinations made under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1673d"},"text":"section 1673d of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id058b7669-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677n/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1677f"},"text":"Section 1677f of this title","children":[],"tail":" shall apply to investigations under this section, to the extent specified by the Trade Representative, after consultation with the administering authority and the Commission."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id058b766a-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title VII, § 783, as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/tII/s232/a"},"text":"Pub. L. 103–465, title II, § 232(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4897"},"text":"108 Stat. 4897","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/295/s20/b/17"},"text":"Pub. L. 104–295, § 20(b)(17)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3528"},"text":"110 Stat. 3528","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id058b766b-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id058b766c-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id058b766d-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/295"},"text":"Pub. L. 104–295","children":[],"tail":" substituted “subsection (e)” for “subsection (d)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id058b766e-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id058b766f-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective, except as otherwise provided, on the date on which the WTO Agreement enters into force with respect to the United States (","children":[{"tag":"date","attrib":{"date":"1995-01-01"},"text":"Jan. 1, 1995","children":[],"tail":"), and applicable with respect to investigations, reviews, and inquiries initiated and petitions filed under specified provisions of this chapter after such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/s291"},"text":"section 291 of Pub. L. 103–465","children":[],"tail":", set out as an Effective Date of 1994 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1671"},"text":"section 1671 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
