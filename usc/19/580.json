{"tag":"section","attrib":{"id":"id0516959a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s580"},"text":null,"children":[{"tag":"num","attrib":{"value":"580"},"text":"§ 580.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest in suits on bonds for recovery of duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Upon all bonds, on which suits are brought for the recovery of duties, interest shall be allowed, at the rate of 6 per centum a year, from the time when said bonds became due.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0516959b-3a70-11f1-8ace-823fb135378d"},"text":"(R.S. § 963.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0516959c-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0516959d-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0516959e-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 963 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1799-03-02/ch22/s65"},"text":"act Mar. 2, 1799, ch. 22, § 65","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/1/676"},"text":"1 Stat. 676","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s787"},"text":"section 787 of Title 28","children":[],"tail":" prior to the general revision and enactment of Title 28, Judiciary and Judicial Procedure, by "},{"tag":"ref","attrib":{"href":"/us/act/1948-06