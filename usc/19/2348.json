{"tag":"section","attrib":{"id":"id05d0961f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2348"},"text":null,"children":[{"tag":"num","attrib":{"value":"2348"},"text":"§ 2348.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protective provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05d09620-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2348/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recordkeeping","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each recipient of adjustment assistance under this part shall keep records which fully disclose the amount and disposition by such recipient of the proceeds, if any, of such adjustment assistance, and which will facilitate an effective audit. The recipient shall also keep such other records as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05d09621-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2348/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audit and examination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary and the Comptroller General of the United States shall have access for the purpose of audit and examination to any books, documents, papers, and records of the recipient pertaining to adjustment assistance under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05d09622-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2348/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No adjustment assistance under this part shall be extended to any firm unless the owners, partners, or officers certify to the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05d09623-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2348/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the names of any attorneys, agents, and other persons engaged by or on behalf of the firm for the purpose of expediting applications for such adjustment assistance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05d09624-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2348/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fees paid or to be paid to any such person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05d09625-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2348/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conflicts of interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No financial assistance shall be provided to any firm under this part unless the owners, partners, or officers shall execute an agreement binding them and the firm for a period of 2 years after such financial assistance is provided, to refrain from employing, tendering any office or employment to, or retaining for professional services any person who, on the date such assistance or any part thereof was provided, or within 1 year prior thereto, shall have served as an officer, attorney, agent, or employee occupying a position or engaging in activities which the Secretary shall have determined involve discretion with respect to the provision of such financial assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05d09626-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/tII/s258"},"text":"Pub. L. 93–618, title II, § 258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2033"},"text":"88 Stat. 2033","children":[],"tail":"; temporarily renumbered § 256 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/5/dB/tI/s1864/a/2"},"text":"Pub. L. 111–5, div. B, title I, § 1864(a)(2)","children":[],"tail":", (c)(1), "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/397"},"text":"123 Stat. 397","children":[],"tail":", 398; "},{"tag":"ref","attrib":{"href":"/us/pl/112/40/tII/s201/b"},"text":"Pub. L. 112–40, title II, § 201(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2011-10-21"},"text":"Oct. 21, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/403"},"text":"125 Stat. 403","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/27/tIV/s402/b"},"text":"Pub. L. 114–27, title IV, § 402(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2015-06-29"},"text":"June 29, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/374"},"text":"129 Stat. 374","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05d09627-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id05d09628-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Assistance","children":[],"tail":null},{"tag":"p","attrib":