{"tag":"section","attrib":{"id":"id05890615-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677k"},"text":null,"children":[{"tag":"num","attrib":{"value":"1677k"},"text":"§ 1677k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Third-country dumping","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05890616-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677k/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05890617-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677k/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05890618-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677k/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Agreement” means the Agreement on Implementation of Article VI of the GATT 1994 (relating to antidumping measures).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05890619-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677k/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “GATT 1994” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3501/1/B"},"text":"section 3501(1)(B) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0589061a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677k/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Agreement country” means a foreign country that has accepted the Agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0589061b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677k/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Trade Representative” means the United States Trade Representative.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0589061c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677k/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Petition by domestic industry","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0589061d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677k/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A domestic industry that produces a product that is like or directly competitive with merchandise produced by a foreign country (whether or not an Agreement country) may, if it has reason to believe that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0589061e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677k/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such merchandise is being dumped in an Agreement country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0589061f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677k/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such domestic industry is being materially injured, or threatened with material injury, by reason of such dumping;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"submit a petition to the Trade Representative that alleges the elements referred to in subparagraphs (A) and (B) and requests the Trade Representative to take action under subsection (c) on behalf of the domestic industry.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05890620-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677k/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A petition submitted under paragraph (1) shall contain such detailed information as the Trade Representative may require in support of the allegations in the petition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05890621-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677k/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application for antidumping action on behalf of domestic industry","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05890622-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677k/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Trade Representative, on the basis of the information contained in a petition submitted under paragraph (1), determines that there is a reasonable basis for the allegations in the petition, the Trade Representative shall submit to the appropriate authority of the Agreement country where the alleged dumping is occurring an application pursuant to Article 12 of the Agreement which requests that appropriate antidumping action under the law of that country be taken, on behalf of the United States, with respect to imports into that country of the merchandise concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05890623-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677k/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At the request of the Trade Representative, the appropriate officers of the Department of Commerce and the United States International Trade Commission shall assist the Trade Representative in preparing the application under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05890624-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677k/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation after submission of application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After submitting an application under subsection (c)(1), the Trade Representative shall seek consultations with the appropriate authority of the Agreement country regarding the request for antidumping action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05890625-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1677k/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action upon refusal of Agreement country to act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the appropriate authority of an Agreement country refuses to undertake antidumping measures in response to a request made therefor by the Trade Representative under subsection (c), the Trade Representative shall promptly consult with the domestic industry on whether action under any other law of the United States is appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05890626-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/tI/s1317"},"text":"Pub. L. 100–418, title I, § 1317","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1188"},"text":"102 Stat. 1188","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/tVI/s621/a/1"},"text":"Pub. L. 103–465, title VI, § 621(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4992"},"text":"108 Stat. 4992","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05890627-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05890628-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id05890629-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Omnibus Trade and Competitiveness Act of 1988, and not as part of the Tariff Act of 1930 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0589062a-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465"},"text":"Pub. L. 103–465","children":[],"tail":" designated existing provisions as subpar. (A), substituted “GATT 1994” for “General Agreement on Tariffs and Trade”, and added subpar. (B)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0589062b-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0589062c-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/tVI/s621/b"},"text":"Pub. L. 103–465, title VI, § 621(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4993"},"text":"108 Stat. 4993","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/465/tVI/s621/b"},"text":"“The amendments made by this section [amending this section and sections 2171, 2411, 2702, 2905, 2906, 3107, 3111, and 3202 of this title] shall take effect on the date on which the WTO Agreement enters into force with respect to the United States (","children":[{"tag":"date","attrib":{"date":"1995-01-01"},"text":"Jan. 1, 1995","children":[],"tail":").”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
