{"tag":"section","attrib":{"id":"id05951361-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2013"},"text":null,"children":[{"tag":"num","attrib":{"value":"2013"},"text":"§ 2013.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date of proclamations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05951362-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2013/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retroactive effect; authority of President","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (b), the President is authorized, notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1514"},"text":"section 1514 of this title","children":[],"tail":" or any other provision of law, to give retroactive effect to any proclamation issued pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2011"},"text":"section 2011 of this title","children":[],"tail":" as of the earliest date after "},{"tag":"date","attrib":{"date":"1965-01-17"},"text":"January 17, 1965","children":[],"tail":", which he determines to be practicable."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05951363-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2013/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Filing of request with customs officer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of liquidated customs entries, the retroactive effect pursuant to subsection (a) of any proclamation shall apply only upon request therefor filed with the customs officer concerned on or before the 90th day after the date of such proclamation and subject to such other conditions as the President may specify.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05951364-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/283/tII/s203"},"text":"Pub. L. 89–283, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-10-21"},"text":"Oct. 21, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1018"},"text":"79 Stat. 1018","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
