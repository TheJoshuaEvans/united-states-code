{"tag":"section","attrib":{"id":"id05ef8fba-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2531"},"text":null,"children":[{"tag":"num","attrib":{"value":"2531"},"text":"§ 2531.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain standards-related activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05ef8fbb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2531/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No bar to engaging in standards activity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this subchapter may be construed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05ef8fbc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2531/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prohibit a Federal agency from engaging in activity related to standards-related measures, including any such measure relating to safety, the protection of human, animal, or plant life or health, the environment, or consumers; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05ef8fbd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2531/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to limit the authority of a Federal agency to determine the level it considers appropriate of safety or of protection of human, animal, or plant life or health, the environment, or consumers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05ef8fbe-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2531/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unnecessary obstacles","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter may be construed as prohibiting any private person, Federal agency, or State agency from engaging in standards-related activities that do not create unnecessary obstacles to the foreign commerce of the United States. No standards-related activity of any private person, Federal agency, or State agency shall be deemed to constitute an unnecessary obstacle to the foreign commerce of the United States if the demonstrable purpose of the standards-related activity is to achieve a legitimate domestic objective including, but not limited to, the protection of legitimate health or safety, essential security, environmental, or consumer interests and if such activity does not operate to exclude imported products which fully meet the objectives of such activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05ef8fbf-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39/tIV/s401"},"text":"Pub. L. 96–39, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/242"},"text":"93 Stat. 242","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/tIII/s351/b"},"text":"Pub. L. 103–465, title III, § 351(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4955"},"text":"108 Stat. 4955","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05ef8fc0-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05ef8fc1-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id05ef8fc2-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465"},"text":"Pub. L. 103–465","children":[],"tail":" added subsec. (a), designated existing provisions as subsec. (b), and inserted subsec. (b) heading."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id05ef8fc3-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id05ef8fc4-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/tIII/s352"},"text":"Pub. L. 103–465, title III, § 352","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4957"},"text":"108 Stat. 4957","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/465/tIII/s352"},"text":"“This subtitle [subtitle F (§§ 351, 352) of title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465"},"text":"Pub. L. 103–465","children":[],"tail":", amending this section and sections 2532, 2544, 2571, and 2573 of this title and repealing provisions set out below] and the amendments made by this subtitle take effect on the date on which the WTO Agreement enters into force with respect to the United States ["},{"tag":"date","attrib":{"date":"1995-01-01"},"text":"Jan. 1, 1995","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id05ef8fc5-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39/tIV/s454"},"text":"Pub. L. 96–39, title IV, § 454","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/250"},"text":"93 Stat. 250","children":[],"tail":", which provided that this subchapter was to take effect on "},{"tag":"date","attrib":{"date":"1980-01-01"},"text":"Jan. 1, 1980","children":[],"tail":", if the Agreement on Technical Barriers to Trade entered into force with respect to the United States by that date, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/tIII/s351/g"},"text":"Pub. L. 103–465, title III, § 351(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4957"},"text":"108 Stat. 4957","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
