{"tag":"section","attrib":{"id":"id0524ec85-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1313a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1313a"},"text":"§ 1313a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriations for refunds, drawbacks, bounties, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are appropriated such amounts as hereafter may be necessary for refund or payment of custom collections or receipts, and payment of debentures or drawbacks, bounties, and allowances, as authorized by law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0524ec86-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-06-30/ch286"},"text":"June 30, 1949, ch. 286","children":[],"tail":", title I, "},{"tag":"ref","attrib":{"href":"/us/stat/63/360"},"text":"63 Stat. 360","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0524ec87-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0524ec88-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0524ec89-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Tariff Act of 1930 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
