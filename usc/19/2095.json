{"tag":"section","attrib":{"id":"id059c18d8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2095"},"text":null,"children":[{"tag":"num","attrib":{"value":"2095"},"text":"§ 2095.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purposes of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id059c18d9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2095/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Secretary” means the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id059c18da-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2095/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “United States” includes the several States, the District of Columbia, and the Commonwealth of Puerto Rico.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id059c18db-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2095/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “pre-Columbian monumental or architectural sculpture or mural” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id059c18dc-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2095/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any stone carving or wall art which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id059c18dd-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2095/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is the product of a pre-Columbian Indian culture of Mexico, Central America, South America, or the Caribbean Islands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id059c18de-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2095/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was an immobile monument or architectural structure or was a part of, or affixed to, any such monument or structure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id059c18df-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2095/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is subject to export control by the country of origin; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id059c18e0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2095/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any fragment or part of any stone carving or wall art described in subparagraph (A) of this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id059c18e1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2095/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “country of origin”, as applied to any pre-Columbian monumental or architectural sculpture or mural, means the country where such sculpture or mural was first discovered.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id059c18e2-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/587/tII/s205"},"text":"Pub. L. 92–587, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-27"},"text":"Oct. 27, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1297"},"text":"86 Stat. 1297","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
