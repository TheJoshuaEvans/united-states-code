{"tag":"section","attrib":{"id":"id0653d11c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4515"},"text":null,"children":[{"tag":"num","attrib":{"value":"4515"},"text":"§ 4515.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of dispute settlement proceedings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id06561a0d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4515/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States Section of Secretariat","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id06561a0e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4515/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment or designation of office","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President is authorized to establish or designate within the Department of Commerce an office to serve as the United States Section of the Secretariat established under article 30.6 of the USMCA.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06561a0f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4515/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions and administrative assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The office established or designated under paragraph (1), subject to the oversight of the interagency group established under section 411(c)(2),","children":[{"tag":"ref","attrib":{"idref":"fn002176"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002176"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id06561a10-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4515/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out its functions within the Secretariat to facilitate the operation of the USMCA, including the operation of section D of chapter 10 and chapter 31 of the USMCA; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06561a11-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4515/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide administrative assistance to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id06561a12-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4515/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" panels established under chapter 31 of the USMCA, including under Annex 31–A (relating to the Facility-Specific Rapid Response Labor Mechanism);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id06561a13-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4515/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical advisers and experts provided for under chapter 31 of the USMCA;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id06561a14-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4515/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" binational panels and extraordinary challenge committees established under section D of chapter 10 of the USMCA; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id06561a15-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4515/a/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" binational panels and extraordinary challenge committees established under NAFTA for matters covered by article 34.1 of the USMCA (relating to transition from NAFTA).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06561a16-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4515/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of office under Freedom of Information Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The office established or designated under paragraph (1) shall not be considered an agency for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id06561a17-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4515/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated for each fiscal year after fiscal year 2020 to the Department of Commerce $2,000,000 for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id06561a18-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4515/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the operations of the office established or designated under subsection (a)(1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06561a19-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4515/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the payment of the United States share of the expenses of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id06561a1a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4515/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" panels established under chapter 31 of the USMCA, including under Annex 31–A (relating to the Facility-Specific Rapid Response Labor Mechanism);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06561a1b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4515/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" binational panels and extraordinary challenge committees established under section D of chapter 10 of the USMCA; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06561a1c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4515/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" binational panels and extraordinary challenge committees established under NAFTA for matters covered by article 34.1 of the USMCA (relating to transition from NAFTA).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id06561a1d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4515/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement of certain expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Canadian Section or the Mexican Section of the Secretariat provides funds to the United States Section during any fiscal year as reimbursement for expenses in connection with dispute settlement proceedings under section D of chapter 10 or chapter 31 of the USMCA, or under chapter 19 of NAFTA, the United States Section may, notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3302"},"text":"section 3302 of title 31","children":[],"tail":", retain and use such funds to carry out the functions described in subsection (a)(2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id06561a1e-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113/tI/s105"},"text":"Pub. L. 116–113, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-01-29"},"text":"Jan. 29, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/18"},"text":"134 Stat. 18","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id06561a1f-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id06561a20-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id06561a21-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 411(c)(2), referred to in subsec. (a)(2), means ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113/s411/c/2"},"text":"section 411(c)(2) of Pub. L. 116–113","children":[],"tail":", but probably should be a reference to section 412(c)(2) of that Act, which establishes an interagency group and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s4582/c/2"},"text":"section 4582(c)(2) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Freedom of Information Act, referred to in subsec. (a)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id06561a22-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id06561a23-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Proc. No. 10053, par. (8), ","children":[{"tag":"date","attrib":{"date":"2020-06-29"},"text":"June 29, 2020","children":[],"tail":", 85 F.R. 39826, authorized The Secretary of Commerce to exercise the authority of the President under subsec. (a) of this section to establish or designate an office within the Department of Commerce to carry out the functions set forth in that subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
