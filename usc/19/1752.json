{"tag":"section","attrib":{"id":"id059031b9-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1752"},"text":null,"children":[{"tag":"num","attrib":{"value":"1752"},"text":"§ 1752.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entry of articles for fairs","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Any article imported or brought into the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id059031ba-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1752/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is in continuous customs custody, covered by a customs exhibition bond, or in a foreign trade zone, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id059031bb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s1752/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on which no duty or internal-revenue tax has been paid,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"may, without payment of any duty or internal-revenue tax, be entered under bond under this section for the purpose of exhibition at a fair, or for use in constructing, installing, or maintaining foreign exhibits at a fair.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id059031bc-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/14/s3"},"text":"Pub. L. 86–14, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-04-22"},"text":"Apr. 22, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/18"},"text":"73 Stat. 18","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id059031bd-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"ta