{"tag":"section","attrib":{"id":"id064a3374-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4210"},"text":null,"children":[{"tag":"num","attrib":{"value":"4210"},"text":"§ 4210.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id064a3375-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4210/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreement on Agriculture","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Agreement on Agriculture” means the agreement referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3511/d/2"},"text":"section 3511(d)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064a3376-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4210/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreement on Safeguards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Agreement on Safeguards” means the agreement referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3511/d/13"},"text":"section 3511(d)(13) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064a3377-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4210/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreement on Subsidies and Countervailing Measures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Agreement on Subsidies and Countervailing Measures” means the agreement referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3511/d/12"},"text":"section 3511(d)(12) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064a3378-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4210/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Antidumping Agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Antidumping Agreement” means the Agreement on Implementation of Article VI of the General Agreement on Tariffs and Trade 1994 referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3511/d/7"},"text":"section 3511(d)(7) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064a3379-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4210/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appellate Body","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Appellate Body” means the Appellate Body established under Article 17.1 of the Dispute Settlement Understanding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064a337a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4210/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Common multilateral environmental agreement","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id064a337b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4210/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “common multilateral environmental agreement” means any agreement specified in subparagraph (B) or included under subparagraph (C) to which both the United States and one or more other parties to the negotiations are full parties, including any current or future mutually agreed upon protocols, amendments, annexes, or adjustments to such an agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id064a337c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4210/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements specified","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The agreements specified in this subparagraph are the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id064a337d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4210/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Convention on International Trade in Endangered Species of Wild Fauna and Flora, done at Washington ","children":[{"tag":"date","attrib":{"date":"1973-03-03"},"text":"March 3, 1973","children":[],"tail":" (27 UST 1087; TIAS 8249)."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id064a337e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4210/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Montreal Protocol on Substances that Deplete the Ozone Layer, done at Montreal ","children":[{"tag":"date","attrib":{"date":"1987-09-16"},"text":"September 16, 1987","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id064a337f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4210/6/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Protocol of 1978 Relating to the International Convention for the Prevention of Pollution from Ships, 1973, done at London ","children":[{"tag":"date","attrib":{"date":"1978-02-17"},"text":"February 17, 1978","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id064a3380-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4210/6/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Convention on Wetlands of International Importance Especially as Waterfowl Habitat, done at Ramsar ","children":[{"tag":"date","attrib":{"date":"1971-02-02"},"text":"February 2, 1971","children":[],"tail":" (TIAS 11084)."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id064a3381-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4210/6/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Convention on the Conservation of Antarctic Marine Living Resources, done at Canberra ","children":[{"tag":"date","attrib":{"date":"1980-05-20"},"text":"May 20, 1980","children":[],"tail":" (33 UST 3476)."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id064a3382-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4210/6/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The International Convention for the Regulation of Whaling, done at Washington ","children":[{"tag":"date","attrib":{"date":"1946-12-02"},"text":"December 2, 1946","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/62/1716"},"text":"62 Stat. 1716","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id064a3383-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4210/6/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Convention for the Establishment of an Inter-American Tropical Tuna Commission, done at Washington ","children":[{"tag":"date","attrib":{"date":"1949-05-31"},"text":"May 31, 1949","children":[],"tail":" (1 UST 230)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id064a3384-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4210/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Both the United States and one or more other parties to the negotiations may agree to include any other multilateral environmental or conservation agreement to which they are full parties as a common multilateral environmental agreement under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064a3385-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4210/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Core labor standards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “core labor standards” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id064a3386-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4210/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" freedom of association;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id064a3387-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4210/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effective recognition of the right to collective bargaining;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id064a3388-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4210/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the elimination of all forms of forced or compulsory labor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id064a3389-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4210/7/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effective abolition of child labor and a prohibition on the worst forms of child labor; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id064a338a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4210/7/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the elimination of discrimination in respect of employment and occupation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064a338b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4210/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dispute Settlement Understanding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Dispute Settlement Understanding” means the Understanding on Rules and Procedures Governing the Settlement of Disputes referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3511/d/16"},"text":"section 3511(d)(16) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064a338c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4210/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enabling Clause","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Enabling Clause” means the Decision on Differential and More Favourable Treatment, Reciprocity and Fuller Participation of Developing Countries (L/4903), adopted ","children":[{"tag":"date","attrib":{"date":"1979-11-28"},"text":"November 28, 1979","children":[],"tail":", under GATT 1947 (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3501"},"text":"section 3501 of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064a338d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4210/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “environmental laws”, with respect to the laws of the United States, means environmental statutes and regulations enforceable by action of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064a338e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4210/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" GATT 1994","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “GATT 1994” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3501"},"text":"section 3501 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064a338f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4210/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General Agreement on Trade in Services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “General Agreement on Trade in Services” means the General Agreement on Trade in Services (referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3511/d/14"},"text":"section 3511(d)(14) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064a3390-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4210/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Government Procurement Agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Government Procurement Agreement” means the Agreement on Government Procurement referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3511/d/17"},"text":"section 3511(d)(17) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064a3391-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4210/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ILO","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “ILO” means the International Labor Organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064a3392-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4210/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Import sensitive agricultural product","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “import sensitive agricultural product” means an agricultural product—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id064a3393-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4210/15/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to which, as a result of the Uruguay Round Agreements, the rate of duty was the subject of tariff reductions by the United States and, pursuant to such Agreements, was reduced on ","children":[{"tag":"date","attrib":{"date":"1995-01-01"},"text":"January 1, 1995","children":[],"tail":", to a rate that was not less than 97.5 percent of the rate of duty that applied to such article on "},{"tag":"date","attrib":{"date":"1994-12-31"},"text":"December 31, 1994","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id064a3394-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4210/15/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which was subject to a tariff rate quota on ","children":[{"tag":"date","attrib":{"date":"2015-06-29"},"text":"June 29, 2015","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064a3395-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4210/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information Technology Agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Information Technology Agreement” means the Ministerial Declaration on Trade in Information Technology Products of the World Trade Organization, agreed to at Singapore ","children":[{"tag":"date","attrib":{"date":"1996-12-13"},"text":"December 13, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064a3396-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4210/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Internationally recognized core labor standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “internationally recognized core labor standards” means the core labor standards only as stated in the ILO Declaration on Fundamental Principles and Rights at Work and its Follow-Up (1998).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064a3397-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4210/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Labor laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “labor laws” means the statutes and regulations, or provisions thereof, of a party to the negotiations that are directly related to core labor standards as well as other labor protections for children and minors and acceptable conditions of work with respect to minimum wages, hours of work, and occupational safety and health, and for the United States, includes Federal statutes and regulations addressing those standards, protections, or conditions, but does not include State or local labor laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064a3398-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4210/19"},"text":null,"children":[{"tag":"num","attrib":{"value":"19"},"text":"(19)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States person","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “United States person” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id064a3399-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4210/19/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a United States citizen;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id064a339a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4210/19/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a partnership, corporation, or other legal entity that is organized under the laws of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id064a339b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4210/19/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a partnership, corporation, or other legal entity that is organized under the laws of a foreign country and is controlled by entities described in subparagraph (B) or United States citizens, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064a339c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4210/20"},"text":null,"children":[{"tag":"num","attrib":{"value":"20"},"text":"(20)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uruguay Round Agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Uruguay Round Agreements” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3501/7"},"text":"section 3501(7) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064a339d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4210/21"},"text":null,"children":[{"tag":"num","attrib":{"value":"21"},"text":"(21)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" World Trade Organization; WTO","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “World Trade Organization” and “WTO” mean the organization established pursuant to the WTO Agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064a339e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4210/22"},"text":null,"children":[{"tag":"num","attrib":{"value":"22"},"text":"(22)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" WTO Agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “WTO Agreement” means the Agreement Establishing the World Trade Organization entered into on ","children":[{"tag":"date","attrib":{"date":"1994-04-15"},"text":"April 15, 1994","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064a339f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4210/23"},"text":null,"children":[{"tag":"num","attrib":{"