{"tag":"section","attrib":{"id":"id060513ca-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3008"},"text":null,"children":[{"tag":"num","attrib":{"value":"3008"},"text":"§ 3008.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Import and export statistics","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce shall compile, and make publicly available, the import and export trade statistics of the United States. Such statistics shall be conformed to the nomenclature of the Convention.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id060513cb-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/tI/s1208"},"text":"Pub. L. 100–418, title I, § 1208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1152"},"text":"102 Stat. 1152","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
