{"tag":"section","attrib":{"id":"id05d306d1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2372"},"text":null,"children":[{"tag":"num","attrib":{"value":"2372"},"text":"§ 2372.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05d306d2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2372/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary of Labor $40,000,000 for each of the fiscal years 2009 and 2010, and $10,000,000 for the period beginning ","children":[{"tag":"date","attrib":{"date":"2010-10-01"},"text":"October 1, 2010","children":[],"tail":", and ending "},{"tag":"date","attrib":{"date":"2010-12-31"},"text":"December 31, 2010","children":[],"tail":", to fund the Community College and Career Training Grant Program. Funds appropriated pursuant to this section shall remain available until expended."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05d306d3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2372/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional funds; minimum allocation to States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are appropriated $500,000,000 for each of fiscal years 2011, 2012, 2013, and 2014 to carry out this subpart,","children":[{"tag":"ref","attrib":{"idref":"fn002108"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002108"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" except that the limitations contained in "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2371/a/2"},"text":"section 2371(a)(2) of this title","children":[],"tail":" shall not apply to such funds and each State shall receive not less than 0.5 percent of the amount appropriated pursuant to this subsection for each such fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05d306d4-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618/tII/s272"},"text":"Pub. L. 93–618, title II, § 272","children":[],"tail":", formerly § 279, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/5/dB/tI/s1872/a"},"text":"Pub. L. 111–5, div. B, title I, § 1872(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/409"},"text":"123 Stat. 409","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/152/tI/s1501"},"text":"Pub. L. 111–152, title I, § 1501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-30"},"text":"Mar. 30, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1070"},"text":"124 Stat. 1070","children":[],"tail":"; as added, renumbered § 272, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/40/tII"},"text":"Pub. L. 112–40, title II","children":[],"tail":", §§ 201(b), (c), 222(a)(3), (c)(2), "},{"tag":"date","attrib":{"date":"2011-10-21"},"text":"Oct. 21, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/403"},"text":"125 Stat. 403","children":[],"tail":", 411, 412.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05d306d5-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05d306d6-3a70-11f1-8ace-82