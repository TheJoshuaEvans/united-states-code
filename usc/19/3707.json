{"tag":"section","attrib":{"id":"id0615b58b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3707"},"text":null,"children":[{"tag":"num","attrib":{"value":"3707"},"text":"§ 3707.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities in support of transparency","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0615b58c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3707/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" AGOA Website","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0615b58d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3707/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall establish a publicly available website for the collection and dissemination of information regarding the African Growth and Opportunity Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3701"},"text":"19 U.S.C. 3701","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0615b58e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3707/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President shall publish on the AGOA Website the information described in paragraph (1), including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0615b58f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3707/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information and technical assistance provided at United States Agency for International Development regional trade hubs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0615b590-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3707/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a link to the websites of United States embassies located in eligible sub-Saharan African countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0615b591-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3707/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions by United States embassies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of State should direct United States embassies located in eligible sub-Saharan African countries to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0615b592-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3707/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage individuals and businesses in such countries to use the benefits available under the African Growth and Opportunity Act; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0615b593-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3707/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a link to the AGOA Website on the websites of such diplomatic missions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id06182694-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3707/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" AGOA Forum","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"After each meeting of the United States–Sub-Saharan Africa Trade and Economic Cooperation Forum, the President should publish on the AGOA Website the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id06182695-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3707/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The outcomes of the meeting of the Forum, including any commitments made by member countries and the private sector.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06182696-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3707/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment of progress made with respect to any commitments made by member countries and the private sector from the previous meeting of the Forum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id06182697-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3707/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President should disseminate the information required under this section in a digital format to the public and publish such information on the AGOA Website.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id06182698-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/167/tI/s103"},"text":"Pub. L. 115–167, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-04-23"},"text":"Apr. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1277"},"text":"132 Stat. 1277","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id06182699-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0618269a-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0618269b-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The African Growth and Opportunity Act, referred to in subsec. (a)(1), (3)(A), is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/200"},"text":"Pub. L. 106–200","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-05-18"},"text":"May 18, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/252"},"text":"114 Stat. 252","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3701"},"text":"section 3701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0618269c-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the African Growth and Opportunity Act and Millennium Challenge Act Modernization Act, also known as the AGOA and MCA Modernization Act, and not as part of the African Growth and Opportunity Act which enacted this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0618269d-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id0618269e-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/167/tI/s102"},"text":"Pub. L. 115–167, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-04-23"},"text":"Apr. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1277"},"text":"132 Stat. 1277","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/167/tI/s102"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“In this title [enacting this section and provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3701"},"text":"section 3701 of this title","children":[],"tail":"]—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agoa website","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘AGOA Website’ means the website established pursuant to section 103(a) [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3707/a"},"text":"19 U.S.C. 3707(a)","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible sub-saharan african country","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘eligible sub-Saharan African country’ means a country that the President has determined meets the eligibility requirements set forth in section 104 of the African Growth and Opportunity Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3703"},"text":"19 U.S.C. 3703","children":[],"tail":").”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
