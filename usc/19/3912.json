{"tag":"section","attrib":{"id":"id063e4c45-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3912"},"text":null,"children":[{"tag":"num","attrib":{"value":"3912"},"text":"§ 3912.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" GAO report","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Not later than 24 months after the effective date of this chapter, the Comptroller General of the United States shall transmit a report to the Congress on the effectiveness of the provisions of this chapter in preventing the importation or exportation of rough diamonds that is prohibited under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3903"},"text":"section 3903 of this title","children":[],"tail":". The Comptroller General shall include in the report any recommendations on any modifications to this chapter that may be necessary."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id063e4c46-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/19/s13"},"text":"Pub. L. 108–19, § 13","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-04-25"},"text":"Apr. 25, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/636"},"text":"117 Stat. 636","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id063e4c47-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id063e4c48-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id063e4c49-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":