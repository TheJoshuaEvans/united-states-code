{"tag":"section","attrib":{"id":"id05f20102-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2578b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2578b"},"text":"§ 2578b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id05f20103-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2578b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this part:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id05f20104-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2578b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “agency” means a Federal department or agency (or combination of Federal departments or agencies).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f20105-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2578b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commissioner","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Commissioner” means the Commissioner of Food and Drugs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f20106-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2578b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International standard-setting organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “international standard-setting organization” means an organization consisting of representatives of 2 or more countries, the purpose of which is to negotiate, develop, promulgate, or amend an international standard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f20107-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2578b/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sanitary or phytosanitary standard","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “sanitary or phytosanitary standard” means a standard intended to form a basis for a sanitary or phytosanitary measure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id05f20108-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2578b/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International standard","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “international standard” means a standard, guideline, or recommendation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id05f20109-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2578b/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regarding food safety, adopted by the Codex Alimentarius Commission, including a standard, guideline, or recommendation regarding decomposition elaborated by the Codex Committee on Fish and Fishery Products, food additives, contaminants, hygienic practice, and methods of analysis and sampling;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05f2010a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2578b/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regarding animal health and zoonoses, developed under the auspices of the International Office of Epizootics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05f2010b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2578b/a/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regarding plant health, developed under the auspices of the Secretariat of the International Plant Protection Convention in cooperation with the North American Plant Protection Organization; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id05f2010c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2578b/a/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" established by or developed under any other international organization agreed to by the USMCA countries (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4502"},"text":"section 4502 of this title","children":[],"tail":") or by the WTO members (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3501/10"},"text":"section 3501(10) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id05f2010d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s2578b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The definitions set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2575b"},"text":"section 2575b of this title","children":[],"tail":" apply for purposes of this part except that in applying paragraph (7) of "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2575b"},"text":"section 2575b of this title","children":[],"tail":" with respect to a sanitary or phytosanitary measure of a foreign country, any reference in such paragraph to the United States shall be deemed to be a reference to that foreign country."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id05f2010e-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39/tIV/s493"},"text":"Pub. L. 96–39, title IV, § 493","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/tIV/s432"},"text":"Pub. L. 103–465, title IV, § 432","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4972"},"text":"108 Stat. 4972","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dO/tVI/s602/f"},"text":"Pub. L. 116–260, div. O, title VI, § 602(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2154"},"text":"134 Stat. 2154","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id05f2010f-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id05f20110-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id05f20111-3a70-11f1-8ac