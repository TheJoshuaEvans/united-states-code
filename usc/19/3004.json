{"tag":"section","attrib":{"id":"id06051372-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3004"},"text":null,"children":[{"tag":"num","attrib":{"value":"3004"},"text":"§ 3004.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enactment of Harmonized Tariff Schedule","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id06051373-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3004/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id06051374-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3004/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modifications to Harmonized Tariff Schedule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"At the earliest practicable date after ","children":[{"tag":"date","attrib":{"date":"1988-08-23"},"text":"August 23, 1988","children":[],"tail":", the President shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id06051375-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3004/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" proclaim such modifications to the Harmonized Tariff Schedule as are consistent with the standards applied in converting the old Schedules into the format of the Convention, as reflected in such Publication No. 2030 and Supplement No. 1.","children":[{"tag":"ref","attrib":{"idref":"fn002150"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002150"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" thereto, and as are necessary or appropriate to implement—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id06051376-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3004/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the future outstanding staged rate reductions authorized by the Congress in—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id06051377-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3004/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Trade Act of 1974 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2101"},"text":"19 U.S.C. 2101","children":[],"tail":" et seq.) and the Trade Agreements Act of 1979 ("},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2501"},"text":"19 U.S.C. 2501","children":[],"tail":" et seq.) to reflect the tariff reductions that resulted from the Tokyo Round of multilateral trade negotiations, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id06051378-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3004/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States-Israel Free Trade Area Implementation Act of 1985 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2112"},"text":"19 U.S.C. 2112","children":[],"tail":" note] to reflect the tariff reduction resulting from the United States-Israel Free Trade Area Agreement,"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06051379-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3004/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the applicable provisions of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0605137a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3004/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" statutes enacted,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0605137b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3004/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" executive actions taken, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0605137c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3004/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" final judicial decisions rendered,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"after ","children":[{"tag":"date","attrib":{"date":"1988-01-01"},"text":"January 1, 1988","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"1989-01-01"},"text":"January 1, 1989","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0605137d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3004/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such technical rectifications as the President considers necessary; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0605137e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3004/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take such action as the President considers necessary to bring trade agreements to which the United States is a party into conformity with the Harmonized Tariff Schedule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0605137f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3004/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status of Harmonized Tariff Schedule","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id06051380-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3004/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The following shall be considered to be statutory provisions of law for all purposes:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id06051381-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3004/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of the Harmonized Tariff Schedule as enacted by this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06051382-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3004/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each statutory amendment to the Harmonized Tariff Schedule.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06051383-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3004/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each modification or change made to the Harmonized Tariff Schedule by the President under authority of law (including section 604 of the Trade Act of 1974 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2483"},"text":"19 U.S.C. 2483","children":[],"tail":"])."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06051384-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3004/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Neither the enactment of this chapter nor the subsequent enactment of any amendment to the Harmonized Tariff Schedule, unless such subsequent enactment otherwise provides, may be construed as limiting the authority of the President—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id06051385-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3004/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to effect the import treatment necessary or appropriate to carry out, modify, withdraw, suspend, or terminate, in whole or in part, trade agreements; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id06051386-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3004/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to take such other actions through the modification, continuance, or imposition of any rate of duty or other import restriction as may be necessary or appropriate under the authority of the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06051387-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3004/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a rate of duty established in column 1 by the President by proclamation or Executive order is higher than the existing rate of duty in column 2, the President may by proclamation or Executive order increase such existing rate to the higher rate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id06051388-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3004/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a rate of duty is suspended or terminated by the President by proclamation or Executive order and the proclamation or Executive order does not specify the rate that is to apply in lieu of the suspended or terminated rate, the last rate of duty that applied prior to the suspended or terminated rate shall be the efffective ","children":[{"tag":"ref","attrib":{"idref":"fn002151"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002151"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “effective”."}],"tail":" rate of duty."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id06051389-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3004/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interim informational use of Harmonized Tariff Schedule classifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0605138a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3004/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proclamation issued by the President;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0605138b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3004/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public notice issued by the Commission or other Federal agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0605138c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3004/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" finding, determination, order, recommendation, or other decision made by the Commission or other Federal agency;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"during the period between ","children":[{"tag":"date","attrib":{"date":"1988-08-23"},"text":"August 23, 1988","children":[],"tail":", and "},{"tag":"date","attrib":{"date":"1989-01-01"},"text":"January 1, 1989","children":[],"tail":", shall, if the proclamation, notice, or decision contains a reference to the tariff classification of any article, include, for informational purposes, a reference to the classification of that article under the Harmonized Tariff Schedule."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0605138d-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/tI/s1204"},"text":"Pub. L. 100–418, title I, § 1204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1148"},"text":"102 Stat. 1148","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0605138e-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0605138f-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id06051390-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Harmonized Tariff Schedule, referred to in text, is not set out in the Code. See Publication of Harmonized Tariff Schedule note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1202"},"text":"section 1202 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Trade Act of 1974, referred to in subsec. (b)(1)(A)(i), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618"},"text":"Pub. L. 93–618","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1978"},"text":"88 Stat. 1978","children":[],"tail":", which is classified principally to chapter 12 (§ 2101 et seq.) of this title. For complete classification of this Act to the Code, see References in Text note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2101"},"text":"section 2101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Trade Agreements Act of 1979, referred to in subsec. (b)(1)(A)(i), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39"},"text":"Pub. L. 96–39","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/144"},"text":"93 Stat. 144","children":[],"tail":". For complete classification of this Act to the Code, see References in Text note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2501"},"text":"section 2501 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The United States-Israel Free Trade Area Implementation Act of 1985, referred to in subsec. (b)(1)(A)(ii), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/47"},"text":"Pub. L. 99–47","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-06-11"},"text":"June 11, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/82"},"text":"99 Stat. 82","children":[],"tail":", which amended sections 2112, 2462 to 2464, and 2518 of this title, and enacted and amended provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2112"},"text":"section 2112 of this title","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2112"},"text":"section 2112 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (c)(1)(A), (2), was in the original “this subtitle”, meaning subtitle B (§§ 1201 to 1217) of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418"},"text":"Pub. L. 100–418","children":[],"tail":", which is classified principally to this chapter. For complete classification of this subtitle to the Code, see References in Text note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3001"},"text":"section 3001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id06051391-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/s1204"},"text":"section 1204 of Pub. L. 100–418","children":[],"tail":". Subsec. (a) of "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/s1204"},"text":"section 1204 of Pub. L. 100–418","children":[],"tail":" amended title I of the Tariff Act of 1930, "},{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497/tI"},"text":"act June