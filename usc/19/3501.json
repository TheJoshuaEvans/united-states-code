{"tag":"section","attrib":{"id":"id060c3f85-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3501"},"text":null,"children":[{"tag":"num","attrib":{"value":"3501"},"text":"§ 3501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this Act:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id060c3f86-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3501/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" GATT 1947; GATT 1994","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id060c3f87-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3501/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" GATT 1947","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “GATT 1947” means the General Agreement on Tariffs and Trade, dated ","children":[{"tag":"date","attrib":{"date":"1947-10-30"},"text":"October 30, 1947","children":[],"tail":", annexed to the Final Act Adopted at the Conclusion of the Second Session of the Preparatory Committee of the United Nations Conference on Trade and Employment, as subsequently rectified, amended, or modified by the terms of legal instruments which have entered into force before the date of entry into force of the WTO Agreement."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id060c3f88-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3501/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" GATT 1994","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “GATT 1994” means the General Agreement on Tariffs and Trade annexed to the WTO Agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060c3f89-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3501/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" HTS","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “HTS” means the Harmonized Tariff Schedule of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060c3f8a-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3501/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International Trade Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “International Trade Commission” means the United States International Trade Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060c3f8b-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3501/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multilateral trade agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “multilateral trade agreement” means an agreement described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3511/d"},"text":"section 3511(d) of this title","children":[],"tail":" (other than an agreement described in paragraph (17) or (18) of such section)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060c3f8c-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3501/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Schedule XX","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Schedule XX” means Schedule XX—United States of America annexed to the Marrakesh Protocol to the GATT 1994.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060c3f8d-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3501/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trade Representative","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Trade Representative” means the United States Trade Representative.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060c3f8e-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3501/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uruguay Round Agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Uruguay Round Agreements” means the agreements approved by the Congress under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3511/a/1"},"text":"section 3511(a)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060c3f8f-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3501/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" World Trade Organization and WTO","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “World Trade Organization” and “WTO” mean the organization established pursuant to the WTO Agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060c3f90-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3501/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" WTO Agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “WTO Agreement” means the Agreement Establishing the World Trade Organization entered into on ","children":[{"tag":"date","attrib":{"date":"1994-04-15"},"text":"April 15, 1994","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id060c3f91-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s3501/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" WTO member and WTO member country","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “WTO member” and “WTO member country” mean a state, or separate customs territory (within the meaning of Article XII of the WTO Agreement), with respect to which the United States applies the WTO Agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id060c3f92-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/s2"},"text":"Pub. L. 103–465, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4813"},"text":"108 Stat. 4813","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id060c3f93-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id060c3f94-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id060c3f95-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465"},"text":"Pub. L. 103–465","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4809"},"text":"108 Stat. 4809","children":[],"tail":", known as the Uruguay Round Agreements Act. For complete classification of this Act to the Code, see Short Title note set out below and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Harmonized Tariff Schedule of the United States, referred to in par. (2), is not set out in the Code. See Publication of Harmonized Tariff Schedule note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1202"},"text":"section 1202 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id060c3f96-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id060c3f97-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","at