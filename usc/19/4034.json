{"tag":"section","attrib":{"id":"id064306eb-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4034"},"text":null,"children":[{"tag":"num","attrib":{"value":"4034"},"text":"§ 4034.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retroactive application for certain liquidations and reliquidations of textile or apparel goods","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id064306ec-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4034/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1514"},"text":"section 1514 of this title","children":[],"tail":" or any other provision of law, and subject to subsection (c), an entry—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id064306ed-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4034/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" of a textile or apparel good—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id064306ee-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4034/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of a CAFTA–DR country that the United States Trade Representative has designated as an eligible country under subsection (b), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id064306ef-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4034/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that would have qualified as an originating good under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4033"},"text":"section 4033 of this title","children":[],"tail":" if the good had been entered after the date of entry into force of the Agreement for that country,"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064306f0-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4034/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that was made on or after ","children":[{"tag":"date","attrib":{"date":"2004-01-01"},"text":"January 1, 2004","children":[],"tail":", and before the date of the entry into force of the Agreement with respect to that country or any other CAFTA–DR country, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064306f1-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4034/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which customs duties in excess of the applicable rate of duty for that good set out in the Schedule of the United States to Annex 3.3 of the Agreement were paid,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be liquidated or reliquidated at the applicable rate of duty for that good set out in the Schedule of the United States to Annex 3.3 of the Agreement, and the Secretary of the Treasury shall refund any excess customs duties paid with respect to such entry.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id064306f2-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4034/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible country","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States Trade Representative shall determine, in accordance with article 3.20 of the Agreement, which CAFTA–DR countries are eligible countries for purposes of this section, and shall publish a list of all such countries in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id064306f3-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4034/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requests","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Liquidation or reliquidation may be made under subsection (a) with respect to an entry of a textile or apparel good only if a request therefor is filed with the Bureau of Customs and Border Protection, within such period as the Bureau of Customs and Border Protection shall establish by regulation in consultation with the Secretary of the Treasury, that contains sufficient information to enable the Bureau of Customs and Border Protection—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id064306f4-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4034/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id064306f5-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4034/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to locate the entry; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id064306f6-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4034/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reconstruct the entry if it cannot be located; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id064306f7-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4034/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to determine that the good satisfies the conditions set out in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id064306f8-3a70-11f1-8ace-823fb135378d","identifier":"/us/usc/t19/s4034/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As used in this section, the term “entry” includes a withdrawal from warehouse for consumption.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id064306f9-3a70-11f1-8ace-823fb135378d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/53/tII/s205"},"text":"Pub. L. 109–53, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-02"},"text":"Aug. 2, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/483"},"text":"119 Stat. 483","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/280/tXIV/s1634/d"},"text":"Pub. L. 109–280, title XIV, § 1634(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1168"},"text":"120 Stat. 1168","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id064306fa-3a70-11f1-8ace-823fb135378d"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id064306fb-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination of section by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/53/s107/d"},"text":"section 107(d) of Pub. L. 109–53","children":[],"tail":", see Effective and Termination Dates note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id064306fc-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id064306fd-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280"},"text":"Pub. L. 109–280","children":[],"tail":" inserted “or any other CAFTA–DR country” after “that country”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id064306fe-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id064306ff-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280"},"text":"Pub. L. 109–280","children":[],"tail":" applicable with respect to goods entered, or withdrawn from warehouse for consumption, on or after the 15th day after "},{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/280/s1641"},"text":"section 1641 of Pub. L. 109–280","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s58c"},"text":"section 58c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id06430700-3a70-11f1-8ace-823fb135378d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective and Termination Dates","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date the Dominican Republic-Central America-United States Free Trade Agreement enters into force (","children":[{"tag":"date","attrib":{"date":"2006-03-01"},"text":"Mar. 1, 2006","children":[],"tail":") and to cease to have effect on the date the Agreement ceases to be in force with respect to the United States, and, during any period in which a country ceases to be a CAFTA–DR country, to cease to have effect with respect to such country, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/53/s107"},"text":"section 107 of Pub. L. 109–53","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s4001"},"text":"section 4001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
