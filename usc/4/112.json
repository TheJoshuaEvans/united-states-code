{"tag":"section","attrib":{"id":"id128bd9d2-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s112"},"text":null,"children":[{"tag":"num","attrib":{"value":"112"},"text":"§ 112.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compacts between States for cooperation in prevention of crime; consent of Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id128bd9d3-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s112/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The consent of Congress is hereby given to any two or more States to enter into agreements or compacts for cooperative effort and mutual assistance in the prevention of crime and in the enforcement of their respective criminal laws and policies, and to establish such agencies, joint or otherwise, as they may deem desirable for making effective such agreements and compacts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id128e22c4-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s112/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of this section, the term “States” means the several States and Alaska, Hawaii, the Commonwealth of Puerto Rico, the Virgin Islands, Guam, and the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id128e22c5-f87d-11ef-b94d-97e317d2120c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-05-24/ch139/s129/b"},"text":"May 24, 1949, ch. 139, § 129(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/107"},"text":"63 Stat. 107","children":[],"tail":", § 112, formerly § 111; amended "},{"tag":"ref","attrib":{"href":"/us/act/1956-08-03/ch941"},"text":"Aug. 3, 1956, ch. 941","children":[],"tail":", "},{"tag":"ref",