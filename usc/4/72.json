{"tag":"section","attrib":{"id":"id128bd985-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s72"},"text":null,"children":[{"tag":"num","attrib":{"value":"72"},"text":"§ 72.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public offices; at seat of Government","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All offices attached to the seat of government shall be exercised in the District of Columbia, and not elsewhere, except as otherwise expressly provided by law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id128bd986-f87d-11ef-b94d-97e317d2120c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-30/ch389"},"text":"July 30, 1947, ch. 389","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/643"},"text":"61 Stat. 643","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
