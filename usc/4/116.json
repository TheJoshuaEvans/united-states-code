{"tag":"section","attrib":{"id":"id128e22fa-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s116"},"text":null,"children":[{"tag":"num","attrib":{"value":"116"},"text":"§ 116.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules for determining State and local government treatment of charges related to mobile telecommunications services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id128e22fb-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s116/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application of This Section Through Section ","children":[],"tail":"126.—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section through ","children":[{"tag":"ref","attrib":{"idref":"fn002007"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002007"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by “section”."}],"tail":" 126 of this title apply to any tax, charge, or fee levied by a taxing jurisdiction as a fixed charge for each customer or measured by gross amounts charged to customers for mobile telecommunications services, regardless of whether such tax, charge, or fee is imposed on the vendor or customer of the service and regardless of the terminology used to describe the tax, charge, or fee."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id128e22fc-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s116/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section through ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" 126 of this title do not apply to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id128e22fd-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s116/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any tax, charge, or fee levied upon or measured by the net income, capital stock, net worth, or property value of the provider of mobile telecommunications service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id128e22fe-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s116/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any tax, charge, or fee that is applied to an equitably apportioned amount that is not determined on a transactional basis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id128e22ff-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s116/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any tax, charge, or fee that represents compensation for a mobile telecommunications service provider’s use of public rights of way or other public property, provided that such tax, charge, or fee is not levied by the taxing jurisdiction as a fixed charge for each customer or measured by gross amounts charged to customers for mobile telecommunication services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id128e2300-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s116/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any generally applicable business and occupation tax that is imposed by a State, is applied to gross receipts or gross proceeds, is the legal liability of the home service provider, and that statutorily allows the home service provider to elect to use the sourcing method required in this section through ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" 126 of this title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id128e2301-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s116/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any fee related to obligations under section 254 of the Communications Act of 1934; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id128e2302-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s116/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any tax, charge, or fee imposed by the Federal Communications Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id128e2303-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s116/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Specific Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section through ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" 126 of this title—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id128e2304-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s116/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" do not apply to the determination of the taxing situs of prepaid telephone calling services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id128e2305-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s116/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" do not affect the taxability of either the initial sale of mobile telecommunications services or subsequent resale of such services, whether as sales of such services alone or as a part of a bundled product, if the Internet Tax Freedom Act would preclude a taxing jurisdiction from subjecting the charges of the sale of such services to a tax, charge, or fee, but this section provides no evidence of the intent of Congress with respect to the applicability of the Internet Tax Freedom Act to such charges; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id128e2306-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s116/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" do not apply to the determination of the taxing situs of air-ground radiotelephone service as defined in section 22.99 of title 47 of the Code of Federal Regulations as in effect on ","children":[{"tag":"date","attrib":{"date":"1999-06-01"},"text":"June 1, 1999","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id128e2307-f87d-11ef-b94d-97e317d2120c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/252/s2/a"},"text":"Pub. L. 106–252, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-07-28"},"text":"July 28, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/626"},"text":"114 Stat. 626","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id128e2308-f87d-11ef-b94d-97e317d2120c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id128e2309-f87d-11ef-b94d-97e317d2120c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id128e230a-f87d-11ef-b94d-97e317d2120c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 254 of the Communications Act of 1934, referred to in subsec. (b)(5), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s254"},"text":"section 254 of Title 47","children":[],"tail":", Telecommunications."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Internet Tax Freedom Act, referred to in subsec. (c)(2), is title XI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dC"},"text":"Pub. L. 105–277, div. C","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-719"},"text":"112 Stat. 2681–719","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s151"},"text":"section 151 of Title 47","children":[],"tail":", Telecommunications."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id128e230b-f87d-11ef-b94d-97e317d2120c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id128e230c-f87d-11ef-b94d-97e317d2120c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date; Application of Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/252/s3"},"text":"Pub. L. 106–252, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-07-28"},"text":"July 28, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/633"},"text":"114 Stat. 633","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/252/s3"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (b), this Act [enacting this section and sections 117 to 126 of this title and provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t4/s1"},"text":"section 1 of this title","children":[],"tail":"] and the amendment made by this Act shall take effect on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2000-07-28"},"text":"July 28, 2000","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application of Act","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendment made by this Act [enacting this section and sections 117 to 126 of this title] shall apply only to customer bills issued after the first day of the first month beginning more than 2 years after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2000-07-28"},"text":"July 28, 2000","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
