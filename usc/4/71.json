{"tag":"section","attrib":{"id":"id12896883-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s71"},"text":null,"children":[{"tag":"num","attrib":{"value":"71"},"text":"§ 71.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permanent seat of Government","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All that part of the territory of the United States included within the present limits of the District of Columbia shall be the permanent seat of government of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id12896884-f87d-11ef-b94d-97e317d2120c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-30/ch389"},"text":"July 30, 1947, ch. 389","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/643"},"text":"61 Stat. 643","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
