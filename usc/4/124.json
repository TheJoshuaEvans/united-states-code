{"tag":"section","attrib":{"id":"id12909455-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s124"},"text":null,"children":[{"tag":"num","attrib":{"value":"124"},"text":"§ 124.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In sections 116 through 126 of this title:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id12909456-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s124/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Charges for mobile telecommunications services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “charges for mobile telecommunications services” means any charge for, or associated with, the provision of commercial mobile radio service, as defined in section 20.3 of title 47 of the Code of Federal Regulations as in effect on ","children":[{"tag":"date","attrib":{"date":"1999-06-01"},"text":"June 1, 1999","children":[],"tail":", or any charge for, or associated with, a service provided as an adjunct to a commercial mobile radio service, that is billed to the customer by or for the customer’s home service provider regardless of whether individual transmissions originate or terminate within the licensed service area of the home service provider."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id12909457-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s124/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Customer.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id12909458-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s124/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “customer” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id12909459-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s124/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person or entity that contracts with the home service provider for mobile telecommunications services; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1290945a-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s124/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the end user of mobile telecommunications services is not the contracting party, the end user of the mobile telecommunications service, but this clause applies only for the purpose of determining the place of primary use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1290945b-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s124/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “customer” does not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id1290945c-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s124/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a reseller of mobile telecommunications service; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1290945d-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s124/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a serving carrier under an arrangement to serve the customer outside the home service provider’s licensed service area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1290945e-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s124/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designated database provider","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “designated database provider” means a corporation, association, or other entity representing all the political subdivisions of a State that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1290945f-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s124/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" responsible for providing an electronic database prescribed in section 119(a) if the State has not provided such electronic database; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id12909460-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s124/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approved by municipal and county associations or leagues of the State whose responsibility it would otherwise be to provide such database prescribed by sections 116 through 126 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id12909461-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s124/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Enhanced zip code","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “enhanced zip code” means a United States postal zip code of 9 or more digits.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id12909462-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s124/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Home service provider","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “home service provider” means the facilities-based carrier or reseller with which the customer contracts for the provision of mobile telecommunications services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id12909463-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s124/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Licensed service area","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “licensed service area” means the geographic area in which the home service provider is authorized by law or contract to provide commercial mobile radio service to the customer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id12909464-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s124/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Mobile telecommunications service","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “mobile telecommunications service” means commercial mobile radio service, as defined in section 20.3 of title 47 of the Code of Federal Regulations as in effect on ","children":[{"tag":"date","attrib":{"date":"1999-06-01"},"text":"June 1, 1999","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id12909465-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s124/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Place of primary use","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “place of primary use” means the street address representative of where the customer’s use of the mobile telecommunications service primarily occurs, which must be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id12909466-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s124/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the residential street address or the primary business street address of the customer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id12909467-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s124/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within the licensed service area of the home service provider.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id12909468-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s124/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prepaid telephone calling services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “prepaid telephone calling service” means the right to purchase exclusively telecommunications services that must be paid for in advance, that enables the origination of calls using an access number, authorization code, or both, whether manually or electronically dialed, if the remaining amount of units of service that have been prepaid is known by the provider of the prepaid service on a continuous basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id12909469-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s124/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reseller","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “reseller”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1290946a-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s124/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means a provider who purchases telecommunications services from another telecommunications service provider and then resells, uses as a component part of, or integrates the purchased services into a mobile telecommunications service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1290946b-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s124/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include a serving carrier with which a home service provider arranges for the services to its customers outside the home service provider’s licensed service area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1290946c-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s124/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Serving carrier","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “serving carrier” means a facilities-based carrier providing mobile telecommunications service to a customer outside a home service provider’s or reseller’s licensed service area.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1290946d-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s124/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Taxing jurisdiction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “taxing jurisdiction” means any of the several States, the District of Columbia, or any territory or possession of the United States, any municipality, city, county, township, parish, transportation district, or assessment jurisdiction, or any other political subdivision within the territorial limits of the United States with the authority to impose a tax, charge, or fee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id1290946e-f87d-11ef-b94d-97e317d2120c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/252/s2/a"},"text":"Pub. L. 106–252, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-07-28"},"text":"July 28, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/631"},"text":"114 Stat. 631","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1290946f-f87d-11ef-b94d-97e317d2120c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id12909470-f87d-11ef-b94d-97e317d2120c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id12909471-f87d-11ef-b94d-97e317d2120c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date; Application of Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2000-07-28"},"text":"July 28, 2000","children":[],"tail":", and applicable only to customer bills issued after the first day of the first month beginning more than 2 years after "},{"tag":"date","attrib":{"date":"2000-07-28"},"text":"July 28, 2000","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/252/s3"},"text":"section 3 of Pub. L. 106–252","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t4/s116"},"text":"section 116 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
