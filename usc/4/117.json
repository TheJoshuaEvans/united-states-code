{"tag":"section","attrib":{"id":"id128e230d-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s117"},"text":null,"children":[{"tag":"num","attrib":{"value":"117"},"text":"§ 117.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sourcing rules","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id128e230e-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s117/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of Charges for Mobile Telecommunications Services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding the law of any State or political subdivision of any State, mobile telecommunications services provided in a taxing jurisdiction to a customer, the charges for which are billed by or for the customer’s home service provider, shall be deemed to be provided by the customer’s home service provider.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id128e230f-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s117/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Jurisdiction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"All charges for mobile telecommunications services that are deemed to be provided by the customer’s home service provider under sections 116 through 126 of this title are authorized to be subjected to tax, charge, or fee by the taxing jurisdictions whose territorial limits encompass the customer’s place of primary use, regardless of where the mobile telecommunication services originate, terminate, or pass through, and no other taxing jurisdiction may impose taxes, charges, or fees on charges for such mobile telecommunications services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id128e2310-f87d-11ef-b94d-97e317d2120c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/252/s2/a"},"text":"Pub. L. 106–252, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-07-28"},"text":"July 28, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/627"},"text":"114 Stat. 627","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id128e2311-f87d-11ef-b94d-97e317d2120c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id128e2312-f87d-11ef-b94d-97e317d2120c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id128e2313-f87d-11ef-b94d-97e317d2120c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date; Application of Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2000-07-28"},"text":"July 28, 2000","children":[],"tail":", and applicable only to customer bills issued after the first day of the first month beginning more than 2 years after "},{"tag":"date","attrib":{"date":"2000-07-28"},"text":"July 28, 2000","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/252/s3"},"text":"section 3 of Pub. L. 106–252","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t4/s116"},"text":"section 116 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
