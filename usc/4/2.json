{"tag":"section","attrib":{"id":"id1284ad1a-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"§ 2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Same; additional stars","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"On the admission of a new State into the Union one star shall be added to the union of the flag; and such addition shall take effect on the fourth day of July then next succeeding such admission.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id1284ad1b-f87d-11ef-b94d-97e317d2120c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-30/ch389"},"text":"July 30, 1947, ch. 389","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/642"},"text":"61 Stat. 642","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
