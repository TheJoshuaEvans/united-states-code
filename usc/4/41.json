{"tag":"section","attrib":{"id":"id12896878-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s41"},"text":null,"children":[{"tag":"num","attrib":{"value":"41"},"text":"§ 41.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Seal of the United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The seal heretofore used by the United States in Congress assembled is declared to be the seal of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id12896879-f87d-11ef-b94d-97e317d2120c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-30/ch389"},"text":"July 30, 1947, ch. 389","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/643"},"text":"61 Stat. 643","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
