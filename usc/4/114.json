{"tag":"section","attrib":{"id":"id128e22d8-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s114"},"text":null,"children":[{"tag":"num","attrib":{"value":"114"},"text":"§ 114.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on State income taxation of certain pension income","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id128e22d9-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s114/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No State may impose an income tax on any retirement income of an individual who is not a resident or domiciliary of such State (as determined under the laws of such State).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id128e22da-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s114/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id128e22db-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s114/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “retirement income” means any income from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id128e22dc-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s114/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a qualified trust under section 401(a) of the Internal Revenue Code of 1986 that is exempt under section 501(a) from taxation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id128e22dd-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s114/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a simplified employee pension as defined in section 408(k) of such Code;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id128e22de-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s114/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an annuity plan described in section 403(a) of such Code;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id128e22df-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s114/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an annuity contract described in section 403(b) of such Code;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id128e22e0-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s114/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual retirement plan described in section 7701(a)(37) of such Code;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id128e22e1-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s114/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an eligible deferred compensation plan (as defined in section 457 of such Code);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id128e22e2-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s114/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a governmental plan (as defined in section 414(d) of such Code);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id128e22e3-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s114/b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a trust described in section 501(c)(18) of such Code; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id128e22e4-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s114/b/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any plan, program, or arrangement described in section 3121(v)(2)(C) of such Code (or any plan, program, or arrangement that is in writing, that provides for retirement payments in recognition of prior service to be made to a retired partner, and that is in effect immediately before retirement begins), if such income—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id128e22e5-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s114/b/1/I/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is part of a series of substantially equal periodic payments (not less frequently than annually which may include income described in subparagraphs (A) through (H)) made for—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id128e22e6-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s114/b/1/I/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the life or life expectancy of the recipient (or the joint lives or joint life expectancies of the recipient and the designated beneficiary of the recipient), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id128e22e7-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s114/b/1/I/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a period of not less than 10 years, or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id128e22e8-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s114/b/1/I/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a payment received after termination of employment and under a plan, program, or arrangement (to which such employment relates) maintained solely for the purpose of providing retirement benefits for employees in excess of the limitations imposed by 1 or more of sections 401(a)(17), 401(k), 401(m), 402(g), 403(b), 408(k), or 415 of such Code or any other limitation on contributions or benefits in such Code on plans to which any of such sections apply.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The fact that payments may be adjusted from time to time pursuant to such plan, program, or arrangement to limit total disbursements under a predetermined formula, or to provide cost of living or similar adjustments, will not cause the periodic payments provided under such plan, program, or arrangement to fail the “substantially equal periodic payments” test.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Such term includes any retired or retainer pay of a member or former member of a uniform service computed under chapter 71 of title 10, United States Code.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id128e22e9-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s114/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “income tax” has the meaning given such term by section 110(c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id128e22ea-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s114/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “State” includes any political subdivision of a State, the District of Columbia, and the possessions of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id128e22eb-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s114/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this section, the term “retired partner” is an individual who is described as a partner in section 7701(a)(2) of the Internal Revenue Code of 1986 and who is retired under such individual’s partnership agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id128e22ec-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s114/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002006"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002006"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. No subsecs. (c) and (d) have been enacted."}],"tail":" Nothing in this section shall be construed as having any effect on the application of section 514 of the Employee Retirement Income Security Act of 1974."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id128e22ed-f87d-11ef-b94d-97e317d2120c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/95/s1/a"},"text":"Pub. L. 104–95, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-01-10"},"text":"Jan. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/979"},"text":"109 Stat. 979","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/264/s1/a"},"text":"Pub. L. 109–264, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-03"},"text":"Aug. 3, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/667"},"text":"120 Stat. 667","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id128e22ee-f87d-11ef-b94d-97e317d2120c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id128e22ef-f87d-11ef-b94d-97e317d2120c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id128e22f0-f87d-11ef-b94d-97e317d2120c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Internal Revenue Code of 1986, referred to in subsec. (b)(1), (4), is classified generally to Title 26, Internal Revenue Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 514 of the Employee Retirement Income Security Act of 1974, referred to in subsec. (e), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1144"},"text":"section 1144 of Title 29","children":[],"tail":", Labor."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id128e22f1-f87d-11ef-b94d-97e317d2120c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (b)(1)(I). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/264/s1/a/1"},"text":"Pub. L. 109–264, § 1(a)(1)","children":[],"tail":"–(3), inserted “(or any plan, program, or arrangement that is in writing, that provides for retirement payments in recognition of prior service to be made to a retired partner, and that is in effect immediately before retirement begins)” after “section 3121(v)(2)(C) of such Code” in introductory provisions, “which may include income described in subparagraphs (A) through (H)” after “(not less frequently than annually” in cl. (i), and concluding provisions at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/264/s1/a/4"},"text":"Pub. L. 109–264, § 1(a)(4)","children":[],"tail":", which directed the addition of par. (4) at end of subsec. (b)(1)(I), was executed by adding par. (4) at end of subsec. (b) to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id128e22f2-f87d-11ef-b94d-97e317d2120c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id128e22f3-f87d-11ef-b94d-97e317d2120c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/264/s1/b"},"text":"Pub. L. 109–264, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-03"},"text":"Aug. 3, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/667"},"text":"120 Stat. 667","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/264/s1/b"},"text":"“The amendments made by this section [amending this section] apply to amounts received after ","children":[{"tag":"date","attrib":{"date":"1995-12-31"},"text":"December 31, 1995","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id128e22f4-f87d-11ef-b94d-97e317d2120c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/95/s1/c"},"text":"Pub. L. 104–95, § 1(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-01-10"},"text":"Jan. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/980"},"text":"109 Stat. 980","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/95/s1/c"},"text":"“The amendments made by this section [enacting this section] shall apply to amounts received after ","children":[{"tag":"date","attrib":{"date":"1995-12-31"},"text":"December 31, 1995","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
