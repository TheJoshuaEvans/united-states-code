{"tag":"section","attrib":{"id":"id1286f71c-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"§ 5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Display and use of flag by civilians; codification of rules and customs; definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The following codification of existing rules and customs pertaining to the display and use of the flag of the United States of America is established for the use of such civilians or civilian groups or organizations as may not be required to conform with regulations promulgated by one or more executive departments of the Government of the United States. The flag of the United States for the purpose of this chapter shall be defined according to sections 1 and 2 of this title and Executive Order 10834 issued pursuant thereto.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id1286f71d-f87d-11ef-b94d-97e317d2120c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225/s2/a"},"text":"Pub. L. 105–225, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1494"},"text":"112 Stat. 1494","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1286f71e-f87d-11ef-b94d-97e317d2120c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id1286f71f-f87d-11ef-b94d-97e317d2120c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id1286f720-f87d-11ef-b94d-97e317d2120c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:173.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1942-06-22/ch435/s1"},"text":"June 22, 1942, ch. 435, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/56/377"},"text":"56 Stat. 377","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1942-12-22/ch806/s1"},"text":"Dec. 22, 1942, ch. 806, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/56/1074"},"text":"56 Stat. 1074","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"July 7, 1976","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/94/344"},"text":"Pub. L. 94–344","children":[],"tail":", (1), "},{"tag":"html:a","attrib":{"href":"/us/stat/90/810"},"text":"90 Stat. 810","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id1286f721-f87d-11ef-b94d-97e317d2120c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id1286f722-f87d-11ef-b94d-97e317d2120c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Executive Order 10834, referred to in text, is set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t4/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id1286f723-f87d-11ef-b94d-97e317d2120c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id1286f724-f87d-11ef-b94d-97e317d2120c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Freedom To Display the American Flag","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/243"},"text":"Pub. L. 109–243","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-24"},"text":"July 24, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/572"},"text":"120 Stat. 572","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/243"},"text":"\n","children":[{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“SECTION 1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" SHORT TITLE.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“This Act may be cited as the ‘Freedom to Display the American Flag Act of 2005’.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“SEC. 2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" DEFINITIONS.","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"“For purposes of this Act—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘flag of the United States’ has the meaning given the term ‘flag, standard, colors, or ensign’ under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t4/s3"},"text":"section 3 of title 4","children":[],"tail":", United States Code;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms ‘condominium association’ and ‘cooperative association’ have the meanings given such terms under ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/399/s604"},"text":"section 604 of Public Law 96–399","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s3603"},"text":"15 U.S.C. 3603","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘residential real estate management association’ has the meaning given such term under section 528 of the Internal Revenue Code of 1986 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s528"},"text":"26 U.S.C. 528","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term ‘member’—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as used with respect to a condominium association, means an owner of a condominium unit (as defined under ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/399/s604"},"text":"section 604 of Public Law 96–399","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s3603"},"text":"15 U.S.C. 3603","children":[],"tail":")) within such association;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as used with respect to a cooperative association, means a cooperative unit owner (as defined under ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/399/s604"},"text":"section 604 of Public Law 96–399","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s3603"},"text":"15 U.S.C. 3603","children":[],"tail":")) within such association; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as used with respect to a residential real estate management association, means an owner of a residential property within a subdivision, development, or similar area subject to any policy or restriction adopted by such association.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“SEC. 3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" RIGHT TO DISPLAY THE FLAG OF THE UNITED STATES.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“A condominium association, cooperative association, or residential real estate management association may not adopt or enforce any policy, or enter into any agreement, that would restrict or prevent a member of the association from displaying the flag of the United States on residential property within the association with respect to which such member has a separate ownership interest or a right to exclusive possession or use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“SEC. 4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" LIMITATIONS.","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"“Nothing in this Act shall be considered to permit any display or use that is inconsistent with—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any provision of chapter 1 of title 4, United States Code, or any rule or custom pertaining to the proper display or use of the flag of the United States (as established pursuant to such chapter or any otherwise applicable provision of law); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any reasonable restriction pertaining to the time, place, or manner of displaying the flag of the United States necessary to protect a substantial interest of the condominium association, cooperative association, or residential real estate management association.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
