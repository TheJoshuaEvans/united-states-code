ag":"html:p","attrib":{},"text":"3.00","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5.70","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(10)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"2.37","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"4.50","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(11)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"1.32","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"2.50","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 22. Flags manufactured or purchased for the use of executive agencies:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(a) Shall conform to the provisions of Part I of this order, except as may be otherwise authorized pursuant to the provisions of section 24, or except as otherwise authorized by the provisions of section 21, of this order.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(b) Shall conform to the provisions of section 21 of this order, except as may be otherwise authorized pursuant to the provisions of section 24 of this order.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 23. The exterior dimensions of each union jack manufactured or purchased for executive agencies shall equal the respective exterior dimensions of the union of a flag of a size authorized by or pursuant to this order. The size of the union jack flown with the national flag shall be the same as the size of the union of that national flag."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 24. (a) The Secretary of Defense in respect of procurement for the Department of Defense (including military colors) and the Administrator of General Services in respect of procurement for executive agencies other than the Department of Defense may, for cause which the Secretary or the Administrator, as the case may be, deems sufficient, make necessary minor adjustments in one or more of the dimensions or proportionate dimensions prescribed by this order, or authorize proportions or sizes other than those prescribed by section 3 or section 21 of this order."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(b) So far as practicable, (1) the actions of the Secretary of Defense under the provisions of section 24(a) of this order, as they relate to the various organizational elements of the Department of Defense, shall be coordinated, and (2) the Secretary and the Administrator shall mutually coordinate their actions under that section.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 25. Subject to such limited exceptions as the Secretary of Defense in respect of the Department of Defense, and the Administrator of General Services in respect of executive agencies other than the Department of Defense, may approve, all national flags and union jacks now in the possession of executive agencies, or hereafter acquired by executive agencies under contracts awarded prior to the date of this order, including those so possessed or so acquired by the General Services Administration, for distribution to other agencies, shall be utilized until unserviceable."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id1284ad18-f87d-11ef-b94d-97e317d2120c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Part III—General Provisions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 31. The flag prescribed by Executive Order No. 10798 of "},{"tag":"date","attrib":{"date":"1959-01-03"},"text":"January 3, 1959","children":[],"tail":", shall be the official flag of the United States until "},{"tag":"date","attrib":{"date":"1960-07-04"},"text":"July 4, 1960","children":[],"tail":", and on that date the flag prescribed by Part I of this order shall become the official flag of the United States; but this section shall neither derogate from section 24 or section 25 of this order nor preclude the procurement, for executive agencies, of flags provided for by or pursuant to this order at any time after the date of this order."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 32. As used in this order, the term “executive agencies” means the executive departments and independent establishments in the executive branch of the Government, including wholly-owned Government corporations."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 33. Executive Order No. 10798 of "},{"tag":"date","attrib":{"date":"1959-01-03"},"text":"January 3, 1959","children":[],"tail":", is hereby revoked."}],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"tex