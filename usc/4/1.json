{"tag":"section","attrib":{"id":"id12823c09-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"§ 1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Flag; stripes and stars on","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The flag of the United States shall be thirteen horizontal stripes, alternate red and white; and the union of the flag shall be forty-eight stars, white in a blue field.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id12823c0a-f87d-11ef-b94d-97e317d2120c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-30/ch389"},"text":"July 30, 1947, ch. 389","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/642"},"text":"61 Stat. 642","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id12823c0b-f87d-11ef-b94d-97e317d2120c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id12823c0c-f87d-11ef-b94d-97e317d2120c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id12823c0d-f87d-11ef-b94d-97e317d2120c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123/dA/s10101"},"text":"Pub. L. 115–123, div. A, § 10101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-02-09"},"text":"Feb. 9, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/64"},"text":"132 Stat. 64","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/123/dA/s10101"},"text":"“This division [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t4/s7"},"text":"section 7 of this title","children":[],"tail":" and enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t4/s7"},"text":"section 7 of this title","children":[],"tail":"] may be cited as the ‘Honoring Hometown Heroes Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id12823c0e-f87d-11ef-b94d-97e317d2120c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/15/s1"},"text":"Pub. L. 115–15, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-03-28"},"text":"Mar. 28, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/79"},"text":"131 Stat. 79","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/15/s1"},"text":"“This Act [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t4/s6"},"text":"section 6 of this title","children":[],"tail":"] may be cited as the ‘Vietnam War Veterans Recognition Act of 2017’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id12823c0f-f87d-11ef-b94d-97e317d2120c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/41/s1"},"text":"Pub. L. 111–41, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-07-27"},"text":"July 27, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1962"},"text":"123 Stat. 1962","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/41/s1"},"text":"“This Act [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t4/s6"},"text":"section 6 of this title","children":[],"tail":"] may be cited as the ‘Korean War Veterans Recognition Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id12823c10-f87d-11ef-b94d-97e317d2120c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/41/s1"},"text":"Pub. L. 110–41, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-06-29"},"text":"June 29, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/233"},"text":"121 Stat. 233","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/41/s1"},"text":"“This Act [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t4/s7"},"text":"section 7 of this title","children":[],"tail":" and provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t4/s7"},"text":"section 7 of this title","children":[],"tail":"] may be cited as the ‘Army Specialist Joseph P. Micks Federal Flag Code Amendment Act of 2007’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id12823c11-f87d-11ef-b94d-97e317d2120c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/252/s1"},"text":"Pub. L. 106–252, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-07-28"},"text":"July 28, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/626"},"text":"114 Stat. 626","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/252/s1"},"text":"“This Act [enacting sections 116 to 126 of this title and provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t4/s116"},"text":"section 116 of this title","children":[],"tail":"] may be cited as the ‘Mobile Telecommunications Sourcing Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id12823c12-f87d-11ef-b94d-97e317d2120c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"executiveOrder","id":"id12823c13-f87d-11ef-b94d-97e317d2120c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Executive Order No. 10798","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Ex. Ord. No. 10798, ","children":[{"tag":"date","attrib":{"date":"1959-01-03"},"text":"Jan. 3, 1959","children":[],"tail":", 24 F.R. 79, which prescribed proportions and sizes of flags until "},{"tag":"date","attrib":{"date":"1960-07-04"},"text":"July 4, 1960","children":[],"tail":", was revoked by section 33 of Ex. Ord. No. 10834, set out as a note under this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"executiveOrder","id":"id12823c14-f87d-11ef-b94d-97e317d2120c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Ex. Ord. No. 10834. Proportions and Sizes of Flags and Position of Stars","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Ex. Ord. No. 10834, ","children":[{"tag":"date","attrib":{"date":"1959-08-21"},"text":"Aug. 21, 1959","children":[],"tail":", 24 F.R. 6865, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"WHEREAS the State of Hawaii has this day been admitted into the Union; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"WHEREAS ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t4/s2"},"text":"section 2 of title 4","children":[],"tail":" of the United States Code provides as follows: “On the admission of a new State into the Union one star shall be added to the union of the flag; and such addition shall take effect on the fourth day of July then next succeeding such admission.”; and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"WHEREAS the Federal Property and Administrative Services Act of 1949 (","children":[{"tag":"ref","attrib":{"href":"/us/stat/63/377"},"text":"63 Stat. 377","children":[],"tail":"), as amended [see chapters 1 to 11 of Title 40, Public Buildings, Property, and Works, and division C (except sections 3302, 3307(e), 3501(b), 3509, 3906, 4710, and 4711) of subtitle I of Title 41, Public Contracts] authorizes the President to prescribe policies and directives governing the procurement and utilization of property by executive agencies; and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"WHEREAS the interests of the Government require that orderly and reasonable provision be made for various matters pertaining to the flag and that appropriate regulations governing the procurement and utilization of national flags and union jacks by executive agencies be prescribed:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"NOW, THEREFORE, by virtue of the authority vested in me as President of the United States and as Commander in Chief of the armed forces of the United States, and the Federal Property and Administrative Services Act of 1949, as amended [see Short Title of 1949 Act note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s101"},"text":"section 101 of Title 41","children":[],"tail":", Public Contracts], it is hereby ordered as follows:"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id12823c15-f87d-11ef-b94d-97e317d2120c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Part I—Design of the Flag","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Section","children":[],"tail":" 1. The flag of the United States shall have thirteen horizontal stripes, alternate red and white, and a union consisting of white stars on a field of blue."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 2. The positions of the stars in the union of the flag and in the union jack shall be as indicated on the attachment to this order, which is hereby made a part of this order."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 3. The dimensions of the constituent parts of the flag shall conform to the proportions set forth in the attachment referred to in section 2 of this order."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id12823c16-f87d-11ef-b94d-97e317d2120c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Part II—Regulations Governing Executive Agencies","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 21. The following sizes of flags are authorized for executive agencies:"}],"tail":"\n"},{"tag":"html:table","attrib":{"width":"50%","id":"id1284ad17-f87d-11ef-b94d-97e317d2120c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"rowspan":"2"},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Size","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{"colspan":"2"},"text":null,"children":[{"tag"