{"tag":"section","attrib":{"id":"id1290949b-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s143"},"text":null,"children":[{"tag":"num","attrib":{"value":"143"},"text":"§ 143.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment and utilization of other personnel; cost of copy reading and indexing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id1290949c-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s143/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In carrying out his functions under this chapter, the Archivist may employ such clerical assistants as may be necessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1290949d-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s143/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The work of copy reading and index making for the publication of the papers described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t4/s141"},"text":"section 141 of this title","children":[],"tail":" shall be done by the regular editorial staff of the National Archives and Records Administration, and the cost of this particular phase of the work (prorated each month according to the number of hours spent and the annual salaries of the clerks employed) shall be charged against the annual appropriations made under "},{"tag":"ref","attrib":{"href":"/us/usc/t4/s146"},"text":"section 146 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id1290949e-f87d-11ef-b94d-97e317d2120c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/act/1951-10-31/ch655/s12"},"text":"Oct. 31, 1951, ch. 655, § 12","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/65/714"},"text":"65 Stat. 714","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/497/tI/s107/f"},"text":"Pub. L. 98–497, title I, § 107(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2292"},"text":"98 Stat. 2292","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1290949f-f87d-11ef-b94d-97e317d2120c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id129094a0-f87d-11ef-b94d-97e317d2120c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id129094a1-f87d-11ef-b94d-97e317d2120c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/497"},"text":"Pub. L. 98–497","children":[],"tail":" substituted “Archivist” for “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/497"},"text":"Pub. L. 98–497","children":[],"tail":" substituted “National Archives and Records Administration” for “General Services Administration”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id129094a2-f87d-11ef-b94d-97e317d2120c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id129094a3-f87d-11ef-b94d-97e317d2120c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[]