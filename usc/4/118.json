{"tag":"section","attrib":{"id":"id128e2314-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s118"},"text":null,"children":[{"tag":"num","attrib":{"value":"118"},"text":"§ 118.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Sections 116 through 126 of this title do not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id128e2315-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s118/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide authority to a taxing jurisdiction to impose a tax, charge, or fee that the laws of such jurisdiction do not authorize such jurisdiction to impose; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id128e2316-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s118/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modify, impair, supersede, or authorize the modification, impairment, or supersession of the law of any taxing jurisdiction pertaining to taxation except as expressly provided in sections 116 through 126 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id128e2317-f87d-11ef-b94d-97e317d2120c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/252/s2/a"},"text":"Pub. L. 106–252, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-07-28"},"text":"July 28, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/627"},"text":"114 Stat. 627","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id128e2318-f87d-11ef-b94d-97e317d2120c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id128e2319-f87d-11ef-b94