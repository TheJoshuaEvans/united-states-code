{"tag":"section","attrib":{"id":"id128e22cc-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s113"},"text":null,"children":[{"tag":"num","attrib":{"value":"113"},"text":"§ 113.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Residence of Members of Congress for State income tax laws","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id128e22cd-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s113/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" No State, or political subdivision thereof, in which a Member of Congress maintains a place of abode for purposes of attending sessions of Congress may, for purposes of any income tax (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t4/s110/c"},"text":"section 110(c) of this title","children":[],"tail":") levied by such State or political subdivision thereof—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id128e22ce-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s113/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" treat such Member as a resident or domiciliary of such State or political subdivision thereof; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id128e22cf-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s113/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" treat any compensation paid by the United States to such Member as income for services performed within, or from sources within, such State or political subdivision thereof,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"unless such Member represents such State or a district in such State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id128e22d0-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s113/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id128e22d1-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s113/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Member of Congress” includes the delegates from the District of Columbia, Guam, and the Virgin Islands, and the Resident Commissioner from Puerto Rico; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id128e22d2-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s113/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “State” includes the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id128e22d3-f87d-11ef-b94d-97e317d2120c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/67/s1/a"},"text":"Pub. L. 95–67, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-07-19"},"text":"July 19, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/271"},"text":"91 Stat. 271","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id128e22d4-f87d-11ef-b94d-97e317d2120c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id128e22d5-f87d-11ef-b94d-97e317d2120c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id128e22d6-f87d-11ef-b94d-97e317d2120c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/67/s1/c"},"text":"Pub. L. 95–67, § 1(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-07-19"},"text":"July 19, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/271"},"text":"91 Stat. 271","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/67/s1/c"},"text":"“The amendments made by subsections (a) and (b) [enacting this section and amending analysis preceding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t4/s101"},"text":"section 101 of this title","children":[],"tail":"] shall be effective with respect to all taxable years, whether beginning before, on, or after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1977-07-19"},"text":"July 19, 1977","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id128e22d7-f87d-11ef-b94d-97e317d2120c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Residence of Members of Congress for State Personal Property Tax on Motor Vehicles","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/190/s101/c/s3067"},"text":"Pub. L. 99–190, § 101(c) [H.R. 3067, § 131]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-19"},"text":"Dec. 19, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1224"},"text":"99 Stat. 1224","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/202/s106"},"text":"Pub. L. 100–202, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1329-433"},"text":"101 Stat. 1329–433","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/202/s106"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No State, or political subdivision thereof, in which a Member of Congress maintains a place of abode for purposes of attending sessions of Congress may impose a personal property tax with respect to any motor vehicle owned by such Member (or by the spouse of such Member) unless such Member represents such State or a district in such State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘Member of Congress’ includes the delegates from the District of Columbia, Guam, and the Virgin Islands, and the Resident Commissioner from Puerto Rico;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘State’ includes the District of Columbia; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘personal property tax’ means any tax imposed on an annual basis and levied on, with respect to, or measured by, the market value or assessed value of an item of personal property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section shall apply to all taxable periods beginning on or after ","children":[{"tag":"date","attrib":{"date":"1985-01-01"},"text":"January 1, 1985","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
