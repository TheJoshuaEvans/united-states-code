{"tag":"section","attrib":{"id":"id129094bb-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s146"},"text":null,"children":[{"tag":"num","attrib":{"value":"146"},"text":"§ 146.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the purposes of this chapter, there are authorized to be appropriated, out of any money in the Treasury not otherwise appropriated, sums of not more than $50,000 for any one fiscal year.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id129094bc-f87d-11ef-b94d-97e317d2120c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/act/1951-10-31/ch655/s12"},"text":"Oct. 31, 1951, ch. 655, § 12","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/65/715"},"text":"65 Stat. 715","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id129094bd-f87d-11ef-b94d-97e317d2120c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id129094be-f87d-11ef-b94d-97e317d2120c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id129094bf-f87d-11ef-b94d-97e317d2120c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Similar Provisions; Repeal; Saving Clause; Delegation of Functions; Transfer of Property and Personnel","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"See note preceding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t4/s141"},"text":"section 141 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
