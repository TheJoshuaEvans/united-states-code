in February;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/41"},"text":"Pub. L. 111–41","children":[],"tail":" inserted “National Korean War Veterans Armistice Day, July 27;” after “July 4;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/239"},"text":"Pub. L. 110–239","children":[],"tail":" inserted “Father’s Day, third Sunday in June;” after “Flag Day, June 14;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/80"},"text":"Pub. L. 106–80","children":[],"tail":" inserted “Martin Luther King Jr.’s birthday, third Monday in January;” after “January 20;”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
