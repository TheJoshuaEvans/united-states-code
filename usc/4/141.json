{"tag":"section","attrib":{"id":"id1290948a-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s141"},"text":null,"children":[{"tag":"num","attrib":{"value":"141"},"text":"§ 141.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection, preparation and publication","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Archivist of the United States, hereinafter referred to in this chapter as the “Archivist”, shall continue to completion the work of collecting, editing, copying, and suitably arranging for issuance as a Government publication, the official papers relating to the Territories from which States of the United States were formed, in the national archives, as listed in Parker’s “Calendar of Papers in Washington” Archives Relating to the Territories of the United States (to 1873)”, being publication numbered 148 of the Carnegie Institution of Washington, together with such additional papers of like character which may be found.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id1290948b-f87d-11ef-b94d-97e317d2120c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/act/1951-10-31/ch655/s12"},"text":"Oct. 31, 1951, ch. 655, § 12","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/65/713"},"text":"65 Stat. 713","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/497/tI/s107/f"},"text":"Pub. L. 98–497, title I, § 107(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2292"},"text":"98 Stat. 2292","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1290948c-f87d-11ef-b94d-97e317d2120c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id1290948d-f87d-11ef-b94d-97e317d2120c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id1290948e-f87d-11ef-b94d-97e317d2120c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/497"},"text":"Pub. L. 98–497","children":[],"tail":" substituted “Archivist of the United States” and “Archivist” for “Administrator of General Services” and “Administrator”, respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id1290948f-f87d-11ef-b94d-97e317d2120c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id12909490-f87d-11ef-b94d-97e317d2120c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/497"},"text":"Pub. L. 98–497","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1985-04-01"},"text":"Apr. 1, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/497/s301"},"text":"section 301 of Pub. L. 98–497","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s2102"},"text":"section 2102 of Title 44","children":[],"tail":", Public Printing and Documents."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id12909491-f87d-11ef-b94d-97e317d2120c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Similar Provisions; Repeal; Saving Clause; Delegation of Functions; Transfer of Property and Personnel","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"See note preceding this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
