{"tag":"section","attrib":{"id":"id128bd9b4-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s109"},"text":null,"children":[{"tag":"num","attrib":{"value":"109"},"text":"§ 109.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Same; exception of Indians","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in sections 105 and 106 of this title shall be deemed to authorize the levy or collection of any tax on or from any Indian not otherwise taxed.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id128bd9b5-f87d-11ef-b94d-97e317d2120c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-30/ch389"},"text":"July 30, 1947, ch. 389","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/645"},"text":"61 Stat. 645","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
