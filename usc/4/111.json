{"tag":"section","attrib":{"id":"id128bd9c0-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s111"},"text":null,"children":[{"tag":"num","attrib":{"value":"111"},"text":"§ 111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Same; taxation affecting Federal employees; income tax","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id128bd9c1-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s111/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Rule","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The United States consents to the taxation of pay or compensation for personal service as an officer or employee of the United States, a territory or possession or political subdivision thereof, the government of the District of Columbia, or an agency or instrumentality of one or more of the foregoing, by a duly constituted taxing authority having jurisdiction, if the taxation does not discriminate against the officer or employee because of the source of the pay or compensation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id128bd9c2-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s111/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of Certain Federal Employees Employed at Federal Hydroelectric Facilities Located on the Columbia River","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Pay or compensation paid by the United States for personal services as an employee of the United States at a hydroelectric facility—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id128bd9c3-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s111/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is owned by the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id128bd9c4-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s111/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is located on the Columbia River; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id128bd9c5-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s111/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" portions of which are within the States of Oregon and Washington,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be subject to taxation by the State or any political subdivision thereof of which such employee is a resident.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id128bd9c6-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s111/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of Certain Federal Employees Employed at Federal Hydroelectric Facilities Located on the Missouri River","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Pay or compensation paid by the United States for personal services as an employee of the United States at a hydroelectric facility—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id128bd9c7-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s111/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is owned by the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id128bd9c8-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s111/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is located on the Missouri River; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id128bd9c9-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s111/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" portions of which are within the States of South Dakota and Nebraska,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be subject to taxation by the State or any political subdivision thereof of which such employee is a resident.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id128bd9ca-f87d-11ef-b94d-97e317d2120c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554/s2/c"},"text":"Pub. L. 89–554, § 2(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/608"},"text":"80 Stat. 608","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tX/s1075/b/1"},"text":"Pub. L. 105–261, div. A, title X, § 1075(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2138"},"text":"112 Stat. 2138","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id128bd9cb-f87d-11ef-b94d-97e317d2120c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id128bd9cc-f87d-11ef-b94d-97e317d2120c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id128bd9cd-f87d-11ef-b94d-97e317d2120c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Statutes and","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Statutes at Large","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s84a"},"text":"5 U.S.C. 84a","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1939-04-12/ch59/s4"},"text":"Apr. 12, 1939, ch. 59, § 4","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/53/575"},"text":"53 Stat. 575","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “received after ","children":[{"tag":"date","attrib":{"date":"1938-12-31"},"text":"December 31, 1938","children":[],"tail":",” are omitted as obsolete. The words “pay or” are added before “compensation” for clarity as the word “pay” is used throughout title 5, United States Code, to refer to the remuneration, salary, wages, or compensation for the personal services of a Federal employee. The word “territory” is not capitalized as there are no longer any “Territories.” The words “to tax such compensation” are omitted as unnecessary."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id128bd9ce-f87d-11ef-b94d-97e317d2120c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id128bd9cf-f87d-11ef-b94d-97e317d2120c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261"},"text":"Pub. L. 105–261","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, and added subsecs. (b) and (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id128bd9d0-f87d-11ef-b94d-97e317d2120c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id128bd9d1-f87d-11ef-b94d-97e317d2120c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tX/s1075/b/2"},"text":"Pub. L. 105–261, div. A, title X, § 1075(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2139"},"text":"112 Stat. 2139","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/261/dA/tX/s1075/b/2"},"text":"“The amendment made by this subsection [amending this section] shall apply to pay and compensation paid after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
