{"tag":"section","attrib":{"id":"id129094ad-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s145"},"text":null,"children":[{"tag":"num","attrib":{"value":"145"},"text":"§ 145.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Printing and distribution","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id129094ae-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s145/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Director of the Government Publishing Office shall print and bind each volume of the official papers relating to the Territories of the United States as provided for in this chapter, of which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id129094af-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s145/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" four hundred and twenty copies shall be delivered to the Superintendent of Documents, Government Publishing Office, for distribution, on the basis of one copy each, and as directed by the Archivist, to those historical associations, commissions, museums, or libraries and other nondepository libraries, not to exceed eight in number within each State, Territory, or Possession, which have been or may be designated by the Governor thereof to receive such copies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id129094b0-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s145/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one hundred copies shall be delivered to the National Archives and Records Administration for the use of that Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id129094b1-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s145/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one hundred copies shall be delivered to the Superintendent of Documents for distribution in such manner and number as may be authorized and directed by the Joint Committee on Printing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id129094b2-f87d-11ef-b94d-97e317d2120c","identifier":"/us/usc/t4/s145/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The historical associations, commissions, museums, or libraries and other nondepository libraries within each State, Territory, or Possession which have been or may be designated by the Governor thereof to receive the publications referred to in subsection (a) of this section, shall, during their existence, receive the succeeding volumes, the distribution of which shall be made by the Superintendent of Documents in accordance with lists of designations transmitted to him by the Archivist. A new designation may be made to the Archivist by the Governor only when a designated association, commission, museum, or library shall cease to exist, or when authorized by law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id129094b3-f87d-11ef-b94d-97e317d2120c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/act/1951-10-31/ch655/s12"},"text":"Oct. 31, 1951, ch. 655, § 12","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/65/714"},"text":"65 Stat. 714","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/497/tI/s107/f"},"text":"Pub. L. 98–497, title I, § 107(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2292"},"text":"98 Stat. 2292","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/b"},"text":"Pub. L. 113–235, div. H, title I, § 1301(b)","children":[],"tail":", (d), "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id129094b4-f87d-11ef-b94d-97e317d2120c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id129094b5-f87d-11ef-b94d-97e317d2120c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id129094b6-f87d-11ef-b94d-97e317d2120c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/497"},"text":"Pub. L. 98–497","children":[],"tail":" substituted “Archivist” for “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/497"},"text":"Pub. L. 98–497","children":[],"tail":" substituted “National Archives and Records Administration” for “General Services Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/497"},"text":"Pub. L. 98–497","children":[],"tail":" substituted “Archivist” for “Administrator” in two places."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id129094b7-f87d-11ef-b94d-97e317d2120c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id129094b8-f87d-11ef-b94d-97e317d2120c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Director of the Government Publishing Office” substituted for “Public Printer” in subsec. (a) on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/s1301/d"},"text":"section 1301(d) of Pub. L. 113–235","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s301"},"text":"section 301 of Title 44","children":[],"tail":", Public Printing and Documents."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Government Publishing Office” substituted for “Government Printing Office” in subsec. (a)(1) on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/s1301/b"},"text":"section 1301(b) of Pub. L. 113–235","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s301"},"text":"section 301 of Title 44","children":[],"tail":", Public Printing and Documents."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id129094b9-f87d-11ef-b94d-97e317d2120c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/497"},"text":"Pub. L. 98–497","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1985-04-01"},"text":"Apr. 1, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/497/s301"},"text":"section 301 of Pub. L. 98–497","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s2102"},"text":"section 2102 of Title 44","children":[],"tail":", Public Printing and Documents."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id129094ba-f87d-11ef-b94d-97e317d2120c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Similar Provisions; Repeal; Saving Clause; Delegation of Functions; Transfer of Property and Personnel","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"See note preceding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t4/s141"},"text":"section 141 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
