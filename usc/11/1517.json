{"tag":"section","attrib":{"id":"idd3bfa976-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1517"},"text":null,"children":[{"tag":"num","attrib":{"value":"1517"},"text":"§ 1517.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Order granting recognition","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd3bfa977-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1517/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to section 1506, after notice and a hearing, an order recognizing a foreign proceeding shall be entered if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd3bfa978-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1517/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such foreign proceeding for which recognition is sought is a foreign main proceeding or foreign nonmain proceeding within the meaning of section 1502;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3bfa979-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1517/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the foreign representative applying for recognition is a person or body; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3bfa97a-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1517/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the petition meets the requirements of section 1515.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3bfa97b-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1517/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Such foreign proceeding shall be recognized—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd3bfa97c-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1517/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a foreign main proceeding if it is pending in the country where the debtor has the center of its main interests; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3bfa97d-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1517/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a foreign nonmain proceeding if the debtor has an establishment within the meaning of section 1502 in the foreign country where the proceeding is pending.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3bfa97e-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1517/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A petition for recognition of a foreign proceeding shall be decided upon at the earliest possible time. Entry of an order recognizing a foreign proceeding constitutes recognition under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3bfa97f-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1517/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of this subchapter do not prevent modification or termination of recognition if it is shown that the grounds for granting it were fully or partially lacking or have ceased to exist, but in considering such action the court shall give due weight to possible prejudice to parties that have relied upon the order granting recognition. A case under this chapter may be closed in the manner prescribed under section 350.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd3bfa980-3a6f-11f1-8dc6-9561437cf370"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/tVIII/s801/a"},"text":"Pub. L. 109–8, title VIII, § 801(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/139"},"text":"119 Stat. 139","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd3bfa981-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd3bfa982-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd3bfa983-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 180 days after ","children":[{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", and not applicable with respect to cases commenced under this title before such effective date, except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/8/s1501"},"text":"section 1501 of Pub. L. 109–8","children":[],"tail":", set out as an Effective Date of 2005 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
