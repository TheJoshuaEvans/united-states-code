{"tag":"section","attrib":{"id":"idd3bfa8b3-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1329"},"text":null,"children":[{"tag":"num","attrib":{"value":"1329"},"text":"§ 1329.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modification of plan after confirmation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd3bfa8b4-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1329/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" At any time after confirmation of the plan but before the completion of payments under such plan, the plan may be modified, upon request of the debtor, the trustee, or the holder of an allowed unsecured claim, to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd3bfa8b5-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1329/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase or reduce the amount of payments on claims of a particular class provided for by the plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3bfa8b6-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1329/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" extend or reduce the time for such payments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3bfa8b7-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1329/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alter the amount of the distribution to a creditor whose claim is provided for by the plan to the extent necessary to take account of any payment of such claim other than under the plan; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3bfa8b8-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1329/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" reduce amounts to be paid under the plan by the actual amount expended by the debtor to purchase health insurance for the debtor (and for any dependent of the debtor if such dependent does not otherwise have health insurance coverage) if the debtor documents the cost of such insurance and demonstrates that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd3bfa8b9-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1329/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such expenses are reasonable and necessary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd3bfa8ba-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1329/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd3bfa8bb-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1329/a/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the debtor previously paid for health insurance, the amount is not materially larger than the cost the debtor previously paid or the cost necessary to maintain the lapsed policy; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd3bfa8bc-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1329/a/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the debtor did not have health insurance, the amount is not materially larger than the reasonable cost that would be incurred by a debtor who purchases health insurance, who has similar income, expenses, age, and health status, and who lives in the same geographical location with the same number of dependents who do not otherwise have health insurance coverage; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd3bfa8bd-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1329/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount is not otherwise allowed for purposes of determining disposable income under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s1325/b"},"text":"section 1325(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"and upon request of any party in interest, files proof that a health insurance policy was purchased.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3bfa8be-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1329/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd3bfa8bf-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1329/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sections 1322(a), 1322(b), and 1323(c) of this title and the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s1325/a"},"text":"section 1325(a) of this title","children":[],"tail":" apply to any modification under subsection (a) of this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3bfa8c0-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1329/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The plan as modified becomes the plan unless, after notice and a hearing, such modification is disapproved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3bfa8c1-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1329/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A plan modified under this section may not provide for payments over a period that expires after the applicable commitment period under section 1325(b)(1)(B) after the time that the first payment under the original confirmed plan was due, unless the court, for cause, approves a longer period, but the court may not approve a period that expires after five years after such time.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd3bfa8c2-3a6f-11f1-8dc6-9561437cf370"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2651"},"text":"92 Stat. 2651","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/353/tIII"},"text":"Pub. L. 98–353, title III","children":[],"tail":", §§ 319, 533, "},{"tag":"date","attrib":{"date":"1984-07-10"},"text":"July 10, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/357"},"text":"98 Stat. 357","children":[],"tail":", 389; "},{"tag":"ref","attrib":{"href":"/us/pl/109/8/tI/s102/i"},"text":"Pub. L. 109–8, title I, § 102(i)","children":[],"tail":", title III, § 318(4), "},{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/34"},"text":"119 Stat. 34","children":[],"tail":", 94; "},{"tag":"ref","attrib":{"href":"/us/pl/116/136/dA/tI/s1113/b/1/C"},"text":"Pub. L. 116–136, div. A, title I, § 1113(b)(1)(C)","children":[],"tail":", (2)(A)(iii), "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/311"},"text":"134 Stat. 311","children":[],"tail":", 312; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dFF/tX/s1001/e"},"text":"Pub. L. 116–260, div. FF, title X, § 1001(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3218"},"text":"134 Stat. 3218","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/5/s2/b/1"},"text":"Pub. L. 117–5, § 2(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-03-27"},"text":"Mar. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/249"},"text":"135 Stat. 249","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd3bfa8c3-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idd3bfa8c4-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd3bfa8c5-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"senate report no. 95–989","children":[],"tail":null},{"tag":"p","attrib":{},"text":"At any time prior to the completion of payments under a confirmed plan, the plan may be modified, after notice and hearing, to change the amount of payments to creditors or a particular class of creditors and to extend or reduce the payment period. A modified plan may not contain any provision which could not be included in an original plan as prescribed by section 1322. A modified plan may not call for payments to be made beyond four years as measured from the date of the commencement of payments under the original plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd3bfa8c6-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd3bfa8c7-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/5"},"text":"Pub. L. 117–5","children":[],"tail":" substituted “the COVID–19 Bankruptcy Relief Extension Act of 2021” for “this subsection” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2020—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/s1113/b/2/A/ii"},"text":"Pub. L. 116–136, § 1113(b)(2)(A)(ii)","children":[],"tail":", struck out subsec. (d) which related to modification of plan confirmed before "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", where debtor experienced material financial hardship due to coronavirus disease 2019 (COVID–19) pandemic."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/s1113/b/1/C"},"text":"Pub. L. 116–136, § 1113(b)(1)(C)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s1001/e/2"},"text":"Pub. L. 116–260, § 1001(e)(2)","children":[],"tail":", struck out subsec. (e) which related to debtor of case for which creditor files proof of claim under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s501/f"},"text":"section 501(f) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s1001/e/1"},"text":"Pub. L. 116–260, § 1001(e)(1)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/s102/i"},"text":"Pub. L. 109–8, § 102(i)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/s318/4"},"text":"Pub. L. 109–8, § 318(4)","children":[],"tail":", substituted “the applicable commitment period under section 1325(b)(1)(B)” for “three years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/353"},"text":"Pub. L. 98–353","children":[],"tail":", §§ 319, 533(1), (2), inserted “of the plan” after “confirmation”, substituted “such plan” for “a plan”, and inserted provisions respecting requests by the debtor, the trustee, or the holder of an allowed unsecured claim for modification."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/353/s533/3"},"text":"Pub. L. 98–353, § 533(3)","children":[],"tail":", substituted “plan to” for “plan, to”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd3bfa8c8-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd3bfa8c9-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2020 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dFF/tX/s1001/e/2"},"text":"Pub. L. 116–260, div. FF, title X, § 1001(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3219"},"text":"134 Stat. 3219","children":[],"tail":", provided that the amendment made by section 1001(e)(2) is effective on the date that is 1 year after "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/dA/tI/s1113/b/1/D/ii"},"text":"Pub. L. 116–136, div. A, title I, § 1113(b)(1)(D)(ii)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/312"},"text":"134 Stat. 312","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/117/5/s2/b/2"},"text":"Pub. L. 117–5, § 2(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-03-27"},"text":"Mar. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/249"},"text":"135 Stat. 249","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/5/s2/b/2"},"text":"“The amendment made by subparagraph (C) [amending this section] shall apply to any case for which a plan has been confirmed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s1325"},"text":"section 1325 of title 11","children":[],"tail":", United States Code, before the date of enactment of the COVID–19 Bankruptcy Relief Extension Act of 2021 ["},{"tag":"ref","attrib":{"href":"/us/pl/117/5"},"text":"Pub. L. 117–5","children":[],"tail":", approved "},{"tag":"date","attrib":{"date":"2021-03-27"},"text":"Mar. 27, 2021","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/s1113/b/2/A/iii"},"text":"section 1113(b)(2)(A)(iii) of Pub. L. 116–136","children":[],"tail":", effective 2 years after "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/116/136/s1113/b/2/B"},"text":"section 1113(b)(2)(B) of Pub. L. 116–136","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd3bfa8ca-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2005 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8"},"text":"Pub. L. 109–8","children":[],"tail":" effective 180 days after "},{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", and not applicable with respect to cases commenced under this title before such effective date, except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/8/s1501"},"text":"section 1501 of Pub. L. 109–8","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd3bfa8cb-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/353"},"text":"Pub. L. 98–353","children":[],"tail":" effective with respect to cases filed 90 days after "},{"tag":"date","attrib":{"date":"1984-07-10"},"text":"July 10, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/353/s552/a"},"text":"section 552(a) of Pub. L. 98–353","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
