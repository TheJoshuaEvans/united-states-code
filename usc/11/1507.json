{"tag":"section","attrib":{"id":"idd3bfa915-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1507"},"text":null,"children":[{"tag":"num","attrib":{"value":"1507"},"text":"§ 1507.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd3bfa916-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1507/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to the specific limitations stated elsewhere in this chapter the court, if recognition is granted, may provide additional assistance to a foreign representative under this title or under other laws of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3bfa917-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1507/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In determining whether to provide additional assistance under this title or under other laws of the United States, the court shall consider whether such additional assistance, consistent with the principles of comity, will reasonably assure—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd3bfa918-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1507/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" just treatment of all holders of claims against or interests in the debtor’s property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3bfa919-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1507/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protection of claim holders in the United States against prejudice and inconvenience in the processing of claims in such foreign proceeding;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3bfa91a-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1507/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevention of preferential or fraudulent dispositions of property of the debtor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3bfa91b-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1507/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" distribution of proceeds of the debtor’s property substantially in accordance with the order prescribed by this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3bfa91c-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1507/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if appropriate, the provision of an opportunity for a fresh start for the individual that such foreign proceeding concerns.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd3bfa91d-3a6f-11f1-8dc6-9561437cf370"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/tVIII/s801/a"},"text":"Pub. L. 109–8, title VIII, § 801(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/136"},"text":"119 Stat. 136","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd3bfa91e-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd3bfa91f-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd3bfa920-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 180 days after ","children":[{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", and not applicable with respect to cases commenced under this title before such effective date, except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/8/s1501"},"text":"section 1501 of Pub. L. 109–8","children":[],"tail":", set out as an Effective Date of 2005 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
