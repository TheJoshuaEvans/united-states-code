{"tag":"section","attrib":{"id":"idd3b6336e-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1208"},"text":null,"children":[{"tag":"num","attrib":{"value":"1208"},"text":"§ 1208.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conversion or dismissal","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd3b6336f-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1208/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The debtor may convert a case under this chapter to a case under chapter 7 of this title at any time. Any waiver of the right to convert under this subsection is unenforceable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3b63370-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1208/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" On request of the debtor at any time, if the case has not been converted under section 706 or 1112 of this title, the court shall dismiss a case under this chapter. Any waiver of the right to dismiss under this subsection is unenforceable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3b63371-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1208/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" On request of a party in interest, and after notice and a hearing, the court may dismiss a case under this chapter for cause, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd3b63372-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1208/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unreasonable delay, or gross mismanagement, by the debtor that is prejudicial to creditors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3b63373-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1208/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nonpayment of any fees and charges required under chapter 123 of title 28;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3b63374-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1208/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" failure to file a plan timely under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s1221"},"text":"section 1221 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3b63375-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1208/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" failure to commence making timely payments required by a confirmed plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3b63376-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1208/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" denial of confirmation of a plan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s1225"},"text":"section 1225 of this title","children":[],"tail":" and denial of a request made for additional time for filing another plan or a modification of a plan;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3b63377-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1208/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" material default by the debtor with respect to a term of a confirmed plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3b63378-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1208/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" revocation of the order of confirmation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s1230"},"text":"section 1230 of this title","children":[],"tail":", and denial of confirmation of a modified plan under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s1229"},"text":"section 1229 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3b63379-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1208/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" termination of a confirmed plan by reason of the occurrence of a condition specified in the plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3b6337a-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1208/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continuing loss to or diminution of the estate and absence of a reasonable likelihood of rehabilitation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3b6337b-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1208/c/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" failure of the debtor to pay any domestic support obligation that first becomes payable after the date of the filing of the petition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3b6337c-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1208/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" On request of a party in interest, and after notice and a hearing, the court may dismiss a case under this chapter or convert a case under this chapter to a case under chapter 7 of this title upon a showing that the debtor has committed fraud in connection with the case.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3b6337d-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1208/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of this section, a case may not be converted to a case under another chapter of this title unless the debtor may be a debtor under such chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd3b6337e-3a6f-11f1-8dc6-9561437cf370"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/554/tII/s255"},"text":"Pub. L. 99–554, title II, § 255","children":[],"tail":", title III, § 302(f), "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3108"},"text":"100 Stat. 3108","children":[],"tail":", 3124; "},{"tag":"ref","attrib":{"href":"/us/pl/103/65/s1"},"text":"Pub. L. 103–65, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-06"},"text":"Aug. 6, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/311"},"text":"107 Stat. 311","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dC/tI/s149/a"},"text":"Pub. L. 105–277, div. C, title I, § 149(a)","children":[],"tail":", "},{"tag