{"tag":"section","attrib":{"id":"idd394c8ef-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s749"},"text":null,"children":[{"tag":"num","attrib":{"value":"749"},"text":"§ 749.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voidable transfers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd394c8f0-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s749/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as otherwise provided in this section, any transfer of property that, but for such transfer, would have been customer property, may be avoided by the trustee, and such property shall be treated as customer property, if and to the extent that the trustee avoids such transfer under section 544, 545, 547, 548, or 549 of this title. For the purpose of such sections, the property so transferred shall be deemed to have been property of the debtor and, if such transfer was made to a customer or for a customer’s benefit, such customer shall be deemed, for the purposes of this section, to have been a creditor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd394c8f1-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s749/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding sections 544, 545, 547, 548, and 549 of this title, the trustee may not avoid a transfer made before seven days after the order for relief if such transfer is approved by the Commission by rule or order, either before or after such transfer, and if such transfer is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd394c8f2-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s749/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a transfer of a securities contract entered into or carried by or through the debtor on behalf of a customer, and of any cash, security, or other property margining or securing such securities contract; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd394c8f3-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s749/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the liquidation of a securities contract entered into or carried by or through the debtor on behalf of a customer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd394c8f4-3a6f-11f1-8dc6-9561437cf370"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2614"},"text":"92 Stat. 2614","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/222/s14"},"text":"Pub. L. 97–222, § 14","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-07-27"},"text":"July 27, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/238"},"text":"96 Stat. 238","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/16/s2/8"},"text":"Pub. L. 111–16, § 2(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-05-07"},"text":"May 7, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1607"},"text":"123 Stat. 1607","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd394c8f5-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idd394c8f6-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd394c8f7-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"senate report no. 95–989","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 749 indicates that if the trustee avoids a transfer, property recovered is customer property to any extent it would have been customer property but for the transfer. The section clarifies that a customer who receives a transfer of property of the debtor is a creditor and that property in a customer’s account is property of a creditor for purposes of the avoiding powers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd394c8f8-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd394c8f9-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/16"},"text":"Pub. L. 111–16","children":[],"tail":" substituted “seven days” for “five days” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/222"},"text":"Pub. L. 97–222","children":[],"tail":" substituted “(a) Except as otherwise provided in this section, any” for “Any”, and “but” for “except”, inserted “such property”, substituted “or 549” for “549, or 724(a)”, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd394c8fa-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd394c8fb-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/16"},"text":"Pub. L. 111–16","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2009-12-01"},"text":"Dec. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/16/s7"},"text":"section 7 of Pub. L. 111–16","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s109"},"text":"section 109 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
