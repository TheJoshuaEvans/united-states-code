{"tag":"section","attrib":{"id":"idd3bfa93a-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1511"},"text":null,"children":[{"tag":"num","attrib":{"value":"1511"},"text":"§ 1511.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commencement of case under section 301, 302, or 303","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd3bfa93b-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1511/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Upon recognition, a foreign representative may commence—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd3bfa93c-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1511/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an involuntary case under section 303; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3bfa93d-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1511/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a voluntary case under section 301 or 302, if the foreign proceeding is a foreign main proceeding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3bfa93e-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1511/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The petition commencing a case under subsection (a) must be accompanied by a certified copy of an order granting recognition. The court where the petition for recognition has been filed must be advised of the foreign representative’s intent to commence a case under subsection (a) prior to such commencement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd3bfa93f-3a6f-11f1-8dc6-9561437cf370"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/tVIII/s801/a"},"text":"Pub. L. 109–8, title VIII, § 801(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/138"},"text":"119 Stat. 138","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/327/s2/a/45"},"text":"Pub. L. 111–327, § 2(a)(45)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-22"},"text":"Dec. 22, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3562"},"text":"124 Stat. 3562","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd3bfa940-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd3bfa941-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd3bfa942-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/327"},"text":"Pub. L. 111–327","children":[],"tail":" inserted “, 302,” after “301” in section catchline."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd3bfa943-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd3bfa944-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 180 days after ","children":[{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", and not applicable with respect to cases commenced under this title before such effective date, except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/8/s1501"},"text":"section 1501 of Pub. L. 109–8","children":[],"tail":", set out as an Effective Date of 2005 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
