{"tag":"section","attrib":{"id":"idd3baeeb9-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1307"},"text":null,"children":[{"tag":"num","attrib":{"value":"1307"},"text":"§ 1307.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conversion or dismissal","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd3baeeba-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1307/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The debtor may convert a case under this chapter to a case under chapter 7 of this title at any time. Any waiver of the right to convert under this subsection is unenforceable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3baeebb-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1307/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" On request of the debtor at any time, if the case has not been converted under section 706, 1112, or 1208 of this title, the court shall dismiss a case under this chapter. Any waiver of the right to dismiss under this subsection is unenforceable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3baeebc-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1307/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in subsection (f) of this section, on request of a party in interest or the United States trustee and after notice and a hearing, the court may convert a case under this chapter to a case under chapter 7 of this title, or may dismiss a case under this chapter, whichever is in the best interests of creditors and the estate, for cause, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd3baeebd-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1307/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unreasonable delay by the debtor that is prejudicial to creditors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3baeebe-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1307/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nonpayment of any fees and charges required under chapter 123 of title 28;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3baeebf-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1307/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" failure to file a plan timely under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s1321"},"text":"section 1321 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3baeec0-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1307/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" failure to commence making timely payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s1326"},"text":"section 1326 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3baeec1-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1307/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" denial of confirmation of a plan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s1325"},"text":"section 1325 of this title","children":[],"tail":" and denial of a request made for additional time for filing another plan or a modification of a plan;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3baeec2-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1307/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" material default by the debtor with respect to a term of a confirmed plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3baeec3-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1307/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" revocation of the order of confirmation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s1330"},"text":"section 1330 of this title","children":[],"tail":", and denial of confirmation of a modified plan under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s1329"},"text":"section 1329 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3baeec4-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1307/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" termination of a confirmed plan by reason of the occurrence of a condition specified in the plan other than completion of payments under the plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3baeec5-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1307/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" only on request of the United States trustee, failure of the debtor to file, within fifteen days, or such additional time as the court may allow, after the filing of the petition commencing such case, the information required by paragraph (1) of section 521(a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3baeec6-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1307/c/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" only on request of the United States trustee, failure to timely file the information required by paragraph (2) of section 521(a); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3baeec7-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1307/c/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" failure of the debtor to pay any domestic support obligation that first becomes payable after the date of the filing of the petition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3baeec8-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1307/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsection (f) of this section, at any time before the confirmation of a plan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s1325"},"text":"section 1325 of this title","children":[],"tail":", on request of a party in interest or the United States trustee and after notice and a hearing, the court may convert a case under this chapter to a case under chapter 11 or 12 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3baeec9-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1307/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon the failure of the debtor to file a tax return under section 1308, on request of a party in interest or the United States trustee and after notice and a hearing, the court shall dismiss a case or convert a case under this chapter to a case under chapter 7 of this title, whichever is in the best interest of the creditors and the estate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3baeeca-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1307/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The court may not convert a case under this chapter to a case under chapter 7, 11, or 12 of this title if the debtor is a farmer, unless the debtor requests such conversion.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3baeecb-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1307/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of this section, a case may not be converted to a case under another chapter of this title unless the debtor may be a debtor under such chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd3baeecc-3a6f-11f1-8dc6-9561437cf370"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2647"},"text":"92 Stat. 2647","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/353/tIII"},"text":"Pub. L. 98–353, title III","children":[],"tail":", §§ 315, 527, "},{"tag":"date","attrib":{"date":"1984-07-10"},"text":"July 10, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/356"},"text":"98 Stat. 356","children":[],"tail":", 389; "},{"tag":"ref","attrib":{"href":"/us/pl/99/554/tII"},"text":"Pub. L. 99–554, title II","children":[],"tail":", §§ 229, 257(v), "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3103"},"text":"100 Stat. 3103","children":[],"tail":", 3116; "},{"tag":"ref","attrib":{"href":"/us/pl/109/8/tII/s213/7"},"text":"Pub. L. 109–8, title II, § 213(7)","children":[],"tail":", title VII, § 716(c), "},{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/53"},"text":"119 Stat. 53","children":[],"tail":", 130; "},{"tag":"ref","attrib":{"href":"/us/pl/111/327/s2/a/41"},"text":"Pub. L. 111–327, § 2(a)(41)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-22"},"text":"Dec. 22, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3562"},"text":"124 Stat. 3562","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd3baeecd-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idd3baeece-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd3baeecf-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"legislative statements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 1307(a) is derived from the Senate amendment in preference to a comparable provision contained in the House bill.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd3baeed0-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"senate report no. 95–989","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsections (a) and (b) confirm, without qualification, the rights of a chapter 13 debtor to convert the case to a liquidating bankruptcy case under chapter 7 of title 11, at any time, or to have the chapter 13 case dismissed. Waiver of any such right is unenforceable. Subsection (c) specifies various conditions for the exercise of the power of the court to convert a chapter 13 case to one under chapter 7 or to dismiss the case. Subsection (d) deals with the conversion of a chapter 13 case to one under chapter 11. Subsection (e) prohibits conversion of the chapter 13 case filed by a farmer to chapter 7 or 11 except at the request of the debtor. No case is to be converted from chapter 13 to any other chapter, unless the debtor is an eligible debtor under the new chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd3baeed1-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"house report no. 95–595","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsection (f) reinforces section 109 by prohibiting conversion to a chapter under which the debtor is not eligible to proceed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd3baeed2-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd3baeed3-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/327/s2/a/41/A/i"},"text":"Pub. L. 111–327, § 2(a)(41)(A)(i)","children":[],"tail":", substituted “subsection (f)” for “subsection (e)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(9), (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/327/s2/a/41/A/ii"},"text":"Pub. L. 111–327, § 2(a)(41)(A)(ii)","children":[],"tail":", (iii), substituted “521(a)” for “521”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/327/s2/a/41/B"},"text":"Pub. L. 111–327, § 2(a)(41)(B)","children":[],"tail":", substituted “subsection (f)” for “subsection (e)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (c)(11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/s213/7"},"text":"Pub. L. 109–8, § 213(7)","children":[],"tail":", added par. (11)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e) to (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/s716/c"},"text":"Pub. L. 109–8, § 716(c)","children":[],"tail":", added subsec. (e) and redesignated former subsecs. (e) and (f) as (f) and (g), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/554/s257/v/1"},"text":"Pub. L. 99–554, § 257(v)(1)","children":[],"tail":", inserted reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s1208"},"text":"section 1208 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/554/s229/1/A"},"text":"Pub. L. 99–554, § 229(1)(A)","children":[],"tail":", inserted “or the United States trustee” after “party in interest” in provisions preceding par. (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(9), (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/554/s229/1/B"},"text":"Pub. L. 99–554, § 229(1)(B)","children":[],"tail":"–(D), added pars. (9) and (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/554/s257/v/2"},"text":"Pub. L. 99–554, § 257(v)(2)","children":[],"tail":", inserted reference to chapter 12."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/554/s229/2"},"text":"Pub. L. 99–554, § 229(2)","children":[],"tail":", inserted “or the United States trustee” after “party in interest”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/554/s257/v/3"},"text":"Pub. L. 99–554, § 257(v)(3)","children":[],"tail":", inserted reference to chapter 12."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/353/s527/a"},"text":"Pub. L. 98–353, § 527(a)","children":[],"tail":", inserted a comma after “time”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/353/s315/2"},"text":"Pub. L. 98–353, § 315(2)","children":[],"tail":", added par. (4). Former par. (4) redesignated (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/353"},"text":"Pub. L. 98–353","children":[],"tail":", §§ 315(1), 527(b)(1), redesignated former par. (4) as (5) and inserted “a request made for” before “additional”. Former par. (5) redesignated (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/353/s315/1"},"text":"Pub. L. 98–353, § 315(1)","children":[],"tail":", redesignated former par. (5) as (6). Former par. (6) redesignated (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/353"},"text":"Pub. L. 98–353","children":[],"tail":", §§ 315(1), 527(b)(2), redesignated former par. (6) as (7) and substituted “or” for “and”. Former par. (7) redesignated (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/353"},"text":"Pub. L. 98–353","children":[],"tail":", §§ 315(1), 527(b)(3), redesignated former par. (7) as (8) and inserted “other than completion of payments under the plan” after “in the plan”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd3baeed4-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd3baeed5-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2005 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8"},"text":"Pub. L. 109–8","children":[],"tail":" effective 180 days after "},{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", and not applicable with respect to cases commenced under this title before such effective date, except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/8/s1501"},"text":"section 1501 of Pub. L. 109–8","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd3baeed6-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Effective date and applicability of amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/554/s229"},"text":"section 229 of Pub. L. 99–554","children":[],"tail":" dependent upon the judicial district involved, see section 302(d), (e) of "},{"tag":"ref","attrib":{"href":"/us/pl/99/554"},"text":"Pub. L. 99–554","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s581"},"text":"section 581 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/554/s257"},"text":"section 257 of Pub. L. 99–554","children":[],"tail":" effective 30 days after "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", but not applicable to cases commenced under this title before that date, see section 302(a), (c)(1) of "},{"tag":"ref","attrib":{"href":"/us/pl/99/554"},"text":"Pub. L. 99–554","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd3baeed7-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/353"},"text":"Pub. L. 98–353","children":[],"tail":" effective with respect to cases filed 90 days after "},{"tag":"date","attrib":{"date":"1984-07-10"},"text":"July 10, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/353/s552/a"},"text":"section 552(a) of Pub. L. 98–353","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
