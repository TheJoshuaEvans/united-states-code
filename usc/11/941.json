{"tag":"section","attrib":{"id":"idd39bf489-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s941"},"text":null,"children":[{"tag":"num","attrib":{"value":"941"},"text":"§ 941.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Filing of plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The debtor shall file a plan for the adjustment of the debtor’s debts. If such a plan is not filed with the petition, the debtor shall file such a plan at such later time as the court fixes.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd39bf48a-3a6f-11f1-8dc6-9561437cf370"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2624"},"text":"92 Stat. 2624","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd39bf48b-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idd39bf48c-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd39bf48d-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"senate report no. 95–989","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 941 gives the debtor the exclusive right to propose a plan, and directs that the debtor propose one either with the petition or within such time as the court directs. The section follows section 90(a) of current law [section 410(a) of former title 11].","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
