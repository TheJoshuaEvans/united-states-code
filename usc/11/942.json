{"tag":"section","attrib":{"id":"idd39bf48e-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s942"},"text":null,"children":[{"tag":"num","attrib":{"value":"942"},"text":"§ 942.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modification of plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The debtor may modify the plan at any time before confirmation, but may not modify the plan so that the plan as modified fails to meet the requirements of this chapter. After the debtor files a modification, the plan as modified becomes the plan.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd39bf48f-3a6f-11f1-8dc6-9561437cf370"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2624"},"text":"92 Stat. 2624","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd39bf490-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idd39bf491-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd39bf492-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"legislative statements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The House amendment deletes section 942 of the Senate amendment in favor of incorporating section 1125 by cross-reference. Similarly, the House amendment does not incorporate section 944 or 945 of the Senate amendment since incorporation of several sections in chapter 11 in section 901 is sufficient.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd39bf493-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"senate report no. 95–989","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 942 permits the debtor to modify the plan at any time before confirmation, as does section 90(a) of current law [section 410(a) of former title 11].","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
