{"tag":"section","attrib":{"id":"idd3b3c34d-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1205"},"text":null,"children":[{"tag":"num","attrib":{"value":"1205"},"text":"§ 1205.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adequate protection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd3b3c34e-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1205/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 361 does not apply in a case under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3b3c34f-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1205/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In a case under this chapter, when adequate protection is required under section 362, 363, or 364 of this title of an interest of an entity in property, such adequate protection may be provided by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd3b3c350-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1205/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requiring the trustee to make a cash payment or periodic cash payments to such entity, to the extent that the stay under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s362"},"text":"section 362 of this title","children":[],"tail":", use, sale, or lease under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s363"},"text":"section 363 of this title","children":[],"tail":", or any grant of a lien under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s364"},"text":"section 364 of this title","children":[],"tail":" results in a decrease in the value of property securing a claim or of an entity’s ownership interest in property;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3b63351-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1205/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing to such entity an additional or replacement lien to the extent that such stay, use, sale, lease, or grant results in a decrease in the value of property securing a claim or of an entity’s ownership interest in property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3b63352-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1205/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paying to such entity for the use of farmland the reasonable rent customary in the community where the property is located, based upon the rental value, net income, and earning capacity of the property; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3b63353-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1205/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" granting such other relief, other than entitling such entity to compensation allowable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s503/b/1"},"text":"section 503(b)(1) of this title","children":[],"tail":" as an administrative expense, as will adequately protect the value of property securing a claim or of such entity’s ownership interest in property."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd3b63354-3a6f-11f1-8dc6-9561437cf370"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/554/tII/s255"},"text":"Pub. L. 99–554, title II, § 255","children":[],"tail":", title III, § 302(f), "},{"t