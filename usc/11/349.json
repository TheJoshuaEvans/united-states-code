{"tag":"section","attrib":{"id":"idd356d58a-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s349"},"text":null,"children":[{"tag":"num","attrib":{"value":"349"},"text":"§ 349.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of dismissal","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd356d58b-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s349/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Unless the court, for cause, orders otherwise, the dismissal of a case under this title does not bar the discharge, in a later case under this title, of debts that were dischargeable in the case dismissed; nor does the dismissal of a case under this title prejudice the debtor with regard to the filing of a subsequent petition under this title, except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s109/g"},"text":"section 109(g) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd356d58c-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s349/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Unless the court, for cause, orders otherwise, a dismissal of a case other than under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s742"},"text":"section 742 of this title","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idd356d58d-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s349/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" reinstates—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd356d58e-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s349/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any proceeding or custodianship superseded under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s543"},"text":"section 543 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd356d58f-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s349/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any transfer avoided under section 522, 544, 545, 547, 548, 549, or 724(a) of this title, or preserved under section 510(c)(2), 522(i)(2), or 551 of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd356d590-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s349/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any lien voided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s506/d"},"text":"section 506(d) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd356d591-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s349/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" vacates any order, judgment, or transfer ordered, under section 522(i)(1), 542, 550, or 553 of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd356d592-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s349/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" revests the property of the estate in the entity in which such property was vested immediately before the commencement of the case under this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd356d593-3a6f-11f1-8dc6-9561437cf370"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2569"},"text":"92 Stat. 2569","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/353/tIII/s303"},"text":"Pub. L. 98–353, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-10"},"text":"July 10, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/352"},"text":"98 Stat. 352","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/394/tV/s501/d/6"},"text":"Pub. L. 103–394, title V, § 501(d)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4144"},"text":"108 Stat. 4144","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd356d594-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idd356d595-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd356d596-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"legislative statements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 349(b)(2) of the House amendment adds a cross reference to section 553 to reflect the new right of recovery of setoffs created under that section. Corresponding changes are made throughout the House amendment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd356d597-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"senate report no. 95–989","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsection (a) specifies that unless the court for cause orders otherwise, the dismissal of a case is without prejudice. The debtor is not barred from receiving a discharge in a later case of debts that were dischargeable in the case dismissed. Of course, this subsection refers only to pre-discharge dismissals. If the debtor has already received a discharge and it is not revoked, then the debtor would be barred under section 727(a) from receiving a discharge in a subsequent liquidation case for six years. Dismissal of an involuntary on the merits will generally not give rise to adequate cause so as to bar the debtor from further relief.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b) specifies that the dismissal reinstates proceedings or custodianships that were superseded by the bankruptcy case, reinstates avoided transfers, reinstates voided liens, vacates any order, judgment, or transfer ordered as a result of the avoidance of a transfer, and revests the property of the estate in the entity in which the property was vested at the commencement of the case. The court is permitted to order a different result for cause. The basic purpose of the subsection is to undo the bankruptcy case, as far as practicable, and to restore all property rights to the position in which they were found at the commencement of the case. This does not necessarily encompass undoing sales of property from the estate to a good faith purchaser. Where there is a question over the scope of the subsection, the court will make the appropriate orders to protect rights acquired in reliance on the bankruptcy case.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd356d598-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd356d599-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/394"},"text":"Pub. L. 103–394","children":[],"tail":" substituted “109(g)” for “109(f)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/353"},"text":"Pub. L. 98–353","children":[],"tail":" inserted “; nor does the dismissal of a case under this title prejudice the debtor with regard to the filing of a subsequent petition under this title, except as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s109/f"},"text":"section 109(f) of this title","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd356d59a-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd356d59b-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/394"},"text":"Pub. L. 103–394","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", and not applicable with respect to cases commenced under this title before "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/394/s702"},"text":"section 702 of Pub. L. 103–394","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd356d59c-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/353"},"text":"Pub. L. 98–353","children":[],"tail":" effective with respect to cases filed 90 days after "},{"tag":"date","attrib":{"date":"1984-07-10"},"text":"July 10, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/353/s552/a"},"text":"section 552(a) of Pub. L. 98–353","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
