{"tag":"section","attrib":{"id":"idd3487db4-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s107"},"text":null,"children":[{"tag":"num","attrib":{"value":"107"},"text":"§ 107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public access to papers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd3487db5-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s107/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsections (b) and (c) and subject to section 112, a paper filed in a case under this title and the dockets of a bankruptcy court are public records and open to examination by an entity at reasonable times without charge.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3487db6-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s107/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" On request of a party in interest, the bankruptcy court shall, and on the bankruptcy court’s own motion, the bankruptcy court may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd3487db7-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s107/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protect an entity with respect to a trade secret or confidential research, development, or commercial information; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3487db8-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s107/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protect a person with respect to scandalous or defamatory matter contained in a paper filed in a case under this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3487db9-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s107/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd3487dba-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s107/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The bankruptcy court, for cause, may protect an individual, with respect to the following types of information to the extent the court finds that disclosure of such information would create undue risk of identity theft or other unlawful injury to the individual or the individual’s property:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd3487dbb-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s107/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any means of identification (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1028/d"},"text":"section 1028(d) of title 18","children":[],"tail":") contained in a paper filed, or to be filed, in a case under this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd3487dbc-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s107/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other information contained in a paper described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3487dbd-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s107/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon ex parte application demonstrating cause, the court shall provide access to information protected pursuant to paragraph (1) to an entity acting pursuant to the police or regulatory power of a domestic governmental unit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3487dbe-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s107/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The United States trustee, bankruptcy administrator, trustee, and any auditor serving under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s586/f"},"text":"section 586(f) of title 28","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd3487dbf-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s107/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall have full access to all information contained in any paper filed or submitted in a case under this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd3487dc0-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s107/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not disclose information specifically protected by the court under this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd3487dc1-3a6f-11f1-8dc6-9561437cf370"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2556"},"text":"92 Stat. 2556","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/8/tII"},"text":"Pub. L. 109–8, title II","children":[],"tail":", §§ 233(c), 234(a), (c), "},{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/74"},"text":"119 Stat. 74","children":[],"tail":", 75; "},{"tag":"ref","attrib":{"href":"/us/pl/111/327/s2/a/5"},"text":"Pub. L. 111–327, § 2(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-22"},"text":"Dec. 22, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3557"},"text":"124 Stat. 3557","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd3487dc2-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idd3487dc3-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd3487dc4-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"senate report no. 95–989","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsection (a) of this section makes all papers filed in a bankruptcy case and the dockets of the bankruptcy court public and open to examination at reasonable times without charge. “Docket” includes the claims docket, the proceedings docket, and all papers filed in a case.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b) permits the court, on its own motion, and requires the court, on the request of a party in interest, to protect trade secrets, confidential research, development, or commercial information, and to protect persons against scandalous or defamatory matter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd3487dc5-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd3487dc6-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/327"},"text":"Pub. L. 111–327","children":[],"tail":" substituted “subsections (b) and (c)” for “subsection (b) of this section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/s234/c"},"text":"Pub. L. 109–8, § 234(c)","children":[],"tail":", which directed the substitution of “subsections (b) and (c),” for “subsection (b),”, could not be executed because “subsection (b),” did not appear in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/s233/c"},"text":"Pub. L. 109–8, § 233(c)","children":[],"tail":", inserted “and subject to section 112” after “section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/s234/a"},"text":"Pub. L. 109–8, § 234(a)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd3487dc7-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd3487dc8-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2005 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8"},"text":"Pub. L. 109–8","children":[],"tail":" effective 180 days after "},{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", and not applicable with respect to cases commenced under this title before such effective date, except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/8/s1501"},"text":"section 1501 of Pub. L. 109–8","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
