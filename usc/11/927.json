{"tag":"section","attrib":{"id":"idd39bf460-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s927"},"text":null,"children":[{"tag":"num","attrib":{"value":"927"},"text":"§ 927.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on recourse","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The holder of a claim payable solely from special revenues of the debtor under applicable nonbankruptcy law shall not be treated as having recourse against the debtor on account of such claim pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s1111/b"},"text":"section 1111(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd39bf461-3a6f-11f1-8dc6-9561437cf370"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/597/s7/2"},"text":"Pub. L. 100–597, § 7(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-03"},"text":"Nov. 3, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3029"},"text":"102 Stat. 3029","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd39bf462-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd39bf463-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd39bf464-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 927 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s930"},"text":"section 930 of this title","children":[],"tail":"."}],"tail":"\n"}],"