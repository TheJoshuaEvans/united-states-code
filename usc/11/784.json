{"tag":"section","attrib":{"id":"idd39983d9-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s784"},"text":null,"children":[{"tag":"num","attrib":{"value":"784"},"text":"§ 784.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right to be heard","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Board or a Federal reserve bank (in the case of a clearing bank that is a member of that bank) may raise and may appear and be heard on any issue in a case under this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd39983da-3a6f-11f1-8dc6-9561437cf370"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/5/tI/s112/c/5/B"},"text":"Pub. L. 106–554, § 1(a)(5) [title I, § 112(c)(5)(B)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–395.)"}],"tail":"\n"}],"tail":null}
