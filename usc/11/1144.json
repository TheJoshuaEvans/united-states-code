{"tag":"section","attrib":{"id":"idd3ac965b-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1144"},"text":null,"children":[{"tag":"num","attrib":{"value":"1144"},"text":"§ 1144.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revocation of an order of confirmation","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"On request of a party in interest at any time before 180 days after the date of the entry of the order of confirmation, and after notice and a hearing, the court may revoke such order if and only if such order was procured by fraud. An order under this section revoking an order of confirmation shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd3ac965c-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1144/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contain such provisions as are necessary to protect any entity acquiring rights in good faith reliance on the order of confirmation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3ac965d-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1144/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" revoke the discharge of the debtor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd3ac965e-3a6f-11f1-8dc6-9561437cf370"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2639"},"text":"92 Stat. 2639","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/353/tIII/s515"},"text":"Pub. L. 98–353, title III, § 515","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-10"},"text":"July 10, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/387"},"text":"98 Stat. 387","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd3ac965f-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idd3ac9660-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd3ac9661-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"senate report no. 95–989","children":[],"tail":null},{"tag":"p","attrib":{},"text":"If an order of confirmation was procured by fraud, then the court may revoke the order on request of a party in interest if the request is made before 180 days after the date of the entry of the order of confirmation. The order revoking the order of confirmation must revoke the discharge of the debtor, and contain such provisions as are necessary to protect any entity acquiring rights in good faith reliance on the order of confirmation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd3ac9662-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd3ac9663-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/353"},"text":"Pub. L. 98–353","children":[],"tail":" inserted “if and only” after “revoke such order”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd3ac9664-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd3ac9665-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/353"},"text":"Pub. L. 98–353","children":[],"tail":" effective with respect to cases filed 90 days after "},{"tag":"date","attrib":{"date":"1984-07-10"},"text":"July 10, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/353/s552/a"},"text":"section 552(a) of Pub. L. 98–353","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
