{"tag":"section","attrib":{"id":"idd365062c-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s366"},"text":null,"children":[{"tag":"num","attrib":{"value":"366"},"text":"§ 366.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Utility service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd365062d-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s366/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsections (b) and (c) of this section, a utility may not alter, refuse, or discontinue service to, or discriminate against, the trustee or the debtor solely on the basis of the commencement of a case under this title or that a debt owed by the debtor to such utility for service rendered before the order for relief was not paid when due.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd365062e-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s366/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such utility may alter, refuse, or discontinue service if neither the trustee nor the debtor, within 20 days after the date of the order for relief, furnishes adequate assurance of payment, in the form of a deposit or other security, for service after such date. On request of a party in interest and after notice and a hearing, the court may order reasonable modification of the amount of the deposit or other security necessary to provide adequate assurance of payment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd365062f-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s366/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd3650630-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s366/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd3650631-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s366/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this subsection, the term “assurance of payment” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd3650632-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s366/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a cash deposit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd3650633-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s366/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a letter of credit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd3650634-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s366/c/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certificate of deposit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd3650635-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s366/c/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a surety bond;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd3650636-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s366/c/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a prepayment of utility consumption; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd3650637-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s366/c/1/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" another form of security that is mutually agreed on between the utility and the debtor or the trustee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd3650638-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s366/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this subsection an administrative expense priority shall not constitute an assurance of payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3650639-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s366/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to paragraphs (3) and (4), with respect to a case filed under chapter 11, a utility referred to in subsection (a) may alter, refuse, or discontinue utility service, if during the 30-day period beginning on the date of the filing of the petition, the utility does not receive from the debtor or the trustee adequate assurance of payment for utility service that is satisfactory to the utility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd365063a-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s366/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd365063b-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s366/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" On request of a party in interest and after notice and a hearing, the court may order modification of the amount of an assurance of payment under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd365063c-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s366/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In making a determination under this paragraph whether an assurance of payment is adequate, the court may not consider—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd365063d-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s366/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the absence of security before the date of the filing of the petition;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd365063e-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s366/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the payment by the debtor of charges for utility service in a timely manner before the date of the filing of the petition; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd365063f-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s366/c/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the availability of an administrative expense priority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3650640-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s366/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of law, with respect to a case subject to this subsection, a utility may recover or set off against a security deposit provided to the utility by the debtor before the date of the filing of the petition without notice or order of the court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd3650641-3a6f-11f1-8dc6-9561437cf370"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2578"},"text":"92 Stat. 2578","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/353/tIII/s443"},"text":"Pub. L. 98–353, title III, § 443","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-10"},"text":"July 10, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/373"},"text":"98 Stat. 373","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/8/tIV/s417"},"text":"Pub. L. 109–8, title IV, § 417","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/108"},"text":"119 Stat. 108","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dFF/tX/s1001/h"},"text":"Pub. L. 116–260, div. FF, title X, § 1001(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3221"},"text":"134 Stat. 3221","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd3650642-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idd3650643-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd3650644-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"legislative statements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 366 of the House amendment represents a compromise between comparable provisions contained in H.R. 8200 as passed by the House and the Senate amendment. Subsection (a) is modified so that the applicable date is the date of the order for relief rather than the date of the filing of the petition. Subsection (b) contains a similar change but is otherwise derived from section 366(b) of the Senate amendment, with the exception that a time period for continued service of 20 days rather than 10 days is adopted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd3650645-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"senate report no. 95–989","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This section gives debtors protection from a cut-off of service by a utility because of the filing of a bankruptcy case. This section is intended to cover utilities that have some special position with respect to the debtor, such as an electric company, gas supplier, or telephone company that is a monopoly in the area so that the debtor cannot easily obtain comparable service from another utility. The utility may not alter, refuse, or discontinue service because of the nonpayment of a bill that would be discharged in the bankruptcy case. Subsection (b) protects the utility company by requiring the trustee or the debtor to provide, within ten days, adequate assurance of payment for service provided after the date of the petition.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd3650646-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd3650647-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s1001/h/2"},"text":"Pub. L. 116–260, § 1001(h)(2)","children":[],"tail":", struck out subsec. (d) which read as follows: “Notwithstanding any other provision of this section, a utility may not alter, refuse, or discontinue service to a debtor who does not furnish adequate assurance of payment under this section if the debtor—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) is an individual;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) makes a payment to the utility for any debt owed to the utility for service provided during the 20-day period beginning on the date of the order for relief; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) after the date on which the 20-day period beginning on the date of the order for relief ends, makes a payment to the utility for services provided during the pendency of case when such a payment becomes due.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s1001/h/1"},"text":"Pub. L. 116–260, § 1001(h)(1)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/s417/1"},"text":"Pub. L. 109–8, § 417(1)","children":[],"tail":", substituted “subsections (b) and (c)” for “subsection (b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/s417/2"},"text":"Pub. L. 109–8, § 417(2)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/353"},"text":"Pub. L. 98–353","children":[],"tail":" inserted “of the commencement of a case under this title or” after “basis”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd3650648-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd3650649-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2020 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dFF/tX/s1001/h/2"},"text":"Pub. L. 116–260, div. FF, title X, § 1001(h)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3221"},"text":"134 Stat. 3221","children":[],"tail":", provided that the amendment made by section 1001(h)(2) is effective on the date that is 1 year after "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd365064a-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2005 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8"},"text":"Pub. L. 109–8","children":[],"tail":" effective 180 days after "},{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", and not applicable with respect to cases commenced under this title before such effective date, except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/8/s1501"},"text":"section 1501 of Pub. L. 109–8","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd365064b-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/353"},"text":"Pub. L. 98–353","children":[],"tail":" effective with respect to cases filed 90 days after "},{"tag":"date","attrib":{"date":"1984-07-10"},"text":"July 10, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/353/s552/a"},"text":"section 552(a) of Pub. L. 98–353","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
