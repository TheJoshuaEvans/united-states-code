{"tag":"section","attrib":{"id":"idd39257bd-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s744"},"text":null,"children":[{"tag":"num","attrib":{"value":"744"},"text":"§ 744.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Executory contracts","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s365/d/1"},"text":"section 365(d)(1) of this title","children":[],"tail":", the trustee shall assume or reject, under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s365"},"text":"section 365 of this title","children":[],"tail":", any executory contract of the debtor for the purchase or sale of a security in the ordinary course of the debtor’s business, within a reasonable time after the date of the order for relief, but not to exceed 30 days. If the trustee does not assume such a contract within such time, such contract is rejected."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd39257be-3a6f-11f1-8dc6-9561437cf370"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2613"},"text":"92 Stat. 2613","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/222/s10"},"text":"Pub. L. 97–222, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-07-27"},"text":"July 27, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/238"},"text":"96 Stat. 238","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd39257bf-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idd39257c0-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd39257c1-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"senate report no. 95–989","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 744 instructs the court to give the trustee a reasonable time, not to exceed 30 days, to assume or reject any executory contract of the stockbroker to buy or sell securities. Any contract not assumed within the time fixed by the court is considered to be rejected.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd39257c2-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd39257c3-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/222"},"text":"Pub. L. 97–222","children":[],"tail":" inserted “but” after “relief,”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
