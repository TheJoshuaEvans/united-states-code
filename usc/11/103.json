{"tag":"section","attrib":{"id":"idd343c266-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s103"},"text":null,"children":[{"tag":"num","attrib":{"value":"103"},"text":"§ 103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of chapters","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd343c267-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s1161"},"text":"section 1161 of this title","children":[],"tail":", chapters 1, 3, and 5 of this title apply in a case under chapter 7, 11, 12, or 13 of this title, and this chapter, sections 307, 362("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"), 555 through 557, and 559 through 562 apply in a case under chapter 15."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd343c268-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subchapters I and II of chapter 7 of this title apply only in a case under such chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd343c269-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subchapter III of chapter 7 of this title applies only in a case under such chapter concerning a stockbroker.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd343c26a-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s103/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subchapter IV of chapter 7 of this title applies only in a case under such chapter concerning a commodity broker.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd343c26b-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s103/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Scope of Application","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subchapter V of chapter 7 of this title shall apply only in a case under such chapter concerning the liquidation of an uninsured State member bank, or a corporation organized under section 25A of the Federal Reserve Act, which operates, or operates as, a multilateral clearing organization pursuant to section 409 ","children":[{"tag":"ref","attrib":{"idref":"fn002006"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002006"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of the Federal Deposit Insurance Corporation Improvement Act of 1991."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd343c26c-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s103/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s901"},"text":"section 901 of this title","children":[],"tail":", only chapters 1 and 9 of this title apply in a case under such chapter 9."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd343c26d-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s103/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s901"},"text":"section 901 of this title","children":[],"tail":", subchapters I, II, and III of chapter 11 of this title apply only in a case under such chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd343c26e-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s103/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subchapter IV of chapter 11 of this title applies only in a case under such chapter concerning a railroad.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd343c26f-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s103/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subchapter V of chapter 11 of this title applies only in a case under chapter 11 in which a debtor (as defined in section 1182) elects that subchapter V of chapter 11 shall apply.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd343c270-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s103/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chapter 13 of this title applies only in a case under such chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd343c271-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s103/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chapter 12 of this title applies only in a case under such chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd343c272-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s103/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Chapter 15 applies only in a case under such chapter, except that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd343c273-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s103/l/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sections 1505, 1513, and 1514 apply in all cases under this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd343c274-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s103/l/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 1509 applies whether or not a case under this title is pending.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd343c275-3a6f-11f1-8dc6-9561437cf370"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2555"},"text":"92 Stat. 2555","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/222/s2"},"text":"Pub. L. 97–222, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-07-27"},"text":"July 27, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/235"},"text":"96 Stat. 235","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/353/tIII/s423"},"text":"Pub. L. 98–353, title III, § 423","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-10"},"text":"July 10, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/369"},"text":"98 Stat. 369","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/554/tII/s252"},"text":"Pub. L. 99–554, title II, § 252","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3104"},"text":"100 Stat. 3104","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/5/tI/s112/c/5/A"},"text":"Pub. L. 106–554, § 1(a)(5) [title I, § 112(c)(5)(A)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–394; "},{"tag":"ref","attrib":{"href":"/us/pl/109/8/tVIII/s802/a"},"text":"Pub. L. 109–8, title VIII, § 802(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/145"},"text":"119 Stat. 145","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/327/s2/a/2"},"text":"Pub. L. 111–327, § 2(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-22"},"text":"Dec. 22, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3557"},"text":"124 Stat. 3557","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/54/s4/a/2"},"text":"Pub. L. 116–54, § 4(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-08-23"},"text":"Aug. 23, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1085"},"text":"133 Stat. 1085","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/136/dA/tI/s1113/a/2"},"text":"Pub. L. 116–136, div. A, title I, § 1113(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/311"},"text":"134 Stat. 311","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd3460c66-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idd3460c67-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd3460c68-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"senate report no. 95–989","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 103 prescribes which chapters of the proposed bankruptcy code apply in various cases. All cases, other than cases ancillary to foreign proceedings, are filed under chapter 7, 9, 11, or 13, the operative chapters of the proposed bankruptcy code. The general provisions that apply no matter which chapter a case is filed under are found in chapters 1, 3, and 5. Subsection (a) makes this explicit, with an exception for chapter 9. The other provisions, which are self-explanatory, provide the special rules for Stockbroker Liquidations, Commodity Broker Liquidations, Municipal Debt Adjustments, and Railroad Reorganizations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd3460c69-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd3460c6a-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 25A of the Federal Reserve Act, referred to in subsec. (e), popularly known as the Edge Act, is classified to subchapter II (§ 611 et seq.) of chapter 6 of Title 12, Banks and Banking. For complete classification of this Act to the Code, see Short Title note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s611"},"text":"section 611 of Title 12","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 409 of the Federal Deposit Insurance Corporation Improvement Act of 1991, referred to in subsec. (e), was classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4422"},"text":"section 4422 of Title 12","children":[],"tail":", Banks and Banking, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tVII/s740"},"text":"Pub. L. 111–203, title VII, § 740","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1729"},"text":"124 Stat. 1729","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd3460c6b-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136"},"text":"Pub. L. 116–136","children":[],"tail":" substituted “debtor (as defined in section 1182)” for “small business debtor”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsecs. (i) to (","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"). "},{"tag":"ref","attrib":{"href":"/us/pl/116/54"},"text":"Pub. L. 116–54","children":[],"tail":" added subsec. (i) and redesignated former subsecs. (i) to (k) as (j) to ("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/327"},"text":"Pub. L. 111–327","children":[],"tail":" substituted “362("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")” for “362(n)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/s802/a/1"},"text":"Pub. L. 109–8, § 802(a)(1)","children":[],"tail":", inserted “, and this chapter, sections 307, 362(n), 555 through 557, and 559 through 562 apply in a case under chapter 15” before period."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (k). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/s802/a/2"},"text":"Pub. L. 109–8, § 802(a)(2)","children":[],"tail":", added subsec. (k)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsecs. (e) to (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554"},"text":"Pub. L. 106–554","children":[],"tail":" added subsec. (e) and redesignated former subsecs. (e) to (i) as (f) to (j), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/554/s252/1"},"text":"Pub. L. 99–554, § 252(1)","children":[],"tail":", inserted reference to chapter 12."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/554/s252/2"},"text":"Pub. L. 99–554, § 252(2)","children":[],"tail":", added subsec. (i)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/353"},"text":"Pub. L. 98–353","children":[],"tail":" substituted “stockbroker” for “stockholder”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/222"},"text":"Pub. L. 97–222","children":[],"tail":" struck out “except with respect to section 746(c) which applies to margin payments made by any debtor to a commodity broker or forward contract merchant” after “concerning a commodity broker”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd3460c6c-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text"