{"tag":"section","attrib":{"id":"idd388e16f-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s557"},"text":null,"children":[{"tag":"num","attrib":{"value":"557"},"text":"§ 557.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expedited determination of interests in, and abandonment or other disposition of grain assets","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd388e170-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s557/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section applies only in a case concerning a debtor that owns or operates a grain storage facility and only with respect to grain and the proceeds of grain. This section does not affect the application of any other section of this title to property other than grain and proceeds of grain.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd388e171-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s557/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd388e172-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s557/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “grain” means wheat, corn, flaxseed, grain sorghum, barley, oats, rye, soybeans, other dry edible beans, or rice;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd388e173-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s557/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “grain storage facility” means a site or physical structure regularly used to store grain for producers, or to store grain acquired from producers for resale; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd388e174-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s557/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “producer” means an entity which engages in the growing of grain.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd388e175-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s557/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd388e176-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s557/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding sections 362, 363, 365, and 554 of this title, on the court’s own motion the court may, and on the request of the trustee or an entity that claims an interest in grain or the proceeds of grain the court shall, expedite the procedures for the determination of interests in and the disposition of grain and the proceeds of grain, by shortening to the greatest extent feasible such time periods as are otherwise applicable for such procedures and by establishing, by order, a timetable having a duration of not to exceed 120 days for the completion of the applicable procedure specified in subsection (d) of this section. Such time periods and such timetable may be modified by the court, for cause, in accordance with subsection (f) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd388e177-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s557/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The court shall determine the extent to which such time periods shall be shortened, based upon—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd388e178-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s557/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any need of an entity claiming an interest in such grain or the proceeds of grain for a prompt determination of such interest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd388e179-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s557/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any need of such entity for a prompt disposition of such grain;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd388e17a-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s557/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the market for such grain;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd388e17b-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s557/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conditions under which such grain is stored;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd388e17c-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s557/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs of continued storage or disposition of such grain;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd388e17d-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s557/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the orderly administration of the estate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd388e17e-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s557/c/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriate opportunity for an entity to assert an interest in such grain; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd388e17f-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s557/c/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other considerations as are relevant to the need to expedite such procedures in the case.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd388e180-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s557/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The procedures that may be expedited under subsection (c) of this section include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd388e181-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s557/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the filing of and response to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd388e182-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s557/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a claim of ownership;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd388e183-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s557/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a proof of claim;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd388e184-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s557/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a request for abandonment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd388e185-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s557/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a request for relief from the stay of action against property under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s362/a"},"text":"section 362(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd388e186-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s557/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a request for determination of secured status;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd388e187-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s557/d/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a request for determination of whether such grain or the proceeds of grain—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd388e188-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s557/d/1/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is property of the estate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd388e189-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s557/d/1/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" must be turned over to the estate; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd388e18a-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s557/d/1/F/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be used, sold, or leased; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd388e18b-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s557/d/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other request for determination of an interest in such grain or the proceeds of grain;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd388e18c-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s557/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the disposition of such grain or the proceeds of grain, before or after determination of interests in such grain or the proceeds of grain, by way of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd388e18d-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s557/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sale of such grain;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd388e18e-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s557/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" abandonment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd388e18f-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s557/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" distribution; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd388e190-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s557/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other method as is equitable in the case;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd388e191-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s557/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to sections 701, 702, 703, 1104, 1183, 1202, and 1302 of this title, the appointment of a trustee or examiner and the retention and compensation of any professional person required to assist with respect to matters relevant to the determination of interests in or disposition of such grain or the proceeds of grain; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd388e192-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s557/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the determination of any dispute concerning a matter specified in paragraph (1), (2), or (3) of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd388e193-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s557/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd388e194-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s557/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any governmental unit that has regulatory jurisdiction over the operation or liquidation of the debtor or the debtor’s business shall be given notice of any request made or order entered under subsection (c) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd388e195-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s557/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any such governmental unit may raise, and may appear and be heard on, any issue relating to grain or the proceeds of grain in a case in which a request is made, or an order is entered, under subsection (c) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd388e196-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s557/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The trustee shall consult with such governmental unit before taking any action relating to the disposition of grain in the possession, custody, or control of the debtor or the estate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd388e197-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s557/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The court may extend the period for final disposition of grain or the proceeds of grain under this section beyond 120 days if the court finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd388e198-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s557/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the interests of justice so require in light of the complexity of the case; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd388e199-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s557/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the interests of those claimants entitled to distribution of grain or the proceeds of grain will not be materially injured by such additional delay.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd388e19a-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s557/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Unless an order establishing an expedited procedure under subsection (c) of this section, or determining any interest in or approving any disposition of grain or the proceeds of grain, is stayed pending appeal—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd388e19b-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s557/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reversal or modification of such order on appeal does not affect the validity of any procedure, determination, or disposition that occurs before such reversal or modification, whether or not any entity knew of the pendency of the appeal; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd388e19c-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s557/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" neither the court nor the trustee may delay, due to the appeal of such order, any proceeding in the case in which such order is issued.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd388e19d-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s557/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd388e19e-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s557/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The trustee may recover from grain and the proceeds of grain the reasonable and necessary costs and expenses allowable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s503/b"},"text":"section 503(b) of this title","children":[],"tail":" attributable to preserving or disposing of grain or the proceeds of grain, but may not recover from such grain or the proceeds of grain any other costs or expenses."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd388e19f-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s557/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s326/a"},"text":"section 326(a) of this title","children":[],"tail":", the dollar amounts of money specified in such section include the value, as of the date of disposition, of any grain that the trustee distributes in kind."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd388e1a0-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s557/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In all cases where the quantity of a specific type of grain held by a debtor operating a grain storage facility exceeds ten thousand bushels, such grain shall be sold by the trustee and the assets thereof distributed in accordance with the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd388e1a1-3a6f-11f1-8dc6-9561437cf370"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/353/tIII/s352/a"},"text":"Pub. L. 98–353, title III, § 352(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-10"},"text":"July 10, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/359"},"text":"98 Stat. 359","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/554/tII/s257/p"},"text":"Pub. L. 99–554, title II, § 257(p)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3115"},"text":"100 Stat. 3115","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/54/s4/a/10"},"text":"Pub. L. 116–54, § 4(a)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-08-23"},"text":"Aug. 23, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1086"},"text":"133 Stat. 1086","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd388e1a2-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd388e1a3-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text"