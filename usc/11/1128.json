{"tag":"section","attrib":{"id":"idd3a7dbe1-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1128"},"text":null,"children":[{"tag":"num","attrib":{"value":"1128"},"text":"§ 1128.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confirmation hearing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd3a7dbe2-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1128/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" After notice, the court shall hold a hearing on confirmation of a plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3a7dbe3-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1128/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A party in interest may object to confirmation of a plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd3a7dbe4-3a6f-11f1-8dc6-9561437cf370"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2635"},"text":"92 Stat. 2635","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd3a7dbe5-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idd3a7dbe6-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd3a7dbe7-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"senate report no. 95–989","children":[],"tail":null},{"tag":"p","attrib":{},"text":"[Section 1129 (enacted as section 1128)] Subsection (a) requires that there be a hearing in every case on the confirmation of the plan. Notice is required.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b) permits any party in interest to object to the confirmation of the plan. The Securities and Exchange Commission and indenture trustees, as parties in interest under section 1109, may object to confirmation of the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
