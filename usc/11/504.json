{"tag":"section","attrib":{"id":"idd369e7d8-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s504"},"text":null,"children":[{"tag":"num","attrib":{"value":"504"},"text":"§ 504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sharing of compensation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd369e7d9-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s504/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in subsection (b) of this section, a person receiving compensation or reimbursement under section 503(b)(2) or 503(b)(4) of this title may not share or agree to share—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd369e7da-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s504/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any such compensation or reimbursement with another person; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd369e7db-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s504/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any compensation or reimbursement received by another person under such sections.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd369e7dc-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s504/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd369e7dd-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s504/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member, partner, or regular associate in a professional association, corporation, or partnership may share compensation or reimbursement received under section 503(b)(2) or 503(b)(4) of this title with another member, partner, or regular associate in such association, corporation, or partnership, and may share in any compensation or reimbursement received under such sections by another member, partner, or regular associate in such association, corporation, or partnership.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd369e7de-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s504/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An attorney for a creditor that files a petition under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s303"},"text":"section 303 of this title","children":[],"tail":" may share compensation and reimbursement received under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s503/b/4"},"text":"section 503(b)(4) of this title","children":[],"tail":" with any other attorney contributing to the services rendered or expenses incurred by such creditor’s attorney."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd369e7df-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s504/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section shall not apply with respect to sharing, or agreeing to share, compensation with a bona fide public service attorney referral program that operates in accordance with non-Federal law regulating attorney referral services and with rules of professional responsibility applicable to attorney acceptance of referrals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd369e7e0-3a6f-11f1-8dc6-9561437cf370"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2582"},"text":"92 Stat. 2582","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/8/tIII/s326"},"text":"Pub. L. 109–8, title III, § 326","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/99"},"text":"119 Stat. 99","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd369e7e1-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idd369e7e2-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd369e7e3-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"senate report no. 95–989","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 504 prohibits the sharing of compensation, or fee splitting, among attorneys, other professionals, or trustees. The section provides only two exceptions: partners or associates in the same professional association, partnership, or corporation may share compensation inter se; and attorneys for petitioning creditors that join in a petition commencing an involuntary case may share compensation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd369e7e4-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd369e7e5-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8"},"text":"Pub. L. 109–8","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd369e7e6-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd369e7e7-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2005 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8"},"text":"Pub. L. 109–8","children":[],"tail":" effective 180 days after "},{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", and not applicable with respect to cases commenced under this title before such effective date, except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/8/s1501"},"text":"section 1501 of Pub. L. 109–8","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
