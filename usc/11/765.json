{"tag":"section","attrib":{"id":"idd3973994-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s765"},"text":null,"children":[{"tag":"num","attrib":{"value":"765"},"text":"§ 765.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Customer instructions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd3973995-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s765/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The notice required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s342"},"text":"section 342 of this title","children":[],"tail":" to customers shall instruct each customer—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idd3973996-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s765/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to file a proof of such customer’s claim promptly, and to specify in such claim any specifically identifiable security, property, or commodity contract; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3973997-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s765/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to instruct the trustee of such customer’s desired disposition, including transfer under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s766"},"text":"section 766 of this title","children":[],"tail":" or liquidation, of any commodity contract specifically identified to such customer."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3973998-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s765/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The trustee shall comply, to the extent practicable, with any instruction received from a customer regarding such customer’s desired disposition of any commodity contract specifically identified to such customer. If the trustee has transferred, under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s766"},"text":"section 766 of this title","children":[],"tail":", such a commodity contract, the trustee shall transmit any such instruction to the commodity broker to whom such commodity contract was so transferred."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd3973999-3a6f-11f1-8dc6-9561437cf370"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2619"},"text":"92 Stat. 2619","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/222/s18"},"text":"Pub. L. 97–222, § 18","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-07-27"},"text":"July 27, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/240"},"text":"96 Stat. 240","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/353/tIII/s488"},"text":"Pub. L. 98–353, title III, § 488","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-10"},"text":"July 10, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/383"},"text":"98 Stat. 383","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd397399a-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idd397399b-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For Historical and Revision Notes for this section, see Historical and Revision Notes set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s766"},"text":"section 766 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd397399c-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd397399d-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/353"},"text":"Pub. L. 98–353","children":[],"tail":" substituted “notice required by” for “notice under”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/222"},"text":"Pub. L. 97–222","children":[],"tail":" substituted “commodity contract” for “commitment”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd397399e-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd397399f-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/353"},"text":"Pub. L. 98–353","children":[],"tail":" effective with respect to cases filed 90 days after "},{"tag":"date","attrib":{"date":"1984-07-10"},"text":"July 10, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/353/s552/a"},"text":"section 552(a) of Pub. L. 98–353","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
