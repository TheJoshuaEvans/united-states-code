{"tag":"section","attrib":{"id":"idd3a56a32-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1121"},"text":null,"children":[{"tag":"num","attrib":{"value":"1121"},"text":"§ 1121.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Who may file a plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd3a56a33-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1121/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The debtor may file a plan with a petition commencing a voluntary case, or at any time in a voluntary case or an involuntary case.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3a56a34-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1121/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as otherwise provided in this section, only the debtor may file a plan until after 120 days after the date of the order for relief under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3a56a35-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1121/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any party in interest, including the debtor, the trustee, a creditors’ committee, an equity security holders’ committee, a creditor, an equity security holder, or any indenture trustee, may file a plan if and only if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd3a56a36-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1121/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a trustee has been appointed under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3a56a37-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1121/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the debtor has not filed a plan before 120 days after the date of the order for relief under this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3a56a38-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1121/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the debtor has not filed a plan that has been accepted, before 180 days after the date of the order for relief under this chapter, by each class of claims or interests that is impaired under the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3a56a39-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1121/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd3a56a3a-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1121/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to paragraph (2), on request of a party in interest made within the respective periods specified in subsections (b) and (c) of this section and after notice and a hearing, the court may for cause reduce or increase the 120-day period or the 180-day period referred to in this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3a56a3b-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1121/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd3a56a3c-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1121/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The 120-day period specified in paragraph (1) may not be extended beyond a date that is 18 months after the date of the order for relief under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd3a56a3d-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1121/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The 180-day period specified in paragraph (1) may not be extended beyond a date that is 20 months after the date of the order for relief under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3a56a3e-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1121/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In a small business case—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd3a56a3f-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1121/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" only the debtor may file a plan until after 180 days after the date of the order for relief, unless that period is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd3a56a40-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1121/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" extended as provided by this subsection, after notice and a hearing; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd3a56a41-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1121/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the court, for cause, orders otherwise;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3a56a42-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1121/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plan and a disclosure statement (if any) shall be filed not later than 300 days after the date of the order for relief; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3a56a43-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1121/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the time periods specified in paragraphs (1) and (2), and the time fixed in section 1129(e) within which the plan shall be confirmed, may be extended only if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd3a56a44-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1121/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the debtor, after providing notice to parties in interest (including the United States trustee), demonstrates by a preponderance of the evidence that it is more likely than not that the court will confirm a plan within a reasonable period of time;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd3a56a45-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1121/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a new deadline is imposed at the time the extension is granted; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd3a56a46-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1121/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the order extending time is signed before the existing deadline has expired.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd3a56a47-3a6f-11f1-8dc6-9561437cf370"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2631"},"text":"92 Stat. 2631","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/353/tIII/s506"},"text":"Pub. L. 98–353, title III, § 506","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-10"},"text":"July 10, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/385"},"text":"98 Stat. 385","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/554/tII/s283/u"},"text":"Pub. L. 99–554, title II, § 283(u)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3118"},"text":"100 Stat. 3118","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/394/tII/s217/d"},"text":"Pub. L. 103–394, title II, § 217(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4127"},"text":"108 Stat. 4127","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/8/tIV"},"text":"Pub. L. 109–8, title IV","children":[],"tail":", §§ 411, 437, "},{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/106"},"text":"119 Stat. 106","children":[],"tail":", 113.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd3a56a48-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idd3a56a49-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd3a56a4a-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"legislative statements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 1121 of the House amendment is derived from section 1121 of the House bill; section 1121(c)(1) will be satisfied automatically in a case under subchapter IV of title 11.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd3a56a4b-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"senate report no. 95–989","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsection (a) permits the debtor to file a reorganization plan with a petition commencing a voluntary case or at any time during a voluntary or involuntary case.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b) gives the debtor the exclusive right to file a plan during the first 120 days of the case. There are exceptions, however, enumerated in subsection (c). If a trustee has been appointed, if the debtor does not meet the 120-day deadline, or if the debtor fails to obtain the required consent within 180 days after the filing of the petition, any party in interest may propose a plan. This includes the debtor, the trustee, a creditors’ committee, an equity security holders’ committee, a creditor, an equity security holder, and an indenture trustee. The list is not exhaustive. In the case of a public company, a trustee is appointed within 10 days of the petition. In such a case, for all practical purposes, any party in interest may file a plan.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (d) permits the court, for cause, to increase or reduce the 120-day and 180-day periods specified. Since, the debtor has an exclusive privilege for 6 months during which others may not file a plan, the granted extension should be based on a showing of some promise of probable success. An extension should not be employed as a tactical device to put pressure on parties in interest to yield to a plan they consider unsatisfactory.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd3a56a4c-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd3a56a4d-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/s411"},"text":"Pub. L. 109–8, § 411","children":[],"tail":", designated existing provisions as par. (1), substituted “Subject to paragraph (2), on” for “On”, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/s437"},"text":"Pub. L. 109–8, § 437","children":[],"tail":", added subsec. (e) and struck out former subsec. (e) which read as follows: “In a case in which the debtor is a small business and elects to be considered a small business—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) only the debtor may file a plan until after 100 days after the date of the order for relief under this chapter;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) all plans shall be filed within 160 days after the date of the order for relief; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) on request of a party in interest made within the respective periods specified in paragraphs (1) and (2) and after notice and a hearing, the court may—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) reduce the 100-day period or the 160-day period specified in paragraph (1) or (2) for cause; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) increase the 100-day period specified in paragraph (1) if the debtor shows that the need for an increase is caused by circumstances for which the debtor should not be held accountable.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/394"},"text":"Pub. L. 103–394","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/554"},"text":"Pub. L. 99–554","children":[],"tail":" inserted reference to subsection (b) of this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/353/s506/a"},"text":"Pub. L. 98–353, § 506(a)","children":[],"tail":", substituted “of claims or interests that is” for “the claims or interests of which are”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/353/s506/b"},"text":"Pub. L. 98–353, § 506(b)","children":[],"tail":", inserted “made within the respective periods specified in subsection (c) of this section”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd3a56a4e-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd3a56a4f-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2005 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8"},"text":"Pub. L. 109–8","children":[],"tail":" effective 180 days after "},{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", and not applicable with respect to cases commenced under this title before such effective date, except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/8/s1501"},"text":"section 1501 of Pub. L. 109–8","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd3a56a50-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/394"},"text":"Pub. L. 103–394","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", and not applicable with respect to cases commenced under this title before "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/394/s702"},"text":"section 702 of Pub. L. 103–394","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd3a56a51-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/554"},"text":"Pub. L. 99–554","children":[],"tail":" effective 30 days after "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/554/s302/a"},"text":"section 302(a) of Pub. L. 99–554","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s581"},"text":"section 581 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd3a56a52-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/353"},"text":"Pub. L. 98–353","children":[],"tail":" effective with respect to cases filed 90 days after "},{"tag":"date","attrib":{"date":"1984-07-10"},"text":"July 10, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/353/s552/a"},"text":"section 552(a) of Pub. L. 98–353","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
