{"tag":"section","attrib":{"id":"idd3bfa8d9-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1501"},"text":null,"children":[{"tag":"num","attrib":{"value":"1501"},"text":"§ 1501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose and scope of application","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd3bfa8da-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1501/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The purpose of this chapter is to incorporate the Model Law on Cross-Border Insolvency so as to provide effective mechanisms for dealing with cases of cross-border insolvency with the objectives of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd3bfa8db-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1501/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" cooperation between—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd3bfa8dc-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1501/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" courts of the United States, United States trustees, trustees, examiners, debtors, and debtors in possession; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd3bfa8dd-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1501/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the courts and other competent authorities of foreign countries involved in cross-border insolvency cases;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3bfa8de-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1501/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" greater legal certainty for trade and investment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3bfa8df-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1501/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fair and efficient administration of cross-border insolvencies that protects the interests of all creditors, and other interested entities, including the debtor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3bfa8e0-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1501/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protection and maximization of the value of the debtor’s assets; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3bfa8e1-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1501/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitation of the rescue of financially troubled businesses, thereby protecting investment and preserving employment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3bfa8e2-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1501/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" This chapter applies where—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd3bfa8e3-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1501/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance is sought in the United States by a foreign court or a foreign representative in connection with a foreign proceeding;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3bfa8e4-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1501/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance is sought in a foreign country in connection with a case under this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3bfa8e5-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1501/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a foreign proceeding and a case under this title with respect to the same debtor are pending concurrently; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3bfa8e6-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1501/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" creditors or other interested persons in a foreign country have an interest in requesting the commencement of, or participating in, a case or proceeding under this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3bfa8e7-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1501/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" This chapter does not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd3bfa8e8-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1501/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a proceeding concerning an entity, other than a foreign insurance company, identified by exclusion in section 109(b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3bfa8e9-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1501/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual, or to an individual and such individual’s spouse, who have debts within the limits specified in section 109(e) and who are citizens of the United States or aliens lawfully admitted for permanent residence in the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3bfa8ea-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1501/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an entity subject to a proceeding under the Securities Investor Protection Act of 1970, a stockbroker subject to subchapter III of chapter 7 of this title, or a commodity broker subject to subchapter IV of chapter 7 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3bfa8eb-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1501/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The court may not grant relief under this chapter with respect to any deposit, escrow, trust fund, or other security required or permitted under any applicable State insurance law or regulation for the benefit of claim holders in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd3bfa8ec-3a6f-11f1-8dc6-9561437cf370"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/tVIII/s801/a"},"text":"Pub. L. 109–8, title VIII, § 801(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/135"},"text":"119 Stat. 135","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd3bfa8ed-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd3bfa8ee-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd3bfa8ef-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Securities Investor Protection Act of 1970, referred to in subsec. (c)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/598"},"text":"Pub. L. 91–598","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-30"},"text":"Dec. 30, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1636"},"text":"84 Stat. 1636","children":[],"tail":", which is classified generally to chapter 2B–1 (§ 78aaa et seq.) of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78aaa"},"text":"section 78aaa of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd3bfa8f0-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1501, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2652"},"text":"92 Stat. 2652","children":[],"tail":", related to applicability of chapter which provided a pilot program for a United States trustee system, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/554/tII/s231"},"text":"Pub. L. 99–554, title II, § 231","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3103"},"text":"100 Stat. 3103","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd3bfa8f1-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd3bfa8f2-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 180 days after ","children":[{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", and not applicable with respect to cases commenced under this title before such effective date, except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/8/s1501"},"text":"section 1501 of Pub. L. 109–8","children":[],"tail":", set out as an Effective Date of 2005 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
