{"tag":"section","attrib":{"id":"idd3b6335a-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1206"},"text":null,"children":[{"tag":"num","attrib":{"value":"1206"},"text":"§ 1206.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sales free of interests","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"After notice and a hearing, in addition to the authorization contained in section 363(f), the trustee in a case under this chapter may sell property under section 363(b) and (c) free and clear of any interest in such property of an entity other than the estate if the property is farmland, farm equipment, or property used to carry out a commercial fishing operation (including a commercial fishing vessel), except that the proceeds of such sale shall be subject to such interest.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd3b6335b-3a6f-11f1-8dc6-9561437cf370"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/554/tII/s255"},"text":"Pub. L. 99–554, title II, § 255","children":[],"tail":", title III, § 302(f), "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3108"},"text":"100 Stat. 3108","children":[],"tail":", 3124; "},{"tag":"ref","attrib":{"href":"/us/pl/103/65/s1"},"text":"Pub. L. 103–65, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-06"},"text":"Aug. 6, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/311"},"text":"107 Stat. 311","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dC/tI/s149/a"},"text":"Pub. L. 105–277, div. C, title I, § 149(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-610"},"text":"112 Stat. 2681–610","ch