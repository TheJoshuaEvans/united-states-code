dren":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-19"},"text":"Dec. 19, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/3115"},"text":"116 Stat. 3115","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/73/s2/a"},"text":"Pub. L. 108–73, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-08-15"},"text":"Aug. 15, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/891"},"text":"117 Stat. 891","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/369/s2/a"},"text":"Pub. L. 108–369, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-25"},"text":"Oct. 25, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1749"},"text":"118 Stat. 1749","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/8/tII/s213/3"},"text":"Pub. L. 109–8, title II, § 213(3)","children":[],"tail":", (4), title X, §§ 1001(a)(1), (c), 1003(a), "},{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/52"},"text":"119 Stat. 52","children":[],"tail":", 185, 186; "},{"tag":"ref","attrib":{"href":"/us/pl/115/72/dB/s1005/b/1/A"},"text":"Pub. L. 115–72, div. B, § 1005(b)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-10-26"},"text":"Oct. 26, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1233"},"text":"131 Stat. 1233","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd3b633a7-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd3b633a8-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd3b633a9-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For repeal of section effective ","children":[{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", and subsequent reenactment of section, see note set out preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s1201"},"text":"section 1201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd3b633aa-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/72/s1005/b/1/A/i"},"text":"Pub. L. 115–72, § 1005(b)(1)(A)(i)","children":[],"tail":", substituted “unless” for “unless—”, struck out subpar. (B) designation before “the holder”, and struck out subpar. (A) which read as follows: “the claim is a claim owed to a governmental unit that arises as a result of the sale, transfer, exchange, or other disposition of any farm asset used in the debtor’s farming operation, in which case the claim shall be treated as an unsecured claim that is not entitled to priority under section 507, but the debt shall be treated in such manner only if the debtor receives a discharge; or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/72/s1005/b/1/A/ii"},"text":"Pub. L. 115–72, § 1005(b)(1)(A)(ii)","children":[],"tail":"–(iv), added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/s1003/a"},"text":"Pub. L. 109–8, § 1003(a)","children":[],"tail":", amended par. (2) generally. Prior to amendment, par. (2) read as follows: “provide for the full payment, in deferred cash payments, of all claims entitled to priority under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s507"},"text":"section 507 of this title","children":[],"tail":", unless the holder of a particular claim agrees to a different treatment of such claim;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/s213/3"},"text":"Pub. L. 109–8, § 213(3)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(11), (12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/s213/4"},"text":"Pub. L. 109–8, § 213(4)","children":[],"tail":", added par. (11) and redesignated former par. (11) as (12)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/394"},"text":"Pub. L. 103–394","children":[],"tail":" added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd3b633ab-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd3b633ac-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/72/dB/s1005/c"},"text":"Pub. L. 115–72, div. B, § 1005(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-10-26"},"text":"Oct. 26, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1234"},"text":"131 Stat. 1234","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/72/dB/s1005/c"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The amendments made by this section [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s1232"},"text":"section 1232 of this title","children":[],"tail":" and amending this section and sections 1228 and 1229 of this title] shall apply to—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any bankruptcy case—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is pending on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2017-10-26"},"text":"Oct. 26, 2017","children":[],"tail":"];"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in which the plan under chapter 12 of title 11, United States Code, has not been confirmed on the date of enactment of this Act; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relating to which an order of discharge under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s1228"},"text":"section 1228 of title 11","children":[],"tail":", United States Code, has not been entered; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any bankruptcy case that commences on or after the date of enactment of this Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib