{"tag":"section","attrib":{"id":"idd3bfa962-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1515"},"text":null,"children":[{"tag":"num","attrib":{"value":"1515"},"text":"§ 1515.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application for recognition","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd3bfa963-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1515/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A foreign representative applies to the court for recognition of a foreign proceeding in which the foreign representative has been appointed by filing a petition for recognition.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3bfa964-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1515/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A petition for recognition shall be accompanied by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd3bfa965-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1515/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certified copy of the decision commencing such foreign proceeding and appointing the foreign representative;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3bfa966-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1515/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certificate from the foreign court affirming the existence of such foreign proceeding and of the appointment of the foreign representative; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3bfa967-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1515/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the absence of evidence referred to in paragraphs (1) and (2), any other evidence acceptable to the court of the existence of such foreign proceeding and of the appointment of the foreign representative.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3bfa968-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1515/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A petition for recognition shall also be accompanied by a statement identifying all foreign proceedings with respect to the debtor that are known to the foreign representative.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3bfa969-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1515/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The documents referred to in paragraphs (1) and (2) of subsection (b) shall be translated into English. The court may require a translation into English of additional documents.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd3bfa96a-3a6f-11f1-8dc6-9561437cf370"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/tVIII/s801/a"},"text":"Pub. L. 109–8, title VIII, § 801(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/139"},"text":"119 Stat. 139","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd3bfa96b-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd3bfa96c-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd3bfa96d-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 180 days after ","children":[{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", and not applicable with respect to cases commenced under this title before such effective date, except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/8/s1501"},"text":"section 1501 of Pub. L. 109–8","children":[],"tail":", set out as an Effective Date of 2005 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
