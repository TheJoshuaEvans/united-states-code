{"tag":"section","attrib":{"id":"idd34fa950-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s325"},"text":null,"children":[{"tag":"num","attrib":{"value":"325"},"text":"§ 325.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of vacancy","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A vacancy in the office of trustee during a case does not abate any pending action or proceeding, and the successor trustee shall be substituted as a party in such action or proceeding.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd34fa951-3a6f-11f1-8dc6-9561437cf370"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2562"},"text":"92 Stat. 2562","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd34fa952-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idd34fa953-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd34fa954-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"senate report no. 95–989","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 325, derived from Bankruptcy Act section 46 [section 74 of former title 11] and Bankruptcy Rule 221(b), specifies that a vacancy in the office of trustee during a case does not abate any pending action or proceeding. The successor trustee, when selected and qualified, is substituted as a party in any pending action or proceeding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
