{"tag":"section","attrib":{"id":"idd39bf467-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s928"},"text":null,"children":[{"tag":"num","attrib":{"value":"928"},"text":"§ 928.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Post petition effect of security interest","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd39bf468-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s928/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s552/a"},"text":"section 552(a) of this title","children":[],"tail":" and subject to subsection (b) of this section, special revenues acquired by the debtor after the commencement of the case shall remain subject to any lien resulting from any security agreement entered into by the debtor before the commencement of the case."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd39bf469-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s928/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any such lien on special revenues, other than municipal betterment assessments, derived from a project or system shall be subject to the necessary operating expenses of such project or system, as the case may be.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd39bf46a-3a6f-11f1-8dc6-9561437cf370"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/597/s8"},"text":"Pub. L. 100–597, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-03"},"text":"Nov. 3, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3029"},"text":"102 Stat. 3029","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd39bf46b-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd39bf46c-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd39bf46d-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1988-11-03"},"text":"Nov. 3, 1988","children":[],"tail":", but not applicable to any case commenced under this title before that date, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/597/s12"},"text":"section 12 of Pub. L. 100–597","children":[],"tail":", set out as an Effective Date of 1988 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
