{"tag":"section","attrib":{"id":"idd3af07a2-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1161"},"text":null,"children":[{"tag":"num","attrib":{"value":"1161"},"text":"§ 1161.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inapplicability of other sections","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Sections 341, 343, 1102(a)(1), 1104, 1105, 1107, 1129(a)(7), and 1129(c) of this title do not apply in a case concerning a railroad.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd3af07a3-3a6f-11f1-8dc6-9561437cf370"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2641"},"text":"92 Stat. 2641","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd3af07a4-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idd3af07a5-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd3af07a6-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"senate report no. 95–989","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This section makes inapplicable sections of the bill which are either inappropriate in railroad reorganizations, or relate to matters which are otherwise dealt with in subchapter IV.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
