{"tag":"section","attrib":{"id":"idd3b178a6-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1187"},"text":null,"children":[{"tag":"num","attrib":{"value":"1187"},"text":"§ 1187.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties and reporting requirements of debtors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd3b178a7-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1187/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Filing Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Upon electing to be a debtor under this subchapter, the debtor shall file the documents required by subparagraphs (A) and (B) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s1116/1"},"text":"section 1116(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3b178a8-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1187/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other Applicable Provisions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A debtor, in addition to the duties provided in this title and as otherwise required by law, shall comply with the requirements of section 308 and paragraphs (2), (3), (4), (5), (6), and (7) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s1116"},"text":"section 1116 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3b178a9-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1187/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Separate Disclosure Statement Exemption","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the court orders under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s1181/b"},"text":"section 1181(b) of this title","children":[],"tail":" that "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s1125"},"text":"section 1125 of this title","children":[],"tail":" applies, "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s1125/f"},"text":"section 1125(f) of this title","children":[],"tail":" shall apply."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd3b3c29a-3a6f-11f1-8dc6-9561437cf370"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/54/s2/a"},"text":"Pub. L. 116–54, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-08-23"},"text":"Aug. 23, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1081"},"text":"133 Stat. 1081","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd3b3c29b-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd3b3c29c-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd3b3c29d-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 180 days after ","children":[{"tag":"date","attrib":{"date":"2019-08-23"},"text":"Aug. 23, 2019","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/116/54/s5"},"text":"section 5 of Pub. L. 116–54","children":[],"tail":", set out as an Effective Date of 2019 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
