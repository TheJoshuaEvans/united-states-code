{"tag":"section","attrib":{"id":"idd3ac964d-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1142"},"text":null,"children":[{"tag":"num","attrib":{"value":"1142"},"text":"§ 1142.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation of plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd3ac964e-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1142/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any otherwise applicable nonbankruptcy law, rule, or regulation relating to financial condition, the debtor and any entity organized or to be organized for the purpose of carrying out the plan shall carry out the plan and shall comply with any orders of the court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3ac964f-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1142/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The court may direct the debtor and any other necessary party to execute or deliver or to join in the execution or delivery of any instrument required to effect a transfer of property dealt with by a confirmed plan, and to perform any other act, including the satisfaction of any lien, that is necessary for the consummation of the plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd3ac9650-3a6f-11f1-8dc6-9561437cf370"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2639"},"text":"92 Stat. 2639","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/353/tIII/s514/a"},"text":"Pub. L. 98–353, title III, § 514(a)","children":[],"tail":", (c), (d), "},{"tag":"date","attrib":{"date":"1984-07-10"},"text":"July 10, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/387"},"text":"98 Stat. 387","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd3ac9651-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd3ac9652-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd3ac9653-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/353/s514/a"},"text":"Pub. L. 98–353, § 514(a)","children":[],"tail":", substituted “Implementation” for “Execution” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/353/s514/c"},"text":"Pub. L. 98–353, § 514(c)","children":[],"tail":", struck out the comma after “shall carry out the plan”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/353/s514/d"},"text":"Pub. L. 98–353, § 514(d)","children":[],"tail":", inserted “a” after “by”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd3ac9654-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd3ac9655-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/353"},"text":"Pub. L. 98–353","children":[],"tail":" effective with respect to cases filed 90 days after "},{"tag":"date","attrib":{"date":"1984-07-10"},"text":"July 10, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/353/s552/a"},"text":"section 552(a) of Pub. L. 98–353","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
