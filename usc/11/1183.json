{"tag":"section","attrib":{"id":"idd3b17877-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1183"},"text":null,"children":[{"tag":"num","attrib":{"value":"1183"},"text":"§ 1183.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trustee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd3b17878-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1183/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the United States trustee has appointed an individual under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s586/b"},"text":"section 586(b) of title 28","children":[],"tail":" to serve as standing trustee in cases under this subchapter, and if such individual qualifies as a trustee under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s322"},"text":"section 322 of this title","children":[],"tail":", then that individual shall serve as trustee in any case under this subchapter. Otherwise, the United States trustee shall appoint one disinterested person to serve as trustee in the case or the United States trustee may serve as trustee in the case, as necessary."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3b17879-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1183/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The trustee shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd3b1787a-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1183/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform the duties specified in paragraphs (2), (5), (6), (7), and (9) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s704/a"},"text":"section 704(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3b1787b-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1183/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform the duties specified in paragraphs (3), (4), and (7) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s1106/a"},"text":"section 1106(a) of this title","children":[],"tail":", if the court, for cause and on request of a party in interest, the trustee, or the United States trustee, so orders;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3b1787c-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1183/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" appear and be heard at the status conference under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s1188"},"text":"section 1188 of this title","children":[],"tail":" and any hearing that concerns—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd3b1787d-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1183/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the value of property subject to a lien;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd3b1787e-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1183/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" confirmation of a plan filed under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd3b1787f-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1183/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modification of the plan after confirmation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd3b17880-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1183/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sale of property of the estate;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3b17881-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1183/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the debtor commences making timely payments required by a plan confirmed under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3b17882-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1183/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the debtor ceases to be a debtor in possession—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd3b17883-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1183/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform the duties specified in section 704(a)(8) and paragraphs (1), (2), and (6) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s1106/a"},"text":"section 1106(a) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd3b17884-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1183/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be authorized to operate the business of the debtor;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3b17885-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1183/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if there is a claim for a domestic support obligation with respect to the debtor, perform the duties specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s704/c"},"text":"section 704(c) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3b17886-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1183/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate the development of a consensual plan of reorganization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3b17887-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1183/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination of Trustee Service.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idd3b17888-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1183/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the plan of the debtor is confirmed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s1191/a"},"text":"section 1191(a) of this title","children":[],"tail":", the service of the trustee in the case shall terminate when the plan has been substantially consummated, except that the United States trustee may reappoint a trustee as needed for performance of duties under subsection (b)(3)(C) of this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s1185/a"},"text":"section 1185(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3b17889-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1183/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Service of notice of substantial consummation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 14 days after the plan of the debtor is substantially consummated, the debtor shall file with the court and serve on the trustee, the United States trustee, and all parties in interest notice of such substantial consummation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd3b1788a-3a6f-11f1-8dc6-9561437cf370"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/54/s2/a"},"text":"Pub. L. 116–54, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-08-23"},"text":"Aug. 23, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1079"},"text":"133 Stat. 1079","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/151/s2/e"},"text":"Pub. L. 117–151, § 2(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-06-21"},"text":"June 21, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1299"},"text":"136 Stat. 1299","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd3b1788b-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd3b1788c-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd3b1788d-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/151"},"text":"Pub. L. 117–151","children":[],"tail":" substituted “possession—” for “possession,”, designated remainder of existing provisions as subpar. (A), struck out “, including operating the business of the debtor” after “1106(a) of this title”, inserted “and” at end, and added subpar. (B)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd3b1788e-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd3b1788f-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/151"},"text":"Pub. L. 117–151","children":[],"tail":" applicable with respect to any case that is commenced under this title on or after "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", and with respec