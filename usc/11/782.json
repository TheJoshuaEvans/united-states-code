{"tag":"section","attrib":{"id":"idd39983c3-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s782"},"text":null,"children":[{"tag":"num","attrib":{"value":"782"},"text":"§ 782.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of trustee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd39983c4-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s782/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idd39983c5-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s782/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of this title, the conservator or receiver who files the petition shall be the trustee under this chapter, unless the Board designates an alternative trustee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd39983c6-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s782/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Successor","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Board may designate a successor trustee if required.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd39983c7-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s782/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority of Trustee","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whenever the Board appoints or designates a trustee, chapter 3 and sections 704 and 705 of this title shall apply to the Board in the same way and to the same extent that they apply to a United States trustee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd39983c8-3a6f-11f1-8dc6-9561437cf370"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/5/tI/s112/c/5/B"},"text":"Pub. L. 106–554, § 1(a)(5) [title I, § 112(c)(5)(B)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–394.)"}],"tail":"\n"}],"tail":null}
