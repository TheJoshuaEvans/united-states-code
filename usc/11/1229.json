d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/s1006/b"},"text":"Pub. L. 109–8, § 1006(b)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd3b87d1b-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd3b87d1c-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/72"},"text":"Pub. L. 115–72","children":[],"tail":" applicable to bankruptcy cases pending on "},{"tag":"date","attrib":{"date":"2017-10-26"},"text":"Oct. 26, 2017","children":[],"tail":", in which the plan under this chapter has not been confirmed on "},{"tag":"date","attrib":{"date":"2017-10-26"},"text":"Oct. 26, 2017","children":[],"tail":", and relating to which an order of discharge under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s1228"},"text":"section 1228 of this title","children":[],"tail":" has not been entered, and to bankruptcy cases that commence on or after "},{"tag":"date","attrib":{"date":"2017-10-26"},"text":"Oct. 26, 2017","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/72/s1005/c"},"text":"section 1005(c) of Pub. L. 115–72","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s1222"},"text":"section 1222 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd3b87d1d-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2005 Amendm