{"tag":"section","attrib":{"id":"idd3b87d08-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1229"},"text":null,"children":[{"tag":"num","attrib":{"value":"1229"},"text":"§ 1229.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modification of plan after confirmation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd3b87d09-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1229/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" At any time after confirmation of the plan but before the completion of payments under such plan, the plan may be modified, on request of the debtor, the trustee, or the holder of an allowed unsecured claim, to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd3b87d0a-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1229/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase or reduce the amount of payments on claims of a particular class provided for by the plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3b87d0b-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1229/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" extend or reduce the time for such payments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3b87d0c-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1229/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alter the amount of the distribution to a creditor whose claim is provided for by the plan to the extent necessary to take account of any payment of such claim other than under the plan; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3b87d0d-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1229/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the payment of a claim described in section 1232(a) that arose after the date on which the petition was filed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3b87d0e-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1229/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd3b87d0f-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1229/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sections 1222(a), 1222(b), and 1223(c) of this title and the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s1225/a"},"text":"section 1225(a) of this title","children":[],"tail":" apply to any modification under subsection (a) of this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3b87d10-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1229/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The plan as modified becomes the plan unless, after notice and a hearing, such modification is disapproved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3b87d11-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1229/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A plan modified under this section may not provide for payments over a period that expires after three years after the time that the first payment under the original confirmed plan was due, unless the court, for cause, approves a longer period, but the court may not approve a period that expires after five years after such time.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3b87d12-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1229/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A plan may not be modified under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd3b87d13-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1229/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase the amount of any payment due before the plan as modified becomes the plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3b87d14-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1229/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by anyone except the debtor, based on an increase in the debtor’s disposable income, to increase the amount of payments to unsecured creditors required for a particular month so that the aggregate of such payments exceeds the debtor’s disposable income for such month; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3b87d15-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1229/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the last year of the plan by anyone except the debtor, to require payments that would leave the debtor with insufficient funds to carry on the farming operation after the plan is completed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd3b87d16-3a6f-11f1-8dc6-9561437cf370"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/554/tII/s255"},"text":"Pub. L. 99–554, title II, § 255","children":[],"tail":", title III, § 302(f), "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3113"},"text":"100 Stat. 3113","children":[],"tail":", 3124; "},{"tag":"ref","attrib":{"href":"/us/pl/103/65/s1"},"text":"Pub. L. 103–65, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-06"},"text":"Aug. 6, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/311"},"text":"107 Stat. 311","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dC/tI/s149/a"},"text":"Pub. L. 105–277, div. C, title I, § 149(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-610"},"text":"112 Stat. 2681–610","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/5/s1/1"},"text":"Pub. L. 106–5, § 1(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"1999-03-30"},"text":"Mar. 30, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/9"},"text":"113 Stat. 9","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/70/s1"},"text":"Pub. L. 106–70, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-09"},"text":"Oct. 9, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1031"},"text":"113 Stat. 1031","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/8/s1"},"text":"Pub. L. 107–8, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-05-11"},"text":"May 11, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/10"},"text":