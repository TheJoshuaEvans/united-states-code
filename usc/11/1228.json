rib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/72/s1005/b/1/B/ii"},"text":"Pub. L. 115–72, § 1005(b)(1)(B)(ii)","children":[],"tail":", inserted “, except as provided in section 1232(c)” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/s330/c/1"},"text":"Pub. L. 109–8, § 330(c)(1)","children":[],"tail":", substituted “Subject to subsection (d), as” for “As” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/s213/6"},"text":"Pub. L. 109–8, § 213(6)","children":[],"tail":", inserted “, and in the case of a debtor who is required by a judicial or administrative order, or by statute, to pay a domestic support obligation, after such debtor certifies that all amounts payable under such order or such statute that are due on or before the date of the certification (including amounts due before the petition was filed, but only to the extent provided for by the plan) have been paid” after “completion by the debtor of all payments under the plan” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/s330/c/2"},"text":"Pub. L. 109–8, § 330(c)(2)","children":[],"tail":", substituted “Subject to subsection (d), at” for “At” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/s330/c/3"},"text":"Pub. L. 109–8, § 330(c)(3)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsecs. (a), (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/518"},"text":"Pub. L. 106–518","children":[],"tail":" substituted “1222(b)(9)” for “1222(b)(10)” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd3b87d04-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd3b87d05-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/72"},"text":"Pub. L. 115–72","children":[],"tail":" applicable to bankruptcy cases pending on "},{"tag":"date","attrib":{"date":"2017-10-26"},"text":"Oct. 26, 2017","children":[],"tail":", in which the plan under this chapter has not been confirmed on "},{"tag":"date","attrib":{"date":"2017-10-26"},"text":"Oct. 26, 2017","children":[],"tail":", and relating to which an order of discharge under this section has not been entered, and to bankruptcy cases that commence on or after "},{"tag":"date","attrib":{"date":"2017-10-26"},"text":"Oct. 26, 2017","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/72/s1005/c"},"text":"section 1005(c) of Pub. L. 115–72","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s1222"},"text":"section 1222 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd3b87d06-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2005 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendments by sections 213(6) and 330(c) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8"},"text":"Pub. L. 109–8","children":[],"tail":" effective 180 days after "},{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", with amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/109/8/s213/6"},"text":"section 213(6) of Pub. L. 109–8","children":[],"tail":" not applicable with respect to cases commenced under this title before such effective date, except as otherwise provided, and amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/109/8/s330/c"},"text":"section 330(c) of Pub. L. 109–8","children":[],"tail":" applicable with respect to cases commenced under this title on or after "},{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/8/s1501"},"text":"section 1501 of Pub. L. 109–8","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd3b87d07-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Dates","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Permanent reenactment of section effective ","children":[{"tag":"date","attrib":{"date":"2005-07-01"},"text":"July 1, 2005","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/8/s1001/a/2"},"text":"section 1001(a)(2) of Pub. L. 109–8","children":[],"tail":", set out as a Repeal, Reenactment, and Termination of Chapter note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s1201"},"text":"section 1201 of this title","children":[],"tail":". For effective dates of section and amendments extending periods for which section was reenacted prior to permanent reenactment, see Effective Date and Effective Date of 1999, 2001, 2002, 2003, and 2004 Amendment notes set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s1201"},"text":"section 1201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
