{"tag":"section","attrib":{"id":"idd38b531b-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s704"},"text":null,"children":[{"tag":"num","attrib":{"value":"704"},"text":"§ 704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of trustee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd38b531c-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s704/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The trustee shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd38b531d-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s704/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect and reduce to money the property of the estate for which such trustee serves, and close such estate as expeditiously as is compatible with the best interests of parties in interest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd38b531e-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s704/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be accountable for all property received;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd38b531f-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s704/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the debtor shall perform his intention as specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s521/a/2/B"},"text":"section 521(a)(2)(B) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd38b5320-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s704/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" investigate the financial affairs of the debtor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd38b5321-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s704/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if a purpose would be served, examine proofs of claims and object to the allowance of any claim that is improper;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd38b5322-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s704/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if advisable, oppose the discharge of the debtor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd38b5323-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s704/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unless the court orders otherwise, furnish such information concerning the estate and the estate’s administration as is requested by a party in interest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd38b5324-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s704/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the business of the debtor is authorized to be operated, file with the court, with the United States trustee, and with any governmental unit charged with responsibility for collection or determination of any tax arising out of such operation, periodic reports and summaries of the operation of such business, including a statement of receipts and disbursements, and such other information as the United States trustee or the court requires;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd38b5325-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s704/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make a final report and file a final account of the administration of the estate with the court and with the United States trustee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd38b5326-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s704/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if with respect to the debtor there is a claim for a domestic support obligation, provide the applicable notice specified in subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd38b5327-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s704/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if, at the time of the commencement of the case, the debtor (or any entity designated by the debtor) served as the administrator (as defined in section 3 of the Employee Retirement Income Security Act of 1974) of an employee benefit plan, continue to perform the obligations required of the administrator; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd38b5328-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s704/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" use all reasonable and best efforts to transfer patients from a health care business that is in the process of being closed to an appropriate health care business that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd38b5329-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s704/a/12/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in the vicinity of the health care business that is closing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd38b532a-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s704/a/12/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides the patient with services that are substantially similar to those provided by the health care business that is in the process of being closed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd38b532b-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s704/a/12/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintains a reasonable quality of care.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd38b532c-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s704/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd38b532d-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s704/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" With respect to a debtor who is an individual in a case under this chapter—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd38b532e-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s704/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States trustee (or the bankruptcy administrator, if any) shall review all materials filed by the debtor and, not later than 10 days after the date of the first meeting of creditors, file with the court a statement as to whether the debtor’s case would be presumed to be an abuse under section 707(b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd38b532f-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s704/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 7 days after receiving a statement under subparagraph (A), the court shall provide a copy of the statement to all creditors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd38b5330-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s704/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The United States trustee (or bankruptcy administrator, if any) shall, not later than 30 days after the date of filing a statement under paragraph (1), either file a motion to dismiss or convert under section 707(b) or file a statement setting forth the reasons the United States trustee (or the bankruptcy administrator, if any) does not consider such a motion to be appropriate, if the United States trustee (or the bankruptcy administrator, if any) determines that the debtor’s case should be presumed to be an abuse under section 707(b) and the product of the debtor’s current monthly income, multiplied by 12 is not less than—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd38b5331-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s704/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a debtor in a household of 1 person, the median family income of the applicable State for 1 earner; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd38b5332-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s704/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a debtor in a household of 2 or more individuals, the highest median family income of the applicable State for a family of the same number or fewer individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd38b5333-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s704/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd38b5334-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s704/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In a case described in subsection (a)(10) to which subsection (a)(10) applies, the trustee shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd38b5335-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s704/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd38b5336-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s704/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide written notice to the holder of the claim described in subsection (a)(10) of such claim and of the right of such holder to use the services of the State child support enforcement agency established under sections 464 and 466 of the Social Security Act for the State in which such holder resides, for assistance in collecting child support during and after the case under this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd38b5337-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s704/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include in the notice provided under clause (i) the address and telephone number of such State child support enforcement agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd38b5338-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s704/c/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include in the notice provided under clause (i) an explanation of the rights of such holder to payment of such claim under this chapter;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd38b5339-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s704/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd38b533a-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s704/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide written notice to such State child support enforcement agency of such claim; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd38b533b-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s704/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include in the notice provided under clause (i) the name, address, and telephone number of such holder; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd38b533c-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s704/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" at such time as the debtor is granted a discharge under section 727, provide written notice to such holder and to such State child support enforcement agency of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd38b533d-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s704/c/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the granting of the discharge;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd38b533e-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s704/c/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the last recent known address of the debtor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd38b533f-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s704/c/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the last recent known name and address of the debtor’s employer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd38b5340-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s704/c/1/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the name of each creditor that holds a claim that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idd38b5341-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s704/c/1/C/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not discharged under paragraph (2), (4), or (14A) of section 523(a); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd38b5342-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s704/c/1/C/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was reaffirmed by the debtor under section 524(c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd38b5343-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s704/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd38b5344-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s704/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The holder of a claim described in subsection (a)(10) or the State child support enforcement agency of the State in which such holder resides may request from a creditor described in paragraph (1)(C)(iv) the last known address of the debtor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd38b5345-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s704/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of law, a creditor that makes a disclosure of a last known address of a debtor in connection with a request made under subparagraph (A) shall not be liable by reason of making such disclosure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd38b5346-3a6f-11f1-8dc6-9561437cf370"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2605"},"text":"92 Stat. 2605","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/353/tIII"},"text":"Pub. L. 98–353, title III","children":[],"tail":", §§ 311(a), 474, "},{"tag":"date","attrib":{"date":"1984-07-10"},"text":"July 10, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/355"},"text":"98 Stat. 355","children":[],"tail":", 381; "},{"tag":"ref","attrib":{"href":"/us/pl/99/554/tII/s217"},"text":"Pub. L. 99–554, title II, § 217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3100"},"text":"100 Stat. 3100","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/8/tI/s102/c"},"text":"Pub. L. 109–8, title I, § 102(c)","children":[],"tail":", title II, § 219(a), title IV, § 446(b), title XI, § 1105(a), "},{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/32"},"text":"119 Stat. 32","children":[],"tail":", 55, 118, 192; "},{"tag":"ref","attrib":{"href":"/us/pl/111/16/s2/7"},"text":"Pub. L. 111–16, § 2(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-05-07"},"text":"May 7, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1607"},"text":"123 Stat. 1607","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/327/s2/a/24"},"text":"Pub. L. 111–327, § 2(a)(24)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-22"},"text":"Dec. 22, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3560"},"text":"124 Stat. 3560","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd38b5347-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idd38b5348-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd38b5349-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"legislative statements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 704(8) of the Senate amendment is deleted in the House amendment. Trustees should give constructive notice of the commencement of the case in the manner specified under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s549/c"},"text":"section 549(c) of title 11","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd38b534a-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"senate report no. 95–989","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The essential duties of the trustee are enumerated in this section. Others, or elaborations on these, may be prescribed by the Rules of Bankruptcy Procedure to the extent not inconsistent with those prescribed by this section. The duties are derived from section 47a of the Bankruptcy Act [section 75(a) of former title 11].","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The trustee’s principal duty is to collect and reduce to money the property of the estate for which he serves, and to close up the estate as expeditiously as is compatible with the best interests of parties in interest. He must be accountable for all property received, and must investigate the financial affairs of the debtor. If a purpose would be served (such as if there are assets that will be distributed), the trustee is required to examine proofs of claims and object to the allowance of any claim that is improper. If advisable, the trustee must oppose the discharge of the debtor, which is for the benefit of general unsecured creditors whom the trustee represents.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The trustee is responsible to furnish such information concerning the estate and its administration as is requested by a party in interest. If the business of the debtor is authorized to be operated, then the trustee is required to file with governmental units charged with the responsibility for collection or determination of any tax arising out of the operation of the business periodic reports and summaries of the operation, including a statement of receipts and disbursements, and such other information as the court requires. He is required to give constructive notice of the commencement of the case in the manner specified under section 342(b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd38b534b-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd38b534c-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 3 of the Employee Retirement Income Security Act of 1974, referred to in subsec. (a)(11), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1002"},"text":"section 1002 of Title 29","children":[],"tail":", Labor."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Sections 464 and 466 of the Social Security Act, referred to in subsec. (c)(1)(A)(i), are classified to sections 664 and 666, respectively, of Title 42, The Public Health and Welfare.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd38b534d-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/327"},"text":"Pub. L. 111–327","children":[],"tail":" substituted “521(a)(2)(B)” for “521(2)(B)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/16"},"text":"Pub. L. 111–16","children":[],"tail":" substituted “7 days” for “5 days”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/s102/c/1"},"text":"Pub. L. 109–8, § 102(c)(1)","children":[],"tail":", designated existing provisions as subsec. (a)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/s219/a/1"},"text":"Pub. L. 109–8, § 219(a)(1)","children":[],"tail":", added par. (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/s446/b"},"text":"Pub. L. 109–8, § 446(b)","children":[],"tail":", added par. (11)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/s1105/a"},"text":"Pub. L. 109–8, § 1105(a)","children":[],"tail":", added par. (12)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/s102/c/2"},"text":"Pub. L. 109–8, § 102(c)(2)","children":[],"tail":", added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/s219/a/2"},"text":"Pub. L. 109–8, § 219(a)(2)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Par. (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/554/s217/1"},"text":"Pub. L. 99–554, § 217(1)","children":[],"tail":", inserted “, with the United States trustee,” after “with the court” and “the United States trustee or” after “information as”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/554/s217/2"},"text":"Pub. L. 99–554, § 217(2)","children":[],"tail":", inserted “with the United States trustee” after “court”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/353/s474"},"text":"Pub. L. 98–353, § 474","children":[],"tail":", substituted “close such estate” for “close up such estate”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (3) to (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/353/s311/a"},"text":"Pub. L. 98–353, § 311(a)","children":[],"tail":", added par. (3) and redesignated former pars. (3) to (8) as (4) to (9), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd38b534e-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd38b534f-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/16"},"text":"Pub. L. 111–16","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2009-12-01"},"text":"Dec. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/16/s7"},"text":"section 7 of Pub. L. 111–16","children":[],"tail":", set out 