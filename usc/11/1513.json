{"tag":"section","attrib":{"id":"idd3bfa94a-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1513"},"text":null,"children":[{"tag":"num","attrib":{"value":"1513"},"text":"§ 1513.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access of foreign creditors to a case under this title","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd3bfa94b-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1513/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Foreign creditors have the same rights regarding the commencement of, and participation in, a case under this title as domestic creditors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3bfa94c-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1513/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd3bfa94d-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1513/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsection (a) does not change or codify present law as to the priority of claims under section 507 or 726, except that the claim of a foreign creditor under those sections shall not be given a lower priority than that of general unsecured claims without priority solely because the holder of such claim is a foreign creditor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3bfa94e-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1513/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd3bfa94f-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1513/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsection (a) and paragraph (1) do not change or codify present law as to the allowability of foreign revenue claims or other foreign public law claims in a proceeding under this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd3bfa950-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1513/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Allowance and priority as to a foreign tax claim or other foreign public law claim shall be governed by any applicable tax treaty of the United States, under the conditions and circumstances specified therein.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd3bfa951-3a6f-11f1-8dc6-9561437cf370"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/tVIII/s801/a"},"text":"Pub. L. 109–8, title VIII, § 801(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/138"},"text":"119 Stat. 138","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd3bfa952-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd3bfa953-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd3bfa954-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 180 days after ","children":[{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", and not applicable with respect to cases commenced under this title before such effective date, except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/8/s1501"},"text":"section 1501 of Pub. L. 109–8","children":[],"tail":", set out as an Effective Date of 2005 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
