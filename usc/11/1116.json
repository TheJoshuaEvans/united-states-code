{"tag":"section","attrib":{"id":"idd3a3212f-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1116"},"text":null,"children":[{"tag":"num","attrib":{"value":"1116"},"text":"§ 1116.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of trustee or debtor in possession in small business cases","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In a small business case, a trustee or the debtor in possession, in addition to the duties provided in this title and as otherwise required by law, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd3a32130-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1116/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" append to the voluntary petition or, in an involuntary case, file not later than 7 days after the date of the order for relief—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd3a32131-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1116/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" its most recent balance sheet, statement of operations, cash-flow statement, and Federal income tax return; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd3a32132-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1116/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement made under penalty of perjury that no balance sheet, statement of operations, or cash-flow statement has been prepared and no Federal tax return has been filed;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3a32133-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1116/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" attend, through its senior management personnel and counsel, meetings scheduled by the court or the United States trustee, including initial debtor interviews, scheduling conferences, and meetings of creditors convened under section 341 unless the court, after notice and a hearing, waives that requirement upon a finding of extraordinary and compelling circumstances;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3a32134-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1116/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" timely file all schedules and statements of financial affairs, unless the court, after notice and a hearing, grants an extension, which shall not extend such time period to a date later than 30 days after the date of the order for relief, absent extraordinary and compelling circumstances;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3a56a25-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1116/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" file all postpetition financial and other reports required by the Federal Rules of Bankruptcy Procedure or by local rule of the district court;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3a56a26-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1116/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to section 363(c)(2), maintain insurance customary and appropriate to the industry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3a56a27-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1116/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd3a56a28-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1116/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" timely file tax returns and other required government filings; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd3a56a29-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1116/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to section 363(c)(2), timely pay all taxes entitled to administrative expense priority except those being contested by appropriate proceedings being diligently prosecuted; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3a56a2a-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1116/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow the United States trustee, or a designated representative of the United States trustee, to inspect the debtor’s business premises, books, and records at reasonable times, after reasonable prior written notice, unless notice is waived by the debtor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd3a56a2b-3a6f-11f1-8dc6-9561437cf370"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/tIV/s436/a"},"text":"Pub. L. 109–8, title IV, § 436(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/112"},"text":"119 Stat. 112","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd3a56a2c-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd3a56a2d-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd3a56a2e-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Rules of Bankruptcy Procedure, referred to in par. (4), are set out in the Appendix to this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd3a56a2f-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd3a56a30-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 180 days after ","children":[{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", and not applicable with respect to cases commenced under this title before such effective date, except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/8/s1501"},"text":"section 1501 of Pub. L. 109–8","children":[],"tail":", set out as an Effective Date of 2005 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
