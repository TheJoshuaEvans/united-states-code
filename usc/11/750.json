{"tag":"section","attrib":{"id":"idd394c8fc-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s750"},"text":null,"children":[{"tag":"num","attrib":{"value":"750"},"text":"§ 750.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of securities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The trustee may not distribute a security except under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s751"},"text":"section 751 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd394c8fd-3a6f-11f1-8dc6-9561437cf370"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2614"},"text":"92 Stat. 2614","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd394c8fe-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idd394c8ff-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd394c900-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"senate report no. 95–989","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 750 forbids the trustee from distributing a security other than a customer name security. The term “distribution” refers to a distribution to customers in satisfaction of net equity claims and is not intended to preclude the trustee from liquidating securities under proposed ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s748"},"text":"11 U.S.C. 748","children":[],"tail":"."}],"tail":"\