{"tag":"section","attrib":{"id":"idd3b3c29e-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1188"},"text":null,"children":[{"tag":"num","attrib":{"value":"1188"},"text":"§ 1188.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status conference","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd3b3c29f-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1188/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (b), not later than 60 days after the entry of the order for relief under this chapter, the court shall hold a status conference to further the expeditious and economical resolution of a case under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3b3c2a0-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1188/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The court may extend the period of time for holding a status conference under subsection (a) if the need for an extension is attributable to circumstances for which the debtor should not justly be held accountable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3b3c2a1-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1188/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 14 days before the date of the status conference under subsection (a), the debtor shall file with the court and serve on the trustee and all parties in interest a report that details the efforts the debtor has undertaken and will undertake to attain a consensual plan of reorganization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd3b3c2a2-3a6f-11f1-8dc6-9561437cf370"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/54/s2/a"},"text":"Pub. L. 116–54, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-08-23"},"text":"Aug. 23, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1081"},"text":"133 Stat. 1081","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd3b3c2a3-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd3b3c2a4-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd3b3c2a5-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 180 days after ","children":[{"tag":"date","attrib":{"date":"2019-08-23"},"text":"Aug. 23, 2019","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/116/54/s5"},"text":"section 5 of Pub. L. 116–54","children":[],"tail":", set out as an Effective Date of 2019 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
