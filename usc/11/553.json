{"tag":"section","attrib":{"id":"idd388e130-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s553"},"text":null,"children":[{"tag":"num","attrib":{"value":"553"},"text":"§ 553.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Setoff","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd388e131-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s553/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as otherwise provided in this section and in sections 362 and 363 of this title, this title does not affect any right of a creditor to offset a mutual debt owing by such creditor to the debtor that arose before the commencement of the case under this title against a claim of such creditor against the debtor that arose before the commencement of the case, except to the extent that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd388e132-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s553/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the claim of such creditor against the debtor is disallowed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd388e133-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s553/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such claim was transferred, by an entity other than the debtor, to such creditor—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd388e134-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s553/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after the commencement of the case; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd388e135-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s553/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd388e136-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s553/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after 90 days before the date of the filing of the petition; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd388e137-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s553/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while the debtor was insolvent (except for a setoff of a kind described in section 362(b)(6), 362(b)(7), 362(b)(17), 362(b)(27), 555, 556, 559, 560, or 561); or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd388e138-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s553/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the debt owed to the debtor by such creditor was incurred by such creditor—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd388e139-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s553/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after 90 days before the date of the filing of the petition;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd388e13a-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s553/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while the debtor was insolvent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd388e13b-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s553/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the purpose of obtaining a right of setoff against the debtor (except for a setoff of a kind described in section 362(b)(6), 362(b)(7), 362(b)(17), 362(b)(27), 555, 556, 559, 560, or 561).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd388e13c-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s553/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd388e13d-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s553/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except with respect to a setoff of a kind described in section 362(b)(6), 362(b)(7), 362(b)(17), 362(b)(27), 555, 556, 559, 560, 561, 365(h), 546(h), or 365(i)(2) of this title, if a creditor offsets a mutual debt owing to the debtor against a claim against the debtor on or within 90 days before the date of the filing of the petition, then the trustee may recover from such creditor the amount so offset to the extent that any insufficiency on the date of such setoff is less than the insufficiency on the later of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd388e13e-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s553/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 90 days before the date of the filing of the petition; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd388e13f-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s553/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the first date during the 90 days immediately preceding the date of the filing of the petition on which there is an insufficiency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd388e140-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s553/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In this subsection, “insufficiency” means amount, if any, by which a claim against the debtor exceeds a mutual debt owing to the debtor by the holder of such claim.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd388e141-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s553/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purposes of this section, the debtor is presumed to have been insolvent on and during the 90 days immediately preceding the date of the filing of the petition.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd388e142-3a6f-11f1-8dc6-9561437cf370"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2602"},"text":"92 Stat. 2602","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/353/tIII"},"text":"Pub. L. 98–353, title III","children":[],"tail":", §§ 395, 467, "},{"tag":"date","attrib":{"date":"1984-07-10"},"text":"July 10, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/365"},"text":"98 Stat. 365","children":[],"tail":", 380; "},{"tag":"ref","attrib":{"href":"/us/pl/101/311/tI/s105"},"text":"Pub. L. 101–311, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-06-25"},"text":"June 25, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/268"},"text":"104 Stat. 268","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/394/tII"},"text":"Pub. L. 103–394, title II","children":[],"tail":", §§ 205(b), 222(b), title V, § 501(d)(19), "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4123"},"text":"108 Stat. 4123","children":[],"tail":", 4129, 4146; "},{"tag":"ref","attrib":{"href":"/us/pl/109/8/tIX/s907/n"},"text":"Pub. L. 109–8, title IX, § 907(n)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/181"},"text":"119 Stat. 181","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd388e143-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idd388e144-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd388e145-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"legislative statements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 553 of the House amendment is derived from a similar provision contained in the Senate amendment, but is modified to clarify application of a two-point test with respect to setoffs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd388e146-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"senate report no. 95–989","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This section preserves, with some changes, the right of setoff in bankruptcy cases now found in section 68 of the Bankruptcy Act [section 108 of former title 11]. One exception to the right is the automatic stay, discussed in connection with proposed ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s362"},"text":"11 U.S.C. 362","children":[],"tail":". Another is the right of the trustee to use property under section 363 that is subject to a right of setoff."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The section states that the right of setoff is unaffected by the bankruptcy code except to the extent that the creditor’s claim is disallowed, the creditor acquired (other than from the debtor) the claim during the 90 days preceding the case while the debtor was insolvent, the debt being offset was incurred for the purpose of obtaining a right of setoff, while the debtor was insolvent and during the 90-day prebankruptcy period, or the creditor improved his position in the 90-day period (similar to the improvement in position test found in the preference section 547(c)(5)). Only the last exception is an addition to current law.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"As under section 547(f), the debtor is presumed to have been insolvent during the 90 days before the case.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd388e147-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd388e148-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—Subsec. (a)(2)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/s907/n/1"},"text":"Pub. L. 109–8, § 907(n)(1)","children":[],"tail":", inserted “(except for a setoff of a kind described in section 362(b)(6), 362(b)(7), 362(b)(17), 362(b)(27), 555, 556, 559, 560, or 561)” before semicolon."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/s907/n/2"},"text":"Pub. L. 109–8, § 907(n)(2)","children":[],"tail":", inserted “(except for a setoff of a kind described in section 362(b)(6), 362(b)(7), 362(b)(17), 362(b)(27), 555, 556, 559, 560, or 561)” before period."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/s907/n/3"},"text":"Pub. L. 109–8, § 907(n)(3)","children":[],"tail":", substituted “362(b)(17), 362(b)(27), 555, 556, 559, 560, 561,” for “362(b)(14),” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/394/s501/d/19/A"},"text":"Pub. L. 103–394, § 501(d)(19)(A)","children":[],"tail":", struck out before semicolon at end “other than under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s502/b/3"},"text":"section 502(b)(3) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/394/s501/d/19/B"},"text":"Pub. L. 103–394, § 501(d)(19)(B)","children":[],"tail":", substituted “section 362(b)(14),” for “section 362(b)(14),,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/394/s222/b"},"text":"Pub. L. 103–394, § 222(b)","children":[],"tail":", which directed the amendment of section 553(b)(1) by inserting “546(h),” after “365(h),” was executed by making the insertion in "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s553/b/1"},"text":"section 553(b)(1) of this title","children":[],"tail":" to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/394/s205/b"},"text":"Pub. L. 103–394, § 205(b)","children":[],"tail":", substituted “365(h)” for “365(h)(2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/311"},"text":"Pub. L. 101–311","children":[],"tail":" substituted “362(b)(7), 362(b)(14),” for “362(b)(7),”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/353"},"text":"Pub. L. 98–353","children":[],"tail":" inserted “, 362(b)(7),” after “362(b)(6)”, and substituted “, 365(h)(2), or 365(i)(2)” for “or 365(h)(1)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd388e149-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd388e14a-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2005 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8"},"text":"Pub. L. 109–8","children":[],"tail":" effective 180 days after "},{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", and not applicable with respect to cases commenced under this title before such effective date, except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/8/s1501"},"text":"section 1501 of Pub. L. 109–8","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd388e14b-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/394"},"text":"Pub. L. 103–394","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", and not applicable with respect to cases commenced under this title before "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/394/s702"},"text":"section 702 of Pub. L. 103–394","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd388e14c-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/353"},"text":"Pub. L. 98–353","children":[],"tail":" effective with respect to cases filed 90 days after "},{"tag":"date","attrib":{"date":"1984-07-10"},"text":"July 10, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/353/s552/a"},"text":"section 552(a) of Pub. L. 98–353","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
