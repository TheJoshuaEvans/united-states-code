{"tag":"section","attrib":{"id":"idd34fa93e-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s323"},"text":null,"children":[{"tag":"num","attrib":{"value":"323"},"text":"§ 323.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Role and capacity of trustee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd34fa93f-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s323/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The trustee in a case under this title is the representative of the estate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd34fa940-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s323/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The trustee in a case under this title has capacity to sue and be sued.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd34fa941-3a6f-11f1-8dc6-9561437cf370"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2562"},"text":"92 Stat. 2562","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd34fa942-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idd34fa943-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd34fa944-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"senate report no. 95–989","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsection (a) of this section makes the trustee the representative of the estate. Subsection (b) grants the trustee the capacity to sue and to be sued. If the debtor remains in possession in a chapter 11 case, section 1107 gives the debtor in possession these rights of the trustee: the debtor in possession becomes the representative of the estate, and may sue and be sued. The same applies in a chapter 13 case.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
