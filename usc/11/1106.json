{"tag":"section","attrib":{"id":"idd3a0af29-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1106"},"text":null,"children":[{"tag":"num","attrib":{"value":"1106"},"text":"§ 1106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of trustee and examiner","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd3a0af2a-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1106/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A trustee shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd3a0af2b-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1106/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform the duties of the trustee, as specified in paragraphs (2), (5), (7), (8), (9), (10), (11), and (12) of section 704(a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3a0af2c-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1106/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the debtor has not done so, file the list, schedule, and statement required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s521/a/1"},"text":"section 521(a)(1) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3a0af2d-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1106/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except to the extent that the court orders otherwise, investigate the acts, conduct, assets, liabilities, and financial condition of the debtor, the operation of the debtor’s business and the desirability of the continuance of such business, and any other matter relevant to the case or to the formulation of a plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3a0af2e-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1106/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" as soon as practicable—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd3a0af2f-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1106/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" file a statement of any investigation conducted under paragraph (3) of this subsection, including any fact ascertained pertaining to fraud, dishonesty, incompetence, misconduct, mismanagement, or irregularity in the management of the affairs of the debtor, or to a cause of action available to the estate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd3a0af30-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1106/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transmit a copy or a summary of any such statement to any creditors’ committee or equity security holders’ committee, to any indenture trustee, and to such other entity as the court designates;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3a0af31-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1106/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as soon as practicable, file a plan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s1121"},"text":"section 1121 of this title","children":[],"tail":", file a report of why the trustee will not file a plan, or recommend conversion of the case to a case under chapter 7, 12, or 13 of this title or dismissal of the case;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3a0af32-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1106/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any year for which the debtor has not filed a tax return required by law, furnish, without personal liability, such information as may be required by the governmental unit with which such tax return was to be filed, in light of the condition of the debtor’s books and records and the availability of such information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3a0af33-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1106/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after confirmation of a plan, file such reports as are necessary or as the court orders; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3a0af34-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1106/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if with respect to the debtor there is a claim for a domestic support obligation, provide the applicable notice specified in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3a0af35-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1106/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An examiner appointed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s1104/d"},"text":"section 1104(d) of this title","children":[],"tail":" shall perform the duties specified in paragraphs (3) and (4) of subsection (a) of this section, and, except to the extent that the court orders otherwise, any other duties of the trustee that the court orders the debtor in possession not to perform."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3a0af36-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1106/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd3a0af37-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1106/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In a case described in subsection (a)(8) to which subsection (a)(8) applies, the trustee shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd3a0af38-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1106/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd3a0af39-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1106/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide written notice to the holder of the claim described in subsection (a)(8) of such claim and of the right of such holder to use the services of the State child support enforcement agency established under sections 464 and 466 of the Social Security Act for the State in which such holder resides, for assistance in collecting child support during and after the case under this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd3a0af3a-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1106/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include in the notice required by clause (i) the address and telephone number of such State child support enforcement agency;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd3a0af3b-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1106/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd3a0af3c-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1106/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide written notice to such State child support enforcement agency of such claim; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd3a0af3d-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1106/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include in the notice required by clause (i) the name, address, and telephone number of such holder; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd3a0af3e-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1106/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" at such time as the debtor is granted a discharge under section 1141, provide written notice to such holder and to such State child support enforcement agency of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd3a0af3f-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1106/c/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the granting of the discharge;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd3a0af40-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1106/c/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the last recent known address of the debtor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd3a0af41-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1106/c/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the last recent known name and address of the debtor’s employer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd3a0af42-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1106/c/1/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the name of each creditor that holds a claim that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idd3a0af43-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1106/c/1/C/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not discharged under paragraph (2), (4), or (14A) of section 523(a); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd3a0af44-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1106/c/1/C/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was reaffirmed by the debtor under section 524(c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3a0af45-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1106/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd3a0af46-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1106/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The holder of a claim described in subsection (a)(8) or the State child enforcement support agency of the State in which such holder resides may request from a creditor described in paragraph (1)(C)(iv) the last known address of the debtor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd3a0af47-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1106/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of law, a creditor that makes a disclosure of a last known address of a debtor in connection with a request made under subparagraph (A) shall not be liable by reason of making such disclosure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd3a0af48-3a6f-11f1-8dc6-9561437cf370"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2628"},"text":"92 Stat. 2628","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/353/tIII"},"text":"Pub. L. 98–353, title III","children":[],"tail":", §§ 311(b)(1), 502, "},{"tag":"date","attrib":{"date":"1984-07-10"},"text":"July 10, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/355"},"text":"98 Stat. 355","children":[],"tail":", 384; "},{"tag":"ref","attrib":{"href":"/us/pl/99/554/tII/s257/c"},"text":"Pub. L. 99–554, title II, § 257(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3114"},"text":"100 Stat. 3114","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/394/tII/s211/b"},"text":"Pub. L. 103–394, title II, § 211(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4125"},"text":"108 Stat. 4125","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/8/tII/s219/b"},"text":"Pub. L. 109–8, title II, § 219(b)","children":[],"tail":", title IV, § 446(c), title XI, § 1105(b), "},{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/56"},"text":"119 Stat. 56","children":[],"tail":", 118, 192; "},{"tag":"ref","attrib":{"href":"/us/pl/111/327/s2/a/31"},"text":"Pub. L. 111–327, § 2(a)(31)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-22"},"text":"Dec. 22, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3560"},"text":"124 Stat. 3560","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd3a0af49-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idd3a0af4a-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd3a0af4b-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"senate report no. 95–989","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsection (a) of this section prescribes the trustee’s duties. He is required to perform the duties of a trustee in a liquidation case specified in section 704 (2), (4), (6), (7), (8), and (9). These include reporting and informational duties, and accountability for all property received. Paragraph (2) of this subsection requires the trustee to file with the court, if the debtor has not done so, the list of creditors, schedule of assets and liabilities, and statement of affairs required under section 521(1).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Paragraph (3) of S. 1106 requires the trustee to investigate the acts, conduct, assets, liabilities, and financial condition of the debtor, the operation of the debtor’s business, and the desirability of the continuance of the business, and any other matter relevant to the case or to the formulation of a plan. Paragraph (4) requires the trustee to report the results of his investigation to the court and to creditors’ committees, equity security holders’ committees, indenture trustees and any other entity the court designates.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Paragraph (5) requires the trustee to file a plan or to report why a plan cannot be formulated, or to recommend conversion to liquidation or to an individual repayment plan case, or dismissal. It is anticipated that the trustee will consult with creditors and other parties in interest in the formulation of a plan, just as the debtor in possession would.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Paragraph (6) [enacted as (7)] requires final reports by the trustee, as the court orders.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b) gives the trustee’s investigative duties to an examiner, if one is appointed. The court is authorized to give the examiner additional duties as the circumstances warrant.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Paragraphs (3), (4), and (5) of subsection (a) are derived from sections 165 and 169 of chapter X [sections 565 and 569 of former title 11].","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd3a0af4c-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd3a0af4d-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 464 and 466 of the Social Security Act, referred to in subsec. (c)(1)(A)(i), are classified to sections 664 and 666, respectively, of Title 42, The Public Health and Welfare.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd3a0af4e-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/327/s2/a/31/A"},"text":"Pub. L. 111–327, § 2(a)(31)(A)","children":[],"tail":", substituted “704(a)” for “704”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/327/s2/a/31/B"},"text":"Pub. L. 111–327, § 2(a)(31)(B)","children":[],"tail":", substituted “521(a)(1)” for “521(1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/s1105/b"},"text":"Pub. L. 109–8, § 1105(b)","children":[],"tail":", substituted “(11), and (12)” for “and (11)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/s446/c"},"text":"Pub. L. 109–8, § 446(c)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) read as follows: “perform the duties of a trustee specified in sections 704(2), 704(5), 704(7), 704(8), and 704(9) of this title;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/s219/b/1"},"text":"Pub. L. 109–8, § 219(b)(1)","children":[],"tail":", added par. (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/s219/b/2"},"text":"Pub. L. 109–8, § 219(b)(2)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/394"},"text":"Pub. L. 103–394","children":[],"tail":" substituted “1104(d)” for “1104(c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/554"},"text":"Pub. L. 99–554","children":[],"tail":" inserted reference to chapter 12."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/353/s311/b/1"},"text":"Pub. L. 98–353, § 311(b)(1)","children":[],"tail":", substituted “704(5), 704(7), 704(8), and 704(9)” for “704(4), 704(6), 704(7) and 704(8)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/353/s502"},"text":"Pub. L. 98–353, § 502","children":[],"tail":", inserted “, except to the extent that the court orders otherwise,”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd3a0af4f-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd3a0af50-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2005 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8"},"text":"Pub. L. 109–8","children":[],"tail":" effective 180 days after "},{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", and not applicable with respect to cases commenced under this title before such effective date, except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/8/s1501"},"text":"section 1501 of Pub. L. 109–8","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd3a0af51-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/394"},"text":"Pub. L. 103–394","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", and not applicable with respect to cases commenced under this title before "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/394/s702"},"text":"section 702 of Pub. L. 103–394","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd3a0af52-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/554"},"text":"Pub. L. 99–554","children":[],"tail":" effective 30 days after "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", but not applicable to cases commenced under this title before that date, see section 302(a), (c)(1) of "},{"tag":"ref","attrib":{"href":"/us/pl/99/554"},"text":"Pub. L. 99–554","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s581"},"text":"section 581 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd3a0af53-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/353"},"text":"Pub. L. 98–353","children":[],"tail":" effective with respect to cases filed 90 days after "},{"tag":"date","attrib":{"date":"1984-07-10"},"text":"July 10, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/353/s552/a"},"text":"section 552(a) of Pub. L. 98–353","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd3a0af54-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Payment of Certain Benefits to Retired Former Employees","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/500/s101/b/tVI/s608"},"text":"Pub. L. 99–500, § 101(b) [title VI, § 608]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-18"},"text":"Oct. 18, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1783-39"},"text":"100 Stat. 1783–39","children":[],"tail":", 1783–74, and "},{"tag":"ref","attrib":{"href":"/us/pl/99/591/s101/b/tVI/s608"},"text":"Pub. L. 99–591, § 101(b) [title VI, § 608]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-30"},"text":"Oct. 30, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3341-39"},"text":"100 Stat. 3341–39","children":[],"tail":", 3341–74, as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/100/41"},"text":"Pub. L. 100–41","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-05-15"},"text":"May 15, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/309"},"text":"101 Stat. 309","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/99"},"text":"Pub. L. 100–99","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-08-18"},"text":"Aug. 18, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/716"},"text":"101 Stat. 716","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/334/s3/a"},"text":"Pub. L. 100–334, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-06-16"},"text":"June 16, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/613"},"text":"102 Stat. 613","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/334/s3/a"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to paragraphs (2), (3), (4), and (5), and notwithstanding title 11 of the United States Code, the trustee shall pay benefits to retired former employees under a plan, fund, or program maintained or established by the debtor prior to filing a petition (through the purchase of insurance or otherwise) for the purpose of providing medical, surgical, or hospital care benefits, or benefits in the event of sickness, accident, disability, or death.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The level of benefits required to be paid by this subsection may be modified prior to confirmation of a plan under section 1129 of such title if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the trustee and an authorized representative of the former employees with respect to whom such benefits are payable agree to the modification of such benefit payments; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the court finds that a modification proposed by the trustee meets the standards of section 1113(b)(1)(A) of such title and the balance of the equities clearly favors the modification.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"If such benefits are covered by a collective bargaining agreement, the authorized representative shall be the labor organization that is signatory to such collective bargaining agreement unless there is a conflict of interest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The trustee shall pay benefits in accordance with this subsection until—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the dismissal of the case involved; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effective date of a plan confirmed under section 1129 of such title which provides for the continued payment after confirmation of the plan of all such benefits at the level established under paragraph (2) of this subsection, at any time prior to the confirmation of the plan, for the duration of the period the debtor (as defined in such title) has obligated itself to provide such benefits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No such benefits paid between the filing of a petition in a case covered by this section and the time a plan confirmed under section 1129 of such title with respect to such case becomes effective shall be deducted or offset from the amount allowed as claims for any benefits which remain unpaid, or from the amount to be paid under the plan with respect to such claims for unpaid benefits, whether such claims for unpaid benefits are based upon or arise from a right to future benefits or from any benefit not paid as a result of modifications allowed pursuant to this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No claim for benefits covered by this section shall be limited by section 502(b)(7) of such title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding any provision of title 11 of the United States Code, the trustee shall pay an allowable claim of any person for a benefit paid—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before the filing of the petition under title 11 of the United States Code; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" directly or indirectly to a retired former employee under a plan, fund, or program described in subsection (a)(1);","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"if, as determined by the court, such person is entitled to recover from such employee, or any provider of health care to such employee, directly or indirectly, the amount of such benefit for which such person receives no payment from the debtor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of paragraph (1), the term ‘provider of health care’ means a person who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is the direct provider of health care (including a physician, dentist, nurse, podiatrist, optometrist, physician assistant, or ancillary personnel employed under the supervision of a physician); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administers a facility or institution (including a hospital, alcohol and drug abuse treatment facility, outpatient facility, or health maintenance organization) in which health care is provided.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section is effective with respect to cases commenced under chapter 11, of title 11, United States Code, in which a plan for reorganization has not been confirmed by the court and in which any such benefit is still being paid on ","children":[{"tag":"date","attrib":{"date":"1986-10-02"},"text":"October 2, 1986","children":[],"tail":", and in cases that become subject to chapter 11, title 11, United States Code, after "},{"tag":"date","attrib":{"date":"1986-10-02"},"text":"October 2, 1986","children":[],"tail":" and before the date of the enactment of the Retiree Benefits Bankruptcy Protection Act of 1988 ["},{"tag":"date","attrib":{"date":"1988-06-16"},"text":"June 16, 1988","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section shall not apply during any period in which a case is subject to chapter 7, title 11, United States Code.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/656/s2"},"text":"Pub. L. 99–656, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3668"},"text":"100 Stat. 3668","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/100/41"},"text":"Pub. L. 100–41","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-05-15"},"text":"May 15, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/309"},"text":"101 Stat. 309","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/99"},"text":"Pub. L. 100–99","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-08-18"},"text":"Aug. 18, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/716"},"text":"101 Stat. 716","children":[],"tail":", and were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/100/334/s3/b"},"text":"Pub. L. 100–334, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-06-16"},"text":"June 16, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/614"},"text":"102 Stat. 614","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
