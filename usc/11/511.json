{"tag":"section","attrib":{"id":"idd36ea376-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s511"},"text":null,"children":[{"tag":"num","attrib":{"value":"511"},"text":"§ 511.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rate of interest on tax claims","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd36ea377-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s511/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If any provision of this title requires the payment of interest on a tax claim or on an administrative expense tax, or the payment of interest to enable a creditor to receive the present value of the allowed amount of a tax claim, the rate of interest shall be the rate determined under applicable nonbankruptcy law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd36ea378-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s511/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of taxes paid under a confirmed plan under this title, the rate of interest shall be determined as of the calendar month in which the plan is confirmed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd36ea379-3a6f-11f1-8dc6-9561437cf370"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/tVII/s704/a"},"text":"Pub. L. 109–8, title VII, § 704(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/125"},"text":"119 Stat. 125","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd36ea37a-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd36ea37b-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd36ea37c-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 180 days after ","children":[{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", and not applicable with respect to cases commenced under this title before such effective date, except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/8/s1501"},"text":"section 1501 of Pub. L. 109–8","children":[],"tail":", set out as an Effective Date of 2005 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
