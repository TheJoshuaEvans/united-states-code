{"tag":"section","attrib":{"id":"idd3b633e1-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1226"},"text":null,"children":[{"tag":"num","attrib":{"value":"1226"},"text":"§ 1226.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd3b633e2-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1226/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Payments and funds received by the trustee shall be retained by the trustee until confirmation or denial of confirmation of a plan. If a plan is confirmed, the trustee shall distribute any such payment in accordance with the plan. If a plan is not confirmed, the trustee shall return any such payments to the debtor, after deducting—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd3b633e3-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1226/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any unpaid claim allowed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s503/b"},"text":"section 503(b) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3b633e4-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1226/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if a standing trustee is serving in the case, the percentage fee fixed for such standing trustee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3b633e5-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1226/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Before or at the time of each payment to creditors under the plan, there shall be paid—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd3b633e6-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1226/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any unpaid claim of the kind specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s507/a/2"},"text":"section 507(a)(2) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3b633e7-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1226/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if a standing trustee appointed under section 1202(c) ","children":[{"tag":"ref","attrib":{"idref":"fn002041"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002041"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title is serving in the case, the percentage fee fixed for such standing trustee under section 1202(d) "},{"tag":"ref","attrib":{"idref":"fn002041"},"text":"1","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3b633e8-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1226/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as otherwise provided in the plan or in the order confirming the plan, the trustee shall make payments to creditors under the plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd3b633e9-3a6f-11f1-8dc6-9561437cf370"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us