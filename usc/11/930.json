{"tag":"section","attrib":{"id":"idd39bf473-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s930"},"text":null,"children":[{"tag":"num","attrib":{"value":"930"},"text":"§ 930.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dismissal","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd39bf474-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s930/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" After notice and a hearing, the court may dismiss a case under this chapter for cause, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd39bf475-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s930/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" want of prosecution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd39bf476-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s930/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unreasonable delay by the debtor that is prejudicial to creditors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd39bf477-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s930/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" failure to propose a plan within the time fixed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s941"},"text":"section 941 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd39bf478-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s930/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if a plan is not accepted within any time fixed by the court;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd39bf479-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s930/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" denial of confirmation of a plan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s943/b"},"text":"section 943(b) of this title","children":[],"tail":" and denial of additional time for filing another plan or a modification of a plan; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd39bf47a-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s930/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the court has retained jurisdiction after confirmation of a plan—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd39bf47b-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s930/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" material default by the debtor with respect to a term of such plan; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd39bf47c-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s930/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" termination of such plan by reason of the occurrence of a condition specified in such plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd39bf47d-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s930/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The court shall dismiss a case under this chapter if confirmation of a plan under this chapter is refused.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd39bf47e-3a6f-11f1-8dc6-9561437cf370"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2623"},"text":"92 Stat. 2623","children":[],"tail":", § 927; "},{"tag":"ref","attrib":{"href":"/us/pl/98/353/tIII/s496"},"text":"Pub. L. 98–353, title III, § 496","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-10"},"text":"July 10, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/384"},"text":"98 Stat. 384","children":[],"tail":"; renumbered § 930, "},{"tag":"ref","attrib":{"href":"/us/pl/100/597/s7/1"},"text":"Pub. L. 100–597, § 7(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-03"},"text":"Nov. 3, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3029"},"text":"102 Stat. 3029","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd39bf47f-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idd39bf480-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd39bf481-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"legislative statements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 927(b) of the House amendment is derived from section 927(b) of the Senate bill. The provision requires mandatory dismissal if confirmation of a plan is refused.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The House amendment deletes section 929 of the Senate amendment as unnecessary since the bankruptcy court has original exclusive jurisdiction of all cases under chapter 9.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The House amendment deletes section 930 of the Senate amendment and incorporates section 507(a)(1) by reference.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd39bf482-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"senate report no. 95–989","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 927 conforms to section 98 of current law [section 418 of former title 11]. The Section permits dismissal by the court for unreasonable delay by the debtor, failure to propose a plan, failure of acceptance of a plan, or default by the debtor under a conformed plan. Mandatory dismissal is required if confirmation is refused.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd39bf483-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"house report no. 95–595","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 926 [enacted as section 927] generally conforms to section 98(a) [section 418(a) of former title 11] of current law. Stylistic changes have been made to conform the language with that used in chapter 11, section 1112. The section permits dismissal by the court for unreasonable delay by the debtor that is prejudicial to creditors, failure to propose a plan, failure of confirmation of a plan, or material default by the debtor under a confirmed plan. The only significant change from current law lies in the second ground. Currently, section 98(a)(2) provides for dismissal if a proposed plan is not accepted, and section 98(b) ","children":[{"tag":"i","attrib":{},"text":"requires","children":[],"tail":" dismissal if an accepted plan is not confirmed. In order to provide greater flexibility to the court, the debtor, and creditors, the bill allows the court to permit the debtor to propose another plan if the first plan is not confirmed. In that event the debtor need not, as under current law, commence the case all over again. This could provide savings in time and administrative expenses if a plan is denied confirmation."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd39bf484-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd39bf485-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/353"},"text":"Pub. L. 98–353","children":[],"tail":" substituted “confirmation of a plan under this chapter” for “confirmation”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd39bf486-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd39bf487-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/353"},"text":"Pub. L. 98–353","children":[],"tail":" effective with respect to cases filed 90 days after "},{"tag":"date","attrib":{"date":"1984-07-10"},"text":"July 10, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/353/s552/a"},"text":"section 552(a) of Pub. L. 98–353","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
