{"tag":"section","attrib":{"id":"idd394c8dd-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s747"},"text":null,"children":[{"tag":"num","attrib":{"value":"747"},"text":"§ 747.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subordination of certain customer claims","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s510"},"text":"section 510 of this title","children":[],"tail":", unless all other customer net equity claims have been paid in full, the trustee may not pay in full or pay in part, directly or indirectly, any net equity claim of a customer that was, on the date the transaction giving rise to such claim occurred—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idd394c8de-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s747/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an insider;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd394c8df-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s747/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a beneficial owner of at least five percent of any class of equity securities of the debtor, other than—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd394c8e0-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s747/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nonconvertible stock having fixed preferential dividend and liquidation rights; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd394c8e1-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s747/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interests of limited partners in a limited partnership;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd394c8e2-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s747/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a limited partner with a participation of at least five percent in the net assets or net profits of the debtor; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd394c8e3-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s747/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an entity that, directly or indirectly, through agreement or otherwise, exercised or had the power to exercise control over the management or policies of the debtor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd394c8e4-3a6f-11f1-8dc6-9561437cf370"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2613"},"text":"92 Stat. 2613","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/222/s13"},"text":"Pub. L. 97–222, § 13","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-07-27"},"text":"July 27, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/238"},"text":"96 Stat. 238","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd394c8e5-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idd394c8e6-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd394c8e7-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"senate report no. 95–989","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 747 subordinates to other customer claims, all claims of a customer who is an insider, a five percent owner of the debtor, or otherwise in control of the debtor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd394c8e8-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd394c8e9-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/222"},"text":"Pub. L. 97–222","children":[],"tail":" substituted “the transaction giving rise to such claim occurred” for “such claim arose” in provisions preceding par. (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
