{"tag":"section","attrib":{"id":"idd3c2199b-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1520"},"text":null,"children":[{"tag":"num","attrib":{"value":"1520"},"text":"§ 1520.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effects of recognition of a foreign main proceeding","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd3c2199c-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1520/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Upon recognition of a foreign proceeding that is a foreign main proceeding—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd3c2199d-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1520/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sections 361 and 362 apply with respect to the debtor and the property of the debtor that is within the territorial jurisdiction of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3c2199e-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1520/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sections 363, 549, and 552 apply to a transfer of an interest of the debtor in property that is within the territorial jurisdiction of the United States to the same extent that the sections would apply to property of an estate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3c2199f-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1520/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unless the court orders otherwise, the foreign representative may operate the debtor’s business and may exercise the rights and powers of a trustee under and to the extent provided by sections 363 and 552; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3c219a0-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1520/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 552 applies to property of the debtor that is within the territorial jurisdiction of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3c219a1-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1520/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsection (a) does not affect the right to commence an individual action or proceeding in a foreign country to the extent necessary to preserve a claim against the debtor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3c219a2-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1520/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsection (a) does not affect the right of a foreign representative or an entity to file a petition commencing a case under this title or the right of any party to file claims or take other proper actions in such a case.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd3c219a3-3a6f-11f1-8dc6-9561437cf370"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/tVIII/s801/a"},"text":"Pub. L. 109–8, title VIII, § 801(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/141"},"text":"119 Stat. 141","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd3c219a4-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd3c219a5-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd3c219a6-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 180 days after ","children":[{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", and not applicable with respect to cases commenced under this title before such effective date, except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/8/s1501"},"text":"section 1501 of Pub. L. 109–8","children":[],"tail":", set out as an Effective Date of 2005 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
