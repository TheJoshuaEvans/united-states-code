{"tag":"section","attrib":{"id":"idd39bf46e-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s929"},"text":null,"children":[{"tag":"num","attrib":{"value":"929"},"text":"§ 929.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Municipal leases","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A lease to a municipality shall not be treated as an executory contract or unexpired lease for the purposes of section 365 or 502(b)(6) of this title solely by reason of its being subject to termination in the event the debtor fails to appropriate rent.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd39bf46f-3a6f-11f1-8dc6-9561437cf370"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/597/s9"},"text":"Pub. L. 100–597, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-03"},"text":"Nov. 3, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3030"},"text":"102 Stat. 3030","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd39bf470-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd39bf471-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd39bf472-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1988-11-03"},"text":"Nov. 3, 1988","children":[],"tail":", but not applicable to any case commenced under this title before that date, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/597/s12"},"text":"section 12 of Pub. L. 100–597","children":[],"tail":", set out as an Effective Date of 1988 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
