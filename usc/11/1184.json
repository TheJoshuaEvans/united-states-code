{"tag":"section","attrib":{"id":"idd3b17891-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1184"},"text":null,"children":[{"tag":"num","attrib":{"value":"1184"},"text":"§ 1184.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights and powers of a debtor in possession","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Subject to such limitations or conditions as the court may prescribe, a debtor in possession shall have all the rights, other than the right to compensation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s330"},"text":"section 330 of this title","children":[],"tail":", and powers, and shall perform all functions and duties, except the duties specified in paragraphs (2), (3), and (4) of "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s1106/a"},"text":"section 1106(a) of this title","children":[],"tail":", of a trustee serving in a case under this chapter, including operating the business of the debtor."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd3b17892-3a6f-11f1-8dc6-9561437cf370"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/54/s2/a"},"text":"Pub. L. 116–54, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-08-23"},"text":"Aug. 23, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1080"},"text":"133 Stat. 1080","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd3b17893-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd3b17894-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd3b17895-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 180 days after ","children":[{"tag":"date","attrib":{"date":"2019-08-23"},"text":"Aug. 23, 2019","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/116/54/s5"},"text":"section 5 of Pub. L. 116–54","children":[],"tail":", set out as an Effective Date of 2019 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
