{"tag":"section","attrib":{"id":"idd3c219bb-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1522"},"text":null,"children":[{"tag":"num","attrib":{"value":"1522"},"text":"§ 1522.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of creditors and other interested persons","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd3c219bc-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1522/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The court may grant relief under section 1519 or 1521, or may modify or terminate relief under subsection (c), only if the interests of the creditors and other interested entities, including the debtor, are sufficiently protected.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3c219bd-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1522/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The court may subject relief granted under section 1519 or 1521, or the operation of the debtor’s business under section 1520(a)(3), to conditions it considers appropriate, including the giving of security or the filing of a bond.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3c219be-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1522/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The court may, at the request of the foreign representative or an entity affected by relief granted under section 1519 or 1521, or at its own motion, modify or terminate such relief.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3c219bf-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1522/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 1104(d) shall apply to the appointment of an examiner under this chapter. Any examiner shall comply with the qualification requirements imposed on a trustee by section 322.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd3c219c0-3a6f-11f1-8dc6-9561437cf370"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/tVIII/s801/a"},"text":"Pub. L. 109–8, title VIII, § 801(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/142"},"text":"119 Stat. 142","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd3c219c1-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd3c219c2-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd3c219c3-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 180 days after ","children":[{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", and not applicable with respect to cases commenced under this title before such effective date, except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/8/s1501"},"text":"section 1501 of Pub. L. 109–8","children":[],"tail":", set out as an Effective Date of 2005 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
