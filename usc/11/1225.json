{"tag":"section","attrib":{"id":"idd3b633c1-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1225"},"text":null,"children":[{"tag":"num","attrib":{"value":"1225"},"text":"§ 1225.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confirmation of plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd3b633c2-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1225/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in subsection (b), the court shall confirm a plan if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd3b633c3-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1225/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plan complies with the provisions of this chapter and with the other applicable provisions of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3b633c4-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1225/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any fee, charge, or amount required under chapter 123 of title 28, or by the plan, to be paid before confirmation, has been paid;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3b633c5-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1225/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plan has been proposed in good faith and not by any means forbidden by law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3b633c6-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1225/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the value, as of the effective date of the plan, of property to be distributed under the plan on account of each allowed unsecured claim is not less than the amount that would be paid on such claim if the estate of the debtor were liquidated under chapter 7 of this title on such date;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3b633c7-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1225/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to each allowed secured claim provided for by the plan—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd3b633c8-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1225/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the holder of such claim has accepted the plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd3b633c9-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1225/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd3b633ca-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1225/a/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plan provides that the holder of such claim retain the lien securing such claim; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd3b633cb-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1225/a/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the value, as of the effective date of the plan, of property to be distributed by the trustee or the debtor under the plan on account of such claim is not less than the allowed amount of such claim; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd3b633cc-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1225/a/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the debtor surrenders the property securing such claim to such holder;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3b633cd-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1225/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the debtor will be able to make all payments under the plan and to comply with the plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3b633ce-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1225/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the debtor has paid all amounts that are required to be paid under a domestic support obligation and that first become payable after the date of the filing of the petition if the debtor is required by a judicial or administrative order, or by statute, to pay such domestic support obligation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3b633cf-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1225/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd3b633d0-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1225/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the trustee or the holder of an allowed unsecured claim objects to the confirmation of the plan, then the court may not approve the plan unless, as of the effective date of the plan—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd3b633d1-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1225/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the value of the property to be distributed under the plan on account of such claim is not less than the amount of such claim;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd3b633d2-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1225/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plan provides that all of the debtor’s projected disposable income to be received in the three-year period, or such longer period as the court may approve under section 1222(c), beginning on the date that the first payment is due under the plan will be applied to make payments under the plan; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd3b633d3-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1225/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the value of the property to be distributed under the plan in the 3-year period, or such longer period as the court may approve under section 1222(c), beginning on the date that the first distribution is due under the plan is not less than the debtor’s projected disposable income for such period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3b633d4-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1225/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this subsection, “disposable income” means income which is received by the debtor and which is not reasonably necessary to be expended—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd3b633d5-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1225/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the maintenance or support of the debtor or a dependent of the debtor or for a domestic support obligation that first becomes payable after the date of the filing of the petition; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd3b633d6-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1225/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the payment of expenditures necessary for the continuation, preservation, and operation of the debtor’s business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3b633d7-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1225/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" After confirmation of a plan, the court may order any entity from whom the debtor receives income to pay all or any part of such income to the trustee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd3b633d8-3a6f-11f1-8dc6-9561437cf370"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/554/tII/s255"},"text":"Pub. L. 99–554, title II, § 255","children":[],"tail":", title III, § 302(f), "},{"tag":"date"