 Stat. 151","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/170/s1"},"text":"Pub. L. 107–170, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-07"},"text":"May 7, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/133"},"text":"116 Stat. 133","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tX/s10814/a"},"text":"Pub. L. 107–171, title X, § 10814(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/532"},"text":"116 Stat. 532","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/377/s2/a"},"text":"Pub. L. 107–377, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-19"},"text":"Dec. 19, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/3115"},"text":"116 Stat. 3115","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/73/s2/a"},"text":"Pub. L. 108–73, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-08-15"},"text":"Aug. 15, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/891"},"text":"117 Stat. 891","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/369/s2/a"},"text":"Pub. L. 108–369, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-25"},"text":"Oct. 25, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1749"},"text":"118 Stat. 1749","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/8/tII"},"text":"Pub. L. 109–8, title II","children":[],"tail":", §§ 213(5), 218, title X, §§ 1001(a)(1), (c), 1006(a), "},{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/52"},"text":"119 Stat. 52","children":[],"tail":", 55, 185–187; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dN/tIII/s320/d"},"text":"Pub. L. 116–260, div. N, title III, § 320(d)","children":[],"tail":", (f)(2)(A)(iv), "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2016"},"text":"134 Stat. 2016","children":[],"tail":", 2017.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd3b633d9-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd3b633da-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd3b633db-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For repeal of section effective ","children":[{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", and subsequent reenactment of section, see note set out preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s1201"},"text":"section 1201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd3b633dc-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s320/f/2/A/iv"},"text":"Pub. L. 116–260, § 320(f)(2)(A)(iv)","children":[],"tail":", contingent on its addition by "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/s320/d"},"text":"Pub. L. 116–260, § 320(d)","children":[],"tail":", struck out subsec. (d) which read as follows: “Notwithstanding "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s1222/a/2"},"text":"section 1222(a)(2) of this title","children":[],"tail":" and subsection (b)(1) of this section, a plan that provides for payment of a claim of a kind specified in "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s503/b/10"},"text":"section 503(b)(10) of this title","children":[],"tail":" may be confirmed if the plan proposes to make payments on account of such claim when due under the terms of the loan giving rise to such claim.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s320/d"},"text":"Pub. L. 116–260, § 320(d)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (a)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/s213/5"},"text":"Pub. L. 109–8, § 213(5)","children":[],"tail":", added par. (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/s1006/a"},"text":"Pub. L. 109–8, § 1006(a)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/s218"},"text":"Pub. L. 109–8, § 218","children":[],"tail":", inserted “or for a domestic support obligation that first becomes payable after the date of the filing of the petition” after “dependent of the debtor”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd3b633dd-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd3b633de-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective and Termination Dates of 2020 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dN/s320/d"},"text":"section 320(d) of div. N of Pub. L. 116–260","children":[],"tail":" effective on the date on which the Administrator of the Small Business Administration submits to the Director of the Executive Office for United States Trustees a written determination relating to loan eligibility under pars. (36) and (37) of "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s636/a"},"text":"section 636(a) of Title 15","children":[],"tail":", Commerce and Trade, and applicable to any case pending on or commenced on or after such date, and amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dN/s320/f/2/A/iv"},"text":"section 320(f)(2)(A)(iv) of div. N of Pub. L. 116–260","children":[],"tail":", relating to repeal of such amendment if it became effective, effective two years after "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/s320/f"},"text":"section 320(f) of Pub. L. 116–260","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s364"},"text":"section 364 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[Pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s636/a/36/A/iii"},"text":"15 U.S.C. 636(a)(36)(A)(iii)","children":[],"tail":", the “covered period” for loans under the Paycheck Protection Program ended on "},{"tag":"date","attrib":{"date":"2021-06-30"},"text":"June 30, 2021","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd3b633df-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2005 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by sections 213(5), 218, and 1006(a) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8"},"text":"Pub. L. 109–8","children":[],"tail":" effective 180 days after "},{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", and not applicable with respect to cases commenced under this title before such effective date, except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/8/s1501"},"text":"section 1501 of Pub. L. 109–8","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd3b633e0-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Dates","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Permanent reenactment of section effective ","children":[{"tag":"date","attrib":{"date":"2005-07-01"},"text":"July 1, 2005","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/8/s1001/a/2"},"text":"section 1001(a)(2) of Pub. L. 109–8","children":[],"tail":", set out as a Repeal, Reenactment, and Termination of Chapter note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s1201"},"text":"section 1201 of this title","children":[],"tail":". For effective dates of section and amendments extending periods for which section was reenacted prior to permanent reenactment, see Effective Date and Effective Date of 1999, 2001, 2002, 2003, and 2004 Amendment notes set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s1201"},"text":"section 1201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
