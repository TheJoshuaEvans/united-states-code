{"tag":"section","attrib":{"id":"idd39bf4ab-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s944"},"text":null,"children":[{"tag":"num","attrib":{"value":"944"},"text":"§ 944.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of confirmation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd39bf4ac-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s944/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The provisions of a confirmed plan bind the debtor and any creditor, whether or not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd39bf4ad-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s944/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a proof of such creditor’s claim is filed or deemed filed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s501"},"text":"section 501 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd39bf4ae-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s944/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such claim is allowed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s502"},"text":"section 502 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd39bf4af-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s944/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such creditor has accepted the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd39bf4b0-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s944/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in subsection (c) of this section, the debtor is discharged from all debts as of the time when—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd39bf4b1-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s944/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plan is confirmed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd39bf4b2-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s944/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the debtor deposits any consideration to be distributed under the plan with a disbursing agent appointed by the court; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd39bf4b3-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s944/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the court has determined—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd39bf4b4-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s944/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that any security so deposited will constitute, after distribution, a valid legal obligation of the debtor; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd39bf4b5-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s944/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that any provision made to pay or secure payment of such obligation is valid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd39bf4b6-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s944/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The debtor is not discharged under subsection (b) of this section from any debt—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd39bf4b7-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s944/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" excepted from discharge by the plan or order confirming the plan; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd39bf4b8-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s944/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owed to an entity that, before confirmation of the plan, had neither notice nor actual knowledge of the case.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd39bf4b9-3a6f-11f1-8dc6-9561437cf370"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2624"},"text":"92 Stat. 2624","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd39bf4ba-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idd39bf4bb-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd39bf4bc-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"senate report no. 95–989","children":[],"tail":null},{"tag":"p","attrib":{},"text":"[Section 947] Subsection (a) [enacted as section 944(a)] makes the provisions of a confirmed plan binding on the debtor and creditors. It is derived from section 95(a) of chapter 9 [section 415(a) of former title 11].","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsections (b) and (c) [enacted as section 944(b) and (c)] provide for the discharge of a municipality. The discharge is essentially the same as that granted under section 95(b) of the Bankruptcy Act [section 415(b) of former title 11].","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
