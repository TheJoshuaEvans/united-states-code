{"tag":"section","attrib":{"id":"idd34fa8ff-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s307"},"text":null,"children":[{"tag":"num","attrib":{"value":"307"},"text":"§ 307.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States trustee","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The United States trustee may raise and may appear and be heard on any issue in any case or proceeding under this title but may not file a plan pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s1121/c"},"text":"section 1121(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd34fa900-3a6f-11f1-8dc6-9561437cf370"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/554/tII/s205/a"},"text":"Pub. L. 99–554, title II, § 205(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3098"},"text":"100 Stat. 3098","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd34fa901-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd34fa902-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd34fa903-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Effective date and applicability of section dependent upon the judicial district involved, see section 302(d), (e) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/554"},"text":"Pub. L. 99–554","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s581"},"text":"section 581 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd34fa904-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Standing and Authority of Bankruptcy Administrator","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/650/tIII/s317/b"},"text":"Pub. L. 101–650, title III, § 317(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-12-01"},"text":"Dec. 1, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/5115"},"text":"104 Stat. 5115","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/650/tIII/s317/b"},"text":"“A bankruptcy administrator may raise and may appear and be heard on any issue in any case under title 11, United States Code, but may not file a plan pursuant to section 1121(c) of such title.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
