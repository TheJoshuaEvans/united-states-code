{"tag":"section","attrib":{"id":"idd34fa945-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s324"},"text":null,"children":[{"tag":"num","attrib":{"value":"324"},"text":"§ 324.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal of trustee or examiner","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd34fa946-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s324/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The court, after notice and a hearing, may remove a trustee, other than the United States trustee, or an examiner, for cause.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd34fa947-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s324/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whenever the court removes a trustee or examiner under subsection (a) in a case under this title, such trustee or examiner shall thereby be removed in all other cases under this title in which such trustee or examiner is then serving unless the court orders otherwise.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd34fa948-3a6f-11f1-8dc6-9561437cf370"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2562"},"text":"92 Stat. 2562","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/554/tII/s208"},"text":"Pub. L. 99–554, title II, § 208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3098"},"text":"100 Stat. 3098","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd34fa949-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idd34fa94a-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd34fa94b-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"senate report no. 95–989","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This section permits the court, after notice and a hearing, to remove a trustee for cause.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd34fa94c-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd34fa94d-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/554"},"text":"Pub. L. 99–554","children":[],"tail":" amended section generally, designating existing provisions as subsec. (a), substituting “a trustee, other than the United States trustee, or an examiner” for “a trustee or an examiner”, and adding subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd34fa94e-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd34fa94f-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Effective date and applicability of amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/554"},"text":"Pub. L. 99–554","children":[],"tail":" dependent upon the judicial district involved, see section 302(d), (e) of "},{"tag":"ref","attrib":{"href":"/us/pl/99/554"},"text":"Pub. L. 99–554","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s581"},"text":"section 581 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
