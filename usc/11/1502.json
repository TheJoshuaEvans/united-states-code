{"tag":"section","attrib":{"id":"idd3bfa8f4-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1502"},"text":null,"children":[{"tag":"num","attrib":{"value":"1502"},"text":"§ 1502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purposes of this chapter, the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd3bfa8f5-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1502/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “debtor” means an entity that is the subject of a foreign proceeding;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3bfa8f6-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1502/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “establishment” means any place of operations where the debtor carries out a nontransitory economic activity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3bfa8f7-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1502/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “foreign court” means a judicial or other authority competent to control or supervise a foreign proceeding;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3bfa8f8-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1502/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “foreign main proceeding” means a foreign proceeding pending in the country where the debtor has the center of its main interests;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3bfa8f9-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1502/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “foreign nonmain proceeding” means a foreign proceeding, other than a foreign main proceeding, pending in a country where the debtor has an establishment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3bfa8fa-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1502/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “trustee” includes a trustee, a debtor in possession in a case under any chapter of this title, or a debtor under chapter 9 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3bfa8fb-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1502/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “recognition” means the entry of an order granting recognition of a foreign main proceeding or foreign nonmain proceeding under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3bfa8fc-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1502/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “within the territorial jurisdiction of the United States”, when used with reference to property of a debtor, refers to tangible property located within the territory of the United States and intangible property deemed under applicable nonbankruptcy law to be located within that territory, including any property subject to attachment or garnishment that may properly be seized or garnished by an action in a Federal or State court in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd3bfa8fd-3a6f-11f1-8dc6-9561437cf370"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/tVIII/s801/a"},"text":"Pub. L. 109–8, title VIII, § 801(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/135"},"text":"119 Stat. 135","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd3bfa8fe-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd3bfa8ff-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd3bfa900-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 180 days after ","children":[{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", and not applicable with respect to cases commenced under this title before such effective date, except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/8/s1501"},"text":"section 1501 of Pub. L. 109–8","children":[],"tail":", set out as an Effective Date of 2005 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
