{"tag":"section","attrib":{"id":"idd3b3c2e5-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1194"},"text":null,"children":[{"tag":"num","attrib":{"value":"1194"},"text":"§ 1194.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd3b3c2e6-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1194/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retention and Distribution by Trustee","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Payments and funds received by the trustee shall be retained by the trustee until confirmation or denial of confirmation of a plan. If a plan is confirmed, the trustee shall distribute any such payment in accordance with the plan. If a plan is not confirmed, the trustee shall return any such payments to the debtor after deducting—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd3b3c2e7-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1194/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any unpaid claim allowed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s503/b"},"text":"section 503(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3b3c2e8-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1194/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any payment made for the purpose of providing adequate protection of an interest in property due to the holder of a secured claim; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3b3c2e9-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1194/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any fee owing to the trustee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3b3c2ea-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1194/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other Plans","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a plan is confirmed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s1191/b"},"text":"section 1191(b) of this title","children":[],"tail":", except as otherwise provided in the plan or in the order confirming the plan, the trustee shall make payments to creditors under the plan."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3b3c2eb-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1194/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payments Prior to Confirmation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Prior to confirmation of a plan, the court, after notice and a hearing, may authorize the trustee to make payments to the holder of a secured claim for the purpose of providing adequate protection of an interest in property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd3b3c2ec-3a6f-11f1-8dc6-9561437cf370"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/54/s2/a"},"text":"Pub. L. 116–54, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-08-23"},"text":"Aug. 23, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1084"},"text":"133 Stat. 1084","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd3b3c2ed-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd3b3c2ee-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd3b3c2ef-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 180 days after ","children":[{"tag":"date","attrib":{"date":"2019-08-23"},"text":"Aug. 23, 2019","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/116/54/s5"},"text":"section 5 of Pub. L. 116–54","children":[],"tail":", set out as an Effective Date of 2019 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
