{"tag":"section","attrib":{"id":"idd39bf431-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s922"},"text":null,"children":[{"tag":"num","attrib":{"value":"922"},"text":"§ 922.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Automatic stay of enforcement of claims against the debtor","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd39bf432-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s922/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A petition filed under this chapter operates as a stay, in addition to the stay provided by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s362"},"text":"section 362 of this title","children":[],"tail":", applicable to all entities, of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idd39bf433-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s922/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the commencement or continuation, including the issuance or employment of process, of a judicial, administrative, or other action or proceeding against an officer or inhabitant of the debtor that seeks to enforce a claim against the debtor; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd39bf434-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s922/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the enforcement of a lien on or arising out of taxes or assessments owed to the debtor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd39bf435-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s922/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsections (c), (d), (e), (f), and (g) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s362"},"text":"section 362 of this title","children":[],"tail":" apply to a stay under subsection (a) of this section the same as such subsections apply to a stay under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s362/a"},"text":"section 362(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd39bf436-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s922/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the debtor provides, under section 362, 364, or 922 of this title, adequate protection of the interest of the holder of a claim secured by a lien on property of the debtor and if, notwithstanding such protection such creditor has a claim arising from the stay of action against such property under section 362 or 922 of this title or from the granting of a lien under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s364/d"},"text":"section 364(d) of this title","children":[],"tail":", then such claim shall be allowable as an administrative expense under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s503/b"},"text":"section 503(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd39bf437-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s922/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s362"},"text":"section 362 of this title","children":[],"tail":" and subsection (a) of this section, a petition filed under this chapter does not operate as a stay of application of pledged special revenues in a manner consistent with "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s927"},"text":"section 927 of this title","children":[],"tail":" to payment of indebtedness secured by such revenues."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd39bf438-3a6f-11f1-8dc6-9561437cf370"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2623"},"text":"92 Stat. 2623","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/353/tIII/s495"},"text":"Pub. L. 98–353, title III, § 495","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-10"},"text":"July 10, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/384"},"text":"98 Stat. 384","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/597/s5"},"text":"Pub. L. 100–597, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-03"},"text":"Nov. 3, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3029"},"text":"102 Stat. 3029","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd39bf439-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idd39bf43a-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd39bf43b-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"house report no. 95–595","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The automatic stay provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s362"},"text":"section 362 of title 11","children":[],"tail":" is incomplete for a municipality, because there is the possibility of action by a creditor against an officer or inhabitant of the municipality to collect taxes due the municipality. Section 85(e)(1) of current chapter IX [section 405(e)(1) of former title 11] stays such actions. Section 922 carries over that protection into the proposed chapter 9. Subsection (b) applies the provisions for relief from the stay that apply generally in section 362 to the stay under section 922."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd39bf43c-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd39bf43d-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/597"},"text":"Pub. L. 100–597","children":[],"tail":" added subsecs. (c) and (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/353"},"text":"Pub. L. 98–353","children":[],"tail":" substituted “a judicial” for “judicial”, and “action or proceeding” for “proceeding”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd39bf43e-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd39bf43f-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/597"},"text":"Pub. L. 100–597","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1988-11-03"},"text":"Nov. 3, 1988","children":[],"tail":", but not applicable to any case commenced under this title before that date, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/597/s12"},"text":"section 12 of Pub. L. 100–597","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd39bf440-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/353"},"text":"Pub. L. 98–353","children":[],"tail":" effective with respect to cases filed 90 days after "},{"tag":"date","attrib":{"date":"1984-07-10"},"text":"July 10, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/353/s552/a"},"text":"section 552(a) of Pub. L. 98–353","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
