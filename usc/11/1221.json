icial Procedure] and the amendments made by this Act shall take effect on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1993-08-06"},"text":"Aug. 6, 1993","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application of Amendment Made by Section","children":[],"tail":" 2.—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendment made by section 2 [amending this section] shall not apply with respect to cases commenced under title 11 of the United States Code before the date of the enactment of this Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd3b6338f-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Dates","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Permanent reenactment of section effective ","children":[{"tag":"date","attrib":{"date":"2005-07-01"},"text":"July 1, 2005","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/8/s1001/a/2"},"text":"section 1001(a)(2) of Pub. L. 109–8","children":[],"tail":", set out as a Repeal, Reenactment, and Termination of Chapter note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s1201"},"text":"section 1201 of this title","children":[],"tail":". For effective dates of section and amendments extending periods for which section was reenacted prior to permanent reenactment, see Effective Date and Effective Date of 1999, 2001, 2002, 2003, and 2004 Amendment notes set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s1201"},"text":"section 1201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
