{"tag":"section","attrib":{"id":"idd34fa928-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s322"},"text":null,"children":[{"tag":"num","attrib":{"value":"322"},"text":"§ 322.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualification of trustee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd34fa929-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s322/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsection (b)(1), a person selected under section 701, 702, 703, 1104, 1163, 1183, 1202, or 1302 of this title to serve as trustee in a case under this title qualifies if before seven days after such selection, and before beginning official duties, such person has filed with the court a bond in favor of the United States conditioned on the faithful performance of such official duties.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd34fa92a-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s322/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd34fa92b-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s322/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States trustee qualifies wherever such trustee serves as trustee in a case under this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd34fa92c-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s322/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The United States trustee shall determine—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd34fa92d-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s322/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of a bond required to be filed under subsection (a) of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd34fa92e-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s322/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sufficiency of the surety on such bond.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd34fa92f-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s322/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A trustee is not liable personally or on such trustee’s bond in favor of the United States for any penalty or forfeiture incurred by the debtor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd34fa930-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s322/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A proceeding on a trustee’s bond may not be commenced after two years after the date on which such trustee was discharged.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd34fa931-3a6f-11f1-8dc6-9561437cf370"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2562"},"text":"92 Stat. 2562","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/353/tIII/s429"},"text":"Pub. L. 98–353, title III, § 429","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-10"},"text":"July 10, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/369"},"text":"98 Stat. 369","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/554/tII"},"text":"Pub. L. 99–554, title II","children":[],"tail":", §§ 207, 257(d), "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3098"},"text":"100 Stat. 3098","children":[],"tail":", 3114; "},{"tag":"ref","attrib":{"href":"/us/pl/103/394/tV/s501/d/3"},"text":"Pub. L. 103–394, title V, § 501(d)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4143"},"text":"108 Stat. 4143","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/16/s2/2"},"text":"Pub. L. 111–16, § 2(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-05-07"},"text":"May 7, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1607"},"text":"123 Stat. 1607","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/54/s4/a/3"},"text":"Pub. L. 116–54, § 4(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-08-23"},"text":"Aug. 23, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1085"},"text":"133 Stat. 1085","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd34fa932-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idd34fa933-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd34fa934-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"legislative statements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 322(a) is modified to include a trustee serving in a railroad reorganization under subchapter IV of chapter 11.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd34fa935-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"senate report no. 95–989","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A trustee qualifies in a case by filing, within five days after selection, a bond in favor of the United States, conditioned on the faithful performance of his official duties. This section is derived from the Bankruptcy Act section 50b [section 78(b) of former title 11]. The court is required to determine the amount of the bond and the sufficiency of the surety on the bond. Subsection (c), derived from Bankruptcy Act section 50i [section 78(i) of former title 11], relieves the trustee from personal liability and from liability on his bond for any penalty or forfeiture incurred by the debtor. Subsection (d), derived from section 50m [section 78(m) of former title 11], fixes a two-year statute of limitations on any action on a trustee’s bond. Finally, subsection (e) dispenses with the bonding requirement for the United States trustee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd34fa936-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd34fa937-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/54"},"text":"Pub. L. 116–54","children":[],"tail":" inserted “1183,” after “1163,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/16"},"text":"Pub. L. 111–16","children":[],"tail":" substituted “seven days” for “five days”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/394"},"text":"Pub. L. 103–394","children":[],"tail":" substituted “1202, or 1302” for “1302, or 1202”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/554/s257/d"},"text":"Pub. L. 99–554, § 257(d)","children":[],"tail":", inserted reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s1202"},"text":"section 1202 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/554/s207/1"},"text":"Pub. L. 99–554, § 207(1)","children":[],"tail":", substituted “Except as provided in subsection (b)(1), a person” for “A person”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/554/s207/2"},"text":"Pub. L. 99–554, § 207(2)","children":[],"tail":", amended subsec. (b) generally, adding par. (1), designating existing provisions as par. (2), substituting “The United States trustee” for “The court”, “(A) the amount” for “(1) the amount”, and “(B) the sufficiency” for “(2) the sufficiency”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/353"},"text":"Pub. L. 98–353","children":[],"tail":" inserted “required to be”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd34fa938-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"te