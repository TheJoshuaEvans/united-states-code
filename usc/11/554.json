{"tag":"section","attrib":{"id":"idd388e14d-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s554"},"text":null,"children":[{"tag":"num","attrib":{"value":"554"},"text":"§ 554.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Abandonment of property of the estate","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd388e14e-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s554/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" After notice and a hearing, the trustee may abandon any property of the estate that is burdensome to the estate or that is of inconsequential value and benefit to the estate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd388e14f-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s554/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" On request of a party in interest and after notice and a hearing, the court may order the trustee to abandon any property of the estate that is burdensome to the estate or that is of inconsequential value and benefit to the estate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd388e150-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s554/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Unless the court orders otherwise, any property scheduled under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s521/a/1"},"text":"section 521(a)(1) of this title","children":[],"tail":" not otherwise administered at the time of the closing of a case is abandoned to the debtor and administered for purposes of "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s350"},"text":"section 350 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd388e151-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s554/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Unless the court orders otherwise, property of the estate that is not abandoned under this section and that is not administered in the case remains property of the estate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd388e152-3a6f-11f1-8dc6-9561437cf370"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2603"},"text":"92 Stat. 2603","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/353/tIII/s468"},"text":"Pub. L. 98–353, title III, § 468","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-10"},"text":"July 10, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/380"},"text":"98 Stat. 380","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/554/tII/s283/p"},"text":"Pub. L. 99–554, title II, § 283(p)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3118"},"text":"100 Stat. 3118","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/327/s2/a/23"},"text":"Pub. L. 111–327, § 2(a)(23)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-22"},"text":"Dec. 22, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3560"},"text":"124 Stat. 3560","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd388e153-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idd388e154-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd388e155-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"legislative statements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 554(b) is new and permits a party in interest to request the court to order the trustee to abandon property of the estate that is burdensome to the estate or that is of inconsequential value to the estate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd388e156-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"senate report no. 95–989","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Under this section the court may authorize the trustee to abandon any property of the estate that is burdensome to the estate or that is of inconsequential value to the estate. Abandonment may be to any party with a possessory interest in the property abandoned. In order to aid administration of the case, subsection (b) deems the court to have authorized abandonment of any property that is scheduled under section 521(1) and that is not administered before the case is closed. That property is deemed abandoned to the debtor. Subsection (c) specifies that if property is neither abandoned nor administered it remains property of the estate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd388e157-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd388e158-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/327"},"text":"Pub. L. 111–327","children":[],"tail":" substituted “521(a)(1)” for “521(1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/554"},"text":"Pub. L. 99–554","children":[],"tail":" substituted “521(1)” for “521(a)(1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/353/s468/a"},"text":"Pub. L. 98–353, § 468(a)","children":[],"tail":", inserted “and benefit” after “value”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/353/s468/b"},"text":"Pub. L. 98–353, § 468(b)","children":[],"tail":", amended subsec. (c) generally. Prior to amendment, subsec. (c) read as follows: “Unless the court orders otherwise, any property that is scheduled under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s521/1"},"text":"section 521(1) of this title","children":[],"tail":" and that is not administered before a case is closed under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s350"},"text":"section 350 of this title","children":[],"tail":" is deemed abandoned.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/353/s468/c"},"text":"Pub. L. 98–353, § 468(c)","children":[],"tail":", struck out “section (a) or (b) of” after “not abandoned under”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd388e159-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd388e15a-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/554"},"text":"Pub. L. 99–554","children":[],"tail":" effective 30 days after "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/554/s302/a"},"text":"section 302(a) of Pub. L. 99–554","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s581"},"text":"section 581 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd388e15b-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/353"},"text":"Pub. L. 98–353","children":[],"tail":" effective with respect to cases filed 90 days after "},{"tag":"date","attrib":{"date":"1984-07-10"},"text":"July 10, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/353/s552/a"},"text":"section 552(a) of Pub. L. 98–353","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
