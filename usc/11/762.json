{"tag":"section","attrib":{"id":"idd3973971-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s762"},"text":null,"children":[{"tag":"num","attrib":{"value":"762"},"text":"§ 762.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice to the Commission and right to be heard","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd3973972-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s762/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The clerk shall give the notice required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s342"},"text":"section 342 of this title","children":[],"tail":" to the Commission."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3973973-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s762/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commission may raise and may appear and be heard on any issue in a case under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd3973974-3a6f-11f1-8dc6-9561437cf370"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2618"},"text":"92 Stat. 2618","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd3973975-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idd3973976-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd3973977-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"senate report no. 95–989","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 762 provides that the Commission shall be given such notice as is appropriate of an order for relief in a bankruptcy case and that the Commission may raise and may appear and may be heard on any issue in case involving a commodity broker liquidation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
