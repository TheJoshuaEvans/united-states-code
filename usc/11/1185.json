{"tag":"section","attrib":{"id":"idd3b17896-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1185"},"text":null,"children":[{"tag":"num","attrib":{"value":"1185"},"text":"§ 1185.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal of debtor in possession","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd3b17897-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1185/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"On request of a party in interest, and after notice and a hearing, the court shall order that the debtor shall not be a debtor in possession for cause, including fraud, dishonesty, incompetence, or gross mismanagement of the affairs of the debtor, either before or after the date of commencement of the case, or for failure to perform the obligations of the debtor under a plan confirmed under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3b17898-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1185/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reinstatement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"On request of a party in interest, and after notice and a hearing, the court may reinstate the debtor in possession.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd3b17899-3a6f-11f1-8dc6-9561437cf370"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/54/s2/a"},"text":"Pub. L. 116–54, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-08-23"},"text":"Aug. 23, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1080"},"text":"133 Stat. 1080","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd3b1789a-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd3b1789b-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd3b1789c-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 180 days after ","children":[{"tag":"date","attrib":{"date":"2019-08-23"},"text":"Aug. 23, 2019","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/116/54/s5"},"text":"section 5 of Pub. L. 116–54","children":[],"tail":", set out as an Effective Date of 2019 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
