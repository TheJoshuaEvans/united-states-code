{"tag":"section","attrib":{"id":"idd3a32126-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1115"},"text":null,"children":[{"tag":"num","attrib":{"value":"1115"},"text":"§ 1115.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Property of the estate","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd3a32127-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1115/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In a case in which the debtor is an individual, property of the estate includes, in addition to the property specified in section 541—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd3a32128-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1115/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all property of the kind specified in section 541 that the debtor acquires after the commencement of the case but before the case is closed, dismissed, or converted to a case under chapter 7, 12, or 13, whichever occurs first; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd3a32129-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1115/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" earnings from services performed by the debtor after the commencement of the case but before the case is closed, dismissed, or converted to a case under chapter 7, 12, or 13, whichever occurs first.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd3a3212a-3a6f-11f1-8dc6-9561437cf370","identifier":"/us/usc/t11/s1115/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in section 1104 or a confirmed plan or order confirming a plan, the debtor shall remain in possession of all property of the estate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd3a3212b-3a6f-11f1-8dc6-9561437cf370"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/tIII/s321/a/1"},"text":"Pub. L. 109–8, title III, § 321(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/94"},"text":"119 Stat. 94","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd3a3212c-3a6f-11f1-8dc6-9561437cf370"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd3a3212d-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd3a3212e-3a6f-11f1-8dc6-9561437cf370"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 180 days after ","children":[{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", and not applicable with respect to cases commenced under this title before such effective date, except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/8/s1501"},"text":"section 1501 of Pub. L. 109–8","children":[],"tail":", set out as an Effective Date of 2005 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
