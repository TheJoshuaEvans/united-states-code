{"tag":"section","attrib":{"id":"iddce7adab-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1826"},"text":null,"children":[{"tag":"num","attrib":{"value":"1826"},"text":"§ 1826.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Easements for rights-of-way","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddce7adac-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1826/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Architect of the Capitol may grant, upon such terms as the Architect of the Capitol considers advisable, including monetary consideration, easements for rights-of-way over, in, and upon the Capitol Grounds and any other public lands under the jurisdiction and control of the Architect of the Capitol.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce7adad-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1826/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No easement granted under this section may include more land than is necessary for the easement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce7adae-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1826/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Easement account","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Treasury an easement account for the Architect of the Capitol. The Architect of the Capitol shall deposit in the account all proceeds received relating to the granting of easements under this section. The proceeds deposited in that account shall be available to the Architect, in such amounts and for such purposes provided in appropriations acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce7adaf-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1826/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In-kind consideration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (f), the Architect may accept in-kind consideration instead of, or in addition to, any monetary consideration, for any easement granted under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce7adb0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1826/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of easement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Architect of the Capitol may terminate all or part of any easement granted under this section for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce7adb1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1826/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" failure to comply with the terms of the grant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce7adb2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1826/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nonuse for a 2-year period; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce7adb3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1826/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" abandonment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce7adb4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1826/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Architect of the Capitol may grant an easement for rights-of-way under subsection (a) upon submission of written notice of intent to grant that easement and the amount or type of consideration to be received, and approval by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce7adb5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1826/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Rules and Administration of the Senate for easements granted on property under Senate jurisdiction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce7adb6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1826/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the House Office Building Commission for property under House of Representatives jurisdiction; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce7adb7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1826/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Rules and Administration of the Senate and the House Office Building Commission for easements granted on any other property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce7adb8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1826/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply to fiscal year 2008 and each fiscal year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddce7adb9-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161/dH/tI/s1307"},"text":"Pub. L. 110–161, div. H, title I, § 1307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2243"},"text":"121 Stat. 2243","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddce7adba-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddce7adbb-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddce7adbc-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Legislative Branch Appropriations Act, 2008, which is div. H of the Consolidated Appropriations Act, 2008.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
