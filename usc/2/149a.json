{"tag":"section","attrib":{"id":"iddc884ed6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s149a"},"text":null,"children":[{"tag":"num","attrib":{"value":"149a"},"text":"§ 149a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permitting use of proceeds from disposition of surplus or obsolete personal property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc884ed7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s149a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within the limits of available appropriations, the Librarian of Congress may dispose of surplus or obsolete personal property of the Library of Congress by interagency transfer, donation, sale, trade-in, or other appropriate method.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc884ed8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s149a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of proceeds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amounts received by the Librarian of Congress from the disposition of property under subsection (a) shall be credited to the funds available for the operations of the Library of Congress, and shall be available to acquire the same or similar property during the fiscal year in which the amounts are received and the following fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc884ed9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s149a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply with respect to fiscal year 2012 and each succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc884eda-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/74/dG/tI/s1304"},"text":"Pub. L. 112–74, div. G, title I, § 1304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-23"},"text":"Dec. 23, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1132"},"text":"125 Stat. 1132","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc884edb-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc884edc-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddc884edd-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Legislative Branch Appropriations Act, 2012, which is div. G of the Consolidated Appropriations Act, 2012.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
