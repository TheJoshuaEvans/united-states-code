{"tag":"section","attrib":{"id":"iddd25a024-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4726"},"text":null,"children":[{"tag":"num","attrib":{"value":"4726"},"text":"§ 4726.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines relating to restrictions on registered lobbyist participation in travel and disclosure","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd25a025-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4726/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (4) and not later than 60 days after ","children":[{"tag":"date","attrib":{"date":"2007-09-14"},"text":"September 14, 2007","children":[],"tail":", and at annual intervals thereafter, the Select Committee on Ethics shall develop and revise, as necessary—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd25a026-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4726/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" guidelines, for purposes of implementing the amendments made by subsection (a),","children":[{"tag":"ref","attrib":{"idref":"fn002107"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002107"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" on evaluating a trip proposal and judging the reasonableness of an expense or expenditure, including guidelines related to evaluating—"}],"tail":null},{"tag":"clause","attrib":{"id":"iddd25a027-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4726/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the stated mission of the organization sponsoring the trip;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd25a028-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4726/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the organization’s prior history of sponsoring congressional trips, if any;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd25a029-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4726/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other educational activities performed by the organization besides sponsoring congressional trips;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd25a02a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4726/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether any trips previously sponsored by the organization led to an investigation by the Select Committee on Ethics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd25a02b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4726/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the length of the trip and the itinerary is consistent with the official purpose of the trip;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd25a02c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4726/1/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether there is an adequate connection between a trip and official duties;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd25a02d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4726/1/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reasonableness of an amount spent by a sponsor of the trip;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd25a02e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4726/1/A/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether there is a direct and immediate relationship between a source of funding and an event; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd25a02f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4726/1/A/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other factor deemed relevant by the Select Committee on Ethics; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd25a030-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4726/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regulations describing the information it will require individuals subject to the requirements of the amendments made by subsection (a) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" to submit to the committee in order to obtain the prior approval of the committee for travel under paragraph 2 of rule XXXV of the Standing Rules of the Senate, including any required certifications."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd25a031-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4726/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In developing and revising guidelines under paragraph (1)(A), the committee shall take into account the maximum per diem rates for official Federal Government travel published annually by the General Services Administration, the Department of State, and the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd25a032-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4726/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unreasonable expense","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, travel on a flight described in paragraph 1(c)(1)(C)(ii) of rule XXXV of the Standing Rules of the Senate shall not be considered to be a reasonable expense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd25a033-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4726/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The deadline for the initial guidelines required by paragraph (1) may be extended for 30 days by the Committee on Rules and Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd25a034-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/81/tV/s544/b"},"text":"Pub. L. 110–81, title V, § 544(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-09-14"},"text":"Sept. 14, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/769"},"text":"121 Stat. 769","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd25a035-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd25a036-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd25a037-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The amendments made by subsection (a), referred to in par. (1), mean the amendments made by subsec. (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/81/s544"},"text":"section 544 of Pub. L. 110–81","children":[],"tail":" to paragraph 2 of rule XXXV of the Standing Rules of the Senate, which are not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd25a038-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s31–3"},"text":"section 31–3 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd25a039-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd25a03a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/81/tV/s544/f"},"text":"Pub. L. 110–81, title V, § 544(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-09-14"},"text":"Sept. 14, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/771"},"text":"121 Stat. 771","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/81/tV/s544/f"},"text":"“The amendments made by subsections (a) [","children":[{"tag":"ref","attrib":{"href":"/us/stat/121/767"},"text":"121 Stat. 767","children":[],"tail":"] and (b) [enacting this section] shall take effect 60 days after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2007-09-14"},"text":"Sept. 14, 2007","children":[],"tail":"] or the date the Select Committee on Ethics issues new guidelines as required by subsection (b), whichever is later. Subsection (c) ["},{"tag":"ref","attrib":{"href":"/us/stat/121/770"},"text":"121 Stat. 770","children":[],"tail":"] shall take effect on the date of enactment of this Act.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd25a03b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Separately Regulated Expenses","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/81/tV/s544/e"},"text":"Pub. L. 110–81, title V, § 544(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-09-14"},"text":"Sept. 14, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/771"},"text":"121 Stat. 771","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/81/tV/s544/e"},"text":"“Nothing in this section [enacting this section and provisions set out as a note under this section] or section 541 [","children":[{"tag":"ref","attrib":{"href":"/us/stat/121/766"},"text":"121 Stat. 766","children":[],"tail":"] is meant to alter treatment under law or Senate rules of expenses that are governed by the Foreign Gifts and Decorations Act [of 1966, "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2621"},"text":"22 U.S.C. 2621","children":[],"tail":" et seq.] or the Mutual Educational and Cultural Exchange Act [of 1961, "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2451"},"text":"22 U.S.C. 2451","children":[],"tail":" et seq.].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
