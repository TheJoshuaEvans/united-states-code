{"tag":"section","attrib":{"id":"iddc8abf65-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s164"},"text":null,"children":[{"tag":"num","attrib":{"value":"164"},"text":"§ 164.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Index and digest of State legislation; preparation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Librarian of Congress is authorized and directed to prepare biennially an index to the legislation of the States of the United States enacted during the biennium, together with a supplemental digest of the more important legislation of the period.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc8abf66-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1927-02-10/ch99/s1"},"text":"Feb. 10, 1927, ch. 99, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/1066"},"text":"44 Stat. 1066","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1929-02-28/ch367/s1"},"text":"Feb. 28, 1929, ch. 367, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/1398"},"text":"45 Stat. 1398","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc8abf67-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc8abf68-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc8abf69-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1929—Act ","children":[{"tag":"date","attrib":{"date":"1929-02-28"},"text":"Feb. 28, 1929","children":[],"tail":", repealed provision that the Librarian of Congress report biennially to Congress an index and digest of State legislation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
