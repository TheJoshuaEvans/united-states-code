{"tag":"section","attrib":{"id":"iddd0b88f7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4109"},"text":null,"children":[{"tag":"num","attrib":{"value":"4109"},"text":"§ 4109.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Detailed reports of receipts and expenditures by Secretary of Senate and Chief Administrative Officer of House","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Senate and the Chief Administrative Officer of the House of Representatives, respectively, shall report to Congress on the first day of each regular session, and at the expiration of their terms of service, a full and complete statement of all their receipts and expenditures as such officers, showing in detail the items of expense, classifying them under the proper appropriations, and also showing the aggregate thereof, and exhibiting in a clear and concise manner the exact condition of all public moneys by them received, paid out, and remaining in their possession as such officers.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd0b88f8-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(R.S. § 70; ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186/tII/s204/60"},"text":"Pub. L. 104–186, title II, § 204(60)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1738"},"text":"110 Stat. 1738","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd0b88f9-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd0b88fa-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd0b88fb-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s113"},"text":"section 113 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 70 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1870-07-15/ch302/s1"},"text":"act July 15, 1870, ch. 302, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/16/365"},"text":"16 Stat. 365","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd0b88fc-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186"},"text":"Pub. L. 104–186","children":[],"tail":" substituted “Chief Administrative Officer” for “Clerk”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
