{"tag":"section","attrib":{"id":"iddc884f26-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s161"},"text":null,"children":[{"tag":"num","attrib":{"value":"161"},"text":"§ 161.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax exemption of gifts, etc., to Library of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Gifts or bequests or devises to or for the benefit of the Library of Congress, including those to the board, and the income therefrom, shall be exempt from all Federal taxes, including all taxes levied by the District of Columbia.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc884f27-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1925-03-03/ch423/s5"},"text":"Mar. 3, 1925, ch. 423, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/43/1108"},"text":"43 Stat. 1108","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1942-10-02/ch576"},"text":"Oct. 2, 1942, ch. 576","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/56/765"},"text":"56 Stat. 765","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc884f28-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc884f29-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc884f2a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1942—Act ","children":[{"tag":"date","attrib":{"date":"1942-10-02"},"text":"Oct. 2, 1942","children":[],"tail":", included devises in the exemptions, and exempted gifts, bequests and devises, and the income therefrom, from taxes levied by the District of Columbia."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
