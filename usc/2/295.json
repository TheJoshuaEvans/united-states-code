{"tag":"section","attrib":{"id":"iddc9b61ec-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s295"},"text":null,"children":[{"tag":"num","attrib":{"value":"295"},"text":"§ 295.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Placement of positions in compensation schedules","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The committee shall place each position (in existence on, or established after, ","children":[{"tag":"date","attrib":{"date":"1965-01-01"},"text":"January 1, 1965","children":[],"tail":") under the House of Representatives to which this chapter applies in its appropriate class, and in its appropriate compensation level of the appropriate compensation schedule, in accordance with the position standards and position descriptions provided for in "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s294"},"text":"section 294 of this title","children":[],"tail":". The committee is authorized, when circumstances so warrant, to change any such position from one class or compensation level to another class or compensation level. All actions of the committee under this section shall be binding on the House officer and organization unit concerned and shall be the basis for payment of compensation and for other personnel benefits and transactions until otherwise changed by the committee."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc9b61ed-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/652/s6"},"text":"Pub. L. 88–652, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-10-13"},"text":"Oct. 13, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/1081"},"text":"78 Stat. 1081","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc9b61ee-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc9b61ef-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddc9b61f0-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/652"},"text":"Pub. L. 88–652","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-10-13"},"text":"Oct. 13, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/1079"},"text":"78 Stat. 1079","children":[],"tail":", known as the House Employees Position Classification Act, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s291"},"text":"section 291 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc9b61f1-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddc9b61f2-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1965-01-01"},"text":"Jan. 1, 1965","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/88/652/s17"},"text":"section 17 of Pub. L. 88–652","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s291"},"text":"section 291 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
