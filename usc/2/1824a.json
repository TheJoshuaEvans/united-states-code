{"tag":"section","attrib":{"id":"iddce7ad92-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1824a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1824a"},"text":"§ 1824a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recyclable materials","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddce7ad93-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1824a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection and sale of recyclable materials","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce7ad94-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1824a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Architect of the Capitol shall establish a program for the collection and sale of recyclable materials collected from or on the Capitol buildings and grounds, in accordance with the procedures applicable under subchapter III of chapter 5 of subtitle I of title 40, to the sale of surplus property by an executive agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce7ad95-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1824a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion of materials subject to other programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The program established under this section shall not apply with respect to any materials which are subject to collection and sale under—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddce7ad96-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1824a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s6516"},"text":"section 6516 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce7ad97-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1824a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s5540"},"text":"section 5540 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce7ad98-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1824a/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s2026"},"text":"section 2026 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce7ad99-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1824a/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other authorized program for the collection and sale of recyclable materials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce7ad9a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1824a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revolving fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce7ad9b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1824a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is established in the Treasury a revolving fund for the Office of the Architect of the Capitol, which shall consist of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddce7ad9c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1824a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proceeds from the sale of recyclable materials under the program established under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce7ad9d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1824a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such amounts as may be appropriated under law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce7ad9e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1824a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of fund","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts in the revolving fund established under paragraph (1) shall be available without fiscal year limitation to the Architect of the Capitol, subject to the Architect providing prior notice to the Committees on Appropriations of the House of Representatives and Senate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddce7ad9f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1824a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out the program established under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce7ada0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1824a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out authorized programs and activities of the Architect to improve the environment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce7ada1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1824a/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out authorized programs and activities of the Architect to promote energy savings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce7ada2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1824a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply with respect to fiscal year 2009 and each fiscal year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddce7ada3-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/8/dG/tI/s1101"},"text":"Pub. L. 111–8, div. G, title I, § 1101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-11"},"text":"Mar. 11, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/822"},"text":"123 Stat. 822","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/76/dI/tI/s1303"},"text":"Pub. L. 113–76, div. I, title I, § 1303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-01-17"},"text":"Jan. 17, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/429"},"text":"128 Stat. 429","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddce7ada4-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddce7ada5-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddce7ada6-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1811"},"text":"section 1811 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddce7ada7-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/76"},"text":"Pub. L. 113–76","children":[],"tail":" substituted “fiscal year 2009 and each fiscal year thereafter” for “each of the fiscal years 2009 through 2013”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
