{"tag":"section","attrib":{"id":"iddd31ae3e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6133"},"text":null,"children":[{"tag":"num","attrib":{"value":"6133"},"text":"§ 6133.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chiefs of Staff for Senate Majority and Minority Leaders; appointment; compensation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd31ae3f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6133/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is established within the Offices of the Majority and Minority Leaders the positions of Chief of Staff for the Majority Leader and Chief of Staff for the Minority Leader, respectively. Individuals appointed to such positions by the Majority Leader and Minority Leader, respectively, shall receive compensation at a rate fixed by the appropriate Leader.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd31ae40-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6133/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Gross compensation for employees filling positions established by subsection (a) for the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1987-09-30"},"text":"September 30, 1987","children":[],"tail":", shall be paid out of any funds available in the Senate appropriation for such year under the item “Salaries, Officers and Employees”."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd31ae41-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/163/tI/s9"},"text":"Pub. L. 101–163, title I, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-21"},"text":"Nov. 21, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/sta