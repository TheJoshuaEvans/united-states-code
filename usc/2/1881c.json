{"tag":"section","attrib":{"id":"iddcec6814-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1881c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1881c"},"text":"§ 1881c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated for each of fiscal years 2017 through 2028 such sums as may be necessary to carry out this subchapter, to be derived from amounts appropriated in each such fiscal year for the operation of the Architect of the Capitol, except that the aggregate amount appropriated to carry out this subchapter for all such fiscal years may not exceed $40,000.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddcec6815-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/156/s5"},"text":"Pub. L. 114–156, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-05-16"},"text":"May 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/392"},"text":"130 Stat. 392","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dI/tI/s131"},"text":"Pub. L. 117–328, div. I, title I, § 131","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4929"},"text":"136 Stat. 4929","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcec6816-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcec6817-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcec6818-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" substituted “through 2028” for “through 2022”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
