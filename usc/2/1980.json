{"tag":"section","attrib":{"id":"iddcf87564-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1980"},"text":null,"children":[{"tag":"num","attrib":{"value":"1980"},"text":"§ 1980.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mounted horse unit","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcf87565-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1980/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Capitol Police may not operate a mounted horse unit during fiscal year 2006 or any succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcf87566-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1980/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 60 days after the date of the enactment of this Act, the Chief of the Capitol Police shall transfer to the Chief of the United States Park Police the horses, equipment, and supplies of the Capitol Police mounted horse unit which remain in the possession of the Capitol Police as of such date.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcf87567-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/55/tI/s1002"},"text":"Pub. L. 109–55, title I, § 1002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-02"},"text":"Aug. 2, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/572"},"text":"119 Stat. 572","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcf87568-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcf87569-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddcf8756a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this Act, referred to in subsec. (b), is the date of the enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/55"},"text":"Pub. L. 109–55","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2005-08-02"},"text":"Aug. 2, 2005","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddcf8756b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Legislative Branch Appropriations Act, 2006.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
