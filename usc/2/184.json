{"tag":"section","attrib":{"id":"iddc91ebc1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s184"},"text":null,"children":[{"tag":"num","attrib":{"value":"184"},"text":"§ 184.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incorporation of digital collections into educational curricula","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc91ebc2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s184/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short title","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section may be cited as the “Library of Congress Digital Collections and Educational Curricula Act of 2005”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc91ebc3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s184/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Librarian of Congress shall administer a program to teach educators and librarians how to incorporate the digital collections of the Library of Congress into educational curricula.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc91ebc4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s184/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Educational consortium","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In administering the program under this section, the Librarian of Congress may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc91ebc5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s184/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish an educational consortium to support the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc91ebc6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s184/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make funds appropriated for the program available to consortium members, educational institutions, and libraries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc91ebc7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s184/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary to carry out this section for fiscal year 2006 and each fiscal year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc91ebc8-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/55/tI/s1306"},"text":"Pub. L. 109–55, title I, § 1306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-02"},"text":"Aug. 2, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/583"},"text":"119 Stat. 583","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc91ebc9-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc91ebca-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddc91ebcb-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Legislative Branch Appropriations Act, 2006.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
