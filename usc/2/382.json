{"tag":"section","attrib":{"id":"iddc9dd30d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s382"},"text":null,"children":[{"tag":"num","attrib":{"value":"382"},"text":"§ 382.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of contest","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc9dd30e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s382/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Filing of notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whoever, having been a candidate for election in the last preceding election and claiming a right to such office, intends to contest the election of a Member of the House of Representatives, shall, within thirty days after the result of such election shall have been declared by the officer or Board of Canvassers authorized by law to declare such result, file with the Clerk and serve upon the contestee written notice of his intention to contest such election.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc9dd30f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s382/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents and form of notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such notice shall state with particularity the grounds upon which contestant contests the election and shall state that an answer thereto must be served upon contestant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s383"},"text":"section 383 of this title","children":[],"tail":" within thirty days after service of such notice. Such notice shall be signed by contestant and verified by his oath or affirmation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc9dd310-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s382/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service of notice; proof of service","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Service of the notice of contest upon contestee shall be made as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc9dd311-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s382/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by delivering a copy to him personally;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc9dd312-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s382/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by leaving a copy at his dwelling house or usual place of abode with a person of discretion not less than sixteen years of age then residing therein;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc9dd313-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s382/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by leaving a copy at his principal office or place of business with some person then in charge thereof;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc9dd314-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s382/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by delivering a copy to an agent authorized by appointment to receive service of such notice;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc9dd315-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s382/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by mailing a copy by registered or certified mail addressed to contestee at his residence or principal office or place of business. Service by mail is complete upon mailing; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc9dd316-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s382/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the verified return by the person so serving such notice, setting forth the time and manner of such service shall be proof of same, and the return post office receipt shall be proof of the service of said notice mailed by registered or certified mail as aforesaid. Proof of service shall be made to the Clerk promptly and in any event within the time during which the contestee must answer the notice of contest. Failure to make proof of service does not affect the validity of the service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc9dd317-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/138/s3"},"text":"Pub. L. 91–138, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-05"},"text":"Dec. 5, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/284"},"text":"83 Stat. 284","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/186/tII/s211/3"},"text":"Pub. L. 104–186, title II, § 211(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1744"},"text":"110 Stat. 1744","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc9dd318-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc9dd319-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc9dd31a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186/s211/3/A"},"text":"Pub. L. 104–186, § 211(3)(A)","children":[],"tail":", struck out “to the House of Representatives” after “for election”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186/s211/3/B"},"text":"Pub. L. 104–186, § 211(3)(B)","children":[],"tail":", struck out “or” at end of par. (4) and inserted “or” at end of par. (5)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc9dd31b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddc9dd31c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable with respect to any general or special election for Representative in, or Resident Commissioner to, the Congress of the United States occurring after ","children":[{"tag":"date","attrib":{"date":"1969-12-05"},"text":"Dec. 5, 1969","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/138/s19"},"text":"section 19 of Pub. L. 91–138","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s381"},"text":"section 381 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
