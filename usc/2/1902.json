{"tag":"section","attrib":{"id":"iddceed852-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1902"},"text":null,"children":[{"tag":"num","attrib":{"value":"1902"},"text":"§ 1902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation of Chief","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The annual rate of pay for the Chief of the Capitol Police shall be the amount equal to the annual rate of basic pay for level II of the Executive Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"section 5313 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddceed853-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/152/s1/c"},"text":"Pub. L. 96–152, § 1(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-12-20"},"text":"Dec. 20, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/1099"},"text":"93 Stat. 1099","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/2/tI/s109/a"},"text":"Pub. L. 106–554, § 1(a)(2) [title I, § 109(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–107; "},{"tag":"ref","attrib":{"href":"/us/pl/107/117/dB/s907/a"},"text":"Pub. L. 107–117, div. B, § 907(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-10"},"text":"Jan. 10, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2319"},"text":"115 Stat. 2319","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/7/dH/tI/s1013/a"},"text":"Pub. L. 108–7, div. H, title I, § 1013(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","childr