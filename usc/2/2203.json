{"tag":"section","attrib":{"id":"iddd0917d9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2203"},"text":null,"children":[{"tag":"num","attrib":{"value":"2203"},"text":"§ 2203.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of the Emancipation Hall of the Capitol Visitor Center","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Emancipation Hall of the Capitol Visitor Center may not be used for any event, except upon the passage of a resolution agreed to by both houses of Congress authorizing the use of the Emancipation Hall for that event.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd0917da-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/437/tI/s103"},"text":"Pub. L. 110–437, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-20"},"text":"Oct. 20, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4986"},"text":"122 Stat. 4986","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
