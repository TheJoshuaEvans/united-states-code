{"tag":"section","attrib":{"id":"iddcb32efa-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s658"},"text":null,"children":[{"tag":"num","attrib":{"value":"658"},"text":"§ 658.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this part:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcb32efb-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s658/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “agency” has the same meaning as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s551/1"},"text":"section 551(1) of title 5","children":[],"tail":", but does not include independent regulatory agencies."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb32efc-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s658/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “amount”, with respect to an authorization of appropriations for Federal financial assistance, means the amount of budget authority for any Federal grant assistance program or any Federal program providing loan guarantees or direct loans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb32efd-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s658/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direct costs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “direct costs”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcb32efe-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s658/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddcb32eff-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s658/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a Federal intergovernmental mandate, means the aggregate estimated amounts that all State, local, and tribal governments would be required to spend or would be prohibited from raising in revenues in order to comply with the Federal intergovernmental mandate; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcb32f00-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s658/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a provision referred to in paragraph (5)(A)(ii), means the amount of Federal financial assistance eliminated or reduced;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcb32f01-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s658/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a Federal private sector mandate, means the aggregate estimated amounts that the private sector will be required to spend in order to comply with the Federal private sector mandate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcb32f02-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s658/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall be determined on the assumption that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddcb32f03-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s658/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State, local, and tribal governments, and the private sector will take all reasonable steps necessary to mitigate the costs resulting from the Federal mandate, and will comply with applicable standards of practice and conduct established by recognized professional or trade associations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcb32f04-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s658/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reasonable steps to mitigate the costs shall not include increases in State, local, or tribal taxes or fees; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcb32f05-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s658/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddcb32f06-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s658/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" estimated amounts that the State, local, and tribal governments (in the case of a Federal intergovernmental mandate) or the private sector (in the case of a Federal private sector mandate) would spend—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddcb32f07-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s658/3/D/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to comply with or carry out all applicable Federal, State, local, and tribal laws and regulations in effect at the time of the adoption of the Federal mandate for the same activity as is affected by that Federal mandate; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddcb32f08-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s658/3/D/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to comply with or carry out State, local, and tribal governmental programs, or private-sector business or other activities in effect at the time of the adoption of the Federal mandate for the same activity as is affected by that mandate; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcb32f09-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s658/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" expenditures to the extent that such expenditures will be offset by any direct savings to the State, local, and tribal governments, or by the private sector, as a result of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddcb32f0a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s658/3/D/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compliance with the Federal mandate; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddcb32f0b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s658/3/D/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other changes in Federal law or regulation that are enacted or adopted in the same bill or joint resolution or proposed or final Federal regulation and that govern the same activity as is affected by the Federal mandate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb32f0c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s658/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direct savings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “direct savings”, when used with respect to the result of compliance with the Federal mandate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcb32f0d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s658/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a Federal intergovernmental mandate, means the aggregate estimated reduction in costs to any State, local, or tribal government as a result of compliance with the Federal intergovernmental mandate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcb32f0e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s658/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a Federal private sector mandate, means the aggregate estimated reduction in costs to the private sector as a result of compliance with the Federal private sector mandate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb32f0f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s658/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal intergovernmental mandate","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Federal intergovernmental mandate” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcb32f10-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s658/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any provision in legislation, statute, or regulation that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddcb32f11-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s658/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" would impose an enforceable duty upon State, local, or tribal governments, except—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddcb32f12-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s658/5/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a condition of Federal assistance; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddcb32f13-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s658/5/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a duty arising from participation in a voluntary Federal program, except as provided in subparagraph (B); or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcb32f14-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s658/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" would reduce or eliminate the amount of authorization of appropriations for—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddcb32f15-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s658/5/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal financial assistance that would be provided to State, local, or tribal governments for the purpose of complying with any such previously imposed duty unless such duty is reduced or eliminated by a corresponding amount; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddcb32f16-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s658/5/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the control of borders by the Federal Government; or reimbursement to State, local, or tribal governments for the net cost associated with illegal, deportable, and excludable aliens, including court-mandated expenses related to emergency health care, education or criminal justice; when such a reduction or elimination would result in increased net costs to State, local, or tribal governments in providing education or emergency health care to, or incarceration of, illegal aliens; except that this subclause shall not be in effect with respect to a State, local, or tribal government, to the extent that such government has not fully cooperated in the efforts of the Federal Government to locate, apprehend, and deport illegal aliens;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcb32f17-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s658/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any provision in legislation, statute, or regulation that relates to a then-existing Federal program under which $500,000,000 or more is provided annually to State, local, and tribal governments under entitlement authority, if the provision—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddcb32f18-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s658/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddcb32f19-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s658/5/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would increase the stringency of conditions of assistance to State, local, or tribal governments under the program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddcb32f1a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s658/5/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would place caps upon, or otherwise decrease, the Federal Government’s responsibility to provide funding to State, local, or tribal governments under the program; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcb32f1b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s658/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State, local, or tribal governments that participate in the Federal program lack authority under that program to amend their financial or programmatic responsibilities to continue providing required services that are affected by the legislation, statute, or regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb32f1c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s658/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal mandate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Federal mandate” means a Federal intergovernmental mandate or a Federal private sector mandate, as defined in paragraphs (5) and (7).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb32f1d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s658/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal private sector mandate","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Federal private sector mandate” means any provision in legislation, statute, or regulation that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcb32f1e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s658/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" would impose an enforceable duty upon the private sector except—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddcb32f1f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s658/7/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a condition of Federal assistance; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcb32f20-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s658/7/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a duty arising from participation in a voluntary Federal program; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcb32f21-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s658/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would reduce or eliminate the amount of authorization of appropriations for Federal financial assistance that will be provided to the private sector for the purposes of ensuring compliance with such duty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb32f22-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s658/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local government","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “local government” has the same meaning as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s6501/6"},"text":"section 6501(6) of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb32f23-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s658/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private sector","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “private sector” means all persons or entities in the United States, including individuals, partnerships, associations, corporations, and educational and nonprofit institutions, but shall not include State, local, or tribal governments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb32f24-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s658/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulation; rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “regulation” or “rule” (except with respect to a rule of either House of the Congress) has the meaning of “rule” as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s601/2"},"text":"section 601(2) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb32f25-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s658/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small government","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “small government” means any small governmental jurisdictions defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s601/5"},"text":"section 601(5) of title 5","children":[],"tail":" and any tribal government."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb32f26-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s658/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” has the same meaning as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s6501/9"},"text":"section 6501(9) of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb32f27-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s658/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal government","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “tribal government” means any Indian tribe, band, nation, or other organized group or community, including any Alaska Native village or regional or village corporation as defined in or established pursuant to the Alaska Native Claims Settlement Act (","children":[{"tag":"ref","attrib":{"href":"/us/stat/85/688"},"text":"85 Stat. 688","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1601"},"text":"43 U.S.C. 1601","children":[],"tail":" et seq.) which is recognized as eligible for the special programs and services provided by the United States to Indians because of their special status as Indians."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcb32f28-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/344/tIV/s421"},"text":"Pub. L. 93–344, title IV, § 421","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/4/tI/s101/a/2"},"text":"Pub. L. 104–4, title I, § 101(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-03-22"},"text":"Mar. 22, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/50"},"text":"109 Stat. 50","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/67/dA/tI/s122/14"},"text":"Pub. L. 113–67, div. A, title I, § 122(14)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/1176"},"text":"127 Stat. 1176","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcb32f29-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcb32f2a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddcb32f2b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Alaska Native Claims Settlement Act, referred to in par. (13), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/203"},"text":"Pub. L. 92–203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-12-18"},"text":"Dec. 18, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/688"},"text":"85 Stat. 688","children":[],"tail":", which is classified generally to chapter 33 (§ 1601 et seq.) of Title 43, Public Lands. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1601"},"text":"section 1601 of Title 43","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcb32f2c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2013—Par. (5)(A)(i)(II). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/67"},"text":"Pub. L. 113–67","children":[],"tail":" substituted “subparagraph (B)” for “subparagraph (B))”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcb32f2d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddcb32f2e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":