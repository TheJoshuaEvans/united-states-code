{"tag":"section","attrib":{"id":"iddce7ad0a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1816"},"text":null,"children":[{"tag":"num","attrib":{"value":"1816"},"text":"§ 1816.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction contracts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddce7ad0b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1816/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liquidated damages","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Architect of the Capitol may not enter into or administer any construction contract with a value greater than $50,000 unless the contract includes a provision requiring the payment of liquidated damages in the amount determined under subsection (b) in the event that completion of the project is delayed because of the contractor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce7ad0c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1816/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of payment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of payment required under a liquidated damages provision described in subsection (a) shall be equal to the product of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce7ad0d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1816/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the daily liquidated damage payment rate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce7ad0e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1816/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of days by which the completion of the project is delayed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce7ad0f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1816/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Daily liquidated damage payment rate","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce7ad10-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1816/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In subsection (b), the “daily liquidated damage payment rate” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddce7ad11-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1816/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $140, in the case of a contract with a value greater than $50,000 and less than $100,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce7ad12-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1816/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $200, in the case of a contract with a value equal to or greater than $100,000 and equal to or less than $500,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce7ad13-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1816/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sum of $200 plus $50 for each $100,000 increment by which the value of the contract exceeds $500,000, in the case of a contract with a value greater than $500,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce7ad14-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1816/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment in rate permitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraph (1), the daily liquidated damage payment rate may be adjusted by the contracting officer involved to a rate greater or lesser than the rate described in such paragraph if the contracting officer makes a written determination that the rate described does not accurately reflect the anticipated damages which will be suffered by the United States as a result of the delay in the completion of the contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce7ad15-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1816/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply with respect to contracts entered into during fiscal year 2002 or any succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddce7ad16-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/68/tI/s130"},"text":"Pub. L. 107–68, title I, § 130","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-11-12"},"text":"Nov. 12, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/580"},"text":"115 Stat. 580","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddce7ad17-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddce7ad18-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddce7ad19-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was classified to section 166j of former Title 40, prior to the enactment of Title 40, Public Buildings, Property, and Works, by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217/s1"},"text":"Pub. L. 107–217, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1062"},"text":"116 Stat. 1062","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
