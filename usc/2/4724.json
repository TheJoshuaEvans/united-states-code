{"tag":"section","attrib":{"id":"iddd25a005-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4724"},"text":null,"children":[{"tag":"num","attrib":{"value":"4724"},"text":"§ 4724.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendment to Senate conflict of interest rule","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd25a006-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4724/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided by subsection (b), any employee of the Senate who is required to file a report pursuant to Senate rules shall refrain from participating personally and substantially as an employee of the Senate in any contact with any agency of the executive or judicial branch of Government with respect to non-legislative matters affecting any non-governmental person in which the employee has a significant financial interest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd25a007-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4724/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsection (a) shall not apply if an employee first advises his supervisor of his significant financial interest and obtains from such supervisor a written waiver stating that the participation of the employee is necessary. A copy of each such waiver shall be filed with the Select Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd25a008-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/194/tIX/s903"},"text":"Pub. L. 101–194, title IX, § 903","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-30"},"text":"Nov. 30, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1781"},"text":"103 Stat. 1781","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd25a009-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd25a00a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd25a00b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s60–2"},"text":"section 60–2 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
