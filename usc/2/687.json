,"attrib":{},"text":"1987—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/119"},"text":"Pub. L. 100–119","children":[],"tail":" substituted “If, under this chapter” for “If, under section 683(b) or 684(b) of this title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/620"},"text":"Pub. L. 98–620","children":[],"tail":" struck out provision requiring that the courts give precedence to civil actions brought under this section, and to appeals and writs from decisions in such actions, over all other civil actions, appeals, and writs."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcb8118f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcb81190-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/620"},"text":"Pub. L. 98–620","children":[],"tail":" not applicable to cases pending on "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/620/s403"},"text":"section 403 of Pub. L. 98–620","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1657"},"text":"section 1657 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddcb81191-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Reaffirmation","children":[],"tail":null