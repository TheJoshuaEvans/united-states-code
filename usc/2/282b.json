{"tag":"section","attrib":{"id":"iddc96a661-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s282b"},"text":null,"children":[{"tag":"num","attrib":{"value":"282b"},"text":"§ 282b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc96a662-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s282b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Legislative Counsel shall be paid at a per annum gross rate equal to the greater of $173,900 or the rate of pay in effect for such position under an order issued by the Speaker of the House of Representatives pursuant to the authority of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s4532"},"text":"section 4532 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc96a663-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s282b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the staff of the Office other than the Legislative Counsel shall be paid at per annum gross rates fixed by the Legislative Counsel with the approval of the Speaker or in accordance with policies approved by the Speaker, but not in excess of the applicable rate of pay in effect under an order issued by the Speaker of the House of Representatives pursuant to the authority of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s4532"},"text":"section 4532 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc96a664-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/510/tV/s523"},"text":"Pub. L. 91–510, title V, § 523","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-26"},"text":"Oct. 26, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1203"},"text":"84 Stat. 1203","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/94/tI/s115"},"text":"Pub. L. 95–94, title I, § 115","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-05"},"text":"Aug. 5, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/668"},"text":"91 Stat. 668","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/94/dE/tII/s212/b/3/A"},"text":"Pub. L. 116–94, div. E, title II, § 212(b)(3)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2776"},"text":"133 Stat. 2776","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc96a665-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc96a666-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddc96a667-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/94"},"text":"Pub. L. 95–94","children":[],"tail":" is based on par. (2) of House Resolution No. 8, Ninety-fifth Congress, "},{"tag":"date","attrib":{"date":"1977-01-04"},"text":"Jan. 4, 1977","children":[],"tail":", which was enacted into permanent law by "},{"tag":"ref","attrib":{"href":"/us/pl/95/94"},"text":"Pub. L. 95–94","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"iddc96a668-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"House Resolution 312, 89th Congress, ","children":[{"tag":"date","attrib":{"date":"1965-03-31"},"text":"Mar. 31, 1965","children":[],"tail":", which was enacted into permanent law by "},{"tag":"ref","attrib":{"href":"/us/pl/89/90/s103"},"text":"section 103 of Pub. L. 89–90","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-07-27"},"text":"July 27, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/281"},"text":"79 Stat. 281","children":[],"tail":", provided that effective "},{"tag":"date","attrib":{"date":"1965-04-01"},"text":"Apr. 1, 1965","children":[],"tail":", the compensation of the Legislative Counsel of the House of Representatives shall be at a gross per annum rate which is equal to the gross per annum rate of compensation of the Legislative Counsel of the Senate, and that the additional sums necessary to carry out this resolution shall be paid out of the contingent fund of the House until otherwise provided by law."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc96a669-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s212/b/3/A/i"},"text":"Pub. L. 116–94, § 212(b)(3)(A)(i)","children":[],"tail":", substituted “equal to the greater of $173,900 or the rate of pay in effect for such position under an order issued by the Speaker of the House of Representatives pursuant to the authority of "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s4532"},"text":"section 4532 of this title","children":[],"tail":".” for “equal to the rate of basic pay, as in effect from time to time, for level III of the Executive Schedule of "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5314"},"text":"section 5314 of title 5","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s212/b/3/A/ii"},"text":"Pub. L. 116–94, § 212(b)(3)(A)(ii)","children":[],"tail":", substituted “in excess of the applicable rate of pay in effect under an order issued by the Speaker of the House of Representatives pursuant to the authority of "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s4532"},"text":"section 4532 of this title","children":[],"tail":".” for “in excess of the rate of basic pay for one pay level above the maximum pay level for employees of the House of Representatives provided under clause 6(c) of Rule XI of the Rules of the House of Representatives.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/94"},"text":"Pub. L. 95–94","children":[],"tail":" substituted provisions authorizing compensation at a rate not in excess of the rate of basic pay for one pay level above the maximum pay level for House employees provided under cl. 6(c) of Rule XI of the Rules of the House of Representatives, for provisions authorizing compensation at per annum gross rates not in excess of a per annum gross rate equal to the rate of basic pay for level V of the Executive Schedule of "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5316"},"text":"section 5316 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc96a66a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddc96a66b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2019 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/dE/tII/s212/c"},"text":"Pub. L. 116–94, div. E, title II, § 212(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2778"},"text":"133 Stat. 2778","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/94/dE/tII/s212/c"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“This section [see Tables for classification] and the amendments made by this section shall take effect on the later of—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the first day of the first applicable pay period beginning on or after ","children":[{"tag":"date","attrib":{"date":"2020-01-01"},"text":"January 1, 2020","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the first day of the first applicable pay period beginning on or after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddc96a66c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Increases in Compensation","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Increases in compensation for House officers and employees under authority of Federal Salary Act of 1967 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/206"},"text":"Pub. L. 90–206","children":[],"tail":"), Federal Pay Comparability Act of 1970 ("},{"tag":"ref","attrib":{"href":"/us/pl/91/656"},"text":"Pub. L. 91–656","children":[],"tail":"), and Legislative Branch Appropriations Act, 1988 ("},{"tag":"ref","attrib":{"href":"/us/pl/100/202"},"text":"Pub. L. 100–202","children":[],"tail":"), see sections 4531 and 4532 of this title, and Salary Directives of Speaker of the House, set out as notes under those sections."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
