{"tag":"section","attrib":{"id":"iddd14fe78-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4537"},"text":null,"children":[{"tag":"num","attrib":{"value":"4537"},"text":"§ 4537.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lump sum payment for accrued annual leave of House employees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd14fe79-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4537/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval; amount; source of payments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon the approval of the appropriate employing authority, an employee of the House of Representatives may be paid a lump sum for the accrued annual leave of the employee or for any other purpose. The lump sum—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd14fe7a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4537/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall be paid in an amount not more than the lesser of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd14fe7b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4537/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the monthly pay of the employee, as determined by the Chief Administrative Officer of the House of Representatives; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd14fe7c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4537/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a lump sum payment for the accrued annual leave of the employee, the amount equal to the monthly pay of the employee, as determined by the Chief Administrative Officer of the House of Representatives, divided by 30, and multiplied by the number of days of the accrued annual leave of the employee;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd176f7d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4537/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall be paid—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd176f7e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4537/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for clerk hire employees, from the clerk hire allowance of the Member;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd176f7f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4537/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for committee employees, from amounts appropriated for committees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd176f80-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4537/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for other employees, from amounts appropriated to the employing authority; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd176f81-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4537/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be based on the rate of pay in effect with respect to the employee on the last day of employment of the employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd176f82-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4537/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Committee on House Oversight shall have authority to prescribe regulations to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd176f83-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4537/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Employee of the House of Representatives” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As used in this section, the term “employee of the House of Representatives” means an employee whose pay is disbursed by the Clerk of the House of Representatives or the Chief Administrative Officer of the House of Representatives, as applicable, except that such term does not include a uniformed or civilian support employee under the Capitol Police Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd176f84-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4537/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separations after ","children":[{"tag":"date","attrib":{"date":"1995-06-30"},"text":"June 30, 1995","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Payments under this section may be made with respect to separations from employment taking place after ","children":[{"tag":"date","attrib":{"date":"1995-06-30"},"text":"June 30, 1995","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd176f85-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/53/tI/s109"},"text":"Pub. L. 104–53, title I, § 109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-11-19"},"text":"Nov. 19, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/522"},"text":"109 Stat. 522","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/55/tI/s103/a"},"text":"Pub. L. 105–55, title I, § 103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-10-07"},"text":"Oct. 7, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1183"},"text":"111 Stat. 1183","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd176f86-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd176f87-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd176f88-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 60","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Congressional Operations Appropriations Act, 1996, which is title I of the Legislative Branch Appropriations Act, 1996.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd176f89-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/55/s103/a/1"},"text":"Pub. L. 105–55, § 103(a)(1)","children":[],"tail":", (2), in introductory provisions, struck out “who is separated from employment,” after “House of Representatives” and substituted “of the employee or for any other purpose” for “of the employee”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/55/s103/a/3"},"text":"Pub. L. 105–55, § 103(a)(3)","children":[],"tail":", substituted “in the case of a lump sum payment for the accrued annual leave of the employee, the amount” for “the amount”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd176f8a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"iddd176f8b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on House Oversight of House of Representatives changed to Committee on House Administration of House of Representatives by House Resolution No. 5, One Hundred Sixth Congress, ","children":[{"tag":"date","attrib":{"date":"1999-01-06"},"text":"Jan. 6, 1999","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd176f8c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/55/tI/s103/b"},"text":"Pub. L. 105–55, title I, § 103(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-10-07"},"text":"Oct. 7, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1183"},"text":"111 Stat. 1183","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/55/tI/s103/b"},"text":"“The amendments made by subsection (a) [amending this section] shall apply to fiscal years beginning on or after ","children":[{"tag":"date","attrib":{"date":"1997-10-01"},"text":"October 1, 1997","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
