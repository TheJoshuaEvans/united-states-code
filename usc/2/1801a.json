{"tag":"section","attrib":{"id":"iddce56263-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1801a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1801a"},"text":"§ 1801a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment and term of service of Architect of the Capitol","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddce56264-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1801a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Architect of the Capitol shall be appointed, without regard to political affiliation and solely on the basis of fitness to perform the duties of the office, upon a majority vote of a congressional commission (referred to in this section as the “commission”) consisting of the Speaker of the House of Representatives, the majority leader of the Senate, the minority leaders of the House of Representatives and Senate, the chair and ranking minority member of the Committee on Appropriations of the House of Representatives, the chairman and ranking minority member of the Committee on Appropriations of the Senate, the chair and ranking minority member of the Committee on House Administration of the House of Representatives, and the chairman and ranking minority member of the Committee on Rules and Administration of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce56265-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1801a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Architect of the Capitol shall be appointed for a term of 10 years and, upon a majority vote of the members of the commission, may be reappointed for additional 10-year terms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce56266-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1801a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Architect of the Capitol may be removed from office at any time upon a majority vote of the members of the commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce56267-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1801a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce56268-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1801a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section, and the amendments made by this section, shall apply with respect to appointments made on or after ","children":[{"tag":"date","attrib":{"date":"2023-12-22"},"text":"December 22, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddce56269-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dE/tLVII/s5702"},"text":"Pub. L. 118–31, div. E, title LVII, § 5702","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/960"},"text":"137 Stat. 960","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddce5626a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddce5626b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddce5626c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For the amendments made by this section, referred to in subsec. (e), see Codification note below.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddce5626d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s5702"},"text":"section 5702 of Pub. L. 118–31","children":[],"tail":". Subsec. (d)(1) of "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/s5702"},"text":"section 5702 of Pub. L. 118–31","children":[],"tail":" repealed "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1801"},"text":"section 1801 of this title","children":[],"tail":". Subsec. (d)(2) of "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/s5702"},"text":"section 5702 of Pub. L. 118–31","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1811"},"text":"section 1811 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
