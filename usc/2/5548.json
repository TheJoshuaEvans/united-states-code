{"tag":"section","attrib":{"id":"iddd2f3d1c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5548"},"text":null,"children":[{"tag":"num","attrib":{"value":"5548"},"text":"§ 5548.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments to ensure continuing availability of goods and services during the coronavirus emergency","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd2f3d1d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5548/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization to make payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law and subject to subsection (b), during an emergency situation, the Chief Administrative Officer of the House of Representatives may make payments under contracts with vendors providing goods and services to the House in amounts and under terms and conditions other than those provided under the contract in order to ensure that those goods and services remain available to the House throughout the duration of the emergency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2f3d1e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5548/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2f3d1f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5548/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chief Administrative Officer may not make payments under the authority of subsection (a) without the approval of the Committee on House Administration of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2f3d20-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5548/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority of the Chief Administrative Officer to make payments under the authority of subsection (a) is subject to the availability of appropriations to make such payments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2f3d21-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5548/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply with respect to fiscal year 2020 and each succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd2f3d22-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/dB/tIX/s19003"},"text":"Pub. L. 116–136, div. B, title IX, § 19003","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/578"},"text":"134 Stat. 578","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd2f3d23-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd2f3d24-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd2f3d25-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Emergency Appropriations for Coronavirus Health Response and Agency Operations, which is div. B of the Coronavirus Aid, Relief, and Economic Security Act or the CARES Act.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd2f3d26-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"iddd2f3d27-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definition","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definition of “coronavirus”, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/s23005"},"text":"section 23005 of Pub. L. 116–136","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s162b"},"text":"section 162b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
