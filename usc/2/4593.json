{"tag":"section","attrib":{"id":"iddd235674-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4593"},"text":null,"children":[{"tag":"num","attrib":{"value":"4593"},"text":"§ 4593.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver by Secretary of Senate of claims of United States arising out of erroneous payments to Vice President, Senator, or Senate employee paid by Secretary of Senate","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd235675-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4593/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver of claim for erroneous payment of pay or allowances","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A claim of the United States against a person arising out of an erroneous payment of any pay or allowances, other than travel and transportation expenses and allowances, on or after ","children":[{"tag":"date","attrib":{"date":"1974-07-25"},"text":"July 25, 1974","children":[],"tail":", to the Vice President, a Senator, or to an officer or employee whose pay is disbursed by the Secretary of the Senate, the collection of which would be against equity and good conscience and not in the best interests of the United States, may be waived in whole or in part by the Secretary of the Senate. An application for waiver shall be investigated by the Financial Clerk of the Senate who shall submit a written report of his investigation to the Secretary of the Senate. An application for waiver of a claim in an amount aggregating more than $1,500 may also be investigated by the Comptroller General of the United States who shall submit a written report of his investigation to the Secretary of the Senate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd235676-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4593/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of waiver","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Senate may not exercise his authority under this section to waive any claim—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd235677-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4593/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if, in his opinion, there exists, in connection with the claim, an indication of fraud, misrepresentation, fault, or lack of good faith on the part of the Vice President, the Senator, the officer or employee, or any other person having an interest in obtaining a waiver of the claim; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd235678-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4593/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the application for waiver is received in his office after the expiration of 3 years immediately following the date on which the erroneous payment of pay or allowances was discovered.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd235679-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4593/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit for waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the audit and settlement of accounts of any accountable officer or official, full credit shall be given for any amounts with respect to which collection by the United States is waived under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd23567a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4593/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An erroneous payment, the collection of which is waived under this section, is deemed a valid payment for all purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd23567b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4593/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction with other laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section does not affect any authority under any other law to litigate, settle, compromise, or waive any claim of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd23567c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4593/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Senate shall promulgate rules and regulations to carry out the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd23567d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/359/s2"},"text":"Pub. L. 93–359, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-07-25"},"text":"July 25, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/394"},"text":"88 Stat. 394","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/69/tIII/s315"},"text":"Pub. L. 103–69, title III, § 315","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-11"},"text":"Aug. 11, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/713"},"text":"107 Stat. 713","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/316/tI/s102/b"},"text":"Pub. L. 104–316, title I, § 102(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3828"},"text":"110 Stat. 3828","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd23567e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd23567f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd235680-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s130c"},"text":"section 130c of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd235681-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/316"},"text":"Pub. L. 104–316","children":[],"tail":" in first sentence struck out “, if the claim is not the subject of an exception made by the Comptroller General in the account of any accountable officer or official” after “in part by the Secretary of the Senate”, and in third sentence substituted “$1,500 may also” for “$1,500 shall also”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/69"},"text":"Pub. L. 103–69","children":[],"tail":" substituted “$1,500” for “$500”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd235682-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd235683-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/316/tI/s101/e"},"text":"Pub. L. 104–316, title I, § 101(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3827"},"text":"110 Stat. 3827","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/316/tI/s101/e"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), this title [see Tables for classification] shall take effect on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Sections 103(d), 105(b), and 116 [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5584"},"text":"section 5584 of Title 5","children":[],"tail":", Government Organization and Employees, "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2774"},"text":"section 2774 of Title 10","children":[],"tail":", Armed Forces, and "},{"tag":"ref","attrib":{"href":"/us/usc/t32/s716"},"text":"section 716 of Title 32","children":[],"tail":", National Guard] shall take effect 60 days after the date of enactment of this Act.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
