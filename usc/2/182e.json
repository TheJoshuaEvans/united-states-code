{"tag":"section","attrib":{"id":"iddc8f7b93-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182e"},"text":null,"children":[{"tag":"num","attrib":{"value":"182e"},"text":"§ 182e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Library of Congress National Collection Stewardship Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc8f7b94-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby established in the Treasury of the United States, as an account for the Librarian of Congress, the “Library of Congress National Collection Stewardship Fund” (hereafter in this section referred to as the “Fund”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc8f7b95-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of Fund","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Fund shall consist of the following amounts:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc8f7b96-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002014"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002014"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. No par. (2) has been enacted."}],"tail":" Such amounts as may be transferred by the Librarian from available amounts appropriated for any fiscal year for the Library of Congress under the heading “Salaries and Expenses”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc8f7b97-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of amounts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts in the Fund may be used by the Librarian as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc8f7b98-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182e/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Librarian may use amounts directly for the purpose of preparing collection materials of the Library of Congress for long-term storage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc8f7b99-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182e/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Librarian may transfer amounts to the Architect of the Capitol for the purpose of designing, constructing, altering, upgrading, and equipping collections preservation and storage facilities for the Library of Congress, or for the purpose of acquiring real property by lease for the preservation and storage of Library of Congress collections in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1823a"},"text":"section 1823a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc8f7b9a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuing availability of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amounts in the Fund shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc8f7b9b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182e/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after the end of each fiscal year, the Librarian shall submit a joint report on the Fund to the Joint Committee on the Library and the Committees on Appropriations of the House of Representatives and Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc8f7b9c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182e/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial 5–year plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 6 months after ","children":[{"tag":"date","attrib":{"date":"2017-05-05"},"text":"May 5, 2017","children":[],"tail":", the Librarian shall submit to the Joint Committee on the Library and the Committees on Appropriations of the House of Representatives and Senate a report providing a plan for expenditures from the Fund for the first 5 fiscal years of the Fund’s operation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc8f7b9d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182e/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of transfers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Prior to any transfer into the Fund, the Librarian shall notify the Joint Committee on the Library and the Committees on Appropriations of the House and the Senate of the amount and origin of funds to be transferred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc8f7b9e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182e/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply with respect to fiscal year 2017 and each succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc8f7b9f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/31/dI/tI/s1302"},"text":"Pub. L. 115–31, div. I, title I, § 1302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-05-05"},"text":"May 5, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/584"},"text":"131 Stat. 584","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
