{"tag":"section","attrib":{"id":"iddcae73ec-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s637"},"text":null,"children":[{"tag":"num","attrib":{"value":"637"},"text":"§ 637.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Legislation dealing with Congressional budget must be handled by Budget Committees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcae73ed-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s637/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In the Senate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the Senate, no bill, resolution, amendment, motion, or conference report, dealing with any matter which is within the jurisdiction of the Committee on the Budget shall be considered unless it is a bill or resolution which has been reported by the Committee on the Budget (or from the consideration of which such committee has been discharged) or unless it is an amendment to such a bill or resolution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcae73ee-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s637/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In the House of Representatives","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the House of Representatives, no bill or joint resolution, or amendment thereto, or conference report thereon, dealing with any matter which is within the jurisdiction of the Committee on the Budget shall be considered unless it is a bill or joint resolution which has been reported by the Committee on the Budget (or from the consideration of which such committee has been discharged) or unless it is an amendment to such a bill or joint resolution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcae73ef-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/344/tIII/s306"},"text":"Pub. L. 93–344, title III, § 306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-07-12"},"text":"July 12, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/313"},"text":"88 Stat. 313","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/177/tII/s201/b"},"text":"Pub. L. 99–177, title II, § 201(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-12"},"text":"Dec. 12, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1050"},"text":"99 Stat. 1050","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXIII/s13207/a/1/D"},"text":"Pub. L. 101–508, title XIII, § 13207(a)(1)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-617"},"text":"104 Stat. 1388–617","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/67/dA/tI/s122/7"},"text":"Pub. L. 113–67, div. A, title I, § 122(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/1175"},"text":"127 Stat. 1175","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcae73f0-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcae73f1-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddcae73f2-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1327"},"text":"section 1327 of Title 31","children":[],"tail":" prior to the general revision and enactment of Title 31, Money and Finance, by "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s1"},"text":"Pub. L. 97–258, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/877"},"text":"96 Stat. 877","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcae73f3-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2013—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/67"},"text":"Pub. L. 113–67","children":[],"tail":" designated existing provisions as subsec. (a) and inserted heading, substituted “In the Senate, no” for “No”, struck out “of either House” after “jurisdiction of the Committee on the Budget”, “in that House” after “shall be considered”, and “of that House” after “reported by the Committee on the Budget”, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" substituted “bill, resolution, amendment, motion, or conference report” for “bill or resolution, and no amendment to any bill or resolution”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/177"},"text":"Pub. L. 99–177","children":[],"tail":" reenacted section without change."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statu