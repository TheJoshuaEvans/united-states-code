{"tag":"section","attrib":{"id":"iddc708190-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s27"},"text":null,"children":[{"tag":"num","attrib":{"value":"27"},"text":"§ 27.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Change of place of meeting","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whenever Congress is about to convene, and from the prevalence of contagious sickness, or the existence of other circumstances, it would, in the opinion of the President, be hazardous to the lives or health of the members to meet at the seat of Government, the President is authorized, by proclamation, to convene Congress at such other place as he may judge proper.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc708191-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(R.S. § 34.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc708192-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc708193-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddc708194-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 34 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1794-04-03/ch17"},"text":"act Apr. 3, 1794, ch. 17","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/1/353"},"text":"1 Stat. 353","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
