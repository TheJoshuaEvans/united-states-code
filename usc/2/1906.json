{"tag":"section","attrib":{"id":"iddceed8b3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1906"},"text":null,"children":[{"tag":"num","attrib":{"value":"1906"},"text":"§ 1906.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposal of surplus property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddceed8b4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1906/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within the limits of available appropriations, the Capitol Police may dispose of surplus or obsolete property of the Capitol Police, and property which is in the possession of the Capitol Police because it has been disposed, forfeited, voluntarily abandoned, or unclaimed, by interagency transfer, donation, sale, trade-in, or other appropriate method.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddceed8b5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1906/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amounts received","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amounts received by the Capitol Police from the disposition of property under subsection (a) shall be credited to the account established for the general expenses of the Capitol Police, and shall be available to carry out the purposes of such account during the fiscal year in which the amounts are received and the following fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddceed8b6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1906/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply to fiscal year 2003 and each fiscal year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddceed8b7-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7/dH/tI/s1003"},"text":"Pub. L. 108–7, div. H, title I, § 1003","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/357"},"text":"117 Stat. 357","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/31/dI/tI/s1001/a"},"text":"Pub. L. 115–31, div. I, title I, § 1001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-05-05"},"text":"May 5, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/578"},"text":"131 Stat. 578","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddceed8b8-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddceed8b9-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddceed8ba-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Legislative Branch Appropriations Act, 2003, which is div. H of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7"},"text":"Pub. L. 108–7","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddceed8bb-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/31"},"text":"Pub. L. 115–31","children":[],"tail":" substituted “surplus or obsolete property of the Capitol Police, and property which is in the possession of the Capitol Police because it has been disposed, forfeited, voluntarily abandoned, or unclaimed,” for “surplus or obsolete property of the Capitol Police”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddceed8bc-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddceed8bd-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/31/dI/tI/s1001/c"},"text":"Pub. L. 115–31, div. I, title I, § 1001(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-05-05"},"text":"May 5, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/578"},"text":"131 Stat. 578","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/31/dI/tI/s1001/c"},"text":"“This section [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1982"},"text":"section 1982 of this title","children":[],"tail":" and amending this section] and the amendment made by this section shall apply with respect to fiscal year 2017 and each succeeding fiscal year.”"}],"tail":"\n"}],"tail":"\