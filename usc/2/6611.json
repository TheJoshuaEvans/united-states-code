{"tag":"section","attrib":{"id":"iddd3d95a8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6611"},"text":null,"children":[{"tag":"num","attrib":{"value":"6611"},"text":"§ 6611.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer authority and Sergeant at Arms Business Continuity and Disaster Recovery Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd3d95a9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6611/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Sergeant at Arms and Doorkeeper of the Senate is authorized, with the approval of the Senate Committee on Appropriations, to transfer, during any fiscal year, from the appropriations account, appropriated under the headings “Salaries, Officers and Employees” and “Office of the Sergeant at Arms and Doorkeeper”, such sums as he shall specify to the appropriations account, within the contingent fund of the Senate, for expenses of the Office of the Sergeant at Arms and Doorkeeper of the Senate; and any funds so transferred shall be available in like manner and for the same purposes as are other funds in the account to which the funds are transferred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3fde9a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6611/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sergeant at Arms Business Continuity and Disaster Recovery Fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd3fde9b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6611/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd3fde9c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6611/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Fund” means the Sergeant at Arms Business Continuity and Disaster Recovery Fund established under paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3fde9d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6611/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Sergeant at Arms” means the Sergeant at Arms and Doorkeeper of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3fde9e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6611/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established under the heading “","children":[{"tag":"inline","attrib":{},"text":"Contingent Expenses of the Senate","children":[],"tail":"” an account to be known as the “Sergeant at Arms Business Continuity and Disaster Recovery Fund”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3fde9f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6611/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts in the Fund shall be available to the Sergeant at Arms for purposes of the business continuity and disaster recovery needs of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3fdea0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6611/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to transfer","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd3fdea1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6611/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraph (C), prior to the date of the withdrawal of amounts appropriated under the heading “","children":[{"tag":"inline","attrib":{},"text":"Contingent Expenses of the Senate—sergeant at arms and doorkeeper of the senate","children":[],"tail":"” in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s4107"},"text":"section 4107 of this title","children":[],"tail":", any unobligated balances of expired discretionary appropriations of such amounts may be transferred by the Sergeant at Arms to the Fund."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3fdea2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6611/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts transferred under subparagraph (A) shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3fdea3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6611/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Sergeant at Arms intends to transfer amounts under subparagraph (A), the Sergeant at Arms shall submit to the Committee on Appropriations of the Senate written notice not later than 15 days before the date of the withdrawal of such amounts in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s4107"},"text":"section 4107 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3fdea4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6611/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority to transfer amounts under this paragraph shall apply with respect to amounts appropriated for fiscal year 2022, or any fiscal year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3fdea5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6611/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Fund such sums as are necessary for fiscal year 2022 and each fiscal year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd3fdea6-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/520/tI/s5"},"text":"Pub. L. 101–520, title I, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2258"},"text":"104 Stat. 2258","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dI/tI/s103"},"text":"Pub. L. 117–103, div. I, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/505"},"text":"136 Stat. 505","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd3fdea7-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd3fdea8-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd3fdea9-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s68–6a"},"text":"section 68–6a of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Congressional Operations Appropriations Act, 1991, which is title I of the Legislative Branch Appropriations Act, 1991.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd3fdeaa-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103"},"text":"Pub. L. 117–103","children":[],"tail":" substituted “Transfer authority and Sergeant at Arms Business Continuity and Disaster Recovery Fund” for “Transfers from appropriations account for expenses of Office of Sergeant at Arms and Doorkeeper of Senate” in section catchline, designated existing provisions as subsec. (a), inserted heading, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
