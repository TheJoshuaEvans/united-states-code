{"tag":"section","attrib":{"id":"iddcb811c8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s802"},"text":null,"children":[{"tag":"num","attrib":{"value":"802"},"text":"§ 802.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcb811c9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s802/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment, functions, and purposes; nature of awards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall establish and administer a program to be known as the Congressional Award Program, which shall be designed to promote initiative, achievement, and excellence among youths in the areas of public service, personal development, and physical and expedition fitness. Under the program medals shall be awarded to young people within the United States, aged fourteen through twenty-three (subject to such exceptions as the Board may prescribe), who have satisfied the standards of achievement established by the Board under subsection (b) of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcb811ca-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s802/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation requirements for Board","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the Congressional Award Program, the Board shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcb811cb-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s802/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish the standards of achievement required for young people to qualify as recipients of the medals and establish such procedures as may be required to verify that individuals satisfy such qualifications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb811cc-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s802/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designate the recipients of the medals in accordance with the standards established under paragraph (1) of this subsection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb811cd-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s802/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" delineate such roles as the Board considers to be appropriate for the Director and Regional Directors in administering the Congressional Award, and set forth in the bylaws of the Board the duties, salaries, and benefits of the Director and Regional Directors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb811ce-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s802/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" raise funds for the operation of the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb811cf-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s802/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take such other actions as may be appropriate for the administration of the Congressional Award Program.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"No salary established by the Board shall exceed $75,000 per annum, except that for calendar years after 1986, such limit shall be increased in proportion to increases in the Consumer Price Index.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcb811d0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s802/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presentation of awards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall arrange for the presentation of the awards to the recipients and shall provide for participation by Members of Congress in such presentation, when appropriate. To the extent possible, recipients shall be provided with opportunities to exchange information and views with Members of Congress in connection with the presentation of the awards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcb811d1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s802/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scholarships for recipients of Congressional Award Gold, Silver, and Bronze Medals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board may award scholarships in such amounts as the Board determines to be appropriate to any recipient of the Congressional Award Gold, Silver, and Bronze Medals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcb811d2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s802/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcb811d3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s802/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional Award Program medals","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcb811d4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s802/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Design and striking","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury shall strike the medals described in subsection (a) and awarded by the Board under this chapter. The medals shall be of such quantity, design, and specifications as the Secretary of the Treasury may determine, after consultation with the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb811d5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s802/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National medals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The medals struck pursuant to this chapter are National medals for purposes of chapter 51 of title 31.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb811d6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s802/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be charged against the Numismatic Public Enterprise Fund such amounts as may be necessary to pay for the cost of the medals struck pursuant to this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcb811d7-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/114/tI/s102"},"text":"Pub. L. 96–114, title I, § 102","children":[],"tail":", formerly § 3, "},{"tag":"date","attrib":{"date":"1979-11-16"},"text":"Nov. 16, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/851"},"text":"93 Stat. 851","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/161/s4/a"},"text":"Pub. L. 99–161, § 4(a)","children":[],"tail":"–(c), "},{"tag":"date","attrib":{"date":"1985-11-25"},"text":"Nov. 25, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/934"},"text":"99 Stat. 934","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/674/s2/a"},"text":"Pub. L. 100–674, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-17"},"text":"Nov. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3996"},"text":"102 Stat. 3996","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/525/s3"},"text":"Pub. L. 101–525, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-06"},"text":"Nov. 6, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2305"},"text":"104 Stat. 2305","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/329/tVI/s637"},"text":"Pub. L. 103–329, title VI, § 637","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-30"},"text":"Sept. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2431"},"text":"108 Stat. 2431","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/63/s1/a"},"text":"Pub. L. 106–63, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-01"},"text":"Oct. 1, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/510"},"text":"113 Stat. 510","children":[],"tail":"; renumbered title I, § 102, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/533/s1/b/1"},"text":"Pub. L. 106–533, § 1(b)(1)","children":[],"tail":", (2), (4), "},{"tag":"date","attrib":{"date":"2000-11-22"},"text":"Nov. 22, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2553"},"text":"114 Stat. 2553","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/200/s2/a"},"text":"Pub. L. 111–200, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-07"},"text":"July 7, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1368"},"text":"124 Stat. 1368","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/66/s3"},"text":"Pub. L. 119–66, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-26"},"text":"Dec. 26, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1992"},"text":"139 Stat. 1992","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcb811d8-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcb811d9-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddcb811da-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (e), which required the Board to submit an annual report to Congress on the activities of the Congressional Award Program, terminated, effective ","children":[{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", pursuant to "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance. See, also, page 199 of House Document No. 103–7."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcb811db-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/66/s3/1"},"text":"Pub. L. 119–66, § 3(1)","children":[],"tail":", struck out “Each medal shall consist of gold-plate over bronze, rhodium over bronze, or bronze and shall be struck in accordance with subsection (f).” after “subsection (b) of this section.”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/66/s3/2"},"text":"Pub. L. 119–66, § 3(2)","children":[],"tail":", substituted “The” for “Subject to subsection (a), the” in second sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/200/s2/a/1"},"text":"Pub. L. 111–200, § 2(a)(1)","children":[],"tail":", struck out “under paragraph (3)” after “established by the Board” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/200/s2/a/2"},"text":"Pub. L. 111–200, § 2(a)(2)","children":[],"tail":", substituted “in connection with” for “during” in second sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/533/s1/b/4/A"},"text":"Pub. L. 106–533, § 1(b)(4)(A)","children":[],"tail":", which directed technical amendment to reference in original act which would have appeared in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s804/g/1"},"text":"section 804(g)(1) of this title","children":[],"tail":", could not be executed because that reference did not appear in the original. See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/533/s1/b/4/B"},"text":"Pub. L. 106–533, § 1(b)(4)(B)","children":[],"tail":", made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s806"},"text":"section 806 of this title","children":[],"tail":". See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/63"},"text":"Pub. L. 106–63","children":[],"tail":" substituted “June 1” for “April 1” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/329/s637/1"},"text":"Pub. L. 103–329, § 637(1)","children":[],"tail":", struck out “gold, silver, and bronze” after “Under the program” and substituted last sentence for former last sentence which read as follows: “The medals shall be of such design and materials as the Board may determine.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/329/s637/2"},"text":"Pub. L. 103–329, § 637(2)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/525"},"text":"Pub. L. 101–525","children":[],"tail":" substituted “April 1” for “March 1”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (e)(6) to (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/674"},"text":"Pub. L. 100–674","children":[],"tail":" added pars. (6) and (7) and redesignated former par. (6) as (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/161/s4/a"},"text":"Pub. L. 99–161, § 4(a)","children":[],"tail":", inserted provision limiting salaries established by Board under par. (3) to $75,000 per annum, such limit after 1986 being increased in proportion to Consumer Price Index."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/161/s4/b"},"text":"Pub. L. 99–161, § 4(b)","children":[],"tail":", inserted reference to Silver and Bronze Medals."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/161/s4/c"},"text":"Pub. L. 99–161, § 4(c)","children":[],"tail":", inserted “for each member, officer, employee, and consultant of the Board (or of the Corporation established pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s806/g/1"},"text":"section 806(g)(1) of this title","children":[],"tail":")”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
