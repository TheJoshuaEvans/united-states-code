{"tag":"section","attrib":{"id":"iddc96a63a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s276b"},"text":null,"children":[{"tag":"num","attrib":{"value":"276b"},"text":"§ 276b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel and related expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Funds expended by the Legislative Counsel of the Senate for travel and related expenses shall be subject to the same regulations and limitations (insofar as they are applicable) as those which the Senate Committee on Rules and Administration prescribes for application to travel and related expenses for which payment is authorized to be made from the contingent fund of the Senate.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc96a63b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/51/tI/s106"},"text":"Pub. L. 98–51, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-07-14"},"text":"July 14, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/267"},"text":"97 Stat. 267","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc96a63c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc96a63d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddc96a63e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Congressional Operations Appropriation Act, 1984, which is title I of the Legislative Branch Appropriation Act, 1984, and not as part of section 1303 of act ","children":[{"tag":"date","attrib":{"date":"1919-02-24"},"text":"Feb. 24, 1919","children":[],"tail":" which comprises this subchapter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section, as it relates to funds expended by the Senate Legal Counsel, is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s288n"},"text":"section 288n of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
