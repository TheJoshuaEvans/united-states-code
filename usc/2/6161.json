{"tag":"section","attrib":{"id":"iddd33f8cb-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6161"},"text":null,"children":[{"tag":"num","attrib":{"value":"6161"},"text":"§ 6161.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Senate Democratic Leadership Offices Funding and Authorities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd33f8cc-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6161/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd33f8cd-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6161/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “applicable conference” means the majority or minority conference of the Senate, as applicable, that represents the Democratic party;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd33f8ce-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6161/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “covered Congress” means the 118th and any subsequent Congress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd33f8cf-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6161/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “covered period” means the period beginning on the date on which the Secretary of the applicable conference submits the letter described in subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd33f8d0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6161/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “designated officer of the applicable conference” means the member of the leadership of the applicable conference to whom the duties and authorities of the Secretary of the applicable conference are assigned under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd33f8d1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6161/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of the applicable conference may, by submission of a letter to the Disbursing Office of the Senate, at the direction of the Chair of the applicable conference, assign to a member of the leadership of the applicable conference the following duties and authorities for the duration of the covered Congress:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd33f8d2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6161/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The authority over any amounts made available for the Office of the Secretary of the applicable conference.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd33f8d3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6161/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The duties and authorities of the Secretary of the applicable conference under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s6154"},"text":"section 6154 of this title","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s6156"},"text":"section 6156 of this title","children":[],"tail":", or any other provision of law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd33f8d4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6161/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of any individual employed by the office of the designated officer of the applicable conference during the covered period—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd33f8d5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6161/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any reference to the Office of the Secretary of the applicable conference in the last sentence of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s6314/e"},"text":"section 6314(e) of this title","children":[],"tail":" shall be deemed to refer to the office of the designated officer of the applicable conference;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd33f8d6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6161/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any reference to the Office of the Secretary of the applicable conference under subsection (b) of the first section of S. Res. 458 (98th Congress) shall be deemed to refer to the office of the designated officer of the applicable conference; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd33f8d7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6161/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any reference to the Secretary of the applicable conference under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s207/e/9/M"},"text":"section 207(e)(9)(M) of title 18","children":[],"tail":" shall be deemed to refer to the designated officer of the applicable conference."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd33f8d8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6161/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of any individual employed by the office of the designated officer of the applicable conference during the covered period and with respect to any practice that occurs during the covered period, any reference to the Office of the Secretary of the applicable conference under section 220(e)(2)(C) of the Congressional Accountability Act of 1995 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1351/e/2/C"},"text":"2 U.S.C. 1351(e)(2)(C)","children":[],"tail":") shall be deemed to be a reference to the office of the designated officer of the applicable conference."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd33f8d9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6161/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this section shall be construed to have any effect on the continuation of any procedure or action initiated under the Congressional Accountability Act of 1995 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1301"},"text":"2 U.S.C. 1301","children":[],"tail":" et seq.) or "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s207"},"text":"section 207 of title 18","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd33f8da-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dI/tI/s104"},"text":"Pub. L. 116–260, div. I, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1631"},"text":"134 Stat. 1631","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dI/tI/s103/a"},"text":"Pub. L. 117–328, div. I, title I, § 103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4917"},"text":"136 Stat. 4917","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/37/dC/tI/s102"},"text":"Pub. L. 119–37, div. C, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-11-12"},"text":"Nov. 12, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/566"},"text":"139 Stat. 566","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd33f8db-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd33f8dc-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd33f8dd-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Congressional Accountability Act of 1995, referred to in subsec. (e), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/1"},"text":"Pub. L. 104–1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-01-23"},"text":"Jan. 23, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/3"},"text":"109 Stat. 3","children":[],"tail":", which is classified principally to chapter 24 (§ 1301 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1301"},"text":"section 1301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd33f8de-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s6154"},"text":"section 6154 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd33f8df-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/37/s102/1"},"text":"Pub. L. 119–37, § 102(1)","children":[],"tail":", inserted “and any subsequent” after “the 118th”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/37/s102/2"},"text":"Pub. L. 119–37, § 102(2)","children":[],"tail":", struck out “and ending on "},{"tag":"date","attrib":{"date":"2025-01-07"},"text":"January 7, 2025","children":[],"tail":"” after “described in subsection (b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/37/s102/3"},"text":"Pub. L. 119–37, § 102(3)","children":[],"tail":", struck out “on or after "},{"tag":"date","attrib":{"date":"2023-01-03"},"text":"January 3, 2023","children":[],"tail":"” after “Disbursing Office of the Senate” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s103/a/2/A"},"text":"Pub. L. 117–328, § 103(a)(2)(A)","children":[],"tail":", substituted “means the 118th Congress;” for “means the 117th Congress; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s103/a/2/B"},"text":"Pub. L. 117–328, § 103(a)(2)(B)","children":[],"tail":", substituted “and ending on "},{"tag":"date","attrib":{"date":"2025-01-07"},"text":"January 7, 2025","children":[],"tail":"; and” for “and ending on "},{"tag":"date","attrib":{"date":"2023-01-03"},"text":"January 3, 2023","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s103/a/2/C"},"text":"Pub. L. 117–328, § 103(a)(2)(C)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":", 103(a)(3), substituted “"},{"tag":"date","attrib":{"date":"2023-01-03"},"text":"January 3, 2023","children":[],"tail":", at the direction of the Chair of the applicable conference, assign to a member of the leadership of the applicable conference” for “"},{"tag":"date","attrib":{"date":"2021-01-03"},"text":"January 3, 2021","children":[],"tail":", assign to the Assistant Leader of the applicable conference” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":", 103(a)(1), substituted “office of the designated officer” for “Office of the Assistant Leader” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":", 103(a)(4), substituted “designated officer” for “Assistant Leader”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":", 103(a)(1), substituted “office of the designated officer” for “Office of the Assistant Leader” in two places."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd33f8e0-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd33f8e1-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dI/tI/s103/b"},"text":"Pub. L. 117–328, div. I, title I, § 103(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4918"},"text":"136 Stat. 4918","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/328/dI/tI/s103/b"},"text":"“The amendments made by subsection (a) [amending this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"2023-01-03"},"text":"January 3, 2023","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
