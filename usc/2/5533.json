{"tag":"section","attrib":{"id":"iddd2ccc58-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5533"},"text":null,"children":[{"tag":"num","attrib":{"value":"5533"},"text":"§ 5533.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" House of Representatives Revolving Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd2ccc59-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5533/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is established in the House of Representatives a fund to be known as the “House of Representatives Revolving Fund”, consisting of the following amounts:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2ccc5a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5533/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts appropriated to the Fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2ccc5b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5533/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts donated to the Fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2ccc5c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5533/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Interest on the balance of the Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2ccc5d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5533/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts in the Fund shall be expended at the direction of the Chief Administrative Officer of the House of Representatives, upon notification provided by the Chief Administrative Officer to the Committee on Appropriations of the House of Representatives, and shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2ccc5e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5533/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply with respect to fiscal year 2004 and each succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd2ccc5f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/199/dH/s156"},"text":"Pub. L. 108–199, div. H, § 156","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-01-23"},"text":"Jan. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/450"},"text":"118 Stat. 450","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd2ccc60-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd2ccc61-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd2ccc62-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s95e"},"text":"section 95e of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Miscellaneous Appropriations and Offsets Act, 2004, which is division H of the Consolidated Appropriations Act, 2004.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
