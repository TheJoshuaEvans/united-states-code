{"tag":"section","attrib":{"id":"iddc94356c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s192"},"text":null,"children":[{"tag":"num","attrib":{"value":"192"},"text":"§ 192.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Refusal of witness to testify or produce papers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Every person who having been summoned as a witness by the authority of either House of Congress to give testimony or to produce papers upon any matter under inquiry before either House, or any joint committee established by a joint or concurrent resolution of the two Houses of Congress, or any committee of either House of Congress, willfully makes default, or who, having appeared, refuses to answer any question pertinent to the question under inquiry, shall be deemed guilty of a misdemeanor, punishable by a fine of not more than $1,000 nor less than $100 and imprisonment in a common jail for not less than one month nor more than twelve months.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc94356d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(R.S. § 102; ","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-22/ch594"},"text":"June 22, 1938, ch. 594","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/942"},"text":"52 Stat. 942","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc94356e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc94356f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddc943570-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 102 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1857-01-24/ch19/s1"},"text":"act Jan. 24, 1857, ch. 19, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/11/155"},"text":"11 Stat. 155","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc943571-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1938—Act ","children":[{"tag":"date","attrib":{"date":"1938-06-22"},"text":"June 22, 1938","children":[],"tail":", reenacted section without change."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
