espect to Financial Management and Budget and Program Development","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/4/dA"},"text":"Pub. L. 106–554, § 1(a)(4) [div. A]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–195, as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/109/13/dA/tIII/s3402/a"},"text":"Pub. L. 109–13, div. A, title III, § 3402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-05-11"},"text":"May 11, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/272"},"text":"119 Stat. 272","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/289/dB/tII/s20703/d/6"},"text":"Pub. L. 109–289, div. B, title II, § 20703(d)(6)","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/110/5/s2"},"text":"Pub. L. 110–5, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-02-15"},"text":"Feb. 15, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/39"},"text":"121 Stat. 39","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/5/s2"},"text":"“That notwithstanding any other provision of law, effective with the One Hundred Seventh Congress and each succeeding Congress the chair of the Subcommittee on the Legislative Branch of the Committee on Appropriations of the House of Representatives shall serve as a member of the Joint Committee on the Library with respect to the Library’s financial management, organization, budget development and implementation, and program development and administration, as well as any other element of the mission of the Library of Congress which is subject to the requirements of Federal law.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
