{"tag":"section","attrib":{"id":"iddd091810-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2216"},"text":null,"children":[{"tag":"num","attrib":{"value":"2216"},"text":"§ 2216.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Food service operations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd091811-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2216/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restaurant, catering, and vending","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Architect of the Capitol, acting through the Chief Executive Officer, shall establish within the Capitol Visitor Center a restaurant and other food service facilities, including catering services and vending machines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd091812-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2216/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract for food service operations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd091813-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2216/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Architect of the Capitol, acting through the Chief Executive Officer, may enter into a contract for food service operations within the Capitol Visitor Center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd091814-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2216/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing contract unaffected","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in paragraph (1) shall be construed to affect any contract for food service operations within the Capitol Visitor Center in effect on ","children":[{"tag":"date","attrib":{"date":"2008-10-20"},"text":"October 20, 2008","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd091815-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2216/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All net profits from the food service operations within the Capitol Visitor Center and all commissions received from the contractor for such food service operations shall be deposited in the Capitol Visitor Center Revolving Fund established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s2231"},"text":"section 2231 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd091816-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2216/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception to prohibition of sale or solicitation on Capitol grounds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s5104/c"},"text":"Section 5104(c) of title 40","children":[],"tail":" shall not apply to any activity carried out under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd091817-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/437/tII/s206"},"text":"Pub. L. 110–437, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-20"},"text":"Oct. 20, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4988"},"text":"122 Stat. 4988","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
