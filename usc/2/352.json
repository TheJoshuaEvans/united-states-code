{"tag":"section","attrib":{"id":"iddc9b625a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s352"},"text":null,"children":[{"tag":"num","attrib":{"value":"352"},"text":"§ 352.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc9b625b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s352/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Commission shall be composed of 11 members, who shall be appointed from private life as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc9b625c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s352/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 appointed by the President of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9b625d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s352/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 appointed by the President pro tempore of the Senate, upon the recommendation of the majority and minority leaders of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9b625e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s352/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 appointed by the Speaker of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9b625f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s352/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 appointed by the Chief Justice of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9b6260-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s352/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 5 appointed by the Administrator of General Services in accordance with paragraph (4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc9b6261-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s352/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" No person shall serve as a member of the Commission who is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc9b6262-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s352/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an officer or employee of the Federal Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9b6263-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s352/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" registered (or required to register) under the Federal Regulation of Lobbying Act; ","children":[{"tag":"ref","attrib":{"idref":"fn002021"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002021"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9b6264-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s352/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a parent, sibling, spouse, child, or dependent relative, of anyone under subparagraph (A) or (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc9b6265-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s352/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The persons appointed under subparagraphs (A) through (D) of paragraph (1) shall be selected without regard to political affiliation, and should be selected from among persons who have experience or expertise in such areas as government, personnel management, or public administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc9b6266-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s352/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Administrator of General Services shall by regulation establish procedures under which persons shall be selected for appointment under paragraph (1)(E). Such procedures—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc9b6267-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s352/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be designed in such a way so as to provide for the maximum degree of geographic diversity practicable among members under paragraph (1)(E);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9b6268-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s352/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall include provisions under which those members shall be chosen by lot from among names randomly selected from voter registration lists; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9b6269-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s352/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall otherwise comply with applicable provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc9b626a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s352/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The chairperson shall be designated by the President.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc9b626b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s352/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A vacancy in the membership of the Commission shall be filled in the manner in which the original appointment was made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc9b626c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s352/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each member of the Commission shall be paid at the rate of $100 for each day such member is engaged upon the work of the Commission and shall be allowed travel expenses, including a per diem allowance, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":", when engaged in the performance of services for the Commission."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc9b626d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s352/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc9b626e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s352/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms of office of persons first appointed as members of the Commission shall be for the period of the 1993 fiscal year of the Federal Government, and shall begin not later than ","children":[{"tag":"date","attrib":{"date":"1993-02-14"},"text":"February 14, 1993","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9b626f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s352/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" After the close of the 1993 fiscal year of the Federal Government, persons shall be appointed as members of the Commission with respect to every fourth fiscal year following the 1993 fiscal year. The terms of office of persons so appointed shall be for the period of the fiscal year with respect to which the appointment is made, except that, if any appointment is made after the beginning and before the close of any such fiscal year, the term of office based on such appointment shall be for the remainder of such fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9b6270-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s352/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddc9b6271-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s352/8/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any provision of subparagraph (A) or (B), members of the Commission may continue to serve after the close of a fiscal year, if the date designated by the President under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s357"},"text":"section 357 of this title","children":[],"tail":" (relating to the date by which the Commission is to submit its report to the President) is subsequent to the close of such fiscal year, and only if or to the extent necessary to allow the Commission to submit such report."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc9b6272-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s352/8/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any provision of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s353"},"text":"section 353 of this title","children":[],"tail":", authority under such section shall remain available, after the close of a fiscal year, so long as members of the Commission continue to serve."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc9b6273-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/206/tII/s225/b"},"text":"Pub. L. 90–206, title II, § 225(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-12-16"},"text":"Dec. 16, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/642"},"text":"81 Stat. 642","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/190/s135/a"},"text":"Pub. L. 99–190, § 135(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-19"},"text":"Dec. 19, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1322"},"text":"99 Stat. 1322","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/194/tVII/s701/b"},"text":"Pub. L. 101–194, title VII, § 701(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-30"},"text":"Nov. 30, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1763"},"text":"103 Stat. 1763","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc9b6274-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc9b6275-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddc9b6276-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Regulation of Lobbying Act, referred to in par. (2)(B), is title III of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-02/ch753"},"text":"act Aug. 2, 1946, ch. 753","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/839"},"text":"60 Stat. 839","children":[],"tail":", which was classified generally to chapter 8A (§ 261 et seq.) of this title, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/104/65/s11/a"},"text":"Pub. L. 104–65, § 11(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-19"},"text":"Dec. 19, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/701"},"text":"109 Stat. 701","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc9b6277-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/194"},"text":"Pub. L. 101–194","children":[],"tail":" amended section generally, substituting pars. (1) to (8) for former pars. (1) to (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/190"},"text":"Pub. L. 99–190","children":[],"tail":" inserted “and with respect to fiscal year 1987” at end of first sentence."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc9b6278-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddc9b6279-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1967-12-16"},"text":"Dec. 16, 1967","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/90/206/s220/a/1"},"text":"section 220(a)(1) of Pub. L. 90–206","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3110"},"text":"section 3110 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
