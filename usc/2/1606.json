{"tag":"section","attrib":{"id":"iddce2f25e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1606"},"text":null,"children":[{"tag":"num","attrib":{"value":"1606"},"text":"§ 1606.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddce2f25f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1606/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil penalty","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whoever knowingly fails to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce2f260-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1606/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remedy a defective filing within 60 days after notice of such a defect by the Secretary of the Senate or the Clerk of the House of Representatives; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce2f261-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1606/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comply with any other provision of this chapter;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall, upon proof of such knowing violation by a preponderance of the evidence, be subject to a civil fine of not more than $200,000, depending on the extent and gravity of the violation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce2f262-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1606/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal penalty","c