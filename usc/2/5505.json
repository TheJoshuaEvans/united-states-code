{"tag":"section","attrib":{"id":"iddd2ccbc7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5505"},"text":null,"children":[{"tag":"num","attrib":{"value":"5505"},"text":"§ 5505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments from applicable accounts of House of Representatives","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd2ccbc8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5505/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No payment may be made from the applicable accounts of the House of Representatives (as determined by the Committee on House Oversight of the House of Representatives), unless sanctioned by that Committee. Payments on vouchers approved in the manner directed by that Committee shall be deemed, held, and taken, and are declared to be conclusive upon all the departments and officers of the Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2ccbc9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5505/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2ccbca-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5505/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “applicable accounts of the House of Representatives” means accounts for salaries and expenses of committees (other than the Committee on Appropriations), the computer support organization of the House of Representatives, and allowances and expenses of Members of the House of Representatives, officers of the House of Representatives, and administrative and support offices of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2ccbcb-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5505/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Member of the House of Representatives” means a Representative in, or a Delegate or Resident Commissioner to, the Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd2ccbcc-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186/tI/s105"},"text":"Pub. L. 104–186, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1721"},"text":"110 Stat. 1721","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd2ccbcd-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd2ccbce-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd2ccbcf-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s95–1"},"text":"section 95–1 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186/s105"},"text":"section 105 of Pub. L. 104–186","children":[],"tail":". Subsec. (c) of "},{"tag":"ref","attrib":{"href":"/us/pl/104/186/s105"},"text":"section 105 of Pub. L. 104–186","children":[],"tail":" amended former "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s95"},"text":"section 95 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"iddd2ccbd0-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in former ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s95"},"text":"section 95 of this title","children":[],"tail":" prior to amendment of that section by "},{"tag":"ref","attrib":{"href":"/us/pl/104/186/tI/s105/c"},"text":"Pub. L. 104–186, title I, § 105(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1722"},"text":"110 Stat. 1722","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd2ccbd1-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"iddd2ccbd2-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on House Oversight of House of Representatives changed to Committee on House Administration of House of Representatives by House Resolution No. 5, One Hundred Sixth Congress, ","children":[{"tag":"date","attrib":{"date":"1999-01-06"},"text":"Jan. 6, 1999","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
