{"tag":"section","attrib":{"id":"iddd424fb5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6652"},"text":null,"children":[{"tag":"num","attrib":{"value":"6652"},"text":"§ 6652.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation of employees of Chaplain of Senate","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Chaplain of the Senate may appoint and fix the compensation of such employees as he deems appropriate, except that the amount which may be paid for any fiscal year as gross compensation for personnel in such Office for any fiscal year shall not exceed $147,000.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd424fb6-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/145"},"text":"Pub. L. 91–145","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-12"},"text":"Dec. 12, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/340"},"text":"83 Stat. 340","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/202/s101/i/tI/s2/b"},"text":"Pub. L. 100–202, § 101(i) [title I, § 2(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1329-290"},"text":"101 Stat. 1329–290","children":[],"tail":", 1329–294; "},{"tag":"ref","attrib":{"href":"/us/pl/101/163/tI/s10"},"text":"Pub. L. 101–163, title I, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-21"},"text":"Nov. 21, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1046"},"text":"103 Stat. 1046","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd424fb7-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd424fb8-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd424fb9-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s61d–1"},"text":"section 61d–1 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd424fba-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/163"},"text":"Pub. L. 101–163","children":[],"tail":" substituted “such employees as he deems appropriate, except that the amount which may be paid for any fiscal year as gross compensation for personnel in such Office for any fiscal year shall not exceed $147,000” for “a secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/202"},"text":"Pub. L. 100–202","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “The Chaplain may appoint and fix the compensation of a secretary at not to exceed $8,541 per annum.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd424fbb-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd424fbc-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Increases in Compensation","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Increases in compensation for Senate officers and employees under authority of Federal Pay Comparability Act of 1970 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/655"},"text":"Pub. L. 91–655","children":[],"tail":"), see Salary Directives of President pro tempore of the Senate, set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s4571"},"text":"section 4571 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
