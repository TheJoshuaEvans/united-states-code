{"tag":"section","attrib":{"id":"iddd235641-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4580"},"text":null,"children":[{"tag":"num","attrib":{"value":"4580"},"text":"§ 4580.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lump sum payment for accrued annual leave of Senate employees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd235642-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4580/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The head of the employing office of an employee of the Senate may, upon termination of employment of the employee, authorize payment of a lump sum for the accrued annual leave of that employee if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd235643-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4580/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the head of the employing office—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd235644-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4580/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has approved a written leave policy authorizing employees to accrue leave and establishing the conditions upon which accrued leave may be paid; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd235645-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4580/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submits written certification to the Financial Clerk of the Senate of the number of days of annual leave accrued by the employee for which payment is to be made under the written leave policy of the employing office; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd235646-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4580/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there are sufficient funds to cover the lump sum payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd235647-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4580/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rates","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd235648-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4580/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A lump sum payment under this section shall not exceed the lesser of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd235649-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4580/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" twice the monthly rate of pay of the employee; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd23564a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4580/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the product of the daily rate of pay of the employee and the number of days of accrued annual leave of the employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd23564b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4580/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Senate shall determine the rates of pay of an employee under paragraph (1)(A) and (B) on the basis of the annual rate of pay of the employee in effect on the date of termination of employment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd23564c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4580/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Source of payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any payment under this section shall be paid from the appropriation account or fund used to pay the employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd23564d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4580/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reemployment refund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an individual who received a lump sum payment under this section is reemployed as an employee of the Senate before the end of the period covered by the lump sum payment, the individual shall refund an amount equal to the applicable pay covering the period between the date of reemployment and the expiration of the lump sum period. Such amount shall be deposited to the appropriation account or fund used to pay the lump sum payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd23564e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4580/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Committee on Rules and Administration of the Senate may prescribe regulations to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd23564f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4580/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd235650-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4580/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “employee of the Senate” means any employee whose pay is disbursed by the Secretary of the Senate, except that the term does not include a member of the Capitol Police or a civilian employee of the Capitol Police; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd235651-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4580/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “head of the employing office” means any person with the final authority to appoint, hire, discharge, and set the terms, conditions, or privileges of the employment of an individual whose pay is disbursed by the Secretary of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd235652-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/2/tI/s6"},"text":"Pub. L. 106–554, § 1(a)(2) [title I, § 6]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–97.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd235653-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd235654-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd235655-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified as a note under section 60","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Congressional Operations Appropriations Act, 2001, which is title I of the Legislative Branch Appropriations Act, 2001.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
