{"tag":"section","attrib":{"id":"iddcff7a63-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2082"},"text":null,"children":[{"tag":"num","attrib":{"value":"2082"},"text":"§ 2082.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Commission to accept gifts and conduct other transactions relating to works of fine art and other property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcff7a64-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2082/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the purposes referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s2081/a"},"text":"section 2081(a) of this title","children":[],"tail":" the Commission is authorized—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcff7a65-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2082/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to accept gifts of works of fine art, gifts of other property, and gifts of money; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcff7a66-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2082/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to acquire property, administer property, dispose of property, and conduct other transactions related to such purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcff7a67-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2082/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer and disposition of works of fine art and other property","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall, with respect to works of fine art and other property received by the Commission—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcff7a68-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2082/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in consultation with the Joint Committee on the Library, the Senate Commission on Art, or the House of Representatives Fine Arts Board, as the case may be, transfer such property to the entity consulted;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcff7a69-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2082/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if a transfer described in paragraph (1) is not appropriate, dispose of the work of fine art by sale or other transaction; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcff7a6a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2082/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of property that is not directly related to the purposes referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s2081/a"},"text":"section 2081(a) of this title","children":[],"tail":", dispose of such property by sale or other transaction."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcff7a6b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2082/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for conduct of transactions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conducting transactions under this section, the Commission shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcff7a6c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2082/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept money only in the form of a check or similar instrument made payable to the Treasury of the United States and shall deposit any such check or instrument in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s2083"},"text":"section 2083 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcff7a6d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2082/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in making sales and engaging in other property transactions, take into consideration market conditions and other relevant factors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcff7a6e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2082/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assure that each transaction is directly related to the purposes referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s2081/a"},"text":"section 2081(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcff7a6f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/696/tVIII/s802"},"text":"Pub. L. 100–696, title VIII, § 802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4609"},"text":"102 Stat. 4609","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/302/tIII/s312/a"},"text":"Pub. L. 101–302, title III, § 312(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-05-25"},"text":"May 25, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/245"},"text":"104 Stat. 245","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcff7a70-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcff7a71-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddcff7a72-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was classified to section 188a–1 of former Title 40, prior to the enactment of Title 40, Public Buildings, Property, and Works, by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217/s1"},"text":"Pub. L. 107–217, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1062"},"text":"116 Stat. 1062","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcff7a73-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/302"},"text":"Pub. L. 101–302","children":[],"tail":" amended par. (1) generally. Prior to amendment, par. (1) read as follows: “upon agreement with the Joint Committee on the Library, the Senate Commission on Art, or the House of Representatives Fine Arts Board, as the case may be, transfer such property to the entity with which the agreement is made;”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
