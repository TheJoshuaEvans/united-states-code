{"tag":"section","attrib":{"id":"iddcde3742-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1432"},"text":null,"children":[{"tag":"num","attrib":{"value":"1432"},"text":"§ 1432.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Political affiliation and place of residence","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcde3743-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1432/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It shall not be a violation of any provision of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1311"},"text":"section 1311 of this title","children":[],"tail":" to consider the—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcde3744-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1432/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" party affiliation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcde3745-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1432/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" domicile; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcde3746-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1432/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" political compatibility with the employing office;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"of an employee referred to in subsection (b) with respect to employment decisions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcde3747-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1432/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Employee” defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a), the term “employee” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcde3748-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1432/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee on the staff of the leadership of the House of Representatives or the leadership of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcde3749-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1432/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an employee on the staff of a committee or subcommittee of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcde374a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1432/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcde374b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1432/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Senate; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcde374c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1432/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a joint committee of the Congress;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcde374d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1432/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee on the staff of a Member of the House of Representatives or on the staff of a Senator;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcde374e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1432/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an officer of the House of Representatives or the Senate or a congressional employee who is elected by the House of Representatives or Senate or is appointed by a Member of the House of Representatives or by a Senator (in addition an employee described in paragraph (1), (2), or (3)); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcde374f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1432/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an applicant for a position that is to be occupied by an individual described in any of paragraphs (1) through (4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcde3750-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/1/tV/s502"},"text":"Pub. L. 104–1, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-01-23"},"text":"Jan. 23, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/39"},"text":"109 Stat. 39","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
