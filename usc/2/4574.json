{"tag":"section","attrib":{"id":"iddd19b930-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4574"},"text":null,"children":[{"tag":"num","attrib":{"value":"4574"},"text":"§ 4574.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limit on rate of compensation of Senate officers and employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No officer or employee of the Senate shall receive pay for any services performed by him at any rate higher than that provided for the office or employment to which he has been regularly appointed.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd19b931-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1882-08-05/ch390/s1"},"text":"Aug. 5, 1882, ch. 390, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/22/270"},"text":"22 Stat. 270","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd19b932-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd19b933-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd19b934-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s61"},"text":"section 61 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
