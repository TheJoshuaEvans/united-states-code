{"tag":"section","attrib":{"id":"iddd14fddf-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4509"},"text":null,"children":[{"tag":"num","attrib":{"value":"4509"},"text":"§ 4509.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Longevity compensation not applicable to individuals paid by Secretary of Senate; savings provision","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s4507"},"text":"Section 4507 of this title","children":[],"tail":" on or after "},{"tag":"date","attrib":{"date":"1983-10-01"},"text":"October 1, 1983","children":[],"tail":" shall not apply to any individual whose pay is disbursed by the Secretary of the Senate; except that, any individual who prior to such date was entitled to longevity compensation under such section on the basis of service performed prior to such date shall continue to be entitled to such compensation, but no individual shall accrue any longevity compensation on the basis of service performed on or after such date."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd14fde0-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/51/tI/s107"},"text":"Pub. L. 98–51, title I, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-07-14"},"text":"July 14, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/267"},"text":"97 Stat. 267","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd14fde1-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd14fde2-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","a