{"tag":"section","attrib":{"id":"iddd28111e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5106"},"text":null,"children":[{"tag":"num","attrib":{"value":"5106"},"text":"§ 5106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowance for compensation of interns in House leadership offices","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd28111f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5106/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established for the House of Representatives an allowance which shall be available for the compensation of interns who serve in House leadership offices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd281120-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5106/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benefit exclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s5321/b"},"text":"Section 5321(b) of this title","children":[],"tail":" shall apply with respect to an intern who is compensated under the allowance under this section in the same manner as such section applies with respect to an intern who is compensated under the Members’ Representational Allowance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd281121-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5106/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd281122-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5106/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “House leadership office” means, with respect to a fiscal year, any office for which the appropriation for salaries and expenses of the office for the fiscal year is provided under the heading “House Leadership Offices” in the Act making appropriations for the Legislative Branch for the fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd281123-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5106/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" term “intern”, with respect to a House leadership office, has the meaning given such term with respect to a Member of the House of Representatives in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s5321/c/2"},"text":"section 5321(c)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd281124-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5106/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section such sums as may be necessary for fiscal year 2020 and each succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd281125-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5106/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd281126-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5106/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section and the amendments made by this section shall apply with respect to fiscal year 2020 and each succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd281127-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/dE/tI/s113"},"text":"Pub. L. 116–94, div. E, title I, § 113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2759"},"text":"133 Stat. 2759","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd281128-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd281129-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd28112a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s113"},"text":"section 113 of Pub. L. 116–94","children":[],"tail":". Subsec. (e) of "},{"tag":"ref","attrib":{"href":"/us/pl/116/94/s113"},"text":"section 113 of Pub. L. 116–94","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s5507"},"text":"section 5507 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
