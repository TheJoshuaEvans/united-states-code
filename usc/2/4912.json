{"tag":"section","attrib":{"id":"iddd25a08a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4912"},"text":null,"children":[{"tag":"num","attrib":{"value":"4912"},"text":"§ 4912.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership of Page Board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd25a08b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4912/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointed and designated members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Page Board shall consist of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd25a08c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4912/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two Members of the House appointed by the Speaker and two Members of the House appointed by the minority leader;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd25a08d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4912/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one individual who, at any time during the 5-year period which ends on the date of the individual’s appointment, is or was a parent of a page participating in the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd25a08e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4912/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one individual who is a former page of the House who is not a Member of the House or an individual described in paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd25a08f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4912/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Clerk and the Sergeant at Arms of the House.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd25a090-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4912/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for members representing parents and former pages","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of the members of the Page Board who are described in paragraphs (2) and (3) of subsection (a), the following shall apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd25a091-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4912/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each such member shall be appointed jointly by the Speaker and minority leader of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd25a092-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4912/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each such member shall serve for a term of one year and may be reappointed for additional terms if the member continues to meet the requirements for appointment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd25a093-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4912/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A vacancy in the position held by any such member shall be filled in the same manner as the original appointment. An individual appointed to fill a vacancy shall serve for the remainder of the original term and may be reappointed in accordance with paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd25a094-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4912/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each such member may be paid travel or transportation expenses, including per diem in lieu of subsistence, for attending meetings of the Page Board while away from the member’s home or place of business. There are authorized to be appropriated from the applicable accounts of the House of Representatives such sums as may be necessary for payments under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd25a095-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4912/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Member of the House” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As used in sections 4911 to 4913 of this title, the term “Member of the House” means a Representative in, and a Delegate or Resident Commissioner to, the Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd25a096-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/377/tI/s127"},"text":"Pub. L. 97–377, title I, § 127","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-12-21"},"text":"Dec. 21, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1914"},"text":"96 Stat. 1914","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/186/tII/s204/37"},"text":"Pub. L. 104–186, title II, § 204(37)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1735"},"text":"110 Stat. 1735","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/275/tI/s101/a"},"text":"Pub. L. 105–275, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2438"},"text":"112 Stat. 2438","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/2/s2"},"text":"Pub. L. 110–2, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-02-02"},"text":"Feb. 2, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/4"},"text":"121 Stat. 4","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd25a097-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd25a098-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd25a099-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s88b–3"},"text":"section 88b–3 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is based on section 2 of House Resolution No. 611, Ninety-seventh Congress, ","children":[{"tag":"date","attrib":{"date":"1982-11-30"},"text":"Nov. 30, 1982","children":[],"tail":", which was enacted into permanent law by "},{"tag":"ref","attrib":{"href":"/us/pl/97/377"},"text":"Pub. L. 97–377","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd25a09a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/2/s2/a/1"},"text":"Pub. L. 110–2, § 2(a)(1)","children":[],"tail":", substituted “and two Members” for “and one Member”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/2/s2/a/2"},"text":"Pub. L. 110–2, § 2(a)(2)","children":[],"tail":"–(4), added pars. (2) and (3) and redesignated former par. (2) as (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/2/s2/b"},"text":"Pub. L. 110–2, § 2(b)","children":[],"tail":", added subsec. (b) and redesignated former subsec. (b) as (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/275"},"text":"Pub. L. 105–275","children":[],"tail":" inserted “and” at end of par. (1), substituted a period for “; and” at end of par. (2), and struck out par. (3) which read as follows: “the Architect of the Capitol.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186"},"text":"Pub. L. 104–186","children":[],"tail":" substituted “Clerk and the Sergeant” for “Clerk, Doorkeeper, and Sergeant”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd25a09b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd25a09c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/2"},"text":"Pub. L. 110–2","children":[],"tail":" applicable with respect to the portion of the One Hundred Tenth Congress which begins after "},{"tag":"date","attrib":{"date":"2007-02-02"},"text":"Feb. 2, 2007","children":[],"tail":", and each succeeding Congress, see "},{"tag":"ref","attrib":{"href":"/us/pl/110/2/s4"},"text":"section 4 of Pub. L. 110–2","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s4911"},"text":"section 4911 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd25a09d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/275/tI/s101/b"},"text":"Pub. L. 105–275, title I, § 101(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2438"},"text":"112 Stat. 2438","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/275/tI/s101/b"},"text":"“The amendment made by subsection (a) [amending this section] shall apply with respect to the One Hundred Sixth Congress and each succeeding Congress.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
