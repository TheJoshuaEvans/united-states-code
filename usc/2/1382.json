{"tag":"section","attrib":{"id":"iddcd70b35-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382"},"text":null,"children":[{"tag":"num","attrib":{"value":"1382"},"text":"§ 1382.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Officers, staff, and other personnel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcd70b36-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Executive Director","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcd70b37-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment and removal","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcd70b38-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chair, subject to the approval of the Board, shall appoint and may remove an Executive Director. Selection and appointment of the Executive Director shall be without regard to political affiliation and solely on the basis of fitness to perform the duties of the Office. The first Executive Director shall be appointed no later than 90 days after the initial appointment of the Board of Directors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcd70b39-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Executive Director shall be an individual with training or expertise in the application of laws referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1302/a"},"text":"section 1302(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcd70b3a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disqualifications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The disqualifications in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1381/d/2"},"text":"section 1381(d)(2) of this title","children":[],"tail":" shall apply to the appointment of the Executive Director."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd70b3b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcd70b3c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to fix compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chair may fix the compensation of the Executive Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcd70b3d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The rate of pay for the Executive Director may not exceed the maximum rate of pay in effect under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s4575/f"},"text":"section 4575(f) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd70b3e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term of office of the Executive Director shall be not more than 2 terms of 5 years, except that the first Executive Director shall have a single term of 7 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd70b3f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Executive Director shall serve as the chief operating officer of the Office. Except as otherwise specified in this chapter, the Executive Director shall carry out all of the responsibilities of the Office under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd70b40-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deputy Executive Directors","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcd70b41-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chair, subject to the approval of the Board, shall appoint and may remove a Deputy Executive Director for the Senate and a Deputy Executive Director for the House of Representatives. Selection and appointment of a Deputy Executive Director shall be without regard to political affiliation and solely on the basis of fitness to perform the duties of the office. The disqualifications in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1381/d/2"},"text":"section 1381(d)(2) of this title","children":[],"tail":" shall apply to the appointment of a Deputy Executive Director."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd70b42-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term of office of a Deputy Executive Director shall be not more than 2 terms of 5 years, except that the first Deputy Executive Directors shall have a single term of 6 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd70b43-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcd70b44-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to fix compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chair may fix the compensation of the Deputy Executive Directors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcd70b45-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The rate of pay for a Deputy Executive Director may not exceed 96 percent of the lesser of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddcd70b46-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the highest annual rate of compensation of any officer of the Senate; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcd70b47-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the highest annual rate of compensation of any officer of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd70b48-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Deputy Executive Director for the Senate shall recommend to the Board regulations under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1384/a/2/B/i"},"text":"section 1384(a)(2)(B)(i) of this title","children":[],"tail":", maintain the regulations and all records pertaining to the regulations, and shall assume such other responsibilities as may be delegated by the Executive Director. The Deputy Executive Director for the House of Representatives shall recommend to the Board the regulations under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1384/a/2/B/ii"},"text":"section 1384(a)(2)(B)(ii) of this title","children":[],"tail":", maintain the regulations and all records pertaining to the regulations, and shall assume such other responsibilities as may be delegated by the Executive Director."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd70b49-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General Counsel","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcd70b4a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chair, subject to the approval of the Board, shall appoint a General Counsel. Selection and appointment of the General Counsel shall be without regard to political affiliation and solely on the basis of fitness to perform the duties of the Office. The disqualifications in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1381/d/2"},"text":"section 1381(d)(2) of this title","children":[],"tail":" shall apply to the appointment of a General Counsel."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd70b4b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcd70b4c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to fix compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chair may fix the compensation of the General Counsel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcd70b4d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The rate of pay for the General Counsel may not exceed the lesser of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddcd70b4e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the highest annual rate of compensation of any officer of the Senate; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcd70b4f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the highest annual rate of compensation of any officer of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd70b50-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The General Counsel shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcd70b51-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exercise the authorities and perform the duties of the General Counsel as specified in this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcd70b52-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise assist the Board and the Executive Director in carrying out their duties and powers, including representing the Office in any judicial proceeding under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd70b53-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attorneys in the office of the General Counsel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The General Counsel shall appoint, and fix the compensation of, and may remove, such additional attorneys as may be necessary to enable the General Counsel to perform the General Counsel’s duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd70b54-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term of office of the General Counsel shall be not more than 2 terms of 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd70b55-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcd70b56-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The General Counsel may be removed from office by the Chair but only for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddcd70b57-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/c/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disability that substantially prevents the General Counsel from carrying out the duties of the General Counsel,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcd70b58-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/c/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incompetence,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcd70b59-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/c/6/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" neglect of duty,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcd70b5a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/c/6/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" malfeasance, including a felony or conduct involving moral turpitude, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcd70b5b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/c/6/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" holding an office or employment or engaging in an activity that disqualifies the individual from service as the General Counsel under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcd70b5c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement of reasons for removal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In removing the General Counsel, the Speaker of the House of Representatives and the President pro tempore of the Senate shall state in writing to the General Counsel the specific reasons for the removal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd70b5d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidential advisors","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcd70b5e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Executive Director shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcd70b5f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appoint, and fix the compensation of, and may remove, 1 or more confidential advisors to carry out the duties described in this subsection; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcd70b60-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designate 1 or more employees of the Office to serve as a confidential advisor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd70b61-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcd70b62-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A confidential advisor appointed or designated under paragraph (1) shall offer to provide to covered employees described in paragraph (4) the services described in subparagraph (B), which a covered employee may accept or decline.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcd70b63-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The services referred to in subparagraph (A) are—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddcd70b64-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" informing, on a privileged and confidential basis, a covered employee who has been subject to a practice that may be a violation of part A of subchapter II about the employee’s rights under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcd70b65-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" consulting, on a privileged and confidential basis, with a covered employee who has been subject to a practice that may be a violation of part A of subchapter II regarding—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddcd70b66-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/d/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the roles, responsibilities, and authority of the Office; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddcd70b67-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/d/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relative merits of securing private counsel, designating a non-attorney representative, or proceeding without representation for proceedings before the Office;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcd70b68-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/d/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advising and consulting with, on a privileged and confidential basis, a covered employee who has been subject to a practice that may be a violation of part A of subchapter II regarding any claims the covered employee may have under subchapter IV, the factual allegations that support each such claim, and the relative merits of the procedural options available to the employee for each such claim;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcd70b69-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/d/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" assisting, on a privileged and confidential basis, a covered employee who seeks consideration under title IV of an allegation of a violation of part A of subchapter II in understanding the procedures, and the significance of the procedures, described in subchapter IV, including—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddcd70b6a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/d/2/B/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisting or consulting with the covered employee regarding the drafting of a claim to be filed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1402/a"},"text":"section 1402(a) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddcd70b6b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/d/2/B/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consulting with the covered employee regarding the procedural options available to the covered employee after a claim is filed, and the relative merits of each option; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcd70b6c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/d/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" informing, on a privileged and confidential basis, a covered employee who has been subject to a practice that may be a violation of part A of subchapter II about the option of pursuing, in appropriate circumstances, a complaint with the Committee on Ethics of the House of Representatives or the Select Committee on Ethics of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcd70b6d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuity of service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Once a covered employee has accepted and received any services offered under this section from a confidential advisor appointed or designated under paragraph (1), any other services requested under this subsection by the covered employee shall be provided, to the extent practicable, by the same confidential advisor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd70b6e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A confidential advisor appointed or designated under paragraph (1) shall be a lawyer who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcd70b6f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is admitted to practice before, and is in good standing with, the bar of a State of the United States, the District of Columbia, or a territory of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcd70b70-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has experience representing clients in cases involving the workplace laws incorporated by part A of subchapter II.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd70b71-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Individuals covered","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The services described in paragraph (2) are available to any covered employee (which, for purposes of this subsection, shall include any staff member described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1311/d"},"text":"section 1311(d) of this title","children":[],"tail":" and any former covered employee (including any such former staff member)), except that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcd70b72-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a former covered employee may only request such services if the practice that may be a violation of part A of subchapter II occurred during the employment or service of the employee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcd70b73-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a covered employee described in this paragraph may only request such services before the expiration of the 180-day period described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1402/d"},"text":"section 1402(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd70b74-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A confidential advisor appointed or designated under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcd70b75-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not act as the designated representative for any covered employee in connection with the covered employee’s participation in any proceeding, including any proceeding under this chapter, any judicial proceeding, or any proceeding before any committee of Congress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcd70b76-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not offer or provide services described in paragraph (2)(B) to a covered employee if the covered employee has designated an attorney representative in connection with the covered employee’s participation in any proceeding under this chapter, except that a confidential advisor may provide general assistance and information to such attorney representative regarding this chapter and the role of the Office as the confidential advisor determines appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcd70b77-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/d/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not serve as a mediator in any mediation conducted pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1403"},"text":"section 1403 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd70b78-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other staff","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Executive Director shall appoint, and fix the compensation of, and may remove, such other additional staff, including hearing officers, but not including attorneys employed in the office of the General Counsel, as may be necessary to enable the Office to perform its duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd70b79-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Detailed personnel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Executive Director may, with the prior consent of the department or agency of the Federal Government concerned, use on a reimbursable or nonreimbursable basis the services of personnel of any such department or agency, including the services of members or personnel of the Government Accountability Office Personnel Appeals Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd70b7a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1382/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the functions of the Office, the Executive Director may procure the temporary (not to exceed 1 year) or intermittent services of consultants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcd70b7b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/1/tIII/s302"},"text":"Pub. L. 104–1, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-01-23"},"text":"Jan. 23, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/26"},"text":"109 Stat. 26","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/161/dH/tI/s1101/b"},"text":"Pub. L. 110–161, div. H, title I, § 1101(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2237"},"text":"121 Stat. 2237","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/164/s2/a"},"text":"Pub. L. 110–164, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2459"},"text":"121 Stat. 2459","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/397/tII/s204"},"text":"Pub. L. 115–397, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5318"},"text":"132 Stat. 5318","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/94/dE/tII/s212/a/3/C"},"text":"Pub. L. 116–94, div. E, title II, § 212(a)(3)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2775"},"text":"133 Stat. 2775","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcd70b7c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcd70b7d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddcd70b7e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a)(4), (c)(3), and (d)(2)(B)(i), (5)(A), (B), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/1"},"text":"Pub. L. 104–1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-01-23"},"text":"Jan. 23, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/3"},"text":"109 Stat. 3","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1301"},"text":"section 1301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Part A of subchapter II, referred to in subsec. (d)(2)(B), (3)(B), (4)(A), was in the original “part A of title II”, meaning part A (§§ 201–207) of title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/1"},"text":"Pub. L. 104–1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-01-23"},"text":"Jan. 23, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/7"},"text":"109 Stat. 7","children":[],"tail":", which is classified principally to part A of subchapter II of this chapter. For complete classification of part A to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcd70b7f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94"},"text":"Pub. L. 116–94","children":[],"tail":" substituted “the maximum rate of pay in effect under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s4575/f"},"text":"section 4575(f) of this title","children":[],"tail":".” for “the lesser of—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) the highest annual rate of compensation of any officer of the Senate; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) the highest annual rate of compensation of any officer of the House of Representatives.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsecs. (d) to (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/397"},"text":"Pub. L. 115–397","children":[],"tail":" added subsec. (d) and redesignated former subsecs. (d) to (f) as (e) to (g), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161/s1101/b/1"},"text":"Pub. L. 110–161, § 1101(b)(1)","children":[],"tail":", added par. (2) and struck out heading and text of former par. (2). Text read as follows: “The Chair may fix the compensation of the Executive Director. The rate of pay for the Executive Director may not exceed the annual rate of basic pay prescribed for level V of the Executive Schedule under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5316"},"text":"section 5316 of title 5","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/164/s2/a/1"},"text":"Pub. L. 110–164, § 2(a)(1)","children":[],"tail":", substituted “not more than 2 terms” for “a single term” the first time appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/164/s2/a/2"},"text":"Pub. L. 110–164, § 2(a)(2)","children":[],"tail":", substituted “not more than 2 terms” for “a single term” the first time appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161/s1101/b/2"},"text":"Pub. L. 110–161, § 1101(b)(2)","children":[],"tail":", added par. (3) and struck out heading and text of former par. (3). Text read as follows: “The Chair may fix the compensation of the Deputy Executive Directors. The rate of pay for a Deputy Executive Director may not exceed 96 percent of the annual rate of basic pay prescribed for level V of the Executive Schedule under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5316"},"text":"section 5316 of title 5","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161/s1101/b/3"},"text":"Pub. L. 110–161, § 1101(b)(3)","children":[],"tail":", added par. (2) and struck out heading and text of former par. (2). Text read as follows: “The Chair may fix the compensation of the General Counsel. The rate of pay for the General Counsel may not exceed the annual rate of basic pay prescribed for level V of the Executive Schedule under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5316"},"text":"section 5316 of title 5","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/164/s2/a/3"},"text":"Pub. L. 110–164, § 2(a)(3)","children":[],"tail":", substituted “not more than 2 terms” for “a single term”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161/s1101/b/4"},"text":"Pub. L. 110–161, § 1101(b)(4)","children":[],"tail":", substituted “Government Accountability Office” for “General Accounting Office”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcd70b80-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcd70b81-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2019 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94"},"text":"Pub. L. 116–94","children":[],"tail":" effective on the later of the first day of the first applicable pay period beginning on or after "},{"tag":"date","attrib":{"date":"2020-01-01"},"text":"Jan. 1, 2020","children":[],"tail":", or the first day of the first applicable pay period beginning on or after "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/116/94/s212/c"},"text":"section 212(c) of Pub. L. 116–94","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s282b"},"text":"section 282b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcd70b82-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/397"},"text":"Pub. L. 115–397","children":[],"tail":" effective upon expiration of the 180-day period beginning on "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", with provisions for effect on pending proceedings, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/397/s401"},"text":"section 401 of Pub. L. 115–397","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcd70b83-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/164/s2/b"},"text":"Pub. L. 110–164, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2459"},"text":"121 Stat. 2459","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/164/s2/b"},"text":"“The amendments made by this section [amending this section] shall apply with respect to an individual who is first appointed to the position of Executive Director, Deputy Executive Director, or General Counsel of the Office of Compliance after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddcd95474-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Permitting Current Executive Director, Deputy Executive Directors, and General Counsel of Office of Compliance To Serve One Additional Term","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/38/s1"},"text":"Pub. L. 109–38, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-07-27"},"text":"July 27, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/408"},"text":"119 Stat. 408","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/38/s1"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Executive Director","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding section 302(a)(3) of the Congressional Accountability Act of 1995 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1382/a/3"},"text":"2 U.S.C. 1382(a)(3)","children":[],"tail":"), the individual serving as Executive Director of the Office of Compliance [now Office of Congressional Workplace Rights] as of the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2005-07-27"},"text":"July 27, 2005","children":[],"tail":"] may serve one additional term."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deputy Executive Directors","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding section 302(b)(2) of such Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1382/b/2"},"text":"2 U.S.C. 1382(b)(2)","children":[],"tail":"), any individual serving as a Deputy Executive Director of the Office of Compliance [now Office of Congressional Workplace Rights] as of the date of the enactment of this Act may serve one additional term."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Counsel","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding section 302(c)(5) of such Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1382/c/5"},"text":"2 U.S.C. 1382(c)(5)","children":[],"tail":"), the individual serving as General Counsel of the Office of Compliance [now Office of Congressional Workplace Rights] as of the date of the enactment of this Act may serve one additional term.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
