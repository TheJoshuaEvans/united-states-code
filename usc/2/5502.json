{"tag":"section","attrib":{"id":"iddd2ccbac-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5502"},"text":null,"children":[{"tag":"num","attrib":{"value":"5502"},"text":"§ 5502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" House emergency operations positions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd2ccbad-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment in certain offices","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Effective with respect to fiscal year 2002 and each succeeding fiscal year, there are hereby established 2 additional positions in each of the following offices of the House of Representatives:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2ccbae-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5502/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of the Clerk.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2ccbaf-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5502/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of the Chief Administrative Officer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2ccbb0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5502/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of the Sergeant at Arms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2ccbb1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The duty of the personnel appointed to a position established under this section shall be to ensure the continuity of the operations of the House of Representatives during periods of emergency, in accordance with the direction of the head of the office in which the position is established.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2ccbb2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5502/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rate of pay","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The annual rate of pay provided for a position established under this section shall be determined by the head of the office in which the position is established.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2ccbb3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5502/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the head of the office in which a position is established under this section shall have the exclusive authority to appoint personnel to such a position.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd2ccbb4-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/68/tI/s118"},"text":"Pub. L. 107–68, title I, § 118","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-11-12"},"text":"Nov. 12, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/573"},"text":"115 Stat. 573","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd2ccbb5-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd2ccbb6-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd2ccbb7-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s75f"},"text":"section 75f of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Congressional Operations Appropriations Act, 2002, which is title I of the Legislative Branch Appropriations Act, 2002.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
