{"tag":"section","attrib":{"id":"iddd3b24c6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6542"},"text":null,"children":[{"tag":"num","attrib":{"value":"6542"},"text":"§ 6542.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employees of Senate Disbursing Office; designation by Secretary of Senate to administer oaths and affirmations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Senate is on and after ","children":[{"tag":"date","attrib":{"date":"1973-11-01"},"text":"November 1, 1973","children":[],"tail":", authorized to designate, in writing, employees of the Disbursing Office of the Senate to administer oaths and affirmations, with respect to matters relating to that Office, authorized or required by law or rules or orders of the Senate (including the oath of office required by "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3331"},"text":"section 3331 of title 5","children":[],"tail":"). During any period in which he is so designated, any such employee may administer such oaths and affirmations."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd3b24c7-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/145"},"text":"Pub. L. 93–145","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-11-01"},"text":"Nov. 1, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/532"},"text":"87 Stat. 532","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd3b24c8-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd3b24c9-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd3b24ca-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s64–1"},"text":"section 64–1 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
