{"tag":"section","attrib":{"id":"iddd06a63c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2134"},"text":null,"children":[{"tag":"num","attrib":{"value":"2134"},"text":"§ 2134.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Art exhibits","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No work of art or manufacture other than the property of the United States shall be exhibited in the National Statuary Hall, the Rotunda, Emancipation Hall of the Capitol Visitor Center, or the corridors of the Capitol.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd06a63d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(R.S. § 1815; ","children":[{"tag":"ref","attrib":{"href":"/us/act/1875-03-03/ch130"},"text":"Mar. 3, 1875, ch. 130","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/18/376"},"text":"18 Stat. 376","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1879-03-03/ch182"},"text":"Mar. 3, 1879, ch. 182","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/20/391"},"text":"20 Stat. 391","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/437/tI/s101/f/2"},"text":"Pub. L. 110–437, title I, § 101(f)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-20"},"text":"Oct. 20, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4985"},"text":"122 Stat. 4985","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd06a63e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd06a63f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd06a640-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was classified to section 189 of former Title 40, prior to the enactment of Title 40, Public Buildings, Property, and Works, by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217/s1"},"text":"Pub. L. 107–217, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1062"},"text":"116 Stat. 1062","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is based on act ","children":[{"tag":"date","attrib":{"date":"1879-03-03"},"text":"Mar. 3, 1879","children":[],"tail":", popularly known as the “Sundry Civil Appropriation Act, fiscal year 1879”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 1815 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1868-07-20/ch176/s6"},"text":"act July 20, 1868, ch. 176, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/15/110"},"text":"15 Stat. 110","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd06a641-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/437"},"text":"Pub. L. 110–437","children":[],"tail":" inserted “Emancipation Hall of the Capitol Visitor Center,” after “Rotunda,”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
