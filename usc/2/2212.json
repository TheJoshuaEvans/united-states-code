{"tag":"section","attrib":{"id":"iddd0917e1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2212"},"text":null,"children":[{"tag":"num","attrib":{"value":"2212"},"text":"§ 2212.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment and supervision of Chief Executive Officer for Visitor Services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd0917e2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2212/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chief Executive Officer shall be appointed by the Architect of the Capitol.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd0917e3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2212/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supervision and oversight","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chief Executive Officer shall report directly to the Architect of the Capitol and shall be subject to oversight by the Committee on Rules and Administration of the Senate and the Committee on House Administration of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd0917e4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2212/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon removal of the Chief Executive Officer, the Architect of the Capitol shall immediately provide notice of the removal to the Committee on Rules and Administration of the Senate, the Committee on House Administration of the House of Representatives, and the Committees on Appropriations of the House of Representatives and Senate. The notice shall include the reasons for the removal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd0917e5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2212/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chief Executive Officer shall be paid at an annual rate of pay equal to the annual rate of pay of the Deputy Architect of the Capitol.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd0917e6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2212/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transition for current Chief Executive Officer for Visitor Services","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd0917e7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2212/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The individual who serves as the Chief Executive Officer for Visitor Services under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1806"},"text":"section 1806 of this title","children":[],"tail":" as of "},{"tag":"date","attrib":{"date":"2008-10-20"},"text":"October 20, 2008","children":[],"tail":", shall be the first Chief Executive Officer for Visitor Services appointed by the Architect under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd0917e8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2212/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd0917e9-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/437/tII/s202"},"text":"Pub. L. 110–437, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-20"},"text":"Oct. 20, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4986"},"text":"122 Stat. 4986","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd0917ea-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd0917eb-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd0917ec-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1806"},"text":"Section 1806 of this title","children":[],"tail":", referred to in subsec. (e)(1), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/437/tII/s202/e/2"},"text":"Pub. L. 110–437, title II, § 202(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-20"},"text":"Oct. 20, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4987"},"text":"122 Stat. 4987","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd0917ed-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/437/s202"},"text":"section 202 of Pub. L. 110–437","children":[],"tail":". Subsec. (e)(2) of "},{"tag":"ref","attrib":{"href":"/us/pl/110/437/s202"},"text":"section 202 of Pub. L. 110–437","children":[],"tail":" repealed "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1806"},"text":"section 1806 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
