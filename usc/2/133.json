{"tag":"section","attrib":{"id":"iddc8393bb-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s133"},"text":null,"children":[{"tag":"num","attrib":{"value":"133"},"text":"§ 133.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint Committee during recess of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The portion of the Joint Committee of Congress on the Library on the part of the Senate remaining in office as Senators shall during the recess of Congress exercise the powers and discharge the duties conferred by law upon the Joint Committee of Congress on the Library.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc8393bc-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1883-03-03/ch141/s2"},"text":"Mar. 3, 1883, ch. 141, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/22/592"},"text":"22 Stat. 592","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1946-08-02/ch753"},"text":"Aug. 2, 1946, ch. 753","children":[],"tail":", title II, § 223, "},{"tag":"ref","attrib":{"href":"/us/stat/60/838"},"text":"60 Stat. 838","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc8393bd-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc8393be-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc8393bf-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1946—Act ","children":[{"tag":"date","attrib":{"date":"1946-08-02"},"text":"Aug. 2