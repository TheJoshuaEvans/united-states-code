{"tag":"section","attrib":{"id":"iddc8f7b35-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182a"},"text":null,"children":[{"tag":"num","attrib":{"value":"182a"},"text":"§ 182a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revolving fund for duplication services associated with audiovisual conservation center","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc8f7b36-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby established in the Treasury a revolving fund for duplication and delivery services provided by the Librarian of Congress (hereafter in sections 182a to 182d of this title referred to as the “Librarian”) which are associated with the national audiovisual conservation center established under the Act entitled “An Act to authorize acquisition of certain real property for the Library of Congress, and for other purposes”, approved ","children":[{"tag":"date","attrib":{"date":"1997-12-15"},"text":"December 15, 1997","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/105/144"},"text":"Public Law 105–144","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s141"},"text":"2 U.S.C. 141","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc8f7b37-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees for services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Librarian may charge a fee for providing services described in subsection (a), and shall deposit any such fees charged into the revolving fund under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc8f7b38-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc8f7b39-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The revolving fund under this section shall consist of the following amounts:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc8f7b3a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts deposited by the Librarian under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc8f7b3b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other amounts received by the Librarian which are attributable to the services described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc8f7b3c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182a/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts deposited by the Librarian under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc8f7b3d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182a/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other amounts as may be appropriated under law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc8f7b3e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit of funds during transition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Librarian shall transfer to the revolving fund under this section the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc8f7b3f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any obligated, unexpended balances existing as of the date of the transfer which are attributable to the services described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc8f7b40-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An amount equal to the difference as of such date between—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddc8f7b41-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182a/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total value of the supplies, inventories, equipment, gift fund balances, and other assets attributable to such services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc8f7b42-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182a/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total value of the liabilities attributable to such services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc8f7b43-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of amounts in fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts in the revolving fund under this section shall be available to the Librarian, in amounts specified in appropriations Acts and without fiscal year limitation, to carry out the services described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc8f7b44-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/481/tI/s101"},"text":"Pub. L. 106–481, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2187"},"text":"114 Stat. 2187","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/68/tII/s207"},"text":"Pub. L. 107–68, title II, § 207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-11-12"},"text":"Nov. 12, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/587"},"text":"115 Stat. 587","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc8f7b45-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc8f7b46-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddc8f7b47-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 182a to 182d of this title, referred to in subsec. (a), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/481"},"text":"Pub. L. 106–481","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2187"},"text":"114 Stat. 2187","children":[],"tail":", known as the Library of Congress Fiscal Operations Improvement Act of 2000, which enacted this section and sections 182b to 182d of this title, amended "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s154"},"text":"section 154 of this title","children":[],"tail":", and enacted provisions set out as notes under this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s154"},"text":"section 154 of this title","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note below and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc8f7b48-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2001—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/68"},"text":"Pub. L. 107–68","children":[],"tail":" struck out “audio and video” before “duplication” in section catchline and in subsec. (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc8f7b49-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddc8f7b4a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/481/tI/s105"},"text":"Pub. L. 106–481, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2190"},"text":"114 Stat. 2190","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/481/tI/s105"},"text":"“The provisions of this title [enacting this section and sections 182b to 182d of this title and provisions set out as a note under this section] shall apply with respect to fiscal year 2002 and each succeeding fiscal year.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"iddc8f7b4b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/481/s1"},"text":"Pub. L. 106–481, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2187"},"text":"114 Stat. 2187","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/481/s1"},"text":"“This Act [enacting this section and sections 182b to 182d of this title, amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s154"},"text":"section 154 of this title","children":[],"tail":", and enacting provisions set out as notes under this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s154"},"text":"section 154 of this title","children":[],"tail":"] may be cited as the ‘Library of Congress Fiscal Operations Improvement Act of 2000’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
