{"tag":"section","attrib":{"id":"iddd366962-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6315"},"text":null,"children":[{"tag":"num","attrib":{"value":"6315"},"text":"§ 6315.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Telecommunications services for Senators; payment of costs out of contingent fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Sergeant at Arms and Doorkeeper of the Senate shall furnish each Senator local and long-distance telecommunications services in Washington, District of Columbia, and in such Senator’s State in accordance with regulations prescribed by the Senate Committee on Rules and Administration; and the costs of such service shall be paid out of the contingent fund of the Senate from moneys made available to him for that purpose.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd366963-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/181/tI/s1205/a"},"text":"Pub. L. 98–181, title I, § 1205(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-11-30"},"text":"Nov. 30, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1290"},"text":"97 Stat. 1290","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/65/s1/b"},"text":"Pub. L. 99–65, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-07-12"},"text":"July 12, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/163"},"text":"99 Stat. 163","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/439"},"text":"Pub. L. 99–439","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-02"},"text":"Oct. 2, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1085"},"text":"100 Stat. 1085","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd366964-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd366965-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd366966-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s58a"},"text":"section 58a of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Supplemental Appropriations Act, 1984.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd366967-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/439"},"text":"Pub. L. 99–439","children":[],"tail":" struck out “(except services for which the charge is based on the amount of time the service is used)” after “Senator’s State”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/65"},"text":"Pub. L. 99–65","children":[],"tail":" inserted “and in such Senator’s State (except services for which the charge is based on the amount of time the service is used)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd366968-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd366969-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1985 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/65"},"text":"Pub. L. 99–65","children":[],"tail":" effective on first day of first calendar month beginning more than 60 days after "},{"tag":"date","attrib":{"date":"1985-07-12"},"text":"July 12, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/65/s2"},"text":"section 2 of Pub. L. 99–65","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s6314"},"text":"section 6314 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd36696a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Payment for Telecommunications Service","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/53/tI/s5"},"text":"Pub. L. 104–53, title I, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-11-19"},"text":"Nov. 19, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/517"},"text":"109 Stat. 517","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/104/197/tI/s4/a"},"text":"Pub. L. 104–197, title I, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-16"},"text":"Sept. 16, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2397"},"text":"110 Stat. 2397","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/68/tI/s104/a"},"text":"Pub. L. 107–68, title I, § 104(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-11-12"},"text":"Nov. 12, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/568"},"text":"115 Stat. 568","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/68/tI/s104/a"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any payment for local and long distance telecommunications service provided to any user shall cover the total invoiced amount, including any amount relating to separately identified toll calls, and shall be charged to the appropriation for the fiscal year in which the underlying base service period covered by the invoice begins.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As used in subsection (a), the term ‘user’ means a Senator, an Officer of the Senate, and any office, committee, or other entity the funds of which are disbursed by the Secretary of the Senate.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/68/tI/s104/b"},"text":"Pub. L. 107–68, title I, § 104(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-11-12"},"text":"Nov. 12, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/568"},"text":"115 Stat. 568","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/68/tI/s104/b"},"text":"“The amendment made by subsection (a) [amending ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/53/s5"},"text":"section 5 of Pub. L. 104–53","children":[],"tail":", set out above] shall take effect on "},{"tag":"date","attrib":{"date":"2001-10-01"},"text":"October 1, 2001","children":[],"tail":", and shall apply to base service periods beginning on or after that date.”"}],"tail":"\n]"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/197/tI/s4/b"},"text":"Pub. L. 104–197, title I, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-16"},"text":"Sept. 16, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2397"},"text":"110 Stat. 2397","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/197/tI/s4/b"},"text":"“The amendments made by subsection (a) [amending ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/53/s5"},"text":"section 5 of Pub. L. 104–53","children":[],"tail":", set out above] shall take effect on "},{"tag":"date","attrib":{"date":"1996-10-01"},"text":"October 1, 1996","children":[],"tail":", and shall apply to all payments made on or after such date for local and long distance telecommunications service.”"}],"tail":"\n]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
