{"tag":"section","attrib":{"id":"iddc72cafa-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s30b"},"text":null,"children":[{"tag":"num","attrib":{"value":"30b"},"text":"§ 30b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of objecting to proceeding","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc72cafb-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s30b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Majority and Minority Leaders of the Senate or their designees shall recognize a notice of intent of a Senator who is a member of their caucus to object to proceeding to a measure or matter only if the Senator—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc72cafc-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s30b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" following the objection to a unanimous consent to proceeding to, and, or passage of, a measure or matter on their behalf, submits the notice of intent in writing to the appropriate leader or their designee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc72cafd-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s30b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 6 session days after the submission under paragraph (1), submits for inclusion in the Congressional Record and in the applicable calendar section described in subsection (b) the following notice:","children":[{"tag":"p","attrib":{},"text":"“I, Senator ____, intend to object to proceedings to ____, dated ____ for the following reasons ____.”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc72cafe-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s30b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Calendar","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc72caff-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s30b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Senate shall establish for both the Senate Calendar of Business and the Senate Executive Calendar a separate section entitled “Notice of Intent to Object to Proceeding”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc72cb00-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s30b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The section required by paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc753c01-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s30b/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of each Senator filing a notice under subsection (a)(2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc753c02-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s30b/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the measure or matter covered by the calendar that the Senator objects to; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc753c03-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s30b/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date the objection was filed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc753c04-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s30b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Senator who has notified their respective leader and who has withdrawn their objection within the 6 session day period is not required to submit a notification under subsection (a)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc753c05-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s30b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Senator may have an item with respect to the Senator removed from a calendar to which it was added under subsection (b) by submitting for inclusion in the Congressional Record the following notice:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“I, Senator ____, do not object to proceed to ____, dated ____.”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc753c06-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/81/tV/s512"},"text":"Pub. L. 110–81, title V, § 512","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-09-14"},"text":"Sept. 14, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/759"},"text":"121 Stat. 759","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc753c07-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc753c08-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddc753c09-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/81/tV/s556"},"text":"Pub. L. 110–81, title V, § 556","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-09-14"},"text":"Sept. 14, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/774"},"text":"121 Stat. 774","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/81/tV/s556"},"text":"“Except as otherwise provided in this title [enacting this section, sections 4722, 4723, 4726, 4727, and 4728 of this title, and provisions set out as notes under this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s4726"},"text":"section 4726 of this title","children":[],"tail":"], this title shall take effect on the date of enactment of this title ["},{"tag":"date","attrib":{"date":"2007-09-14"},"text":"Sept. 14, 2007","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddc753c0a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Exercise of Rulemaking Powers","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/81/tV/s555"},"text":"Pub. L. 110–81, title V, § 555","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-09-14"},"text":"Sept. 14, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/774"},"text":"121 Stat. 774","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/81/tV/s555"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Senate adopts the provisions of this title [see Effective Date note above]—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as an exercise of the rulemaking power of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with full recognition of the constitutional right of the Senate to change those rules at any time, in the same manner, and to the same extent as in the case of any other rule of the Senate.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
