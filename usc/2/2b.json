{"tag":"section","attrib":{"id":"iddc6e101a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2b"},"text":"§ 2b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Number of Representatives from each State in 78th and subsequent Congresses","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Each State shall be entitled, in the Seventy-eighth and in each Congress thereafter until the taking effect of a reapportionment under a subsequent statute or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s2a"},"text":"section 2a of this title","children":[],"tail":", to the number of Representatives shown in the statement transmitted to the Congress on "},{"tag":"date","attrib":{"date":"1941-01-08"},"text":"January 8, 1941","children":[],"tail":", based upon the method known as the method of equal proportions, no State to receive less than one Member."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc6e101b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1941-11-15/ch470/s2/a"},"text":"Nov. 15, 1941, ch. 470, § 2(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/55/762"},"text":"55 Stat. 762","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc6e101c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc6e101d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddc6e101e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Certificates to Executives of States","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1941-11-15/ch470/s2/b"},"text":"Act Nov. 15, 1941, ch. 470, § 2(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/55/762"},"text":"55 Stat. 762","children":[],"tail":", required Clerk of House of Representatives, within 15 days of "},{"tag":"date","attrib":{"date":"1941-11-15"},"text":"Nov. 15, 1941","children":[],"tail":", to send a new certificate of entitlement of a State to Representatives, if such a certificate had been sent prior to "},{"tag":"date","attrib":{"date":"1941-11-15"},"text":"Nov. 15, 1941","children":[],"tail":", under provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s2a"},"text":"section 2a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
