{"tag":"section","attrib":{"id":"iddca748b1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s608"},"text":null,"children":[{"tag":"num","attrib":{"value":"608"},"text":"§ 608.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lump-sum payments to enhance staff recruitment and to reward exceptional performance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddca748b2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s608/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Congressional Budget Office shall have the authority to make lump-sum payments to enhance staff recruitment and to reward exceptional performance by an employee or a group of employees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca748b3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s608/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsection (a) shall apply with respect to fiscal years beginning after ","children":[{"tag":"date","attrib":{"date":"1999-09-30"},"text":"September 30, 1999","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddca748b4-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/57/tI/s106"},"text":"Pub. L. 106–57, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-09-29"},"text":"Sept. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/418"},"text":"113 Stat. 418","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddca748b5-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddca748b6-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddca748b7-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Congressional Operations Appropriations Act, 2000, which is title I of the Legislative Branch Appropriations Act, 2000, and not as part of title II of the Congressional Budget and Impoundment Control Act of 1974 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
