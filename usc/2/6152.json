{"tag":"section","attrib":{"id":"iddd33f870-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6152"},"text":null,"children":[{"tag":"num","attrib":{"value":"6152"},"text":"§ 6152.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment and compensation of employees by Secretaries for Senate Majority and Minority; gross compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Effective ","children":[{"tag":"date","attrib":{"date":"1977-10-01"},"text":"October 1, 1977","children":[],"tail":", the Secretary for the Majority and the Secretary for the Minority are each authorized to appoint and fix the compensation of such employees as they deem appropriate: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the gross compensation paid to such employees shall not exceed $143,200 each fiscal year for each Secretary."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd33f871-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/94/tI"},"text":"Pub. L. 95–94, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-05"},"text":"Aug. 5, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/658"},"text":"91 Stat. 658","children":[],"tail":", 659.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd33f872-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd33f873-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd33f874-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s61g–5"},"text":"section 61g–5 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Congressional Operations Appropriation Act, 1978, which is title I of the Legislative Branch Appropriation Act, 1978.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd33f875-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd33f876-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Increases in Compensation","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Increases in compensation for Senate officers and employees under authority of Federal Pay Comparability Act of 1970 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/656"},"text":"Pub. L. 91–656","children":[],"tail":"), see Salary Directives of President pro tempore of the Senate, set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s4571"},"text":"section 4571 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
