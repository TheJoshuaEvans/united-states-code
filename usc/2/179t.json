{"tag":"section","attrib":{"id":"iddc8f7af5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s179t"},"text":null,"children":[{"tag":"num","attrib":{"value":"179t"},"text":"§ 179t.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff of Board; experts and consultants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc8f7af6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s179t/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Librarian may appoint and fix the pay of such personnel as the Librarian considers appropriate to carry out sections 179","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":" to 179w of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc8f7af7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s179t/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Experts and consultants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Librarian may, in carrying out sections 179","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":" to 179w of this title, procure temporary and intermittent services under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109/b"},"text":"section 3109(b) of title 5","children":[],"tail":", but at rates for individuals not to exceed the daily equivalent of the maximum rate of basic pay payable for GS–15 of the General Schedule. In no case may a member of the Board or an alternate be paid as an expert or consultant under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc8f7af8-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/285/tI/s110"},"text":"Pub. L. 104–285, title I, § 110","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3381"},"text":"110 Stat. 3381","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc8f7af9-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc8f7afa-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddc8f7afb-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The General Schedule, referred to in subsec. (b), is set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
