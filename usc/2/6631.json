{"tag":"section","attrib":{"id":"iddd3fdf5a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6631"},"text":null,"children":[{"tag":"num","attrib":{"value":"6631"},"text":"§ 6631.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of excess or surplus educationally useful equipment to public schools","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd3fdf5b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6631/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Sergeant at Arms and Doorkeeper of the Senate may directly, or through the General Services Administration, transfer title to excess or surplus educationally useful equipment to a public school. Any such transfer shall be completed at the lowest possible cost to the public school and the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3fdf5c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6631/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Committee on Rules and Administration of the Senate shall prescribe regulations to carry out the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3fdf5d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6631/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit of receipts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Receipts from reimbursements for the costs of transfer of excess or surplus educationally useful equipment under this section,","children":[{"tag":"ref","attrib":{"idref":"fn002121"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002121"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Comma probably should not appear."}],"tail":" shall be deposited in the United States Treasury for credit to the account for the “Sergeant at Arms and Doorkeeper of the Senate” within the contingent fund of the Senate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3fdf5e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6631/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd3fdf5f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6631/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “public school” means a ","children":[{"tag":"ref","attrib":{"idref":"fn002122"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002122"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “an”."}],"tail":" elementary school or secondary school, as such terms are defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3fdf60-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6631/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “educationally useful equipment” means computers and related peripheral tools, including printers, modems, routers, servers, computer keyboards, scanners, and other telecommunications and research equipment, that are appropriate for use in public school education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3fdf61-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6631/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall take effect beginning with fiscal year 1997 and shall be effective each fiscal year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd3fdf62-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/197/tI/s5"},"text":"Pub. L. 104–197, title I, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-16"},"text":"Sept. 16, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2397"},"text":"110 Stat. 2397","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tX/s1076/a"},"text":"Pub. L. 107–110, title X, § 1076(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2091"},"text":"115 Stat. 2091","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIX/s9215/yy"},"text":"Pub. L. 114–95, title IX, § 9215(yy)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2184"},"text":"129 Stat. 2184","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd3fdf63-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd3fdf64-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd3fdf65-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s117b–2"},"text":"section 117b–2 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Congressional Operations Appropriations Act, 1997, which is title I of the Legislative Branch Appropriations Act, 1997.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd3fdf66-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" substituted “elementary school or secondary school, as such terms are defined in section 7801” for “public elementary or secondary school as such terms are defined in section 7801”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":" substituted “7801” for “8801”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes