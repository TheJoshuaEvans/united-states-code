{"tag":"section","attrib":{"id":"iddc943608-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s272"},"text":null,"children":[{"tag":"num","attrib":{"value":"272"},"text":"§ 272.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Legislative Counsel","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Legislative Counsel shall be appointed by the President pro tempore of the Senate, without reference to political affiliations and solely on the ground of fitness to perform the duties of the office.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc943609-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1919-02-24/ch18"},"text":"Feb. 24, 1919, ch. 18","children":[],"tail":", title XIII, § 1303(a), (d), "},{"tag":"ref","attrib":{"href":"/us/stat/40/1141"},"text":"40 Stat. 1141","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1924-06-02/ch234"},"text":"June 2, 1924, ch. 234","children":[],"tail":", title XI, § 1101, "},{"tag":"ref","attrib":{"href":"/us/stat/43/353"},"text":"43 Stat. 353","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1941-09-20/ch412"},"text":"Sept. 20, 1941, ch. 412","children":[],"tail":", title VI, § 602, "},{"tag":"ref","attrib":{"href":"/us/stat/55/726"},"text":"55 Stat. 726","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc94360a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc94360b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddc94360c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions authorizing appointment of a legislative counsel for the House of Representatives by the Speaker were omitted in view of nonapplicability of section to Speaker, employee, etc., of the House of Representatives pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/510/s531"},"text":"section 531 of Pub. L. 91–510","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s281"},"text":"section 281 of this title","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s282"},"text":"section 282 of this title","children":[],"tail":" for provisions authorizing appointment, etc., of Legislative Counsel of the House of Representatives."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc94360d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1941—Act ","children":[{"tag":"date","attrib":{"date":"1941-09-20"},"text":"Sept. 20, 1941","children":[],"tail":", substituted “President pro tempore of the Senate” for “President of the Senate.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
