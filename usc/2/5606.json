{"tag":"section","attrib":{"id":"iddd31adab-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5606"},"text":null,"children":[{"tag":"num","attrib":{"value":"5606"},"text":"§ 5606.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Arrangements for attendance at funeral of deceased House Members; payment of funeral expenses and expenses of attending funeral rites","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the Sergeant at Arms of the House is authorized and directed on and after ","children":[{"tag":"date","attrib":{"date":"1962-10-02"},"text":"October 2, 1962","children":[],"tail":", to make such arrangements as may be necessary for any committee of Members of the Senate and House of Representatives duly appointed to attend the funeral of a deceased Member of the House. Notwithstanding any other provision of law, there shall be paid out of the applicable accounts of the House of Representatives, under such rules and regulations as the Committee on House Oversight may prescribe, such sums as may be necessary to defray the funeral expenses of the deceased Member and to defray the expenses of such committee, the Sergeant at Arms of the House or a representative of his office, and the widow (or widower) or minor children, or both, of the deceased Member incurred in attending the funeral rites and burial of such Member."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd31adac-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/730/s101"},"text":"Pub. L. 87–730, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-02"},"text":"Oct. 2, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/686"},"text":"76 Stat. 686","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/186/tII/s204/69"},"text":"Pub. L. 104–186, title II, § 204(69)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1740"},"text":"110 Stat. 1740","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd31adad-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd31adae-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd31adaf-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s124"},"text":"section 124 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Legislative Branch Appropriation Act, 1963.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"iddd31adb0-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in the following prior appropriation acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1955-08-05/ch568"},"text":"Aug. 5, 1955, ch. 568","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/513"},"text":"69 Stat. 513","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1954-07-02/ch455"},"text":"July 2, 1954, ch. 455","children":[],"tail":", title I, "},{"tag":"ref","attrib":{"href":"/us/stat/68/403"},"text":"68 Stat. 403","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1953-08-01/ch304"},"text":"Aug. 1, 1953, ch. 304","children":[],"tail":", title I, "},{"tag":"ref","attrib":{"href":"/us/stat/67/325"},"text":"67 Stat. 325","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd31adb1-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186"},"text":"Pub. L. 104–186","children":[],"tail":" substituted “applicable accounts of the House of Representatives” for “contingent fund of the House” and “House Oversight” for “House Administration”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd31adb2-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"iddd31adb3-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on House Oversight of House of Representatives changed to Committee on House Administration of House of Representatives by House Resolution No. 5, One Hundred Sixth Congress, ","children":[{"tag":"date","attrib":{"date":"1999-01-06"},"text":"Jan. 6, 1999","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
