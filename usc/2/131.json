c":"amendments","id":"iddc839391-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1987—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/202"},"text":"Pub. L. 100–202","children":[],"tail":" struck out after first sentence “The law library shall be preserved in the Capitol in the rooms which were on "},{"tag":"date","attrib":{"date":"1872-07-04"},"text":"July 4, 1872","children":[],"tail":", appropriated to its use, and in such others as may hereafter be assigned thereto.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/553"},"text":"Pub. L. 94–553","children":[],"tail":" substituted “acquisition of material under the copyright law” for “deposit to secure copyright”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc839392-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddc839393-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/553"},"text":"Pub. L. 94–553","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1978-01-01"},"text":"Jan. 1, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/553/s102"},"text":"section 102 of Pub. L. 94–553","children":[],"tail":" set out as an Effective Date note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t17/s101"},"text":"section 101 of Title 17","children":[],"tail":", Copyrights."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"iddc839394-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2019 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/dP/tXIV/s1401"},"text":"Pub. L. 116–94, div. P, title XIV, § 1401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3206"},"text":"133 Stat. 3206","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/94/dP/tXIV/s1401"},"text":"“This title [amending sections 135a, 136a–2, and 166 of this title, sections 701, 802, and 803 of Title 17, Copyrights, and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s2103"},"text":"section 2103 of Title 20","children":[],"tail":", Education, repealing "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s135a–1"},"text":"section 135a–1 of this title","children":[],"tail":" and enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t17/s802"},"text":"section 802 of Title 17","children":[],"tail":"] may be cited as the ‘Library of Congress Technical Corrections Act of 2019’.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/dP/tXVI/s1601"},"text":"Pub. L. 116–94, div. P, title XVI, § 1601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3209"},"text":"133 Stat. 3209","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/94/dP/tXVI/s1601"},"text":"“This title [amending sections 185 and 1808 of this title and sections 3902 and 3903 of Title 44, Public Printing and Documents] may be cited as the ‘Legislative Branch Inspectors General Independence Act of 2019’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddc839395-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transfer to Library Building","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions for the removal of the Library to the Library Building, erected pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/act/1886-04-15/ch50"},"text":"act Apr. 15, 1886, ch. 50","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/24/12"},"text":"24 Stat. 12","children":[],"tail":", and for the custody, care, and maintenance of that building, were made by act "},{"tag":"date","attrib":{"date":"1897-02-19"},"text":"Feb. 19, 1897","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddc839396-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Organizing and Microfilming of Presidential Papers; Appropriation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/85/147"},"text":"Pub. L. 85–147","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1957-08-16"},"text":"Aug. 16, 1957","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/71/368"},"text":"71 Stat. 368","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/87/263"},"text":"Pub. L. 87–263","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-21"},"text":"Sept. 21, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/544"},"text":"75 Stat. 544","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/299"},"text":"Pub. L. 88–299","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-04-27"},"text":"Apr. 27, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/183"},"text":"78 Stat. 183","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/88/299"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“That the Librarian of Congress is authorized and directed to arrange, index and microfilm the papers of the Presidents of the United States in the collections of the Library of Congress, in order to preserve their contents against destruction by war or other calamity and for the purpose of making them more readily available for study and research to the fullest possible extent consistent with any existing limitations that may have been imposed on the use of or the access to such papers by their donors or by those placing them on deposit with the Library of Congress. Neither the United States nor any officer or employee of the United States shall be liable for damages for infringement of literary property rights by reason of any activity authorized by this Act.","children":[],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“Sec. 2.","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There are authorized to be appropriated such amounts as may be necessary to carry out the provisions of this Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
