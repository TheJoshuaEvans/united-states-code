{"tag":"section","attrib":{"id":"iddc83938c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s131"},"text":null,"children":[{"tag":"num","attrib":{"value":"131"},"text":"§ 131.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collections composing Library; location","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Library of Congress, composed of the books, maps, and other publications which on ","children":[{"tag":"date","attrib":{"date":"1873-12-01"},"text":"December 1, 1873","children":[],"tail":", remained in existence, from the collections theretofore united under authority of law and those added from time to time by purchase, exchange, donation, reservation from publications ordered by Congress, acquisition of material under the copyright law, and otherwise, shall be preserved in the Library Building."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc83938d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(R.S. § 80; ","children":[{"tag":"ref","attrib":{"href":"/us/act/1897-02-19/ch265/s1"},"text":"Feb. 19, 1897, ch. 265, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/29/545"},"text":"29 Stat. 545","children":[],"tail":", 546; "},{"tag":"ref","attrib":{"href":"/us/pl/94/553/tI/s105/g"},"text":"Pub. L. 94–553, title I, § 105(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-19"},"text":"Oct. 19, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2599"},"text":"90 Stat. 2599","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/202/s101/i/tIII/s310"},"text":"Pub. L. 100–202, § 101(i) [title III, § 310]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1329-290"},"text":"101 Stat. 1329–290","children":[],"tail":", 1329–310.)"}],"tail":"\n"},{"tag":"notes","attrib":{