{"tag":"section","attrib":{"id":"iddca748d7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s612"},"text":null,"children":[{"tag":"num","attrib":{"value":"612"},"text":"§ 612.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Executive exchange program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddca748d8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s612/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Congressional Budget Office may establish and conduct an executive exchange program under which employees of the Office may be assigned to private sector organizations, and employees of private sector organizations may be assigned to the Office, for 1-year periods to further the institutional interests of the Office or Congress, including for the purpose of providing training to officers and employees of the Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca748d9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s612/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations and conditions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the Congressional Budget Office shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddca748da-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s612/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limit the number of officers and employees who are assigned to private sector organizations at any one time to not more than 5;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca748db-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s612/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limit the number of employees from private sector organizations who are assigned to the Office at any one time to not more than 5;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca748dc-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s612/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require that an employee of a private sector organization assigned to the Office may not have access to any trade secrets or to any other nonpublic information which is of commercial value to the private sector organization from which such employee is assigned; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca748dd-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s612/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approve employees to be detailed from the private sector without regard to political affiliation and solely on the basis of their fitness to perform their assigned duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca748de-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s612/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of private employees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An employee of a private sector organization assigned to the Office under the executive exchange program shall be considered to be an employee of the Office for purposes of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddca748df-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s612/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 73 of title 5;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca748e0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s612/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sections 201, 203, 205, 207, 208, 209, 603, 606, 607, 643, 654, 1905, and 1913 of title 18;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca748e1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s612/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sections 1343, 1344, and 1349(b) of title 31;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca748e2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s612/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 171 of title 28 (commonly referred to as the “Federal Tort Claims Act”) and any other Federal tort liability statute;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca748e3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s612/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 131 of title 5; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca748e4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s612/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s1043"},"text":"section 1043 of title 26","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca748e5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s612/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply to fiscal year 2008 and each fiscal year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddca748e6-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161/dH/tI/s1201"},"text":"Pub. L. 110–161, div. H, title I, § 1201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2238"},"text":"121 Stat. 2238","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/68/dA/tI/s1201"},"text":"Pub. L. 111–68, div. A, title I, § 1201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2032"},"text":"123 Stat. 2032","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/c/1"},"text":"Pub. L. 117–286, § 4(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4353"},"text":"136 Stat. 4353","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddca748e7-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddca748e8-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddca748e9-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Legislative Branch Appropriations Act, 2008, which is div. H of the Consolidated Appropriations Act, 2008, and not as part of title II of the Congressional Budget and Impoundment Control Act of 1974 which comprises this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s611"},"text":"section 611 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddca748ea-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “chapter 131 of title 5;” for “the Ethics in Government Act of 1978 (5 U.S.C. App.);”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (b)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/68/s1201/1"},"text":"Pub. L. 111–68, § 1201(1)","children":[],"tail":", substituted “5” for “3”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/68/s1201/2"},"text":"Pub. L. 111–68, § 1201(2)","children":[],"tail":", (3), redesignated subsec. (e) as (d), substituted “This” for “Subject to subsection (d), this”, and struck out former subsec. (d). Prior to amendment, text of subsec. (d) read as follows: “No assignment under this section shall commence after the end of the 2-year period beginning on "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"December 26, 2007","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
