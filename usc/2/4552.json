{"tag":"section","attrib":{"id":"iddd176f9e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4552"},"text":null,"children":[{"tag":"num","attrib":{"value":"4552"},"text":"§ 4552.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certificates to pay rolls of employees of House","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Clerk, Sergeant at Arms, and Chief Administrative Officer of the House of Representatives shall make certificate each month to their respective pay rolls, stating whether the persons named in such pay rolls and employed in their respective departments have been actually present at their respective places of duty and have actually performed the services for which compensation is provided in said pay rolls, and in each case where a person carried on such pay roll has been absent and has not performed the services in whole or in part for which payment is proposed, the reason for such absence and for such nonperformance of services shall be stated.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd176f9f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1901-03-03/ch830/s1"},"text":"Mar. 3, 1901, ch. 830, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/31/968"},"text":"31 Stat. 968","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/186/tII/s204/41"},"text":"Pub. L. 104–186, title II, § 204(41)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1736"},"text":"110 Stat. 1736","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd176fa0-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd176fa1-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd176fa2-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s89"},"text":"section 89 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd176fa3-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186"},"text":"Pub. L. 104–186","children":[],"tail":" substituted “and Chief Administrative Officer” for “Doorkeeper, and Postmaster”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
