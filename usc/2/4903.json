{"tag":"section","attrib":{"id":"iddd25a078-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4903"},"text":null,"children":[{"tag":"num","attrib":{"value":"4903"},"text":"§ 4903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Education of other minors who are Senate employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The facilities provided for the education of Congressional and Supreme Court pages shall be available from and after ","children":[{"tag":"date","attrib":{"date":"1947-01-02"},"text":"January 2, 1947","children":[],"tail":", also for the education of such other minors who are Senate employees as may be certified by the Secretary of the Senate to receive such education."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd25a079-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-03-22/ch20"},"text":"Mar. 22, 1947, ch. 20","children":[],"tail":", title I, "},{"tag":"ref","attrib":{"href":"/us/stat/61/16"},"text":"61 Stat. 16","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/367/tI/s103"},"text":"Pub. L. 98–367, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-17"},"text":"July 17, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/479"},"text":"98 Stat. 479","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/186/tII/s204/35"},"text":"Pub. L. 104–186, title II, § 204(35)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1735"},"text":"110 Stat. 1735","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd25a07a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd25a07b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd25a07c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s88b"},"text":"section 88b of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The first paragraph of this section is based on act ","children":[{"tag":"date","attrib":{"date":"1947-03-22"},"text":"Mar. 22, 1947","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The second paragraph was based on H. Res. No. 279, Ninety-eighth Congress, ","children":[{"tag":"date","attrib":{"date":"1983-07-21"},"text":"July 21, 1983","children":[],"tail":", enacted into permanent law by "},{"tag":"ref","attrib":{"href":"/us/pl/98/367"},"text":"Pub. L. 98–367","children":[],"tail":". See 1996 Amendment note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd25a07d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186"},"text":"Pub. L. 104–186","children":[],"tail":", in first par., substituted “Senate employees” for “congressional employees” and struck out “and the Clerk of the House of Representatives” after “Secretary of the Senate”, and struck out second par. which read as follows: “This section shall not apply to any minor who is an employee of the House of Representatives or to any educational facility under the House of Representatives Page Board.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
