{"tag":"section","attrib":{"id":"iddcf87574-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1982"},"text":null,"children":[{"tag":"num","attrib":{"value":"1982"},"text":"§ 1982.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance of surplus or obsolete property","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Upon notifying the Committees of Appropriations of the House of Representatives and Senate, the United States Capitol Police may accept surplus or obsolete property offered by another Federal department, agency, or office.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddcf87575-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/31/dI/tI/s1001/b"},"text":"Pub. L. 115–31, div. I, title I, § 1001(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-05-05"},"text":"May 5, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/578"},"text":"131 Stat. 578","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcf87576-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcf87577-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddcf87578-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Legislative Branch Appropriations Act, 2017, which is div. I of the Consolidated Appropriations Act, 2017.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcf87579-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddcf8757a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable with respect to fiscal year 2017 and each succeeding fiscal year, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/31/s1001/c"},"text":"section 1001(c) of Pub. L. 115–31","children":[],"tail":", set out as an Effective Date of 2017 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1906"},"text":"section 1906 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
