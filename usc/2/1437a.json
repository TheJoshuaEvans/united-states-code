{"tag":"section","attrib":{"id":"iddcde3781-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1437a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1437a"},"text":"§ 1437a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training and education programs of employing offices","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcde3782-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1437a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requiring offices to develop and implement programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each employing office shall develop and implement a program to train and educate covered employees of the office in the rights and protections provided under this chapter, including the procedures available under subchapter IV to consider alleged violations of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcde3783-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1437a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to committees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcde3784-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1437a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 45 days after the beginning of each Congress (beginning with the One Hundred Seventeenth Congress), each employing office shall submit a report to the Committee on House Administration of the House of Representatives and the Committee on Rules and Administration of the Senate on the implementation of the program required under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcde3785-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1437a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for first report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2018-12-21"},"text":"December 21, 2018","children":[],"tail":", each employing office shall submit the report described in paragraph (1) to the Committees described in such paragraph."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcde3786-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1437a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for offices of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section does not apply to an employing office of the House of Representatives or an employing office of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcde3787-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/1/tV/s509"},"text":"Pub. L. 104–1, title V, § 509","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/397/tIII/s306/a/2"},"text":"Pub. L. 115–397, title III, § 306(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5324"},"text":"132 Stat. 5324","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcde3788-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcde3789-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddcde378a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/1"},"text":"Pub. L. 104–1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-01-23"},"text":"Jan. 23, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/3"},"text":"109 Stat. 3","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1301"},"text":"section 1301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"iddcde378b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/1/s509"},"text":"section 509 of Pub. L. 104–1","children":[],"tail":" was renumbered section 511 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1438"},"text":"section 1438 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcde378c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddcde378d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective upon expiration of the 180-day period beginning on ","children":[{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", with provisions for effect on pending proceedings, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/397/s401"},"text":"section 401 of Pub. L. 115–397","children":[],"tail":", set out as an Effective Date of 2018 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
