{"tag":"section","attrib":{"id":"iddd0b88bf-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4104"},"text":null,"children":[{"tag":"num","attrib":{"value":"4104"},"text":"§ 4104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" American goods to be preferred in purchases for Senate and House","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Senate and the Chief Administrative Officer of the House of Representatives shall, in disbursing the public moneys for the use of the two Houses, respectively, purchase only articles the growth and manufacture of the United States, provided the articles required can be procured of such growth and manufacture upon as good terms as to quality and price as are demanded for like articles of foreign growth and manufacture.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd0b88c0-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(R.S. § 69; ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186/tII/s204/57"},"text":"Pub. L. 104–186, title II, § 204(57)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1738"},"text":"110 Stat. 1738","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd0b88c1-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd0b88c2-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd0b88c3-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s109"},"text":"section 109 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 69 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1844-06-17/ch105/s1"},"text":"act June 17, 1844, ch. 105, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/5/681"},"text":"5 Stat. 681","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd0b88c4-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186"},"text":"Pub. L. 104–186","children":[],"tail":" substituted “Chief Administrative Officer” for “Clerk”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
