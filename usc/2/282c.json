{"tag":"section","attrib":{"id":"iddc96a66d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s282c"},"text":null,"children":[{"tag":"num","attrib":{"value":"282c"},"text":"§ 282c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditures","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In accordance with policies and procedures approved by the Speaker, the Legislative Counsel may make such expenditures as may be necessary or appropriate for the functioning of the Office.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc96a66e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/510/tV/s524"},"text":"Pub. L. 91–510, title V, § 524","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-26"},"text":"Oct. 26, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1203"},"text":"84 Stat. 1203","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
