{"tag":"section","attrib":{"id":"iddca748b8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s609"},"text":null,"children":[{"tag":"num","attrib":{"value":"609"},"text":"§ 609.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employee training","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddca748b9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s609/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Congressional Budget Office may, by regulation, make applicable such provisions of chapter 41 of title 5 as the Director determines necessary to provide on and after ","children":[{"tag":"date","attrib":{"date":"2001-11-12"},"text":"November 12, 2001","children":[],"tail":", for training of individuals employed by the Congressional Budget Office."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca748ba-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s609/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The implementing regulations shall provide for training that, in the determination of the Director, is consistent with the training provided by agencies subject to chapter 41 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca748bb-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s609/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery of debt","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any recovery of debt owed to the Congressional Budget Office under this section and its implementing regulations shall be credited to the appropriations account available for salaries and expenses of the Office at the time of recovery.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca748bc-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s609/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply to fiscal year 2002 and each fiscal year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddca748bd-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/68/tI/s125"},"text":"Pub. L. 107–68, title I, § 125","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-11-12"},"text":"Nov. 12, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/577"},"text":"115 Stat. 577","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddca748be-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddca748bf-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddca748c0-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Congressional Operations Appropriations Act, 2002, which is title I of the Legislative Branch Appropriations Act, 2002, and not as part of title II of the Congressional Budget and Impoundment Control Act of 1974 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
