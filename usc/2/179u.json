{"tag":"section","attrib":{"id":"iddc8f7afc-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s179u"},"text":null,"children":[{"tag":"num","attrib":{"value":"179u"},"text":"§ 179u.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in sections 179","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":" to 179w of this title—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc8f7afd-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s179u/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Librarian” means the Librarian of Congress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc8f7afe-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s179u/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Board” means the National Film Preservation Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc8f7aff-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s179u/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “film” means a “motion picture” as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t17/s101"},"text":"section 101 of title 17","children":[],"tail":", except that such term does not include any work not originally fixed on film stock, such as a work fixed on videotape or laser disk;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc8f7b00-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s179u/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “publication” means “publication” as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t17/s101"},"text":"section 101 of title 17","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc8f7b01-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s179u/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Registry version” means, with respect to a film, the version of a film first published, or as complete a version as bona fide preservation and restoration activities by the Librarian, an archivist other than the Librarian, or the copyright owner can compile in those cases where the original material has been irretrievably lost.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc8f7b02-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/285/tI/s111"},"text":"Pub. L. 104–285, title I, § 111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3382"},"text":"110 Stat. 3382","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
