{"tag":"section","attrib":{"id":"iddce081f0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1603"},"text":null,"children":[{"tag":"num","attrib":{"value":"1603"},"text":"§ 1603.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registration of lobbyists","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddce081f1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1603/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce081f2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1603/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No later than 45 days after a lobbyist first makes a lobbying contact or is employed or retained to make a lobbying contact, whichever is earlier, or on the first business day after such 45th day if the 45th day is not a business day, such lobbyist (or, as provided under paragraph (2), the organization employing such lobbyist), shall register with the Secretary of the Senate and the Clerk of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce081f3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1603/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employer filing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any organization that has 1 or more employees who are lobbyists shall file a single registration under this section on behalf of such employees for each client on whose behalf the employees act as lobbyists.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce081f4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1603/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddce081f5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1603/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding paragraphs (1) and (2), a person or entity whose—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddce081f6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1603/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" total income for matters related to lobbying activities on behalf of a particular client (in the case of a lobbying firm) does not exceed and is not expected to exceed $2,500; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddce081f7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1603/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" total expenses in connection with lobbying activities (in the case of an organization whose employees engage in lobbying activities on its own behalf) do not exceed or are not expected to exceed $10,000,","children":[{"tag":"p","attrib":{},"text":"(as estimated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1604"},"text":"section 1604 of this title","children":[],"tail":") in the quarterly period described in "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1604/a"},"text":"section 1604(a) of this title","children":[],"tail":" during which the registration would be made is not required to register under this subsection with respect to such client."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce081f8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1603/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The dollar amounts in subparagraph (A) shall be adjusted—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddce081f9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1603/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on ","children":[{"tag":"date","attrib":{"date":"1997-01-01"},"text":"January 1, 1997","children":[],"tail":", to reflect changes in the Consumer Price Index (as determined by the Secretary of Labor) since "},{"tag":"date","attrib":{"date":"1995-12-19"},"text":"December 19, 1995","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddce081fa-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1603/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on January 1 of each fourth year occurring after ","children":[{"tag":"date","attrib":{"date":"1997-01-01"},"text":"January 1, 1997","children":[],"tail":", to reflect changes in the Consumer Price Index (as determined by the Secretary of Labor) during the preceding 4-year period,"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"rounded to the nearest $500.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce081fb-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1603/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of registration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each registration under this section shall contain—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce081fc-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1603/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name, address, business telephone number, and principal place of business of the registrant, and a general description of its business or activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce081fd-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1603/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name, address, and principal place of business of the registrant’s client, and a general description of its business or activities (if different from paragraph (1));","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce081fe-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1603/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the name, address, and principal place of business of any organization, other than the client, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddce081ff-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1603/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contributes more than $5,000 to the registrant or the client in the quarterly period to fund the lobbying activities of the registrant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce08200-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1603/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actively participates in the planning, supervision, or control of such lobbying activities;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce08201-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1603/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the name, address, principal place of business, amount of any contribution of more than $5,000 to the lobbying activities of the registrant, and approximate percentage of equitable ownership in the client (if any) of any foreign entity that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddce08202-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1603/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" holds at least 20 percent equitable ownership in the client or any organization identified under paragraph (3);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce08203-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1603/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" directly or indirectly, in whole or in major part, plans, supervises, controls, directs, finances, or subsidizes the activities of the client or any organization identified under paragraph (3); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce08204-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1603/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an affiliate of the client or any organization identified under paragraph (3) and has a direct interest in the outcome of the lobbying activity;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce08205-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1603/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a statement of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddce08206-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1603/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the general issue areas in which the registrant expects to engage in lobbying activities on behalf of the client; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce08207-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1603/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent practicable, specific issues that have (as of the date of the registration) already been addressed or are likely to be addressed in lobbying activities;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce08208-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1603/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of each employee of the registrant who has acted or whom the registrant expects to act as a lobbyist on behalf of the client and, if any such employee has served as a covered executive branch official or a covered legislative branch official in the 20 years before the date on which the employee first acted as a lobbyist on behalf of the client, the position in which such employee served; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce08209-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1603/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any listed lobbyist who was convicted in a Federal or State court of an offense involving bribery, extortion, embezzlement, an illegal kickback, tax evasion, fraud, a conflict of interest, making a false statement, perjury, or money laundering, the date of the conviction and a description of the offense.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"No disclosure is required under paragraph (3)(B) if the organization that would be identified as affiliated with the client is listed on the client’s publicly accessible Internet website as being a member of or contributor to the client, unless the organization in whole or in major part plans, supervises, or controls such lobbying activities. If a registrant relies upon the preceding sentence, the registrant must disclose the specific Internet address of the web page containing the information relied upon. Nothing in paragraph (3)(B) shall be construed to require the disclosure of any information about individuals who are members of, or donors to, an entity treated as a client by this chapter or an organization identified under that paragraph.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce0820a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1603/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines for registration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce0820b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1603/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multiple clients","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a registrant making lobbying contacts on behalf of more than 1 client, a separate registration under this section shall be filed for each such client.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce0820c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1603/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multiple contacts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A registrant who makes more than 1 lobbying contact for the same client shall file a single registration covering all such lobbying contacts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce0820d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1603/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of registration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A registrant who after registration—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce0820e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1603/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is no longer employed or retained by a client to conduct lobbying activities, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce0820f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1603/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not anticipate any additional lobbying activities for such client,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"may so notify the Secretary of the Senate and the Clerk of the House of Representatives and terminate its registration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddce08210-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/65/s4"},"text":"Pub. L. 104–65, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-19"},"text":"Dec. 19, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/696"},"text":"109 Stat. 696","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/81/tII"},"text":"Pub. L. 110–81, title II","children":[],"tail":", §§ 201(b)(2), (5), 207(a)(1), (b), 208, "},{"tag":"date","attrib":{"date":"2007-09-14"},"text":"Sept. 14, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/742"},"text":"121 Stat. 742","children":[],"tail":", 747, 748; "},{"tag":"ref","attrib":{"href":"/us/pl/115/418/s2/a"},"text":"Pub. L. 115–418, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-03"},"text":"Jan. 3, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5440"},"text":"132 Stat. 5440","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddce08211-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddce08212-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddce08213-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (b), was in the original “this Act” meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/65"},"text":"Pub. L. 104–65","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-19"},"text":"Dec. 19, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/691"},"text":"109 Stat. 691","children":[],"tail":", known as the Lobbying Disclosure Act of 1995. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1601"},"text":"section 1601 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddce08214-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (b)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/418"},"text":"Pub. L. 115–418","children":[],"tail":" added par. (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/81/s201/b/2/A"},"text":"Pub. L. 110–81, § 201(b)(2)(A)","children":[],"tail":", inserted “or on the first business day after such 45th day if the 45th day is not a business day,” after “earlier,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/81/s201/b/2/B"},"text":"Pub. L. 110–81, § 201(b)(2)(B)","children":[],"tail":", substituted “quarterly period” for “semiannual period” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/81/s201/b/5/A"},"text":"Pub. L. 110–81, § 201(b)(5)(A)","children":[],"tail":", substituted “$2,500” for “$5,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/81/s201/b/5/B"},"text":"Pub. L. 110–81, § 201(b)(5)(B)","children":[],"tail":", substituted “$10,000” for “$20,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/81/s207/b"},"text":"Pub. L. 110–81, § 207(b)","children":[],"tail":", inserted concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/81/s207/a/1/A"},"text":"Pub. L. 110–81, § 207(a)(1)(A)","children":[],"tail":", amended subpar. (A) generally. Prior to amendment, subpar. (A) read as follows: “contributes more than $5,000 toward the lobbying activities of the registrant in a semiannual period described in "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1604/a"},"text":"section 1604(a) of this title","children":[],"tail":"; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/81/s201/b/5/C"},"text":"Pub. L. 110–81, § 201(b)(5)(C)","children":[],"tail":", substituted “$5,000” for “$10,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/81/s207/a/1/B"},"text":"Pub. L. 110–81, § 207(a)(1)(B)","children":[],"tail":", amended subpar. (B) generally. Prior to amendment, subpar. (B) read as follows: “in whole or in major part plans, supervises, or controls such lobbying activities.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/81/s201/b/5/D"},"text":"Pub. L. 110–81, § 201(b)(5)(D)","children":[],"tail":", substituted “$5,000” for “$10,000” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/81/s208"},"text":"Pub. L. 110–81, § 208","children":[],"tail":", substituted “in the 20 years before the date on which the employee first acted” for “in the 2 years before the date on which such employee first acted (after "},{"tag":"date","attrib":{"date":"1995-12-19"},"text":"December 19, 1995","children":[],"tail":")”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddce08215-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddce08216-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Except as otherwise provided, amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/81"},"text":"Pub. L. 110–81","children":[],"tail":" applicable with respect to registrations under the Lobbying Disclosure Act of 1995 (this chapter) having an effective date of "},{"tag":"date","attrib":{"date":"2008-01-01"},"text":"Jan. 1, 2008","children":[],"tail":", or later and with respect to quarterly reports under that Act covering calendar quarters beginning on or after "},{"tag":"date","attrib":{"date":"2008-01-01"},"text":"Jan. 1, 2008","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/81/s215"},"text":"section 215 of Pub. L. 110–81","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s30104"},"text":"section 30104 of Title 52","children":[],"tail":", Voting and Elections."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"to