{"tag":"section","attrib":{"id":"iddc96a635-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s276a"},"text":null,"children":[{"tag":"num","attrib":{"value":"276a"},"text":"§ 276a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditures","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"With the approval of the President Pro Tempore of the Senate, the Legislative Counsel of the Senate may make such expenditures as may be necessary or appropriate for the functioning of the Office of the Legislative Counsel of the Senate.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc96a636-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/51/tI/s105"},"text":"Pub. L. 98–51, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-07-14"},"text":"July 14, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/267"},"text":"97 Stat. 267","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc96a637-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc96a638-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddc96a639-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Congressional Operations Appropriation Act, 1984, which is title I of the Legislative Branch Appropriation Act, 1984, and not as part of section 1303 of act ","children":[{"tag":"date","attrib":{"date":"1919-02-24"},"text":"Feb. 24, 1919","children":[],"tail":" which comprises this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
