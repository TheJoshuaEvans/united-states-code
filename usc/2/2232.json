{"tag":"section","attrib":{"id":"iddd09181d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2232"},"text":null,"children":[{"tag":"num","attrib":{"value":"2232"},"text":"§ 2232.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposits in the Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd09181e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2232/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gift Shop Account","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be deposited in the Gift Shop Account all monies received from sales and other services by the gift shop established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s2215"},"text":"section 2215 of this title","children":[],"tail":", together with any interest accrued on balances in the Account."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd0b881f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2232/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Miscellaneous Receipts Account","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There shall be deposited in the Miscellaneous Receipts Account each of the following (together with any interest accrued on balances in the Account):","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd0b8820-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2232/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any amounts deposited under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s2216/c"},"text":"section 2216(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd0b8821-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2232/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other receipts received from the operation of the Capitol Visitor Center.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd0b8822-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2232/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any amounts described under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s2273/d"},"text":"section 2273(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd0b8823-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/437/tIII/s302"},"text":"Pub. L. 110–437, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-20"},"text":"Oct. 20, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4989"},"text":"122 Stat. 4989","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
