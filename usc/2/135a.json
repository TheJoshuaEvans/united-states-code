{"tag":"section","attrib":{"id":"iddc8393cc-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s135a"},"text":null,"children":[{"tag":"num","attrib":{"value":"135a"},"text":"§ 135a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National library service for the blind and print disabled","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc8393cd-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s135a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accessible materials and reproducers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc8393ce-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s135a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Librarian of Congress is authorized to provide to eligible persons who are residents of the United States (including residents of the several States, insular possessions, and the District of Columbia) and to eligible persons who are United States citizens residing outside the United States the following items:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc8393cf-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s135a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Literary works published in raised characters, on sound-reproduction recordings, or in any other accessible format.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc8393d0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s135a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Musical scores, instructional texts, and other specialized materials used in furthering educational, vocational, and cultural opportunities in the field of music published in any accessible format.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc8393d1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s135a/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reproducers for such formats.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc8393d2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s135a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ownership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any item provided under paragraph (1) shall be provided on a loan basis and shall remain the property of the Library of Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc8393d3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s135a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lending preference","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the lending of items under subsection (a), the Librarian shall at all times give preference to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc8393d4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s135a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the needs of the blind and visually disabled; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc8393d5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s135a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the needs of eligible persons who have been honorably discharged from the Armed Forces of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc8393d6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s135a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Network","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Librarian of Congress may contract or otherwise arrange with such public or other nonprofit libraries, agencies, or organizations as the Librarian may determine appropriate to serve as local or regional centers for the circulation of items described in subsection (a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc8393d7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s135a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Librarian of Congress is authorized to provide items described in subparagraphs (A) and (B) of subsection (a)(1) to authorized entities located in a country that is a party to the Marrakesh Treaty, if any such items are delivered to authorized entities through online, not physical, means. The Librarian may contract or otherwise arrange with such authorized entities to deliver such items to eligible persons located in their countries in any accessible format and consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t17/s121A"},"text":"section 121A of title 17","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc8393d8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s135a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracting preference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the purchase and maintenance of items described in subsection (a), the Librarian of Congress, without regard to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s6101"},"text":"section 6101 of title 41","children":[],"tail":", shall give preference to nonprofit institutions or agencies whose activities are primarily concerned with the blind and with other physically disabled persons, in all cases where, considering all the circumstances and needs involved, the Librarian determines that the prices submitted are fair and reasonable."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc8393d9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s135a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Librarian of Congress shall prescribe regulations for services under this section, in consultation with eligible persons and authorized entities. Such regulations shall include procedures that shall be used by an individual to establish that the individual is an eligible person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc8393da-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s135a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc8393db-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s135a/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms “accessible format”, “authorized entity”, and “eligible person” have the meanings given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t17/s121"},"text":"section 121 of title 17","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc8393dc-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s135a/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Marrakesh Treaty” has the meaning given in section 121A of such title 17.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc8393dd-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s135a/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section such sums as may be necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc8393de-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1931-03-03/ch400/s1"},"text":"Mar. 3, 1931, ch. 400, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/1487"},"text":"46 Stat. 1487","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1933-03-04/ch279"},"text":"Mar. 4, 1933, ch. 279","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/47/1570"},"text":"47 Stat. 1570","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1935-06-14/ch242/s1"},"text":"June 14, 1935, ch. 242, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/374"},"text":"49 Stat. 374","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1937-04-23/ch125/s1"},"text":"Apr. 23, 1937, ch. 125, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/50/72"},"text":"50 Stat. 72","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1939-06-07/ch191"},"text":"June 7, 1939, ch. 191","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/812"},"text":"53 Stat. 812","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1940-06-06/ch255"},"text":"June 6, 1940, ch. 255","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/245"},"text":"54 Stat. 245","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1942-10-01/ch575/s1"},"text":"Oct. 1, 1942, ch. 575, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/56/764"},"text":"56 Stat. 764","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1944-06-13/ch246/s1"},"text":"June 13, 1944, ch. 246, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/58/276"},"text":"58 Stat. 276","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1946-08-08/ch868/s1"},"text":"Aug. 8, 1946, ch. 868, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/908"},"text":"60 Stat. 908","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1952-07-03/ch566"},"text":"July 3, 1952, ch. 566","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/326"},"text":"66 Stat. 326","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/308/s1"},"text":"Pub. L. 85–308, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1957-09-07"},"text":"Sept. 7, 1957","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/71/630"},"text":"71 Stat. 630","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/522/s1"},"text":"Pub. L. 89–522, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-07-30"},"text":"July 30, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/330"},"text":"80 Stat. 330","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/219/s1"},"text":"Pub. L. 114–219, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-07-29"},"text":"July 29, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/845"},"text":"130 Stat. 845","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/94/dP/tXIV/s1403/a"},"text":"Pub. L. 116–94, div. P, title XIV, § 1403(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3206"},"text":"133 Stat. 3206","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc8393df-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc8393e0-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc8393e1-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94"},"text":"Pub. L. 116–94","children":[],"tail":" amended section generally. Prior to amendment, text read as follows: “There is authorized to be appropriated annually to the Library of Congress, in addition to appropriations otherwise made to said Library, such sums for expenditure under the direction of the Librarian of Congress as may be necessary to provide books published either in raised characters, on sound-reproduction recordings or in any other form, and for purchase, maintenance, and replacement of reproducers for any such forms, for the use of the blind and for other physically handicapped residents of the United States, including the several States, Territories, insular possessions, and the District of Columbia, all of which books, recordings, and reproducers will remain the property of the Library of Congress but will be loaned to blind and to other physically handicapped readers certified by competent authority as unable to read normal printed material as a result of physical limitations, under regulations prescribed by the Librarian of Congress for this service. In the purchase of books in either raised characters or in sound-reproduction recordings the Librarian of Congress, without reference to the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s6101"},"text":"section 6101 of title 41","children":[],"tail":", shall give preference to nonprofit-making institutions or agencies whose activities are primarily concerned with the blind and with other physically handicapped persons, in all cases where the prices or bids submitted by such institutions or agencies are, by said Librarian, under all the circumstances and needs involved, determined to be fair and reasonable.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/219"},"text":"Pub. L. 114–219","children":[],"tail":" substituted “and for purchase, maintenance, and replacement of reproducers for any such forms” for “and for purchase, maintenance, and replacement of reproducers for such sound-reproduction recordings” in first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/522"},"text":"Pub. L. 89–522","children":[],"tail":" amended section generally, extending availability of books and materials under this section by authorizing their loan to other physically handicapped residents, in addition to blind persons, certified by competent authority as unable to read normal printed material as a result of physical limitations."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1957—","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/308"},"text":"Pub. L. 85–308","children":[],"tail":" authorized annual appropriation of necessary sums in lieu of provisions which limited annual appropriation to $1,125,000, and struck out limitation of $200,000 on amount of appropriated funds to be expended annually for books in raised characters."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1952—Act ","children":[{"tag":"date","attrib":{"date":"1952-07-03"},"text":"July 3, 1952","children":[],"tail":", included children within its provisions as well as adults."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1946—Act ","children":[{"tag":"date","attrib":{"date":"1946-08-08"},"text":"Aug. 8, 1946","children":[],"tail":", increased annual appropriation from $500,000 to $1,125,000."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1944—Act ","children":[{"tag":"date","attrib":{"date":"1944-06-13"},"text":"June 13, 1944","children":[],"tail":", increased annual appropriation from $370,000 to $500,000, the amount allocated to sound-reproduction records from $250,000 to $400,000, and struck out provision allocating $20,000 to maintenance and replacement of Government-owned reproducers."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1942—Act ","children":[{"tag":"date","attrib":{"date":"1942-10-01"},"text":"Oct. 1, 1942","children":[],"tail":", substituted “$370,000” for “$350,000”, and inserted clause at end of first sentence relating to expenditure of not exceeding $20,000 for maintenance and replacement of reproducers for sound-reproduction records."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1940—Act ","children":[{"tag":"date","attrib":{"date":"1940-06-06"},"text":"June 6, 1940","children":[],"tail":", substituted “$350,000” for “$275,000” and “$250,000” for “$175,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1939—Act ","children":[{"tag":"date","attrib":{"date":"1939-06-07"},"text":"June 7, 1939","children":[],"tail":", inserted last sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1937—Act ","children":[{"tag":"date","attrib":{"date":"1937-04-23"},"text":"Apr. 23, 1937","children":[],"tail":", substituted “$275,000” for “$175,000” in two places and “$175,000” for “$75,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1935—Act ","children":[{"tag":"date","attrib":{"date":"1935-06-14"},"text":"June 14, 1935","children":[],"tail":", substituted “$175,000” for “$100,000” and inserted provision that $100,000 of the $175,000 annual appropriation be expended for books in raised characters and the balance for sound-reproduction records."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1933—Act ","children":[{"tag":"date","attrib":{"date":"1933-03-04"},"text":"Mar. 4, 1933","children":[],"tail":", inserted “published either in raised characters, on sound-reproduction records, or in any other form”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc8393e2-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddc8393e3-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1957 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/85/308/s2"},"text":"Pub. L. 85–308, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1957-09-07"},"text":"Sept. 7, 1957","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/71/630"},"text":"71 Stat. 630","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/85/308/s2"},"text":"“This Act [amending this section] shall be applicable with respect to the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1958-06-30"},"text":"June 30, 1958","children":[],"tail":", and for each fiscal year thereafter.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddc8393e4-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1946 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-08/ch868/s2"},"text":"Act Aug. 8, 1946, ch. 868, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/908"},"text":"60 Stat. 908","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/act/1946-08-08/ch868/s2"},"text":"“This Act [amending this section] shall be applicable with respect to the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1947-06-30"},"text":"June 30, 1947","children":[],"tail":", and for each fiscal year thereafter.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddc8393e5-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1944 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1944-06-13/ch246/s2"},"text":"Act June 13, 1944, ch. 246, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/58/276"},"text":"58 Stat. 276","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/act/1944-06-13/ch246/s2"},"text":"“This Act [amending this section] shall be applicable with respect to the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1945-06-30"},"text":"June 30, 1945","children":[],"tail":", and for each fiscal year thereafter.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddc8393e6-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1942 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1942-10-01/ch575/s2"},"text":"Act Oct. 1, 1942, ch. 575, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/56/764"},"text":"56 Stat. 764","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/act/1942-10-01/ch575/s2"},"text":"“This Act [amending this section] shall be applicable with respect to the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1943-06-30"},"text":"June 30, 1943","children":[],"tail":", and for each fiscal year thereafter.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddc8393e7-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1937 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1937-04-23/ch125/s2"},"text":"Act Apr. 23, 1937, ch. 125, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/50/72"},"text":"50 Stat. 72","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/act/1937-04-23/ch125/s2"},"text":"“This Act [amending this section] shall be applicable with respect to the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1938-06-30"},"text":"June 30, 1938","children":[],"tail":", and for each fiscal year thereafter.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
