{"tag":"section","attrib":{"id":"iddd259fe7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4721"},"text":null,"children":[{"tag":"num","attrib":{"value":"4721"},"text":"§ 4721.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Referral of ethics violations by Senate Ethics Committee to Government Accountability Office for investigation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If the Committee on Ethics of the Senate determines that there is a reasonable basis to believe that a Member, officer, or employee of the Senate may have committed an ethics violation, the committee may request the Office of Special Investigations of the Government Accountability Office to conduct factfinding and an investigation into the matter. The Office of Special Investigations shall promptly investigate the matter as directed by the committee.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd259fe8-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/194/tV/s501"},"text":"Pub. L. 101–194, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-30"},"text":"Nov. 30, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1753"},"text":"103 Stat. 1753","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/271/s8/b"},"text":"Pub. L. 108–271, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-07"},"text":"July 7, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/814"},"text":"118 Stat. 814","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd259fe9-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd259fea-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd259feb-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s72a–1g"},"text":"section 72a–1g of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd259fec-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271"},"text":"Pub. L. 108–271","children":[],"tail":" substituted “Government Accountability Office” for “General Accounting Office” in section catchline and text."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
