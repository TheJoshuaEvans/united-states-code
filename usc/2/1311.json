{"tag":"section","attrib":{"id":"iddcd22960-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1311"},"text":null,"children":[{"tag":"num","attrib":{"value":"1311"},"text":"§ 1311.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights and protections under title VII of Civil Rights Act of 1964, Age Discrimination in Employment Act of 1967, Rehabilitation Act of 1973, and title I of Americans with Disabilities Act of 1990","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcd22961-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1311/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discriminatory practices prohibited","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"All personnel actions affecting covered employees shall be made free from any discrimination based on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcd22962-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1311/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" race, color, religion, sex, or national origin, within the meaning of section 703 of the Civil Rights Act of 1964 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000e–2"},"text":"42 U.S.C. 2000e–2","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd22963-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1311/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" age, within the meaning of section 15 of the Age Discrimination in Employment Act of 1967 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s633a"},"text":"29 U.S.C. 633a","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd22964-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1311/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disability, within the meaning of section 501 of the Rehabilitation Act of 1973 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s791"},"text":"29 U.S.C. 791","children":[],"tail":") and sections 102 through 104 of the Americans with Disabilities Act of 1990 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12112–121"},"text":"42 U.S.C. 12112–121","children":[],"tail":"14)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd22965-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1311/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remedy","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcd22966-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1311/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil rights","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The remedy for a violation of subsection (a)(1) shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcd22967-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1311/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such remedy as would be appropriate if awarded under section 706(g) of the Civil Rights Act of 1964 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000e–5/g"},"text":"42 U.S.C. 2000e–5(g)","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcd22968-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1311/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such compensatory damages as would be appropriate if awarded under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1981"},"text":"section 1981 of title 42","children":[],"tail":", or as would be appropriate if awarded under sections 1981a(a)(1), 1981a(b)(2), and, irrespective of the size of the employing office, 1981a(b)(3)(D) of title 42."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd22969-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1311/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Age discrimination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The remedy for a violation of subsection (a)(2) shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcd2296a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1311/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such remedy as would be appropriate if awarded under section 15(c) of the Age Discrimination in Employment Act of 1967 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s633a/c"},"text":"29 U.S.C. 633a(c)","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcd2296b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1311/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such liquidated damages as would be appropriate if awarded under section 7(b) of such Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s626/b"},"text":"29 U.S.C. 626(b)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"In addition, the waiver provisions of section 7(f) of such Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s626/f"},"text":"29 U.S.C. 626(f)","children":[],"tail":") shall apply to covered employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd2296c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1311/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disabilities discrimination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The remedy for a violation of subsection (a)(3) shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcd2296d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1311/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such remedy as would be appropriate if awarded under section 505(a)(1) of the Rehabilitation Act of 1973 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s794a/a/1"},"text":"29 U.S.C. 794a(a)(1)","children":[],"tail":") or section 107(a) of the Americans with Disabilities Act of 1990 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12117/a"},"text":"42 U.S.C. 12117(a)","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcd2296e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1311/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such compensatory damages as would be appropriate if awarded under sections 1981a(a)(2), 1981a(a)(3), 1981a(b)(2), and, irrespective of the size of the employing office, 1981a(b)(3)(D) of title 42.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd2296f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1311/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd22970-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1311/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application to unpaid staff","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcd22971-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1311/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsections (a) and (b) shall apply with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcd22972-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1311/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any staff member of an employing office who carries out official duties of the employing office but who is not paid by the employing office for carrying out such duties (referred to in this subsection as an “unpaid staff member”), including an intern, an individual detailed to an employing office, and an individual participating in a fellowship program, in the same manner and to the same extent as such subsections apply with respect to a covered employee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcd22973-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1311/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a former unpaid staff member, if the act that may be a violation of subsection (a) occurred during the service of the former unpaid staffer for the employing office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd22974-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1311/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in paragraph (1) may be construed to extend liability for a violation of subsection (a) to an employing office on the basis of an action taken by any person who is not under the supervision or control of the employing office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd22975-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1311/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intern defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, the term “intern” means an individual who performs service for an employing office which is uncompensated by the United States to earn credit awarded by an educational institution or to learn a trade or occupation, and includes any individual participating in a page program operated by any House of Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd22976-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1311/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall take effect 1 year after ","children":[{"tag":"date","attrib":{"date":"1995-01-23"},"text":"January 23, 1995","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcd22977-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/1/tII/s201"},"text":"Pub. L. 104–1, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-01-23"},"text":"Jan. 23, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/7"},"text":"109 Stat. 7","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/397/tIII/s302/a"},"text":"Pub. L. 115–397, title III, § 302(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5321"},"text":"132 Stat. 5321","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcd22978-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcd22979-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddcd2297a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/1/s201"},"text":"section 201 of Pub. L. 104–1","children":[],"tail":". Subsec. (c) of "},{"tag":"ref","attrib":{"href":"/us/pl/104/1/s201"},"text":"section 201 of Pub. L. 104–1","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s633a"},"text":"section 633a of Title 29","children":[],"tail":", Labor, and sections 2000e–16 and 12209 of Title 42, The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcd2297b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/397"},"text":"Pub. L. 115–397","children":[],"tail":" added subsec. (d) and redesignated former subsec. (d) as (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcd2297c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcd2297d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/397"},"text":"Pub. L. 115–397","children":[],"tail":" effective upon expiration of the 180-day period beginning on "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", with provisions for effect on pending proceedings, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/397/s401"},"text":"section 401 of Pub. L. 115–397","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddcd2297e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Coverage of House of Representatives and the Agencies of the Legislative Branch","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/166/tI/s117"},"text":"Pub. L. 102–166, title I, § 117","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-11-21"},"text":"Nov. 21, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1080"},"text":"105 Stat. 1080","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/108/271/s8/b"},"text":"Pub. L. 108–271, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-07"},"text":"July 7, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/814"},"text":"118 Stat. 814","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/b"},"text":"Pub. L. 113–235, div. H, title I, § 1301(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/235/dH/tI/s1301/b"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coverage of the House of Representatives","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any provision of title VII of the Civil Rights Act of 1964 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000e"},"text":"42 U.S.C. 2000e","children":[],"tail":" et seq.) or of other law, the purposes of such title shall, subject to paragraph (2), apply in their entirety to the House of Representatives."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Employment in the house","children":[],"tail":".—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The rights and protections under title VII of the Civil Rights Act of 1964 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000e"},"text":"42 U.S.C. 2000e","children":[],"tail":" et seq.) shall, subject to subparagraph (B), apply with respect to any employee in an employment position in the House of Representatives and any employing authority of the House of Representatives."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administration","children":[],"tail":".—"}],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the administration of this paragraph, the remedies and procedures made applicable pursuant to the resolution described in clause (ii) shall apply exclusively.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Resolution","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The resolution referred to in clause (i) is the Fair Employment Practices Resolution (House Resolution 558 of the One Hundredth Congress, as agreed to ","children":[{"tag":"date","attrib":{"date":"1988-10-04"},"text":"October 4, 1988","children":[],"tail":"), as incorporated into the Rules of the House of Representatives of the One Hundred Second Congress as Rule LI, or any other provision that continues in effect the provisions of such resolution."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exercise of rulemaking power","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The provisions of subparagraph (B) are enacted by the House of Representatives as an exercise of the rulemaking power of the House of Representatives, with full recognition of the right of the House to change its rules, in the same manner, and to the same extent as in the case of any other rule of the House.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Instrumentalities of Congress","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The rights and protections under this title [see Tables for classification] and title VII of the Civil Rights Act of 1964 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000e"},"text":"42 U.S.C. 2000e","children":[],"tail":" et seq.) shall, subject to paragraph (2), apply with respect to the conduct of each instrumentality of the Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment of remedies and procedures by instrumentalities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The chief official of each instrumentality of the Congress shall establish remedies and procedures to be utilized with respect to the rights and protections provided pursuant to paragraph (1). Such remedies and procedures shall apply exclusively, except for the employees who are defined as Senate employees, in [former] section 301(c)(1) [former ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000e–16a/c/1"},"text":"42 U.S.C. 2000e–16a(c)(1)","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report to congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The chief official of each instrumentality of the Congress shall, after establishing remedies and procedures for purposes of paragraph (2), submit to the Congress a report describing the remedies and procedures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition of instrumentalities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this section, instrumentalities of the Congress include the following: the Architect of the Capitol, the Congressional Budget Office, the Government Accountability Office, the Government Publishing Office, the Office of Technology Assessment, and the United States Botanic Garden.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall alter the enforcement procedures for individuals protected under section 717 of title VII for [of] the Civil Rights Act of 1964 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000e–16"},"text":"42 U.S.C. 2000e–16","children":[],"tail":").”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[Section effective ","children":[{"tag":"date","attrib":{"date":"1991-11-21"},"text":"Nov. 21, 1991","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/102/166/s402/a"},"text":"section 402(a) of Pub. L. 102–166","children":[],"tail":", set out as an Effective Date of 1991 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1981"},"text":"section 1981 of Title 42","children":[],"tail":", The Public Health and Welfare.]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
