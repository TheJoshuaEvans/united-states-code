{"tag":"section","attrib":{"id":"iddd2a81d1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5307"},"text":null,"children":[{"tag":"num","attrib":{"value":"5307"},"text":"§ 5307.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification of salary and mileage accounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Salary and mileage accounts of Representatives and Delegates shall be certified by the Speaker of the House of Representatives; and such certificates shall be conclusive upon all the departments and officers of the Government.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd2a81d2-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(R.S. §§ 47, 48; ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447/dG/tI/s11"},"text":"Pub. L. 108–447, div. G, title I, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3171"},"text":"118 Stat. 3171","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd2a81d3-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd2a81d4-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd2a81d5-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s48"},"text":"section 48 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 47 derived from acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1866-07-28/ch296/s17"},"text":"July 28, 1866, ch. 296, § 17","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/14/323"},"text":"14 Stat. 323","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/act/1818-01-22/ch5/s3"},"text":"Jan. 22, 1818, ch. 5, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/3/404"},"text":"3 Stat. 404","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 48 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1850-09-30/ch90/s1"},"text":"act Sept. 30, 1850, ch. 90, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/9/523"},"text":"9 Stat. 523","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 47 constitutes first clause and R.S. § 48 constitutes remainder.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “mileage accounts” substituted for words “accounts for traveling expenses in going to and returning from Congress” based on text of section 17 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1866-07-28/ch296"},"text":"act July 28, 1866, ch. 296","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/14/323"},"text":"14 Stat. 323","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd2a81d6-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447"},"text":"Pub. L. 108–447","children":[],"tail":" substituted “of Representatives and Delegates shall be certified” for “of Senators shall be certified by the President of the Senate, and those of Representatives and Delegates”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
