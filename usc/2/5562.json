{"tag":"section","attrib":{"id":"iddd2f3d3a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5562"},"text":null,"children":[{"tag":"num","attrib":{"value":"5562"},"text":"§ 5562.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preservation of reports, statements, or documents filed with Clerk of House","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd2f3d3b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5562/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the Clerk of the House of Representatives is required under any law, rule, or regulation to make available for public inspection a report, statement, or other document filed with the Office of the Clerk, the Clerk shall preserve the report, statement, or document—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2f3d3c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5562/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a period of 6 years from the date on which the document is filed; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2f3d3d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5562/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the law, rule, or regulation so provides, the period required under such law, rule, or regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2f3d3e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5562/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsection (a) shall apply with respect to reports, statements, and documents filed before, on, or after ","children":[{"tag":"date","attrib":{"date":"2004-12-08"},"text":"December 8, 2004","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd2f3d3f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447/dG/tI/s106"},"text":"Pub. L. 108–447, div. G, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3176"},"text":"118 Stat. 3176","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd2f3d40-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd2f3d41-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd2f3d42-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s104c"},"text":"section 104c of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Legislative Branch Appropriations Act, 2005, which is div. G of the Consolidated Appropriations Act, 2005.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
