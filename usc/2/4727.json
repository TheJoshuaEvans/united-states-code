{"tag":"section","attrib":{"id":"iddd25a03c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4727"},"text":null,"children":[{"tag":"num","attrib":{"value":"4727"},"text":"§ 4727.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Senate privately paid travel public website","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd25a03d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4727/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel disclosure","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2008-01-01"},"text":"January 1, 2008","children":[],"tail":", the Secretary of the Senate shall establish a publicly available website without fee or without access charge, that contains information on travel that is subject to disclosure under paragraph 2 of rule XXXV of the Standing Rules of the Senate, that includes, with respect to travel occurring on or after "},{"tag":"date","attrib":{"date":"2008-01-01"},"text":"January 1, 2008","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd25a03e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4727/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a search engine;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd25a03f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4727/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uniform categorization by Member, dates of travel, and any other common categories associated with congressional travel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd25a040-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4727/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" forms filed in the Senate relating to officially related travel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd25a041-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4727/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retention","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Senate shall maintain the information posted on the public Internet site of the Office of the Secretary under this section for a period not longer than 4 years after receiving the information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd25a042-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4727/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension of authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary of the Senate is unable to meet the deadline established under subsection (a), the Committee on Rules and Administration of the Senate may grant an extension of the Secretary of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd25a043-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4727/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002108"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002108"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. No subsec. (d) has been enacted."}],"tail":" Authorization of appropriations"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as are necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd25a044-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/81/tV/s546"},"text":"Pub. L. 110–81, title V, § 546","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-09-14"},"text":"Sept. 14, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/772"},"text":"121 Stat. 772","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd25a045-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd25a046-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd25a047-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s104g"},"text":"section 104g of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
