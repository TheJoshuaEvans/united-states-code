{"tag":"section","attrib":{"id":"iddd3d9584-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6595"},"text":null,"children":[{"tag":"num","attrib":{"value":"6595"},"text":"§ 6595.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation of Administrative Assistant to Sergeant at Arms and Doorkeeper of Senate","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Effective ","children":[{"tag":"date","attrib":{"date":"1979-08-01"},"text":"August 1, 1979","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd3d9585-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6595/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the maximum annual rate of compensation of the Administrative Assistant to the Sergeant at Arms and Doorkeeper of the Senate shall be the same as the highest maximum annual rate of compensation that may be paid to an employee in the office of a Senator; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3d9586-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6595/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Omitted","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd3d9587-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/38/tI/s106/2"},"text":"Pub. L. 96–38, title I, § 106(2)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"1979-07-25"},"text":"July 25, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/112"},"text":"93 Stat. 112","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd3d9588-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd3d9589-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd3d958a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s61e–2"},"text":"section 61e–2 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section consists of pars. (2) and (3) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/38/s106"},"text":"section 106 of Pub. L. 96–38","children":[],"tail":", Supplemental Appropriations Act, 1979. The paragraph numbers (2) and (3) in the original have been changed to (1) and (2) for purposes of codification."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2), relating to maximum annual rate of compensation of Executive Assistant to Sergeant at Arms and Doorkeeper of Senate, was omitted from the Code in view of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s6597"},"text":"section 6597 of this title","children":[],"tail":" which abolished all statutory positions in the Office of Sergeant at Arms and Doorkeeper of Senate, with specified exceptions, effective "},{"tag":"date","attrib":{"date":"1981-10-01"},"text":"Oct. 1, 1981","children":[],"tail":", and authorized Sergeant at Arms and Doorkeeper of Senate to appoint and fix compensation of such employees as appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
