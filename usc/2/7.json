{"tag":"section","attrib":{"id":"iddc6e102c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"§ 7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time of election","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Tuesday next after the 1st Monday in November, in every even numbered year, is established as the day for the election, in each of the States and Territories of the United States, of Representatives and Delegates to the Congress commencing on the 3d day of January next thereafter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc6e102d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(R.S. § 25; ","children":[{"tag":"ref","attrib":{"href":"/us/act/1875-03-03/ch130/s6"},"text":"Mar. 3, 1875, ch. 130, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/18/400"},"text":"18 Stat. 400","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1934-06-05/ch390/s2"},"text":"June 5, 1934, ch. 390, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/879"},"text":"48 Stat. 879","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc6e102e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc6e102f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddc6e1030-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 25 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1872-02-02/ch11/s3"},"text":"act Feb. 2, 1872, ch. 11, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/17/28"},"text":"17 Stat. 28","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The second sentence of this section, which was based on section 6 of the act ","children":[{"tag":"date","attrib":{"date":"1875-03-03"},"text":"Mar. 3, 1875","children":[],"tail":" and made this section inapplicable to any State that had not yet changed its day of election and whose constitution required an amendment to change the day of election of its State officers, was omitted."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc6e1031-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1934—Act ","children":[{"tag":"date","attrib":{"date":"1934-06-05"},"text":"June 5, 1934","children":[],"tail":", substituted “3d day of January” for “fourth day of March”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddc6e1032-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Constitutional Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The first section of Amendment XX to the Constitution provides: “The terms of Senators and Representatives [shall end] at noon on the 3d day of January, of the years in which such terms would have ended if this article had not been ratified; and the terms of their successors shall then begin.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Time for election of Representatives, see Const. Art. I, § 4, cl. 1.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
