{"tag":"section","attrib":{"id":"iddcd954b0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1387"},"text":null,"children":[{"tag":"num","attrib":{"value":"1387"},"text":"§ 1387.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Semiannual report of disbursements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcd954b1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1387/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 60 days after the last day of each semiannual period of a fiscal year, the Executive Director of the Office of Compliance ","children":[{"tag":"ref","attrib":{"idref":"fn002060"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002060"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Change of Name note below."}],"tail":" shall submit to the Committee on House Administration of the House of Representatives, the Committee on Rules and Administration of the Senate, and the Committees on Appropriations of the House of Representatives and Senate, with respect to that period, a detailed, itemized report of the disbursements for the operations of the Office of Compliance."},{"tag":"ref","attrib":{"idref":"fn002060"},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd954b2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1387/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcd954b3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1387/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report required by subsection (a) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcd954b4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1387/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identification of each person who receives a payment from the Office of Compliance,","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" except that in the case of an individual, the identification shall be provided in a manner that does not identify the individual by name;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcd954b5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1387/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quantity and price of any item furnished to the Office of Compliance; ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcd954b6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1387/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of any service rendered to the Office of Compliance,","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" together with a statement of the time required for the service, and the name, title, and amount paid to each person who renders the service;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcd954b7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1387/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of all amounts appropriated to, or received or expended by, the Office of Compliance ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" and any unexpended balances of such amounts; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcd954b8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1387/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such additional information as may be required by regulation of the Committee on House Administration of the House of Representatives, the Committee on Rules and Administration of the Senate, or the Committees on Appropriations of the House of Representatives or Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd954b9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1387/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for confidential information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Executive Director of the Office of Compliance ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" may exclude from any report required by subsection (a) any information the disclosure of which would violate confidentiality policies of the Office of Compliance."},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd954ba-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1387/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply with respect to the semiannual periods of October 1 through March 31 and April 1 through September 30 of each fiscal year, beginning with fiscal year 2014.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcd954bb-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/76/dI/tI/s1102"},"text":"Pub. L. 113–76, div. I, title I, § 1102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-01-17"},"text":"Jan. 17, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/425"},"text":"128 Stat. 425","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcd954bc-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcd954bd-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddcd954be-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Legislative Branch Appropriations Act, 2014, and also as part of the Consolidated Appropriations Act, 2014, and not as part of the Congressional Accountability Act of 1995 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcd954bf-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"iddcd954c0-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Office of Compliance changed, as of ","children":[{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", and considered to refer and apply, to the Office of Congressional Workplace Rights, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/397/s308/d"},"text":"section 308(d) of Pub. L. 115–397","children":[],"tail":", set out as an Effective Date of 2018 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1381"},"text":"section 1381 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
