2"},"text":"119 Stat. 272","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/13/dA/tIII/s3401/c"},"text":"“The amendments made by this section [amending this section] shall take effect as if included in the enactment of the Legislative Branch Appropriations Act, 2005 [","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447/dG"},"text":"Pub. L. 108–447, div. G","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd2f3d0a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Membership in House of Representatives Exercise Facility for Active Duty Armed Forces Members Assigned to Congressional Liaison Office","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/248/s1"},"text":"Pub. L. 111–248, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-09-30"},"text":"Sept. 30, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2625"},"text":"124 Stat. 2625","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/248/s1"},"text":"“Any active duty member of the Armed Forces who is assigned to a congressional liaison office of the Armed Forces at the House of Representatives may obtain membership in the exercise facility established for employees of the House of Representatives (as described in section 103(a) of the Legislative Branch Appropriations Act, 2005 [","children":[{"tag":"ref","attrib":{"href":"/us/stat/118/3174"},"text":"118 Stat. 3174","children":[],"tail":"]) in the same manner as an employee of the House of Representatives, in accordance with such regulations as the Committee on House Administration may promulgate.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
