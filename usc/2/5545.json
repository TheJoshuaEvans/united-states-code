{"tag":"section","attrib":{"id":"iddd2f3cea-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5545"},"text":null,"children":[{"tag":"num","attrib":{"value":"5545"},"text":"§ 5545.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" House Services Revolving Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd2f3ceb-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5545/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of House Services Revolving Fund","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is hereby established in the Treasury of the United States a revolving fund for the House of Representatives to be known as the “House Services Revolving Fund” (hereafter in this section referred to as the “Revolving Fund”), consisting of funds deposited by the Chief Administrative Officer of the House of Representatives from all amounts received by the House of Representatives with respect to the following activities:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2f3cec-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5545/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The operation of the House Barber Shop.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2f3ced-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5545/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The operation of the House Beauty Shop.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2f3cee-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5545/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The operation of the House Restaurant System (including vending operations).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2f3cef-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5545/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provision of mail services to entities which are not part of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2f3cf0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5545/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The payment of fees for the use of the exercise facility described in section 103(a).","children":[{"tag":"ref","attrib":{"idref":"fn002115"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002115"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2f3cf1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5545/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The collection of promotional rebates and incentives on credit card purchases, balances, and payments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2f3cf2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5545/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The collection of a service fee from vendors of the Master Web Services Agreement or the Technology Services Contract for failure to abide by and maintain House of Representatives security policies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2f3cf3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5545/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The operation of the House Dry Cleaning and Laundry Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2f3cf4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5545/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other activities related to the operation of services offered by the House of Representatives, as approved by the Committee on Appropriations of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2f3cf5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5545/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of amounts in Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts in the Revolving Funds ","children":[{"tag":"ref","attrib":{"idref":"fn002116"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002116"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “Fund”."}],"tail":" shall be used for any purpose designated by the Chief Administrative Officer, including purposes relating to energy and water conservation and environmental activities carried out in buildings, facilities, and grounds under the Chief Administrative Officer’s jurisdiction, upon notification provided by the Chief Administrative Officer to the Committee on Appropriations of the House of Representatives."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2f3cf6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5545/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Revolving Fund shall be treated as a category of allowances and expenses for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s5507/a"},"text":"section 5507(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2f3cf7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5545/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination and transfer of existing funds and accounts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2f3cf8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5545/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each fund and account specified in paragraph (2) is hereby terminated, and the balance of each such fund and account is hereby transferred to the Revolving Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2f3cf9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5545/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funds and accounts specified","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The funds and accounts referred to in paragraph (1) are as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd2f3cfa-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5545/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The revolving fund for the House Barber Shop, established by the paragraph under the heading “HOUSE BARBER SHOPS REVOLVING FUND” in the matter relating to the House of Representatives in chapter III of title I of the Supplemental Appropriations Act, 1975 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/554"},"text":"Public Law 93–554","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/88/1776"},"text":"88 Stat. 1776","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd2f3cfb-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5545/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The revolving funds for the House Beauty Shop, established by the matter under the heading “","children":[{"tag":"inline","attrib":{},"text":"house beauty shop","children":[],"tail":"” in the matter relating to administrative provisions for the House of Representatives in the Legislative Branch Appropriations Act, 1970 ("},{"tag":"ref","attrib":{"href":"/us/pl/91/145"},"text":"Public Law 91–145","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/83/347"},"text":"83 Stat. 347","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd2f3cfc-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5545/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The special deposit account established for the House of Representatives Restaurant by section 208 of the First Supplemental Civil Functions Appropriation Act, 1941, or any successor fund or account established for the receipt of revenues of the House Restaurant System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2f3cfd-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5545/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall take effect ","children":[{"tag":"date","attrib":{"date":"2004-10-01"},"text":"October 1, 2004","children":[],"tail":", and shall apply with respect to fiscal year 2005 and each succeeding fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd2f3cfe-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447/dG/tI/s105"},"text":"Pub. L. 108–447, div. G, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3175"},"text":"118 Stat. 3175","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/13/dA/tIII/s3401/b"},"text":"Pub. L. 109–13, div. A, title III, § 3401(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-05-11"},"text":"May 11, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/272"},"text":"119 Stat. 272","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/161/dH/tI/s104/a"},"text":"Pub. L. 110–161, div. H, title I, § 104(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2225"},"text":"121 Stat. 2225","children":[],"tail":"; "},{"tag":"ref