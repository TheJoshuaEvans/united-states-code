{"tag":"section","attrib":{"id":"iddd2f3d49-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5571"},"text":null,"children":[{"tag":"num","attrib":{"value":"5571"},"text":"§ 5571.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of General Counsel of House; administrative provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd2f3d4a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5571/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance with admission requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The General Counsel of the House of Representatives and any other counsel in the Office of the General Counsel of the House of Representatives, including any counsel specially retained by the Office of General Counsel, shall be entitled, for the purpose of performing the counsel’s functions, to enter an appearance in any proceeding before any court of the United States or of any State or political subdivision thereof without compliance with any requirements for admission to practice before such court, except that the authorization conferred by this subsection shall not apply with respect to the admission of any such person to practice before the United States Supreme Court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2f3d4b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5571/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification by Attorney General","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall notify the General Counsel of the House of Representatives as required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s530D"},"text":"section 530D of title 28","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2f3d4c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5571/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General Counsel definition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “General Counsel of the House of Representatives” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2f3d4d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5571/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the head of the Office of General Counsel established and operating under clause 8 of rule II of the Rules of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2f3d4e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5571/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the head of any successor office to the Office of General Counsel which is established after ","children":[{"tag":"date","attrib":{"date":"1999-09-29"},"text":"September 29, 1999","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2f3d4f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5571/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other person authorized and directed in accordance with the Rules of the House of Representatives to provide legal assistance and representation to the House in connection with the matters described in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2f3d50-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5571/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of this section shall become effective beginning with ","children":[{"tag":"date","attrib":{"date":"1999-09-29"},"text":"September 29, 1999","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd2f3d51-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/57/tI/s101"},"text":"Pub. L. 106–57, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-09-29"},"text":"Sept. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/414"},"text":"113 Stat. 414","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dA/tII/s202/b/5"},"text":"Pub. L. 107–273, div. A, title II, § 202(b)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1775"},"text":"116 Stat. 1775","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/7/dH/tI/s110/a"},"text":"Pub. L. 108–7, div. H, title I, § 110(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/355"},"text":"117 Stat. 355","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd2f3d52-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd2f3d53-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd2f3d54-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s130f"},"text":"section 130f of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Congressional Operations Appropriations Act, 2000, which is title I of the Legislative Branch Appropriations Act, 2000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd2f3d55-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7"},"text":"Pub. L. 108–7","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/273"},"text":"Pub. L. 107–273","children":[],"tail":". See 2002 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273"},"text":"Pub. L. 107–273","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/108/7"},"text":"Pub. L. 108–7","children":[],"tail":", substituted “as required by "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s530D"},"text":"section 530D of title 28","children":[],"tail":"” for “with respect to any proceeding in which the United States is a party of any determination by the Attorney General or Solicitor General not to appeal any court decision affecting the constitutionality of an Act or joint resolution of Congress within such time as will enable the House to direct the General Counsel to intervene as a party in such proceeding pursuant to applicable rules of the House of Representatives”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd2f3d56-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd2f3d57-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2003 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7/dH/tI/s110/c"},"text":"Pub. L. 108–7, div. H, title I, § 110(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/355"},"text":"117 Stat. 355","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/7/dH/tI/s110/c"},"text":"“The amendments made by this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s288k"},"text":"section 288k of this title","children":[],"tail":"] shall take effect as if included in the enactment of the 21st Century Department of Justice Appropriations Authorization Act ["},{"tag":"ref","attrib":{"href":"/us/pl/107/273"},"text":"Pub. L. 107–273","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
