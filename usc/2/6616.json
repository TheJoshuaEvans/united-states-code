{"tag":"section","attrib":{"id":"iddd3fdec6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6616"},"text":null,"children":[{"tag":"num","attrib":{"value":"6616"},"text":"§ 6616.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support services for Senate during emergency; memorandum of understanding with an executive agency","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd3fdec7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6616/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd3fdec8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6616/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to paragraph (3), the Sergeant at Arms of the Senate and the head of an executive agency (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s105"},"text":"section 105 of title 5","children":[],"tail":") may enter into a memorandum of understanding under which the agency may provide facilities, equipment, supplies, personnel, and other support services for the use of the Senate during an emergency situation;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3fdec9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6616/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Sergeant at Arms of the Senate and the head of the agency may take any action necessary to carry out the terms of the memorandum of understanding; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3fdeca-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6616/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Sergeant at Arms of the Senate may enter into a memorandum of understanding described in paragraph (1) consistent with the Senate Procurement Regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3fdecb-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6616/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Obligations and expenditures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Sergeant at Arms of the Senate may incur obligations and make expenditures for meals, refreshments, and other support and maintenance for Members, officers, and employees of the Senate when such obligations and expenditures are necessary to respond to emergencies involving the safety of human life or the protection of property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3fdecc-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6616/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply with respect to fiscal year 2002 and each succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd3fdecd-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/117/dB/s902"},"text":"Pub. L. 107–117, div. B, § 902","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-10"},"text":"Jan. 10, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2316"},"text":"115 Stat. 2316","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/94/dP/tXV/s1502"},"text":"Pub. L. 116–94, div. P, title XV, § 1502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3209"},"text":"133 Stat. 3209","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd3fdece-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd3fdecf-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd3fded0-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s130g"},"text":"section 130g of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Emergency Supplemental Act, 2002, which is div. B of the Department of Defense and Emergency Supplemental Appropriations for Recovery from and Response to Terrorist Attacks on the United States Act, 2002.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd3fded1-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s1502/1/A/i"},"text":"Pub. L. 116–94, § 1502(1)(A)(i)","children":[],"tail":", substituted “paragraph (3)” for “subsection (b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s1502/1/A/ii"},"text":"Pub. L. 116–94, § 1502(1)(A)(ii)","children":[],"tail":"–(C), added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s1502/2"},"text":"Pub. L. 116–94, § 1502(2)","children":[],"tail":", added subsec. (b) and struck out former subsec. (b). Prior to amendment, text read as follows: “The Sergeant at Arms of the Senate may enter into a memorandum of understanding described in subsection (a)(1) consistent with the Senate Procurement Regulations.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
