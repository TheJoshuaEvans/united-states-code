{"tag":"section","attrib":{"id":"iddd3b2406-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6509"},"text":null,"children":[{"tag":"num","attrib":{"value":"6509"},"text":"§ 6509.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vouchering Senate office charges","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd3b2407-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6509/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Senate support office charges","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Charges for expenses of any office, the funds of which are disbursed by the Secretary of the Senate, may be vouchered by a Senate support office paying such expenses or to which such charges are owed for goods or services provided, if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd3b2408-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6509/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such charges are paid on behalf of the office incurring such expenses by such Senate support office; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3b2409-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6509/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such charges are payable to such Senate support office for goods or services provided by such office to the office incurring such expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3b240a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6509/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment charged to official funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Payments under this section shall be charged to the official funds of the office on whose behalf the expenses were paid, or which received the goods or services for which payment is required.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3b240b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6509/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any voucher submitted by a Senate support office pursuant to this section shall be accompanied by a certification from such office of the amount and that such purchases were of the nature that they could be charged to the official funds of the office on whose behalf charges were paid, or to which goods or services were provided.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3b240c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6509/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Vouchers under this section shall be submitted and paid subject to such regulations as may be promulgated by the Committee on Rules and Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd3b240d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/69/tI/s1"},"text":"Pub. L. 103–69, title I, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-11"},"text":"Aug. 11, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/695"},"text":"107 Stat. 695","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd3b240e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd3b240f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd3b2410-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s68–8"},"text":"section 68–8 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Congressional Operations Appropriations Act, 1994, which is title I of the Legislative Branch Appropriations Act, 1994.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
