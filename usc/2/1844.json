{"tag":"section","attrib":{"id":"iddcea1e23-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1844"},"text":null,"children":[{"tag":"num","attrib":{"value":"1844"},"text":"§ 1844.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings provisions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The provisions of sections 1841 to 1846 of this title shall not be construed to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcea1e24-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1844/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limit or otherwise affect any authority for the making of any appointment to, or for fixing or adjusting the pay for, the position of any employee described in subparagraph (1) or subparagraph (2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1841"},"text":"section 1841 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcea1e25-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1844/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affect the continuity of employment of, or reduce the pay of, any employee holding any position referred to in subparagraph (1) of this section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcea1e26-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1844/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modify, change, supersede, or otherwise affect the provisions of sections 5504 and 6101(a)(5) of title 5, insofar as such sections relate to the Office of the Architect of the Capitol.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd