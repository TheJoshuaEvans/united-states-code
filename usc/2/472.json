{"tag":"section","attrib":{"id":"iddca28d62-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s472"},"text":null,"children":[{"tag":"num","attrib":{"value":"472"},"text":"§ 472.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Technology Assessment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddca28d63-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s472/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Creation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with the findings and declaration of purpose in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s471"},"text":"section 471 of this title","children":[],"tail":", there is hereby created the Office of Technology Assessment (hereinafter referred to as the “Office”) which shall be within and responsible to the legislative branch of the Government."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca28d64-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s472/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office shall consist of a Technology Assessment Board (hereinafter referred to as the “Board”) which shall formulate and promulgate the policies of the Office, and a Director who shall carry out such policies and administer the operations of the Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca28d65-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s472/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions and duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The basic function of the Office shall be to provide early indications of the probable beneficial and adverse impacts of the applications of technology and to develop other coordinate information which may assist the Congress. In carrying out such function, the Office shall:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddca28d66-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s472/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify existing or probable impacts of technology or technological programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca28d67-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s472/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" where possible, ascertain cause-and-effect relationships;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca28d68-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s472/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify alternative technological methods of implementing specific programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca28d69-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s472/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify alternative programs for achieving requisite goals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca28d6a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s472/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make estimates and comparisons of the impacts of alternative methods and programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca28d6b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s472/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" present findings of completed analyses to the appropriate legislative authorities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca28d6c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s472/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify areas where additional research or data collection is required to provide adequate support for the assessments and estimates described in paragraph (1) through (5) of this subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca28d6d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s472/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" undertake such additional associated activities as the appropriate authorities specified under subsection (d) may direct.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca28d6e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s472/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initiation of assessment activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Assessment activities undertaken by the Office may be initiated upon the request of:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddca28d6f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s472/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the chairman of any standing, special, or select committee of either House of the Congress, or of any joint committee of the Congress, acting for himself or at the request of the ranking minority member or a majority of the committee members;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca28d70-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s472/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Board; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca28d71-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s472/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director, in consultation with the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca28d72-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s472/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Assessments made by the Office, including information, surveys, studies, reports, and findings related thereto, shall be made available to the initiating committee or other appropriate committees of the Congress. In addition, any such information, surveys, studies, reports, and findings produced by the Office may be made available to the public except where—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddca28d73-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s472/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to do so would violate security statutes; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca28d74-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s472/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Board considers it necessary or advisable to withhold such information in accordance with one or more of the numbered paragraphs in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b"},"text":"section 552(b) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddca28d75-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/484/s3"},"text":"Pub. L. 92–484, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-13"},"text":"Oct. 13, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/797"},"text":"86 Stat. 797","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
