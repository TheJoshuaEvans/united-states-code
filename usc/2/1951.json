{"tag":"section","attrib":{"id":"iddcf3941a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1951"},"text":null,"children":[{"tag":"num","attrib":{"value":"1951"},"text":"§ 1951.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of United States Capitol Police Memorial Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is hereby established in the Treasury of the United States the United States Capitol Police Memorial Fund (hereafter in this part referred to as the “Fund”). All amounts received by the Capitol Police Board which are designated for deposit into the Fund, including amounts received in response to the shooting incident at the practice for the Congressional Baseball Game for Charity on ","children":[{"tag":"date","attrib":{"date":"2017-06-14"},"text":"June 14, 2017","children":[],"tail":", shall be deposited into the Fund."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddcf3941b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/223/s1"},"text":"Pub. L. 105–223, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1250"},"text":"112 Stat. 1250","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/45/s2/c"},"text":"Pub. L. 115–45, § 2(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-04"},"text":"Aug. 4, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/957"},"text":"131 Stat. 957","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcf3941c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcf3941d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddcf3941e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was classified to section 207c of former Title 40, prior to the enactment of Title 40, Public Buildings, Property, and Works, by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217/s1"},"text":"Pub. L. 107–217, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1062"},"text":"116 Stat. 1062","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcf3941f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/45"},"text":"Pub. L. 115–45","children":[],"tail":" substituted “deposit into the Fund, including amounts received in response to the shooting incident at the practice for the Congressional Baseball Game for Charity on "},{"tag":"date","attrib":{"date":"2017-06-14"},"text":"June 14, 2017","children":[],"tail":",” for “deposit into the Fund”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
