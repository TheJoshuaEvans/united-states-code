{"tag":"section","attrib":{"id":"iddcb5a032-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s681"},"text":null,"children":[{"tag":"num","attrib":{"value":"681"},"text":"§ 681.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclaimer","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Nothing contained in this Act, or in any amendments made by this Act, shall be construed as—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcb5a033-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s681/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" asserting or conceding the constitutional powers or limitations of either the Congress or the President;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb5a034-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s681/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ratifying or approving any impoundment heretofore or hereafter executed or approved by the President or any other Federal officer or employee, except insofar as pursuant to statutory authorization then in effect;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb5a035-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s681/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affecting in any way the claims or defenses of any party to litigation concerning any impoundment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb5a036-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s681/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" superseding any provi