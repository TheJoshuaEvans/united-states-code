{"tag":"section","attrib":{"id":"iddd2810f0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5103"},"text":null,"children":[{"tag":"num","attrib":{"value":"5103"},"text":"§ 5103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Single per annum gross rates of allowances for personal services in offices of Speaker, Leaders, and Whips","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The allowance for additional office personnel in the office of each of the following officials of the House of Representatives shall be at a single per annum gross rate, as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2810f1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5103/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Speaker, $110,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2810f2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5103/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Majority Leader, $90,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2810f3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5103/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Minority Leader, $55,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2810f4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5103/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Majority Whip, $55,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2810f5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5103/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Minority Whip, $55,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd2810f6-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/510/tIV/s473"},"text":"Pub. L. 91–510, title IV, § 473","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-26"},"text":"Oct. 26, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1194"},"text":"84 Stat. 1194","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd2810f7-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd2810f8-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd2810f9-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s333"},"text":"section 333 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd2810fa-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd2810fb-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"