{"tag":"section","attrib":{"id":"iddcfac013-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2026"},"text":null,"children":[{"tag":"num","attrib":{"value":"2026"},"text":"§ 2026.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Senate Staff Health and Fitness Facility Revolving Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcfac014-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2026/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Treasury of the United States a revolving fund to be known as the Senate Staff Health and Fitness Facility Revolving Fund (“the revolving fund”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcfac015-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2026/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit of receipts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Architect of the Capitol shall deposit in the revolving fund—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcfac016-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2026/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amounts received as dues or other assessments for use of the Senate Staff Health and Fitness Facility, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcfac017-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2026/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amounts received from the operation of the Senate waste recycling program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcfac018-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2026/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the approval of the Committee on Appropriations of the Senate, amounts in the revolving fund shall be available to the Architect of the Capitol, without fiscal year limitation, for payment of costs of the Senate Staff Health and Fitness Facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcfac019-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2026/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal of excess amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Architect of the Capitol shall withdraw from the revolving fund and deposit in the Treasury of the United States as miscellaneous receipts all moneys in the revolving fund that the Architect determines are in excess of the current and reasonably foreseeable needs of the Senate Staff Health and Fitness Facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcfac01a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2026/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Committee on Rules and Administration of the Senate shall promulgate regulations pertaining to the operation and use of the Senate Staff Health and Fitness Facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcfac01b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/2/tI/s4"},"text":"Pub. L. 106–554, § 1(a)(2) [title I, § 4]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–96; "},{"tag":"ref","attrib":{"href":"/us/pl/108/7/dH/tI/s1207"},"text":"Pub. L. 108–7, div. H, title I, § 1207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/375"},"text":"117 Stat. 375","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcfac01c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcfac01d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddcfac01e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s121f"},"text":"section 121f of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Congressional Operations Appropriations Act, 2001, which is title I of the Legislative Branch Appropriations Act, 2001.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcfac01f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—Subsecs. (a), (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7/s1207/1"},"text":"Pub. L. 108–7, § 1207(1)","children":[],"tail":", (2), inserted “Staff” after “Senate”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7/s1207/3"},"text":"Pub. L. 108–7, § 1207(3)","children":[],"tail":", inserted “Staff” after “costs of the Senate”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7/s1207/4"},"text":"Pub. L. 108–7, § 1207(4)","children":[],"tail":", inserted “Staff” after “Senate”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7/s1207/5"},"text":"Pub. L. 108–7, § 1207(5)","children":[],"tail":", added subsec. (e) and struck out former subsec. (e) which read as follows: “Subject to the approval of the Committee on Rules and Administration of the Senate, the Architect of the Capitol may issue such regulations as may be necessary to carry out the provisions of this section.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
