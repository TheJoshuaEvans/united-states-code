{"tag":"section","attrib":{"id":"iddd0dd238-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4123"},"text":null,"children":[{"tag":"num","attrib":{"value":"4123"},"text":"§ 4123.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Attending Physician in response to medical contingencies or public health emergencies at Capitol","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd0dd239-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4123/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attending Physician to Congress shall have the authority and responsibility for overseeing and coordinating the use of medical assets in response to a bioterrorism event and other medical contingencies or public health emergencies occurring within the Capitol Buildings or the United States Capitol Grounds. This shall include the authority to enact quarantine and to declare death. These actions will be carried out in close cooperation and communication with the Commissioner of Public Health, Chief Medical Examiner, and other Public Health Officials of the District of Columbia government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd0dd23a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4123/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd0dd23b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4123/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Capitol Buildings” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s5101"},"text":"section 5101 of title 40","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd0dd23c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4123/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “United States Capitol Grounds” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s5102/a"},"text":"section 5102(a) of title 40","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd0dd23d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4123/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall take effect on ","children":[{"tag":"date","attrib":{"date":"2004-01-23"},"text":"January 23, 2004","children":[],"tail":", and shall apply during any fiscal year occurring on or after "},{"tag":"date","attrib":{"date":"2004-01-23"},"text":"January 23, 2004","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd0dd23e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/199/dH/s151"},"text":"Pub. L. 108–199, div. H, § 151","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-01-23"},"text":"Jan. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/448"},"text":"118 Stat. 448","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd0dd23f-3a6e-11f1-a0f3-db3efcbbb4ee"