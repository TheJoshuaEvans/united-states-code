{"tag":"section","attrib":{"id":"iddc8d0987-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s179l"},"text":null,"children":[{"tag":"num","attrib":{"value":"179l"},"text":"§ 179l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Film Registry of Library of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Librarian of Congress (hereafter in sections 179","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":" to 179w of this title referred to as the “Librarian”) shall continue the National Film Registry established and maintained under the National Film Preservation Act of 1988 ("},{"tag":"ref","attrib":{"href":"/us/pl/100/446"},"text":"Public Law 100–446","children":[],"tail":"), and the National Film Preservation Act of 1992 ("},{"tag":"ref","attrib":{"href":"/us/pl/102/307"},"text":"Public Law 102–307","children":[],"tail":") pursuant to the provisions of sections 179"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" to 179w of this title, for the purpose of maintaining and preserving films that are culturally, historically, or aesthetically significant."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc8d0988-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/285/tI/s102"},"text":"Pub. L. 104–285, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3377"},"text":"110 Stat. 3377","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc8d0989-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc8d098a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},