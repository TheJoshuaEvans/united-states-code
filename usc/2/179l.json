72","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The National Film Preservation Act of 1992, referred to in text, is title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/307"},"text":"Pub. L. 102–307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-06-26"},"text":"June 26, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/267"},"text":"106 Stat. 267","children":[],"tail":", which was classified principally to sections 179 to 179k of this title and was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/104/285/tI/s114"},"text":"Pub. L. 104–285, title I, § 114","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3382"},"text":"110 Stat. 3382","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"iddc8d098c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior provisions similar to sections 179","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":" to 179w of this title were contained in former section 179 et seq. of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc8d098d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"iddc8d098e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2016 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/217/s1