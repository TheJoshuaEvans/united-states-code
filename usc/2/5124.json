{"tag":"section","attrib":{"id":"iddd281142-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5124"},"text":null,"children":[{"tag":"num","attrib":{"value":"5124"},"text":"§ 5124.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lump sum allowance for Speaker","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd281143-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5124/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The aggregate amount otherwise authorized to be appropriated for a fiscal year for the lump-sum allowance for the Office of the Speaker of the House of Representatives shall be increased by $40,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd281144-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5124/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section shall apply with respect to fiscal year 2002 and each succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd281145-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/68/tI/s117"},"text":"Pub. L. 107–68, title I, § 117","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-11-12"},"text":"Nov. 12, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/573"},"text":"115 Stat. 573","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd281146-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd281147-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd281148-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s74a–12"},"text":"section 74a–12 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Congressional Operations Appropriations Act, 2002, which is title I of the Legislative Branch Appropriations Act, 2002.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
