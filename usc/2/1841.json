{"tag":"section","attrib":{"id":"iddcea1e0a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1841"},"text":null,"children":[{"tag":"num","attrib":{"value":"1841"},"text":"§ 1841.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Single per annum gross rates of pay","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Whenever the rate of pay of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcea1e0b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1841/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee of the Office of the Architect of the Capitol; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcea1e0c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1841/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee of the House Restaurant, or of the Senate Restaurant, under the supervision of the Architect of the Capitol as an agent of the House or Senate, respectively, as the case may be;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"is fixed or adjusted on or after the effective date of this section, that rate, as so fixed and adjusted, shall be a single per annum gross rate.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcea1e0d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/510/tIV/s481"},"text":"Pub. L. 91–510, title IV, § 481","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-26"},"text":"Oct. 26, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1196"},"text":"84 Stat. 1196","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcea1e0e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcea1e0f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddcea1e10-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The effective date of this section, referred to in text, means immediately prior to noon on ","children":[{"tag":"date","attrib":{"date":"1971-01-03"},"text":"Jan. 3, 1971","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/pl/91/510/s601/1"},"text":"section 601(1) of Pub. L. 91–510","children":[],"tail":", set out as an Effective Date of 1970 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s4301"},"text":"section 4301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddcea1e11-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was classified to section 166b–1a of former Title 40, prior to the enactment of Title 40, Public Buildings, Property, and Works, by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217/s1"},"text":"Pub. L. 107–217, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1062"},"text":"116 Stat. 1062","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
