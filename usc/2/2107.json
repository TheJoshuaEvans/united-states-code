":" substituted “2002” for “2001” in first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/2/tIII/s309"},"text":"Pub. L. 106–554, § 1(a)(2) [title III, § 309]","children":[],"tail":", substituted “2001” for “2000” in first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/2/tI/s8/1"},"text":"Pub. L. 106–554, § 1(a)(2) [title I, § 8(1), (2)]","children":[],"tail":", in first sentence, substituted “works of art, historical objects, documents, or material relating to historical matters for placement or exhibition” for “items of art, fine art, and historical items” and, in second sentence, substituted “such works, objects, documents, or material” for “such items” in two places and “a work, object, document, or material” for “an item”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/2/tI/s8/3"},"text":"Pub. L. 106–554, § 1(a)(2) [title I, § 8(3)]","children":[],"tail":", substituted “such works, objects, documents, or materials” for “such items of art” and “may” for “shall”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/57"},"text":"Pub. L. 106–57","children":[],"tail":" substituted “2000” for “1999”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/275"},"text":"Pub. L. 105–275","children":[],"tail":" substituted “1999” for “1998”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/55"},"text":"Pub. L. 105–55","children":[],"tail":" substituted “1998” for “1997”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/197"},"text":"Pub. L. 104–197","children":[],"tail":" substituted “1997” for “1996”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1995—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/53"},"text":"Pub. L. 104–53","children":[],"tail":" substituted “1996” for “1995”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/283"},"text":"Pub. L. 103–283","children":[],"tail":" substituted “1995” for “1994”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/69"},"text":"Pub. L. 103–69","children":[],"tail":" substituted “1994” for “1993”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/392"},"text":"Pub. L. 102–392","children":[],"tail":" substituted “1993” for “1992”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/90"},"text":"Pub. L. 102–90","children":[],"tail":" substituted “1992” for “1991”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/520"},"text":"Pub. L. 101–520","children":[],"tail":" substituted “1991” for “1990”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
