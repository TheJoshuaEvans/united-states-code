{"tag":"section","attrib":{"id":"iddcec67ef-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1871"},"text":null,"children":[{"tag":"num","attrib":{"value":"1871"},"text":"§ 1871.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expired appropriations available for deposit into Employees’ Compensation Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcec67f0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1871/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding section 1101, available balances of expired Architect of the Capitol appropriations shall be available to the Architect of the Capitol to make the deposit to the credit of the Employees’ Compensation Fund required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8147/b"},"text":"section 8147(b) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcec67f1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1871/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply with respect to appropriations for fiscal year 2013 and each year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcec67f2-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/6/dF/tVI/s1606"},"text":"Pub. L. 113–6, div. F, title VI, § 1606","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-03-26"},"text":"Mar. 26, 2013","children":[],"tail":", "},