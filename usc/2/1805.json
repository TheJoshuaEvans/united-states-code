{"tag":"section","attrib":{"id":"iddce56287-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1805"},"text":null,"children":[{"tag":"num","attrib":{"value":"1805"},"text":"§ 1805.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deputy Architect of the Capitol","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddce56288-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1805/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Deputy Architect of the Capitol","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Architect of the Capitol (in this section referred to as the “Architect”) shall appoint a suitable individual to be the Deputy Architect of the Capitol (in this section referred to as the “Deputy Architect”). The Architect may delegate to the Deputy Architect such duties as the Architect determines are necessary or appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce56289-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1805/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Architect shall appoint a Deputy Architect under subsection (a) not later than 120 days after—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce5628a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1805/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the Architect is appointed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1801a"},"text":"section 1801a of this title","children":[],"tail":", if there is no Deputy Architect on the date of the appointment; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce5628b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1805/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which a vacancy arises in the office of the Deputy Architect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce5628c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1805/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Deputy Architect shall be paid at an annual rate of pay to be determined by the Architect but not to exceed $1,500 less than the annual rate of pay for the Architect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce5628d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1805/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to appoint","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Architect does not appoint a Deputy Architect on or before the applicable date specified in subsection (b), the congressional commission described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1801a/a"},"text":"section 1801a(a) of this title","children":[],"tail":" shall appoint the Deputy Architect by a majority vote of the members of the commission."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce5628e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1805/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the position of Deputy Architect becomes vacant, the Architect shall immediately notify the members of the congressional commission described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1801a/a"},"text":"section 1801a(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddce5628f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7/dH/tI/s1203"},"text":"Pub. L. 108–7, div. H, title I, § 1203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/373"},"text":"117 Stat. 373","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/11/tII/s2601/a"},"text":"Pub. L. 108–11, title II, § 2601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-04-16"},"text":"Apr. 16, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/599"},"text":"117 Stat. 599","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/271/s8/b"},"text":"Pub. L. 108–271, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-07"},"text":"July 7, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/814"},"text":"118 Stat. 814","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/316/s1/b"},"text":"Pub. L. 111–316, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3452"},"text":"124 Stat. 3452","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dO/tVII/s701/b"},"text":"Pub. L. 116–260, div. O, title VII, § 701(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2154"},"text":"134 Stat. 2154","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dE/tLVII/s5703"},"text":"Pub. L. 118–31, div. E, title LVII, § 5703","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/961"},"text":"137 Stat. 961","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddce56290-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddce56291-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddce56292-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Legislative Branch Appropriations Act, 2003, which is div. H of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7"},"text":"Pub. L. 108–7","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddce56293-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s5703/1"},"text":"Pub. L. 118–31, § 5703(1)","children":[],"tail":", inserted “(in this section referred to as the ‘Architect’)” after “The Architect of the Capitol” and “(in this section referred to as the ‘Deputy Architect’)” after “Deputy Architect of the Capitol”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s5703/3"},"text":"Pub. L. 118–31, § 5703(3)","children":[],"tail":", added subsec. (b). Former subsec. (b) redesignated (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s5703/2"},"text":"Pub. L. 118–31, § 5703(2)","children":[],"tail":", (4), redesignated subsec. (b) as (c) and struck out “of the Capitol” after “The Deputy Architect” and after “pay for the Architect”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s5703/5"},"text":"Pub. L. 118–31, § 5703(5)","children":[],"tail":", added subsecs. (d) and (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2020—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s701/b/1"},"text":"Pub. L. 116–260, § 701(b)(1)","children":[],"tail":", substituted “Capitol” for “Capitol/Chief Operating Officer” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s701/b/2"},"text":"Pub. L. 116–260, § 701(b)(2)","children":[],"tail":", inserted text of subsec. (a) and struck out former text of subsec. (a) which read as follows: “There shall be a Deputy Architect of the Capitol who shall serve as the Chief Operating Officer of the Office of the Architect of the Capitol. The Deputy Architect of the Capitol shall be appointed by the Architect of the Capitol and shall report directly to the Architect of the Capitol and shall be subject to the authority of the Architect of the Capitol. The Architect of the Capitol shall appoint the Deputy Architect of the Capitol not later than 180 days after "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"February 20, 2003","children":[],"tail":". The Architect of the Capitol shall consult with the Comptroller General or his designee before making the appointment.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b) to (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s701/b/3"},"text":"Pub. L. 116–260, § 701(b)(3)","children":[],"tail":", (4), redesignated subsec. (h) as (b) and struck out former subsecs. (b) to (g) which related to Deputy Architect qualifications and responsibilities, submission of an action plan and annual evaluation of its implementation, and removal of the Deputy Architect."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (i), (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s702/b/5"},"text":"Pub. L. 116–260, § 702(b)(5)","children":[],"tail":", struck out subsecs. (i) and (j) which required the Deputy Architect to prepare and transmit an annual performance report and terminated the role of the Comptroller General and the Government Accountability Office in this section as of "},{"tag":"date","attrib":{"date":"2006-10-01"},"text":"Oct. 1, 2006","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/316"},"text":"Pub. L. 111–316","children":[],"tail":" struck out par. (3). Text read as follows: “Notwithstanding "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1849/a"},"text":"section 1849(a) of this title","children":[],"tail":", as amended by section 129(c) of the Legislative Branch Appropriations Act, 2002, the Architect of the Capitol may fix the rate of basic pay for not more than 3 additional positions at a rate not to exceed the highest total rate of pay for the Senior Executive Service under subchapter VIII of chapter 53 of title 5 for the locality involved.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsecs. (f), (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271"},"text":"Pub. L. 108–271","children":[],"tail":" substituted “Government Accountability Office” for “General Accounting Office”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/11"},"text":"Pub. L. 108–11","children":[],"tail":", substituted “not later than 180 days” for “not later than 90 days”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddce56294-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddce56295-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/316/s1/c"},"text":"Pub. L. 111–316, § 1(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3452"},"text":"124 Stat. 3452","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/316/s1/c"},"text":"“The amendments made by this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1849"},"text":"section 1849 of this title","children":[],"tail":"] shall apply with respect to pay periods beginning on or after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddce56296-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2003 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/11/tII/s2601/b"},"text":"Pub. L. 108–11, title II, § 2601(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-04-16"},"text":"Apr. 16, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/599"},"text":"117 Stat. 599","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/11/tII/s2601/b"},"text":"“The amendment made by subsection (a) [amending this section] shall take effect as if included in the enactment of the Legislative Branch Appropriations Act, 2003 [","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7/dH"},"text":"Pub. L. 108–7, div. H","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
