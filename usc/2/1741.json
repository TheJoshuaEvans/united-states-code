{"tag":"section","attrib":{"id":"iddce5623e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1741"},"text":null,"children":[{"tag":"num","attrib":{"value":"1741"},"text":"§ 1741.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce5623f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1741/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Librarian” means the Librarian of Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce56240-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1741/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Board” means the National Recording Preservation Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce56241-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1741/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “sound recording” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t17/s101"},"text":"section 101 of title 17","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce56242-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1741/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “publication” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t17/s101"},"text":"section 101 of title 17","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce56243-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1741/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Registry version” means, with respect to a sound recording, the version of a recording first published or offered for mass distribution whether as a publication or a broadcast, or as complete a version as bona fide preservation and restoration activities by the Librarian, an archivist other than the Librarian, or the copyright legal owner can compile in those cases where the original material has been irretrievably lost or the recording is unpublished.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddce56244-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/474/tI/s131"},"text":"Pub. L. 106–474, title I, § 131","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2090"},"text":"114 Stat. 2090","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
