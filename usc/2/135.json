{"tag":"section","attrib":{"id":"iddc8393c7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s135"},"text":null,"children":[{"tag":"num","attrib":{"value":"135"},"text":"§ 135.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purchase of books for law library","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Librarian shall make the purchases of books for the law library, under the direction of and pursuant to the catalogue furnished him by the Chief Justice of the Supreme Court.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc8393c8-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(R.S. § 84.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc8393c9-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc8393ca-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddc8393cb-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 84 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1832-07-14/ch221/s4"},"text":"act July 14, 1832, ch. 221, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/4/579"},"text":"4 Stat. 579","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
