{"tag":"section","attrib":{"id":"iddc98f10c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288c"},"text":null,"children":[{"tag":"num","attrib":{"value":"288c"},"text":"§ 288c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Defending the Senate, committee, subcommittee, member, officer, or employee of Senate","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc98f10d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as otherwise provided in subsection (b), when directed to do so pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s288b/a"},"text":"section 288b(a) of this title","children":[],"tail":", the Counsel shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc98f10e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" defend the Senate, a committee, subcommittee, Member, officer, or employee of the Senate in any civil action pending in any court of the United States or of a State or political subdivision thereof, in which the Senate, such committee, subcommittee, Member, officer, or employee is made a party defendant and in which there is placed in issue the validity of any proceeding of, or action, including issuance of any subpena or order, taken by the Senate, or such committee, subcommittee, Member, officer, or employee in its or his official or representative capacity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc98f10f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" defend the Senate or a committee, subcommittee, Member, officer, or employee of the Senate in any proceeding with respect to any subpena or order directed to the Senate or such committee, subcommittee, Member, officer, or employee in its or his official or representative capacity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc98f110-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Representation of a Member, officer, or employee under subsection (a) shall be undertaken by the Counsel only upon the consent of such Member, officer, or employee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc98f111-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/521/tVII/s704"},"text":"Pub. L. 95–521, title VII, § 704","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-26"},"text":"Oct. 26, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1877"},"text":"92 Stat. 1877","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc98f112-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc98f113-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddc98f114-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1979-01-03"},"text":"Jan. 3, 1979","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/521/s717"},"text":"section 717 of Pub. L. 95–521","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s288"},"text":"section 288 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
