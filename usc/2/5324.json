use Members on pay roll to six months."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd2a822f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd2a8230-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-21/ch600/s4"},"text":"Act Aug. 21, 1935, ch. 600, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/680"},"text":"49 Stat. 680","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/act/1935-08-21/ch600/s4"},"text":"“This joint resolution [enacting sections 5324 to 5326 of this title] shall be effective as of the beginning of the Seventy-fourth Congress, ","children":[{"tag":"date","attrib":{"date":"1935-01-03"},"text":"January 3, 1935","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
