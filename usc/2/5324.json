{"tag":"section","attrib":{"id":"iddd2a8229-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5324"},"text":null,"children":[{"tag":"num","attrib":{"value":"5324"},"text":"§ 5324.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pay of clerical assistants as affected by death or resignation of Member of House","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s5323"},"text":"section 5323 of this title","children":[],"tail":", in case of the death or resignation of a Member of the House during his term of office, the clerical assistants designated by him and borne upon the clerk hire pay rolls of the House of Representatives on the date of such death or resignation shall be continued upon such pay rolls at their respective salaries until the successor to such Member of the House is elected to fill the vacancy."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd2a822a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-21/ch600/s1"},"text":"Aug. 21, 1935, ch. 600, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/679"},"text":"49 Stat. 679","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1950-04-24/ch96"},"text":"Apr. 24, 1950, ch. 96","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/82"},"text":"64 Stat. 82","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1952-07-15/ch759/s1"},"text":"July 15, 1952, ch. 759, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/662"},"text":"66 Stat. 662","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/554/s8/a"},"text":"Pub. L. 89–554, § 8(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref