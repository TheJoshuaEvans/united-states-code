{"tag":"section","attrib":{"id":"iddce0812f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1536"},"text":null,"children":[{"tag":"num","attrib":{"value":"1536"},"text":"§ 1536.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance to Congressional Budget Office","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Director of the Office of Management and Budget shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce08130-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1536/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect from agencies the statements prepared under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1532"},"text":"section 1532 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce08131-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1536/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" periodically forward copies of such statements to the Director of the Congressional Budget Office on a reasonably timely basis after promulgation of the general notice of proposed rulemaking or of the final rule for which the statement was prepared.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddce08132-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/4/tII/s206"},"text":"Pub. L. 104–4, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-03-22"},"text":"Mar. 22, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/66"},"text":"109 Stat. 66","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
