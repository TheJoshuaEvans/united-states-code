{"tag":"section","attrib":{"id":"iddd176fd3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4557"},"text":null,"children":[{"tag":"num","attrib":{"value":"4557"},"text":"§ 4557.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withholding of charitable contributions by Chief Administrative Officer of House","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd176fd4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4557/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Until otherwise provided by law and except as provided in subsection (c), the Chief Administrative Officer of the House of Representatives shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd176fd5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4557/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify employees of the opportunity to have amounts withheld from their compensation for contribution to charitable organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd176fd6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4557/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if an employee files with such officer a voluntary request specifying the amount to be withheld and one Combined Federal Campaign Center in the Washington metropolitan area to receive such amount—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd176fd7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4557/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" withhold such amount from the compensation of such employee, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd176fd8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4557/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transmit (not less than once each calendar quarter) the amount so withheld to the Combined Federal Campaign Center as specified in such request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd176fd9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4557/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time of fundraising activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chief Administrative Officer of the House of Representatives shall, to the extent practicable, carry out subsection (a) at or about the time of the Combined Federal Campaign and other fundraising in the executive branch of the Federal Government conducted pursuant to Executive Order 10927, dated ","children":[{"tag":"date","attrib":{"date":"1961-03-18"},"text":"March 18, 1961","children":[],"tail":", and at such other times as such officer deems appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd176fda-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4557/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum amounts withheld","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd176fdb-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4557/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" No amount shall be withheld under subsection (a) from the compensation of any employee for any pay period if the amount of such compensation for such period is less than the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd176fdc-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4557/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount specified to be withheld from such compensation under subsection (a) for such period, plus","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd176fdd-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4557/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of all other withholdings from such compensation for such period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd176fde-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4557/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" No amount may be specified by an employee to be withheld for any pay period under subsection (a) which is less than—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd176fdf-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4557/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 cents, if the pay period of such individual is biweekly or semimonthly; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd176fe0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4557/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1, if the pay period of such individual is monthly.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd176fe1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4557/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duty, burden, or requirement not imposed","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section imposes no duty, burden, or requirement upon the United States, the House of Representatives, or any officer or employee of the United States, except as specifically provided in this section. Nothing in this section shall be deemed to consent to the application of any provision of law which has the effect of subjecting the United States, the House of Representatives, or any officer or employee of the United States to any penalty or liability by reason of the provisions of this section. Any paper, form, document, or any other item filed with, or submitted to, the Chief Administrative Officer of the House of Representatives under this section is considered to be a paper of the House of Representatives within the provisions of the Rules of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd176fe2-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/391/tI/s111"},"text":"Pub. L. 95–391, title I, § 111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-09-30"},"text":"Sept. 30, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/777"},"text":"92 Stat. 777","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/186/tII/s204/5/A"},"text":"Pub. L. 104–186, title II, § 204(5)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1730"},"text":"110 Stat. 1730","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd176fe3-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd176fe4-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd176fe5-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Executive Order 10927, dated ","children":[{"tag":"date","attrib":{"date":"1961-03-18"},"text":"March 18, 1961","children":[],"tail":", referred to in subsec. (b), was revoked, and is covered, by Ex. Ord. No. 12353, "},{"tag":"date","attrib":{"date":"1982-03-23"},"text":"Mar. 23, 1982","children":[],"tail":", 47 F.R. 12785."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd176fe6-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s60e–1c"},"text":"section 60e–1c of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is based on section 1 of House Resolution No. 12, Ninety-fifth Congress, ","children":[{"tag":"date","attrib":{"date":"1977-08-05"},"text":"August 5, 1977","children":[],"tail":", which was enacted into permanent law by "},{"tag":"ref","attrib":{"href":"/us/pl/95/391"},"text":"Pub. L. 95–391","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd176fe7-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186/s204/5/A/i"},"text":"Pub. L. 104–186, § 204(5)(A)(i)","children":[],"tail":", substituted “Chief Administrative Officer” for “Clerk” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186/s204/5/A/ii"},"text":"Pub. L. 104–186, § 204(5)(A)(ii)","children":[],"tail":", substituted “Chief Administrative Officer of the House of Representatives” for “Clerk”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
