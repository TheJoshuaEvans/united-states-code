{"tag":"section","attrib":{"id":"iddd3b2472-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6532"},"text":null,"children":[{"tag":"num","attrib":{"value":"6532"},"text":"§ 6532.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Death, resignation, or disability of Secretary and Assistant Secretary of Senate; Financial Clerk deemed successor as disbursing officer","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For any period during which both the Secretary and the Assistant Secretary of the Senate are unable (because of death, resignation, or disability) to discharge such Secretary’s duties as disbursing officer of the Senate, the Financial Clerk of the Senate shall be deemed to be the successor of such Secretary as disbursing officer.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd3b2473-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1926-03-03/ch44/s1"},"text":"Mar. 3, 1926, ch. 44, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/162"},"text":"44 Stat. 162","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/105/s2"},"text":"Pub. L. 91–105, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-10-31"},"text":"Oct. 31, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/169"},"text":"83 Stat. 169","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/382"},"text":"Pub. L. 91–382","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-18"},"text":"Aug. 18, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/810"},"text":"84 Stat. 810","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/310/tII/s220/g"},"text":"Pub. L. 92–310, title II, § 220(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-06-06"},"text":"June 6, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/204"},"text":"86 Stat. 204","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/367/tI/s2/a"},"text":"Pub. L. 98–367, title I, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-17"},"text":"July 17, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/474"},"text":"98 Stat. 474","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd3b2474-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd3b2475-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd3b2476-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s64a"},"text":"section 64a of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd3b2477-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/367"},"text":"Pub. L. 98–367","children":[],"tail":" substituted “For any period during which both the Secretary and the Assistant Secretary of the Senate are unable (because of death, resignation, or disability) to discharge such Secretary’s duties as disbursing officer of the Senate, the Financial Clerk of the Senate shall be deemed to be the successor of such Secretary as disbursing officer” for “In the event of the death, resignation, or disability of the Secretary of the Senate, the Financial Clerk of the Senate shall be deemed his successor as a disbursing officer and he shall serve as such disbursing officer until the end of the quarterly period during which a new Secretary shall have been elected and qualified, or such disability shall have been ended”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/310"},"text":"Pub. L. 92–310","children":[],"tail":" struck out provisions which related to the bond of the Financial Clerk."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/382"},"text":"Pub. L. 91–382","children":[],"tail":" substituted “Financial Clerk” for “Comptroller”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1969—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/105"},"text":"Pub. L. 91–105","children":[],"tail":" substituted the Comptroller of the Senate for the Financial Clerk of the Senate as the successor of the Secretary of the Senate in the event of the death, resignation, or disability of the Secretary."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd3b2478-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd3b2479-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1970 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/91/382"},"text":"Pub. L. 91–382","children":[],"tail":" provided that the amendment made by "},{"tag":"ref","attrib":{"href":"/us/pl/91/382"},"text":"Pub. L. 91–382","children":[],"tail":" is effective "},{"tag":"date","attrib":{"date":"1970-08-01"},"text":"Aug. 1, 1970","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd3b247a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Certification of Disability","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Secretary of the Senate to be considered as disabled for purposes of this section only during such period of time as the Majority and Minority Leaders and the President pro tempore of the Senate certify jointly to the Senate that he is unable to perform his duties, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s6533"},"text":"section 6533 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
