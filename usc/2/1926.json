{"tag":"section","attrib":{"id":"iddcf14a97-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1926"},"text":null,"children":[{"tag":"num","attrib":{"value":"1926"},"text":"§ 1926.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Educational assistance program for employees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcf14a98-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1926/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to recruit or retain qualified personnel, the Chief of the Capitol Police may establish an educational assistance program for employees of the Capitol Police under which the Capitol Police may agree—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcf14a99-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1926/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to repay (by direct payments on behalf of the participating employee) all or any portion of a student loan previously taken out by the employee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf14a9a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1926/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make direct payments to an educational institution on behalf of a participating employee or to reimburse a participating employee for all or any portion of any tuition or related educational expenses paid by the employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcf14a9b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1926/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for student loan repayments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcf14a9c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1926/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of regulations under executive branch program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out subsection (a)(1), the Chief of the Capitol Police may, by regulation, make applicable such provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5379"},"text":"section 5379 of title 5","children":[],"tail":" as the Chief determines necessary to provide for such program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf14a9d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1926/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions on prior reimbursements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Capitol Police may not reimburse any individual under subsection (a)(1) for any repayments made by the individual prior to entering into an agreement with the Capitol Police to participate in the program under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf14a9e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1926/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of recovered amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amount repaid by, or recovered from, an individual under subsection (a)(1) and its implementing regulations shall be credited to the appropriation account available for salaries or general expenses of the Capitol Police at the time of repayment or recovery. Such credited amount may be used for any authorized purpose of the account and shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcf14a9f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1926/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limit on amount of payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The total amount paid by the Capitol Police with respect to any individual under the program under this section may not exceed $80,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcf14aa0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1926/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No review of determinations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any determination made under the program under this section shall not be reviewable or appealable in any manner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcf14aa1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1926/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply with respect to fiscal year 2003 and each succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcf14aa2-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/117/dB/s908"},"text":"Pub. L. 107–117, div. B, § 908","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-10"},"text":"Jan. 10, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2319"},"text":"115 Stat. 2319","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/7/dH/tI/s1007"},"text":"Pub. L. 108–7, div. H, title I, § 1007","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/358"},"text":"117 Stat. 358","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/94/dE/tI/s120"},"text":"Pub. L. 116–94, div. E, title I, § 120","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2763"},"text":"133 Stat. 2763","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dI/tI/s120"},"text":"Pub. L. 116–260, div. I, title I, § 120","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1643"},"text":"134 Stat. 1643","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcf14aa3-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcf14aa4-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddcf14aa5-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was classified to section 207b–1 of former Title 40, prior to the enactment of Title 40, Public Buildings, Property, and Works, by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217/s1"},"text":"Pub. L. 107–217, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1062"},"text":"116 Stat. 1062","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcf14aa6-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" substituted “$80,000” for “$60,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94"},"text":"Pub. L. 116–94","children":[],"tail":" substituted “$60,000” for “$40,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7"},"text":"Pub. L. 108–7","children":[],"tail":" amended section generally. Prior to amendment, section consisted of subsecs. (a) to (f) relating to student loan repayment program."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcf14aa7-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddcf14aa8-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Deadline for Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7/dH/tI/s1020"},"text":"Pub. L. 108–7, div. H, title I, § 1020","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/370"},"text":"117 Stat. 370","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/7/dH/tI/s1020"},"text":"“Not later than 60 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":"], the Chief of the Capitol Police shall promulgate any regulations required by sections 1004, 1006, 1007, and 1011 of this Act [enacting "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1931"},"text":"section 1931 of this title","children":[],"tail":" and amending this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1927"},"text":"section 1927 of this title","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
