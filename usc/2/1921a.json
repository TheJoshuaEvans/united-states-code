{"tag":"section","attrib":{"id":"iddcf14a48-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1921a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1921a"},"text":"§ 1921a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sole and exclusive authority of Board and Chief to determine rates of pay","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcf14a49-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1921a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Capitol Police Board and the Chief of the Capitol Police shall have the sole and exclusive authority to determine the rates and amounts for each of the following for members of the Capitol Police:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcf14a4a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1921a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The rate of basic pay (including the rate of basic pay upon appointment), premium pay, specialty assignment and proficiency pay, and merit pay.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf14a4b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1921a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The rate of cost-of-living adjustments, comparability adjustments, and locality adjustments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf14a4c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1921a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount for recruitment and relocation bonuses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf14a4d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1921a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount for retention allowances.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf14a4e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1921a/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount for educational assistance payments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcf14a4f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1921a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No review or appeal permitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The determination of a rate or amount described in subsection (a) may not be subject to review or appeal in any manner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcf14a50-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1921a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section may be construed to affect—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcf14a51-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1921a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any authority provided under law for a committee of the House of Representatives or Senate, or any other entity of the legislative branch, to review or approve any determination of a rate or amount described in subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf14a52-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1921a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any rate or amount described in subsection (a) which is established under law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf14a53-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1921a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms of any collective bargaining agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcf14a54-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1921a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply with respect to fiscal year 2005 and each succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcf14a55-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447/dG/tI/s1004"},"text":"Pub. L. 108–447, div. G, title I, § 1004","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3180"},"text":"118 Stat. 3180","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcf14a56-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcf14a57-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddcf14a58-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Legislative Branch Appropriations Act, 2005, which is div. G of the Consolidated Appropriations Act, 2005.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
