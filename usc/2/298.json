{"tag":"section","attrib":{"id":"iddc9b620e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s298"},"text":null,"children":[{"tag":"num","attrib":{"value":"298"},"text":"§ 298.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reductions in compensation level","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Each employee in a position of a compensation level of the House Employees Schedule (HS) or the House Wage Schedule (HWS), whose employment in such position and level is terminated and who is reemployed, with or without break in service, in a position in a lower compensation level (HS level or HWS level) of such schedule, or whose position is placed in a lower compensation level of such schedule pursuant to a reclassification of such position, shall be placed by the committee in such step of such lower compensation level as the committee deems appropriate.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc9b620f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/652/s9"},"text":"Pub. L. 88–652, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-10-13"},"text":"Oct. 13, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/1083"},"text":"78 Stat. 1083","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc9b6210-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc9b6211-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddc9b6212-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1965-01-01"},"text":"Jan. 1, 1965","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/88/652/s17"},"text":"section 17 of Pub. L. 88–652","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s291"},"text":"section 291 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
