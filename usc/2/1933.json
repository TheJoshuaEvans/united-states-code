{"tag":"section","attrib":{"id":"iddcf393db-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1933"},"text":null,"children":[{"tag":"num","attrib":{"value":"1933"},"text":"§ 1933.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clarification of authorities regarding certain personnel benefits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcf393dc-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1933/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No lump-sum payment permitted for unused compensatory time","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcf393dd-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1933/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No officer or employee of the United States Capitol Police whose service with the United States Capitol Police is terminated may receive any lump-sum payment with respect to accrued compensatory time off, except to the extent permitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1313/c/4"},"text":"section 1313(c)(4) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf393de-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1933/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcf393df-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1933/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Overtime compensation for officers and employees exempt from Fair Labor Standards Act of 1938","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcf393e0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1933/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria under which compensation permitted","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Chief of the Capitol Police may provide for the compensation of overtime work of exempt individuals which is performed on or after ","children":[{"tag":"date","attrib":{"date":"2010-03-04"},"text":"March 4, 2010","children":[],"tail":", in the form of additional pay or compensatory time off, only if—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcf393e1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1933/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the overtime work is carried out in connection with special circumstances, as determined by the Chief;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcf393e2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1933/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chief has established a monetary value for the overtime work performed by such individual; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcf393e3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1933/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sum of the total amount of the compensation paid to the individual for the overtime work (as determined on the basis of the monetary value established under subparagraph (B)) and the total regular compensation paid to the individual with respect to the pay period involved may not exceed an amount equal to the cap on the aggregate amount of annual compensation that may be paid to the individual under applicable law during the year in which the pay period occurs, as allocated on a per pay period basis consistent with premium pay regulations of the Capitol Police Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf393e4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1933/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exempt individuals defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, an “exempt individual” is an officer or employee of the United States Capitol Police—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcf393e5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1933/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is classified under regulations issued pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1313"},"text":"section 1313 of this title","children":[],"tail":" as exempt from the application of the rights and protections established by subsections (a)(1) and (d) of section 206, section 207, and "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s212/c"},"text":"section 212(c) of title 29","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcf393e6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1933/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose annual rate of pay is not established specifically under any law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf393e7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1933/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conforming amendment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcf393e8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1933/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcf393e9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1933/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amendment made by subparagraph (A) shall take effect as if included in the enactment of the Legislative Branch Appropriations Act, 2003, except that the amendment shall not apply with respect to any overtime work performed prior to ","children":[{"tag":"date","attrib":{"date":"2010-03-04"},"text":"March 4, 2010","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcf393ea-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/145/s5"},"text":"Pub. L. 111–145, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-04"},"text":"Mar. 4, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/52"},"text":"124 Stat. 52","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcf393eb-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcf393ec-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddcf393ed-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Legislative Branch Appropriations Act, 2003, referred to in subsec. (b)(3)(B), is div. H of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7"},"text":"Pub. L. 108–7","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddcf393ee-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/145/s5"},"text":"section 5 of Pub. L. 111–145","children":[],"tail":". Subsec. (a)(2) of "},{"tag":"ref","attrib":{"href":"/us/pl/111/145/s5"},"text":"section 5 of Pub. L. 111–145","children":[],"tail":" repealed sections 1924 and 1925 of this title. Subsec. (b)(3)(A) of "},{"tag":"ref","attrib":{"href":"/us/pl/111/145/s5"},"text":"section 5 of Pub. L. 111–145","children":[],"tail":" repealed section 1009 of the Legislative Branch Appropriations Act, 2003, "},{"tag":"ref","attrib":{"href":"/us/pl/108/7/dH"},"text":"Pub. L. 108–7, div. H","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/359"},"text":"117 Stat. 359","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
