{"tag":"section","attrib":{"id":"iddcec6802-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1881"},"text":null,"children":[{"tag":"num","attrib":{"value":"1881"},"text":"§ 1881.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcec6803-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1881/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Capitol-flown flag” means a flag of the United States flown over the Capitol in honor of the deceased individual for whom the flag is requested;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcec6804-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1881/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms “chaplain”, “firefighter”, “law enforcement officer”, “member of a rescue squad or ambulance crew”, and “public agency” have the meanings given such terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10284"},"text":"section 10284 of title 34","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcec6805-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1881/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “immediate family member”, with respect to an individual, means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcec6806-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1881/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the spouse, parent, brother, sister, or child of the individual or a person to whom the individual stands in loco parentis; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcec6807-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1881/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other person related to the individual by blood or marriage;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcec6808-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1881/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “public safety officer” means an individual serving a public agency in an official capacity, with or without compensation, as a law enforcement officer, as a firefighter, or as a chaplain; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcec6809-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1881/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Representative” includes a Delegate or Resident Commissioner to the Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcec680a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/156/s2"},"text":"Pub. L. 114–156, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-05-16"},"text":"May 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/391"},"text":"130 Stat. 391","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
