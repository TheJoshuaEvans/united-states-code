{"tag":"section","attrib":{"id":"iddd1043ab-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4303"},"text":null,"children":[{"tag":"num","attrib":{"value":"4303"},"text":"§ 4303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preparation and contents of statement of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The statement of all appropriations made during each session of Congress shall be prepared under the direction of the Committees on Appropriations of the Senate and House of Representatives, and said statement shall contain a chronological history of the regular appropriation bills passed during the session for which it is prepared. The statement shall indicate the amount of contracts authorized by appropriation Acts in addition to appropriations made therein, and shall also contain specific reference to all indefinite appropriations made each session and shall contain such additional information concerning estimates and appropriations as the committees may deem necessary.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd1043ac-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1888-10-19/ch1210/s1"},"text":"Oct. 19, 1888, ch. 1210, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/25/587"},"text":"25 Stat. 587","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1897-07-19/ch9"},"text":"July 19, 1897, ch. 9","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/30/136"},"text":"30 Stat. 136","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1924-06-07/ch303/s1"},"text":"June 7, 1924, ch. 303, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/43/586"},"text":"43 Stat. 586","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd1043ad-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd1043ae-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd1043af-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s105"},"text":"section 105 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
