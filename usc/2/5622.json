{"tag":"section","attrib":{"id":"iddd31adc0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5622"},"text":null,"children":[{"tag":"num","attrib":{"value":"5622"},"text":"§ 5622.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lump sum allowance for Corrections Calendar Office","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There shall be a lump sum allowance of $300,000 per fiscal year for the salaries and expenses of the Corrections Calendar Office, established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s5621"},"text":"section 5621 of this title","children":[],"tail":". Such amount shall be allocated between the majority party and the minority party as determined by the Speaker, in consultation with the minority leader."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd31adc1-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/55/tI/s101"},"text":"Pub. L. 105–55, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-10-07"},"text":"Oct. 7, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1183"},"text":"111 Stat. 1183","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd31adc2-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd31adc3-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd31adc4-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s74d–1"},"text":"section 74d–1 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is based on section 1 of House Resolution No. 130, One Hundred Fifth Congress, ","children":[{"tag":"date","attrib":{"date":"1997-04-24"},"text":"Apr. 24, 1997","children":[],"tail":", which was enacted into permanent law by "},{"tag":"ref","attrib":{"href":"/us/pl/105/55"},"text":"Pub. L. 105–55","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd31adc5-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd31adc6-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transfer of Allowance","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For transfer of lump sum allowance under this section to Offices of Speaker and Minority Leader, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s5624"},"text":"section 5624 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
