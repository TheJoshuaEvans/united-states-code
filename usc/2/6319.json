{"tag":"section","attrib":{"id":"iddd38b2a5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6319"},"text":null,"children":[{"tag":"num","attrib":{"value":"6319"},"text":"§ 6319.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation of official records and papers to a Senator’s State","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd38b2a6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6319/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of reasonable transportation expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon request of a Senator, amounts in the appropriation account “Miscellaneous Items” within the contingent fund of the Senate shall be available to pay the reasonable expenses of sending or transporting the official records and papers of the Senator from the District of Columbia to any location designated by such Senator in the State represented by the Senator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd38b2a7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6319/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sending and transportation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Sergeant at Arms and Doorkeeper of the Senate shall provide for the most economical means of sending or transporting the official records and papers under this section while ensuring the orderly and timely delivery of the records and papers to the location specified by the Senator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd38b2a8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6319/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oversight","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Committee on Rules and Administration shall have the authority to issue rules and regulations to carry out the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd38b2a9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6319/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Official records defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “official records and papers” means books, records, papers, and official files which could be sent as franked mail.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd38b2aa-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6319/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply with respect to fiscal year 2005 and each succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd38b2ab-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447/dG/tI/s7"},"text":"Pub. L. 108–447, div. G, title I, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3170"},"text":"118 Stat. 3170","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd38b2ac-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd38b2ad-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd38b2ae-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s59d–1"},"text":"section 59d–1 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Legislative Branch Appropriations Act, 2005, which is div. G of the Consolidated Appropriations Act, 2005.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
