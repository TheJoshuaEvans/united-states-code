{"tag":"section","attrib":{"id":"iddd2f3d0b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5546"},"text":null,"children":[{"tag":"num","attrib":{"value":"5546"},"text":"§ 5546.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support services for House during emergency; memorandum of understanding with an executive agency","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd2f3d0c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5546/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2f3d0d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5546/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to subsection (b), the Chief Administrative Officer of the House of Representatives and the head of an executive agency (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s105"},"text":"section 105 of title 5","children":[],"tail":") may enter into a memorandum of understanding under which the agency may provide facilities, equipment, supplies, personnel, and other support services for the use of the House of Representatives during an emergency situation; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2f3d0e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5546/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chief Administrative Officer and the head of the agency may take any action necessary to carry out the terms of the memorandum of understanding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2f3d0f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5546/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of Speaker required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chief Administrative Officer of the House of Representatives may not enter into a memorandum of understanding described in subsection (a)(1) without the approval of the Speaker of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2f3d10-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5546/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply with respect to fiscal year 2002 and each succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd2f3d11-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/117/dB/s904"},"text":"Pub. L. 107–117, div. B, § 904","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-10"},"text":"Jan. 10, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2318"},"text":"115 Stat. 2318","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd2f3d12-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd2f3d13-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd2f3d14-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s130h"},"text":"section 130h of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Emergency Supplemental Act, 2002, which is div. B of the Department of Defense and Emergency Supplemental Appropriations for Recovery from and Response to Terrorist Attacks on the United States Act, 2002.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
