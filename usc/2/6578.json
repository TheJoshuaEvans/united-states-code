{"tag":"section","attrib":{"id":"iddd3d955e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6578"},"text":null,"children":[{"tag":"num","attrib":{"value":"6578"},"text":"§ 6578.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Senate Leader’s Lecture Series","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd3d955f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6578/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established the Senate Leader’s Lecture Series (hereinafter referred to as the “lecture series”). Expenses incurred in connection with the lecture series shall be paid from the appropriations account “Secretary of the Senate” within the contingent fund of the Senate and shall not exceed $30,000 in any fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3d9560-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6578/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenses covered","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Payments for expenses in connection with the lecture series may cover expenses incurred by speakers, including travel, subsistence, and per diem, and the cost of receptions, including food, food related items, and hospitality.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3d9561-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6578/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments for expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Payments for expenses of the lecture series shall be made on vouchers approved by the Secretary of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3d9562-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6578/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section is effective on and after ","children":[{"tag":"date","attrib":{"date":"1997-10-01"},"text":"October 1, 1997","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd3d9563-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/275/tI/s5"},"text":"Pub. L. 105–275, title I, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2433"},"text":"112 Stat. 2433","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd3d9564-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd3d9565-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd3d9566-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s69b"},"text":"section 69b of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Congressional Operations Appropriations Act, 1999, which is title I of the Legislative Branch Appropriations Act, 1999.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
