{"tag":"section","attrib":{"id":"iddcb59fd7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s661b"},"text":null,"children":[{"tag":"num","attrib":{"value":"661b"},"text":"§ 661b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" OMB and CBO analysis, coordination, and review","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcb59fd8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s661b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the executive branch, the Director shall be responsible for coordinating the estimates required by this subchapter. The Director shall consult with the agencies that administer direct loan or loan guarantee programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcb59fd9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s661b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delegation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may delegate to agencies authority to make estimates of costs. The delegation of authority shall be based upon written guidelines, regulations, or criteria consistent with the definitions in this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcb59fda-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s661b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with Congressional Budget Office","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In developing estimation guidelines, regulations, or criteria to be used by Federal agencies, the Director shall consult with the Director of the Congressional Budget Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcb59fdb-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s661b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improving cost estimates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director and the Director of the Congressional Budget Office shall coordinate the development of more accurate data on historical performance of direct loan and loan guarantee programs. They shall annually review the performance of outstanding direct loans and loan guarantees to improve estimates of costs. The Office of Management and Budget and the Congressional Budget Office shall have access to all agency data that may facilitate the development and improvement of estimates of costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcb59fdc-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s661b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Historical credit program costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall review, to the extent possible, historical data and develop the best possible estimates of adjustments that would convert aggregate historical budget data to credit reform accounting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcb59fdd-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s661b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director and the Director of the Congressional Budget Office shall each analyze and report to Congress on differences in long-term administrative costs for credit programs versus grant programs by ","children":[{"tag":"date","attrib":{"date":"1992-01-31"},"text":"January 31, 1992","children":[],"tail":". Their reports shall recommend to Congress any changes, if necessary, in the treatment of administrative costs under credit reform accounting."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcb59fde-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/344/tV/s503"},"text":"Pub. L. 93–344, title V, § 503","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXIII/s13201/a"},"text":"Pub. L. 101–508, title XIII, § 13201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-611"},"text":"104 Stat. 1388–611","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcb59fdf-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcb59fe0-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"iddcb59fe1-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/344/s503"},"text":"section 503 of Pub. L. 93–344","children":[],"tail":", title V, "},{"tag":"date","attrib":{"date":"1974-07-12"},"text":"July 12, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/321"},"text":"88 Stat. 321","children":[],"tail":", was classified to section 701 of former Title 31, prior to repeal and reenactment in "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1552/a"},"text":"section 1552(a) of Title 31","children":[],"tail":", Money and Finance, by "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s5/b"},"text":"Pub. L. 97–258, § 5(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1068"},"text":"96 Stat. 1068","children":[],"tail":", the first section of which enacted Title 31."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
