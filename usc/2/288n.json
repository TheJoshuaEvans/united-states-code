{"tag":"section","attrib":{"id":"iddc98f194-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288n"},"text":null,"children":[{"tag":"num","attrib":{"value":"288n"},"text":"§ 288n.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel and related expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Funds expended by the Senate Legal Counsel for travel and related expenses shall be subject to the same regulations and limitations (insofar as they are applicable) as those which the Senate Committee on Rules and Administration prescribes for application to travel and related expenses for which payment is authorized to be made from the contingent fund of the Senate.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc98f195-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/51/tI/s106"},"text":"Pub. L. 98–51, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-07-14"},"text":"July 14, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/267"},"text":"97 Stat. 267","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc98f196-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc98f197-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddc98f198-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Congressional Operations Appropriation Act, 1984, which is title I of the Legislative Branch Appropriation Act, 1984, and not as part of title VII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/521"},"text":"Pub. L. 95–521","children":[],"tail":" which in part comprises this chapter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section, as it relates to funds expended by the Legislative Counsel of the Senate, is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s276b"},"text":"section 276b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
