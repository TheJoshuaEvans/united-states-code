{"tag":"section","attrib":{"id":"iddd281135-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5122"},"text":null,"children":[{"tag":"num","attrib":{"value":"5122"},"text":"§ 5122.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personal services in office of Speaker; payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There shall be paid from the applicable accounts of the House of Representatives until otherwise provided by law, for personal services in the office of the Speaker of the House, an additional basic sum of $10,000 per annum.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd281136-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/730/s103"},"text":"Pub. L. 87–730, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-02"},"text":"Oct. 2, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/693"},"text":"76 Stat. 693","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/186/tII/s204/14"},"text":"Pub. L. 104–186, title II, § 204(14)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1732"},"text":"110 Stat. 1732","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd281137-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd281138-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd281139-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s74–1"},"text":"section 74–1 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is based on House Resolution No. 487, Eighty-seventh Congress, ","children":[{"tag":"date","attrib":{"date":"1962-01-10"},"text":"Jan. 10, 1962","children":[],"tail":", which was enacted into permanent law by "},{"tag":"ref","attrib":{"href":"/us/pl/87/730"},"text":"Pub. L. 87–730","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd28113a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186"},"text":"Pub. L. 104–186","children":[],"tail":" substituted “applicable accounts of the House of Representatives” for “contingent fund of the House”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
