{"tag":"section","attrib":{"id":"iddd38b2cd-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6502"},"text":null,"children":[{"tag":"num","attrib":{"value":"6502"},"text":"§ 6502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procurement of temporary help","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd38b2ce-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd38b2cf-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6502/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to regulations that the Committee on Rules and Administration of the Senate may prescribe, the Secretary of the Senate and the Sergeant at Arms and Doorkeeper of the Senate may procure temporary help services from a private sector source that offers such services. Each procurement of services under this subsection shall be for no longer than 30 days.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd38b2d0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6502/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person performing services procured under paragraph (1) shall not, during the period of the performance of the services, be an employee of the United States or be considered to be an employee of the United States for any purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd38b2d1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall take effect on ","children":[{"tag":"date","attrib":{"date":"2001-10-01"},"text":"October 1, 2001","children":[],"tail":", and shall apply in fiscal year 2002 and successive fiscal years."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd38b2d2-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/68/tI/s109"},"text":"Pub. L. 107–68, title I, § 109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-11-12"},"text":"Nov. 12, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/569"},"text":"115 Stat. 569","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd38b2d3-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd38b2d4-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd38b2d5-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s61f–10"},"text":"section 61f–10 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Congressional Operations Appropriations Act, 2002, which is title I of the Legislative Branch Appropriations Act, 2002.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
