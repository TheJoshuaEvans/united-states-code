{"tag":"section","attrib":{"id":"iddd31adf7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6111"},"text":null,"children":[{"tag":"num","attrib":{"value":"6111"},"text":"§ 6111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation of President pro tempore of Senate","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whenever there is no Vice President, the President of the Senate for the time being is entitled to the compensation provided by law for the Vice President.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd31adf8-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(R.S. § 36.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd31adf9-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd31adfa-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd31adfb-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s32"},"text":"section 32 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 36 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1856-08-16/ch123/s2"},"text":"act Aug. 16, 1856, ch. 123, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/11/48"},"text":"11 Stat. 48","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"crossReferences","id":"iddd31adfc