{"tag":"section","attrib":{"id":"iddc96a628-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s275"},"text":null,"children":[{"tag":"num","attrib":{"value":"275"},"text":"§ 275.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Office of the Legislative Counsel shall aid in drafting public bills and resolutions or amendments thereto on the request of any committee of the Senate but the Committee on Rules and Administration of the Senate may determine the preference, if any, to be given to such requests of the committees. The Legislative Counsel shall, from time to time, prescribe rules and regulations for the conduct of the work of the Office for the committees, subject to the approval of such Committee on Rules and Administration.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc96a629-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1919-02-24/ch18"},"text":"Feb. 24, 1919, ch. 18","children":[],"tail":", title XIII, § 1303(b), (d), "},{"tag":"ref","attrib":{"href":"/us/stat/40/1141"},"text":"40 Stat. 1141","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1924-06-02/ch234"},"text":"June 2, 1924, ch. 234","children":[],"tail":", title XI, § 1101, "},{"tag":"ref","attrib":{"href":"/us/stat/43/353"},"text":"43 Stat. 353","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1946-08-02/ch753"},"text":"Aug. 2, 1946, ch. 753","children":[],"tail":", title I, §§ 102, 121, "},{"tag":"ref","attrib":{"href":"/us/stat/60/814"},"text":"60 Stat. 814","children":[],"tail":", 822.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc96a62a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc96a62b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddc96a62c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions setting forth functions of office of legislative counsel with respect to the House of Representatives and the committees thereof were omitted in view of nonapplicability of section to Speaker, employee, etc., of the House of Representatives pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/510/s531"},"text":"section 531 of Pub. L. 91–510","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s281"},"text":"section 281 of this title","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s281b"},"text":"section 281b of this title","children":[],"tail":" for functions of Office of Legislative Counsel of House of Representatives."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc96a62d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1946—Act ","children":[{"tag":"date","attrib":{"date":"1946-08-02"},"text":"Aug. 2, 1946","children":[],"tail":", substituted “Committee on Rules and Administration” for “Library Committee of the Senate” and “Committee on House Administration” for “Library Committee of the House of Representatives”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc96a62e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddc96a62f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1946 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-02/ch753/tI/s142"},"text":"Act Aug. 2, 1946, ch. 753, title I, § 142","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/834"},"text":"60 Stat. 834","children":[],"tail":", provided that the amendment made by that act is effective "},{"tag":"date","attrib":{"date":"1947-01-02"},"text":"Jan. 2, 1947","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
