{"tag":"section","attrib":{"id":"iddd176fcb-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4556"},"text":null,"children":[{"tag":"num","attrib":{"value":"4556"},"text":"§ 4556.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State income tax withholding; definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s4555"},"text":"section 4555 of this title","children":[],"tail":" and this section—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd176fcc-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4556/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “State” means any of the several States, the District of Columbia, the Commonwealth of Puerto Rico, or any other territory or possession of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd176fcd-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4556/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Member” means a Member of the House of Representatives, the Delegates from the District of Columbia, Guam, and the Virgin Islands, and the Resident Commissioner from Puerto Rico; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd176fce-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4556/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “legislative days” does not include any calendar day on which the House of Representatives is not in session.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd176fcf-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/440/tII/s101"},"text":"Pub. L. 94–440, title II, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-01"},"text":"Oct. 1, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1448"},"text":"90 Stat. 1448","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd176fd0-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd176fd1-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd176fd2-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s60e–1b"},"text":"section 60e–1b of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is based on section 2 of House Resolution No. 732, Ninety-fourth Congress, ","children":[{"tag":"date","attrib":{"date":"1975-11-04"},"text":"Nov. 4, 1975","children":[],"tail":", which was enacted into permanent law by "},{"tag":"ref","attrib":{"href":"/us/pl/94/440"},"text":"Pub. L. 94–440","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
