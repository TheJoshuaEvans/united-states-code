{"tag":"section","attrib":{"id":"iddce7ad80-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1823a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1823a"},"text":"§ 1823a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of real property for Library of Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddce7ad81-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1823a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permitting leasing of space","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the availability of funds, the Architect of the Capitol may acquire real property by lease for the use of the Library of Congress in any State or the District of Columbia if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce7ad82-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1823a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Architect of the Capitol and the Librarian of Congress submit a joint request for the Architect to lease the property to the Joint Committee on the Library and to the Committees on Appropriations of the House of Representatives and Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce7ad83-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1823a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Joint Committee on the Library and the Committees on Appropriations of the House of Representatives and Senate each approve the request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce7ad84-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1823a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the approval of the Joint Committee on the Library and the Committees on Appropriations of the House of Representatives and the Senate, the Architect of the Capitol and the Librarian of Congress may transfer between themselves appropriations or other available funds to pay the costs incurred in acquiring real property pursuant to the authority of this section and the costs of necessary expenses incurred in connection with the acquisition of the property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce7ad85-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1823a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limit on obligations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No obligation entered into pursuant to the authority of this section shall be in advance of, or in excess of, available appropriations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce7ad86-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1823a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply with respect to fiscal year 2009 and each succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddce7ad87-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/8/dG/tI/s1102"},"text":"Pub. L. 111–8, div. G, title I, § 1102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-11"},"text":"Mar. 11, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/823"},"text":"123 Stat. 823","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddce7ad88-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddce7ad89-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddce7ad8a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Legislative Branch Appropriations Act, 2009, which is div. G of the Omnibus Appropriations Act, 2009.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
