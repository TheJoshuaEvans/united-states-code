{"tag":"section","attrib":{"id":"iddd2356a7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4701"},"text":null,"children":[{"tag":"num","attrib":{"value":"4701"},"text":"§ 4701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subletting duties of employees of Senate or House","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No employee of Congress, either in the Senate or House, shall sublet to, or hire, another to do or perform any part of the duties or work attached to the position to which he was appointed.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd2356a8-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-03-02/ch177/s1"},"text":"Mar. 2, 1895, ch. 177, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/771"},"text":"28 Stat. 771","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd2356a9-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd2356aa-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd2356ab-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s101"},"text":"section 101 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
