{"tag":"section","attrib":{"id":"iddca28dbb-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s479"},"text":null,"children":[{"tag":"num","attrib":{"value":"479"},"text":"§ 479.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination of activities with National Science Foundation","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Office shall maintain a continuing liaison with the National Science Foundation with respect to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddca28dbc-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s479/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grants and contracts formulated or activated by the Foundation which are for purposes of technology assessment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca28dbd-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s479/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the promotion of coordination in areas of technology assessment, and the avoidance of unnecessary duplication or overlapping of research activities in the development of technology assessment techniques and programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddca28dbe-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/484/s10/a"},"text":"Pub. L. 92–484, § 10(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-13"},"text":"Oct. 13, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/802"},"text":"86 Stat. 802","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
