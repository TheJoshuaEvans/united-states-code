{"tag":"section","attrib":{"id":"iddd31adb9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5621"},"text":null,"children":[{"tag":"num","attrib":{"value":"5621"},"text":"§ 5621.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corrections Calendar Office","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"There is established in the House of Representatives an office to be known as the Corrections Calendar Office, which shall have the responsibility of assisting the Speaker in the management of the Corrections Calendar under the Rules of the House of Representatives. The Office shall have not more than five employees—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd31adba-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5621/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who shall be appointed by the Speaker, in consultation with the minority leader; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd31adbb-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5621/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose annual rate of pay shall be established by the Speaker, but may not exceed 75 percent of the maximum annual rate under the general limitation specified by the order of the Speaker in effect under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s4532"},"text":"section 4532 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd31adbc-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/55/tI/s101"},"text":"Pub. L. 105–55, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-10-07"},"text":"Oct. 7, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1183"},"text":"111 Stat. 1183","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd31adbd-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd31adbe-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd31adbf-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s74d"},"text":"section 74d of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is based on House Resolution No. 7, One Hundred Fifth Congress, ","children":[{"tag":"date","attrib":{"date":"1997-01-07"},"text":"Jan. 7, 1997","children":[],"tail":", which was enacted into permanent law by "},{"tag":"ref","attrib":{"href":"/us/pl/105/55"},"text":"Pub. L. 105–55","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
