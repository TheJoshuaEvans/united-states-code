{"tag":"section","attrib":{"id":"iddc884eeb-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s152"},"text":null,"children":[{"tag":"num","attrib":{"value":"152"},"text":"§ 152.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Care and use of Smithsonian Library","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Smithsonian Institution shall have the use of the library referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s151"},"text":"section 151 of this title","children":[],"tail":" in like manner as before its removal. All the books, maps, and charts of the Smithsonian Library shall be properly cared for and preserved in like manner as are those of the Congressional Library; from which the Smithsonian Library shall not be removed except on reimbursement by the Smithsonian Institution to the Treasury of the United States of expenses incurred in binding and in taking care of the same, or upon such terms and conditions as shall be mutually agreed upon by Congress and the Regents of the Institution."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc884eec-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(R.S. § 100.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc884eed-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc884eee-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddc884eef-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 100 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1866-04-