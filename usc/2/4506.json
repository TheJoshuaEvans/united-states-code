{"tag":"section","attrib":{"id":"iddd128db2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4506"},"text":null,"children":[{"tag":"num","attrib":{"value":"4506"},"text":"§ 4506.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Death gratuity payments as gifts","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any death gratuity payment at any time specifically appropriated by any Act of Congress or at any time made out of the applicable accounts of the House of Representatives or the contingent fund of the Senate shall be held to have been a gift.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd128db3-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-05/ch369"},"text":"June 5, 1952, ch. 369","children":[],"tail":", Ch. I, "},{"tag":"ref","attrib":{"href":"/us/stat/66/101"},"text":"66 Stat. 101","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/186/tII/s203/6"},"text":"Pub. L. 104–186, title II, § 203(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1725"},"text":"110 Stat. 1725","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd128db4-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd128db5-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd128db6-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified identically to sections 38b and 125a of this title. Section 38b was omitted from the Code and section 125a was editorially reclassified and renumbered as this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd128db7-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186"},"text":"Pub. L. 104–186","children":[],"tail":" substituted “applicable accounts of the House of Representatives or the contingent fund” for “contingent fund of the House of Representatives or”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
