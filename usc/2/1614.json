{"tag":"section","attrib":{"id":"iddce2f2bd-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1614"},"text":null,"children":[{"tag":"num","attrib":{"value":"1614"},"text":"§ 1614.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual audits and reports by Comptroller General","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddce2f2be-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1614/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On an annual basis, the Comptroller General shall audit the extent of compliance or noncompliance with the requirements of this chapter by lobbyists, lobbying firms, and registrants through a random sampling of publicly available lobbying registrations and reports filed under this chapter during each calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce2f2bf-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1614/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce2f2c0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1614/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than April 1 of each year, the Comptroller General shall submit to the Congress a report on the review required by subsection (a) for the preceding calendar year. The report shall include the Comptroller General’s assessment of the matters required to be emphasized by that subsection and any recommendations of the Comptroller General to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddce2f2c1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1614/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the compliance by lobbyists, lobbying firms, and registrants with the requirements of this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce2f2c2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1614/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the Department of Justice with the resources and authorities needed for the effective enforcement of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce2f2c3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1614/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment of compliance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The annual report under paragraph (1) shall include an assessment of compliance by registrants with the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1603/b/3"},"text":"section 1603(b)(3) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce2f2c4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1614/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Comptroller General may, in carrying out this section, request information from and access to any relevant documents from any person registered under paragraph (1) or (2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1603/a"},"text":"section 1603(a) of this title","children":[],"tail":" and each employee who is listed as a lobbyist under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1603/b/6"},"text":"section 1603(b)(6) of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1604/b/2/C"},"text":"section 1604(b)(2)(C) of this title","children":[],"tail":" if the material requested relates to the purposes of this section. The Comptroller General may request such person to submit in writing such information as the Comptroller General may prescribe. The Comptroller General may notify the Congress in writing if a person from whom information has been requested under this subsection refuses to comply with the request within 45 days after the request is made."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddce2f2c5-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/65/s26"},"text":"Pub. L. 104–65, § 26","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/81/tII/s213/a"},"text":"Pub. L. 110–81, title II, § 213(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-09-14"},"text":"Sept. 14, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/750"},"text":"121 Stat. 750","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddce2f2c6-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddce2f2c7-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddce2f2c8-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a) and (b)(1), was in the original “this Act” meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/65"},"text":"Pub. L. 104–65","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-19"},"text":"Dec. 19, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/691"},"text":"109 Stat. 691","children":[],"tail":", known as the Lobbying Disclosure Act of 1995. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1601"},"text":"section 1601 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddce2f2c9-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddce2f2ca-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/81/tII/s213/b"},"text":"Pub. L. 110–81, title II, § 213(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-09-14"},"text":"Sept. 14, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/750"},"text":"121 Stat. 750","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/81/tII/s213/b"},"text":"“The initial audit under subsection (a) of section 26 of the Lobbying Disclosure Act of 1995 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1614/a"},"text":"2 U.S.C. 1614(a)","children":[],"tail":"] (as added by subsection (a) of this section) shall be made with respect to lobbying registrations and reports filed during the first calendar quarter of 2008, and the initial report under subsection (b) of such section shall be filed, with respect to those registrations and reports, not later than 6 months after the end of that calendar quarter.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
