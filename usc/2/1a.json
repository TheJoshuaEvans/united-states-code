{"tag":"section","attrib":{"id":"iddc6e1000-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1a"},"text":"§ 1a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election to be certified by governor","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It shall be the duty of the executive of the State from which any Senator has been chosen to certify his election, under the seal of the State, to the President of the Senate of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc6e1001-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(R.S. § 18.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc6e1002-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc6e1003-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddc6e1004-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 18 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1866-07-25/ch245/s3"},"text":"act July 25, 1866, ch. 245, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/14/244"},"text":"14 Stat. 244","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
