{"tag":"section","attrib":{"id":"iddcf60485-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1965a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1965a"},"text":"§ 1965a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on use of funds for installation of permanent fencing on Capitol Grounds","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"None of the funds made available in this or any other Act in prior fiscal years, this fiscal year, or any fiscal year thereafter may be used to install permanent, above-ground fencing around the perimeter, or any portion thereof, of the United States Capitol Grounds, as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s5102"},"text":"section 5102 of title 40","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddcf60486-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/31/tIII/s310"},"text":"Pub. L. 117–31, title III, § 310","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-07-30"},"text":"July 30, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/314"},"text":"135 Stat. 314","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
