{"tag":"section","attrib":{"id":"iddca748eb-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s613"},"text":null,"children":[{"tag":"num","attrib":{"value":"613"},"text":"§ 613.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of senior level positions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddca748ec-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s613/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding the fourth sentence of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s601/b"},"text":"section 601(b) of this title","children":[],"tail":", the Director of the Congressional Budget Office may establish and fix the compensation of senior level positions in the Congressional Budget Office to meet critical scientific, technical, professional, or executive needs of the Office."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca748ed-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s613/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The annual rate of pay for any position established under this section may not exceed the annual rate of pay for level II of the Executive Schedule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca748ee-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s613/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply with respect to fiscal year 2017 and each succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddca748ef-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/31/dI/tI/s1101"},"text":"Pub. L. 115–31, div. I, title I, § 1101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-05-05"},"text":"May 5, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/578"},"text":"131 Stat. 578","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddca748f0-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddca748f1-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddca748f2-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Level II of the Executive Schedule, referred to in subsec. (b), is set out in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"section 5313 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddca748f3-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Legislative Branch Appropriations Act, 2017, which is div. I of the Consolidated Appropriations Act, 2017, and not as part of title II of the Congressional Budget and Impoundment Control Act of 1974 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
