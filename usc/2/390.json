{"tag":"section","attrib":{"id":"iddca01c56-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s390"},"text":null,"children":[{"tag":"num","attrib":{"value":"390"},"text":"§ 390.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty for failure to appear, testify, or produce documents","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Every person who, having been subpenaed as a witness under this chapter to give testimony or to produce documents, willfully makes default, or who, having appeared, refuses to answer any question pertinent to the contested election case, shall be deemed guilty of a misdemeanor punishable by fine of not more than $1,000 nor less than $100 or imprisonment for not less than one month nor more than twelve months, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddca01c57-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/138/s11"},"text":"Pub. L. 91–138, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-05"},"text":"Dec. 5, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/288"},"text":"83 Stat. 288","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddca01c58-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddca01c59-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddca01c5a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable with respect to any general or special election for Representative in, or Resident Commissioner to, the Congress of the United States occurring after ","children":[{"tag":"date","attrib":{"date":"1969-12-05"},"text":"Dec. 5, 1969","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/138/s19"},"text":"section 19 of Pub. L. 91–138","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s381"},"text":"section 381 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
