":[{"tag":"ref","attrib":{"href":"/us/pl/97/12/tI/s107"},"text":"Pub. L. 97–12, title I, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-06-05"},"text":"June 5, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/62"},"text":"95 Stat. 62","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
