{"tag":"section","attrib":{"id":"iddd3b24df-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6562"},"text":null,"children":[{"tag":"num","attrib":{"value":"6562"},"text":"§ 6562.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers of funds by Secretary of Senate; approval of Committee on Appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"During any fiscal year (commencing with the fiscal year beginning ","children":[{"tag":"date","attrib":{"date":"1982-10-01"},"text":"October 1, 1982","children":[],"tail":") the Secretary of the Senate is authorized to make such transfers between appropriations of funds available for disbursement by him during such year, subject to the approval of the Committee on Appropriations of the Senate."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd3d94e0-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/276/s101/e"},"text":"Pub. L. 97–276, § 101(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-02"},"text":"Oct. 2, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1189"},"text":"96 Stat. 1189","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd3d94e1-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd3d94e2-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd3d94e3-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","a