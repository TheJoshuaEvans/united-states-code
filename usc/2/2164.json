{"tag":"section","attrib":{"id":"iddd06a6c2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2164"},"text":null,"children":[{"tag":"num","attrib":{"value":"2164"},"text":"§ 2164.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation of House Pages by Capitol Grounds shuttle service","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The passenger motor vehicles authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s2163"},"text":"section 2163 of this title","children":[],"tail":" to provide a shuttle service for Members and employees of Congress may be used for the transportation of House Pages to and from special events associated with their education when approved by the House of Representatives Page Board: "},{"tag":"i","attrib":{},"text":"Provided further","children":[],"tail":", That the use of the said passenger motor vehicles for transportation of House Pages shall not interfere with the shuttle service for Members and employees of the Congress."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd06a6c3-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/151/tI"},"text":"Pub. L. 99–151, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-13"},"text":"Nov. 13, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/801"},"text":"99 Stat. 801","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd06a6c4-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd06a6c5-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd06a6c6-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was classified to section 224 of former Title 40, prior to the enactment of Title 40, Public Buildings, Property, and Works, by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217/s1"},"text":"Pub. L. 107–217, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1062"},"text":"116 Stat. 1062","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
