{"tag":"section","attrib":{"id":"iddd31ad7b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5591"},"text":null,"children":[{"tag":"num","attrib":{"value":"5591"},"text":"§ 5591.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Media support services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd31ad7c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5591/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support services for presidential nominating conventions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The responsibilities of positions under the House Press Gallery, the House Periodical Press Gallery, and the House Radio and Television Correspondents’ Gallery shall include providing media support services with respect to the presidential nominating conventions of the national committees of political parties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd31ad7d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5591/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements with national committees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Standing Committee of Correspondents may enter into agreements with national committees of political parties under which the committees and persons authorized by the committees may reimburse employees for necessary expenses incurred in carrying out the responsibilities described in subsection (a) and employees may accept such reimbursement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd31ad7e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5591/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms and conditions under which employees exercise responsibilities under subsection (a), and the terms and conditions of any agreement entered into under subsection (b), shall be subject to the approval of the Chief Administrative Officer of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd31ad7f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5591/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the terms “national committee” and “political party” have the meaning given such terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s30101"},"text":"section 30101 of title 52","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd31ad80-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/289/dB/tII/s20702/b"},"text":"Pub. L. 109–289, div. B, title II, § 20702(b)","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/5/s2"},"text":"Pub. L. 110–5, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-02-15"},"text":"Feb. 15, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/38"},"text":"121 Stat. 38","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd31ad81-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd31ad82-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd31ad83-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 130","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Continuing Appropriations Resolution, 2007, which is div. B of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/289"},"text":"Pub. L. 109–289","children":[],"tail":", and is based on section 107 of title I of H.R. 5521, as passed by the House of Representatives on "},{"tag":"date","attrib":{"date":"2006-06-07"},"text":"June 7, 2006","children":[],"tail":", which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/109/289/s20702/b"},"text":"section 20702(b) of Pub. L. 109–289","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/110/5"},"text":"Pub. L. 110–5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
