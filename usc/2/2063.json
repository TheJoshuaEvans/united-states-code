{"tag":"section","attrib":{"id":"iddcff7a0f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2063"},"text":null,"children":[{"tag":"num","attrib":{"value":"2063"},"text":"§ 2063.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Senate Employee Child Care Center","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcff7a10-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2063/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of this section shall apply to any individual who is employed by the Senate day care center (known as the “Senate Employee Child Care Center” and hereafter in this section referred to as the “Center”) established pursuant to Senate Resolution 269, Ninety-eighth Congress, and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s2061"},"text":"section 2061 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcff7a11-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2063/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employee election of health care insurance coverage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any individual described under subsection (a) who is employed by the Center on or after ","children":[{"tag":"date","attrib":{"date":"1991-08-14"},"text":"August 14, 1991","children":[],"tail":", shall be deemed an employee under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8901/1"},"text":"section 8901(1) of title 5","children":[],"tail":" for purposes of health insurance coverage under chapter 89 of such title. An individual described under subsection (a) who is an employee of the Center on "},{"tag":"date","attrib":{"date":"1991-08-14"},"text":"August 14, 1991","children":[],"tail":", may elect coverage under this subsection during the 31-day period beginning on "},{"tag":"date","attrib":{"date":"1991-08-14"},"text":"August 14, 1991","children":[],"tail":", and during such periods as determined by the Office of Personnel Management for employees of the Center employed after "},{"tag":"date","attrib":{"date":"1991-08-14"},"text":"August 14, 1991","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcff7a12-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2063/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deductions and withholding from employee pay","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Center shall make such deductions and withholdings from the pay of an individual described under subsection (a) who is an employee of the Center in accordance with subsection (d) of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcff7a13-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2063/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employee records; amount of deductions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Center shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcff7a14-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2063/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain records on all employees covered under this section in such manner as the Secretary of the Senate may require for administrative purposes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcff7a15-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2063/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" after consultation with the Secretary of the Senate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcff7a16-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2063/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make deductions from the pay of employees of amounts determined in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8906"},"text":"section 8906 of title 5","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcff7a17-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2063/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transmit such deductions to the Secretary of the Senate for deposit and remittance to the Office of Personnel Management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcff7a18-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2063/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Government contributions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Government contributions for individuals receiving benefits under this section, as computed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8906"},"text":"section 8906 of title 5","children":[],"tail":", shall be made by the Secretary of the Senate from the appropriations account, within the contingent fund of the Senate, “miscellaneous items”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcff7a19-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2063/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office of Personnel Management may prescribe regulations to carry out the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcff7a1a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/90/tIII/s311"},"text":"Pub. L. 102–90, title III, § 311","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-14"},"text":"Aug. 14, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/467"},"text":"105 Stat. 467","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcff7a1b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcff7a1c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddcff7a1d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For Senate Resolution 269, referred to in subsec. (a), see References in Text note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s2061"},"text":"section 2061 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddcff7a1e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was classified to section 214c of former Title 40, prior to the enactment of Title 40, Public Buildings, Property, and Works, by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217/s1"},"text":"Pub. L. 107–217, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1062"},"text":"116 Stat. 1062","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcff7a1f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddcff7a20-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Source of Funds Used for Payment of Salaries and Expenses of Senate Employee Child Care Center","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/dB/tIX/s19001"},"text":"Pub. L. 116–136, div. B, title IX, § 19001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/577"},"text":"134 Stat. 577","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dO/tXI/s1101/a"},"text":"Pub. L. 116–260, div. O, title XI, § 1101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2156"},"text":"134 Stat. 2156","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/260/dO/tXI/s1101/a"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"During the period beginning on ","children":[{"tag":"date","attrib":{"date":"2020-07-01"},"text":"July 1, 2020","children":[],"tail":" and ending on the termination date of the public health emergency declared pursuant to section 319 of the Public Health Service Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s247d"},"text":"42 U.S.C. 247d","children":[],"tail":") resulting from the COVID–19 pandemic, the Secretary of the Senate shall reimburse the Senate Employee Child Care Center for expenses, due to measures taken in the Capitol complex to combat coronavirus, as calculated under subsection (b) and from amounts in the appropriations account ‘Miscellaneous Items’ within the contingent fund of the Senate."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of the reimbursement under this section for each month of the period described in subsection (a) shall be equal to the difference between—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the lesser of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the operating costs (including payroll, general, and administrative expenses) of the Center for such month; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $105,000; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of tuition payments collected by the Center for such month.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definition of “coronavirus” as used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/s19001"},"text":"section 19001 of Pub. L. 116–136","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/136/s23005"},"text":"section 23005 of Pub. L. 116–136","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s162b"},"text":"section 162b of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
