{"tag":"section","attrib":{"id":"iddd20e58f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4575a"},"text":null,"children":[{"tag":"num","attrib":{"value":"4575a"},"text":"§ 4575a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Change in maximum rates of pay for statutory employees","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd20e590-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4575a/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fixed salary positions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For any position for which the Secretary of the Senate disburses the pay for the position and for which the specific amount of the rate of pay for the particular position is fixed by statute on the day before the effective date of the amendments made by this section, on and after such effective date the amount of the rate of pay for such position shall be fixed by the President pro tempore in an amount not to exceed the maximum rate of pay in effect under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s4575/f"},"text":"section 4575(f) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd20e591-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4575a/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Positions with maximums","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For any position for which the Secretary of the Senate disburses the pay for the position and for which the maximum rate of pay for the particular position is fixed by statute on the day before the effective date of the amendments made by this section, on and after such effective date the maximum rate of pay for such position shall be fixed by the President pro tempore, which shall not exceed the maximum rate of pay in effect under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s4575/f"},"text":"section 4575(f) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd20e592-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/dE/tII/s212/a/1/B"},"text":"Pub. L. 116–94, div. E, title II, § 212(a)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2774"},"text":"133 Stat. 2774","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd20e593-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd20e594-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd20e595-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The effective date of the amendments made by this section, referred to in text, is the effective date of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s212"},"text":"section 212 of Pub. L. 116–94","children":[],"tail":", which is set out in a note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd20e596-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd20e597-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the later of the first day of the first applicable pay period beginning on or after ","children":[{"tag":"date","attrib":{"date":"2020-01-01"},"text":"Jan. 1, 2020","children":[],"tail":", or the first day of the first applicable pay period beginning on or after "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/116/94/s212/c"},"text":"section 212(c) of Pub. L. 116–94","children":[],"tail":", set out as an Effective Date of 2019 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s282b"},"text":"section 282b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
