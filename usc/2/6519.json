{"tag":"section","attrib":{"id":"iddd3b2457-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6519"},"text":null,"children":[{"tag":"num","attrib":{"value":"6519"},"text":"§ 6519.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" McCain-Mansfield and SFC Sean Cooley and SPC Christopher Horton Congressional Gold Star Family Fellowships Programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd3b2458-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6519/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd3b2459-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6519/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “appropriate committees of the Senate” means the Committee on Appropriations and the Committee on Rules and Administration of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3b245a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6519/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Fellowships Programs” means the SFC Sean Cooley and SPC Christopher Horton Congressional Gold Star Family Fellowship Program (commonly referred to as the “Green and Gold Congressional Aide Program”) established under Senate Resolution 442 (117th Congress), agreed to ","children":[{"tag":"date","attrib":{"date":"2021-11-04"},"text":"November 4, 2021","children":[],"tail":", and the McCain-Mansfield Fellowship Program established under Senate Resolution 443 (117th Congress), agreed to "},{"tag":"date","attrib":{"date":"2021-11-04"},"text":"November 4, 2021","children":[],"tail":", or any successor program to such programs;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3b245b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6519/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Fund” means the Sergeant at Arms Fellowships Fund established under subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3b245c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6519/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Sergeant at Arms” means the Sergeant at Arms and Doorkeeper of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3b245d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6519/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established under the heading “","children":[{"tag":"inline","attrib":{},"text":"Contingent Expenses of the Senate","children":[],"tail":"” an account to be known as the “"},{"tag":"inline","attrib":{},"text":"sergeant at arms fellowships fund","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3b245e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6519/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of amounts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd3b245f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6519/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts in the Fund shall be available to the Sergeant at Arms for the costs of compensation of fellows under the Fellowships Programs and the administration of the Fellowships Programs, except as provided in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3b2460-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6519/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency contributions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Agency contributions for the Fellowships Programs shall be paid from the appropriations account for “Salaries, Officers and Employees” of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3b2461-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6519/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oversight","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Sergeant at Arms shall provide to the appropriate committees of the Senate—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd3b2462-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6519/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan regarding the administration of the Fund by the Sergeant at Arms prior to obligation of any funds, to be updated and resubmitted following any changes to the plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3b2463-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6519/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" annual reports regarding the costs of the Fellowships Programs paid from the Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3b2464-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6519/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Fund for fiscal year 2023, and each fiscal year thereafter, such sums as are necessary for the compensation of fellows under the Fellowships Programs during the fiscal year and for the administration of the Fellowships Programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3b2465-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6519/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion for purposes of staffing limits on the Office of the Sergeant at Arms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The payment of compensation to any individual serving in a fellowship under the Fellowships Programs by the Sergeant at Arms shall not be included for purposes of any limitation on staffing levels of the Office of the Sergeant at Arms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd3b2466-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dI/tI/s102"},"text":"Pub. L. 117–328, div. I, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4917"},"text":"136 Stat. 4917","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd3b2467-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd3b2468-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd3b2469-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Senate Resolution 442 (117th Congress), agreed to ","children":[{"tag":"date","attrib":{"date":"2021-11-04"},"text":"November 4, 2021","children":[],"tail":", and Senate Resolution 443 (117th Congress), agreed to "},{"tag":"date","attrib":{"date":"2021-11-04"},"text":"November 4, 2021","children":[],"tail":", referred to in subsec. (a)(2), which established the SFC Sean Cooley and SPC Christopher Horton Congressional Gold Star Family Fellowship Program for family members of members of the Armed Forces who die in the line of duty or of veterans who die of service-connected injuries and the McCain-Mansfield Fellowship Program for wounded or disabled veterans, are not classified to the Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
