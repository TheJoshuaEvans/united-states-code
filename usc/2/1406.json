{"tag":"section","attrib":{"id":"iddcdbc56d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1406"},"text":null,"children":[{"tag":"num","attrib":{"value":"1406"},"text":"§ 1406.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appeal to Board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcdbc56e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1406/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any party aggrieved by the decision of a hearing officer under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1405/g"},"text":"section 1405(g) of this title","children":[],"tail":" may file a petition for review by the Board not later than 30 days after entry of the decision in the records of the Office."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcdbc56f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1406/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Parties’ opportunity to submit argument","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The parties to the hearing upon which the decision of the hearing officer was made shall have a reasonable opportunity to be heard, through written submission and, in the discretion of the Board, through oral argument.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcdbc570-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1406/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standard of review","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall set aside a decision of a hearing officer if the Board determines that the decision was—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcdbc571-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1406/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" arbitrary, capricious, an abuse of discretion, or otherwise not consistent with law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcdbc572-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1406/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not made consistent with required procedures; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcdbc573-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1406/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unsupported by substantial evidence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcdbc574-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1406/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Record","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making determinations under subsection (c), the Board shall review the whole record, or those parts of it cited by a party, and due account shall be taken of the rule of prejudicial error.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcdbc575-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1406/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Decision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall issue a written decision setting forth the reasons for its decision. The decision may affirm, reverse, or remand to the hearing officer for further proceedings. A decision that does not require further proceedings before a hearing officer shall be entered in the records of the Office as a final decision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcdbc576-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/1/tIV/s406"},"text":"Pub. L. 104–1, title IV, § 406","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-01-23"},"text":"Jan. 23, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/35"},"text":"109 Stat. 35","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
