{"tag":"section","attrib":{"id":"iddd3fdedd-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6618"},"text":null,"children":[{"tag":"num","attrib":{"value":"6618"},"text":"§ 6618.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data processing equipment, software, and services","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the Sergeant at Arms, subject to the approval of the Committee on Rules and Administration, is hereafter authorized to enter into multi-year contracts for data processing equipment, software, and services.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd3fdede-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/32/tI"},"text":"Pub. L. 94–32, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-06-12"},"text":"June 12, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/182"},"text":"89 Stat. 182","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/26/tI/s103"},"text":"Pub. L. 95–26, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-05-04"},"text":"May 4, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/82"},"text":"91 Stat. 82","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd3fdedf-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd3fdee0-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd3fdee1-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s123c"},"text":"section 123c of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Second Supplemental Appropriations Act, 1975.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd3fdee2-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1977—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/26"},"text":"Pub. L. 95–26","children":[],"tail":" substituted “multi-year contracts for data processing equipment, software, and services” for “multi-year leases for automatic data processing equipment”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
