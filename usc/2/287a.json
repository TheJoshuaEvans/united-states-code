{"tag":"section","attrib":{"id":"iddc96a6c9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s287a"},"text":null,"children":[{"tag":"num","attrib":{"value":"287a"},"text":"§ 287a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Parliamentarian","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The management, supervision, and administration of the Office shall be vested in the Parliamentarian, who shall be appointed by the Speaker of the House of Representatives without regard to political affiliation and solely on the basis of fitness to perform the duties of the position. Any person so appointed shall serve at the pleasure of the Speaker.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc96a6ca-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/94/tI/s115"},"text":"Pub. L. 95–94, title I, § 115","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-05"},"text":"Aug. 5, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/668"},"text":"91 Stat. 668","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc96a6cb-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc96a6cc-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddc96a6cd-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is based on section 2 of House Resolution No. 502, Ninety-fifth Congress, ","children":[{"tag":"date","attrib":{"date":"1977-04-20"},"text":"Apr. 20, 1977","children":[],"tail":", which was enacted into permanent law by "},{"tag":"ref","attrib":{"href":"/us/pl/95/94"},"text":"Pub. L. 95–94","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
