{"tag":"section","attrib":{"id":"iddc884ebc-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s145"},"text":null,"children":[{"tag":"num","attrib":{"value":"145"},"text":"§ 145.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Copies of journals and documents","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Two copies of the journals and documents, and of each book printed by either House of Congress, well bound in calf, shall be deposited in the Library, and must not be taken therefrom.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc884ebd-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(R.S. § 97.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc884ebe-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc884ebf-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddc884ec0-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 97 derived from Res. ","children":[{"tag":"date","attrib":{"date":"1857-01-02"},"text":"Jan. 2, 1857","children":[],"tail":", No. 5, § 5, "},{"tag":"ref","attrib":{"href":"/us/stat/11/253"},"text":"11 Stat. 253","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
