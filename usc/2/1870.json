{"tag":"section","attrib":{"id":"iddcec67e5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1870"},"text":null,"children":[{"tag":"num","attrib":{"value":"1870"},"text":"§ 1870.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" House Historic Buildings Revitalization Trust Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcec67e6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1870/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby established in the Treasury of the United States, as an account for the Architect of the Capitol, the House Historic Buildings Revitalization Trust Fund (hereafter in this section referred to as the “Fund”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcec67e7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1870/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts in the Fund shall be used by the Architect of the Capitol for the revitalization of the major historical buildings and assets of the House of Representatives which the Architect is responsible for maintaining and preserving, except that the Architect may not obligate any amounts in the Fund without the approval of the Committee on Appropriations of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcec67e8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1870/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuing availability of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amounts transferred to and merged with, or otherwise deposited into, the Fund shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcec67e9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1870/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcec67ea-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1870/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section and the amendment made by this section shall apply with respect to fiscal year 2010 and each succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcec67eb-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/68/dA/tI/s1304"},"text":"Pub. L. 111–68, div. A, title I, § 1304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2035"},"text":"123 Stat. 2035","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcec67ec-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcec67ed-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddcec67ee-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/68/s1304"},"text":"section 1304 of Pub. L. 111–68","children":[],"tail":". Subsec. (d) of "},{"tag":"ref","attrib":{"href":"/us/pl/111/68/s1304"},"text":"section 1304 of Pub. L. 111–68","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s5507"},"text":"section 5507 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Legislative Branch Appropriations Act, 2010, which is div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/68"},"text":"Pub. L. 111–68","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
