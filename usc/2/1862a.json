{"tag":"section","attrib":{"id":"iddcea1ea6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1862a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1862a"},"text":"§ 1862a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of construction project funds to reimburse Capitol Police for related overtime costs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcea1ea7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1862a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of overtime costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Architect of the Capitol shall transfer amounts made available for construction projects during a fiscal year to the applicable appropriations accounts of the United States Capitol Police in order to reimburse the Capitol Police for overtime costs incurred in connection with such projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcea1ea8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1862a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply with respect to fiscal year 2013 and each succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcea1ea9-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/74/dG/tI/s1201"},"text":"Pub. L. 112–74, div. G, title I, § 1201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-23"},"text":"Dec. 23, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1128"},"text":"125 Stat. 1128","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcea1eaa-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcea1eab-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddcea1eac-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Legislative Branch Appropriations Act, 2012, which is div. G of the Consolidated Appropriations Act, 2012.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
