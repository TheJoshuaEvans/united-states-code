{"tag":"section","attrib":{"id":"iddccfdf95-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161"},"text":null,"children":[{"tag":"num","attrib":{"value":"1161"},"text":"§ 1161.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bill Emerson National Hunger Fellows and Mickey Leland International Hunger Fellows","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddccfdf96-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short title","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section may be cited as the “Bill Emerson National Hunger Fellows and Mickey Leland International Hunger Fellows Program Act of 2008”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddccfdf97-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection: ","children":[{"tag":"ref","attrib":{"idref":"fn002054"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002054"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “section:”."}],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddccfdf98-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Director” means the head of the Congressional Hunger Center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddccfdf99-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fellow","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “fellow” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddccfdf9a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Bill Emerson Hunger Fellow; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddccfdf9b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Mickey Leland Hunger Fellow.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddccfdf9c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fellowship Programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Fellowship Programs” means the Bill Emerson National Hunger Fellowship Program and the Mickey Leland International Hunger Fellowship Program established under subsection (c)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddccfdf9d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fellowship Programs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddccfdf9e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established the Bill Emerson National Hunger Fellowship Program and the Mickey Leland International Hunger Fellowship Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddccfdf9f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddccfdfa0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the Fellowship Programs are—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddccfdfa1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to encourage future leaders of the United States—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddccfdfa2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/c/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to pursue careers in humanitarian and public service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddccfdfa3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/c/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to recognize the needs of low-income people and hungry people;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddccfdfa4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/c/2/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide assistance to people in need; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddccfdfa5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/c/2/A/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to seek public policy solutions to the challenges of hunger and poverty;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddccfdfa6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide training and development opportunities for such leaders through placement in programs operated by appropriate organizations or entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddccfdfa7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase awareness of the importance of public service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddccfdfa8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bill Emerson Hunger Fellowship Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of the Bill Emerson Hunger Fellowship Program is to address hunger and poverty in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddccfdfa9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mickey Leland Hunger Fellowship Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of the Mickey Leland Hunger Fellowship Program is to address international hunger and other humanitarian needs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddccfdfaa-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddccfdfab-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraph (B), the Secretary shall offer to provide a grant to the Congressional Hunger Center to administer the Fellowship Programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddccfdfac-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms of grant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms of the grant provided under subparagraph (A), including the length of the grant and provisions for the alteration or termination of the grant, shall be determined by the Secretary in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddccfdfad-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fellowships","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddccfdfae-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall make available Bill Emerson Hunger Fellowships and Mickey Leland Hunger Fellowships in accordance with this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddccfdfaf-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Curriculum","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddccfdfb0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Fellowship Programs shall provide experience and training to develop the skills necessary to train fellows to carry out the purposes described in subsection (c)(2), including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddccfdfb1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training in direct service programs for the hungry and other anti-hunger programs in conjunction with community-based organizations through a program of field placement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddccfdfb2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing experience in policy development through placement in a governmental entity or nongovernmental, nonprofit, or private sector organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddccfdfb3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Work plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To carry out subparagraph (A) and assist in the evaluation of the fellowships under paragraph (6), the Director shall, for each fellow, approve a work plan that identifies the target objectives for the fellow in the fellowship, including specific duties and responsibilities relating to those objectives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddccfdfb4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of fellowship","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddccfdfb5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bill Emerson Hunger Fellow","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Bill Emerson Hunger Fellowship awarded under this section shall be for not more than 15 months.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddccfdfb6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mickey Leland Hunger Fellow","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Mickey Leland Hunger Fellowship awarded under this section shall be for not more than 2 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddccfdfb7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of fellows","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddccfdfb8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Fellowships shall be awarded pursuant to a nationwide competition established by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddccfdfb9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A successful program applicant shall be an individual who has demonstrated—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddccfdfba-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/d/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an intent to pursue a career in humanitarian services and outstanding potential for such a career;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddccfdfbb-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/d/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leadership potential or actual leadership experience;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddccfdfbc-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/d/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" diverse life experience;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddccfdfbd-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/d/4/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proficient writing and speaking skills;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddccfdfbe-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/d/4/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an ability to live in poor or diverse communities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddccfdfbf-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/d/4/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other attributes as are considered to be appropriate by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddccfdfc0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of award","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddccfdfc1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A fellow shall receive—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddccfdfc2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/d/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a living allowance during the term of the Fellowship; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddccfdfc3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/d/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to subparagraph (B), an end-of-service award.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddccfdfc4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement for successful completion of fellowship","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each fellow shall be entitled to receive an end-of-service award at an appropriate rate for each month of satisfactory service completed, as determined by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddccfdfc5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/d/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms of fellowship","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A fellow shall not be considered an employee of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddccfdfc6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/d/5/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Agriculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddccfdfc7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/d/5/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Congressional Hunger Center; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddccfdfc8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/d/5/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a host agency in the field or policy placement of the fellow.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddccfdfc9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/d/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recognition of fellowship award","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddccfdfca-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/d/5/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emerson Fellow","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual awarded a fellowship from the Bill Emerson Hunger Fellowship shall be known as an “Emerson Fellow”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddccfdfcb-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/d/5/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leland Fellow","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual awarded a fellowship from the Mickey Leland Hunger Fellowship shall be known as a “Leland Fellow”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddccfdfcc-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluations and audits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under terms stipulated in the contract entered into under subsection (c)(3), the Director shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddccfdfcd-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/d/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct periodic evaluations of the Fellowship Programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddccfdfce-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/d/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" arrange for annual independent financial audits of expenditures under the Fellowship Programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddccfdfcf-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddccfdfd0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), in carrying out this section, the Director may solicit, accept, use, and dispose of gifts, bequests, or devises of services or property, both real and personal, for the purpose of facilitating the work of the Fellowship Programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddccfdfd1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Gifts, bequests, or devises of money and proceeds from sales of other property received as gifts, bequests, or devises shall be used exclusively for the purposes of the Fellowship Programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddccfdfd2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall annually submit to the Secretary of Agriculture, the Committee on Agriculture of the House of Representatives, and the Committee on Agriculture, Nutrition, and Forestry of the Senate a report that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddccfdfd3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the activities and expenditures of the Fellowship Programs during the preceding fiscal year, including expenditures made from funds made available under subsection (g); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddccfdfd4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes the results of evaluations and audits required by subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddccfdfd5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1161/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary such sums as are necessary to carry out this section, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddccfdfd6-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tIV/s4404"},"text":"Pub. L. 107–171, title IV, § 4404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/335"},"text":"116 Stat. 335","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/161/dH/tI/s1502/c"},"text":"Pub. L. 110–161, div. H, title I, § 1502(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2250"},"text":"121 Stat. 2250","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tIV/s4401"},"text":"Pub. L. 110–234, title IV, § 4401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1132"},"text":"122 Stat. 1132","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title IV, § 4401, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/1