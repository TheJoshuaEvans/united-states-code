{"tag":"section","attrib":{"id":"iddc91ec17-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s186"},"text":null,"children":[{"tag":"num","attrib":{"value":"186"},"text":"§ 186.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Library of Congress orders under task and delivery order contracts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc91ec18-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s186/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract modifications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An order issued under a task order contract or a delivery order contract (as such terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s4101"},"text":"section 4101 of title 41","children":[],"tail":") entered into by the Librarian of Congress may not increase the scope, period, or maximum value of the contract under which the order is issued. The scope, period, or maximum value of the contract may be increased only by modification of the contract."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc91ec19-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s186/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc91ec1a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s186/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protests","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc91ec1b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s186/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protest not authorized","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A protest to an order described in subsection (a) filed pursuant to the procedures in subchapter V of chapter 35 of title 31 is not authorized unless such protest—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc91ec1c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s186/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an objection on the basis that the order is in violation of subsection (a); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc91ec1d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s186/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" concerns an order valued in excess of $10,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc91ec1e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s186/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction over protests","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3556"},"text":"section 3556 of title 31","children":[],"tail":", the Comptroller General shall have exclusive jurisdiction of a protest authorized under paragraph (1)(B)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc91ec1f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s186/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section and the amendment made by this section shall apply with respect to fiscal year 2022 and each succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc91ec20-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/dI/tI/s142"},"text":"Pub. L. 117–103, div. I, title I, § 142","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/519"},"text":"136 Stat. 519","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc91ec21-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc91ec22-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddc91ec23-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/dI/s142"},"text":"section 142 of div. I of Pub. L. 117–103","children":[],"tail":". Subsec. (b) of "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dI/s142"},"text":"section 142 of div. I of Pub. L. 117–103","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s6102"},"text":"section 6102 of Title 41","children":[],"tail":", Public Contracts."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
