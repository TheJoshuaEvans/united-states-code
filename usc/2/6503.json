{"tag":"section","attrib":{"id":"iddd38b2d6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6503"},"text":null,"children":[{"tag":"num","attrib":{"value":"6503"},"text":"§ 6503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments from Senate contingent fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No payment shall be made from the contingent fund of the Senate unless sanctioned by the Committee on Rules and Administration of the Senate. Payments made upon vouchers or abstracts of disbursements of salaries approved by said Committee shall be deemed, held, and taken, and are declared to be conclusive upon all the departments and officers of the Government: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That no payment shall be made from said contingent fund as additional salary or compensation to any officer or employee of the Senate."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd38b2d7-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1888-10-02/ch1069"},"text":"Oct. 2, 1888, ch. 1069","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/25/546"},"text":"25 Stat. 546","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1946-08-02/ch753"},"text":"Aug. 2, 1946, ch. 753","children":[],"tail":", title I, § 102, "},{"tag":"ref","attrib":{"href":"/us/stat/60/814"},"text":"60 Stat. 814","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/554/tI"},"text":"Pub. L. 93–554, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-12-27"},"text":"Dec. 27, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1776"},"text":"88 Stat. 1776","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/186/tI/s105/c"},"text":"Pub. L. 104–186, title I, § 105(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1722"},"text":"110 Stat. 1722","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd38b2d8-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd38b2d9-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd38b2da-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s68"},"text":"section 68 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is based on provisions of last par. on ","children":[{"tag":"ref","attrib":{"href":"/us/stat/25/546"},"text":"25 Stat. 546","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/act/1888-10-02/ch1069"},"text":"act of Oct. 2, 1888, ch. 1069","children":[],"tail":", relating to payments from contingent fund of Senate. Provisions of that par. relating to payments from contingent fund of House of Representatives were classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s95"},"text":"section 95 of this title","children":[],"tail":" prior to being struck out by "},{"tag":"ref","attrib":{"href":"/us/pl/104/186"},"text":"Pub. L. 104–186","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd38b2db-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1974—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/554"},"text":"Pub. L. 93–554","children":[],"tail":" inserted provision relating to applicability to payments made upon abstracts of disbursements of salaries."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1946—Act ","children":[{"tag":"date","attrib":{"date":"1946-08-02"},"text":"Aug. 2, 1946","children":[],"tail":", substituted “Committee on Rules and Administration” for “Committee to Audit and Control Contingent Expenses”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd38b2dc-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd38b2dd-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1974 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/554/tI"},"text":"Pub. L. 93–554, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-12-27"},"text":"Dec. 27, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1776"},"text":"88 Stat. 1776","children":[],"tail":", provided in part that the amendment made by "},{"tag":"ref","attrib":{"href":"/us/pl/93/554"},"text":"Pub. L. 93–554","children":[],"tail":" is effective "},{"tag":"date","attrib":{"date":"1975-01-01"},"text":"Jan. 1, 1975","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd38b2de-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1946 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"tex