{"tag":"section","attrib":{"id":"iddce2f2da-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1703"},"text":null,"children":[{"tag":"num","attrib":{"value":"1703"},"text":"§ 1703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Seal of the National Recording Registry","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddce2f2db-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1703/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Librarian shall provide a seal to indicate that a sound recording has been included in the National Recording Registry and is the Registry version of that recording.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce2f2dc-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1703/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of seal","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Librarian shall establish guidelines for approval of the use of the seal provided under subsection (a), and shall include in the guidelines the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce2f2dd-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1703/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The seal may only be used on recording copies of the Registry version of a sound recording.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce2f2de-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1703/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The seal may be used only after the Librarian has given approval to those persons seeking to apply the seal in accordance with the guidelines.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce2f2df-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1703/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of copyrighted mass distributed, broadcast, or published works, only the copyright legal owner or an authorized licensee of that copyright owner may place or authorize the placement of the seal on any recording copy of the Registry version of any sound recording that is maintained in the National Recording Registry Collection in the Library of Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce2f2e0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1703/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Anyone authorized to place the seal on any recording copy of any Registry version of a sound recording may accompany such seal with the following language: “This sound recording is selected for inclusion in the National Recording Registry by the Librarian of Congress in consultation with the National Recording Preservation Board of the Library of Congress because of its cultural, historical, or aesthetic significance.”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce2f2e1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1703/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date of the seal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The use of the seal provided under subsection (a) with respect to a sound recording shall be effective beginning on the date the Librarian publishes in the Federal Register (in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1702/b"},"text":"section 1702(b) of this title","children":[],"tail":") the name of the recording, as selected for inclusion in the National Recording Registry."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce2f2e2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1703/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited uses of the seal","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce2f2e3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1703/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on distribution and exhibition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No person may knowingly distribute or exhibit to the public a version of a sound recording or any copy of a sound recording which bears the seal described in subsection (a) if such recording—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddce2f2e4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1703/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not included in the National Recording Registry; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce2f2e5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1703/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is included in the National Recording Registry but has not been approved for use of the seal by the Librarian pursuant to the guidelines established under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce2f2e6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1703/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on promotion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No person may knowingly use the seal described in subsection (a) to promote any version of a sound recording or recording copy other than a Registry version.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce2f2e7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1703/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remedies for violations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce2f2e8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1703/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The several district courts of the United States shall have jurisdiction, for cause shown, to prevent and restrain violations of subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce2f2e9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1703/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relief","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddce2f2ea-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1703/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal of seal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), relief for violation of subsection (d) shall be limited to the removal of the seal from the sound recording involved in the violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce2f2eb-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1703/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fine and injunctive relief","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a pattern or practice of the willful violation of subsection (d), the court may order a civil fine of not more than $10,000 and appropriate injunctive relief.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce2f2ec-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1703/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation of remedies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The remedies provided in this subsection shall be the exclusive remedies under this chapter, or any other Federal or State law, regarding the use of the seal described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddce2f2ed-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/474/tI/s103"},"text":"Pub. L. 106–474, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2086"},"text":"114 Stat. 2086","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
