{"tag":"section","attrib":{"id":"iddcba5b3f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s807"},"text":null,"children":[{"tag":"num","attrib":{"value":"807"},"text":"§ 807.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcba5b40-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s807/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts with independent public accountant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall enter into a contract with an independent public accountant to conduct an annual audit in accordance with generally accepted government auditing standards, of the financial records of the Board and of any corporation established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s806/i"},"text":"section 806(i) of this title","children":[],"tail":", and shall ensure that the independent public accountant has access for the purpose of the audit to any books, documents, papers, and records of the Board or such corporation (or any agent of the Board or such corporation) which the independent public accountant reasonably determines to be pertinent to the Congressional Award Program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcba5b41-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s807/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report to Congress on audit results","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than May 15 of each calendar year, the Board shall submit to appropriate officers, committees, and subcommittees of Congress and to the Comptroller General of the United States a report on the results of the most recent audit conducted pursuant to this section, and shall include in the report information on any such additional areas as the independent public accountant who conducted the audit determines deserve or require evaluation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcba5b42-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s807/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review by the Comptroller General of annual audit","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcba5b43-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s807/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Comptroller General of the United States shall review each annual audit conducted under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcba5b44-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s807/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of a review under paragraph (1), the Comptroller General, or any duly authorized representative of the Comptroller General, shall have access to any books, documents, papers, and records of the Board or such corporation, or any agent of the Board or such corporation, including the independent external auditor designated under subsection (a), which, in the opinion of the Comptroller General, may be pertinent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcba5b45-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s807/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 180 days after the date on which the Comptroller General receives a report under subsection (b), the Comptroller General shall submit to Congress a report containing the results of the review conducted under paragraph (1) with respect to the preceding year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcba5b46-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/114/tI/s107"},"text":"Pub. L. 96–114, title I, § 107","children":[],"tail":", formerly § 8, "},{"tag":"date","attrib":{"date":"1979-11-16"},"text":"Nov. 16, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/855"},"text":"93 Stat. 855","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/161/s4/g"},"text":"Pub. L. 99–161, § 4(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-25"},"text":"Nov. 25, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/935"},"text":"99 Stat. 935","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/674/s2/e"},"text":"Pub. L. 100–674, § 2(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-17"},"text":"Nov. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3998"},"text":"102 Stat. 3998","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/525/s8"},"text":"Pub. L. 101–525, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-06"},"text":"Nov. 6, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2308"},"text":"104 Stat. 2308","children":[],"tail":"; renumbered title I, § 107, "},{"tag":"ref","attrib":{"href":"/us/pl/106/533/s1/b/1"},"text":"Pub. L. 106–533, § 1(b)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"2000-11-22"},"text":"Nov. 22, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2553"},"text":"114 Stat. 2553","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/188/tIX/s902/c/1"},"text":"Pub. L. 113–188, title IX, § 902(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-11-26"},"text":"Nov. 26, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2021"},"text":"128 Stat. 2021","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcba5b47-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcba5b48-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcba5b49-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/188"},"text":"Pub. L. 113–188","children":[],"tail":" amended section generally. Prior to amendment, section related to annual audits and reports by the Comptroller General."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/525/s8/1"},"text":"Pub. L. 101–525, § 8(1)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t2/s806/i"},"text":"section 806(i) of this title","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t2/s806/h"},"text":"section 806(h) of this title","children":[],"tail":"” and “annually” for “at least biennially”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/525/s8/2"},"text":"Pub. L. 101–525, § 8(2)","children":[],"tail":", added subsec. (b) and struck out former subsec. (b) which required audit to assess adequacy of fiscal control and funds accountability procedures and propriety of expenses."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/525/s8/2"},"text":"Pub. L. 101–525, § 8(2)","children":[],"tail":", struck out subsec. (c) which required the Comptroller General to include in report on first audit performed after "},{"tag":"date","attrib":{"date":"1985-11-25"},"text":"Nov. 25, 1985","children":[],"tail":", an evaluation of programs and activities under this chapter and specified contents of such evaluation, and subsec. (d) which directed that report on first audit performed after "},{"tag":"date","attrib":{"date":"1985-11-25"},"text":"Nov. 25, 1985","children":[],"tail":", was to be submitted on or before "},{"tag":"date","attrib":{"date":"1988-05-15"},"text":"May 15, 1988","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/674"},"text":"Pub. L. 100–674","children":[],"tail":" substituted “section 806(h)” for “section 806(g)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/161/s4/g/1"},"text":"Pub. L. 99–161, § 4(g)(1)","children":[],"tail":", inserted “and evaluation” after “Audits” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/161/s4/g/2"},"text":"Pub. L. 99–161, § 4(g)(2)","children":[],"tail":"–(4), designated existing provisions as subsec. (a), substituted “shall be audited at least biennially” for “may be audited”, and struck out “at such times as the Comptroller General may determine to be appropriate” after “referred to as the ‘Comptroller General’)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b) to (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/161/s4/g/5"},"text":"Pub. L. 99–161, § 4(g)(5)","children":[],"tail":", added subsecs. (b) to (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcba5b4a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcba5b4b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2014 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/188"},"text":"Pub. L. 113–188","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2014-10-01"},"text":"Oct. 1, 2014","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/113/188/s902/c/3"},"text":"section 902(c)(3) of Pub. L. 113–188","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s804"},"text":"section 804 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
