{"tag":"section","attrib":{"id":"iddd2a81ad-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5301"},"text":null,"children":[{"tag":"num","attrib":{"value":"5301"},"text":"§ 5301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Representatives’ and Delegates’ salaries payable monthly","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Representatives and Delegates-elect to Congress, whose credentials in due form of law have been duly filed with the Clerk of the House of Representatives, in accordance with the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s26"},"text":"section 26 of this title","children":[],"tail":", may receive their compensation monthly, from the beginning of their term until the beginning of the first session of each Congress, upon a certificate in the form now in use to be signed by the Clerk of the House, which certificate shall have the like force and effect as is given to the certificate of the Speaker."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd2a81ae-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(R.S. § 38; ","children":[{"tag":"ref","attrib":{"href":"/us/act/1875-03-03/ch130/s1"},"text":"Mar. 3, 1875, ch. 130, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/18/389"},"text":"18 Stat. 389","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd2a81af-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd2a81b0-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd2a81b1-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s34"},"text":"section 34 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 38 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1873-03-03/ch226/s1"},"text":"act Mar. 3, 1873, ch. 226, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/17/488"},"text":"17 Stat. 488","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
