{"tag":"section","attrib":{"id":"iddd3d956e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6592"},"text":null,"children":[{"tag":"num","attrib":{"value":"6592"},"text":"§ 6592.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on compensation of Sergeant at Arms and Doorkeeper of Senate","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Sergeant at Arms and Doorkeeper of the Senate shall receive, directly or indirectly, no fees or other compensation or emolument whatever for performing the duties of the office, or in connection therewith, other than the salary prescribed by law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd3d956f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1874-06-20/ch328"},"text":"June 20, 1874, ch. 328","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/18/85"},"text":"18 Stat. 85","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd3d9570-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd3d9571-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd3d9572-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s62"},"text":"section 62 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic