{"tag":"section","attrib":{"id":"iddd23566d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4592"},"text":null,"children":[{"tag":"num","attrib":{"value":"4592"},"text":"§ 4592.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of sums due deceased Senators and Senate personnel","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Under regulations prescribed by the Secretary of the Senate, a person serving as a Senator or officer or employee whose compensation is disbursed by the Secretary of the Senate may designate a beneficiary or beneficiaries to be paid any unpaid balance of salary or other sums due such person at the time of his death. When any person dies while so serving, any such unpaid balance shall be paid by the disbursing officer of the Senate to the designated beneficiary or beneficiaries. If no designation has been made, such unpaid balance shall be paid to the widow or widower of that person, or if there is no widow or widower, to the next of kin or heirs at law of that person.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 50 of the Revised Statutes ","children":[{"tag":"ref","attrib":{"idref":"fn002100"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002100"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":"See References in Text note below."}],"tail":" shall not be effective as to persons included within the foregoing."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd23566e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1951-01-06/ch1213"},"text":"Jan. 6, 1951, ch. 1213","children":[],"tail":", Ch. I, § 1, "},{"tag":"ref","attrib":{"href":"/us/stat/64/1224"},"text":"64 Stat. 1224","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/607"},"text":"Pub. L. 92–607","children":[],"tail":", ch. V, § 503, "},{"tag":"date","attrib":{"date":"1972-10-31"},"text":"Oct. 31, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1505"},"text":"86 Stat. 1505","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd23566f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd235670-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd235671-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 50 of the Revised Statutes, referred to in text, was classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s38"},"text":"section 38 of this title","children":[],"tail":" and was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/104/186/tII/s203/4"},"text":"Pub. L. 104–186, title II, § 203(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1725"},"text":"110 Stat. 1725","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s5305"},"text":"section 5305 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd235672-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s36a"},"text":"section 36a of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd235673-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1972—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/607"},"text":"Pub. L. 92–607","children":[],"tail":" inserted provisions for designation of a beneficiary by Senators and officers and employees whose compensation is disbursed by Secretary of Senate to whom shall be paid any unpaid balance of salary or other sums due such person at time of death."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
