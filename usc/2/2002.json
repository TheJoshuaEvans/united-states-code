{"tag":"section","attrib":{"id":"iddcf87593-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2002"},"text":null,"children":[{"tag":"num","attrib":{"value":"2002"},"text":"§ 2002.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of buildings and facilities for use in emergency situation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcf87594-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2002/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of buildings and facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, in order to respond to an emergency situation, the Chief Administrative Officer of the House of Representatives may acquire buildings and facilities, subject to the availability of appropriations, for the use of the House of Representatives by lease, purchase, or such other arrangement as the Chief Administrative Officer considers appropriate (including a memorandum of understanding with the head of an executive agency, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s105"},"text":"section 105 of title 5","children":[],"tail":", in the case of a building or facility under the control of such Agency), subject to the approval of the House Office Building Commission."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcf87595-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2002/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, for purposes of carrying out subsection (a), the Chief Administrative Officer may carry out such activities and enter into such agreements related to the use of any building or facility acquired pursuant to such subsection as the Chief Administrative Officer considers appropriate, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcf87596-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2002/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agreements with the United States Capitol Police or any other entity relating to the policing of such building or facility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf87597-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2002/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agreements with the Architect of the Capitol or any other entity relating to the care and maintenance of such building or facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcf87598-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2002/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Capitol Police and Architect","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcf87599-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2002/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Architect of the Capitol","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the Architect of the Capitol may take any action necessary to carry out an agreement entered into with the Chief Administrative Officer pursuant to subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcfabf8a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2002/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcfabf8b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2002/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of certain funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the approval of the Committee on Appropriations of the House of Representatives, the Architect of the Capitol may transfer to the Chief Administrative Officer amounts made available to the Architect for necessary expenses for the maintenance, care and operation of the House office buildings during a fiscal year in order to cover any portion of the costs incurred by the Chief Administrative Officer during the year in acquiring a building or facility pursuant to subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcfabf8c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2002/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section and the amendments made by this section shall apply with respect to fiscal year 2002 and each succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcfabf8d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/117/dB/s903"},"text":"Pub. L. 107–117, div. B, § 903","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-10"},"text":"Jan. 10, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2317"},"text":"115 Stat. 2317","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/206/tI/s903/a/1"},"text":"Pub. L. 107–206, title I, § 903(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-02"},"text":"Aug. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/876"},"text":"116 Stat. 876","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcfabf8e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcfabf8f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddcfabf90-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For the amendments made by this section, referred to in subsec. (e), see Codification note below.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddcfabf91-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was classified to section 175a of former Title 40, prior to the enactment of Title 40, Public Buildings, Property, and Works, by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217/s1"},"text":"Pub. L. 107–217, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1062"},"text":"116 Stat. 1062","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/117/s903"},"text":"section 903 of Pub. L. 107–117","children":[],"tail":". Subsec. (c)(2) of "},{"tag":"ref","attrib":{"href":"/us/pl/107/117/s903"},"text":"section 903 of Pub. L. 107–117","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1961"},"text":"section 1961 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcfabf92-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/206"},"text":"Pub. L. 107–206","children":[],"tail":" substituted “buildings and facilities, subject to the availability of appropriations,” for “buildings and facilities”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcfabf93-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcfabf94-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/206/tI/s903/c"},"text":"Pub. L. 107–206, title I, § 903(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-02"},"text":"Aug. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/876"},"text":"116 Stat. 876","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/206/tI/s903/c"},"text":"“The amendment made by this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1961"},"text":"section 1961 of this title","children":[],"tail":"] shall take effect as if included in the enactment of the Emergency Supplemental Act, 2002 ["},{"tag":"ref","attrib":{"href":"/us/pl/107/117/dB"},"text":"Pub. L. 107–117, div. B","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
