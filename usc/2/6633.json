{"tag":"section","attrib":{"id":"iddd3fdf6f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6633"},"text":null,"children":[{"tag":"num","attrib":{"value":"6633"},"text":"§ 6633.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Media support services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd3fdf70-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6633/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the terms “national committee” and “political party” have the meaning given such terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s30101"},"text":"section 30101 of title 52","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3fdf71-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6633/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The official duties of employees of the Sergeant at Arms and Doorkeeper of the Senate under the Senate Daily Press Gallery, the Senate Periodical Press Gallery, the Senate Press Photographers Gallery, and the Senate Radio and Television Correspondents Gallery may include providing media support services with respect to the presidential nominating conventions of the national committees of political parties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3fdf72-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6633/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of Sergeant at Arms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms and conditions under which employees perform official duties under subsection (b) shall be subject to the approval of the Sergeant at Arms and Doorkeeper of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3fdf73-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6633/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply to fiscal year 2008 and each fiscal year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd3fdf74-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161/dH/tI/s7"},"text":"Pub. L. 110–161, div. H, title I, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2222"},"text":"121 Stat. 2222","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd3fdf75-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd3fdf76-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd424f77-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s61f–13"},"text":"section 61f–13 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Legislative Branch Appropriations Act, 2008, which is div. H of the Consolidated Appropriations Act, 2008.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
