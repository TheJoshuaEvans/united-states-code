{"tag":"section","attrib":{"id":"iddc839419-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s137"},"text":null,"children":[{"tag":"num","attrib":{"value":"137"},"text":"§ 137.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use and regulation of law library","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The justices of the Supreme Court shall have free access to the law library; and they are authorized to make regulations, not inconsistent with law, for the use of the same during the sittings of the court. But such regulations shall not restrict any person authorized to take books from the Library from having access to the law library, or using the books therein in the same manner as he may be entitled to use the books of the general Library.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc83941a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(R.S. § 95.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc83941b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc83941c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddc83941d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 95 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1832-07-14/ch221/s2"},"text":"act July 14, 1832, ch. 221, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/4/579"},"text":"4 Stat. 579","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
