{"tag":"section","attrib":{"id":"iddcd49a53-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1341"},"text":null,"children":[{"tag":"num","attrib":{"value":"1341"},"text":"§ 1341.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights and protections under Occupational Safety and Health Act of 1970; procedures for remedy of violations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcd49a54-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1341/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Occupational safety and health protections","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcd49a55-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1341/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each employing office and each covered employee shall comply with the provisions of section 5 of the Occupational Safety and Health Act of 1970 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s654"},"text":"29 U.S.C. 654","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd49a56-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1341/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of the application under this section of the Occupational Safety and Health Act of 1970 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s651"},"text":"29 U.S.C. 651","children":[],"tail":" et seq.]—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcd49a57-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1341/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “employer” as used in such Act means an employing office;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcd49a58-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1341/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “employee” as used in such Act means a covered employee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcd49a59-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1341/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “employing office” includes the Government Accountability Office and any entity listed in subsection (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1331"},"text":"section 1331 of this title","children":[],"tail":" that is responsible for correcting a violation of this section, irrespective of whether the entity has an employment relationship with any covered employee in any employing office in which such a violation occurs; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcd49a5a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1341/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “employee” includes employees of the Government Accountability Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd49a5b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1341/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remedy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The remedy for a violation of subsection (a) shall be an order to correct the violation, including such order as would be appropriate if issued under section 13(a) of the Occupational Safety and Health Act of 1970 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s662/a"},"text":"29 U.S.C. 662(a)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd49a5c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1341/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcd49a5d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1341/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requests for inspections","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon written request of any employing office or covered employee, the General Counsel shall exercise the authorities granted to the Secretary of Labor by subsections (a), (d), (e), and (f) of section 8 of the Occupational Safety and Health Act of 1970 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s657/a"},"text":"29 U.S.C. 657(a)","children":[],"tail":", (d), (e), and (f)) to inspect and investigate places of employment under the jurisdiction of employing offices."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd49a5e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1341/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Citations, notices, and notifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the General Counsel shall exercise the authorities granted to the Secretary of Labor in sections 9 and 10 of the Occupational Safety and Health Act of 1970 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s658"},"text":"29 U.S.C. 658","children":[],"tail":" and 659), to issue—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcd49a5f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1341/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a citation or notice to any employing office responsible for correcting a violation of subsection (a); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcd49a60-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1341/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a notification to any employing office that the General Counsel believes has failed to correct a violation for which a citation has been issued within the period permitted for its correction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd49a61-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1341/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hearings and review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If after issuing a citation or notification, the General Counsel determines that a violation has not been corrected, the General Counsel may file a complaint with the Office against the employing office named in the citation or notification. The complaint shall be submitted to a hearing officer for decision pursuant to subsections (b) through (h) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1405"},"text":"section 1405 of this title","children":[],"tail":", subject to review by the Board pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1406"},"text":"section 1406 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd49a62-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1341/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Variance procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An employing office may request from the Board an order granting a variance from a standard made applicable by this section. For the purposes of this section, the Board shall exercise the authorities granted to the Secretary of Labor in sections 6(b)(6) and 6(d) of the Occupational Safety and Health Act of 1970 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s655/b/6"},"text":"29 U.S.C. 655(b)(6)","children":[],"tail":" and 655(d)) to act on any employing office’s request for a variance. The Board shall refer the matter to a hearing officer pursuant to subsections (b) through (h) of "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1405"},"text":"section 1405 of this title","children":[],"tail":", subject to review by the Board pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1406"},"text":"section 1406 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd49a63-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1341/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The General Counsel or employing office aggrieved by a final decision of the Board under paragraph (3) or (4), may file a petition for review with the United States Court of Appeals for the Federal Circuit pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1407"},"text":"section 1407 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd49a64-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1341/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If new appropriated funds are necessary to correct a violation of subsection (a) for which a citation is issued, or to comply with an order requiring correction of such a violation, correction or compliance shall take place as soon as possible, but not later than the end of the fiscal year following the fiscal year in which the citation is issued or the order requiring correction becomes final and not subject to further review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd49a65-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1341/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations to implement section","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcd49a66-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1341/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall, pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1384"},"text":"section 1384 of this title","children":[],"tail":", issue regulations to implement this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd49a67-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1341/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The regulations issued under paragraph (1) shall be the same as substantive regulations promulgated by the Secretary of Labor to implement the statutory provisions referred to in subsection (a) except to the extent that the Board may determine, for good cause shown and stated together with the regulation, that a modification of such regulations would be more effective for the implementation of the rights and protections under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd49a68-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1341/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employing office responsible for correction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The regulations issued under paragraph (1) shall include a method of identifying, for purposes of this section and for different categories of violations of subsection (a), the employing office responsible for correction of a particular violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd49a69-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1341/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic inspections; report to Congress","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcd49a6a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1341/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic inspections","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On a regular basis, and at least once each Congress, the General Counsel, exercising the same authorities of the Secretary of Labor as under subsection (c)(1), shall conduct periodic inspections of all facilities of the House of Representatives, the Senate, the Office of Congressional Accessibility Services, the Capitol Police, the Congressional Budget Office, the Office of the Architect of the Capitol, the Office of the Attending Physician, the Office of Congressional Workplace Rights, the Office of Technology Assessment, the Library of Congress, and the Government Accountability Office to report on compliance with subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd49a6b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1341/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On the basis of each periodic inspection, the General Counsel shall prepare and submit a report—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcd49a6c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1341/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the Speaker of the House of Representatives, the President pro tempore of the Senate, and the Office of the Architect of the Capitol or other employing office responsible for correcting the violation of this section uncovered by such inspection, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcd49a6d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1341/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" containing the results of the periodic inspection, identifying the employing office responsible for correcting the violation of this section uncovered by such inspection, describing any steps necessary to correct any violation of this section, and assessing any risks to employee health and safety associated with any violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd49a6e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1341/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action after report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a report identifies any violation of this section, the General Counsel shall issue a citation or notice in accordance with subsection (c)(2)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd49a6f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1341/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Detailed personnel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Labor may, on request of the Executive Director, detail to the Office such personnel as may be necessary to advise and assist the Office in carrying out its duties under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd49a70-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1341/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial period for study and corrective action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The period from ","children":[{"tag":"date","attrib":{"date":"1995-01-23"},"text":"January 23, 1995","children":[],"tail":", until "},{"tag":"date","attrib":{"date":"1996-12-31"},"text":"December 31, 1996","children":[],"tail":", shall be available to the Office of the Architect of the Capitol and other employing offices to identify any violations of subsection (a), to determine the costs of compliance, and to take any necessary corrective action to abate any violations. The Office shall assist the Office of the Architect of the Capitol and other employing offices by arranging for inspections and other technical assistance at their request. Prior to "},{"tag":"date","attrib":{"date":"1996-07-01"},"text":"July 1, 1996","children":[],"tail":", the General Counsel shall conduct a thorough inspection under subsection (e)(1) and shall submit the report under subsection (e)(2) for the One Hundred Fourth Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd49a71-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1341/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcd49a72-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1341/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), subsections (a), (b), (c), and (e)(3) shall be effective on ","children":[{"tag":"date","attrib":{"date":"1997-01-01"},"text":"January 1, 1997","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd49a73-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1341/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Government Accountability Office and Library of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall be effective with respect to the Government Accountability Office and the Library of Congress 1 year after transmission to the Congress of the study under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1371"},"text":"section 1371 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcd49a74-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/1/tII/s215"},"text":"Pub. L. 104–1, title II, § 215","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-01-23"},"text":"Jan. 23, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/16"},"text":"109 Stat. 16","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/271/s8/b"},"text":"Pub. L. 108–271, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-07"},"text":"July 7, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/814"},"text":"118 Stat. 814","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/437/tIV/s422/b/4"},"text":"Pub. L. 110–437, title IV, § 422(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-20"},"text":"Oct. 20, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4996"},"text":"122 Stat. 4996","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dI/tI/s153/a/2/D"},"text":"Pub. L. 115–141, div. I, title I, § 153(a)(2)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/785"},"text":"132 Stat. 785","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/397/tIII/s308/b/9"},"text":"Pub. L. 115–397, title III, § 308(b)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5326"},"text":"132 Stat. 5326","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcd49a75-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcd49a76-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddcd49a77-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Occupational Safety and Health Act of 1970, referred to in subsec. (a)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/596"},"text":"Pub. L. 91–596","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-29"},"text":"Dec. 29, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1590"},"text":"84 Stat. 1590","children":[],"tail"