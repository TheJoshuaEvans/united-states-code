{"tag":"section","attrib":{"id":"iddd2a82a0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5349"},"text":null,"children":[{"tag":"num","attrib":{"value":"5349"},"text":"§ 5349.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on printed copies of U.S. Code to House","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd2a82a1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5349/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" None of the funds made available in any fiscal year may be to provide an aggregate number of more than 50 printed copies of any edition of the United States Code to all offices of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2a82a2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5349/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section shall apply with respect to fiscal year 2019 and each succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd2a82a3-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/244/dB/tI/s114"},"text":"Pub. L. 115–244, div. B, title I, § 114","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-09-21"},"text":"Sept. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2929"},"text":"132 Stat. 2929","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
