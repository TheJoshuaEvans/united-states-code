{"tag":"section","attrib":{"id":"iddc708159-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"§ 9.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voting for Representatives","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All votes for Representatives in Congress must be by written or printed ballot, or voting machine the use of which has been duly authorized by the State law; and all votes received or recorded contrary to this section shall be of no effect.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc70815a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(R.S. § 27; ","children":[{"tag":"ref","attrib":{"href":"/us/act/1899-02-14/ch154"},"text":"Feb. 14, 1899, ch. 154","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/30/836"},"text":"30 Stat. 836","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc70815b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc70815c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddc70815d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 27 derived from acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1871-02-28/ch99/s19"},"text":"Feb. 28, 1871, ch. 99, § 19","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/16/440"},"text":"16 Stat. 440","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/act/1872-05-30/ch239"},"text":"May 30, 1872, ch. 239