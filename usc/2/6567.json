{"tag":"section","attrib":{"id":"iddd3d9504-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6567"},"text":null,"children":[{"tag":"num","attrib":{"value":"6567"},"text":"§ 6567.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funds for Secretary of Senate to assist in proper discharge within United States of responsibilities to foreign parliamentary groups or other foreign officials","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd3d9505-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6567/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On and after ","children":[{"tag":"date","attrib":{"date":"1987-07-11"},"text":"July 11, 1987","children":[],"tail":", the Secretary of the Senate is authorized to use any available funds (but not in excess of $50,000 for any fiscal year), out of the appropriation account (within the Contingent Fund of the Senate) for the Secretary of the Senate, to assist him in the proper discharge, within the United States, of his appropriate responsibilities to members of foreign parliamentary groups or other foreign officials."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3d9506-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6567/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of subsection (a) shall be effective in the case of expenditures for fiscal years ending after ","children":[{"tag":"date","attrib":{"date":"1986-09-30"},"text":"September 30, 1986","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3d9507-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6567/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon the written request of the Secretary of the Senate, and upon notification to the Committee on Appropriations of the Senate, there shall be transferred any amount of funds available under subsection (a) specified in the request, but not to exceed $15,000 in any fiscal year, from the appropriation account (within the contingent fund of the Senate) for expenses of the Office of the Secretary of the Senate to the appropriation account for the expense allowance of the Secretary of the Senate. Any funds so transferred shall be available in like manner and for the same purposes as are other funds in the account to which the funds are transferred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd3d9508-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/71/tI/s2"},"text":"Pub. L. 100–71, title I, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-07-11"},"text":"July 11, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/423"},"text":"101 Stat. 423","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/90/tI/s4"},"text":"Pub. L. 102–90, title I, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-14"},"text":"Aug. 14, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/450"},"text":"105 Stat. 450","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/18/tII/s7003/a"},"text":"Pub. L. 105–18, title II, § 7003(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-06-12"},"text":"June 12, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/192"},"text":"111 Stat. 192","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/447/dG/tI/s6"},"text":"Pub. L. 108–447, div. G, title I, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3170"},"text":"118 Stat. 3170","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/94/dP/tXV/s1501"},"text":"Pub. L. 116–94, div. P, title XV, § 1501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3209"},"text":"133 Stat. 3209","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd3d9509-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd3d950a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd3d950b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s65f"},"text":"section 65f of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Supplemental Appropriations Act, 1987.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd3d950c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94"},"text":"Pub. L. 116–94","children":[],"tail":" substituted “$15,000” for “$10,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447"},"text":"Pub. L. 108–447","children":[],"tail":" substituted “and upon notification to” for “with the approval of” in first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/18"},"text":"Pub. L. 105–18","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/90"},"text":"Pub. L. 102–90","children":[],"tail":" substituted “On and after "},{"tag":"date","attrib":{"date":"1987-07-11"},"text":"July 11, 1987","children":[],"tail":", the Secretary of the Senate is authorized” for “The Secretary of the Senate is authorized” and “$50,000” for “$25,000”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd3d950d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd3d950e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/18/tII/s7003/b"},"text":"Pub. L. 105–18, title II, § 7003(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-06-12"},"text":"June 12, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/192"},"text":"111 Stat. 192","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/18/tII/s7003/b"},"text":"“The amendment made by subsection (a) [amending this section] shall be effective with respect to appropriations for fiscal years beginning on or after ","children":[{"tag":"date","attrib":{"date":"1996-10-01"},"text":"October 1, 1996","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
