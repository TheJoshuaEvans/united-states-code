{"tag":"section","attrib":{"id":"iddcb81218-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s805"},"text":null,"children":[{"tag":"num","attrib":{"value":"805"},"text":"§ 805.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional award directors of program; appointment criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Regional award directors may be appointed by the Board, upon recommendation of the Director, for any State or other appropriate geographic area of the United States. The Director shall make such recommendations with respect to a State or geographic area only after soliciting recommendations regarding such appointments from public and private youth organizations within such State or geographic area.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddcba5b09-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/114/tI/s105"},"text":"Pub. L. 96–114, title I, § 105","children":[],"tail":", formerly § 6, "},{"tag":"date","attrib":{"date":"1979-11-16"},"text":"Nov. 16, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/853"},"text":"93 Stat. 853","children":[],"tail":"; renumbered title I, § 105, "},{"tag":"ref","attrib":{"href":"/us/pl/106/533/s1/b/1"},"text":"Pub. L. 106–533, § 1(b)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"2000-11-22"},"text":"Nov. 22, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2553"},"text":"114 Stat. 2553","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
