{"tag":"section","attrib":{"id":"iddd2f3d28-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5549"},"text":null,"children":[{"tag":"num","attrib":{"value":"5549"},"text":"§ 5549.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" House Intern Resource Office","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd2f3d29-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5549/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment; Coordinator","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2f3d2a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5549/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment; Coordinator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Office of the Chief Administrative Officer of the House of Representatives the House Intern Resource Office (hereinafter referred to as the “Office”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2f3d2b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5549/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office shall be headed by the House Intern Resource Coordinator (hereinafter referred to as the “Coordinator”), who shall be employed by the Chief Administrative Officer in consultation with the chair and ranking minority member of the Committee on House Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2f3d2c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5549/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In consultation with the Office of Diversity and Inclusion and such other offices as the Coordinator considers appropriate, the Office shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2f3d2d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5549/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide support services, such as accommodations, training, and professional development, to interns of offices of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2f3d2e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5549/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as a center for resources and best practices for the recruitment, hiring, training, and use of interns by offices of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2f3d2f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5549/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gather demographic and other data about interns of offices of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2f3d30-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5549/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Addressing inequities in access to internships","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out its duties, the Office shall consider inequities in access to internships in offices of the House of Representatives, and shall consider the viability of establishing an intern stipend program for interns from underrepresented backgrounds, including those who attend Historically Black Colleges and Universities (HBCUs), Tribal Colleges and Universities, Hispanic-Serving Institutions (HSIs), and other Minority Serving Institutions described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1067q/a"},"text":"section 1067q(a) of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2f3d31-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5549/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated for fiscal year 2023 and each succeeding fiscal year such sums as may be necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2f3d32-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5549/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply with respect to fiscal year 2023 and each succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd2f3d33-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dI/tI/s113"},"text":"Pub. L. 117–328, div. I, title I, § 113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4922"},"text":"136 Stat. 4922","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
