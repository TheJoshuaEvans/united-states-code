{"tag":"section","attrib":{"id":"iddcb32ecf-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s653"},"text":null,"children":[{"tag":"num","attrib":{"value":"653"},"text":"§ 653.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Analysis by Congressional Budget Office","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Director of the Congressional Budget Office shall, to the extent practicable, prepare for each bill or resolution of a public character reported by any committee of the House of Representatives or the Senate (except the Committee on Appropriations of each House), and submit to such committee—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcb32ed0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s653/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the costs which would be incurred in carrying out such bill or resolution in the fiscal year in which it is to become effective and in each of the 4 fiscal years following such fiscal year, together with the basis for each such estimate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb32ed1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s653/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a comparison of the estimates of costs described in paragraph (1) with any available estimates of costs made by such committee or by any Federal agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb32ed2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s653/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of each method for establishing a Federal financial commitment contained in such bill or resolution.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The estimates, comparison, and description so submitted shall be included in the report accompanying such bill or resolution if timely submitted to such committee before such report is filed.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcb32ed3-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/344/tIV/s402"},"text":"Pub. L. 93–344, title IV, § 402","children":[],"tail":", formerly § 403, "},{"tag":"date","attrib":{"date":"1974-07-12"},"text":"July 12, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/320"},"text":"88 Stat. 320","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/108/s2/a"},"text":"Pub. L. 97–108, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-23"},"text":"Dec. 23, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1510"},"text":"95 Stat. 1510","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/177/tII/s213"},"text":"Pub. L. 99–177, title II, § 213","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-12"},"text":"Dec. 12, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1059"},"text":"99 Stat. 1059","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/4/tI/s104"},"text":"Pub. L. 104–4, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-03-22"},"text":"Mar. 22, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/62"},"text":"109 Stat. 62","children":[],"tail":"; renumbered § 402, "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/tX/s10116/c/1"},"text":"Pub. L. 105–33, title X, § 10116(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/692"},"text":"111 Stat. 692","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcb32ed4-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcb32ed5-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddcb32ed6-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1353"},"text":"section 1353 of Title 31","children":[],"tail":" prior to the general revision and enactment of Title 31, Money and Finance, by "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s1"},"text":"Pub. L. 97–258, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/877"},"text":"96 Stat. 877","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"iddcb32ed7-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/344/s402"},"text":"section 402 of Pub. L. 93–344","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s652"},"text":"section 652 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/33"},"text":"Pub. L. 105–33","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcb32ed8-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1995—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/4/s104/2"},"text":"Pub. L. 104–4, § 104(2)","children":[],"tail":", struck out subsection designation."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/4/s104/1/A"},"text":"Pub. L. 104–4, § 104(1)(A)","children":[],"tail":", (C), redesignated par. (3) as (2) and struck out former par. (2), which read as follows: “an estimate of the cost which would be incurred by State and local governments in carrying out or complying with any significant bill or resolution in the fiscal year in which it is to become effective and in each of the four fiscal years following such fiscal year, together with the basis for each such estimate;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/4/s104/1/C"},"text":"Pub. L. 104–4, § 104(1)(C)","children":[],"tail":", redesignated par. (4) as (3). Former par. (3) redesignated (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/4/s104/1/B"},"text":"Pub. L. 104–4, § 104(1)(B)","children":[],"tail":", which directed the substitution of “paragraph (1)” for “paragraphs (1) and (2)”, was executed by making the substitution for “paragraph (1) and (2)” to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/4/s104/1/C"},"text":"Pub. L. 104–4, § 104(1)(C)","children":[],"tail":", redesignated par. (4) as (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/4/s104/3"},"text":"Pub. L. 104–4, § 104(3)","children":[],"tail":", struck out subsecs. (b) and (c) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) For purposes of subsection (a)(2) of this section, the term ‘local government’ has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s6501"},"text":"section 6501 of title 31","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(c) For purposes of subsection (a)(2) of this section, the term ‘significant bill or resolution’ is defined as any bill or resolution which in the judgment of the Director of the Congressional Budget Office is likely to result in an annual cost to State and local governments of $200,000,000 or more, or is likely to have exceptional fiscal consequences for a geographic region or a particular level of government.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/177"},"text":"Pub. L. 99–177","children":[],"tail":" added par. (4) and substituted “estimates, comparison, and description” for “estimates and comparison” in last sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/108/s2/a/1"},"text":"Pub. L. 97–108, § 2(a)(1)","children":[],"tail":"–(6), designated existing provisions as subsec. (a), added par. (2), redesignated former par. (2) as (3), in par. (3) as so redesignated, substituted “estimates” for “estimate” in two places, and substituted reference to pars. (1) and (2) for reference to par. (1), and in provision following par. (3) substituted “estimates” for “estimate”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b) and (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/108/s2/a/7"},"text":"Pub. L. 97–108, § 2(a)(7)","children":[],"tail":", added subsecs. (b) and (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcb32ed9-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcb32eda-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1995 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/4"},"text":"Pub. L. 104–4","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", or on the date 90 days after appropriations are made available as authorized under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1516"},"text":"section 1516 of this title","children":[],"tail":", whichever is earlier, and applicable to legislation considered on and after such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/4/s110"},"text":"section 110 of Pub. L. 104–4","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1511"},"text":"section 1511 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcb32edb-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1985 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/177"},"text":"Pub. L. 99–177","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1985-12-12"},"text":"Dec. 12, 1985","children":[],"tail":", and applicable with respect to fiscal years beginning after "},{"tag":"date","attrib":{"date":"1985-09-30"},"text":"Sept. 30, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/177/s275/a/1"},"text":"section 275(a)(1) of Pub. L. 99–177","children":