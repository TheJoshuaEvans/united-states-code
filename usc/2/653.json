ointed under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s601/a"},"text":"section 601(a) of this title","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/344/s905/b"},"text":"section 905(b) of Pub. L. 93–344","children":[],"tail":", formerly set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s621"},"text":"section 621 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddcb32ede-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/108/s3"},"text":"Pub. L. 97–108, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-23"},"text":"Dec. 23, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1511"},"text":"95 Stat. 1511","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/108/s3"},"text":"“There are authorized to be appropriated such sums as may be necessary to carry out this Act [amending this section and enacting provisions set out as notes under this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s621"},"text":"section 621 of this title","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddcb32edf-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Expiration of Authorization","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/108/s4"},"text":"Pub. L. 97–108, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-23"},"text":"Dec. 23, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1511"},"text":"95 Stat. 1511","children":[],"tail":", 