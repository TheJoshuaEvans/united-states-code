{"tag":"section","attrib":{"id":"iddd31ad9e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5605"},"text":null,"children":[{"tag":"num","attrib":{"value":"5605"},"text":"§ 5605.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Law enforcement authority of Sergeant at Arms","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd31ad9f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5605/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Law enforcement authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Sergeant at Arms of the House of Representatives shall have the same law enforcement authority, including the authority to carry firearms, as a member of the Capitol Police. The law enforcement authority under the preceding sentence shall be subject to the requirement that the Sergeant at Arms have the qualifications specified in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd31ada0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5605/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The qualifications referred to in subsection (a) are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd31ada1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5605/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A minimum of five years of experience as a law enforcement officer before beginning service as the Sergeant at Arms.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd31ada2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5605/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Current certification in the use of firearms by the appropriate Federal law enforcement entity or an equivalent non-Federal entity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd31ada3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5605/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other firearms qualification required for members of the Capitol Police.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd31ada4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5605/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Committee on House Oversight of the House of Representatives shall have authority to prescribe regulations to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd31ada5-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/53/tIII/s313"},"text":"Pub. L. 104–53, title III, § 313","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-11-19"},"text":"Nov. 19, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/538"},"text":"109 Stat. 538","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd31ada6-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd31ada7-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd31ada8-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s78"},"text":"section 78 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd31ada9-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"iddd31adaa-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on House Oversight of House of Representatives changed to Committee on House Administration of House of Representatives by House Resolution No. 5, One Hundred Sixth Congress, ","children":[{"tag":"date","attrib":{"date":"1999-01-06"},"text":"Jan. 6, 1999","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
