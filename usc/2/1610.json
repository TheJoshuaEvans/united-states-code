{"tag":"section","attrib":{"id":"iddce2f28d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1610"},"text":null,"children":[{"tag":"num","attrib":{"value":"1610"},"text":"§ 1610.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Estimates based on tax reporting system","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddce2f28e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1610/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entities covered by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6033/b"},"text":"section 6033(b) of title 26","children":[],"tail":null}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person, other than a lobbying firm, that is required to report and does report lobbying expenditures pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6033/b/8"},"text":"section 6033(b)(8) of title 26","children":[],"tail":" may—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce2f28f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1610/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make a good faith estimate (by category of dollar value) of applicable amounts that would be required to be disclosed under such section for the appropriate quarterly period to meet the requirements of sections 1603(a)(3) and 1604(b)(4) of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce2f290-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1610/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for all other purposes consider as lobbying contacts and lobbying activities only—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddce2f291-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1610/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lobbying contacts with covered legislative branch officials (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1602/4"},"text":"section 1602(4) of this title","children":[],"tail":") and lobbying activities in support of such contacts; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce2f292-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1610/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lobbying of Federal executive branch officials to the extent that such activities are influencing legislation as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s4911/d"},"text":"section 4911(d) of title 26","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce2f293-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1610/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entities covered by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s162/e"},"text":"section 162(e) of title 26","children":[],"tail":null}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person, other than a lobbying firm, who is required to account and does account for lobbying expenditures pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s162/e"},"text":"section 162(e) of title 26","children":[],"tail":" may—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce2f294-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1610/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make a good faith estimate (by category of dollar value) of applicable amounts that would not be deductible pursuant to such section for the appropriate quarterly period to meet the requirements of sections 1603(a)(3) and 1604(b)(4) of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce2f295-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1610/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for all other purposes consider as lobbying contacts and lobbying activities only—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddce2f296-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1610/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lobbying contacts with covered legislative branch officials (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1602/4"},"text":"section 1602(4) of this title","children":[],"tail":") and lobbying activities in support of such contacts; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce2f297-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1610/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lobbying of Federal executive branch officials to the extent that amounts paid or costs incurred in connection with such activities are not deductible pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s162/e"},"text":"section 162(e) of title 26","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce2f298-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1610/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure of estimate","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any registrant that elects to make estimates required by this chapter under the procedures authorized by subsection (a) or (b) for reporting or threshold purposes shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce2f299-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1610/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inform the Secretary of the Senate and the Clerk of the House of Representatives that the registrant has elected to make its estimates under such procedures; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce2f29a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1610/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make all such estimates, in a given calendar year, under such procedures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce2f29b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1610/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"1997-03-31"},"text":"March 31, 1997","children":[],"tail":", the Comptroller General of the United States shall review reporting by registrants under subsections (a) and (b) and report to the Congress—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce2f29c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1610/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the differences between the definition of “lobbying activities” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1602/7"},"text":"section 1602(7) of this title","children":[],"tail":" and the definitions of “lobbying expenditures”, “influencing legislation”, and related terms in sections 162(e) and 4911 of title 26, as each are implemented by regulations;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce2f29d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1610/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact that any such differences may have on filing and reporting under this chapter pursuant to this subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce2f29e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1610/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any changes to this chapter or to the appropriate sections of title 26 that the Comptroller General may recommend to harmonize the definitions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddce2f29f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/65/s15"},"text":"Pub. L. 104–65, § 15","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-19"},"text":"Dec. 19, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/702"},"text":"109 Stat. 702","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/166/s4/a"},"text":"Pub. L. 105–166, § 4(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1998-04-06"},"text":"Apr. 6, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/38"},"text":"112 Stat. 38","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/81/tII/s201/b/4"},"text":"Pub. L. 110–81, title II, § 201(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-09-14"},"text":"Sept. 14, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/742"},"text":"121 Stat. 742","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddce2f2a0-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddce2f2a1-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddce2f2a2-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (c) and (d)(2), (3), was in the original “this Act” meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/65"},"text":"Pub. L. 104–65","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-19"},"text":"Dec. 19, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/691"},"text":"109 Stat. 691","children":[],"tail":", known as the Lobbying Disclosure Act of 1995. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1601"},"text":"section 1601 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddce2f2a3-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsecs. (a)(1), (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/81"},"text":"Pub. L. 110–81","children":[],"tail":" substituted “quarterly period” for “semiannual period”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/166/s4/a/1"},"text":"Pub. L. 105–166, § 4(a)(1)","children":[],"tail":", in introductory provisions, substituted “A person, other than a lobbying firm,” for “A registrant”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/166/s4/a/2"},"text":"Pub. L. 105–166, § 4(a)(2)","children":[],"tail":", amended par. (2) generally. Prior to amendment, par. (2) read as follows: “in lieu of using the definition of ‘lobbying activities’ in "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1602/7"},"text":"section 1602(7) of this title","children":[],"tail":", consider as lobbying activities only those activities that are influencing legislation as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4911/d"},"text":"section 4911(d) of title 26","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/166/s4/b/1"},"text":"Pub. L. 105–166, § 4(b)(1)","children":[],"tail":", in introductory provisions, substituted “A person, other than a lobbying firm, who is required to account and does account for lobbying expenditures pursuant to” for “A registrant that is subject to”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/166/s4/b/2"},"text":"Pub. L. 105–166, § 4(b)(2)","children":[],"tail":", amended par. (2) generally. Prior to amendment, par. (2) read as follows: “in lieu of using the definition of ‘lobbying activities’ in "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1602/7"},"text":"section 1602(7) of this title","children":[],"tail":", consider as lobbying activities only those activities, the costs of which are not deductible pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s162/e"},"text":"section 162(e) of title 26","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddce2f2a4-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddce2f2a5-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Except as otherwise provided, amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/81"},"text":"Pub. L. 110–81","children":[],"tail":" applicable with respect to registrations under the Lobbying Disclosure Act of 1995 (this chapter) having an effective date of "},{"tag":"date","attrib":{"date":"2008-01-01"},"text":"Jan. 1, 2008","children":[],"tail":", or later and with respect to quarterly reports under that Act covering calendar quarters beginning on or after "},{"tag":"date","attrib":{"date":"2008-01-01"},"text":"Jan. 1, 2008","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/81/s215"},"text":"section 215 of Pub. L. 110–81","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s30104"},"text":"section 30104 of Title 52","children":[],"tail":", Voting and Elections."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddce2f2a6-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/65/s24"},"text":"section 24 of Pub. L. 104–65","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1601"},"text":"section 1601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
