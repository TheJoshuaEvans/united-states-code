{"tag":"section","attrib":{"id":"iddc8393fb-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s136–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"136–1"},"text":"§ 136–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment and term of service of Librarian of Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc8393fc-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s136–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall appoint the Librarian of Congress, by and with the advice and consent of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc8393fd-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s136–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Librarian of Congress shall be appointed for a term of 10 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc8393fe-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s136–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reappointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual appointed to the position of Librarian of Congress, by and with the advice and consent of the Senate, may be reappointed to that position in accordance with subsections (a) and (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc8393ff-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s136–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply with respect to appointments made on or after ","children":[{"tag":"date","attrib":{"date":"2015-11-05"},"text":"November 5, 2015","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc839400-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/86/s2"},"text":"Pub. L. 114–86, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-05"},"text":"Nov. 5, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/675"},"text":"129 Stat. 675","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
