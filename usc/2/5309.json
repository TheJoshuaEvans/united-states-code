{"tag":"section","attrib":{"id":"iddd2a81dd-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5309"},"text":null,"children":[{"tag":"num","attrib":{"value":"5309"},"text":"§ 5309.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disbursement of compensation of House Members by Chief Administrative Officer","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The moneys which have been, or may be, appropriated for the compensation and mileage of Members and Delegates shall be paid at the Treasury on requisitions drawn by the Chief Administrative Officer of the House of Representatives, and shall be kept, disbursed, and accounted for by him according to law, and he shall be a disbursing officer, but he shall not be entitled to any compensation additional to the salary fixed by law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd2a81de-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1890-10-01/ch1256/s3"},"text":"Oct. 1, 1890, ch. 1256, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/26/645"},"text":"26 Stat. 645","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/186/tII/s204/25/B"},"text":"Pub. L. 104–186, title II, § 204(25)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1734"},"text":"110 Stat. 1734","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd2a81df-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd2a81e0-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd2a81e1-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s80"},"text":"section 80 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd2a81e2-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186"},"text":"Pub. L. 104–186","children":[],"tail":" substituted “Chief Administrative Officer” for “Sergeant-at-Arms”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
