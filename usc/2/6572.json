{"tag":"section","attrib":{"id":"iddd3d951c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6572"},"text":null,"children":[{"tag":"num","attrib":{"value":"6572"},"text":"§ 6572.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purchases of stationery and materials for folding","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Purchases of stationery and materials for folding shall be made in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s4104"},"text":"section 4104 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"All contracts and bonds for purchases made under the authority of this section shall be filed with the Committee on Rules and Administration of the Senate.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd3d951d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1887-03-03/ch392/s1"},"text":"Mar. 3, 1887, ch. 392, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/24/596"},"text":"24 Stat. 596","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1946-08-02/ch753"},"text":"Aug. 2, 1946, ch. 753","children":[],"tail":", title I, § 102, "},{"tag":"ref","attrib":{"href":"/us/stat/60/814"},"text":"60 Stat. 814","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/186/tII/s204/58"},"text":"Pub. L. 104–186, title II, § 204(58)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1738"},"text":"110 Stat. 1738","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1/b"},"text":"Pub. L. 113–235, div. H, title I, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib