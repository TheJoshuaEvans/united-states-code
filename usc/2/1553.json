{"tag":"section","attrib":{"id":"iddce0816a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1553"},"text":null,"children":[{"tag":"num","attrib":{"value":"1553"},"text":"§ 1553.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special authorities of Advisory Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddce0816b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1553/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Experts and consultants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of carrying out this subchapter, the Advisory Commission may procure temporary and intermittent services of experts or consultants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109/b"},"text":"section 3109(b) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce0816c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1553/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Detail of staff of Federal agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon request of the Executive Director of the Advisory Commission, the head of any Federal department or agency may detail, on a reimbursable basis, any of the personnel of that department or agency to the Advisory Commission to assist it in carrying out this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce0816d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1553/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative support services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon the request of the Advisory Commission, the Administrator of General Services shall provide to the Advisory Commission, on a reimbursable basis, the administrative support services necessary for the Advisory Commission to carry out its duties under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce0816e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1553/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Commission may, subject to appropriations, contract with and compensate government and private persons (including agencies) for property and services used to carry out its duties under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddce0816f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/4/tIII/s303"},"text":"Pub. L. 104–4, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-03-22"},"text":"Mar. 22, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/69"},"text":"109 Stat. 69","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
