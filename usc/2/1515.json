{"tag":"section","attrib":{"id":"iddcde37fc-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1515"},"text":null,"children":[{"tag":"num","attrib":{"value":"1515"},"text":"§ 1515.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exercise of rulemaking powers","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The provisions of sections 658 to 658g and 1514 of this title are enacted by Congress—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcde37fd-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1515/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as an exercise of the rulemaking power of the Senate and the House of Representatives, respectively, and as such they shall be considered as part of the rules of such House, respectively, and such rules shall supersede other rules only to the extent that they are inconsistent therewith; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcde37fe-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1515/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with full recognition of the constitutional right of either House to change such rules (so far as relating to such House) at any time, in the same manner, and to the same extent as in the case of any other rule of each House.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcde37ff-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/4/tI/s108"},"text":"Pub. L. 104–4, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-03-22"},"text":"Mar. 22, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/63"},"text":"109 Stat. 63","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcde3800-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcde3801-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddcde3802-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", or on the date 90 days after appropriations are made available as authorized under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1516"},"text":"section 1516 of this title","children":[],"tail":", whichever is earlier, and applicable to legislation considered on and after such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/4/s110"},"text":"section 110 of Pub. L. 104–4","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1511"},"text":"section 1511 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
