{"tag":"section","attrib":{"id":"iddc72ca99-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s28b"},"text":null,"children":[{"tag":"num","attrib":{"value":"28b"},"text":"§ 28b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Printing and binding as public document of Precedents of House of Representatives; number of sets authorized","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc72ca9a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s28b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There shall be printed and bound as a public document two thousand sets of the Prec­edents of the House of Representatives compiled and prepared by Lewis Deschler (hereinafter in sections 28b to 28e of this title referred to as the “Precedents”) in accordance with the provisions of the Legislative Branch Appropriation Act, 1966 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/90"},"text":"Public Law 89–90","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/79/265"},"text":"79 Stat. 265","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc72ca9b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s28b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of sets authorized to be printed and bound by or pursuant to sections 28b to 28e of this title shall be in lieu of the usual number of copies for binding and distribution required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s701"},"text":"section 701 of title 44","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc72ca9c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/551/s1"},"text":"Pub. L. 94–551, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-18"},"text":"Oct. 18, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2537"},"text":"90 Stat. 2537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc72ca9d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc72ca9e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddc72ca9f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Legislative Branch Appropriation Act, 1966, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/90"},"text":"Pub. L. 89–90","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-07-27"},"text":"July 27, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/265"},"text":"79 Stat. 265","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
