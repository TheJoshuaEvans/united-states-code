{"tag":"section","attrib":{"id":"iddd19b91e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4572"},"text":null,"children":[{"tag":"num","attrib":{"value":"4572"},"text":"§ 4572.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rates of compensation paid by Secretary of Senate; applicability of Senate pay adjustments by President pro tempore of Senate","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No provision of this Act or of any Act enacted after ","children":[{"tag":"date","attrib":{"date":"1976-10-01"},"text":"October 1, 1976","children":[],"tail":", which specifies a rate of compensation (including a maximum rate) for any position or employee whose compensation is disbursed by the Secretary of the Senate shall, unless otherwise specifically provided therein, be construed to affect the applicability of "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s4571"},"text":"section 4571 of this title","children":[],"tail":" to such rate."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd19b91f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/440/tI/s107"},"text":"Pub. L. 94–440, title I, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-01"},"text":"Oct. 1, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1444"},"text":"90 Stat. 1444","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd19b920-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd19b921-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd19b922-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, means the Legislative Branch Appropriation Act, 1977, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/440"},"text":"Pub. L. 94–440","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-01"},"text":"Oct. 1, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1439"},"text":"90 Stat. 1439","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd19b923-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s60a–1a"},"text":"section 60a–1a of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
