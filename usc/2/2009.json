{"tag":"section","attrib":{"id":"iddcfabfb7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2009"},"text":null,"children":[{"tag":"num","attrib":{"value":"2009"},"text":"§ 2009.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assignment of rooms to Commissioner from Puerto Rico","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In the matter of the assignment of rooms under sections 2004 to 2011 of this title, Delegates in Congress and the Commissioner from Puerto Rico shall be treated the same as Representatives.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddcfabfb8-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"date","attrib":{"date":"1908-05-28"},"text":"May 28, 1908","children":[],"tail":", No. 30, "},{"tag":"ref","attrib":{"href":"/us/stat/35/579"},"text":"35 Stat. 579","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1932-05-17/ch190"},"text":"May 17, 1932, ch. 190","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/47/158"},"text":"47 Stat. 158","children":[],"tail":"; Proc. No. 2695, eff. "},{"tag":"date","attrib":{"date":"1946-07-04"},"text":"July 4, 1946","children":[],"tail":", 11 F.R. 7517, "},{"tag":"ref","attrib":{"href":"/us/stat/60/1352"},"text":"60 Stat. 1352","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcfabfb9-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcfabfba-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddcfabfbb-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[]