{"tag":"section","attrib":{"id":"iddd281178-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5144"},"text":null,"children":[{"tag":"num","attrib":{"value":"5144"},"text":"§ 5144.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lump-sum allowances for House Minority Leader and Majority Whip","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd281179-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5144/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The aggregate amount otherwise authorized to be appropriated for a fiscal year for the lump-sum allowance for the Office of the Minority Leader of the House of Representatives and the aggregate amount otherwise authorized to be appropriated for a fiscal year for the lump-sum allowance for the Office of the Majority Whip of the House of Representatives shall each be increased by $333,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd28117a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5144/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section shall apply with respect to fiscal year 2000 and each succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd28117b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/31/tIII/s3008"},"text":"Pub. L. 106–31, title III, § 3008","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-05-21"},"text":"May 21, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/93"},"text":"113 Stat. 93","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd28117c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd28117d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd28117e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s74a–10"},"text":"section 74a–10 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the 1999 Emergency Supplemental Appropriations Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
