{"tag":"section","attrib":{"id":"iddd2f3cd7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5542"},"text":null,"children":[{"tag":"num","attrib":{"value":"5542"},"text":"§ 5542.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations for safe handling of mail matter","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd2f3cd8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5542/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the approval of the Committee on House Administration, the Chief Administrative Officer of the House of Representatives shall implement regulations under which the Chief Administrative Officer shall be authorized to handle any mail matter delivered by the United States Postal Service or any other carrier to the House of Representatives, or to any other entity with whom the Chief Administrative Officer has entered into an agreement to receive mail matter delivered to the entity, in such manner as the Chief Administrative Officer deems necessary to ensure the safety of any individuals who may come into contact with, or otherwise be exposed to, such mail matter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2f3cd9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5542/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil or criminal liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No action taken under the regulations implemented pursuant to this section may serve as a basis for civil or criminal liability of any individual or entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2f3cda-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5542/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As used in this section, the term “handle” includes but is not limited to collecting, isolating, testing, opening, disposing, and destroying.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2f3cdb-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5542/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply with respect to fiscal year 2004 and each succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd2f3cdc-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447/dG/tI/s108"},"text":"Pub. L. 108–447, div. G, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3177"},"text":"118 Stat. 3177","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd2f3cdd-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd2f3cde-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd2f3cdf-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s117j–1"},"text":"section 117j–1 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Legislative Branch Appropriations Act, 2005, which is div. G of the Consolidated Appropriations Act, 2005.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
