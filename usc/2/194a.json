{"tag":"section","attrib":{"id":"iddc94357e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s194a"},"text":null,"children":[{"tag":"num","attrib":{"value":"194a"},"text":"§ 194a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Request by Congressional committees to officers or employees of Federal departments, agencies, etc., concerned with foreign countries or multilateral organizations for expression of views and opinions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Upon the request of a committee of either House of Congress, a joint committee of Congress, or a member of such committee, any officer or employee of the Department of State, the Agency for International Development, or any other department, agency, or independent establishment of the United States Government primarily concerned with matters relating to foreign countries or multilateral organizations may express his views and opinions, and make recommendations he considers appropriate, if the request of the committee or member of the committee relates to a subject which is within the jurisdiction of that committee.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc94357f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/352/tV/s502"},"text":"Pub. L. 92–352, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-07-13"},"text":"July 13, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/496"},"text":"86 Stat. 496","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/126/s17"},"text":"Pub. L. 93–126, § 17","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-10-18"},"text":"Oct. 18, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/455"},"text":"87 Stat. 455","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dG"},"text":"Pub. L. 105–277, div. G","children":[],"tail":", subdiv. A, title XII, § 1225(g), title XIII, § 1335(n), "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-775"},"text":"112 Stat. 2681–775","children":[],"tail":", 2681–789.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc943580-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc943581-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc943582-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1335/n"},"text":"Pub. L. 105–277, § 1335(n)","children":[],"tail":", struck out “the United States Information Agency,” after “Department of State,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1225/g"},"text":"Pub. L. 105–277, § 1225(g)","children":[],"tail":", struck out “the United States Arms Control and Disarmament Agency,” after “International Development,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1973—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/126"},"text":"Pub. L. 93–126","children":[],"tail":" substituted “or employee of” for “appointed by the President, by and with the advice and consent of the Senate, to a position in”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc943583-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddc943584-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1225/g"},"text":"section 1225(g) of Pub. L. 105–277","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1999-04-01"},"text":"Apr. 1, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1201"},"text":"section 1201 of Pub. L. 105–277","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6511"},"text":"section 6511 of Title 22","children":[],"tail":", Foreign Relations and Intercourse."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1335/n"},"text":"section 1335(n) of Pub. L. 105–277","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1999-10-01"},"text":"Oct. 1, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1301"},"text":"section 1301 of Pub. L. 105–277","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6531"},"text":"section 6531 of Title 22","children":[],"tail":", Foreign Relations and Intercourse."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
