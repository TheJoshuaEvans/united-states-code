{"tag":"section","attrib":{"id":"iddd0917d3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2202"},"text":null,"children":[{"tag":"num","attrib":{"value":"2202"},"text":"§ 2202.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation and naming within the Capitol Visitor Center","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd0917d4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2202/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided under subsection (b), no part of the Capitol Visitor Center may be designated or named without the approval of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd0917d5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2202/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than ¾ of all members on the Capitol Preservation Commission who are members of the Democratic party; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd0917d6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2202/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than ¾ of all members on the Capitol Preservation Commission who are members of the Republican party.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd0917d7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2202/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall not apply to any room or space under the jurisdiction of the Senate or the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd0917d8-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/437/tI/s102"},"text":"Pub. L. 110–437, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-20"},"text":"Oct. 20, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4986"},"text":"122 Stat. 4986","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
