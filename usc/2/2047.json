{"tag":"section","attrib":{"id":"iddcfd304d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2047"},"text":null,"children":[{"tag":"num","attrib":{"value":"2047"},"text":"§ 2047.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supersedure of prior provisions for maintenance and operation of Senate Restaurants","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Sections 2042 to 2047 of this title shall supersede any other Acts or resolutions heretofore approved for the maintenance and operation of the Senate Restaurants: ","children":[{"tag":"i","attrib":{},"text":"Provided, however","children":[],"tail":", That any Acts or resolutions now in effect shall again become effective, should the restaurants at any future time revert to the jurisdiction of the Senate Committee on Rules and Administration."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddcfd304e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/82/s7"},"text":"Pub. L. 87–82, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-07-06"},"text":"July 6, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/200"},"text":"75 Stat. 200","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcfd304f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcfd3050-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddcfd3051-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was classified to section 174j–7 of former Title 40, prior to the enactment of Title 40, Public Buildings, Property, and Works, by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217/s1"},"text":"Pub. L. 107–217, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1062"},"text":"116 Stat. 1062","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
