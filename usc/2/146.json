{"tag":"section","attrib":{"id":"iddc884ec6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s146"},"text":null,"children":[{"tag":"num","attrib":{"value":"146"},"text":"§ 146.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit of Journals of Senate and House","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Twenty-five copies of the public Journals of the Senate, and of the House of Representatives, shall be deposited in the Library of the United States, at the seat of government, to be delivered to Members of Congress during any session, and to all other persons authorized by law to use the books in the Library, upon their application to the Librarian, and giving their responsible receipts for the same, in like manner as for other books.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc884ec7-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(R.S. § 98.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc884ec8-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc884ec9-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddc884eca-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 98 derived from Res. ","children":[{"tag":"date","attrib":{"date":"1813-12-27"},"text":"Dec. 27, 1813","children":[],"tail":", No. 1, "},{"tag":"ref","attrib":{"href":"/us/stat/3/140"},"text":"3 Stat. 140","children":[],"tail":"; Res. "},{"tag":"date","attrib":{"date":"1840-07-20"},"text":"July 20, 1840","children":[],"tail":", No. 5, "},{"tag":"ref","attrib":{"href":"/us/stat/5/409"},"text":"5 Stat. 409","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
