{"tag":"section","attrib":{"id":"iddce08133-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1537"},"text":null,"children":[{"tag":"num","attrib":{"value":"1537"},"text":"§ 1537.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pilot program on small government flexibility","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddce08134-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1537/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the Office of Management and Budget, in consultation with Federal agencies, shall establish pilot programs in at least 2 agencies to test innovative, and more flexible regulatory approaches that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce08135-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1537/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce reporting and compliance burdens on small governments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce08136-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1537/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet overall statutory goals and objectives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce08137-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1537/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program focus","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The pilot programs shall focus on rules in effect or proposed rules, or a combination thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddce08138-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/4/tII/s207"},"text":"Pub. L. 104–4, title II, § 207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-03-22"},"text":"Mar. 22, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/67"},"text":"109 Stat. 67","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
