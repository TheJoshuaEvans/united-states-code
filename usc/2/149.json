{"tag":"section","attrib":{"id":"iddc884ed1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s149"},"text":null,"children":[{"tag":"num","attrib":{"value":"149"},"text":"§ 149.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of books to other libraries","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Librarian of Congress may from time to time transfer to other governmental libraries within the District of Columbia, including the Public Library, books and material in the possession of the Library of Congress in his judgment no longer necessary to its uses, but in the judgment of the custodians of such other collections likely to be useful to them, and may dispose of or destroy such material as has become useless: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That no records of the Federal Government shall be transferred, disposed of, or destroyed under the authority granted in this section."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc884ed2-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch297/s1"},"text":"Mar. 4, 1909, ch. 297, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/858"},"text":"35 Stat. 858","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1951-10-25/ch562/s4/1"},"text":"Oct. 25, 1951, ch. 562, § 4(1)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/65/640"},"text":"65 Stat. 640","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc884ed3-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc884ed4-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc884ed5-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1951—Act ","children":[{"tag":"date","attrib":{"date":"1951-10-25"},"text":"Oct. 25, 1951","children":[],"tail":", inserted proviso."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
