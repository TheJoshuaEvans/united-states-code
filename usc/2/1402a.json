{"tag":"section","attrib":{"id":"iddcd95513-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1402a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1402a"},"text":"§ 1402a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preliminary review of claims","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcd95514-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1402a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preliminary review by hearing officer","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcd95515-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1402a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 7 days after transmission to the employing office of a claim pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1402/b"},"text":"section 1402(b) of this title","children":[],"tail":", the Executive Director shall appoint a hearing officer to conduct a preliminary review of the claim."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd95516-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1402a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Process for appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Executive Director shall appoint a hearing officer under this subsection in the same manner and in accordance with the same requirements and procedures applicable to the appointment of a hearing officer under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1405/c"},"text":"section 1405(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd95517-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1402a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessments required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conducting a preliminary review of a claim under this section, the hearing officer shall assess each of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcd95518-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1402a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether the claimant is a covered employee authorized to obtain relief relating to the claim under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd95519-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1402a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether the office which is the subject of the claim is an employing office under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd9551a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1402a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether the individual filing the claim has met the applicable deadlines for filing the claim under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd9551b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1402a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The identification of factual and legal issues involved with respect to the claim.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd9551c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1402a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The specific relief sought by the individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd9551d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1402a/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether, on the basis of the assessments made under paragraphs (1) through (5), the individual filing the claim is a covered employee who has stated a claim for which, if the allegations contained in the claim are true, relief may be granted under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd9551e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1402a/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The potential for the settlement of the claim without a formal hearing as provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1405"},"text":"section 1405 of this title","children":[],"tail":" or a civil action as provided under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1408"},"text":"section 1408 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd9551f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1402a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on review","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcd95520-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1402a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after a claim is filed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1402"},"text":"section 1402 of this title","children":[],"tail":", the hearing officer shall submit to the individual filing the claim and the office which is the subject of the claim a report on the preliminary review conducted under this section, and shall include in the report the hearing officer’s determination as to whether the individual is a covered employee who has stated a claim for which relief may be granted under this subchapter (as described in paragraph (6) of subsection (b)). The submission of the report shall conclude the preliminary review."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd95521-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1402a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension of deadline","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The hearing officer may (upon notice to the individual filing the claim and the employing office which is the subject of the claim) use an additional period of not to exceed 30 days to conclude the preliminary review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd95522-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1402a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of determination of failure to state claim for which relief may be granted","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the hearing officer’s report on the preliminary review of a claim under subsection (c) includes the determination that the individual filing the claim is not a covered employee or has not stated a claim for which relief may be granted under this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcd95523-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1402a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual (including an individual who is a Library claimant, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1401/d/1"},"text":"section 1401(d)(1) of this title","children":[],"tail":") may not obtain a formal hearing with respect to the claim as provided under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1405"},"text":"section 1405 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd95524-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1402a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the hearing officer shall provide the individual and the Executive Director with a written notice that the individual may file a civil action with respect to the claim in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1408"},"text":"section 1408 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd95525-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1402a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transmission of report on preliminary review of certain claims to congressional ethics committees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a hearing officer’s report under subsection (c) on the preliminary review of a claim alleging a violation described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1415/d/1/A"},"text":"section 1415(d)(1)(A) of this title","children":[],"tail":", the hearing officer shall transmit the report to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcd95526-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1402a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Ethics of the House of Representatives, in the case of such an act by a Member of the House of Representatives (including a Delegate or Resident Commissioner to the Congress); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd95527-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1402a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Select Committee on Ethics of the Senate, in the case of such an act by a Senator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcd95528-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/1/tIV/s403"},"text":"Pub. L. 104–1, title IV, § 403","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/397/tI/s103/a"},"text":"Pub. L. 115–397, title I, § 103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5303"},"text":"132 Stat. 5303","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcd95529-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcd9552a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddcd9552b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (b)(2), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/1"},"text":"Pub. L. 104–1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-01-23"},"text":"Jan. 23, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/3"},"text":"109 Stat. 3","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1301"},"text":"section 1301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"iddcd9552c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/1/s403"},"text":"section 403 of Pub. L. 104–1","children":[],"tail":" was renumbered section 404 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1403"},"text":"section 1403 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcd9552d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddcd9552e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective upon expiration of the 180-day period beginning on ","children":[{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", with provisions for effect on pending proceedings, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/397/s401"},"text":"section 401 of Pub. L. 115–397","children":[],"tail":", set out as an Effective Date of 2018 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
