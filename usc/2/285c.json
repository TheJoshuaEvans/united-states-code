{"tag":"section","attrib":{"id":"iddc96a693-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s285c"},"text":null,"children":[{"tag":"num","attrib":{"value":"285c"},"text":"§ 285c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Law Revision Counsel","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The management, supervision, and administration of the Office are vested in the Law Revision Counsel, who shall be appointed by the Speaker without regard to political affiliation and solely on the basis of fitness to perform the duties of the position. Any person so appointed shall serve at the pleasure of the Speaker.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc96a694-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/554/tI"},"text":"Pub. L. 93–554, title I","children":[],"tail":", ch. III, § 101, "},{"tag":"date","attrib":{"date":"1974-12-27"},"text":"Dec. 27, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1777"},"text":"88 Stat. 1777","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc96a695-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc96a696-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddc96a697-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is based on section 205(d) of House Resolution No. 988, Ninety-third Congress, ","children":[{"tag":"date","attrib":{"date":"1974-10-08"},"text":"Oct. 8, 1974","children":[],"tail":", which was enacted into permanent law by "},{"tag":"ref","attrib":{"href":"/us/pl/93/554"},"text":"Pub. L. 93–554","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
