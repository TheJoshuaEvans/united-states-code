{"tag":"section","attrib":{"id":"iddcf14a59-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1922"},"text":null,"children":[{"tag":"num","attrib":{"value":"1922"},"text":"§ 1922.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unified payroll administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Payroll administration for the Capitol Police and civilian support personnel of the Capitol Police shall be carried out on a unified basis by a single disbursing authority. The Capitol Police Board, with the approval of the Committee on House Oversight of the House of Representatives and the Committee on Rules and Administration of the Senate, acting jointly, shall, by contract or otherwise, provide for such unified payroll administration.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddcf14a5a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-07-31/ch707/s9C"},"text":"July 31, 1946, ch. 707, § 9C","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/397/tI/s102"},"text":"Pub. L. 102–397, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-06"},"text":"Oct. 6, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1950"},"text":"106 Stat. 1950","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/186/tII/s221/12"},"text":"Pub. L. 104–186, title II, § 221(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1750"},"text":"110 Stat. 1750","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcf14a5b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcf14a5c-3a6e-11f1