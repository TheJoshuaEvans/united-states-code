{"tag":"section","attrib":{"id":"iddca4ff2e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s506"},"text":null,"children":[{"tag":"num","attrib":{"value":"506"},"text":"§ 506.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mass mailing sent by House Members","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddca4ff2f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s506/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice that mailing is at taxpayer expense","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddca4ff30-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s506/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each mass mailing sent by a Member of the House of Representatives shall bear in a prominent place on its face, or on the envelope or outside cover or wrapper in which the mail matter is sent, one of the notices described in paragraph (2) or a notice to the same effect in words which may be prescribed under subsection (c). The notice shall be printed in a type size not smaller than 7-point.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca4ff31-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s506/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The notices described in this paragraph are as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddca4ff32-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s506/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Paid for with official funds from the office of _____.”, with the blank filled in with the name of the Member sending the mailing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddca4ff33-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s506/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Paid for by the funds authorized by the House of Representatives for District __ of _____.”, with the first blank filled in with the name of the congressional district number, and the second blank filled in with the name of the State, of the Member sending the mailing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddca4ff34-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s506/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Paid for by official funds authorized by the House of Representatives.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca4ff35-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s506/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication of each Member’s total expense and amount","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddca4ff36-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s506/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There shall be published in the itemized report of disbursements of the House of Representatives as required by law, a summary tabulation setting forth, for the office of each Member of the House of Representatives, the total number of pieces of mass mail mailed during the period involved and the total cost of those mass mailings.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca4ff37-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s506/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each such tabulation shall also include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddca4ff38-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s506/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total cost (as referred to in paragraph (1)) divided by the number (as determined by the Postmaster General) of addresses (other than business possible delivery stops) in the Congressional district from which the Member was elected (as such addresses are described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s3210/d/7/B"},"text":"section 3210(d)(7)(B) of title 39","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddca4ff39-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s506/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of pieces of mass mail (as referred to in paragraph (1)) divided by the number (as determined by the Postmaster General) of addresses (other than business possible delivery stops) in the Congressional district from which the Member was elected (as such addresses are described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s3210/d/7/B"},"text":"section 3210(d)(7)(B) of title 39","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca4ff3a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s506/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Committee on House Oversight shall prescribe such rules and regulations and shall take such other action as the Committee considers necessary and proper for Members to conform to the provisions of this subsection and applicable rules and regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca4ff3b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s506/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddca4ff3c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s506/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Member of the House of Representatives” means a Representative in, or a Delegate or Resident Commissioner to, the Congress; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca4ff3d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s506/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “mass mailing” has the meaning given such term by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s3210/a/6/E"},"text":"section 3210(a)(6)(E) of title 39","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca4ff3e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s506/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply with respect to sessions of Congress beginning after ","children":[{"tag":"date","attrib":{"date":"1996-09-16"},"text":"September 16, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddca4ff3f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/197/tIII/s311"},"text":"Pub. L. 104–197, title III, § 311","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-16"},"text":"Sept. 16, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2414"},"text":"110 Stat. 2414","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dI/tI/s116/d"},"text":"Pub. L. 116–260, div. I, title I, § 116(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1640"},"text":"134 Stat. 1640","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddca4ff40-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddca4ff41-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddca4ff42-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s59h"},"text":"section 59h of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Legislative Branch Appropriations Act, 1997.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddca4ff43-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" designated existing provisions as par. (1), substituted “one of the notices described in paragraph (2) or a notice” for “the following notice: “this mailing was prepared, published, and mailed at taxpayer expense.”, or a notice”, and added par. (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddca4ff44-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"iddca4ff45-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on House Oversight of House of Representatives changed to Committee on House Administration of House of Representatives by House Resolution No. 5, One Hundred Sixth Congress, ","children":[{"tag":"date","attrib":{"date":"1999-01-06"},"text":"Jan. 6, 1999","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddca4ff46-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2020 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" applicable with respect to communications disseminated on or after "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dI/s116/f"},"text":"section 116(f) of div. I of Pub. L. 116–260","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s501"},"text":"section 501 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
