{"tag":"section","attrib":{"id":"iddd31ad96-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5604"},"text":null,"children":[{"tag":"num","attrib":{"value":"5604"},"text":"§ 5604.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of Sergeant at Arms","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It shall be the duty of the Sergeant at Arms of the House of Representatives to attend the House during its sittings, to maintain order under the direction of the Speaker, and, pending the election of a Speaker or Speaker pro tempore, under the direction of the Clerk, execute the commands of the House and all processes issued by authority thereof, directed to him by the Speaker.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd31ad97-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1890-10-01/ch1256/s1"},"text":"Oct. 1, 1890, ch. 1256, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/26/645"},"text":"26 Stat. 645","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/186/tII/s204/25/A"},"text":"Pub. L. 104–186, title II, § 204(25)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1733"},"text":"110 Stat. 1733","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd31ad98-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd31ad99-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd31ad9a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text"