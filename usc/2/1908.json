{"tag":"section","attrib":{"id":"iddcf149e9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1908"},"text":null,"children":[{"tag":"num","attrib":{"value":"1908"},"text":"§ 1908.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Legal representation authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcf149ea-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1908/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcf149eb-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1908/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of representation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any counsel described under paragraph (2) may for the purposes of providing legal assistance and representation to the United States Capitol Police Board or the United States Capitol Police enter an appearance in any proceeding before any court of the United States or of any State or political subdivision thereof, without compliance with any requirement for admission to practice before such court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf149ec-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1908/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Counsel","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) refers to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcf149ed-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1908/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the General Counsel to the Chief of Police and the United States Capitol Police;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcf149ee-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1908/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Employment Counsel to the Chief of Police and the United States Capitol Police;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcf149ef-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1908/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any attorney employed in the Office of the General Counsel for the United States Capitol Police or the Office of Employment Counsel for the United States Capitol Police;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcf149f0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1908/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the counsel for, or any attorney employed by, any successor office of either office described under subparagraph (C); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcf149f1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1908/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any attorney retained by contract with either office described under subparagraph (C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcf149f2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1908/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcf149f3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1908/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direction for appearance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Entrance of appearance authorized under subsection (a) shall be subject to the direction of the Capitol Police Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf149f4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1908/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States Supreme Court","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority under subsection (a) shall not apply with respect to the admission of any person to practice before the United States Supreme Court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcf149f5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1908/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply to fiscal year 2004, and each fiscal year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcf149f6-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/83/tI/s1002"},"text":"Pub. L. 108–83, title I, § 1002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-09-30"},"text":"Sept. 30, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1020"},"text":"117 Stat. 1020","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/145"},"text":"Pub. L. 111–145","children":[],"tail":", §§ 3(b)(1), 4(a)(1), "},{"tag":"date","attrib":{"date":"2010-03-04"},"text":"Mar. 4, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/52"},"text":"124 Stat. 52","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcf149f7-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcf149f8-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddcf149f9-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Legislative Branch Appropriations Act, 2004.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcf149fa-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/145/s3/b/1"},"text":"Pub. L. 111–145, § 3(b)(1)","children":[],"tail":", substituted “the General Counsel to the Chief of Police and the United States Capitol Police” for “the General Counsel for the United States Capitol Police Board and the Chief of the Capitol Police”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/145/s4/a/1"},"text":"Pub. L. 111–145, § 4(a)(1)","children":[],"tail":", substituted “the Employment Counsel to the Chief of Police and the United States Capitol Police” for “the Employment Counsel for the United States Capitol Police Board and the United States Capitol Police”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcf149fb-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddcf149fc-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/145/s3/b/2"},"text":"Pub. L. 111–145, § 3(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-04"},"text":"Mar. 4, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/52"},"text":"124 Stat. 52","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/145/s3/b/2"},"text":"“Nothing in the amendment made by paragraph (1) [amending this section] may be construed to affect the authority of any individual to enter an appearance in any proceeding before any court of the United States or of any State or political subdivision thereof which is initiated prior to the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2010-03-04"},"text":"Mar. 4, 2010","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/145/s4/a/2"},"text":"Pub. L. 111–145, § 4(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-04"},"text":"Mar. 4, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/52"},"text":"124 Stat. 52","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/145/s4/a/2"},"text":"“Nothing in the amendment made by paragraph (1) [amending this section] may be construed to affect the authority of any individual to enter an appearance in any proceeding before any court of the United States or of any State or political subdivision thereof which is initiated prior to the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2010-03-04"},"text":"Mar. 4, 2010","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/145/s4/b"},"text":"Pub. L. 111–145, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-04"},"text":"Mar. 4, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/52"},"text":"124 Stat. 52","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/145/s4/b"},"text":"“Nothing in this section [amending this section and enacting provisions set out as a note above] or the amendments made by this section may be construed to affect the status of the individual serving as the Employment Counsel to the Chief of Police and the United States Capitol Police as of the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2010-03-04"},"text":"Mar. 4, 2010","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
