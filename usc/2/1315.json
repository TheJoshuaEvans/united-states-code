{"tag":"section","attrib":{"id":"iddcd229c6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1315"},"text":null,"children":[{"tag":"num","attrib":{"value":"1315"},"text":"§ 1315.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights and protections under Worker Adjustment and Retraining Notification Act","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcd229c7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1315/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Worker adjustment and retraining notification rights","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcd229c8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1315/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No employing office shall be closed or a mass layoff ordered within the meaning of section 3 of the Worker Adjustment and Retraining Notification Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2102"},"text":"29 U.S.C. 2102","children":[],"tail":") until the end of a 60-day period after the employing office serves written notice of such prospective closing or layoff to representatives of covered employees or, if there are no representatives, to covered employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd229c9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1315/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “covered employee” shall include employees of the Government Accountability Office and the term “employing office” shall include the Government Accountability Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd229ca-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1315/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remedy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The remedy for a violation of subsection (a) shall be such remedy as would be appropriate if awarded under paragraphs (1), (2), and (4) of section 5(a) of the Worker Adjustment and Retraining Notification Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2104/a/1"},"text":"29 U.S.C. 2104(a)(1)","children":[],"tail":", (2), and (4))."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd229cb-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1315/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations to implement section","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcd229cc-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1315/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall, pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1384"},"text":"section 1384 of this title","children":[],"tail":", issue regulations to implement this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd229cd-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1315/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The regulations issued under paragraph (1) shall be the same as substantive regulations promulgated by the Secretary of Labor to implement the statutory provisions referred to in subsection (a) except insofar as the Board may determine, for good cause shown and stated together with the regulation, that a modification of such regulations would be more effective for the implementation of the rights and protections under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd229ce-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1315/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcd229cf-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1315/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), subsections (a) and (b) shall be effective 1 year after ","children":[{"tag":"date","attrib":{"date":"1995-01-23"},"text":"January 23, 1995","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd229d0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1315/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Government Accountability Office and Library of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall be effective with respect to the Government Accountability Office and the Library of Congress 1 year after transmission to the Congress of the study under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1371"},"text":"section 1371 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcd229d1-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/1/tII/s205"},"text":"Pub. L. 104–1, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-01-23"},"text":"Jan. 23, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/11"},"text":"109 Stat. 11","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/271/s8/b"},"text":"Pub. L. 108–271, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-07"},"text":"July 7, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/814"},"text":"118 Stat. 814","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dI/tI/s153/a/2/B"},"text":"Pub. L. 115–141, div. I, title I, § 153(a)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/785"},"text":"132 Stat. 785","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcd229d2-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcd229d3-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcd229d4-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" struck out “and the Library of Congress” after “the Government Accountability Office” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271"},"text":"Pub. L. 108–271","children":[],"tail":" substituted “Government Accountability Office” for “General Accounting Office” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271"},"text":"Pub. L. 108–271","children":[],"tail":" substituted “Government Accountability Office” for “General Accounting Office” in heading and text."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
