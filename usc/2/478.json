{"tag":"section","attrib":{"id":"iddca28db2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s478"},"text":null,"children":[{"tag":"num","attrib":{"value":"478"},"text":"§ 478.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Utilization of the Government Accountability Office","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddca28db3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s478/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Government Accountability Office to furnish financial and administrative services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Financial and administrative services (including those related to budgeting, accounting, financial reporting, personnel, and procurement) and such other services as may be appropriate shall be provided the Office by the Government Accountability Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca28db4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s478/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope of services and assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such services and assistance to the Office shall include, but not be limited to, all of the services and assistance which the Government Accountability Office is otherwise authorized to provide to the Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca28db5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s478/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Services or responsibilities performed by Government Accountability Office for Congress not altered or modified","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall alter or modify any services or responsibilities, other than those performed for the Office, which the Government Accountability Office under law performs for or on behalf of the Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca28db6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s478/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement for services and assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Services and assistance made available to the Office by the Government Accountability Office in accordance with this section may be provided with or without reimbursement from funds of the Office, as agreed upon by the Board and the Comptroller General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddca28db7-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/484/s9"},"text":"Pub. L. 92–484, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-13"},"text":"Oct. 13, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/802"},"text":"86 Stat. 802","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/271/s8/b"},"text":"Pub. L. 108–271, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-07"},"text":"July 7, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/814"},"text":"118 Stat. 814","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddca28db8-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddca28db9-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddca28dba-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271"},"text":"Pub. L. 108–271","children":[],"tail":" substituted “Government Accountability Office” for “General Accounting Office” in section catchline and wherever appearing in text."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
