{"tag":"section","attrib":{"id":"iddcea1e18-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1843"},"text":null,"children":[{"tag":"num","attrib":{"value":"1843"},"text":"§ 1843.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Obsolete references","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In any case in which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcea1e19-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1843/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the rate of pay of, or any maximum or minimum rate of pay with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcea1e1a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1843/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any employee described in subparagraph (1) or subparagraph (2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1841"},"text":"section 1841 of this title","children":[],"tail":", or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcea1e1b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1843/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the position of such employee, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcea1e1c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1843/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any class or group of such employees or positions,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"is referred to in or provided by statute or other authority; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcea1e1d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1843/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rate so referred to or provided is a basic rate with respect to which additional pay is provided by law;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"such statutory provision or authority shall be deemed to refer, in lieu of such basic rate, to the per annum gross rate which an employee receiving such basic rate immediately prior to the effective date of this section would receive, without regard to such statutory provision or authority, under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1842"},"text":"section 1842 of this title","children":[],"tail":" on and after such date."}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcea1e1e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/510/tIV/s483"},"text":"Pub. L. 91–510, title IV, § 483","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-26"},"text":"Oct. 26, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1196"},"text":"84 Stat. 1196","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcea1e1f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcea1e20-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddcea1e21-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The effective date of this section, referred to in text, means immediately prior to noon on ","children":[{"tag":"date","attrib":{"date":"1971-01-03"},"text":"Jan. 3, 1971","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/pl/91/510/s601/1"},"text":"section 601(1) of Pub. L. 91–510","children":[],"tail":", set out as an Effective Date of 1970 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s4301"},"text":"section 4301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddcea1e22-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was classified to section 166b–1c of former Title 40, prior to the enactment of Title 40, Public Buildings, Property, and Works, by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217/s1"},"text":"Pub. L. 107–217, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1062"},"text":"116 Stat. 1062","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
