{"tag":"section","attrib":{"id":"iddd1043cf-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4314"},"text":null,"children":[{"tag":"num","attrib":{"value":"4314"},"text":"§ 4314.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on allowance authority of Committee on House Oversight","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd1043d0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4314/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An order under the provision of law specified in subsection (c) may fix or adjust the allowances of the House of Representatives only by reason of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd1043d1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4314/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a change in the price of materials, services, or office space;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1043d2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4314/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a technological change or other improvement in office equipment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1043d3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4314/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an increase under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5303"},"text":"section 5303 of title 5","children":[],"tail":" in rates of pay under the General Schedule."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1043d4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4314/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Resolution requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of reasons other than the reasons specified in paragraph (1), (2), or (3) of subsection (a), the fixing and adjustment of the allowances of the House of Representatives in the categories described in the provision of law specified in subsection (c) may be carried out only by resolution of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1043d5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4314/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision specified","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provision of law referred to in subsections (a) and (b) is ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s4313"},"text":"section 4313 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd1043d6-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/440/tII/s101"},"text":"Pub. L. 94–440, title II, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-01"},"text":"Oct. 1, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1448"},"text":"90 Stat. 1448","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/186/tI/s103"},"text":"Pub. L. 104–186, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1720"},"text":"110 Stat. 1720","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd1043d7-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd1043d8-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd1043d9-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The General Schedule, referred to in subsec. (a)(3), is set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd1043da-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s57a"},"text":"section 57a of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is based on House Resolution No. 1372, § 1, Ninety-fourth Congress, ","children":[{"tag":"date","attrib":{"date":"1976-07-01"},"text":"July 1, 1976","children":[],"tail":", which was enacted into permanent law by "},{"tag":"ref","attrib":{"href":"/us/pl/94/440"},"text":"Pub. L. 94–440","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd1043db-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186"},"text":"Pub. L. 104–186","children":[],"tail":" amended section generally. Prior to amendment, section consisted of subsecs. (a) and (b) relating to limitations on authority of the Committee on House Administration to fix and adjust allowances."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd1043dc-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"iddd1043dd-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on House Oversight of House of Representatives changed to Committee on House Administration of House of Representatives by House Resolution No. 5, One Hundred Sixth Congress, ","children":[{"tag":"date","attrib":{"date":"1999-01-06"},"text":"Jan. 6, 1999","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
