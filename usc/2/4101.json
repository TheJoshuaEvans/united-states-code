{"tag":"section","attrib":{"id":"iddd0b88a1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4101"},"text":null,"children":[{"tag":"num","attrib":{"value":"4101"},"text":"§ 4101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of officers of Congress over Congressional employees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd0b88a2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4101/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications determinations; removal and discipline","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each officer of the Congress having responsibility for the supervision of employees, including employees appointed upon recommendation of Members of Congress, shall have authority—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd0b88a3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4101/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to determine, before the appointment of any individual as an employee under the supervision of that officer of the Congress, whether that individual possesses the qualifications necessary for the satisfactory performance of the duties and responsibilities to be assigned to him; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd0b88a4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4101/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to remove or otherwise discipline any employee under his supervision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd0b88a5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4101/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Officer of the Congress” defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section, the term “officer of the Congress” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd0b88a6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4101/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an elected officer of the Senate or House of Representatives who is not a Member of the Senate or House; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd0b88a7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4101/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Architect of the Capitol.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd0b88a8-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/510/tIV/s431"},"text":"Pub. L. 91–510, title IV, § 431","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-26"},"text":"Oct. 26, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1190"},"text":"84 Stat. 1190","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd0b88a9-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd0b88aa-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd0b88ab-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s60–1"},"text":"section 60–1 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd0b88ac-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd0b88ad-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective immediately prior to noon on ","children":[{"tag":"date","attrib":{"date":"1971-01-03"},"text":"Jan. 3, 1971","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/510/s601/1"},"text":"section 601(1) of Pub. L. 91–510","children":[],"tail":", set out as an Effective Date of 1970 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s4301"},"text":"section 4301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
