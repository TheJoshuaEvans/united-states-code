{"tag":"section","attrib":{"id":"iddd31ae09-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6114"},"text":null,"children":[{"tag":"num","attrib":{"value":"6114"},"text":"§ 6114.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment and compensation of Administrative Assistant, Legislative Assistant, and Executive Secretary for Deputy President pro tempore of Senate","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Effective ","children":[{"tag":"date","attrib":{"date":"1977-04-01"},"text":"April 1, 1977","children":[],"tail":", the Deputy President pro tempore is authorized to appoint and fix the compensation of an Administrative Assistant at not to exceed $47,595 per annum; a Legislative Assistant at not to exceed $40,080 per annum, and an Executive Secretary at not to exceed $23,380 per annum."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd31ae0a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/26/tI"},"text":"Pub. L. 95–26, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-05-04"},"text":"May 4, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/80"},"text":"91 Stat. 80","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd31ae0b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd31ae0c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd31ae0d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 61","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Supplemental Appropriations Act, 1977.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd31ae0e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd31ae0f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Increases in Compensation","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Increases in compensation for officers and employees of the Senate under authority of the Federal Pay Comparability Act of 1970 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/656"},"text":"Pub. L. 91–656","children":[],"tail":"), see Salary Directives of the President pro tempore of the Senate, set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s4571"},"text":"section 4571 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
