{"tag":"section","attrib":{"id":"iddcb32ee8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s655"},"text":null,"children":[{"tag":"num","attrib":{"value":"655"},"text":"§ 655.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Off-budget agencies, programs, and activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcb32ee9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s655/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of law, budget authority, credit authority, and estimates of outlays and receipts for activities of the Federal budget which are off-budget immediately prior to ","children":[{"tag":"date","attrib":{"date":"1985-12-12"},"text":"December 12, 1985","children":[],"tail":", not including activities of the Federal Old-Age and Survivors Insurance and Federal Disability Insurance Trust Funds, shall be included in a budget submitted pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":" and in a concurrent resolution on the budget reported pursuant to section 632 or "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s635"},"text":"section 635 of this title","children":[],"tail":" and shall be considered, for purposes of this Act, budget authority, outlays, and spending authority in accordance with definitions set forth in this Act."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcb32eea-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s655/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All receipts and disbursements of the Federal Financing Bank with respect to any obligations which are issued, sold, or guaranteed by a Federal agency shall be treated as a means of financing such agency for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":" and for purposes of this Act."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcb32eeb-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/344/tIV/s405"},"text":"Pub. L. 93–344, title IV, § 405","children":[],"tail":", formerly § 406, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/177/tII/s214"},"text":"Pub. L. 99–177, title II, § 214","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-12"},"text":"Dec. 12, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1059"},"text":"99 Stat. 1059","children":[],"tail":"; renumbered § 405, "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/tX/s10116/c/1"},"text":"Pub. L. 105–33, title X, § 10116(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/692"},"text":"111 Stat. 692","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcb32eec-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcb32eed-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddcb32eee-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, means ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/344"},"text":"Pub. L. 93–344","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-07-12"},"text":"July 12, 1974","children":[],"tail