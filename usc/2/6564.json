{"tag":"section","attrib":{"id":"iddd3d94ed-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6564"},"text":null,"children":[{"tag":"num","attrib":{"value":"6564"},"text":"§ 6564.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel expenses of Secretary of Senate; advancement of travel funds to designated employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out his duties, the Secretary of the Senate is authorized to incur official travel expenses. The Secretary of the Senate is authorized to advance, in his discretion, to any designated employee under his jurisdiction, such sums as may be necessary, not exceeding $1,000, to defray official travel expenses in assisting the Secretary in carrying out his duties. Any such employee shall, as soon as practicable, furnish to the Secretary a detailed voucher for such expenses incurred and make settlement with respect to any amount so advanced. Payments to carry out the provisions of this section shall be made from funds included in the appropriation “Miscellaneous Items” under the heading “Contingent Expenses of the Senate” upon vouchers approved by the Secretary of the Senate.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd3d94ee-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/59/tI/s101"},"text":"Pub. L. 94–59, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-07-25"},"text":"July 25, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/273"},"text":"89 Stat. 273","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/94/tI/s106"},"text":"Pub. L. 95–94, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-05"},"text":"Aug. 5, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/661"},"text":"91 Stat. 661","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/355/tI/s101"},"text":"Pub. L. 95–355, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-09-08"},"text":"Sept. 8, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/533"},"text":"92 Stat. 533","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/12/tI/s102"},"text":"Pub. L. 97–12, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-06-05"},"text":"June 5, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/61"},"text":"95 Stat. 61","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/367/tI/s1"},"text":"Pub. L. 98–367, title I, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-17"},"text":"July 17, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/474"},"text":"98 Stat. 474","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd3d94ef-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd3d94f0-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd3d94f1-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s61a–9a"},"text":"section 61a–9a of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd3d94f2-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/367"},"text":"Pub. L. 98–367","children":[],"tail":" struck out provision that travel expenses could not exceed $10,000 during any fiscal year."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/12"},"text":"Pub. L. 97–12","children":[],"tail":" substituted “$10,000” for “$7,500”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/355"},"text":"Pub. L. 95–355","children":[],"tail":" substituted “$7,500” for “$5,500”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/94"},"text":"Pub. L. 95–94","children":[],"tail":" substituted “$5,500” for “$5,000”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd3d94f3-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd3d94f4-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/367/tI/s1"},"text":"Pub. L. 98–367, title I, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-17"},"text":"July 17, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/474"},"text":"98 Stat. 474","children":[],"tail":", provided that the amendment made by section 1 is effective with respect to fiscal years beginning on or after "},{"tag":"date","attrib":{"date":"1983-10-01"},"text":"Oct. 1, 1