{"tag":"section","attrib":{"id":"iddc943572-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s193"},"text":null,"children":[{"tag":"num","attrib":{"value":"193"},"text":"§ 193.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Privilege of witnesses","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No witness is privileged to refuse to testify to any fact, or to produce any paper, respecting which he shall be examined by either House of Congress, or by any joint committee established by a joint or concurrent resolution of the two Houses of Congress, or by any committee of either House, upon the ground that his testimony to such fact or his production of such paper may tend to disgrace him or otherwise render him infamous.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc943573-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(R.S. § 103; ","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-22/ch594"},"text":"June 22, 1938, ch. 594","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/942"},"text":"52 Stat. 942","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc943574-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc943575-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddc943576-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 103 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1862-01-24/ch11"},"text":"act Jan. 24, 1862, ch. 11","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/12/333"},"text":"12 Stat. 333","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc943577-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1938—Act ","children":[{"tag":"date","attrib":{"date":"1938-06-22"},"text":"June 22, 1938","children":[],"tail":", reenacted section without change."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
