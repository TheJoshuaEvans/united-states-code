{"tag":"section","attrib":{"id":"iddca748a1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s606"},"text":null,"children":[{"tag":"num","attrib":{"value":"606"},"text":"§ 606.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of surplus or obsolete property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddca748a2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s606/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Congressional Budget Office shall have the authority, within the limits of available appropriations, to dispose of surplus or obsolete personal property by inter-agency transfer, donation, sale, trade-in, or discarding. Amounts received for the sale or trade-in of personal property shall be credited to funds available for the operations of the Congressional Budget Office and be available for the costs of acquiring the same or similar property. Such funds shall be available for such purposes during the fiscal year in which received and the following fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca748a3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s606/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsection (a) shall apply with respect to fiscal years beginning after ","children":[{"tag":"date","attrib":{"date":"1996-09-30"},"text":"September 30, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddca748a4-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/197/tI/s105"},"text":"Pub. L. 104–197, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-16"},"text":"Sept. 16, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2404"},"text":"110 Stat. 2404","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/68/tI/s126"},"text":"Pub. L. 107–68, title I, § 126","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-11-12"},"text":"Nov. 12, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/577"},"text":"115 Stat. 577","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddca748a5-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddca748a6-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddca748a7-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the appropriation act cited as the credit to this section, and not as part of title II of the Congressional Budget and Impoundment Control Act of 1974 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"iddca748a8-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in the following prior appropriation acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/53/tI"},"text":"Pub. L. 104–53, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-11-19"},"text":"Nov. 19, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/527"},"text":"109 Stat. 527","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/283/tI"},"text":"Pub. L. 103–283, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-22"},"text":"July 22, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1433"},"text":"108 Stat. 1433","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/69/tI"},"text":"Pub. L. 103–69, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-11"},"text":"Aug. 11, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/701"},"text":"107 Stat. 701","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddca748a9-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2001—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/68"},"text":"Pub. L. 107–68","children":[],"tail":" substituted “sale, trade-in, or discarding” for “or discarding” and inserted at end “Amounts received for the sale or trade-in of personal property shall be credited to funds available for the operations of the Congressional Budget Office and be available for the costs of acquiring the same or similar property. Such funds shall be available for such purposes during the fiscal year in which received and the following fiscal year.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
