{"tag":"section","attrib":{"id":"iddc884f17-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s159"},"text":null,"children":[{"tag":"num","attrib":{"value":"159"},"text":"§ 159.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Perpetual succession and suits by or against Library of Congress Trust Fund Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The board shall have perpetual succession, with all the usual powers and obligations of a trustee, including the power to sell, except as herein limited, in respect of all property, moneys, or securities which shall be conveyed, transferred, assigned, bequeathed, delivered, or paid over to it for the purposes above specified. The board may be sued in the United States District Court for the District of Columbia, which is given jurisdiction of such suits, for the purpose of enforcing the provisions of any trust accepted by it.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc884f18-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1925-03-03/ch423/s3"},"text":"Mar. 3, 1925, ch. 423, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/43/1108"},"text":"43 Stat. 1108","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1926-01-27/ch6/s1"},"text":"Jan. 27, 1926, ch. 6, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/2"},"text":"44 Stat. 2","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1936-06-25/ch804"},"text":"June 25, 1936, ch. 804","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1921"},"text":"49 Stat. 1921","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646/s32/a"},"text":"June 25, 1948, ch. 646, § 32(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/991"},"text":"62 Stat. 991","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-05-24/ch139/s127"},"text":"May 24, 1949, ch. 139, § 127","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/107"},"text":"63 Stat. 107","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc884f19-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc884f1a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc884f1b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1926—Act ","children":[{"tag":"date","attrib":{"date":"1926-01-27"},"text":"Jan. 27, 1926","children":[],"tail":", inserted “including the power to sell” in first sentence."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc884f1c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"iddc884f1d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1948-06-25"},"text":"June 25, 1948","children":[],"tail":", eff. "},{"tag":"date","attrib":{"date":"1948-09-01"},"text":"Sept. 1, 1948","children":[],"tail":", as amended by act "},{"tag":"date","attrib":{"date":"1949-05-24"},"text":"May 24, 1949","children":[],"tail":", substituted “United States District Court for the District of Columbia” for “district court of the United States for the District of Columbia”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1936-06-25"},"text":"June 25, 1936","children":[],"tail":", provided that the Supreme Court of the District of Columbia is to be known as the District Court of the United States for the District of Columbia."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
