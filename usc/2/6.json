{"tag":"section","attrib":{"id":"iddc6e1027-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"§ 6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction of representation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Should any State deny or abridge the right of any of the male inhabitants thereof, being twenty-one years of age, and citizens of the United States, to vote at any election named in the amendment to the Constitution, article 14, section 2, except for participation in the rebellion or other crime, the number of Representatives apportioned to such State shall be reduced in the proportion which the number of such male citizens shall have to the whole number of male citizens twenty-one years of age in such State.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc6e1028-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(R.S. § 22.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc6e1029-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc6e102a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddc6e102b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 22 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1872-02-02/ch11/s6"},"text":"act Feb. 2, 1872, ch. 11, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/17/29"},"text":"17 Stat. 29","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
