:"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1950-06-30"},"text":"June 30, 1950","children":[],"tail":", $250,000; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For each fiscal year thereafter such sums as may be necessary to carry on the work of the Office.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[Section 204 of act ","children":[{"tag":"date","attrib":{"date":"1946-08-02"},"text":"Aug. 2, 1946","children":[],"tail":", set out above, was made effective "},{"tag":"date","attrib":{"date":"1946-08-02"},"text":"Aug. 2, 1946","children":[],"tail":", by section 245 of act "},{"tag":"date","attrib":{"date":"1946-08-02"},"text":"Aug. 2, 1946","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s4301"},"text":"section 4301 of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
