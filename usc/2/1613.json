{"tag":"section","attrib":{"id":"iddce2f2b6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1613"},"text":null,"children":[{"tag":"num","attrib":{"value":"1613"},"text":"§ 1613.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on provision of gifts or travel by registered lobbyists to Members of Congress and to congressional employees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddce2f2b7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1613/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person described in subsection (b) may not make a gift or provide travel to a covered legislative branch official if the person has knowledge that the gift or travel may not be accepted by that covered legislative branch official under the Rules of the House of Representatives or the Standing Rules of the Senate (as the case may be).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce2f2b8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1613/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persons subject to prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The persons subject to the prohibition under subsection (a) are any lobbyist that is registered or is required to register under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1603/a/1"},"text":"section 1603(a)(1) of this title","children":[],"tail":", any organization that employs 1 or more lobbyists and is registered or is required to register under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1603/a/2"},"text":"section 1603(a)(2) of this title","children":[],"tail":", and any employee listed or required to be listed as a lobbyist by a registrant under section 1603(b)(6) or 1604(b)(2)(C) of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddce2f2b9-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/65/s25"},"text":"Pub. L. 104–65, § 25","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/81/tII/s206/a"},"text":"Pub. L. 110–81, title II, § 206(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-09-14"},"text":"Sept. 14, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/747"},"text":"121 Stat. 747","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddce2f2ba-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddce2f2bb-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddce2f2bc-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/81/tII/s206/b"},"text":"Pub. L. 110–81, title II, § 206(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-09-14"},"text":"Sept. 14, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/747"},"text":"121 Stat. 747","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/81/tII/s206/b"},"text":"“The amendment made by this section [enacting this section] shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2007-09-14"},"text":"Sept. 14, 2007","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
