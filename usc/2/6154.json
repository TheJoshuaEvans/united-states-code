{"tag":"section","attrib":{"id":"iddd33f88e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6154"},"text":null,"children":[{"tag":"num","attrib":{"value":"6154"},"text":"§ 6154.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offices of the Secretaries of the Conference of the Majority and the Conference of the Minority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd33f88f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6154/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon the written request of the Secretary of the Conference of the Majority or the Secretary of the Conference of the Minority, the Secretary of the Senate shall transfer from the appropriations account appropriated under the subheading “","children":[{"tag":"inline","attrib":{},"text":"offices of the secretaries of the conference of the majority and the conference of the minority","children":[],"tail":"” under the heading “"},{"tag":"inline","attrib":{},"text":"Salaries, Officers and Employees","children":[],"tail":"” such amount as the Secretary of the Conference of the Majority or the Secretary of the Conference of the Minority shall specify to the appropriations account under the heading “"},{"tag":"inline","attrib":{},"text":"miscellaneous items","children":[],"tail":"” within the contingent fund of the Senate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd33f890-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6154/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to incur expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Conference of the Majority or the Secretary of the Conference of the Minority may incur such expenses as may be necessary or appropriate. Expenses incurred by the Secretary of the Conference of the Majority or the Secretary of the Conference of the Minority shall be paid from the amount transferred under subsection (a) by the Secretary of the Conference of the Majority or the Secretary of the Conference of the Minority and upon vouchers approved by the Secretary of the Conference of the Majority or the Secretary of the Conference of the Minority, as applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd33f891-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6154/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to advance sums","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Senate may advance such sums as may be necessary to defray expenses incurred in carrying out subsections (a) and (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd33f892-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6154/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply to fiscal year 2008 and each fiscal year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd33f893-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161/dH/tI/s3"},"text":"Pub. L. 110–161, div. H, title I, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2221"},"text":"121 Stat. 2221","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd33f894-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd33f895-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd33f896-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s61g–6b"},"text":"section 61g–6b of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Legislative Branch Appropriations Act, 2008, which is div. H of the Consolidated Appropriations Act, 2008.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd33f897-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd33f898-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Senate Democratic Leadership Offices Funding and Authorities","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dI/tI/s104"},"text":"Pub. L. 116–260, div. I, title I, § 104","ch