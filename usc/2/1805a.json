{"tag":"section","attrib":{"id":"iddce56297-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1805a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1805a"},"text":"§ 1805a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deputy Architect of the Capitol to serve as acting in case of absence, disability, or vacancy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddce56298-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1805a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Deputy Architect of the Capitol (in this section referred to as the “Deputy Architect”) shall act as Architect of the Capitol (in this section referred to as the “Architect”) if the Architect is absent or disabled or there is no Architect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce56299-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1805a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Absence, disability, or vacancy in Office of Deputy Architect","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a), if the Deputy Architect is also absent or disabled or there is no Deputy Architect, the congressional commission described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1801a/a"},"text":"section 1801a(a) of this title","children":[],"tail":" shall designate, by a majority vote of the members of the commission, an individual to serve as acting Architect until—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce5629a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1805a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the end of the absence or disability of the Architect or the Deputy Architect; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce5629b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1805a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of vacancies in both positions, an Architect has been appointed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1801a/a"},"text":"section 1801a(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce5629c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1805a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An officer serving as acting Architect under subsection (a) or (b) shall perform all the duties and exercise all the authorities of the Architect, including the authority to delegate the duties and authorities of the Architect in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1803"},"text":"section 1803 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddce5629d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dE/tLVII/s5704"},"text":"Pub. L. 118–31, div. E, title LVII, § 5704","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/961"},"text":"137 Stat. 961","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddce5629e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddce5629f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddce562a0-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s5704"},"text":"section 5704 of Pub. L. 118–31","children":[],"tail":". Subsec. (d) of "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/s5704"},"text":"section 5704 of Pub. L. 118–31","children":[],"tail":" repealed "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1804"},"text":"section 1804 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
