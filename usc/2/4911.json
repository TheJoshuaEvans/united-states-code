{"tag":"section","attrib":{"id":"iddd25a07f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4911"},"text":null,"children":[{"tag":"num","attrib":{"value":"4911"},"text":"§ 4911.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" House of Representatives Page Board; establishment and purpose","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd25a080-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4911/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Until otherwise provided by law, there is hereby established a board to be known as the House of Representatives Page Board to ensure that the page program is conducted in a manner that is consistent with the efficient functioning of the House and the welfare of the pages.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd25a081-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4911/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Page Board shall meet regularly, in accordance with a schedule established jointly by the Speaker and minority leader of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd25a082-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/377/tI/s127"},"text":"Pub. L. 97–377, title I, § 127","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-12-21"},"text":"Dec. 21, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1914"},"text":"96 Stat. 1914","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/2/s3"},"text":"Pub. L. 110–2, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-02-02"},"text":"Feb. 2, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/5"},"text":"121 Stat. 5","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd25a083-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd25a084-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd25a085-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s88b–2"},"text":"section 88b–2 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is based on section 1 of House Resolution No. 611, Ninety-seventh Congress, ","children":[{"tag":"date","attrib":{"date":"1982-11-30"},"text":"Nov. 30, 1982","children":[],"tail":", which was enacted into permanent law by "},{"tag":"ref","attrib":{"href":"/us/pl/97/377"},"text":"Pub. L. 97–377","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd25a086-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/2"},"text":"Pub. L. 110–2","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd25a087-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd25a088-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/2/s4"},"text":"Pub. L. 110–2, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-02-02"},"text":"Feb. 2, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/5"},"text":"121 Stat. 5","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/2/s4"},"text":"“The amendments made by this Act [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s4912"},"text":"section 4912 of this title","children":[],"tail":"] shall apply with respect to the portion of the One Hundred Tenth Congress which begins after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2007-02-02"},"text":"Feb. 2, 2007","children":[],"tail":"] and each succeeding Congress.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"iddd25a089-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Pub. L . 110–2, § 1, ","children":[{"tag":"date","attrib":{"date":"2007-02-02"},"text":"Feb. 2, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/4"},"text":"121 Stat. 4","children":[],"tail":", provided that: “This Act [see Tables for classification] may be cited as the ‘House Page Board Revision Act of 2007’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
