{"tag":"section","attrib":{"id":"iddccd6e3f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1108"},"text":null,"children":[{"tag":"num","attrib":{"value":"1108"},"text":"§ 1108.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddccd6e40-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1108/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to carry out the provisions of this chapter, the Center may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddccd6e41-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1108/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appoint and fix the compensation of such personnel as may be necessary to carry out the provisions of this chapter, except that in no case shall employees other than the Executive Director be compensated at a rate to exceed the maximum rate for employees in grade GS–15 of the General Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of title 5","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddccd6e42-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1108/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procure temporary and intermittent services of experts and consultants as are necessary to the extent authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109"},"text":"section 3109 of title 5","children":[],"tail":", but at rates not to exceed the rate specified at the time of such service for grade GS–18 under section 5332 of such title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddccd6e43-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1108/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribe such regulations as it considers necessary governing the manner in which its functions shall be carried out;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddccd6e44-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1108/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" solicit and receive money and other property donated, bequeathed, or devised, without condition or restriction other than it be used for the purposes of the Center, and to use, sell, or otherwise dispose of such property for the purpose of carrying out its functions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddccd6e45-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1108/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept and utilize the services of voluntary and noncompensated personnel and reimburse them for travel expenses, including per diem, as authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddccd6e46-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1108/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into contracts, grants, or other arrangements, or modifications thereof, to carry out the provisions of this chapter, and such contracts or modifications thereof may, with the concurrence of two-thirds of the members of the Board, be entered into without performance or other bonds, and without regard to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s6101"},"text":"section 6101 of title 41","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddccd6e47-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1108/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make expenditures for official reception and representation expenses as well as expenditures for meals, entertainment and refreshments in connection with official training sessions or other authorized programs or activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddccd6e48-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1108/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" apply for, receive and use for the purposes of the Center grants or other assistance from Federal sources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddccd6e49-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1108/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish, receive and use for the purposes of the Center fees or other charges for goods or services provided in fulfilling the Center’s purposes to persons not enumerated in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1104/b"},"text":"section 1104(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddccd6e4a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1108/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" invest, as specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1105/b"},"text":"section 1105(b) of this title","children":[],"tail":", moneys authorized to be received under this section; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddccd6e4b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1108/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make other necessary expenditures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddccfdf4c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1108/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddccfdf4d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/458/tI/s119"},"text":"Pub. L. 100–458, title I, § 119","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-01"},"text":"Oct. 1, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2176"},"text":"102 Stat. 2176","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/163/tIII/s320"},"text":"Pub. L. 101–163, title III, § 320","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-21"},"text":"Nov. 21, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1068"},"text":"103 Stat. 1068","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/520/tIII/s313/c"},"text":"Pub. L. 101–520, title III, § 313(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","