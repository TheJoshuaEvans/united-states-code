in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5376"},"text":"section 5376 of Title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
