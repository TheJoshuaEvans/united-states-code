{"tag":"section","attrib":{"id":"iddce2f2af-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1612"},"text":null,"children":[{"tag":"num","attrib":{"value":"1612"},"text":"§ 1612.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Senate that lobbying expenses should remain nondeductible","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddce2f2b0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1612/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Senate finds that ordinary Americans generally are not allowed to deduct the costs of communicating with their elected representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce2f2b1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1612/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Senate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the sense of the Senate that lobbying expenses should not be tax deductible.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddce2f2b2-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/65/s23"},"text":"Pub. L. 104–65, § 23","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-19"},"text":"Dec. 19, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/705"},"text":"109 Stat. 705","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddce2f2b3-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddce2f2b4-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddce2f2b5-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/65/s24"},"text":"section 24 of Pub. L. 104–65","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1601"},"text":"section 1601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
