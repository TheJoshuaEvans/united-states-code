{"tag":"section","attrib":{"id":"iddce2f2ce-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1701"},"text":null,"children":[{"tag":"num","attrib":{"value":"1701"},"text":"§ 1701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Recording Registry of the Library of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Librarian of Congress shall establish the National Recording Registry for the purpose of maintaining and preserving sound recordings that are culturally, historically, or aesthetically significant.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddce2f2cf-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/474/tI/s101"},"text":"Pub. L. 106–474, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2085"},"text":"114 Stat. 2085","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddce2f2d0-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddce2f2d1-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"iddce2f2d2-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/474/s1"},"text":"Pub. L. 106–474, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2085"},"text":"114 Stat. 2085","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/474/s1"},"text":"“This Act [enacting this chapter and chapter 1524 of Title 36, Patriotic and National Observances, Ceremonies, and Organizations] may be cited as the ‘National Recording Preservation Act of 2000’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
