{"tag":"section","attrib":{"id":"iddc85dd5e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s142a"},"text":null,"children":[{"tag":"num","attrib":{"value":"142a"},"text":"§ 142a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of administrative assistant and disbursing officer in Library of Congress abolished; transfer of duties to appointee of Librarian","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"From and after ","children":[{"tag":"date","attrib":{"date":"1928-06-10"},"text":"June 10, 1928","children":[],"tail":", the office of administrative assistant and disbursing officer of the Library of Congress, created by "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s142"},"text":"section 142 of this title","children":[],"tail":", is abolished and thereafter the duties required to be performed by the administrative assistant and disbursing officer shall be performed, under the direction of the Librarian of Congress, by such persons as the Librarian may appoint for those purposes."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc85dd5f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1928-05-11/ch521"},"text":"May 11, 1928, ch. 521","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/497"},"text":"45 Stat. 497","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/310/tII/s220/h"},"text":"Pub. L. 92–310, title II, § 220(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-06-06"},"text":"June 6, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/205"},"text":"86 Stat. 205","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc85dd60-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc85dd61-3a6e-11f1-a0f3-db3efcbbb4ee"},"