{"tag":"section","attrib":{"id":"iddd2a81d7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5308"},"text":null,"children":[{"tag":"num","attrib":{"value":"5308"},"text":"§ 5308.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Substitute to sign certificates for salary and accounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Speaker is authorized to designate from time to time some one from among those appointed by him and appropriated for and employed in his office, whose duty it shall be under the direction of the Speaker to sign in his name and for him all certificates required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s5307"},"text":"section 5307 of this title","children":[],"tail":" for salary and accounts for traveling expenses in going to and returning from Congress of Representatives and Delegates."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd2a81d8-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"date","attrib":{"date":"1903-11-12"},"text":"Nov. 12, 1903","children":[],"tail":", P. Res. No. 1, "},{"tag":"ref","attrib":{"href":"/us/stat/33/1"},"text":"33 Stat. 1","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd2a81d9-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd2a81da-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd2a81db-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s5307"},"text":"Section 5307 of this title","children":[],"tail":", referred to in text, was in the original “section forty-seven of the Revised Statutes”, which initially enacted part of "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s48"},"text":"section 48 of this title","children":[],"tail":" and was subsequently reclassified as "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s5307"},"text":"section 5307 of this title","children":[],"tail":". See Codification notes under sections 48 and 5307 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd2a81dc-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s50"},"text":"section 50 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
