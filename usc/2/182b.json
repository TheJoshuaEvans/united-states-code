{"tag":"section","attrib":{"id":"iddc8f7b4c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182b"},"text":null,"children":[{"tag":"num","attrib":{"value":"182b"},"text":"§ 182b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revolving fund for sales shop and other services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc8f7b4d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is hereby established in the Treasury a revolving fund for the following programs and activities of the Librarian:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc8f7b4e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Decimal classification development.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc8f7b4f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The operation of a gift shop or other sales of items associated with collections, exhibits, performances, and special events of the Library of Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc8f7b50-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Document reproduction and microfilming services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc8f7b51-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182b/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Special events and programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc8f7b52-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182b/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Training.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc8f7b53-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Individual accounting requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A separate account shall be maintained in the revolving fund under this section with respect to the programs and activities described in each of the paragraphs of subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc8f7b54-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees for services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Librarian may charge a fee for services under any of the programs and activities described in subsection (a), and shall deposit any such fees charged into the account of the revolving fund under this section for such program or activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc8f7b55-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of accounts in fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc8f7b56-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each account of the revolving fund under this section shall consist of the following amounts:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc8f7b57-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182b/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts deposited by the Librarian under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc8f7b58-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182b/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other amounts received by the Librarian which are attributable to the programs and activities covered by such account.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc8f7b59-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182b/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts deposited by the Librarian under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc8f7b5a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182b/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other amounts as may be appropriated under law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc8f7b5b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit of funds during transition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Librarian shall transfer to each account of the revolving fund under this section the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc8f7b5c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182b/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any obligated, unexpended balances existing as of the date of the transfer which are attributable to the programs and activities covered by such account.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc8f7b5d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182b/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An amount equal to the difference as of such date between—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddc8f7b5e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182b/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total value of the supplies, inventories, equipment, gift fund balances, and other assets attributable to such programs and activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc8f7b5f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182b/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total value of the liabilities attributable to such programs and activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc8f7b60-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of amounts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc8f7b61-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), amounts in the accounts of the revolving fund under this section shall be available to the Librarian, in amounts specified in appropriations Acts and without fiscal year limitation, to carry out the programs and activities covered by such accounts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc8f7b62-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for payments for certain Capitol Police services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any amount in the revolving fund consisting of a payment received for services of the United States Capitol Police in connection with a special event or program described in subsection (a)(4), the Librarian shall transfer such amount upon receipt to the Capitol Police for deposit into the applicable appropriations accounts of the Capitol Police.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc8f7b63-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/481/tI/s102"},"text":"Pub. L. 106–481, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2188"},"text":"114 Stat. 2188","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/68/tII/s208/a"},"text":"Pub. L. 107–68, title II, § 208(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-11-12"},"text":"Nov. 12, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/587"},"text":"115 Stat. 587","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/161/dH/tI/s1004/f/1"},"text":"Pub. L. 110–161, div. H, title I, § 1004(f)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2235"},"text":"121 Stat. 2235","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/178/s6/a"},"text":"Pub. L. 110–178, § 6(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-07"},"text":"Jan. 7, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2553"},"text":"121 Stat. 2553","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/145/s6/d/1"},"text":"Pub. L. 111–145, § 6(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-04"},"text":"Mar. 4, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/54"},"text":"124 Stat. 54","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dI/tI/s151/1"},"text":"Pub. L. 115–141, div. I, title I, § 151(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/784"},"text":"132 Stat. 784","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc8f7b64-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc8f7b65-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc8f7b66-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s151/1/A"},"text":"Pub. L. 115–141, § 151(1)(A)","children":[],"tail":", substituted “Revolving fund for sales shop and other services” for “Revolving fund for gift shop, decimal classification, photo duplication, and related services” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s151/1/B"},"text":"Pub. L. 115–141, § 151(1)(B)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/145"},"text":"Pub. L. 111–145","children":[],"tail":" repealed "},{"tag":"ref","attrib":{"href":"/us/pl/110/161/s1004/f/1"},"text":"Pub. L. 110–161, § 1004(f)(1)","children":[],"tail":". See 2007 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/178"},"text":"Pub. L. 110–178","children":[],"tail":" reenacted heading without change and amended text generally. Prior to amendment, text read as follows: “Amounts in the accounts of the revolving fund under this section shall be available to the Librarian, in amounts specified in appropriations Acts and without fiscal year limitation, to carry out the programs and activities covered by such accounts.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161/s1004/f/1"},"text":"Pub. L. 110–161, § 1004(f)(1)","children":[],"tail":", which made an amendment identical to that made by "},{"tag":"ref","attrib":{"href":"/us/pl/110/178"},"text":"Pub. L. 110–178","children":[],"tail":", was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/111/145"},"text":"Pub. L. 111–145","children":[],"tail":". See Effective Date of 2010 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/68"},"text":"Pub. L. 107–68","children":[],"tail":" added par. (4)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc8f7b67-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddc8f7b68-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161/s1004"},"text":"section 1004 of Pub. L. 110–161","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/111/145"},"text":"Pub. L. 111–145","children":[],"tail":" effective as if included in the enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/161"},"text":"Pub. L. 110–161","children":[],"tail":" and provisions amended by "},{"tag":"ref","attrib":{"href":"/us/pl/110/161/s1004"},"text":"section 1004 of Pub. L. 110–161","children":[],"tail":" to be restored as if such section had not been enacted, and repeal to have no effect on the enactment or implementation of any provision of "},{"tag":"ref","attrib":{"href":"/us/pl/110/178"},"text":"Pub. L. 110–178","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/145/s6/d"},"text":"section 6(d) of Pub. L. 111–145","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1901"},"text":"section 1901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddc8f7b69-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/178/s6/c"},"text":"Pub. L. 110–178, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-07"},"text":"Jan. 7, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2554"},"text":"121 Stat. 2554","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/178/s6/c"},"text":"“The amendments made by this section [amending this section] shall apply with respect to services provided by the United States Capitol Police on or after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2008-01-07"},"text":"Jan. 7, 2008","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddc8f7b6a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161/dH/tI/s1004/f/3"},"text":"Pub. L. 110–161, div. H, title I, § 1004(f)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2236"},"text":"121 Stat. 2236","children":[],"tail":", which provided that the amendments made by section 1004(f) (amending this section) would apply with respect to services provided by the United States Capitol Police on or after "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":", was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/111/145/s6/d/1"},"text":"Pub. L. 111–145, § 6(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-04"},"text":"Mar. 4, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/54"},"text":"124 Stat. 54","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddc8f7b6b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2001 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/68/tII/s208/b"},"text":"Pub. L. 107–68, title II, § 208(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-11-12"},"text":"Nov. 12, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/587"},"text":"115 Stat. 587","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/68/tII/s208/b"},"text":"“The amendment made by subsection (a) [amending this section] shall take effect upon the date on which the Committees on Appropriations of the House of Representatives and Senate approve a report submitted to the Committees by the Librarian of Congress which describes the guidelines and policies applicable to the hosting of special events and programs by the Librarian which are covered under section 102(a)(4) of the Library of Congress Fiscal Operations Improvement Act of 2000 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s182b/a/4"},"text":"2 U.S.C. 182b(a)(4)","children":[],"tail":"] (as added by subsection (a)).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddc8f7b6c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable with respect to fiscal year 2002 and each succeeding fiscal year, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/481/s105"},"text":"section 105 of Pub. L. 106–481","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s182a"},"text":"section 182a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
