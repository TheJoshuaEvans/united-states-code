{"tag":"section","attrib":{"id":"iddd33f8b5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6158"},"text":null,"children":[{"tag":"num","attrib":{"value":"6158"},"text":"§ 6158.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Utilization of funds for specialized training of professional staff for Majority and Minority Conference Committee of Senate","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Funds appropriated to the Conference of the Majority and funds appropriated to the Conference of the Minority for any fiscal year (commencing with the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1991-09-30"},"text":"September 30, 1991","children":[],"tail":"), may be utilized in such amounts as the Chairman of each Conference deems appropriate for the specialized training of professional staff, subject to such limitations, insofar as they are applicable, as are imposed by the Committee on Rules and Administration with respect to such training when provided to professional staff of standing committees of the Senate."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd33f8b6-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/520/tI/s2"},"text":"Pub. L. 101–520, title I, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2257"},"text":"104 Stat. 2257","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd33f8b7-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd33f8b8-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd33f8b9-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s61g–8"},"text":"section 61g–8 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Congressional Operations Appropriations Act, 1991, which is title I of the Legislative Branch Appropriations Act, 1991.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"iddd33f8ba-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions relating to utilization of funds for specific fiscal year for specialized training of professional staff for Majority and Minority Conference Committee of Senate were contained in the following prior appropriation acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/163/tI/s2"},"text":"Pub. L. 101–163, title I, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-21"},"text":"Nov. 21, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1044"},"text":"103 Stat. 1044","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/458/tI/s2"},"text":"Pub. L. 100–458, title I, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-01"},"text":"Oct. 1, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2161"},"text":"102 Stat. 2161","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","att