{"tag":"section","attrib":{"id":"iddce2f241-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1605"},"text":null,"children":[{"tag":"num","attrib":{"value":"1605"},"text":"§ 1605.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure and enforcement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddce2f242-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1605/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Senate and the Clerk of the House of Representatives shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce2f243-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1605/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide guidance and assistance on the registration and reporting requirements of this chapter and develop common standards, rules, and procedures for compliance with this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce2f244-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1605/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review, and, where necessary, verify and inquire to ensure the accuracy, completeness, and timeliness of registration and reports;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce2f245-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1605/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop filing, coding, and cross-indexing systems to carry out the purpose of this chapter, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddce2f246-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1605/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a publicly available list of all registered lobbyists, lobbying firms, and their clients; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce2f247-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1605/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" computerized systems designed to minimize the burden of filing and maximize public access to materials filed under this chapter;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce2f248-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1605/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make available for public inspection and copying at reasonable times the registrations and reports filed under this chapter and, in the case of a report filed in electronic form under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1604/e"},"text":"section 1604(e) of this title","children":[],"tail":", make such report available for public inspection over the Internet as soon as technically practicable after the report is so filed;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce2f249-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1605/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" retain registrations for a period of at least 6 years after they are terminated and reports for a period of at least 6 years after they are filed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce2f24a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1605/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compile and summarize, with respect to each quarterly period, the information contained in registrations and reports filed with respect to such period in a clear and complete manner;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce2f24b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1605/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify any lobbyist or lobbying firm in writing that may be in noncompliance with this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce2f24c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1605/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the United States Attorney for the District of Columbia that a lobbyist or lobbying firm may be in noncompliance with this chapter, if the registrant has been notified in writing and has failed to provide an appropriate response within 60 days after notice was given under paragraph (7);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce2f24d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1605/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" maintain all registrations and reports filed under this chapter, and make them available to the public over the Internet, without a fee or other access charge, in a searchable, sortable, and downloadable manner, to the extent technically practicable, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddce2f24e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1605/a/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes the information contained in the registrations and reports;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce2f24f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1605/a/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is searchable and sortable to the maximum extent practicable, including searchable and sortable by each of the categories of information described in section 1603(b) or 1604(b) of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce2f250-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1605/a/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides electronic links or other appropriate mechanisms to allow users to obtain relevant information in the database of the Federal Election Commission;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce2f251-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1605/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" retain the information contained in a registration or report filed under this chapter for a period of 6 years after the registration or report (as the case may be) is filed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce2f252-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1605/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make publicly available, on a semiannual basis, the aggregate number of registrants referred to the United States Attorney for the District of Columbia for noncompliance as required by paragraph (8).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce2f253-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1605/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce2f254-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1605/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall report to the congressional committees referred to in paragraph (2), after the end of each semiannual period beginning on January 1 and July 1, the aggregate number of enforcement actions taken by the Department of Justice under this chapter during that semiannual period and, by case, any sentences imposed, except that such report shall not include the names of individuals, or personally identifiable information, that is not already a matter of public record.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce2f255-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1605/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Committees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The congressional committees referred to in paragraph (1) are the Committee on Homeland Security and Governmental Affairs and the Committee on the Judiciary of the Senate and the Committee on the Judiciary of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddce2f256-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/65/s6"},"text":"Pub. L. 104–65, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-19"},"text":"Dec. 19, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/698"},"text":"109 Stat. 698","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/81/tII"},"text":"Pub. L. 110–81, title II","children":[],"tail":", §§ 201(b)(3), 209(a), (b), 210, "},{"tag":"date","attrib":{"date":"2007-09-14"},"text":"Sept. 14, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/742"},"text":"121 Stat. 742","children":[],"tail":", 748.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddce2f257-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddce2f258-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddce2f259-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act” meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/65"},"text":"Pub. L. 104–65","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-19"},"text":"Dec. 19, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/691"},"text":"109 Stat. 691","children":[],"tail":", known as the Lobbying Disclosure Act of 1995. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1601"},"text":"section 1601 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddce2f25a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/81/s210"},"text":"Pub. L. 110–81, § 210","children":[],"tail":", designated existing provisions as subsec. (a), inserted heading, and added par. (11) and subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/81/s209/b"},"text":"Pub. L. 110–81, § 209(b)","children":[],"tail":", inserted before semicolon at end “and, in the case of a report filed in electronic form under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1604/e"},"text":"section 1604(e) of this title","children":[],"tail":", make such report available for public inspection over the Internet as soon as technically practicable after the report is so filed”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/81/s201/b/3"},"text":"Pub. L. 110–81, § 201(b)(3)","children":[],"tail":", substituted “quarterly period” for “semiannual period”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (9), (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/81/s209/a"},"text":"Pub. L. 110–81, § 209(a)","children":[],"tail":", added pars. (9) and (10)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddce2f25b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddce2f25c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Except as otherwise provided, amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/81"},"text":"Pub. L. 110–81","children":[],"tail":" applicable with respect to registrations under the Lobbying Disclosure Act of 1995 (this chapter) having an effective date of "},{"tag":"date","attrib":{"date":"2008-01-01"},"text":"Jan. 1, 2008","children":[],"tail":", or later and with respect to quarterly reports under that Act covering calendar quarters beginning on or after "},{"tag":"date","attrib":{"date":"2008-01-01"},"text":"Jan. 1, 2008","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/81/s215"},"text":"section 215 of Pub. L. 110–81","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s30104"},"text":"section 30104 of Title 52","children":[],"tail":", Voting and Elections."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddce2f25d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/65/s24"},"text":"section 24 of Pub. L. 104–65","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1601"},"text":"section 1601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
