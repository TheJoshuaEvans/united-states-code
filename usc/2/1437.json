{"tag":"section","attrib":{"id":"iddcde377c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1437"},"text":null,"children":[{"tag":"num","attrib":{"value":"1437"},"text":"§ 1437.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Senate regarding adoption of simplified and streamlined acquisition procedures for Senate acquisitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It is the sense of the Senate that the Committee on Rules and Administration of the Senate should review the rules applicable to purchases by Senate offices to determine whether they are consistent with the acquisition simplification and streamlining laws enacted in the Federal Acquisition Streamlining Act of 1994 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/355"},"text":"Public Law 103–355","children":[],"tail":")."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddcde377d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/1/tV/s508"},"text":"Pub. L. 104–1, title V, § 508","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-01-23"},"text":"Jan. 23, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/44"},"text":"109 Stat. 44","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcde377e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcde377f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddcde3780-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attri