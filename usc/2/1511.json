{"tag":"section","attrib":{"id":"iddcde37d0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1511"},"text":null,"children":[{"tag":"num","attrib":{"value":"1511"},"text":"§ 1511.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost of regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcde37d1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1511/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the sense of the Congress that Federal agencies should review and evaluate planned regulations to ensure that the cost estimates provided by the Congressional Budget Office will be carefully considered as regulations are promulgated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcde37d2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1511/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement of cost","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"At the request of a committee chairman or ranking minority member, the Director shall, to the extent practicable, prepare a comparison between—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcde37d3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1511/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate by the relevant agency, prepared under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1532"},"text":"section 1532 of this title","children":[],"tail":", of the costs of regulations implementing an Act containing a Federal mandate; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcde37d4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1511/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost estimate prepared by the Congressional Budget Office for such Act when it was enacted by the Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcde37d5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1511/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation of Office of Management and Budget","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the request of the Director of the Congressional Budget Office, the Director of the Office of Management and Budget shall provide data and cost estimates for regulations implementing an Act containing a Federal mandate covered by part B of title IV of the Congressional Budget and Impoundment Control Act of 1974 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s658"},"text":"2 U.S.C. 658","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcde37d6-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/4/tI/s103"},"text":"Pub. L. 104–4, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-03-22"},"text":"Mar. 22, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/62"},"text":"109 Stat. 62","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcde37d7-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcde37d8-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddcde37d9-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Congressional Budget and Impoundment Control Act of 1974, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/344"},"text":"Pub. L. 93–344","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-07-12"},"text":"July 12, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/297"},"text":"88 Stat. 297","children":[],"tail":". Part B of title IV of the Act is classified generally to part B (§ 658 et seq.) of subchapter II of chapter 17A of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s621"},"text":"section 621 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcde37da-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddcde37db-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/4/tI/s110"},"text":"Pub. L. 104–4, title I, § 110","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-03-22"},"text":"Mar. 22, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/64"},"text":"109 Stat. 64","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/4/tI/s110"},"text":"“This title [enacting this subchapter and sections 658 to 658g of this title and amending sections 602, 632, and 653 of this title] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"January 1, 1996","children":[],"tail":" or on the date 90 days after appropriations are made available as authorized under section 109 ["},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1516"},"text":"2 U.S.C. 1516","children":[],"tail":"], whichever is earlier and shall apply to legislation considered on and after such date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
