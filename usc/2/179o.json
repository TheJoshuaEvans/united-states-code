{"tag":"section","attrib":{"id":"iddc8f7acb-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s179o"},"text":null,"children":[{"tag":"num","attrib":{"value":"179o"},"text":"§ 179o.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities and powers of Board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc8f7acc-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s179o/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall review nominations of films submitted to it for inclusion in the National Film Registry and consult with the Librarian, as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s179m"},"text":"section 179m of this title","children":[],"tail":", with respect to the inclusion of such films in the Registry and the preservation of these and other films that are culturally, historically, or aesthetically significant."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc8f7acd-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s179o/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nomination of films","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall consider, for inclusion in the National Film Registry, nominations submitted by the general public as well as representatives of the film industry, such as the guilds and societies representing actors, directors, screenwriters, cinematographers, and other creative artists, producers, and film critics, archives and other film preservation organizations, and representatives of academic institutions with film study programs. The Board shall nominate not more than 25 films each year for inclusion in the Registry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc8f7ace-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s179o/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc8f7acf-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s179o/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board may, for the purpose of carrying out its duties, hold such hearings, sit and act at such times and places, take such testimony, and receive such evidence, as the Librarian and the Board consider appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc8f7ad0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s179o/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service on Foundation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Two sitting members of the Board shall be appointed by the Librarian, and shall serve, as Board members of the National Film Preservation Foundation, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t36/s151703"},"text":"section 151703 of title 36","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc8f7ad1-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/285/tI/s105"},"text":"Pub. L. 104–285, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3380"},"text":"110 Stat. 3380","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc8f7ad2-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc8f7ad3-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddc8f7ad4-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t36/s151703"},"text":"Section 151703 of title 36","children":[],"tail":"” substituted in subsec. (c)(2) for “section 203”, meaning section 203 of the National Film Preservation Act of 1996, on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/105/225/s5/b"},"text":"Pub. L. 105–225, § 5(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1499"},"text":"112 Stat. 1499","children":[],"tail":", the first section of which enacted Title 36, Patriotic and National Observances, Ceremonies, and Organizations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
