{"tag":"section","attrib":{"id":"iddcf87547-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1978"},"text":null,"children":[{"tag":"num","attrib":{"value":"1978"},"text":"§ 1978.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deployment outside of jurisdiction","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcf87548-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1978/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for prior notice and approval","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Chief of the Capitol Police may not deploy any officer outside of the areas established by law for the jurisdiction of the Capitol Police unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcf87549-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1978/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chief provides prior notification to the Committee on House Administration of the House of Representatives, the Committee on Rules and Administration of the Senate, and the Committees on Appropriations of the House of Representatives and Senate of the costs anticipated to be incurred with respect to the deployment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf8754a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1978/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Capitol Police Board gives prior approval to the deployment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcf8754b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1978/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for certain services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) does not apply with respect to the deployment of any officer for any of the following purposes:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcf8754c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1978/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Responding to an imminent threat or emergency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf8754d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1978/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Intelligence gathering.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf8754e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1978/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Providing protective services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcf8754f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1978/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply with respect to fiscal year 2005 and each succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcf87550-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447/dG/tI/s1007"},"text":"Pub. L. 108–447, div. G, title I, § 1007","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3182"},"text":"118 Stat. 3182","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/145/s2/c"},"text":"Pub. L. 111–145, § 2(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-04"},"text":"Mar. 4, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/51"},"text":"124 Stat. 51","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcf87551-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcf87552-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddcf87553-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Legislative Branch Appropriations Act, 2005, which is div. G of the Consolidated Appropriations Act, 2005.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcf87554-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/145"},"text":"Pub. L. 111–145","children":[],"tail":" substituted “prior notification to the Committee on House Administration of the House of Representatives, the Committee on Rules and Administration of the Senate, and” for “prior notification to”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
