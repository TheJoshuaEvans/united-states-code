{"tag":"section","attrib":{"id":"iddd281163-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5142"},"text":null,"children":[{"tag":"num","attrib":{"value":"5142"},"text":"§ 5142.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional amounts for personnel and equipment for House Majority and Minority Leaders and Majority and Minority Whips","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Effective ","children":[{"tag":"date","attrib":{"date":"1977-03-01"},"text":"March 1, 1977","children":[],"tail":", and until otherwise provided by law, there shall be paid out of the applicable accounts of the House of Representatives such additional amounts as may be necessary for office personnel, and rental or lease of necessary equipment, of each of the following officials of the House the following per annum amounts:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd281164-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5142/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The majority leader, $30,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd281165-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5142/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The minority leader, $30,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd281166-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5142/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The majority whip, $15,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd281167-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5142/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The minority whip, $15,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd281168-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/94/tI/s115"},"text":"Pub. L. 95–94, title I, § 115","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-05"},"text":"Aug. 5, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/668"},"text":"91 Stat. 668","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/186/tII/s204/15/B"},"text":"Pub. L. 104–186, title II, § 204(15)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1732"},"text":"110 Stat. 1732","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd281169-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd28116a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd28116b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s74a–4"},"text":"section 74a–4 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is based on section 2 of House Resolution No. 393, Ninety-fifth Congress, ","children":[{"tag":"date","attrib":{"date":"1977-03-31"},"text":"Mar. 31, 1977","children":[],"tail":", which was enacted into permanent law by "},{"tag":"ref","attrib":{"href":"/us/pl/95/94"},"text":"Pub. L. 95–94","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd28116c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186"},"text":"Pub. L. 104–186","children":[],"tail":" substituted “applicable accounts of the House of Representatives” for “contingent fund of the House”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd28116d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd28116e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Limits on Uses of Funds","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/51/tI/s112"},"text":"Pub. L. 98–51, title I, § 112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-07-14"},"text":"July 14, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/270"},"text":"97 Stat. 270","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/104/186/tII/s204/16"},"text":"Pub. L. 104–186, title II, § 204(16)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1732"},"text":"110 Stat. 1732","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/186/tII/s204/16"},"text":"“The funds provided under the provisions of section 2 of House Resolution 393, Ninety-fifth Congress, agreed to ","children":[{"tag":"date","attrib":{"date":"1977-03-31"},"text":"March 31, 1977","children":[],"tail":", as enacted into permanent law by section 115 of the Congressional Operations Appropriation Act, 1978 ["},{"tag":"ref","attrib":{"href":"/us/usc/t2/s5142"},"text":"2 U.S.C. 5142","children":[],"tail":"], and section 473 of the Legislative Reorganization Act of 1970 ["},{"tag":"ref","attrib":{"href":"/us/usc/t2/s5103"},"text":"2 U.S.C. 5103","children":[],"tail":"], shall be limited to use for the compensation of additional personnel and other necessary official expenses.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
