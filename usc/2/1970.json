{"tag":"section","attrib":{"id":"iddcf604c6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1970"},"text":null,"children":[{"tag":"num","attrib":{"value":"1970"},"text":"§ 1970.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance by Executive departments and agencies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcf604c7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1970/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcf604c8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1970/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Executive departments and Executive agencies may assist the United States Capitol Police in the performance of its duties by providing services (including personnel), equipment, and facilities on a temporary and reimbursable basis when requested by the Capitol Police Board or in accordance with paragraph (4) and on a permanent and reimbursable basis upon advance written request of the Capitol Police Board; except that the Department of Defense and the Coast Guard may provide such assistance on a temporary basis without reimbursement when assisting the United States Capitol Police in its duties directly related to protection under sections 1922, 1961, 1966, 1967, and 1969 of this title and sections 5101 to 5107 and 5109 of title 40.","children":[{"tag":"ref","attrib":{"idref":"fn002074"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002074"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" Before making a request under this paragraph, the Capitol Police Board shall consult with appropriate Members of the Senate and House of Representatives in leadership positions, except in an emergency."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf604c9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1970/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procurement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No services (including personnel), equipment, or facilities may be ordered, purchased, leased, or otherwise procured for the purposes of carrying out the duties of the United States Capitol Police by persons other than officers or employees of the Federal Government duly authorized by the Chairman of the Capitol Police Board to make such orders, purchases, leases, or procurements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf604ca-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1970/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditures or obligation of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No funds may be expended or obligated for the purpose of carrying out this section other than funds specifically appropriated to the Capitol Police Board or the United States Capitol Police for those purposes with the exception of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcf604cb-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1970/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expenditures made by the Department of Defense or the Coast Guard from funds appropriated to the Department of Defense or the Coast Guard in providing assistance on a temporary basis to the United States Capitol Police in the performance of its duties directly related to protection under sections 1922, 1961, 1966, 1967, and 1969 of this title and sections 5101 to 5107 and 5109 of title 40; ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcf604cc-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1970/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expenditures made by Executive departments and agencies, in providing assistance at the request of the United States Capitol Police in the performance of its duties, and which will be reimbursed by the United States Capitol Police under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf604cd-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1970/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Assistance under this section shall be provided—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcf604ce-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1970/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consistent with the authority of the Capitol Police under sections 1961 and 1966 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcf604cf-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1970/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" upon the written request of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddcf604d0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1970/a/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Capitol Police Board; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcf604d1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1970/a/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in an emergency—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddcf604d2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1970/a/4/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Sergeant at Arms and Doorkeeper of the Senate in any matter relating to the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddcf604d3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1970/a/4/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Sergeant at Arms of the House of Representatives in any matter relating to the House of Representatives; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddcf604d4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1970/a/4/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chief of the Capitol Police, if the Chief of the Capitol Police has determined that the provision of assistance is necessary to prevent the significant disruption of governmental function and public order within the United States Capitol Buildings and Grounds, as described in section 1961 ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcf604d5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1970/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddcf604d6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1970/a/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on a temporary and reimbursable basis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcf604d7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1970/a/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on a permanent reimbursable basis upon advance written request of the Capitol Police Board; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcf604d8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1970/a/4/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on a temporary basis without reimbursement by the Department of Defense and the Coast Guard as described under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf604d9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1970/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revocation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Capitol Police Board may revoke a request for assistance provided under paragraph (4)(B)(ii)(III) upon consultation with appropriate Members of the Senate and House of Representatives in leadership positions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcf604da-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1970/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcf604db-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1970/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to any fiscal year in which an executive department or executive agency provides assistance under this section, the head of that department or agency shall submit a report not later than 90 days after the end of the fiscal year to the Chairman of the Capitol Police Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf604dc-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1970/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The report submitted under paragraph (1) shall contain a detailed account of all expenditures made by the Executive department or executive agency in providing assistance under this section during the applicable fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf604dd-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1970/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Summary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After receipt of all reports under paragraph (2) with respect to any fiscal year, the Chairman of the Capitol Police Board shall submit a summary of such reports to the Committees on Appropriations of the Senate and the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcf604de-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1970/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall take effect on ","children":[{"tag":"date","attrib":{"date":"2002-01-10"},"text":"January 10, 2002","children":[],"tail":", and apply to each fiscal year occurring after such date."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcf604df-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/117/dB/s911"},"text":"Pub. L. 107–117, div. B, § 911","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-10"},"text":"Jan. 10, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2322"},"text":"115 Stat. 2322","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/77/s2/a"},"text":"Pub. L. 117–77, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-22"},"text":"Dec. 22, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1522"},"text":"135 Stat. 1522","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcf604e0-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcf604e1-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddcf604e2-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 1922, 1961, 1966, 1967, and 1969 of this title and sections 5101 to 5107 and 5109 of title 40, referred to in subsec. (a)(1), (3)(A), (4)(B)(ii)(III), was in the original a reference to the Act of ","children":[{"tag":"date","attrib":{"date":"1946-07-31"},"text":"July 31, 1946","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t40/s212a–2"},"text":"40 U.S.C. 212a–2","children":[],"tail":"), which is "},{"tag":"ref","attrib":{"href":"/us/act/1946-07-31/ch707"},"text":"act July 31, 1946, ch. 707","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/718"},"text":"60 Stat. 718","children":[],"tail":". Sections 9, 9A, 9B, 9C, and 14 of the Act are classified, respectively, to sections 1961, 1966, 1967, 1922, and 1969 of this title, and section 16(b) of the Act is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1961"},"text":"section 1961 of this title","children":[],"tail":". Sections 1 to 8, 10 to 13, and 16(a) of the Act, which were classified to sections 193a to 193m of former Title 40, Public Buildings, Property, and Works, were repealed and reenacted as sections 5101 to 5107 and 5109 of Title 40, Public Buildings, Property, and Works, by "},{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", §§ 1, 6(b), "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1062"},"text":"116 Stat. 1062","children":[],"tail":", 1312, the first section of which enacted Title 40. "},{"tag":"ref","attrib":{"href":"/us/pl/107/217/s5/c"},"text":"Section 5(c) of Pub. L. 107–217","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s101"},"text":"section 101 of Title 40","children":[],"tail":", provides that a reference to a law replaced by "},{"tag":"ref","attrib":{"href":"/us/pl/107/217/s1"},"text":"section 1 of Pub. L. 107–217","children":[],"tail":" is deemed to refer to the corresponding provision enacted by "},{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":". For complete classification of the act of "},{"tag":"date","attrib":{"date":"1946-07-31"},"text":"July 31, 1946","children":[],"tail":", to the Code, see Tables. For disposition of sections of former Title 40, see table at the beginning of Title 40."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddcf604e3-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was classified to section 212c of former Title 40, prior to the enactment of Title 40, Public Buildings, Property, and Works, by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217/s1"},"text":"Pub. L. 107–217, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1062"},"text":"116 Stat. 1062","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcf604e4-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/77/s2/a/1"},"text":"Pub. L. 117–77, § 2(a)(1)","children":[],"tail":", inserted “or in accordance with paragraph (4)” before “and on a permanent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/77/s2/a/2/A"},"text":"Pub. L. 117–77, § 2(a)(2)(A)","children":[],"tail":", struck out “advance” before “written request” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4)(B)(ii)(III). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/77/s2/a/2/B"},"text":"Pub. L. 117–77, § 2(a)(2)(B)","children":[],"tail":", added subcl. (III)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/77/s2/a/3"},"text":"Pub. L. 117–77, § 2(a)(3)","children":[],"tail":", added par. (5)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcf604e5-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcf604e6-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/77/s4"},"text":"Pub. L. 117–77, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-22"},"text":"Dec. 22, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1524"},"text":"135 Stat. 1524","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/77/s4"},"text":"“The amendments made by this Act [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1974"},"text":"section 1974 of this title","children":[],"tail":"] shall take effect on "},{"tag":"date","attrib":{"date":"2021-10-01"},"text":"October 1, 2021","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
