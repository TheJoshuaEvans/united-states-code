{"tag":"section","attrib":{"id":"iddc72cab8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s28d"},"text":null,"children":[{"tag":"num","attrib":{"value":"28d"},"text":"§ 28d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of Precedents by Director of the Government Publishing Office for official use; particular distribution; marking and ownership of sets","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc72cab9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s28d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Director of the Government Publishing Office shall make the following distribution of sets of the Precedents;","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc72caba-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s28d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to each standing or joint committee of the Congress which is in existence on ","children":[{"tag":"date","attrib":{"date":"1976-10-18"},"text":"October 18, 1976","children":[],"tail":", or which is established after "},{"tag":"date","attrib":{"date":"1976-10-18"},"text":"October 18, 1976","children":[],"tail":", four sets;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc72cabb-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s28d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the office of the Legislative Counsel of the House of Representatives, five sets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc72cabc-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s28d/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the office of the Legislative Counsel of the Senate, five sets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc72cabd-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s28d/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the library of the House of Representatives, four sets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc72cabe-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s28d/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the library of the Senate, two sets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc72cabf-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s28d/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the library of the Supreme Court of the United States, nine sets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc72cac0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s28d/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the office of the Official Reporter of Debates of the House of Representatives, three sets; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc72cac1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s28d/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the office of the Official Reporter of Debates of the Senate, three sets.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc72cac2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s28d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each set of Precedents distributed by the Director of the Government Publishing Office under subsection (a) of this section shall be for official use. Each such set shall be legibly stamped on the front cover “Property of the United States Government.” Each such set, upon delivery, shall become and remain the property of the United States, and may not be removed from the building in which is located the designated library or office, as the case may be.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc72cac3-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/551/s3"},"text":"Pub. L. 94–551, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-18"},"text":"Oct. 18, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2538"},"text":"90 Stat. 2538","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/d"},"text":"Pub. L. 113–235, div. H, title I, § 1301(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc72cac4-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc72cac5-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"iddc72cac6-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Director of the Government Publishing Office” substituted for “Public Printer” in text on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/s1301/d"},"text":"section 1301(d) of Pub. L. 113–235","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s301"},"text":"section 301 of Title 44","children":[],"tail":", Public Printing and Documents. Substitution was also made in section catchline that had been supplied editorially."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
