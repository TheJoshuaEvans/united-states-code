{"tag":"section","attrib":{"id":"iddd3fdf07-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6623"},"text":null,"children":[{"tag":"num","attrib":{"value":"6623"},"text":"§ 6623.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on telecommunications to Committee on Rules and Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Sergeant at Arms shall report to the Committee on Rules and Administration of the Senate, at such time or times, and in such form and manner, as the Committee may direct, on expenditures made, and revenues received, pursuant to sections 6621 to 6623 of this title. It shall be the function of the Sergeant at Arms to advise the Committee, as soon as possible, of any dispute regarding payments to and from such Appropriation Account as related to the line item for Telecommunications, including any amounts due and unpaid by any user, if any such dispute has remained unresolved for a period of at least 60 days.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd3fdf08-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/123/s3"},"text":"Pub. L. 100–123, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-10-05"},"text":"Oct. 5, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/795"},"text":"101 Stat. 795","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd3fdf09-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd3fdf0a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd3fdf0b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s58a–3"},"text":"section 58a–3 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd3fdf0c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd3fdf0d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1987-10-01"},"text":"Oct. 1, 1987","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/123/s4"},"text":"section 4 of Pub. L. 100–123","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s6621"},"text":"section 6621 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
