{"tag":"section","attrib":{"id":"iddc96a630-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s276"},"text":null,"children":[{"tag":"num","attrib":{"value":"276"},"text":"§ 276.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disbursement of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All appropriations for the Office of the Legislative Counsel shall be disbursed by the Secretary of the Senate.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc96a631-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1919-02-24/ch18"},"text":"Feb. 24, 1919, ch. 18","children":[],"tail":", title XIII, § 1303(c), (d), "},{"tag":"ref","attrib":{"href":"/us/stat/40/1142"},"text":"40 Stat. 1142","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1924-06-02/ch234"},"text":"June 2, 1924, ch. 234","children":[],"tail":", title XI, § 1101, "},{"tag":"ref","attrib":{"href":"/us/stat/43/353"},"text":"43 Stat. 353","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc96a632-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc96a633-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddc96a634-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"As originally enacted, section provided for disbursement of one-half of appropriations for office of legislative counsel by Secretary of Senate and one-half by Clerk of House of Representatives. In view of nonapplicability of section to Speaker, employee, etc., of the House of Representatives pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/510/s531"},"text":"section 531 of Pub. L. 91–510","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s281"},"text":"section 281 of this title","children":[],"tail":", section has been revised to limit application to Office of the Legislative Counsel of the Senate. See "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s282c"},"text":"section 282c of this title","children":[],"tail":" for provisions relating to expenditures by Legislative Counsel of the House of Representatives."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
