n":[],"tail":", 5323, 5324, 5326; "},{"tag":"ref","attrib":{"href":"/us/pl/116/94/dJ/tVIII/s805/b"},"text":"Pub. L. 116–94, div. J, title VIII, § 805(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3077"},"text":"133 Stat. 3077","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcd22931-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcd22932-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddcd22933-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/1"},"text":"Pub. L. 104–1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-01-23"},"text":"Jan. 23, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/3"},"text":"109 Stat. 3","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note below and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The U.S.–China Relations Act of 2000, referred to in subsec. (b)(3)(B), is div. B of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/286"},"text":"Pub. L. 106–286","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-10"},"text":"Oct. 10, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/891"},"text":"114 Stat. 891","children":[],"tail":". Title III of the Act is classified to subchapter II (§ 6911 et seq.) of chapter 77 of Title 22, Foreign Relations and Intercourse. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6901"},"text":"section 6901 of Title 22","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcd22934-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s805/b/1"},"text":"Pub. L. 116–94, § 805(b)(1)","children":[],"tail":", inserted “the United States Commission on International Religious Freedom,” after “With respect to” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s805/b/2"},"text":"Pub. L. 116–94, § 805(b)(2)","children":[],"tail":", inserted subpar. (A) designation before “Subject to paragraph (3),”, redesignated former subpars. (A) and (B) as cls. (i) and (ii), respectively, of subpar. (A), and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s805/b/3"},"text":"Pub. L. 116–94, § 805(b)(3)","children":[],"tail":", added subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/397/s305/a"},"text":"Pub. L. 115–397, § 305(a)","children":[],"tail":", designated existing provisions as subsec. (a), inserted heading, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/397/s308/b/1"},"text":"Pub. L. 115–397, § 308(b)(1)","children":[],"tail":"–(7), substituted “Office of Congressional Workplace Rights” for “Office of Compliance” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3)(J). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s153/a/1/A/i"},"text":"Pub. L. 115–141, § 153(a)(1)(A)(i)","children":[],"tail":", added subpar. (J). Par. (3)(J) subsequently redesignated subsec. (a)(3)(J)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(K). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/397/s305/b/1"},"text":"Pub. L. 115–397, § 305(b)(1)","children":[],"tail":", added subpar. (K)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/397/s305/c"},"text":"Pub. L. 115–397, § 305(c)","children":[],"tail":", substituted “subparagraphs (C) through (K)” for “subparagraphs (C) through (I)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/397/s302/b"},"text":"Pub. L. 115–397, § 302(b)","children":[],"tail":", substituted “disbursed by the Chief Administrative Officer of the House of Representatives” for “disbursed by the Clerk of the House of Representatives”. Amendment, which was directed to par. (7), was executed to subsec. (a)(7) to reflect the intervening redesignation made by "},{"tag":"ref","attrib":{"href":"/us/pl/115/397/s305/a"},"text":"section 305(a) of Pub. L. 115–397","children":[],"tail":". See above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/397/s305/c"},"text":"Pub. L. 115–397, § 305(c)","children":[],"tail":", substituted “subparagraphs (C) through (K)” for “subparagraphs (C) through (I)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(9)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/397/s305/b/2"},"text":"Pub. L. 115–397, § 305(b)(2)","children":[],"tail":", substituted “the Office of Technology Assessment, and the John C. Stennis Center for Public Service Training and Development” for “and the Office of Technology Assessment”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (9)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s153/a/1/A/ii"},"text":"Pub. L. 115–141, § 153(a)(1)(A)(ii)","children":[],"tail":", added subpar. (E). Par. (9)(E) subsequently redesignated subsec. (a)(9)(E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Par. (9)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/145"},"text":"Pub. L. 111–145","children":[],"tail":" substituted “the United States Capitol Police,” for “the Capitol Police Board,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Par. (3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/437/s422/b/1"},"text":"Pub. L. 110–437, § 422(b)(1)","children":[],"tail":", substituted “the Office of Congressional Accessibility Services;” for “the Capitol Guide Service;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/279"},"text":"Pub. L. 110–279","children":[],"tail":", which directed substitution of “or the Botanic Garden” for “, the Botanic Garden, or the Senate Restaurant”, was executed by making the substitution for “, the Botanic Garden, or the Senate Restaurants” to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (9)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/437/s422/b/2"},"text":"Pub. L. 110–437, § 422(b)(2)","children":[],"tail":", substituted “the Office of Congressional Accessibility Services,” for “the Capitol Guide Board,”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcd22935-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcd22936-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/397/tIII/s305/d"},"text":"Pub. L. 115–397, title III, § 305(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5324"},"text":"132 Stat. 5324","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/397/tIII/s305/d"},"text":"“The amendments made by this section [amending this section] shall take effect as if included in the enactment of the Congressional Accountability Act of 1995 [","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/1"},"text":"Pub. L. 104–1","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/397/s308/b"},"text":"section 308(b) of Pub. L. 115–397","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", and any reference to the Office of Compliance in any law, rule, regulation, or other official paper in effect as of such date to be considered to refer and apply to the Office of Congressional Workplace Rights, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/397/s308/d"},"text":"section 308(d) of Pub. L. 115–397","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1381"},"text":"section 1381 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/397/tIV/s401"},"text":"Pub. L. 115–397, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5327"},"text":"132 Stat. 5327","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/397/tIV/s401"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as otherwise provided in this Act [See Short Title of 2018 Amendment note below], this Act and the amendments made by this Act shall take effect upon the expiration of the 180-day period which begins on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No Effect on Pending Proceedings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this Act or the amendments made by this Act may be construed to affect any proceeding or payment of an award or settlement relating to a claim under title IV of the Congressional Accountability Act of 1995 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1401"},"text":"2 U.S.C. 1401","children":[],"tail":" et seq.) which is pending as of the date after that 180-day period. If, as of that date, an employee has begun any of the proceedings under that title that were available to the employee prior to that date, the employee may complete, or initiate and complete, all such proceedings, and such proceedings shall remain in effect with respect to, and provide the exclusive proceedings for, the claim involved until the completion of all such proceedings.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/dI/tI/s153/c"},"text":"Pub. L. 115–141, div. I, title I, § 153(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/787"},"text":"132 Stat. 787","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/141/dI/tI/s153/c"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“This section [amending this section and sections 1314 to 1316, 1331, 1341, 1351, 1401, 1404, and 1415 of this title] and the amendments made by this section—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall take effect on the date of enactment of this section [","children":[{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":"]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall apply to any charge, complaint, or claim, that is made on or after the date of enactment of this section, of a violation of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 201, 202, 203, 207, or 210 of the Congressional Accountability Act of 1995 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1311"},"text":"2 U.S.C. 1311","children":[],"tail":" et seq.) ["},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1311"},"text":"2 U.S.C. 1311","children":[],"tail":", 1312, 1313, 1317, 1331]; or"}],"tail":"\n"}],"tail":"\n"},{