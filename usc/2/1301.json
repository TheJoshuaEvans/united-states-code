{"tag":"section","attrib":{"id":"iddccfe014-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1301"},"text":null,"children":[{"tag":"num","attrib":{"value":"1301"},"text":"§ 1301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddccfe015-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1301/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise specifically provided in this chapter, as used in this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddccfe016-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1301/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Board” means the Board of Directors of the Office of Congressional Workplace Rights.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddccfe017-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1301/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chair","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Chair” means the Chair of the Board of Directors of the Office of Congressional Workplace Rights.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddccfe018-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1301/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered employee","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered employee” means any employee of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddccfe019-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1301/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddccfe01a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1301/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddccfe01b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1301/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Congressional Accessibility Services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddccfe01c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1301/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Capitol Police;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddccfe01d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1301/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Congressional Budget Office;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddccfe01e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1301/a/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of the Architect of the Capitol;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddccfe01f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1301/a/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of the Attending Physician;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddccfe020-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1301/a/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Congressional Workplace Rights;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddccfe021-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1301/a/3/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Technology Assessment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddccfe022-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1301/a/3/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Library of Congress, except for ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1351"},"text":"section 1351 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddccfe023-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1301/a/3/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the John C. Stennis Center for Public Service Training and Development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddccfe024-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1301/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “employee” includes an applicant for employment and a former employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddccfe025-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1301/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employee of the Office of the Architect of the Capitol","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “employee of the Office of the Architect of the Capitol” includes any employee of the Office of the Architect of the Capitol or the Botanic Garden.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddccfe026-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1301/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employee of the Capitol Police","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “employee of the Capitol Police” includes any member or officer of the Capitol Police.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddccfe027-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1301/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employee of the House of Representatives","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “employee of the House of Representatives” includes an individual occupying a position the pay for which is disbursed by the Chief Administrative Officer of the House of Representatives, or another official designated by the House of Representatives, or any employment position in an entity that is paid with funds derived from the clerk-hire allowance of the House of Representatives but not any such individual employed by any entity listed in subparagraphs (C) through (K) of paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddccfe028-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1301/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employee of the Senate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “employee of the Senate” includes any employee whose pay is disbursed by the Secretary of the Senate, but not any such individual employed by any entity listed in subparagraphs (C) through (K) of paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddccfe029-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1301/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employing office","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “employing office” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddccfe02a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1301/a/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the personal office of a Member of the House of Representatives or of a Senator;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddccfe02b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1301/a/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a committee of the House of Representatives or the Senate or a joint committee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddccfe02c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1301/a/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other office headed by a person with the final authority to appoint, hire, discharge, and set the terms, conditions, or privileges of the employment of an employee of the House of Representatives or the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddccfe02d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1301/a/9/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Congressional Accessibility Services, the United States Capitol Police, the Congressional Budget Office, the Office of the Architect of the Capitol, the Office of the Attending Physician, the Office of Congressional Workplace Rights, the Office of Technology Assessment, and the John C. Stennis Center for Public Service Training and Development; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcd2291e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1301/a/9/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Library of Congress, except for ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1351"},"text":"section 1351 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd2291f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1301/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Executive Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Executive Director” means the Executive Director of the Office of Congressional Workplace Rights.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd22920-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1301/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General Counsel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “General Counsel” means the General Counsel of the Office of Congressional Workplace Rights.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd22921-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1301/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Office” means the Office of Congressional Workplace Rights.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd22922-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1301/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clarification of coverage of employees of certain commissions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcd22923-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1301/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coverage","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to the United States Commission on International Religious Freedom, the China Review Commission, the Congressional-Executive China Commission, and the Helsinki Commission—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcd22924-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1301/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any individual who is an employee of such Commission shall be considered a covered employee for purposes of this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcd22925-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1301/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commission shall be considered an employing office for purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd22926-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1301/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to provide legal assistance and representation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcd22927-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1301/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to paragraph (3), legal assistance and representation under this chapter, including assistance and representation with respect to the proposal or acceptance of the disposition of a claim under this chapter, shall be provided to the China Review Commission, the Congressional-Executive China Commission, and the Helsinki Commission—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddcd22928-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1301/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the Office of House Employment Counsel of the House of Representatives, in the case of assistance and representation in connection with a claim filed under subchapter IV (including all subsequent proceedings under such subchapter in connection with the claim) at a time when the chair of the Commission is a Member of the House, and in the case of assistance and representation in connection with any subsequent claim under subchapter IV related to the initial claim where the subsequent claim involves the same parties; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcd22929-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1301/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the Office of Senate Chief Counsel for Employment of the Senate, in the case of assistance and representation in connection with a claim filed under subchapter IV (including all subsequent proceedings under such subchapter in connection with the claim) at a time when the chair of the Commission is a Senator, and in the case of assistance and representation in connection with any subsequent claim under subchapter IV related to the initial claim where the subsequent claim involves the same parties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcd2292a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1301/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Legal assistance and representation under this chapter, including assistance and representation with respect to the proposal or acceptance of the disposition of a claim under this chapter, shall be provided to the United States Commission on International Religious Freedom by the Office of Senate Chief Counsel for Employment of the Senate, in the case of assistance and representation in connection with a claim filed under subchapter IV (including all subsequent proceedings under such subchapter in connection with such claim).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd2292b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1301/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcd2292c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1301/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “China Review Commission” means the United States-China Economic and Security Review Commission established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7002"},"text":"section 7002 of title 22","children":[],"tail":", as enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1"},"text":"section 1 of Public Law 106–398","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcd2292d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1301/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Congressional-Executive China Commission” means the Congressional–Executive Commission on the People’s Republic of China established under title III of the U.S.–China Relations Act of 2000 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/286"},"text":"Public Law 106–286","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6911"},"text":"22 U.S.C. 6911","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcd2292e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1301/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Helsinki Commission” means the Commission on Security and Cooperation in Europe established under the Act entitled “An Act to establish a Commission on Security and Cooperation in Europe”, approved ","children":[{"tag":"date","attrib":{"date":"1976-06-03"},"text":"June 3, 1976","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/94/304"},"text":"Public Law 94–304","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3001"},"text":"22 U.S.C. 3001","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcd2292f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1301/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “United States Commission on International Religious Freedom” means the Commission established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6431"},"text":"section 6431 of title 22","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcd22930-3a6e-11f1