{"tag":"section","attrib":{"id":"iddc8d0955-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s176"},"text":null,"children":[{"tag":"num","attrib":{"value":"176"},"text":"§ 176.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mass Book Deacidification Facility; operation by Librarian of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the Librarian of Congress shall equip, furnish, operate, and maintain the Library of Congress Mass Book Deacidification Facility.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc8d0956-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/427/s2"},"text":"Pub. L. 98–427, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-09-28"},"text":"Sept. 28, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1656"},"text":"98 Stat. 1656","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc8d0957-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc8d0958-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddc8d0959-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Authorization To Construct Facility","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/427/s1"},"text":"Pub. L. 98–427, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-09-28"},"text":"Sept. 28, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1656"},"text":"98 Stat. 1656","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/427/s1"},"text":"“That the Librarian of Congress is authorized and directed, subject to the supervision and construction authority of a Federal civilian or military agency, to construct the Library of Congress Mass Book Deacidification Facility in accordance with the general design developed by the Library of Congress and reviewed by the Architect of the Capitol, as set forth in the document entitled ‘Library of Congress Mass Book Deacidification Facility, Engineering, Design, and Cost Estimate and Drawings’, dated December 1983. Such facility shall be constructed on Federal property within seventy-five miles of the United States Capitol Building.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddc8d095a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Authorization of Appropriation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/427/s3"},"text":"Pub. L. 98–427, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-09-28"},"text":"Sept. 28, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1656"},"text":"98 Stat. 1656","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/427/s3"},"text":"“There are authorized to be appropriated for fiscal years beginning after ","children":[{"tag":"date","attrib":{"date":"1983-09-30"},"text":"September 30, 1983","children":[],"tail":", sums not to exceed $11,500,000 to carry out the provisions of this Act [enacting this section and a provision set out as a note under this section].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
