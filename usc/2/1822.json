{"tag":"section","attrib":{"id":"iddce7ad66-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1822"},"text":null,"children":[{"tag":"num","attrib":{"value":"1822"},"text":"§ 1822.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leasing of space","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddce7ad67-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1822/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds appropriated to the Architect of the Capitol shall be available—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce7ad68-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1822/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the leasing of space in areas within the District of Columbia and its environs beyond the boundaries of the United States Capitol Grounds to meet space requirements of the United States Senate, United States House of Representatives, United States Capitol Police, and the Architect of the Capitol under such terms and conditions as the Committee or Commission referred to under subsection (b) may authorize; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce7ad69-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1822/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to incur any necessary expense in connection with any leasing of space under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce7ad6a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1822/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions to lease space","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Architect of the Capitol may lease space under subsection (a) upon submission of written notice of intent to lease such space to, and approved by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce7ad6b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1822/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committees on Appropriations and Rules and Administration of the Senate for space to be leased for the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce7ad6c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1822/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the House of Representatives and the House Office Building Commission for space to be leased for the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce7ad6d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1822/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committees on Appropriations of the Senate and House of Representatives, for space to be leased for any other entity under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce7ad6e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1822/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply with respect to fiscal year 2004, and each fiscal year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddce7ad6f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/83/tI/s1102"},"text":"Pub. L. 108–83, title I, § 1102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-09-30"},"text":"Sept. 30, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1027"},"text":"117 Stat. 1027","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/161/dH/tI/s1306/a"},"text":"Pub. L. 110–161, div. H, title I, § 1306(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2243"},"text":"121 Stat. 2243","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddce7ad70-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddce7ad71-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddce7ad72-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Legislative Branch Appropriations Act, 2004.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddce7ad73-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161/s1306/a/1"},"text":"Pub. L. 110–161, § 1306(a)(1)","children":[],"tail":", substituted “Committees on Appropriations and Rules and Administration” for “Committee on Rules and Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161/s1306/a/2"},"text":"Pub. L. 110–161, § 1306(a)(2)","children":[],"tail":", substituted “the Committee on Appropriations of the House of Representatives and the House Office Building Commission” for “the House Office Building Commission”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161/s1306/a/3"},"text":"Pub. L. 110–161, § 1306(a)(3)","children":[],"tail":", substituted “, for space to be leased for any other entity under subsection (a).” for period at end."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddce7ad74-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddce7ad75-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161/dH/tI/s1306/b"},"text":"Pub. L. 110–161, div. H, title I, § 1306(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2243"},"text":"121 Stat. 2243","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/161/dH/tI/s1306/b"},"text":"“The amendments made by subsection (a) [amending this section] shall take effect as if included in the enactment of the Legislative Branch Appropriations Act, 2004 [","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/83"},"text":"Pub. L. 108–83","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
