{"tag":"section","attrib":{"id":"iddd31adb4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5607"},"text":null,"children":[{"tag":"num","attrib":{"value":"5607"},"text":"§ 5607.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Member security: funding for improvements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd31adb5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5607/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Sergeant at Arms of the House of Representatives may use funds made available for providing security for the residences of Members of the House to make essential security improvements if the improvements are included in a category established and updated as necessary by the Sergeant at Arms and approved and regulated by the Committee on House Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd31adb6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5607/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section shall apply with respect to funds made available for fiscal year 2026 and each succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd31adb7-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/37/dC/tI/s117"},"text":"Pub. L. 119–37, div. C, title I, § 117","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-11-12"},"text":"Nov. 12, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/571"},"text":"139 Stat. 571","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
