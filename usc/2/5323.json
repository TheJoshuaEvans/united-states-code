{"tag":"section","attrib":{"id":"iddd2a8222-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5323"},"text":null,"children":[{"tag":"num","attrib":{"value":"5323"},"text":"§ 5323.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pay of clerical assistants as affected by death of Senator or Representative","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"When a Senator ","children":[{"tag":"ref","attrib":{"idref":"fn002109"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002109"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Inapplicability to Employees of Senate note below."}],"tail":" or Member of the House of Representatives or Delegate or Resident Commissioner dies during his term of office the clerical assistants appointed by him, and then borne upon the pay rolls of the Senate or House of Representatives, shall be continued on such pay rolls in their respective positions and be paid for a period not longer than one month: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That this shall not apply to clerical assistants of standing committees of the Senate or House of Representatives, when their service otherwise would continue beyond such period."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd2a8223-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1927-02-23/ch168/s1"},"text":"Feb. 23, 1927, ch. 168, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/1148"},"text":"44 Stat. 1148","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd2a8224-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd2a8225-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd2a8226-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s92a"},"text":"section 92a of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd2a8227-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd2a8228-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Inapplicability to Employees of Senate","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tI/s123A/a"},"text":"Pub. L. 98–473, title I, § 123A(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1969"},"text":"98 Stat. 1969","children":[],"tail":", provided that this section shall not apply to any employee of the Senate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
