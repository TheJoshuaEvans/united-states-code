{"tag":"section","attrib":{"id":"iddc8f7ae2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s179q"},"text":null,"children":[{"tag":"num","attrib":{"value":"179q"},"text":"§ 179q.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Seal of National Film Registry","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc8f7ae3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s179q/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of seal","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc8f7ae4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s179q/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on distribution and exhibition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No person shall knowingly distribute or exhibit to the public a version of a film or any copy in any format of a film which bears the seal described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s179m/a/3"},"text":"section 179m(a)(3) of this title","children":[],"tail":" if such film—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc8f7ae5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s179q/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not included in the National Film Registry; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc8f7ae6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s179q/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is included in the National Film Registry, but such film or film copy has not been approved for use of the seal by the Librarian pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s179m/a/1/D"},"text":"section 179m(a)(1)(D) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc8f7ae7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s179q/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on promotion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No person shall knowingly use the seal described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s179m/a/3"},"text":"section 179m(a)(3) of this title","children":[],"tail":" to promote any version of a film in any format other than a Registry version."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc8f7ae8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s179q/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date of seal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The use of the seal described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s179m/a/3"},"text":"section 179m(a)(3) of this title","children":[],"tail":" shall be effective for each film after the Librarian publishes in the Federal Register, in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s179m/a/2"},"text":"section 179m(a)(2) of this title","children":[],"tail":", the name of that film as selected for inclusion in the National Film Registry."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc8f7ae9-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/285/tI/s107"},"text":"Pub. L. 104–285, title I, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3381"},"text":"110 Stat. 3381","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/9/tIII/s302/d"},"text":"Pub. L. 109–9, title III, § 302(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-04-27"},"text":"Apr. 27, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/225"},"text":"119 Stat. 225","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc8f7aea-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc8f7aeb-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc8f7aec-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/9/s302/d/1"},"text":"Pub. L. 109–9, § 302(d)(1)","children":[],"tail":", inserted “in any format” after “or any copy” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/9/s302/d/2"},"text":"Pub. L. 109–9, § 302(d)(2)","children":[],"tail":", substituted “in any format” for “or film copy”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
