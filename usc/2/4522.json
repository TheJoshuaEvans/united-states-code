{"tag":"section","attrib":{"id":"iddd14fdea-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4522"},"text":null,"children":[{"tag":"num","attrib":{"value":"4522"},"text":"§ 4522.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deductions for withdrawal","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"When any Member or Delegate withdraws from his seat and does not return before the adjournment of Congress, he shall, in addition to the sum deducted for each day, forfeit a sum equal to the amount which would have been allowed by law for his mileage in returning home; and such sum shall be deducted from his compensation, unless the withdrawal is with the leave of the Senate or House of Representatives respectively.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd14fdeb-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(R.S. § 41.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd14fdec-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd14fded-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd14fdee-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s40"},"text":"section 40 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 41 derived from Res. ","children":[{"tag":"date","attrib":{"date":"1862-07-17"},"text":"July 17, 1862","children":[],"tail":", No. 68, § 2, "},{"tag":"ref","attrib":{"href":"/us/stat/12/628"},"text":"12 Stat. 628","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
