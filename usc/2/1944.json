{"tag":"section","attrib":{"id":"iddcf39414-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1944"},"text":null,"children":[{"tag":"num","attrib":{"value":"1944"},"text":"§ 1944.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wearing uniform on duty","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The officers, privates, and watchmen of the Capitol police shall, when on duty, wear the regulation uniform.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddcf39415-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1904-03-18/ch716/s1"},"text":"Mar. 18, 1904, ch. 716, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/33/89"},"text":"33 Stat. 89","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcf39416-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcf39417-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddcf39418-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was classified to section 212 of former Title 40, prior to the enactment of Title 40, Public Buildings, Property, and Works, by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217/s1"},"text":"Pub. L. 107–217, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1062"},"text":"116 Stat. 1062","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib"