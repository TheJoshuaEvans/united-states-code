{"tag":"section","attrib":{"id":"iddceed85f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1903"},"text":null,"children":[{"tag":"num","attrib":{"value":"1903"},"text":"§ 1903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chief Administrative Officer","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddceed860-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1903/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chief Administrative Officer","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddceed861-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1903/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be within the United States Capitol Police an Office of Administration, to be headed by the Chief Administrative Officer, who shall report to and serve at the pleasure of the Chief of the Capitol Police.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddceed862-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1903/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chief Administrative Officer shall be appointed by the Chief of the United States Capitol Police, after consultation with the Capitol Police Board, without regard to political affiliation and solely on the basis of fitness to perform the duties of the position.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddceed863-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1903/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The annual rate of pay for the Chief Administrative Officer shall be the amount equal to $1,000 less than the annual rate of pay in effect for the Chief of the Capitol Police.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddceed864-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1903/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Chief Administrative Officer shall have the following areas of responsibility:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddceed865-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1903/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Budgeting","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Chief Administrative Officer shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddceed866-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1903/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare and submit to the Capitol Police Board an annual budget for the Capitol Police; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddceed867-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1903/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" execute the budget and monitor through periodic examinations the execution of the Capitol Police budget in relation to actual obligations and expenditures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddceed868-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1903/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial management","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Chief Administrative Officer shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddceed869-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1903/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" oversee all financial management activities relating to the programs and operations of the Capitol Police;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddceed86a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1903/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop and maintain an integrated accounting and financial system for the Capitol Police, including financial reporting and internal controls, which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddceed86b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1903/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complies with applicable accounting principles, standards, and requirements, and internal control standards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddceed86c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1903/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complies with any other requirements applicable to such systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddceed86d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1903/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provides for—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddceed86e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1903/b/2/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complete, reliable, consistent, and timely information which is prepared on a uniform basis and which is responsive to financial information needs of the Capitol Police;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddceed86f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1903/b/2/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development and reporting of cost information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddceed870-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1903/b/2/B/iii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the integration of accounting and budgeting information; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddceed871-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1903/b/2/B/iii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the systematic measurement of performance;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddceed872-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1903/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" direct, manage, and provide policy guidance and oversight of Capitol Police financial management personnel, activities, and operations, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddceed873-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1903/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recruitment, selection, and training of personnel to carry out Capitol Police financial management functions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddceed874-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1903/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the implementation of Capitol Police asset management systems, including systems for cash management, debt collection, and property and inventory management and control; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddceed875-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1903/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Prepare ","children":[{"tag":"ref","attrib":{"idref":"fn002070"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002070"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should not be capitalized."}],"tail":" annual financial statements for the Capitol Police, and such financial statements shall be audited by the Inspector General of the Capitol Police or by an independent public accountant, as determined by the Inspector General."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddceed876-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1903/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information technology","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Chief Administrative Officer shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddceed877-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1903/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct, coordinate, and oversee the acquisition, use, and management of information technology by the Capitol Police;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddceed878-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1903/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote and oversee the use of information technology to improve the efficiency and effectiveness of programs of the Capitol Police; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddceed879-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1903/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish and enforce information technology principles, guidelines, and objectives, including developing and maintaining an information technology architecture for the Capitol Police.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddceed87a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1903/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Human resources","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Chief Administrative Officer shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddceed87b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1903/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct, coordinate, and oversee human resources management activities of the Capitol Police;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddceed87c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1903/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and monitor payroll and time and attendance systems and employee services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddceed87d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1903/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and monitor processes for recruiting, selecting, appraising, and promoting employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddceed87e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/2/tI/s108"},"text":"Pub. L. 106–554, § 1(a)(2) [title I, § 108]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–104; "},{"tag":"ref","attrib":{"href":"/us/pl/106/346/s101/a/tV/s507/a"},"text":"Pub. L. 106–346, § 101(a) [title V, § 507(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-23"},"text":"Oct. 23, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1356"},"text":"114 Stat. 1356","children":[],"tail":", 1356A–55; "},{"tag":"ref","attrib":{"href":"/us/pl/107/68/tI/s122/a"},"text":"Pub. L. 107–68, title I, § 122(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-11-12"},"text":"Nov. 12, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/576"},"text":"115 Stat. 576","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/7/dH/tI/s1013/c"},"text":"Pub. L. 108–7, div. H, title I, § 1013(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/361"},"text":"117 Stat. 361","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/271/s8/b"},"text":"Pub. L. 108–271, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-07"},"text":"July 7, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/814"},"text":"118 Stat. 814","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/55/tI/s1004/g"},"text":"Pub. L. 109–55, title I, § 1004(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-02"},"text":"Aug. 2, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/575"},"text":"119 Stat. 575","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/145"},"text":"Pub. L. 111–145","children":[],"tail":", §§ 2(a)(1), (2), 6(a), "},{"tag":"date","attrib":{"date":"2010-03-04"},"text":"Mar. 4, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/49"},"text":"124 Stat. 49","children":[],"tail":", 54.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddceed87f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddceed880-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddceed881-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was classified to section 206a–9 of former Title 40, prior to the enactment of Title 40, Public Buildings, Property, and Works, by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217/s1"},"text":"Pub. L. 107–217, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1062"},"text":"116 Stat. 1062","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddceed882-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/145/s2/a/1"},"text":"Pub. L. 111–145, § 2(a)(1)","children":[],"tail":", amended subsec. (a) generally. Prior to amendment, subsec. (a) related to the establishment of the Office of Administration and the appointment and compensation of the Chief Administrative Officer."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/145/s2/a/2"},"text":"Pub. L. 111–145, § 2(a)(2)","children":[],"tail":", struck out subsec. (c) which related to the Chief Administrative Officer’s employment of personnel and access to resources of other agencies."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d) to (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/145/s6/a"},"text":"Pub. L. 111–145, § 6(a)","children":[],"tail":", struck out subsecs. (d) to (g) which related to a plan for office policies, procedures, and actions, a report on progress made in such planning, submission of the plan and report to the appropriate congressional committees, and termination of the role of the Comptroller General."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (b)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/55"},"text":"Pub. L. 109–55","children":[],"tail":" amended subpar. (D) generally. Prior to amendment, subpar. (D) read as follows: “shall prepare annual financial statements for the Capitol Police and provide for an annual audit of the financial statements by an independent public accountant in accordance with generally accepted government auditing standards.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271"},"text":"Pub. L. 108–271","children":[],"tail":" substituted “Government Accountability Office” for “General Accounting Office”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7"},"text":"Pub. L. 108–7","children":[],"tail":" amended par. (4) generally. Prior to amendment, par. (4) read as follows: “The Chief Administrative Officer shall receive basic pay at a rate determined by the Chief of the Capitol Police, but not to exceed $1,000 less than the annual rate of pay for the Chief of the Capitol Police.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/68"},"text":"Pub. L. 107–68","children":[],"tail":" substituted “the Chief of the Capitol Police, but not to exceed $1,000 less than the annual rate of pay for the Chief of the Capitol Police” for “the Capitol Police Board, but not to exceed the annual rate of basic pay payable for ES–2 of the Senior Executive Service, as established under subchapter VIII of chapter 53 of title 5 (taking into account any comparability payments made under section 5304(h) of such title)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/346"},"text":"Pub. L. 106–346","children":[],"tail":" amended section generally, substituting present provisions for similar provisions establishing within the Capitol Police an Office of Administration to be headed by a Chief Administrative Officer, providing that the Chief Administrative Officer would be appointed and his pay rate would be set by the Comptroller General, setting out the powers and duties of the Chief Administrative Officer, and providing that as of "},{"tag":"date","attrib":{"date":"2002-10-01"},"text":"Oct. 1, 2002","children":[],"tail":", the Chief Administrative Officer would cease to be an employee of the General Accounting Office, would become an employee of the Capitol Police, and the Capitol Police Board would assume all responsibilities of the Comptroller General under this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddceed883-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddceed884-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2005 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/55"},"text":"Pub. L