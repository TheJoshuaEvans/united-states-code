{"tag":"section","attrib":{"id":"iddd2810fd-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5104"},"text":null,"children":[{"tag":"num","attrib":{"value":"5104"},"text":"§ 5104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Speaker and Minority Leader to allocate funds among certain House leadership offices","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd2810fe-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Speaker","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2810ff-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5104/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority described","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law (including any provision of law that sets forth an allowance for official expenses), the amount appropriated or otherwise made available during a Congress for the salaries and expenses of any office or authority described in paragraph (2) shall be the amount allocated for such office or authority by the Speaker of the House of Representatives from the aggregate amount appropriated or otherwise made available for all such offices and authorities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd281100-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5104/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offices and authorities described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The offices and authorities described in this paragraph are as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd281101-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5104/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of the Speaker.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd281102-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5104/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Speaker’s Office for Legislative Floor Activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd281103-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5104/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Republican Steering Committee (if the Speaker is a member of the Republican party) or the Democratic Steering and Policy Committee (if the Speaker is a member of the Democratic party).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd281104-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5104/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Republican Policy Committee (if the Speaker is a member of the Republican party).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd281105-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5104/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Training and program development—majority (as described under the heading “House leadership offices” in the most recent bill making appropriations for the legislative branch that was enacted prior to ","children":[{"tag":"date","attrib":{"date":"2011-12-23"},"text":"December 23, 2011","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd281106-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5104/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Cloakroom personnel—majority (as so described).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd281107-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Minority Leader","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd281108-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5104/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority described","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law (including any provision of law that sets forth an allowance for official expenses), the amount appropriated or otherwise made available during a Congress for the salaries and expenses of any office or authority described in paragraph (2) shall be the amount allocated for such office or authority by the Minority Leader of the House of Representatives from the aggregate amount appropriated or otherwise made available for all such offices and authorities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd281109-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5104/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offices and authorities described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The offices and authorities described in this paragraph are as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd28110a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5104/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of the Minority Leader.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd28110b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5104/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Democratic Steering and Policy Committee (if the Minority Leader is a member of the Democratic party) or the Republican Steering Committee (if the Minority Leader is a member of the Republican party).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd28110c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5104/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Republican Policy Committee (if the Minority Leader is a member of the Republican party).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd28110d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5104/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Training and program development—minority (as described under the heading “House leadership offices” in the most recent bill making appropriations for the legislative branch that was enacted prior to ","children":[{"tag":"date","attrib":{"date":"2011-12-23"},"text":"December 23, 2011","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd28110e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5104/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Cloakroom personnel—minority (as so described).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd28110f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5104/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nine minority employees (as so described).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd281110-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5104/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply with respect to any months occurring during the One Hundred Twelfth Congress that begin after ","children":[{"tag":"date","attrib":{"date":"2011-12-23"},"text":"December 23, 2011","children":[],"tail":", and to any succeeding Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd281111-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/74/dG/tI/s103"},"text":"Pub. L. 112–74, div. G, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-23"},"text":"Dec. 23, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1121"},"text":"125 Stat. 1121","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd281112-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd281113-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd281114-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The most recent bill making appropriations for the legislative branch that was enacted prior to ","children":[{"tag":"date","attrib":{"date":"2011-12-23"},"text":"December 23, 2011","children":[],"tail":", containing the heading “House leadership offices”, referred to in subsecs. (a)(2)(E) and (b)(2)(D), is "},{"tag":"ref","attrib":{"href":"/us/pl/111/68/dA"},"text":"Pub. L. 111–68, div. A","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2023"},"text":"123 Stat. 2023","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd281115-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s74a–11a"},"text":"section 74a–11a of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Legislative Branch Appropriations Act, 2012, which is div. G of the Consolidated Appropriations Act, 2012.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
