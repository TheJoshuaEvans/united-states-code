{"tag":"section","attrib":{"id":"iddc83939c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s132a"},"text":null,"children":[{"tag":"num","attrib":{"value":"132a"},"text":"§ 132a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriations for increase of general library","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The unexpended balance of any sums appropriated by Congress for the increase of the general library, together with such sums as may hereafter be appropriated to the same purpose, shall be laid out under the direction of the Joint Committee of Congress on the Library.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc83939d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(R.S. § 82; ","children":[{"tag":"date","attrib":{"date":"1902-02-07"},"text":"Feb. 7, 1902","children":[],"tail":", No. 5, "},{"tag":"ref","attrib":{"href":"/us/stat/32/735"},"text":"32 Stat. 735","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1946-08-02/ch753"},"text":"Aug. 2, 1946, ch. 753","children":[],"tail":", title II, § 223, "},{"tag":"ref","attrib":{"href":"/us/stat/60/838"},"text":"60 Stat. 838","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc83939e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc83939f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddc8393a0-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 82 derived from acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1800