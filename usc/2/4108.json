"},{"tag":"ref","attrib":{"href":"/us/stat/123/2026"},"text":"123 Stat. 2026","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd0b88ed-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd0b88ee-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd0b88ef-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s102"},"text":"Section 102 of this title","children":[],"tail":", referred to in par. (1), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/104/186/tII/s204/52"},"text":"Pub. L. 104–186, title II, § 204(52)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1737"},"text":"110 Stat. 1737","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Sections 103 and 104 of this title, referred to in par. (1), were omitted from the Code.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd0b88f0-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s104a"},"text":"section 104a of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In par. (1), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3523/a"},"text":"section 3523(a) of title 31","children":[],"tail":"” substituted for “section 117(a) of the Budget and Accounting Procedures Act of 1950 ("},{"tag":"ref","attrib":{"href":"/us/usc/t31/s67/a"},"text":"31 U.S.C. 67(a)","children":[],"tail":")” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s4/b"},"text":"Pub. L. 97–258, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1067"},"text":"96 Stat. 1067","children":[],"tail":", the first section of which enacted Title 31, Money and Finance."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is based on the first paragraph of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/454/s105/a"},"text":"section 105(a) of Pub. L. 88–454","children":[],"tail":". Remainder of section 105(a) was classified to section 67 of former Title 31, which was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s5/b"},"text":"Pub. L. 97–258, § 5(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1068"},"text":"96 Stat. 1068","children":[],"tail":", and reenacted as "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3523"},"text":"section 3523 of Title 31","children":[],"tail":", Money and Finance."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd0b88f1-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/68/s2/1"},"text":"Pub. L. 111–68, § 2(1)","children":[],"tail":", substituted “may” for “shall” in last sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/68/s2/2"},"text":"Pub. L. 111–68, § 2(2)","children":[],"tail":", added par. (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271"},"text":"Pub. L. 108–271","children":[],"tail":" substituted “Government Accountability Office” for “General Accounting Office”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554"},"text":"Pub. L. 106–554","children":[],"tail":" added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186"},"text":"Pub. L. 104–186","children":[],"tail":" substituted “Chief Administrative Officer” for “Clerk” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/283"},"text":"Pub. L. 103–283","children":[],"tail":" added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/392"},"text":"Pub. L. 102–392","children":[],"tail":" added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/303"},"text":"Pub. L. 94–303","children":[],"tail":" designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1964—","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/656"},"text":"Pub. L. 88–656","children":[],"tail":" provided that information regarding persons paid by voucher for appearances as a witness before any committee of Congress in executive session shall not be included in semiannual report except for date of payment, voucher number, and amount paid, however, any information so excluded shall be included in next succeeding semiannual period."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd0b88f2-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd0b88f3-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/2/tI/s1/b"},"text":"Pub. L. 106–554, § 1(a)(2) [title I, § 1(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–96, provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/554/s1/a/2/tI/s1/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to paragraph (2), the amendment made by this section [amending this section] shall take effect on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"First report after enactment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Senate may elect to compile and submit the report for the semiannual period during which the date of enactment of this section occurs, as if the amendment made by this section had not been enacted.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd0b88f4-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/283"},"text":"Pub. L. 103–283","children":[],"tail":" effective with respect to reports and statements covering periods beginning on and after "},{"tag":"date","attrib":{"date":"1994-10-01"},"text":"Oct. 1, 1994","children":[],"tail":", and appropriations made and obligations incurred on and after such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/283/s3/c"},"text":"section 3(c) of Pub. L. 103–283","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s504"},"text":"section 504 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd0b88f5-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", of provisions of law requiring submittal to Congress of any annual, semiannual, or other regular periodic report listed in House Document No. 103–7 (in which the report required by this section is listed on page 1), see "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance."}],"tail":"\n"}],