{"tag":"section","attrib":{"id":"iddd424f78-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6634"},"text":null,"children":[{"tag":"num","attrib":{"value":"6634"},"text":"§ 6634.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Senate Hair Care Services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd424f79-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6634/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment and compensation of personnel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Sergeant at Arms and Doorkeeper of the Senate is authorized to appoint and fix the compensation of such employees as may be necessary to operate Senate Hair Care Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd424f7a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6634/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of revolving fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Treasury of the United States within the contingent fund of the Senate a revolving fund to be known as the Senate Hair Care Services Revolving Fund (hereafter in this section referred to as the “revolving fund”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd424f7b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6634/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit and availability of moneys","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd424f7c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6634/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All moneys received by Senate Hair Care Services from fees for services or from any other source shall be deposited in the revolving fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd424f7d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6634/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Moneys in the revolving fund shall be available without fiscal year limitation for disbursement by the Secretary of the Senate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd424f7e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6634/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the payment of salaries of employees of Senate Hair Care Services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd424f7f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6634/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for necessary supplies, equipment, and other expenses of Senate Hair Care Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd424f80-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6634/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s5104/c"},"text":"section 5104(c) of title 40","children":[],"tail":", except for the provisions relating to solicitation, shall not apply to any activity carried out pursuant to this section, subject to approval of such activities by the Committee on Rules and Administration."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd424f81-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6634/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002123"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002123"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “(4)”."}],"tail":" Agency contributions for employees of Senate Hair Care Services shall be paid from the appropriations account for “"},{"tag":"inline","attrib":{},"text":"Salaries, Officers and Employees","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd424f82-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6634/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disbursements upon vouchers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Disbursements from the revolving fund shall be made upon vouchers signed by the Sergeant at Arms and Doorkeeper of the Senate, except that vouchers shall not be required for the disbursement of salaries paid at an annual rate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd424f83-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6634/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excess moneys","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the direction of the Committee on Rules and Administration, the Secretary of the Senate shall withdraw from the revolving fund and deposit in the Treasury of the United States as miscellaneous receipts all moneys in the revolving fund that the Committee may determine are in excess of the current and reasonably foreseeable needs of Senate Hair Care Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd424f84-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6634/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Sergeant at Arms and Doorkeeper of the Senate are authorized to prescribe such regulations as may be necessary to carry out the provisions of this section, subject to the approval of the Committee on Rules and Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd424f85-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6634/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of unobligated balances","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is transferred to the revolving fund established by this section any unobligated balance in the fund established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s121a"},"text":"section 121a of this title","children":[],"tail":" on the effective date of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd424f86-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6634/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd424f87-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6634/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall be effective on and after ","children":[{"tag":"date","attrib":{"date":"1998-10-01"},"text":"October 1, 1998","children":[],"tail":", or 30 days after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"October 21, 1998","children":[],"tail":"], whichever is later."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd424f88-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/275/tI/s6"},"text":"Pub. L. 105–275, title I, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2434"},"text":"112 Stat. 2434","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/57/tI/s4"},"text":"Pub. L. 106–57, title I, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-09-29"},"text":"Sept. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/412"},"text":"113 Stat. 412","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/2/tI/s3/a"},"text":"Pub. L. 106–554, § 1(a)(2) [title I, § 3(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–96.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd424f89-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd424f8a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd424f8b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s121a"},"text":"Section 121a of this title","children":[],"tail":", referred to in subsec. (g), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/105/275/tI/s6/h/1"},"text":"Pub. L. 105–275, title I, § 6(h)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2434"},"text":"112 Stat. 2434","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd424f8c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s121b–1"},"text":"section 121b–1 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/275/s6"},"text":"section 6 of Pub. L. 105–275","children":[],"tail":". Subsec. (h) of "},{"tag":"ref","attrib":{"href":"/us/pl/105/275/s6"},"text":"section 6 of Pub. L. 105–275","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/458/tI/s10"},"text":"section 10 of title I of Pub. L. 100–458","children":[],"tail":", set out as a note below, and repealed "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s121a"},"text":"section 121a of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Congressional Operations Appropriations Act, 1999, which is title I of the Legislative Branch Appropriations Act, 1999.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (c), in the first par. (3), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s5104/c"},"text":"section 5104(c) of title 40","children":[],"tail":"” substituted for “"},{"tag":"ref","attrib":{"href":"/us/act/1946-07-31/s4"},"text":"section 4 of the Act of July 31, 1946","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t40/s193d"},"text":"40 U.S.C. 193d","children":[],"tail":")” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/107/217/s5/c"},"text":"Pub. L. 107–217, § 5(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1303"},"text":"116 Stat. 1303","children":[],"tail":", the first section of which enacted Title 40, Public Buildings, Property, and Works."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd424f8d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (c)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/2/tI/s3/a/1"},"text":"Pub. L. 106–554, § 1(a)(2) [title I, § 3(a)(1)]","children":[],"tail":", struck out “and agency contributions” after “salaries”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/2/tI/s3/a/2"},"text":"Pub. L. 106–554, § 1(a)(2) [title I, § 3(a)(2)]","children":[],"tail":", added par. (3) relating to agency contributions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/57"},"text":"Pub. L. 106–57","children":[],"tail":" added par. (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd424f8e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd424f8f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/2/tI/s3/b"},"text":"Pub. L. 106–554, § 1(a)(2) [title I, § 3(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–96, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/554/s1/a/2/tI/s3/b"},"text":"“This section [amending this section] shall apply to pay periods beginning on or after ","children":[{"tag":"date","attrib":{"date":"2000-10-01"},"text":"October 1, 2000","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd424f90-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Senate Beauty Shop","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/458/tI/s10"},"text":"Pub. L. 100–458, title I, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-01"},"text":"Oct. 1, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2162"},"text":"102 Stat. 2162","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/105/275/tI/s6/h/2"},"text":"Pub. L. 105–275, title I, § 6(h)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2434"},"text":"112 Stat. 2434","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/275/tI/s6/h/2"},"text":"\n","children":[{"tag":"subsection","attrib":{"status":"repealed"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“[(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/275/tI/s6/h/2"},"text":"Pub. L. 105–275, title I, § 6(h)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2434"},"text":"112 Stat. 2434","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“[(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amended former ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s121a"},"text":"section 121a of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any individual who, on the date of the enactment of this section [","children":[{"tag":"date","attrib":{"date":"1988-10-01"},"text":"Oct. 1, 1988","children":[],"tail":"], is an employee of the Senate Building Beauty Shop and who, after having been employed by the Sergeant at Arms and Doorkeeper pursuant to subsection (a) of this section, attains 5 years of civilian service creditable under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8411"},"text":"section 8411 of title 5","children":[],"tail":", United States Code, other than service credited pursuant to subsection (d) of this section, may be credited under such section for any service as an employee of the Senate Building Beauty Shop prior to such date of enactment, if such employee makes a payment of the amount, determined by the Office of Personnel Management, that would have been deducted and withheld from the basic pay of such employee under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8422"},"text":"section 8422 of title 5","children":[],"tail":", United States Code, for such period so credited, together with interest thereon."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding any other provision of this section, any service performed by an individual in the Senate Building Beauty Shop prior to the date of the enactment of this section [","children":[{"tag":"date","attrib":{"date":"1988-10-01"},"text":"Oct. 1, 1988","children":[],"tail":"] is deemed to be civilian service creditable under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8411"},"text":"section 8411 of title 5","children":[],"tail":", United States Code, for purposes of qualifying for survivor annuities and disability benefits under subchapters IV and V of chapter 84 of title 5, United States Code, if such individual—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the date of the enactment of this Act, is an employee of the Senate Building Beauty Shop;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on or after the date of such enactment is employed by the Sergeant at Arms and Doorkeeper pursuant to subsection (a) of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payment is made of an amount, determined by the Office of Personnel Management, which would have been deducted and withheld from the basic pay of such employee under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8422"},"text":"section 8422 of title 5","children":[],"tail":", United States Code, for such period so credited, together with interest thereon."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Personnel Management shall accept the certification of the Secretary of the Senate concerning creditable service for the purpose of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"“(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The foregoing provisions of this section shall take effect on ","children":[{"tag":"date","attrib":{"date":"1988-10-01"},"text":"October 1, 1988","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
