{"tag":"section","attrib":{"id":"iddd3fdee8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6620"},"text":null,"children":[{"tag":"num","attrib":{"value":"6620"},"text":"§ 6620.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of services and equipment on a reimbursable basis","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd3fdee9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6620/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the approval of the Committee on Rules and Administration of the Senate, the Sergeant at Arms and Doorkeeper of the Senate may provide services and equipment funded by appropriations available to the Senate to persons and entities not funded by such appropriations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3fdeea-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6620/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provision of services and equipment under subsection (a) shall be on a reimbursable basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3fdeeb-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6620/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Crediting of reimbursed amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of services or equipment provided under subsection (a) that were procured using amounts available to the Sergeant at Arms and Doorkeeper of the Senate in the account for Contingent Expenses, Sergeant at Arms and Doorkeeper of the Senate, amounts received under subsection (b) as reimbursement for the provision of such services or equipment shall be credited to that account or, if applicable, to any subaccount of that account. Amounts credited to any such account or subaccount shall be merged with amounts in that account or subaccount and shall be available to the same extent, and subject to the same terms and conditions, as amounts in that account or subaccount.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3fdeec-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6620/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply to fiscal year 2004 and each succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd3fdeed-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/83/tI/s9"},"text":"Pub. L. 108–83, title I, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-09-30"},"text":"Sept. 30, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1013"},"text":"117 Stat. 1013","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd3fdeee-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd3fdeef-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd3fdef0-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s61f–11"},"text":"section 61f–11 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Legislative Branch Appropriations Act, 2004.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
