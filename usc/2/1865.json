{"tag":"section","attrib":{"id":"iddcec67ac-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1865"},"text":null,"children":[{"tag":"num","attrib":{"value":"1865"},"text":"§ 1865.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capitol Police Buildings and Grounds Account","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcec67ad-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1865/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby established in the Treasury of the United States an account for the Architect of the Capitol to be known as “Capitol Police Buildings and Grounds” (hereinafter in this section referred to as the “account”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcec67ae-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1865/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds in the account shall be used by the Architect of the Capitol for all necessary expenses for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcec67af-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1865/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resilience and security programs of the Architect of the Capitol; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcec67b0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1865/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the maintenance, care, and operation of buildings, grounds, and security enhancements for facilities of the United States Capitol Police and for other facilities associated with such resilience and security programs at any location.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcec67b1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1865/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of transfers of appropriations from Legislative Branch agencies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcec67b2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1865/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For carrying out the purposes of the account, the Architect of the Capitol may receive transfers of appropriations from any agency of the Legislative Branch upon the approval of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcec67b3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1865/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the House of Representatives, in the case of a transfer from an office of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcec67b4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1865/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the Senate, in the case of a transfer from an office of the Senate; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcec67b5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1865/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committees on Appropriations of the House of Representatives and the Senate, in the case of a transfer from any other office of the Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcec67b6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1865/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts transferred under this subsection shall be merged with the account and made available under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcec67b7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1865/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This subsection shall apply with respect to fiscal year 2019 and each succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcec67b8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1865/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date; transfer of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply with respect to fiscal year 2002 and each succeeding fiscal year. Any amounts provided to the Architect of the Capitol prior to ","children":[{"tag":"date","attrib":{"date":"2002-08-02"},"text":"August 2, 2002","children":[],"tail":", for the maintenance, care, and operation of buildings of the United States Capitol Police during fiscal year 2002 shall be transferred to the account."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcec67b9-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/206/tI/s906"},"text":"Pub. L. 107–206, title I, § 906","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-02"},"text":"Aug. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/877"},"text":"116 Stat. 877","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/244/dB/tI/s132"},"text":"Pub. L. 115–244, div. B, title I, § 132","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-09-21"},"text":"Sept. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2936"},"text":"132 Stat. 2936","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcec67ba-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcec67bb-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddcec67bc-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was classified to section 166","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of former Title 40, prior to the enactment of Title 40, Public Buildings, Property, and Works, by "},{"tag":"ref","attrib":{"href":"/us/pl/107/217/s1"},"text":"Pub. L. 107–217, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1062"},"text":"116 Stat. 1062","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcec67bd-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsecs. (b) to (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/244"},"text":"Pub. L. 115–244","children":[],"tail":" added subsec. (c), redesignated former subsec. (c) as (d), and amended subsec. (b) generally. Prior to amendment, text of subsec. (b) read as follows: “Funds in the account shall be used by the Architect of the Capitol for all necessary expenses for the maintenance, care, and operation of buildings and grounds of the United States Capitol Police.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
