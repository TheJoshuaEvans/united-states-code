{"tag":"section","attrib":{"id":"iddd31ae02-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6113"},"text":null,"children":[{"tag":"num","attrib":{"value":"6113"},"text":"§ 6113.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment and compensation of employees by President pro tempore of Senate","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Effective ","children":[{"tag":"date","attrib":{"date":"1979-10-01"},"text":"October 1, 1979","children":[],"tail":", the President pro tempore is authorized to appoint and fix the compensation of such employees as he deems appropriate: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the gross compensation paid to such employees shall not exceed $123,000 each fiscal year."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd31ae03-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/38/tI/s101"},"text":"Pub. L. 96–38, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-25"},"text":"July 25, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/111"},"text":"93 Stat. 111","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd31ae04-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd31ae05-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd31ae06-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s61k"},"text":"section 61k of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Supplemental Appropriations Act, 1979.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd31ae07-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd31ae08-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Increases in Compensation","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Increases in compensation for Senate officers and employees under authority of Federal Pay Comparability Act of 1970 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/656"},"text":"Pub. L. 91–656","children":[],"tail":"), see Salary Directives of President pro tempore of the Senate, set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s4571"},"text":"section 4571 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
