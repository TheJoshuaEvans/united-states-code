{"tag":"section","attrib":{"id":"iddd1043b1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4311"},"text":null,"children":[{"tag":"num","attrib":{"value":"4311"},"text":"§ 4311.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of employment and compensation of committee employees by House standing committees","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Standing committees of the House shall have authority to approve the employment and compensation of committee employees (other than special and select committee employees) from the effective date of the beginning of each Congress, or such subsequent date as their service commenced.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd1043b2-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/130/s103"},"text":"Pub. L. 87–130, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-08-10"},"text":"Aug. 10, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/334"},"text":"75 Stat. 334","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd1043b3-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd1043b4-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd1043b5-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s72a–1b"},"text":"section 72a–1b of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is based on House Resolution No. 16, Eighty-seventh Congress, ","children":[{"tag":"date","attrib":{"date":"1961-01-03"},"text":"Jan. 3, 1961","children":[],"tail":", which was enacted into permanent law by "},{"tag":"ref","attrib":{"href":"/us/pl/87/130"},"text":"Pub. L. 87–130","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd1043b6-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd1043b7-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Increases in Compensation","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Increases in compensation for House officers and employees under authority of Federal Salary Act of 1967 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/206"},"text":"Pub. L. 90–206","children":[],"tail":"), Federal Pay Comparability Act of 1970 ("},{"tag":"ref","attrib":{"href":"/us/pl/91/656"},"text":"Pub. L. 91–656","children":[],"tail":"), and Legislative Branch Appropriations Act, 1988 ("},{"tag":"ref","attrib":{"href":"/us/pl/100/202"},"text":"Pub. L. 100–202","children":[],"tail":"), see sections 4531 and 4532 of this title, and Salary Directives of Speaker of the House, set out as notes under those sections."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
