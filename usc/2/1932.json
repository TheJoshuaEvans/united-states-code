{"tag":"section","attrib":{"id":"iddcf393d4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1932"},"text":null,"children":[{"tag":"num","attrib":{"value":"1932"},"text":"§ 1932.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of premium pay limits on annualized basis","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcf393d5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1932/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any limits on the amount of premium pay which may be earned by officers and members of the Capitol Police during emergencies (as determined by the Capitol Police Board) shall be applied by the Chief of the Capitol Police on an annual basis and not on a pay period basis. Any determination under this subsection shall not be reviewable or appealable in any manner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcf393d6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1932/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall apply with respect to hours of duty occurring on or after ","children":[{"tag":"date","attrib":{"date":"2001-09-11"},"text":"September 11, 2001","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcf393d7-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7/dH/tI/s1012"},"text":"Pub. L. 108–7, div. H, title I, § 1012","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/361"},"text":"117 Stat. 361","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcf393d8-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcf393d9-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddcf393da-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Legislative Branch Appropriations Act, 2003, which is div. H of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7"},"text":"Pub. L. 108–7","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
