{"tag":"section","attrib":{"id":"iddc98f178-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288k"},"text":null,"children":[{"tag":"num","attrib":{"value":"288k"},"text":"§ 288k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attorney General relieved of responsibility","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc98f179-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288k/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Upon receipt of written notice that the Counsel has undertaken, pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s288c/a"},"text":"section 288c(a) of this title","children":[],"tail":", to perform any representational service with respect to any designated party in any action or proceeding pending or to be instituted, the Attorney General shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc98f17a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288k/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be relieved of any responsibility with respect to such representational service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc98f17b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288k/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have no authority to perform such service in such action or proceeding except at the request or with the approval of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc98f17c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288k/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transfer all materials relevant to the representation authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s288c/a"},"text":"section 288c(a) of this title","children":[],"tail":" to the Counsel, except that nothing in this subsection shall limit any right of the Attorney General under existing law to intervene or appear as amicus curiae in such action or proceeding."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc98f17d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288k/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Attorney General shall notify Counsel as required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s530D"},"text":"section 530D of title 28","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc98f17e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/521/tVII/s712"},"text":"Pub. L. 95–521, title VII, § 712","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-26"},"text":"Oct. 26, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1883"},"text":"92 Stat. 1883","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dA/tII/s202/b/2"},"text":"Pub. L. 107–273, div. A, title II, § 202(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1774"},"text":"116 Stat. 1774","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/7/dH/tI/s110/b"},"text":"Pub. L. 108–7, div. H, title I, § 110(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/355"},"text":"117 Stat. 355","children":[],"tail":".)"}],"tail":