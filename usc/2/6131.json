{"tag":"section","attrib":{"id":"iddd31ae2f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6131"},"text":null,"children":[{"tag":"num","attrib":{"value":"6131"},"text":"§ 6131.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment of employees by Senate Majority and Minority Leaders; compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Effective ","children":[{"tag":"date","attrib":{"date":"1977-04-01"},"text":"April 1, 1977","children":[],"tail":", the Majority Leader and the Minority Leader are each authorized to appoint and fix the compensation of such employees as they deem appropriate: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the gross compensation paid to such employees shall not exceed $191,700 each fiscal year for each Leader."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd31ae30-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/26/tI"},"text":"Pub. L. 95–26, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-05-04"},"text":"May 4, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/80"},"text":"91 Stat. 80","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd31ae31-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd31ae32-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd31ae33-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s61h–4"},"text":"section 61h–4 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Supplemental Appropriations Act, 1977.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd31ae34-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd31ae35-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Managing Political Fund Activity","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/dP/tXVII/s1701"},"text":"Pub. L. 116–94, div. P, title XVII, § 1701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3220"},"text":"133 Stat. 3220","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/94/dP/tXVII/s1701"},"text":"“The Majority Leader and the Minority Leader may each designate up to 2 employees of their respective leadership office staff as designees referred to in the second sentence of paragraph 1 of rule XLI of the Standing Rules of the Senate.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd31ae36-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Increases in Compensation","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Increases in compensation for Senate officers and employees under authority of Federal Pay Comparability Act of 1970 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/656"},"text":"Pub. L. 91–656","children":[],"tail":"), see Salary Directives of President pro tempore of the Senate, set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s4571"},"text":"section 4571 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
