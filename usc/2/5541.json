{"tag":"section","attrib":{"id":"iddd2f3ccf-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5541"},"text":null,"children":[{"tag":"num","attrib":{"value":"5541"},"text":"§ 5541.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees for internal delivery in House of Representatives of nonpostage mail from outside sources","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Effective with respect to fiscal years beginning with fiscal year 1995, in the case of mail from outside sources presented to the Chief Administrative Officer of the House of Representatives (other than mail through the Postal Service and mail with postage otherwise paid) for internal delivery in the House of Representatives, the Chief Administrative Officer is authorized to collect fees equal to the applicable postage. Amounts received by the Chief Administrative Officer as fees under the preceding sentence shall be deposited in the Treasury for credit to the account of the Office of the Chief Administrative Officer.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd2f3cd0-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/53/tI/s101"},"text":"Pub. L. 104–53, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-11-19"},"text":"Nov. 19, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/520"},"text":"109 Stat. 520","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/161/dH/tI/s103/a"},"text":"Pub. L. 110–161, div. H, title I, § 103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2225"},"text":"121 Stat. 2225","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd2f3cd1-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd2f3cd2-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd2f3cd3-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s117j"},"text":"section 117j of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Congressional Operations Appropriations Act, 1996, which is title I of the Legislative Branch Appropriations Act, 1996.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd2f3cd4-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161"},"text":"Pub. L. 110–161","children":[],"tail":" substituted “deposited in the Treasury for credit to the account of the Office of the Chief Administrative Officer” for “deposited in the Treasury as miscellaneous receipts”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd2f3cd5-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd2f3cd6-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161/dH/tI/s103/b"},"text":"Pub. L. 110–161, div. H, title I, § 103(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2225"},"text":"121 Stat. 2225","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/161/dH/tI/s103/b"},"text":"“The amendments made by this section [amending this section] shall apply with respect to fiscal year 2008 and each succeeding fiscal year.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
