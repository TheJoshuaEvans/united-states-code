{"tag":"section","attrib":{"id":"iddce0818d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1601"},"text":null,"children":[{"tag":"num","attrib":{"value":"1601"},"text":"§ 1601.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce0818e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1601/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" responsible representative Government requires public awareness of the efforts of paid lobbyists to influence the public decisionmaking process in both the legislative and executive branches of the Federal Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce0818f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1601/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" existing lobbying disclosure statutes have been ineffective because of unclear statutory language, weak administrative and enforcement provisions, and an absence of clear guidance as to who is required to register and what they are required to disclose; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce08190-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1601/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effective public disclosure of the identity and extent of the efforts of paid lobbyists to influence Federal officials in the conduct of Government actions will increase public confidence in the integrity of Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddce08191-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/65/s2"},"text":"Pub. L. 104–65, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-19"},"text":"Dec. 19, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/691"},"text":"109 Stat. 691","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddce08192-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddce08193-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddce08194-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/65/s24"},"text":"Pub. L. 104–65, § 24","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-19"},"text":"Dec. 19, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/705"},"text":"109 Stat. 705","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/65/s24"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as otherwise provided in this section, this Act [see Short Title note below] and the amendments made by this Act shall take effect on ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"January 1, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The repeals and amendments made under sections 9, 10, 11, and 12 [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s4804"},"text":"section 4804 of Title 15","children":[],"tail":", Commerce and Trade, "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s219"},"text":"section 219 of Title 18","children":[],"tail":", Crimes and Criminal Procedure, sections 611, 613, 614, 616, 618, and 4002 of Title 22, Foreign Relations and Intercourse, "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1352"},"text":"section 1352 of Title 31","children":[],"tail":", Money and Finance, and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1490p"},"text":"section 1490p of Title 42","children":[],"tail":", The Public Health and Welfare, repealing sections 261 to 270 of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3537b"},"text":"section 3537b of Title 42","children":[],"tail":", and repealing provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s261"},"text":"section 261 of this title","children":[],"tail":"] shall take effect as provided under subsection (a), except that such repeals and amendments—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not affect any proceeding or suit commenced before the effective date under subsection (a), and in all such proceedings or suits, proceedings shall be had, appeals taken, and judgments rendered in the same manner and with the same effect as if this Act had not been enacted; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not affect the requirements of Federal agencies to compile, publish, and retain information filed or received before the effective date of such repeals and amendments.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"iddce08195-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2019 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/418/s1"},"text":"Pub. L. 115–418, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-03"},"text":"Jan. 3, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5440"},"text":"132 Stat. 5440","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/418/s1"},"text":"“This Act [amending sections 1603 and 1604 of this title] may be cited as the ‘Justice Against Corruption on K Street Act of 2018’ or the ‘JACK Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"iddce08196-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/81/s1/a"},"text":"Pub. L. 110–81, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-09-14"},"text":"Sept. 14, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/735"},"text":"121 Stat. 735","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/81/s1/a"},"text":"“This Act [see Tables for classification] may be cited as the ‘Honest Leadership and Open Government Act of 2007’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"iddce08197-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/166/s1/a"},"text":"Pub. L. 105–166, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-04-06"},"text":"Apr. 6, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/38"},"text":"112 Stat. 38","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/166/s1/a"},"text":"“This Act [amending sections 1602, 1604, and 1610 of this title and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s613"},"text":"section 613 of Title 22","children":[],"tail":", Foreign Relations and Intercourse] may be cited as the ‘Lobbying Disclosure Technical Amendments Act of 1998’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"iddce08198-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/65/s1"},"text":"Pub. L. 104–65, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-19"},"text":"Dec. 19, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/691"},"text":"109 Stat. 691","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/65/s1"},"text":"“This Act [enacting this chapter, amending sections 3304 of Title 5, Government Organization and Employees, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/521/s102"},"text":"section 102 of Pub. L. 95–521","children":[],"tail":", set out in the Appendix to Title 5, "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s4804"},"text":"section 4804 of Title 15","children":[],"tail":", Commerce and Trade, sections 207 and 219 of Title 18, Crimes and Criminal Procedure, "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2171"},"text":"section 2171 of Title 19","children":[],"tail":", Customs Duties, sections 611, 613, 614, 616, 618, 621, and 4002 of Title 22, Foreign Relations and Intercourse, "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1352"},"text":"section 1352 of Title 31","children":[],"tail":", Money and Finance, and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1490p"},"text":"section 1490p of Title 42","children":[],"tail":", The Public Health and Welfare, repealing sections 261 to 270 of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3537b"},"text":"section 3537b of Title 42","children":[],"tail":", enacting provisions set out as notes under this section, "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3304"},"text":"section 3304 of Title 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/95/521/s102"},"text":"section 102 of Pub. L. 95–521","children":[],"tail":", set out in the Appendix to Title 5, and "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s207"},"text":"section 207 of Title 18","children":[],"tail":", and repealing provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s261"},"text":"section 261 of this title","children":[],"tail":"] may be cited as the ‘Lobbying Disclosure Act of 1995’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddce08199-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/81/tVII/s703"},"text":"Pub. L. 110–81, title VII, § 703","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-09-14"},"text":"Sept. 14, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/776"},"text":"121 Stat. 776","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/81/tVII/s703"},"text":"“Nothing in this Act [see Tables for classification] or the amendments made by this Act shall be construed to prohibit any expressive conduct protected from legal prohibition by, or any activities protected by the free speech, free exercise, or free association clauses of, the First Amendment to the Constitution.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
