{"tag":"section","attrib":{"id":"iddd31addf-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6101"},"text":null,"children":[{"tag":"num","attrib":{"value":"6101"},"text":"§ 6101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of funds from appropriations account of the Office of the Vice President and the Offices of the Secretaries for the Majority and Minority to the Senate contingent fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd31ade0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6101/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of the Vice President","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd31ade1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6101/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon the written request of the Vice President, the Secretary of the Senate shall transfer from the appropriations account appropriated under the subheading “","children":[{"tag":"inline","attrib":{},"text":"office of the vice president","children":[],"tail":"” under the heading “"},{"tag":"inline","attrib":{},"text":"Salaries, Officers and Employees","children":[],"tail":"” such amount as the Vice President shall specify to the appropriations account under the heading “"},{"tag":"inline","attrib":{},"text":"miscellaneous items","children":[],"tail":"” within the contingent fund of the Senate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd31ade2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6101/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to incur expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Vice President may incur such expenses as may be necessary or appropriate. Expenses incurred by the Vice President shall be paid from the amount transferred under paragraph (1) by the Vice President and upon vouchers approved by the Vice President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd31ade3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6101/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to advance sums","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Senate may advance such sums as may be necessary to defray expenses incurred in carrying out paragraphs (1) and (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd31ade4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6101/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offices of the Secretaries for the Majority and Minority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd31ade5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6101/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon the written request of the Secretary for the Majority or the Secretary for the Minority, the Secretary of the Senate shall transfer from the appropriations account appropriated under the subheading “","children":[{"tag":"inline","attrib":{},"text":"offices of the secretaries for the majority and minority","children":[],"tail":"” under the heading “"},{"tag":"inline","attrib":{},"text":"Salaries, Officers and Employees","children":[],"tail":"” such amount as the Secretary for the Majority or the Secretary for the Minority shall specify to the appropriations account under the heading “"},{"tag":"inline","attrib":{},"text":"miscellaneous items","children":[],"tail":"” within the contingent fund of the Senate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd31ade6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6101/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to incur expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary for the Majority or the Secretary for the Minority may incur such expenses as may be necessary or appropriate. Expenses incurred by the Secretary for the Majority or the Secretary for the Minority shall be paid from the amount transferred under paragraph (1) by the Secretary for the Majority or the Secretary for the Minority and upon vouchers approved by the Secretary for the Majority or the Secretary for the Minority, as applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd31ade7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6101/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to advance sums","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Senate may advance such sums as may be necessary to defray expenses incurred in carrying out paragraphs (1) and (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd31ade8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6101/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply to fiscal year 2005 and each fiscal year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd31ade9-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447/dG/tI/s5"},"text":"Pub. L. 108–447, div. G, title I, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3169"},"text":"118 Stat. 3169","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd31adea-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd31adeb-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd31adec-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s31a–2d"},"text":"section 31a–2d of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Legislative Branch Appropriations Act, 2005, which is div. G of the Consolidated Appropriations Act, 2005.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
