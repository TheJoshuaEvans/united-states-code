{"tag":"section","attrib":{"id":"iddcf14a62-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1923"},"text":null,"children":[{"tag":"num","attrib":{"value":"1923"},"text":"§ 1923.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unified schedules of rates of basic pay and leave system","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcf14a63-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1923/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rates of basic pay","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcf14a64-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1923/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Capitol Police Board shall establish and maintain unified schedules of rates of basic pay for members and civilian employees of the Capitol Police which shall apply to both members and employees whose appointing authority is an officer of the Senate and members and employees whose appointing authority is an officer of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf14a65-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1923/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Capitol Police Board may, from time to time, adjust any schedule established under paragraph (1) to the extent that the Board determines appropriate to reflect changes in the cost of living and to maintain pay comparability.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf14a66-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1923/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A schedule established or revised under paragraph (1) or (2) shall take effect only upon approval by the Committee on House Oversight of the House of Representatives and the Committee on Rules and Administration of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf14a67-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1923/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A schedule approved under paragraph (3) shall have the force and effect of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcf14a68-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1923/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leave system","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcf14a69-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1923/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Capitol Police Board shall prescribe, by regulation, a unified leave system for members and civilian employees of the Capitol Police which shall apply to both members and employees whose appointing authority is an officer of the Senate and members and employees whose appointing authority is an officer of the House of Representatives. The leave system shall include provisions for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcf14a6a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1923/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" annual leave, based on years of service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcf14a6b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1923/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sick leave;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcf14a6c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1923/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administrative leave;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcf14a6d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1923/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leave under the Family and Medical Leave Act of 1993 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2601"},"text":"29 U.S.C. 2601","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcf14a6e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1923/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leave without pay and leave with reduced pay, including provisions relating to contributions for benefits for any period of such leave;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcf14a6f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1923/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approval of all leave by the Chief or the designee of the Chief;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcf14a70-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1923/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the order in which categories of leave shall be used;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcf14a71-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1923/b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use, accrual, and carryover rules and limitations, including rules and limitations for any period of active duty in the Armed Forces;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcf14a72-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1923/b/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advance of annual leave or sick leave after a member or civilian employee has used all such accrued leave;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcf14a73-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1923/b/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" buy back of annual leave or sick leave used during an extended recovery period in the case of an injury in the performance of duty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcf14a74-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1923/b/1/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of accrued leave before termination of the employment as a member or civilian employee of the Capitol Police, with provision for lump sum payment for unused annual leave; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcf14a75-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1923/b/1/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a leave-sharing program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf14a76-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1923/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The leave system under this section may not provide for the accrual of either annual or sick leave for any period of leave without pay or leave with reduced pay.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf14a77-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1923/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All provisions of the leave system established under this subsection shall be subject to the approval of the Committee on House Oversight of the House of Representatives and the Committee on Rules and Administration of the Senate. All regulations approved under this subsection shall have the force and effect of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcf14a78-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1923/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lump sum payments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcf14a79-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1923/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon the approval of the Capitol Police Board, a member or civilian employee of the Capitol Police who is separated from service may be paid a lump sum payment for the accrued annual leave of the member or civilian employee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf14a7a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1923/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The lump sum payment under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcf14a7b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1923/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall equal the pay the member or civilian employee would have received had such member or employee remained in the service until the expiration of the period of annual leave;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcf14a7c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1923/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be paid from amounts appropriated to the Capitol Police;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcf14a7d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1923/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be based on the rate of basic pay in effect with respect to the member or civilian employee on the last day of service of the member or civilian employee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcf14a7e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1923/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be calculated on the basis of extending the period of leave described under subparagraph (A) by any holiday occurring after the date of separation from service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcf14a7f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1923/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be considered pay for taxation purposes only; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcf14a80-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1923/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be paid only after the Chairman of the Capitol Police Board certifies the applicable period of leave to the Secretary of the Senate or the Chief Administrative Officer of the House of Representatives, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf14a81-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1923/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A member or civilian employee of the Capitol Police who enters active duty in the Armed Forces may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcf14a82-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1923/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receive a lump sum payment for accrued annual leave in accordance with this subsection, in addition to any pay or allowance payable from the Armed Forces; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcf14a83-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1923/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" elect to have the leave remain to the credit of such member or civilian employee until such member or civilian employee returns from active duty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf14a84-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1923/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Capitol Police Board may prescribe regulations to carry out this subsection. No lump sum payment may be paid under this subsection until such regulations are approved by the Committee on Rules and Administration of the Senate and the Committee on House Oversight of the House of Representatives. All regulations approved under this subsection shall have the force and effect of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcf14a85-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1923/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on appointment authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to affect the appointing authority of any officer of the Senate or the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcf14a86-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/55/tI/s111"},"text":"Pub. L. 105–55, title I, § 111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-10-07"},"text":"Oct. 7, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1186"},"text":"111 Stat. 1186","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcf14a87-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcf14a88-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddcf14a89-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Family and Medical Leave Act of 1993, referred to in subsec. (b)(1)(D), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/3"},"text":"Pub. L. 103–3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-02-05"},"text":"Feb. 5, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/6"},"text":"107 Stat. 6","children":[],"tail":", which enacted sections 60m and 60n of this title, sections 6381 to 6387 of Title 5, Government Organization and Employees, and chapter 28 (§ 2601 et seq.) of Title 29, Labor, amended "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s2105"},"text":"section 2105 of Title 5","children":[],"tail":", and enacted provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2601"},"text":"section 2601 of Title 29","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2601"},"text":"section 2601 of Title 29","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddcf14a8a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was classified to section 207b of former Title 40, prior to the enactment of Title 40, Public Buildings, Property, and Works, by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217/s1"},"text":"Pub. L. 107–217, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1062"},"text":"116 Stat. 1062","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcf14a8b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"iddcf14a8c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on House Oversight of House of Representatives changed to Committee on House Administration of House of Representatives by House Resolution No. 5, One Hundred Sixth Congress, ","children":[{"tag":"date","attrib":{"date":"1999-01-06"},"text":"Jan. 6, 1999","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
