{"tag":"section","attrib":{"id":"iddc96a6af-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s285g"},"text":null,"children":[{"tag":"num","attrib":{"value":"285g"},"text":"§ 285g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of applicable accounts of House","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Until such time as funds are appropriated by law to carry out the purpose of this chapter, the applicable accounts of the House of Representatives shall be available for such purpose.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc96a6b0-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/554/tI"},"text":"Pub. L. 93–554, title I","children":[],"tail":", ch. III, § 101, "},{"tag":"date","attrib":{"date":"1974-12-27"},"text":"Dec. 27, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1777"},"text":"88 Stat. 1777","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/186/tII/s207"},"text":"Pub. L. 104–186, title II, § 207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1742"},"text":"110 Stat. 1742","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc96a6b1-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc96a6b2-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddc96a6b3-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is based on section 205(h) of House Resolution No. 988, Ninety-third Congress, ","children":[{"tag":"date","attrib":{"date":"1974-10-08"},"text":"Oct. 8, 1974","children":[],"tail":", which was enacted into permanent law by "},{"tag":"ref","attrib":{"href":"/us/pl/93/554"},"text":"Pub. L. 93–554","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc96a6b4-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186"},"text":"Pub. L. 104–186","children":[],"tail":" substituted “applicable accounts of the House of Representatives” for “contingent fund of the House”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
