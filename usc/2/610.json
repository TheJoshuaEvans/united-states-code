{"tag":"section","attrib":{"id":"iddca748c1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s610"},"text":null,"children":[{"tag":"num","attrib":{"value":"610"},"text":"§ 610.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment of student loan on behalf of employee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddca748c2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s610/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Congressional Budget Office may, in order to recruit or retain qualified personnel, establish and maintain on and after ","children":[{"tag":"date","attrib":{"date":"2001-11-12"},"text":"November 12, 2001","children":[],"tail":", a program under which the Office may agree to repay (by direct payments on behalf of the employee) all or a portion of any student loan previously taken out by such employee."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca748c3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s610/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may, by regulation, make applicable such provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5379"},"text":"section 5379 of title 5","children":[],"tail":" as the Director determines necessary to provide for such program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca748c4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s610/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The regulations shall provide the amount paid by the Office may not exceed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddca748c5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s610/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $6,000 for any employee in any calendar year; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca748c6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s610/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a total of $40,000 in the case of any employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca748c7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s610/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office may not reimburse an employee for any repayments made by such employee prior to the Office entering into an agreement under this section with such employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca748c8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s610/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accounting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amount repaid by, or recovered from, an individual under this section and its implementing regulations shall be credited to the appropriation account available for salaries and expenses of the Office at the time of repayment or recovery.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca748c9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s610/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply to fiscal year 2002 and each fiscal year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddca748ca-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/68/tI/s127"},"text":"Pub. L. 107–68, title I, § 127","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-11-12"},"text":"Nov. 12, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/577"},"text":"115 Stat. 577","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddca748cb-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddca748cc-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddca748cd-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Congressional Operations Appropriations Act, 2002, which is title I of the Legislative Branch Appropriations Act, 2002, and not as part of title II of the Congressional Budget and Impoundment Control Act of 1974 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
