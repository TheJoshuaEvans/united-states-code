{"tag":"section","attrib":{"id":"iddcd954ab-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1386"},"text":null,"children":[{"tag":"num","attrib":{"value":"1386"},"text":"§ 1386.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of surplus or obsolete personal property","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Executive Director may, within the limits of available appropriations, dispose of surplus or obsolete personal property by interagency transfer, donation, or discarding.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddcd954ac-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/1/tIII/s306"},"text":"Pub. L. 104–1, title III, § 306","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/68/dA/tI/s1101/a"},"text":"Pub. L. 111–68, div. A, title I, § 1101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2031"},"text":"123 Stat. 2031","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcd954ad-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcd954ae-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddcd954af-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/68/dA/tI/s1101/c"},"text":"Pub. L. 111–68, div. A, title I, § 1101(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2031"},"text":"123 Stat. 2031","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/68/dA/tI/s1101/c"},"text":"“The amendments made by this section [enacting this section] shall apply with respect to fiscal year 2010, and each fiscal year thereafter.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
