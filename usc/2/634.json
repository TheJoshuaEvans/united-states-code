{"tag":"section","attrib":{"id":"iddcac03ad-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s634"},"text":null,"children":[{"tag":"num","attrib":{"value":"634"},"text":"§ 634.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Concurrent resolution on the budget must be adopted before budget-related legislation is considered","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcac03ae-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s634/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Until the concurrent resolution on the budget for a fiscal year has been agreed to, it shall not be in order in the House of Representatives, with respect to the first fiscal year covered by that resolution, or the Senate, with respect to any fiscal year covered by that resolution, to consider any bill or joint resolution, amendment or motion thereto, or conference report thereon that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcac03af-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s634/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" first provides new budget authority for that fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcac03b0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s634/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" first provides an increase or decrease in revenues during that fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcac03b1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s634/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides an increase or decrease in the public debt limit to become effective during that fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcac03b2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s634/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the Senate only, first provides new entitlement authority for that fiscal year; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcac03b3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s634/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the Senate only, first provides for an increase or decrease in outlays for that fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcac03b4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s634/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions in House","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the House of Representatives, subsection (a) does not apply—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcac03b5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s634/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcac03b6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s634/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to any bill or joint resolution, as reported, providing advance discretionary new budget authority that first becomes available for the first or second fiscal year after the budget year; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcac03b7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s634/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to any bill or joint resolution, as reported, first increasing or decreasing revenues in a fiscal year following the fiscal year to which the concurrent resolution applies;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcac03b8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s634/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after May 15, to any general appropriation bill or amendment thereto; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcac03b9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s634/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to any bill or joint resolution unless it is reported by a committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcac03ba-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s634/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application to appropriation measures in Senate","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcac03bb-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s634/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Until the concurrent resolution on the budget for a fiscal year has been agreed to and an allocation has been made to the Committee on Appropriations of the Senate under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s633/a"},"text":"section 633(a) of this title","children":[],"tail":" for that year, it shall not be in order in the Senate to consider any appropriation bill or joint resolution, amendment or motion thereto, or conference report thereon for that year or any subsequent year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcac03bc-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s634/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) does not apply to appropriations legislation making advance appropriations for the first or second fiscal year after the year the allocation referred to in that paragraph is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcac03bd-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/344/tIII/s303"},"text":"Pub. L. 93–344, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-07-12"},"text":"July 12, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/309"},"text":"88 Stat. 309","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/177/tII/s201/b"},"text":"Pub. L. 99–177, title II, § 201(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-12"},"text":"Dec. 12, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1046"},"text":"99 Stat. 1046","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXIII"},"text":"Pub. L. 101–508, title XIII","children":[],"tail":", §§ 13205, 13207(a)(1)(C), "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-616"},"text":"104 Stat. 1388–616","children":[],"tail":", 1388–617; "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/tX/s10107/a"},"text":"Pub. L. 105–33, title X, § 10107(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/683"},"text":"111 Stat. 683","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcac03be-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcac03bf-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddcac03c0-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1324"},"text":"section 1324 of Title 31","children":[],"tail":" prior to the general revision and enactment of Title 31, Money and Finance, by "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s1"},"text":"Pub. L. 97–258, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/877"},"text":"96 Stat. 877","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcac03c1-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33"},"text":"Pub. L. 105–33","children":[],"tail":" amended section catchline and text generally. Prior to amendment, text provided that concurrent resolution on the budget must be adopted before legislation providing new budget authority, new spending authority, new credit authority, or changes in revenues or public debt limit could be considered."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/s13207/a/1/C"},"text":"Pub. L. 101–508, § 13207(a)(1)(C)","children":[],"tail":", substituted “bill, joint resolution, amendment, motion, or conference report” for “bill or resolution (or amendment thereto)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/s13205/a/4"},"text":"Pub. L. 101–508, § 13205(a)(4)","children":[],"tail":", inserted “(or, in the Senate, a concurrent resolution on the budget covering such fiscal year)” after “fiscal year” in closing provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5), (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/s13205/a/1"},"text":"Pub. L. 101–508, § 13205(a)(1)","children":[],"tail":"–(3), added pars. (5) and (6) and struck out former par. (5) which read as follows: “new credit authority for a fiscal year,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/s13205/b"},"text":"Pub. L. 101–508, § 13205(b)","children":[],"tail":", designated existing provisions as par. (1) and substituted “In the House of Representatives, subsection (a)” for “Subsection (a)”, redesignated former pars. (1) and (2) as subpars. (A) and (B), respectively, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/177"},"text":"Pub. L. 99–177","children":[],"tail":" inserted reference to new credit authority in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/177"},"text":"Pub. L. 99–177","children":[],"tail":" amended subsec. (a) generally, substituting provisions respecting new entitlement authority or new credit authority, for provisions respecting new spending authority."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/177"},"text":"Pub. L. 99–177","children":[],"tail":" amended subsec. (b) generally, inserting provisions relating to applicability of subsec. (a) after May 15 of any calendar year."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/177"},"text":"Pub. L. 99–177","children":[],"tail":" amended subsec. (c) generally, inserting references to amendments of bills or resolutions wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcac03c2-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcac03c3-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1985 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/177"},"text":"Pub. L. 99–177","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1985-12-12"},"text":"Dec. 12, 1985","children":[],"tail":", and applicable with respect to fiscal years beginning after "},{"tag":"date","attrib":{"date":"1985-09-30"},"text":"Sept. 30, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/177/s275/a/1"},"text":"section 275(a)(1) of Pub. L. 99–177","children":[],"tail":", formerly set out as an Effective and Termination Dates note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s900"},"text":"section 900 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/112/25/tI/s104/a"},"text":"Pub. L. 112–25, title I, § 104(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-08-02"},"text":"Aug. 2, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/246"},"text":"125 Stat. 246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
