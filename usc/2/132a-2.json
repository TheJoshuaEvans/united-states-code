{"tag":"section","attrib":{"id":"iddc8393a6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s132a–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"132a–2"},"text":"§ 132a–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Furniture, furnishings, and office and library equipment; transfer of funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc8393a7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s132a–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to any other transfer authority provided by law, during fiscal year 2001 and fiscal years thereafter, the Librarian of Congress may transfer to and among available accounts of the Library of Congress amounts appropriated to the Librarian from funds for the purchase, installation, maintenance, and repair of furniture, furnishings, and office and library equipment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc8393a8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s132a–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amounts transferred pursuant to subsection (a) shall be merged with and be available for the same purpose and for the same period as the appropriation or account to which such amounts are transferred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc8393a9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s132a–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Librarian may transfer amounts pursuant to subsection (a) only with the approval of the Committees on Appropriations of the House of Representatives and Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc8393aa-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/2/tII/s209"},"text":"Pub. L. 106–554, § 1(a)(2) [title II, § 209]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–114.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc8393ab-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc8393ac-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddc8393ad-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Legislative Branch Appropriations Act, 2001.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
