{"tag":"section","attrib":{"id":"iddd259ff6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4723"},"text":null,"children":[{"tag":"num","attrib":{"value":"4723"},"text":"§ 4723.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report by Select Committee on Ethics","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Select Committee on Ethics of the Senate shall issue an annual report due no later than January 31, describing the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd259ff7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4723/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of alleged violations of Senate rules received from any source, including the number raised by a Senator or staff of the committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd259ff8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4723/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A list of the number of alleged violations that were dismissed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd259ff9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4723/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for lack of subject matter jurisdiction or, in which, even if the allegations in the complaint are true, no violation of Senate rules would exist; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd259ffa-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4723/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" because they failed to provide sufficient facts as to any material violation of the Senate rules beyond mere allegation or assertion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd259ffb-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4723/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of alleged violations in which the committee staff conducted a preliminary inquiry.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd259ffc-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4723/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of alleged violations that resulted in an adjudicatory review.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd259ffd-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4723/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of alleged violations that the committee dismissed for lack of substantial merit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd259ffe-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4723/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of private letters of admonition or public letters of admonition issued.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd259fff-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4723/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of matters resulting in a disciplinary sanction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd25a000-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4723/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other information deemed by the committee to be appropriate to describe its activities in the preceding year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd25a001-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/81/tV/s554"},"text":"Pub. L. 110–81, title V, § 554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-09-14"},"text":"Sept. 14, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/773"},"text":"121 Stat. 773","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd25a002-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd25a003-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd25a004-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s72a–1i"},"text":"section 72a–1i of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
