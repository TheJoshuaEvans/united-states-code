{"tag":"section","attrib":{"id":"iddc98f185-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288l"},"text":null,"children":[{"tag":"num","attrib":{"value":"288l"},"text":"§ 288l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedural provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc98f186-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288l/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intervention or appearance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Permission to intervene as a party or to appear as amicus curiae under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s288e"},"text":"section 288e of this title","children":[],"tail":" shall be of right and may be denied by a court only upon an express finding that such intervention or appearance is untimely and would significantly delay the pending action or that standing to intervene has not been established under section 2 of article III of the Constitution of the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc98f187-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288l/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance with admission requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Counsel, the Deputy Counsel, or any designated Assistant Counsel or counsel specially retained by the Office shall be entitled, for the purpose of performing his functions under this chapter, to enter an appearance in any proceeding before any court of the United States or of a State or political subdivision thereof without compliance with any requirement for admission to practice before such court, except that the authorization conferred by this subsection shall not apply with respect to the admission of any such person to practice before the United States Supreme Court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc98f188-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288l/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standing to sue; jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed to confer standing on any party seeking to bring, or jurisdiction on any court with respect to, any civil or criminal action against Congress, either House of Congress, a Member of Congress, a committee or subcommittee of a House of Congress, any office or agency of Congress, or any officer or employee of a House of Congress or any office or agency of Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc98f189-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/521/tVII/s713"},"text":"Pub. L. 95–521, title VII, § 713","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-26"},"text":"Oct. 26, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1883"},"text":"92 Stat. 1883","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc98f18a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc98f18b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddc98f18c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (b) and (c), was in the original “this title”, meaning title VII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/521"},"text":"Pub. L. 95–521","children":[],"tail":", which enacted this chapter, "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s5504"},"text":"section 5504 of this title","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1364"},"text":"section 1364 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure, and amended sections 3210, 3216, and 3219 of Title 39, Postal Service. For complete classification of title VII to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc98f18d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddc98f18e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1979-01-03"},"text":"Jan. 3, 1979","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/521/s717"},"text":"section 717 of Pub. L. 95–521","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s288"},"text":"section 288 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
