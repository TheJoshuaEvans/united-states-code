{"tag":"section","attrib":{"id":"iddcb32f90-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s658e"},"text":null,"children":[{"tag":"num","attrib":{"value":"658e"},"text":"§ 658e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provisions relating to House of Representatives","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcb32f91-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s658e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement in House of Representatives","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall not be in order in the House of Representatives to consider a rule or order that waives the application of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s658d"},"text":"section 658d of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcb32f92-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s658e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of points of order","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcb32f93-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s658e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application to House of Representatives","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subsection shall apply only to the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb32f94-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s658e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Threshold burden","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to be cognizable by the Chair, a point of order under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s658d"},"text":"section 658d of this title","children":[],"tail":" or subsection (a) of this section must specify the precise language on which it is premised."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb32f95-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s658e/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Question of consideration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As disposition of points of order under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s658d"},"text":"section 658d of this title","children":[],"tail":" or subsection (a) of this section, the Chair shall put the question of consideration with respect to the proposition that is the subject of the points of order."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb32f96-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s658e/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Debate and intervening motions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A question of consideration under this section shall be debatable for 10 minutes by each Member initiating a point of order and for 10 minutes by an opponent on each point of order, but shall otherwise be decided without intervening motion except one that the House adjourn or that the Committee of the Whole rise, as the case may be.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb32f97-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s658e/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on amendment in order as original text","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The disposition of the question of consideration under this subsection with respect to a bill or joint resolution shall be considered also to determine the question of consideration under this subsection with respect to an amendment made in order as original text.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcb32f98-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/344/tIV/s426"},"text":"Pub. L. 93–344, title IV, § 426","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/4/tI/s101/a/2"},"text":"Pub. L. 104–4, title I, § 101(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-03-22"},"text":"Mar. 22, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/59"},"text":"109 Stat. 59","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcb32f99-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcb32f9a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddcb32f9b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", or on the date 90 days after appropriations are made available as authorized under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1516"},"text":"section 1516 of this title","children":[],"tail":", whichever is earlier, and applicable to legislation considered on and after such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/4/s110"},"text":"section 110 of Pub. L. 104–4","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1511"},"text":"section 1511 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
