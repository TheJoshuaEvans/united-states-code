{"tag":"section","attrib":{"id":"iddc6e1025-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"§ 5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nominations for Representatives at large","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Candidates for Representative or Representatives to be elected at large in any State shall be nominated in the same manner as candidates for governor, unless otherwise provided by the laws of such State.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc6e1026-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-08-08/ch5/s5"},"text":"Aug. 8, 1911, ch. 5, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/37/14"},"text":"37 Stat. 14","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
