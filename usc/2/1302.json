{"tag":"section","attrib":{"id":"iddcd2293d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1302"},"text":null,"children":[{"tag":"num","attrib":{"value":"1302"},"text":"§ 1302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of laws","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcd2293e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1302/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Laws made applicable","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following laws shall apply, as prescribed by this chapter, to the legislative branch of the Federal Government:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcd2293f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1302/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Fair Labor Standards Act of 1938 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s201"},"text":"29 U.S.C. 201","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd22940-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1302/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Title VII of the Civil Rights Act of 1964 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000e"},"text":"42 U.S.C. 2000e","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd22941-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1302/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Americans with Disabilities Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12101"},"text":"42 U.S.C. 12101","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd22942-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1302/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Age Discrimination in Employment Act of 1967 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s621"},"text":"29 U.S.C. 621","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd22943-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1302/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Family and Medical Leave Act of 1993 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2611"},"text":"29 U.S.C. 2611","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd22944-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1302/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Occupational Safety and Health Act of 1970 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s651"},"text":"29 U.S.C. 651","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd22945-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1302/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chapter 71 (relating to Federal service labor-management relations) of title 5.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd22946-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1302/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Employee Polygraph Protection Act of 1988 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2001"},"text":"29 U.S.C. 2001","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd22947-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1302/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Worker Adjustment and Retraining Notification Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2101"},"text":"29 U.S.C. 2101","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd22948-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1302/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Rehabilitation Act of 1973 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s701"},"text":"29 U.S.C. 701","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd22949-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1302/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chapter 43 (relating to veterans’ employment and reemployment) of title 38.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd2294a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1302/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s9202"},"text":"Section 9202 of title 5","children":[],"tail":"."},{"tag":"ref","attrib":{"idref":"fn002055"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002055"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Effective Date of 2019 Amendment note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd2294b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1302/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Laws which may be made applicable","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcd2294c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1302/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall review provisions of Federal law (including regulations) relating to (A) the terms and conditions of employment (including hiring, promotion, demotion, termination, salary, wages, overtime compensation, benefits, work assignments or reassignments, grievance and disciplinary procedures, protection from discrimination in personnel actions, occupational health and safety, and family and medical and other leave) of employees, and (B) access to public services and accommodations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd2294d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1302/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning on ","children":[{"tag":"date","attrib":{"date":"1996-12-31"},"text":"December 31, 1996","children":[],"tail":", and every 2 years thereafter, the Board shall report on (A) whether or to what degree the provisions described in paragraph (1) are applicable or inapplicable to the legislative branch, and (B) with respect to provisions inapplicable to the legislative branch, whether such provisions should be made applicable to the legislative branch. The presiding officers of the House of Representatives and the Senate shall cause each such report to be printed in the Congressional Record and each such report shall be referred to the committees of the House of Representatives and the Senate with jurisdiction."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd2294e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1302/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports of congressional committees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report accompanying any bill or joint resolution relating to terms and conditions of employment or access to public services or accommodations reported by a committee of the House of Representatives or the Senate shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcd2294f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1302/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the manner in which the provisions of the bill or joint resolution apply to the legislative branch; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcd22950-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1302/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a provision not applicable to the legislative branch, include a statement of the reasons the provision does not apply.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"On the objection of any Member, it shall not be in order for the Senate or the House of Representatives to consider any such bill or joint resolution if the report of the committee on such bill or joint resolution does not comply with the provisions of this paragraph. This paragraph may be waived in either House by majority vote of that House.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd22951-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1302/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Genetic Information Nondiscrimination Act of 2008","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcd22952-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1302/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of this chapter that apply to a violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1311/a/1"},"text":"section 1311(a)(1) of this title","children":[],"tail":" shall be considered to apply to a violation of title II of the Genetic Information Nondiscrimination Act of 2008 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000ff"},"text":"42 U.S.C. 2000ff","children":[],"tail":" et seq.), consistent with section 207(c) of that Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000ff–6/c"},"text":"42 U.S.C. 2000ff–6(c)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd22953-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1302/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcd22954-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1302/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No limitation on other laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section limits the provisions of this chapter that apply to a violation of a law described in subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcd22955-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1302/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A law described in this subparagraph is a law (even if not listed in subsection (a) or this subsection) that explicitly applies one or more provisions of this chapter to a violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcd22956-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/1/tI/s102"},"text":"Pub. L. 104–1, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-01-23"},"text":"Jan. 23, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/5"},"text":"109 Stat. 5","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/397/tIII/s301"},"text":"Pub. L. 115–397, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5320"},"text":"132 Stat. 5320","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tXI/s1122/d/1/A"},"text":"Pub. L. 116–92, div. A, title XI, § 1122(d)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1608"},"text":"133 Stat. 1608","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcd22957-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcd22958-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddcd22959-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a) and (c), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/1"},"text":"Pub. L. 104–1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-01-23"},"text":"Jan. 23, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/3"},"text":"109 Stat. 3","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1301"},"text":"section 1301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Fair Labor Standards Act of 1938, referred to in subsec. (a)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch676"},"text":"act June 25, 1938, ch. 676","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/1060"},"text":"52 Stat. 1060","children":[],"tail":", as amended, which is classified generally to chapter 8 (§ 201 et seq.) of Title 29, Labor. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s201"},"text":"section 201 of Title 29","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Civil Rights Act of 1964, referred to in subsec. (a)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/352"},"text":"Pub. L. 88–352","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-07-02"},"text":"July 2, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/252"},"text":"78 Stat. 252","children":[],"tail":". Title VII of the Act is classified generally to subchapter VI (§ 2000e et seq.) of chapter 21 of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000a"},"text":"section 2000a of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Americans with Disabilities Act of 1990, referred to in subsec. (a)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/336"},"text":"Pub. L. 101–336","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-07-26"},"text":"July 26, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/327"},"text":"104 Stat. 327","children":[],"tail":", which is classified principally to chapter 126 (§ 12101 et seq.) of Title 42. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12101"},"text":"section 12101 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Age Discrimination in Employment Act of 1967, referred to in subsec. (a)(4), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/202"},"text":"Pub. L. 90–202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-12-15"},"text":"Dec. 15, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/602"},"text":"81 Stat. 602","children":[],"tail":", which is classified generally to chapter 14 (§ 621 et seq.) of Title 29, Labor. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s621"},"text":"section 621 of Title 29","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Family and Medical Leave Act of 1993, referred to in subsec. (a)(5), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/3"},"text":"Pub. L. 103–3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-02-05"},"text":"Feb. 5, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/6"},"text":"107 Stat. 6","children":[],"tail":", as amended, which enacted sections 60m and 60n of this title, sections 6381 to 6387 of Title 5, Government Organization and Employees, and chapter 28 (§ 2601 et seq.) of Title 29, Labor, amended "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s2105"},"text":"section 2105 of Title 5","children":[],"tail":", and enacted provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2601"},"text":"section 2601 of Title 29","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2601"},"text":"section 2601 of Title 29","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Occupational Safety and Health Act of 1970, referred to in subsec. (a)(6), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/596"},"text":"Pub. L. 91–596","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-29"},"text":"Dec. 29, 1970","children":[],"