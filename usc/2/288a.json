{"tag":"section","attrib":{"id":"iddc98f0f2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288a"},"text":null,"children":[{"tag":"num","attrib":{"value":"288a"},"text":"§ 288a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Senate Joint Leadership Group","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc98f0f3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accountability of Office","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office shall be directly accountable to the Joint Leadership Group in the performance of the duties of the Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc98f0f4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter, the Joint Leadership Group shall consist of the following Members:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc98f0f5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President pro tempore (or if he so designates, the Deputy President pro tempore) of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc98f0f6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The majority and minority leaders of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc98f0f7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chairman and ranking minority Member of the Committee on the Judiciary of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc98f0f8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chairman and ranking minority Member of the committee of the Senate which has jurisdiction over the contingent fund of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc98f0f9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance of Secretary of Senate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Joint Leadership Group shall be assisted in the performance of its duties by the Secretary of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc98f0fa-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/521/tVII/s702"},"text":"Pub. L. 95–521, title VII, § 702","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-26"},"text":"Oct. 26, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1877"},"text":"92 Stat. 1877","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc98f0fb-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc98f0fc-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddc98f0fd-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (b), was in the original “this title”, meaning title VII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/521"},"text":"Pub. L. 95–521","children":[],"tail":", which enacted this chapter, "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s5504"},"text":"section 5504 of this title","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1364"},"text":"section 1364 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure, and amended sections 3210, 3216, and 3219 of Title 39, Postal Service. For complete classification of title VII to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc98f0fe-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddc98f0ff-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1979-01-03"},"text":"Jan. 3, 1979","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/521/s717"},"text":"section 717 of Pub. L. 95–521","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s288"},"text":"section 288 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
