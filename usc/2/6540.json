{"tag":"section","attrib":{"id":"iddd3b24b8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6540"},"text":null,"children":[{"tag":"num","attrib":{"value":"6540"},"text":"§ 6540.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment of rate of compensation by Secretary of Senate","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any specific rate of compensation established by law, as such rate has been increased or may hereafter be increased by or pursuant to law, for any position under the jurisdiction of the Secretary shall be considered as the maximum rate of compensation for that position, and the Secretary is authorized to adjust the rate of compensation of an individual occupying any such position to a rate not exceeding such maximum rate.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd3b24b9-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/382"},"text":"Pub. L. 91–382","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-18"},"text":"Aug. 18, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/808"},"text":"84 Stat. 808","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd3b24ba-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd3b24bb-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd3b24bc-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s61c–1"},"text":"section 61c–1 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd3b24bd-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd3b24be-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Increases in Compensation","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Increases in compensation for Senate officers and employees under authority of Federal Pay Comparability Act of 1970 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/656"},"text":"Pub. L. 91–656","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s4571"},"text":"section 4571 of this title","children":[],"tail":", and Salary Directives of President pro tempore of the Senate, set out as notes under that section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
