{"tag":"section","attrib":{"id":"iddc70816f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s24"},"text":null,"children":[{"tag":"num","attrib":{"value":"24"},"text":"§ 24.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary of Senate or assistant secretary may administer oaths","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Senate, and the assistant secretary thereof, shall, respectively, have power to administer any oath or affirmation required by law, or by the rules or orders of the Senate, to be taken by any officer of the Senate, and to any witness produced before it.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc708170-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1876-04-18/ch66/s2"},"text":"Apr. 18, 1876, ch. 66, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/19/34"},"text":"19 Stat. 34","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/51"},"text":"Pub. L. 92–51","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-07-09"},"text":"July 9, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/125"},"text":"85 Stat. 125","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc708171-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc708172-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"iddc708173-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Assistant secretary of the Senate deemed successor in references to chief clerk of the Senate in all laws, rules, resolutions, and orders, effective ","children":[{"tag":"date","attrib":{"date":"1971-07-01"},"text":"July 1, 1971","children":[],"tail":", under provisions of "},{"tag":"ref","attrib":{"href":"/us/pl/92/51"},"text":"Pub. L. 92–51","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-07-09"},"text":"July 9, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/125"},"text":"85 Stat. 125","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
