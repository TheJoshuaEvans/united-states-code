{"tag":"section","attrib":{"id":"iddcfabfbf-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2010"},"text":null,"children":[{"tag":"num","attrib":{"value":"2010"},"text":"§ 2010.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assignment of rooms; control of by House","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The assignment and reassignment of the rooms and other space in the House Office Building shall be subject to the control of the House of Representatives by rule, resolution, order, or otherwise. Nothing in sections 2004 to 2011 of this title shall be construed to affect or repeal the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s2001"},"text":"section 2001 of this title","children":[],"tail":", placing said House Office Building under the control of the Architect of the Capitol, subject to the approval and direction of the commission provided therein."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddcfabfc0-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"date","attrib":{"date":"1908-05-28"},"text":"May 28, 1908","children":[],"tail":", No. 30, "},{"tag":"ref","attrib":{"href":"/us/stat/35/579"},"text":"35 Stat. 579","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1921-03-03/ch124"},"text":"Mar. 3, 1921, ch. 124","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/1291"},"text":"41 Stat. 1291","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcfabfc1-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcfabfc2-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddcfabfc3-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was classified to section 183 of former Title 40, prior to the enactment of Title 40, Public Buildings, Property, and Works, by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217/s1"},"text":"Pub. L. 107–217, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1062"},"text":"116 Stat. 1062","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcfabfc4-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"iddcfabfc5-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Change of name of Architect of the Capitol, functions abolished, transferred, etc., by prior acts, see Prior Provisions and Change of Name notes set out under former ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1801"},"text":"section 1801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
