{"tag":"section","attrib":{"id":"iddc884ede-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s150"},"text":null,"children":[{"tag":"num","attrib":{"value":"150"},"text":"§ 150.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale of copies of card indexes and other publications","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Librarian of Congress is authorized to furnish to such institutions or individuals as may desire to buy them, such copies of the card indexes and other publications of the Library as may not be required for its ordinary transactions, and charge for the same a price which will cover their cost and ten per centum added, and all moneys received by him shall be deposited in the Treasury and shall be credited to the appropriation for necessary expenses for the preparation and distribution of catalog cards and other publications of the Library.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc884edf-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1902-06-28/ch1301/s1"},"text":"June 28, 1902, ch. 1301, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/32/480"},"text":"32 Stat. 480","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/94/tIV/s405/a"},"text":"Pub. L. 95–94, title IV, § 405(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-05"},"text":"Aug. 5, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/682"},"text":"91 Stat. 682","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc884ee0-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc884ee1-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc884ee2-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1977—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/94"},"text":"Pub. L. 95–94","children":[],"tail":" inserted provisions relating to crediting of the moneys deposited in the Treasury."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc884ee3-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddc884ee4-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1977 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/94/tIV/s405/b"},"text":"Pub. L. 95–94, title IV, § 405(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-05"},"text":"Aug. 5, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/682"},"text":"91 Stat. 682","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/94/tIV/s405/b"},"text":"“The amendment made by subsection (a) [amending this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1977-10-01"},"text":"October 1, 1977","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
