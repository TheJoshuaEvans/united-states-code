{"tag":"section","attrib":{"id":"iddcb5a011-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s661e"},"text":null,"children":[{"tag":"num","attrib":{"value":"661e"},"text":"§ 661e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of deposit insurance and agencies and other insurance programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcb5a012-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s661e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subchapter shall not apply to the credit or insurance activities of the Federal Deposit Insurance Corporation, National Credit Union Administration, Resolution Trust Corporation, Pension Benefit Guaranty Corporation, National Flood Insurance, National Insurance Development Fund, Crop Insurance, or Tennessee Valley Authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcb5a013-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s661e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director and the Director of the Congressional Budget Office shall each study whether the accounting for Federal deposit insurance programs should be on a cash basis on the same basis as loan guarantees, or on a different basis. Each Director shall report findings and recommendations to the President and the Congress on or before ","children":[{"tag":"date","attrib":{"date":"1991-05-31"},"text":"May 31, 1991","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcb5a014-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s661e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to data","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of subsection (b), the Office of Management and Budget and the Congressional Budget Office shall have access to all agency data that may facilitate these studies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcb5a015-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/344/tV/s506"},"text":"Pub. L. 93–344, title V, § 506","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXIII/s13201/a"},"text":"Pub. L. 101–508, title XIII, § 13201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-614"},"text":"104 Stat. 1388–614","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/tX/s10117/d"},"text":"Pub. L. 105–33, title X, § 10117(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/695"},"text":"111 Stat. 695","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcb5a016-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcb5a017-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"iddcb5a018-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/344/s506"},"text":"section 506 of Pub. L. 93–344","children":[],"tail":", title V, "},{"tag":"date","attrib":{"date":"1974-07-12"},"text":"July 12, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/322"},"text":"88 Stat. 322","children":[],"tail":", amended "},{"tag":"ref","attrib":{"href":"/us/usc/t1/s105"},"text":"section 105 of Title 1","children":[],"tail":", General Provisions, and enacted provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t1/s105"},"text":"section 105 of Title 1","children":[],"tail":", prior to the general revision of title V of "},{"tag":"ref","attrib":{"href":"/us/pl/93/344"},"text":"Pub. L. 93–344","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcb5a019-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33"},"text":"Pub. L. 105–33","children":[],"tail":" struck out subsec. (a) designation and heading, redesignated pars. (1) to (3) of former subsec. (a) as subsecs. (a) to (c), respectively, inserted subsec. headings, and substituted “subsection (b)” for “paragraph (2)” in subsec. (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
