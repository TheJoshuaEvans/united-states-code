{"tag":"section","attrib":{"id":"iddd424fc2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6654"},"text":null,"children":[{"tag":"num","attrib":{"value":"6654"},"text":"§ 6654.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of expenses of the Chaplain of the Senate from the contingent fund of the Senate","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd424fc3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6654/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each fiscal year there is authorized to be expended from the contingent fund of the Senate an amount, not in excess of $50,000 for the Chaplain of the Senate. Payments under this section shall be made only for expenses actually incurred by the Chaplain of the Senate in carrying out his functions, and shall be made upon certification and documentation of the expenses involved, by the Chaplain claiming payment under this section and upon vouchers approved by the Chaplain and by the Committee on Rules and Administration. Funds authorized for expenditure under this section may be used to purchase food or food related items.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd424fc4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6654/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repeal of Revolving Fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd424fc5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6654/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd424fc6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6654/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remaining funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any funds in the Chaplain Expense Revolving Fund on the date of the repeal under this section shall be remitted to the general fund of the United States Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd424fc7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6654/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply with respect to fiscal year 2004, and each fiscal year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd424fc8-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/199/dH/s155"},"text":"Pub. L. 108–199, div. H, § 155","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-01-23"},"text":"Jan. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/450"},"text":"118 Stat. 450","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd424fc9-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd424fca-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd424fcb-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s61d–4"},"text":"section 61d–4 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/199/dH/s155"},"text":"section 155 of div. H of Pub. L. 108–199","children":[],"tail":". Subsec. (b)(1) of "},{"tag":"ref","attrib":{"href":"/us/pl/108/199/s155"},"text":"section 155 of Pub. L. 108–199","children":[],"tail":" repealed "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s61d–3"},"text":"section 61d–3 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Miscellaneous Appropriations and Offsets Act, 2004, which is division H of the Consolidated Appropriations Act, 2004.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
