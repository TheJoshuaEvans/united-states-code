{"tag":"section","attrib":{"id":"iddd3fdf0e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6624"},"text":null,"children":[{"tag":"num","attrib":{"value":"6624"},"text":"§ 6624.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Metered charges on copiers; “Sergeant at Arms” and “user” defined; certification of services and equipment as official; deposit of payments; availability for expenditure","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd3fdf0f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6624/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" As used in this section, the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd3fdf10-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6624/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Sergeant at Arms” means the Sergeant at Arms and Doorkeeper of the United States Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3fdf11-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6624/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “user” means any Senator, Officer of the Senate, Committee, office, or entity provided copiers by the Sergeant at Arms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3fdf12-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6624/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd3fdf13-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6624/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to such regulations as may on and after ","children":[{"tag":"date","attrib":{"date":"1990-11-05"},"text":"November 5, 1990","children":[],"tail":", be issued by the Committee on Rules and Administration of the Senate, the Sergeant at Arms shall have the authority, with respect to metered charges on copying equipment provided by the Sergeant at Arms, solely for the purposes of this section, to make such certification as may be necessary to establish such services and equipment as official, issue invoices in conjunction therewith, and receive payment for such services and equipment by certification, voucher, or otherwise."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3fdf14-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6624/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All moneys, derived from the payment of metered charges on copying equipment provided from funds from the Appropriation Account within the contingent fund of the Senate for “Contingent Expenses, Sergeant at Arms and Doorkeeper of the Senate” under the line item for the Service Department, shall be deposited in and made a part of such Appropriation Account and under such line item, and shall be available for expenditure or obligation, or both, in like manner and subject to the same limitations as any other moneys in such account and under such line item.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd3fdf15-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/520/tI/s4/a"},"text":"Pub. L. 101–520, title I, § 4(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2257"},"text":"104 Stat. 2257","children":[],"tail":".)"}],"tai