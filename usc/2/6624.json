eading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd3fdf1b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1990-10-01"},"text":"Oct. 1, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/520/s4/d"},"text":"section 4(d) of Pub. L. 101–520","children":[],"tail":", set out as an Effective Date of 1990 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s6314"},"text":"section 6314 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
