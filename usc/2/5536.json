{"tag":"section","attrib":{"id":"iddd2ccc81-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5536"},"text":null,"children":[{"tag":"num","attrib":{"value":"5536"},"text":"§ 5536.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office equipment for House Members, officers, and committees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd2ccc82-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5536/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Chief Administrative Officer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the request of any Member, officer, or committee of the House of Representatives, or the Resident Commissioner from Puerto Rico, and with the approval of the Committee on House Oversight, but subject to the limitations prescribed by this Act, the Chief Administrative Officer of the House of Representatives shall furnish office equipment for use in the office of that Member, Resident Commissioner, officer, or committee. Office equipment so furnished is limited to equipment of those types and categories which the Committee on House Oversight shall prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2f3c83-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5536/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registration and ownership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Office equipment furnished under this section shall be registered in the office of the Chief Administrative Officer of the House of Representatives and shall remain the property of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2f3c84-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5536/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The cost of office equipment furnished under this section shall be paid from the applicable accounts of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2f3c85-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5536/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Committee on House Oversight shall prescribe such regulations as it considers necessary to carry out the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd2f3c86-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/139/s1"},"text":"Pub. L. 91–139, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-05"},"text":"Dec. 5, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/291"},"text":"83 Stat. 291","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/186/tII/s204/59"},"text":"Pub. L. 104–186, title II, § 204(59)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1738"},"text":"110 Stat. 1738","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd2f3c87-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd2f3c88-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd2f3c89-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/139"},"text":"Pub. L. 91–139","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-05"},"text":"Dec. 5, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/291"},"text":"83 Stat. 291","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd2f3c8a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s112e"},"text":"section 112e of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd2f3c8b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186/s204/59/A/i"},"text":"Pub. L. 104–186, § 204(59)(A)(i)","children":[],"tail":", (B)(i), substituted “House Oversight” for “House Administration” in two places and “Chief Administrative Officer of the House of Representatives shall furnish” for “Clerk of the House shall furnish electrical and mechanical”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186/s204/59/A/ii"},"text":"Pub. L. 104–186, § 204(59)(A)(ii)","children":[],"tail":", substituted “Chief Administrative Officer” for “Clerk”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186/s204/59/B/ii"},"text":"Pub. L. 104–186, § 204(59)(B)(ii)","children":[],"tail":", substituted “applicable accounts” for “contingent fund”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186/s204/59/B/i"},"text":"Pub. L. 104–186, § 204(59)(B)(i)","children":[],"tail":", (iii), substituted “House Oversight” for “House Administration” and struck out at end “The regulations shall limit, on such basis as the committee considers appropriate, the total value of office equipment, with allowance for equipment depreciation, which may be in use at any one time in the office of a Member or the Resident Commissioner.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd2f3c8c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"iddd2f3c8d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on House Oversight of House of Representatives changed to Committee on House Administration of House of Representatives by House Resolution No. 5, One Hundred Sixth Congress, ","children":[{"tag":"date","attrib":{"date":"1999-01-06"},"text":"Jan. 6, 1999","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd2f3c8e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/91/139/s3"},"text":"Pub. L. 91–139, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-05"},"text":"Dec. 5, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/292"},"text":"83 Stat. 292","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/91/139/s3"},"text":"“This Act [enacting this section and provisions set out as a note under former sections 112a to 112d of this title, and repealing sections 112a to 112d of this title] shall become effective at the beginning of the first calendar month which commences on or after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1969-12-05"},"text":"Dec. 5, 1969","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
