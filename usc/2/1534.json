{"tag":"section","attrib":{"id":"iddcde382a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1534"},"text":null,"children":[{"tag":"num","attrib":{"value":"1534"},"text":"§ 1534.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State, local, and tribal government input","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcde382b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1534/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each agency shall, to the extent permitted in law, develop an effective process to permit elected officers of State, local, and tribal governments (or their designated employees with authority to act on their behalf) to provide meaningful and timely input in the development of regulatory proposals containing significant Federal intergovernmental mandates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcde382c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1534/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings between State, local, tribal and Federal officers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Chapter 10 of title 5 shall not apply to actions in support of intergovernmental communications where—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcde382d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1534/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meetings are held exclusively between Federal officials and elected officers of State, local, and tribal governments (or their designated employees with authority to act on their behalf) acting in their official capacities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcde382e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1534/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such meetings are solely for the purposes of exchanging views, information, or advice relating to the management or implementation of Federal programs established pursuant to public law that explicitly or inherently share intergovernmental responsibilities or administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcde382f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1534/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementing guidelines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No later than 6 months after ","children":[{"tag":"date","attrib":{"date":"1995-03-22"},"text":"March 22, 1995","children":[],"tail":", the President shall issue guidelines and instructions to Federal agencies for appropriate implementation of subsections (a) and (b) consistent with applicable laws and regulations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddce08120-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/4/tII/s204"},"text":"Pub. L. 104–4, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-03-22"},"text":"Mar. 22, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/65"},"text":"109 Stat. 65","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/1"},"text":"Pub. L. 117–286, § 4(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4305"},"text":"136 Stat. 4305","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddce08121-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddce08122-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddce08123-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “Chapter 10 of title 5” for “The Federal Advisory Committee Act (5 U.S.C. App.)” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"iddce08124-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddce08125-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Authority To Issue Guidelines and Instructions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"1995-08-25"},"text":"Aug. 25, 1995","children":[],"tail":", 60 F.R. 45039, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum for the Director of the Office of Management and Budget","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"By the authority vested in me as President by the Constitution and laws of the United States, including section 204(c) of the Unfunded Mandates Reform Act of 1995 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/4"},"text":"Public Law 104–4","children":[],"tail":") ["},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1534/c"},"text":"2 U.S.C. 1534(c)","children":[],"tail":"] and "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"section 301 of title 3","children":[],"tail":" of the United States Code, I hereby delegate to the Director of the Office of Management and Budget the authority vested in the President to issue the guidelines and instructions to Federal agencies required by section 204(c) of that Act."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"You are authorized and directed to publish this memorandum in the Federal Register.","children":[],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"text":"William J. Clinton.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
