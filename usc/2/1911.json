{"tag":"section","attrib":{"id":"iddcf14a2e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1911"},"text":null,"children":[{"tag":"num","attrib":{"value":"1911"},"text":"§ 1911.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General Counsel to the Chief of Police and the United States Capitol Police","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcf14a2f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1911/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be within the United States Capitol Police the General Counsel to the Chief of Police and the United States Capitol Police (in this subsection referred to as the “General Counsel”), who shall report to and serve at the pleasure of the Chief of the United States Capitol Police.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf14a30-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1911/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The General Counsel shall be appointed by the Chief of the Capitol Police in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1907/e/1"},"text":"section 1907(e)(1) of this title","children":[],"tail":" (as amended by section 2(a)(4)),"},{"tag":"ref","attrib":{"idref":"fn002071"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002071"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" after consultation with the Capitol Police Board, without regard to political affiliation and solely on the basis of fitness to perform the duties of the position."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf14a31-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1911/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcf14a32-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1911/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraph (B), the annual rate of pay for the General Counsel shall be fixed by the Chief of the Capitol Police.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcf14a33-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1911/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The annual rate of pay for the General Counsel may not exceed an annual rate equal to $1,000 less than the annual rate of pay in effect for the Chief of the Capitol Police.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf14a34-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1911/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf14a35-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1911/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No effect on current General Counsel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section or the amendments made by this section may be construed to affect the status of the individual serving as the General Counsel to the Chief of Police and the United States Capitol Police as of ","children":[{"tag":"date","attrib":{"date":"2010-03-04"},"text":"March 4, 2010","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcf14a36-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/145/s3/a"},"text":"Pub. L. 111–145, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-04"},"text":"Mar. 4, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/51"},"text":"124 Stat. 51","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcf14a37-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcf14a38-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddcf14a39-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 2(a)(4), referred to in par. (2), means ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/145/s2/a/4"},"text":"section 2(a)(4) of Pub. L. 111–145","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"For the amendments made by this section, referred to in par. (5), see Codification note below.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddcf14a3a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of subsec. (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/145/s3"},"text":"section 3 of Pub. L. 111–145","children":[],"tail":". Subsec. (a)(4) of "},{"tag":"ref","attrib":{"href":"/us/pl/111/145/s3"},"text":"section 3 of Pub. L. 111–145","children":[],"tail":" repealed "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s84–2"},"text":"section 84–2 of this title","children":[],"tail":", now "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s5521"},"text":"section 5521 of this title","children":[],"tail":", and provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1901"},"text":"section 1901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
