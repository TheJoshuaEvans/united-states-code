{"tag":"section","attrib":{"id":"iddc884f00-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s156"},"text":null,"children":[{"tag":"num","attrib":{"value":"156"},"text":"§ 156.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gifts, etc., to Library of Congress Trust Fund Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Board is authorized to accept, receive, hold, and administer such gifts, bequests, or devises of property for the benefit of, or in connection with, the Library, its collections, or its service, as may be approved by the Board and by the Joint Committee on the Library.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc884f01-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1925-03-03/ch423/s2"},"text":"Mar. 3, 1925, ch. 423, § 2","children":[],"tail":", formerly § 1, "},{"tag":"ref","attrib":{"href":"/us/stat/43/1107"},"text":"43 Stat. 1107","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/act/1936-04-13/ch213"},"text":"Apr. 13, 1936, ch. 213","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1205"},"text":"49 Stat. 1205","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc884f02-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc884f03-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddc884f04-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of first par. of section 2 of act ","children":[{"tag":"date","attrib":{"date":"1925-03-03"},"text":"Mar. 3, 1925","children":[],"tail":". Second, third, and fourth pars. of section 2 are classified to sections 157, 158, and 158a of this title, respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
