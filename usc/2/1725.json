{"tag":"section","attrib":{"id":"iddce56239-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1725"},"text":null,"children":[{"tag":"num","attrib":{"value":"1725"},"text":"§ 1725.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General powers of Board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddce5623a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1725/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board may, for the purpose of carrying out its duties, hold such hearings, sit and act at such times and places, take such testimony, and receive such evidence, as the Librarian and the Board consider appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce5623b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1725/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service on Foundation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Two sitting members of the Board shall be appointed by the Librarian and shall serve as members of the board of directors of the National Recording Preservation Foundation, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t36/s152403"},"text":"section 152403 of title 36","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddce5623c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/474/tI/s125"},"text":"Pub. L. 106–474, title I, § 125","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2090"},"text":"114 Stat. 2090","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
