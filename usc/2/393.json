{"tag":"section","attrib":{"id":"iddca01c6f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s393"},"text":null,"children":[{"tag":"num","attrib":{"value":"393"},"text":"§ 393.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Filing of pleadings, motions, depositions, appendixes, briefs, and other papers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddca01c70-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s393/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Filings of pleadings, motions, depositions, appendixes, briefs, and other papers shall be accomplished by:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddca01c71-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s393/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" delivering a copy thereof to the Clerk of the House of Representatives at his office in Washington, District of Columbia, or to a member of his staff at such office; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca01c72-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s393/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mailing a copy thereof, by registered or certified mail, addressed to the Clerk at the House of Representatives, Washington, District of Columbia: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That if such copy is not actually received, another copy shall be filed within a reasonable time; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca01c73-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s393/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" delivering or mailing, simultaneously with the delivery or mailing of a copy thereof under paragraphs (1) and (2) of this subsection, such additional copies as the committee may by rule prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca01c74-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s393/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All papers filed with the Clerk pursuant to this chapter shall be promptly transmitted by him to the committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddca01c75-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/138/s14"},"text":"Pub. L. 91–138, § 14","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-05"},"text":"Dec. 5, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/289"},"text":"83 Stat. 289","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddca01c76-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddca01c77-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddca01c78-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable with respect to any general or special election for Representative in, or Resident Commissioner to, the Congress of the United States occurring after ","children":[{"tag":"date","attrib":{"date":"1969-12-05"},"text":"Dec. 5, 1969","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/138/s19"},"text":"section 19 of Pub. L. 91–138","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s381"},"text":"section 381 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
