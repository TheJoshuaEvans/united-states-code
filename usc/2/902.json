{"tag":"section","attrib":{"id":"iddcc18789-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s902"},"text":null,"children":[{"tag":"num","attrib":{"value":"902"},"text":"§ 902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcing pay-as-you-go","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcc1878a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s902/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of this section is to assure that any legislation enacted before ","children":[{"tag":"date","attrib":{"date":"2002-10-01"},"text":"October 1, 2002","children":[],"tail":", affecting direct spending or receipts that increases the deficit will trigger an offsetting sequestration."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcc1878b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s902/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sequestration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcc1878c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s902/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 15 calendar days after the date Congress adjourns to end a session and on the same day as a sequestration (if any) under section 901 or 903 of this title, there shall be a sequestration to offset the amount of any net deficit increase caused by all direct spending and receipts legislation enacted before ","children":[{"tag":"date","attrib":{"date":"2002-10-01"},"text":"October 1, 2002","children":[],"tail":", as calculated under paragraph (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc1878d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s902/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Calculation of deficit increase","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"OMB shall calculate the amount of deficit increase or decrease by adding—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcc1878e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s902/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all OMB estimates for the budget year of direct spending and receipts legislation transmitted under subsection (d);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcc1878f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s902/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estimated amount of savings in direct spending programs applicable to the budget year resulting from the prior year’s sequestration under this section or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s903"},"text":"section 903 of this title","children":[],"tail":", if any, as published in OMB’s final sequestration report for that prior year; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcc18790-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s902/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any net deficit increase or decrease in the current year resulting from all OMB estimates for the current year of direct spending and receipts legislation transmitted under subsection (d) that were not reflected in the final OMB sequestration report for the current year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcc18791-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s902/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eliminating a deficit increase","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcc18792-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s902/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The amount required to be sequestered in a fiscal year under subsection (b) shall be obtained from non-exempt direct spending accounts from actions taken in the following order:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcc18793-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s902/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" First","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All reductions in automatic spending increases specified in section 906(a) ","children":[{"tag":"ref","attrib":{"idref":"fn002034"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002034"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title shall be made."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcc18794-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s902/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Second","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If additional reductions in direct spending accounts are required to be made, the maximum reductions permissible under sections 906(b) of this title (guaranteed and direct student loans) and 906(c) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title (foster care and adoption assistance) shall be made."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcc18795-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s902/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Third","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddcc18796-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s902/c/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If additional reductions in direct spending accounts are required to be made, each remaining non-exempt direct spending account shall be reduced by the uniform percentage necessary to make the reductions in direct spending required by subsection (b); except that the medicare programs specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s906/d"},"text":"section 906(d) of this title","children":[],"tail":" shall not be reduced by more than 4 percent and the uniform percentage applicable to all other direct spending programs under this paragraph shall be increased (if necessary) to a level sufficient to achieve the required reduction in direct spending."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcc18797-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s902/c/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of determining reductions under clause (i), outlay reductions (as a result of sequestration of Commodity Credit Corporation commodity price support contracts in the fiscal year of a sequestration) that would occur in the following fiscal year shall be credited as outlay reductions in the fiscal year of the sequestration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc18798-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s902/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this subsection, accounts shall be assumed to be at the level in the baseline.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcc18799-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s902/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Estimates","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcc1879a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s902/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" CBO estimates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As soon as practicable after Congress completes action on any direct spending or receipts legislation, CBO shall provide an estimate to OMB of that legislation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc1879b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s902/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" OMB estimates","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 7 calendar days (excluding Saturdays, Sundays, and legal holidays) after the date of enactment of any direct spending or receipts legislation, OMB shall transmit a report to the House of Representatives and to the Senate containing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcc1879c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s902/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the CBO estimate of that legislation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcc1879d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s902/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an OMB estimate of that legislation using current economic and technical assumptions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcc1879e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s902/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an explanation of any difference between the 2 estimates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc1879f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s902/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Significant differences","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If during the preparation of the report under paragraph (2) OMB determines that there is a significant difference between the OMB and CBO estimates, OMB shall consult with the Committees on the Budget of the House of Representatives and the Senate regarding that difference and that consultation, to the extent practicable, shall include written communication to such committees that affords such committees the opportunity to comment before the issuance of that report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc187a0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s902/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope of estimates","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The estimates under this section shall include the amount of change in outlays or receipts for the current year (if applicable), the budget year, and each outyear excluding any amounts resulting from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcc187a1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s902/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" full funding of, and continuation of, the deposit insurance guarantee commitment in effect under current estimates; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcc187a2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s902/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" emergency provisions as designated under subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc187a3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s902/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scorekeeping guidelines","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"OMB and CBO, after consultation with each other and the Committees on the Budget of the House of Representatives and the Senate, shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcc187a4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s902/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine common scorekeeping guidelines; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcc187a5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s902/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in conformance with such guidelines, prepare estimates under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcc187a6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s902/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency legislation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a provision of direct spending or receipts legislation is enacted that the President designates as an emergency requirement and that the Congress so designates in statute, the amounts of new budget authority, outlays, and receipts in all fiscal years resulting from that provision shall be designated as an emergency requirement in the reports required under subsection (d). This subsection shall not apply to direct spending provisions to cover agricultural crop disaster assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcc187a7-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/177/tII/s252"},"text":"Pub. L. 99–177, title II, § 252","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-12"},"text":"Dec. 12, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1072"},"text":"99 Stat. 1072","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/119/tI/s102/a"},"text":"Pub. L. 100–119, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-09-29"},"text":"Sept. 29, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/764"},"text":"101 Stat. 764","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tVIII/s8003/e"},"text":"Pub. L. 100–203, title VIII, § 8003(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-282"},"text":"101 Stat. 1330–282","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXIII/s13101/a"},"text":"Pub. L. 101–508, title XIII, § 13101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-581"},"text":"104 Stat. 1388–581","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXIV/s14003/a"},"text":"Pub. L. 103–66, title XIV, § 14003(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/684"},"text":"107 Stat. 684","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/354/tI/s119/d/2"},"text":"Pub. L. 103–354, title I, § 119(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3208"},"text":"108 Stat. 3208","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/tX/s10205"},"text":"Pub. L. 105–33, title X, § 10205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/702"},"text":"111 Stat. 702","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/67/dA/tI/s121/1"},"text":"Pub. L. 113–67, div. A, title I, § 121(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/1174"},"text":"127 Stat. 1174","children":[],"tail":", 1175.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcc187a8-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcc187a9-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddcc187aa-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s906/a"},"text":"Section 906(a) of this title","children":[],"tail":", referred to in subsec. (c)(1)(A), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/111/139/tI/s10/a"},"text":"Pub. L. 111–139, title I, § 10(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-02-12"},"text":"Feb. 12, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/21"},"text":"124 Stat. 21","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s906/c"},"text":"Section 906(c) of this title","children":[],"tail":", referred to in subsec. (c)(1)(B), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/111/139/tI/s10/c"},"text":"Pub. L. 111–139, title I, § 10(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-02-12"},"text":"Feb. 12, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/22"},"text":"124 Stat. 22","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcc187ab-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2013—Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/67/s121/1"},"text":"Pub. L. 113–67, § 121(1)","children":[],"tail":", substituted “applicable to the budget year” for “applicable to budget year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(C)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/67/s121/2"},"text":"Pub. L. 113–67, § 121(2)","children":[],"tail":", substituted “subsection (b)” for “paragraph (1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s10205/1"},"text":"Pub. L. 105–33, § 10205(1)","children":[],"tail":", added subsec. (a) and struck out heading and text of former subsec. (a). Text read as follows: “The purpose of this section is to assure that any legislation (enacted after "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"November 5, 1990","children":[],"tail":") affecting direct spending or receipts that increases the deficit in any fiscal year covered by this Act will trigger an offsetting sequestration.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s10205/1"},"text":"Pub. L. 105–33, § 10205(1)","children":[],"tail":", added subsec. (b) and struck out heading and text of former subsec. (b) which required sequestrations at the end of a session of Congress to offset amount of any net deficit increase in that fiscal year and prior fiscal year caused by all direct spending and receipts legislation enacted after "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s10205/2"},"text":"Pub. L. 105–33, § 10205(2)","children":[],"tail":", inserted “and direct” after “guaranteed”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s10205/3"},"text":"Pub. L. 105–33, § 10205(3)","children":[],"tail":", amended heading and text of subsec. (d) generally. Prior to amendment, text read as follows: “As soon as practicable after Congress completes action on any direct spending or receipts legislation enacted after "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"November 5, 1990","children":[],"tail":", after consultation with the Committees on the Budget of the House of Representatives and the Senate, CBO shall provide OMB with an estimate of the amount of change in outlays or receipts, as the case may be, in each fiscal year through fiscal year 1998 resulting from that legislation. Within 5 calendar days after the enactment of any direct spending or receipts legislation enacted after "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"November 5, 1990","children":[],"tail":", OMB shall transmit a report to the House of Representatives and to the Senate containing such CBO estimate of that legislation, an OMB estimate of the amount of change in outlays or receipts, as the case may be, in each fiscal year through fiscal year 1998 resulting from that legislation, and an explanation of any difference between the two estimates. Those OMB estimates shall be made using current economic and technical assumptions. OMB and CBO shall prepare estimates under this paragraph in conformance with scorekeeping guidelines determined after consultation among the House and Senate Committees on the Budget, CBO, and OMB.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s10205/4"},"text":"Pub. L. 105–33, § 10205(4)","children":[],"tail":", struck out “, for any fiscal year from 1991 through 1998,” after “If” and “through 1995” after “receipts in all fiscal years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354"},"text":"Pub. L. 103–354","children":[],"tail":" inserted at end “This subsection shall not apply to direct spending provisions to cover agricultural crop disaster assistance.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/s14003/a/1"},"text":"Pub. L. 103–66, § 14003(a)(1)","children":[],"tail":", which directed the substitution of “Fiscal year 1992–1998 enforcement” for “Fiscal year 1992–1995 enforcement” in heading, was executed by substituting “Fiscal years 1992–1998 enforcement” for “Fiscal years 1992–1995 enforcement”, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/s14003/a/2"},"text":"Pub. L. 103–66, § 14003(a)(2)","children":[],"tail":", substituted “through fiscal year 1998” for “through fiscal year 1995” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/s14003/a/3"},"text":"Pub. L. 103–66, § 14003(a)(3)","children":[],"tail":", substituted “for any fiscal year from 1991 through 1998” for “for fiscal year 1991, 1992, 1993, 1994, or 1995”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" amended section generally, substituting subsecs. (a) to (e) relating to enforcement of pay-as-you-go for former subsecs. (a) to (g) relating to Presidential order."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/119"},"text":"Pub. L. 100–119","children":[],"tail":" amended section generally to reflect substitution of Director of OMB for Comptroller General as official submitting reports under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s901"},"text":"section 901 of this title","children":[],"tail":" and to revise provisions relating to content of Presidential orders issued in accordance with those reports."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(F)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/s8003/e"},"text":"Pub. L. 100–203, § 8003(e)","children":[],"tail":", substituted “proposed” for “made”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcc187ac-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcc187ad-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354/tI/s119/d/2"},"text":"Pub. L. 103–354, title I, § 119(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3208"},"text":"108 Stat. 3208","children":[],"tail":", provided that the amendment made by that section is effective "},{"tag":"date","attrib":{"date":"1995-01-01"},"text":"Jan. 1, 1995","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddcc187ae-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Congressional Budget Office Excepted From Certain Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/25/tI/s104/b"},"text":"Pub. L. 112–25, title I, § 104(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-08-02"},"text":"Aug. 2, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/246"},"text":"125 Stat. 246","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/25/tI/s104/b"},"text":"“Sections 252(d)(1), 254(c), 254(f)(3), and 254(i) of the Balanced Budget and Emergency Deficit Control Act of 1985 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s902/d/1"},"text":"2 U.S.C. 902(d)(1)","children":[],"tail":", 904(c), (f)(3), (i)] shall not apply to the Congressional Budget Office.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddcc187af-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Reduction of Preexisting Paygo Balances","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/312/s1"},"text":"Pub. L. 107–312, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2456"},"text":"116 Stat. 2456","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/312/s1"},"text":"“Upon enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":"], the Director of the Office of Management and Budget shall reduce any balances of direct spending and receipts legislation for all fiscal years under section 252 of the Balanced Budget and Emergency Deficit Control Act of 1985 ["},{"tag":"ref","attrib":{"href":"/us/usc/t2/s902"},"text":"2 U.S.C. 902","children":[],"tail":"] to zero.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddcc187b0-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Pay-As-You-Go Adjustment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/117/dC/s102"},"text":"Pub. L. 107–117, div. C, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-10"},"text":"Jan. 10, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2342"},"text":"115 Stat. 2342","children":[],"tail":", provided that in preparing the final sequestration report for fiscal year 2002 required by "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s904/f/3"},"text":"section 904(f)(3) of this title","children":[],"tail":", the Director of the Office of Management and Budget should change any balance of direct spending and receipts legislation for fiscal years 2001 and 2002 under this section to zero."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddcc187b1-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Conforming Paygo Scorecard With Transportation Equity Act for 21st Century","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/tVIII/s8102"},"text":"Pub. L. 105–178, title VIII, § 8102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/492"},"text":"112 Stat. 492","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/tIX/s9013/c"},"text":"Pub. L. 105–206, title IX, § 9013(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/865"},"text":"112 Stat. 865","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/206/tIX/s9013/c"},"text":"“Upon the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":"], the Director of the Office of Management and Budget shall not make any estimates under section 252(d) of the Balanced Budget and Emergency Deficit Control Act of 1985 ["},{"tag":"ref","attrib":{"href":"/us/usc/t2/s902/d"},"text":"2 U.S.C. 902(d)","children":[],"tail":"] of changes in direct spending outlays and receipts for any fiscal year resulting from this title [see Tables for classification] or from section 1102 of this Act [former "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s104"},"text":"23 U.S.C. 104","children":[],"tail":" note].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddcc187b2-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Reduction of Preexisting Balances and Exclusion of Effects of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33"},"text":"Pub. L. 105–33","children":[],"tail":" From Paygo Scorecard"}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/tX/s10213"},"text":"Pub. L. 105–33, title X, § 10213","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/712"},"text":"111 Stat. 712","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/33/tX/s10213"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Upon the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":"], the Director of the Office of Management and Budget shall—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce any balances of direct spending and receipts legislation for any fiscal year under section 252 of the Balanced Budget and Emergency Deficit Control Act of 1985 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s902"},"text":"2 U.S.C. 902","children":[],"tail":"] to zero; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not make any estimates of changes in direct spending outlays and receipts under subsection (d) of that section for any fiscal year resulting from the enactment of this Act [see Tables for classification] or of the Taxpayer Relief Act of 1997 [","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":", see Tables for classification].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddcc187b3-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Reduction of Direct Spending and Receipts Legislation Balances","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXIV/s14003/c"},"text":"Pub. L. 103–66, title XIV, § 14003(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/685"},"text":"107 Stat. 685","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/66/tXIV/s14003/c"},"text":"“Upon enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":"], the director of the Office of Management and Budget shall reduce the balances of direct spending and receipts legislation applicable to each fiscal year under section 252 of the Balanced Budget and Emergency Deficit Control Act of 1985 ["},{"tag":"ref","attrib":{"href":"/us/usc/t2/s902"},"text":"2 U.S.C. 902","children":[],"tail":"] by an amount equal to the net deficit reduction achieved through the enactment in this Act [see Tables for classification] of direct spending and receipts legislation for that year.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
