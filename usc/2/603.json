{"tag":"section","attrib":{"id":"iddca7487e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s603"},"text":null,"children":[{"tag":"num","attrib":{"value":"603"},"text":"§ 603.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public access to budget data","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddca7487f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s603/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right to copy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsections (c), (d), and (e), the Director shall make all information, data, estimates, and statistics obtained under section 601(d) and (e) of this title available for public copying during normal business hours, subject to reasonable rules and regulations, and shall to the extent practicable, at the request of any person, furnish a copy of any such information, data, estimates, or statistics upon payment by such person of the cost of making and furnishing such copy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca74880-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s603/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Index","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall develop and maintain filing, coding, and indexing systems that identify the information, data, estimates, and statistics to which subsection (a) applies and shall make such systems available for public use during normal business hours.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca74881-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s603/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) shall not apply to information, data, estimates, and statistics—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddca74882-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s603/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which are specifically exempted from disclosure by law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca74883-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s603/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" which the Director determines will disclose—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddca74884-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s603/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" matters necessary to be kept secret in the interests of national defense or the confidential conduct of the foreign relations of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddca74885-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s603/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information relating to trade secrets or financial or commercial information pertaining specifically to a given person if the information has been obtained by the Government on a confidential basis, other than through an application by such person for a specific financial or other benefit, and is required to be kept secret in order to prevent undue injury to the competitive position of such person; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddca74886-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s603/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" personnel or medical data or similar data the disclosure of which would constitute a clearly unwarranted invasion of personal privacy;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"unless the portions containing such matters, information, or data have been excised.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca74887-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s603/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information obtained for committees and Members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall apply to any information, data, estimates, and statistics obtained at the request of any committee, joint committee, or Member unless such committee, joint committee, or Member has instructed the Director not to make such information, data, estimates, or statistics available for public copying.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca74888-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s603/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Level of confidentiality","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to information, data, estimates, and statistics obtained under sections 601(d) and 601(e) of this title, the Director shall maintain the same level of confidentiality as is required by law of the department, agency, establishment, or regulatory agency or commission from which it is obtained. Officers and employees of the Congressional Budget Office shall be subject to the same statutory penalties for unauthorized disclosure or use as officers or employees of the department, agency, establishment, or regulatory agency or commission from which it is obtained.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddca74889-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/344/tII/s203"},"text":"Pub. L. 93–344, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-07-12"},"text":"July 12, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/305"},"text":"88 Stat. 305","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tIII/s310/b"},"text":"Pub. L. 106–554, § 1(a)(7) [title III, § 310(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–639.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddca7488a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddca7488b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddca7488c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tIII/s310/b/2"},"text":"Pub. L. 106–554, § 1(a)(7) [title III, § 310(b)(2)]","children":[],"tail":", substituted “subsections (c), (d), and (e)” for “subsections (c) and (d)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tIII/s310/b/1"},"text":"Pub. L. 106–554, § 1(a)(7) [title III, § 310(b)(1)]","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddca7488d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddca7488e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on day on which first Director of Congressional Budget Office is appointed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s601/a"},"text":"section 601(a) of this title","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/344/s905/b"},"text":"section 905(b) of Pub. L. 93–344","children":[],"tail":", formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s621"},"text":"section 621 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
