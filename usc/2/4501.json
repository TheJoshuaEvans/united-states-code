{"tag":"section","attrib":{"id":"iddd128d2c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4501"},"text":null,"children":[{"tag":"num","attrib":{"value":"4501"},"text":"§ 4501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation of Members of Congress","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd128d2d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4501/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The annual rate of pay for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd128d2e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4501/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each Senator, Member of the House of Representatives, and Delegate to the House of Representatives, and the Resident Commissioner from Puerto Rico,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd128d2f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4501/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President pro tempore of the Senate, the majority leader and the minority leader of the Senate, and the majority leader and the minority leader of the House of Representatives, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd128d30-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4501/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Speaker of the House of Representatives,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be the rate determined for such positions under chapter 11 of this title, as adjusted by paragraph (2) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd128d31-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4501/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd128d32-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4501/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to subparagraph (B), effective at the beginning of the first applicable pay period commencing on or after the first day of the month in which an adjustment takes effect under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5303"},"text":"section 5303 of title 5","children":[],"tail":" in the rates of pay under the General Schedule, each annual rate referred to in paragraph (1) shall be adjusted by an amount, rounded to the nearest multiple of $100 (or if midway between multiples of $100, to the next higher multiple of $100), equal to the percentage of such annual rate which corresponds to the most recent percentage change in the ECI (relative to the date described in the next sentence), as determined under section 704(a)(1) of the Ethics Reform Act of 1989. The appropriate date under this sentence is the first day of the fiscal year in which such adjustment in the rates of pay under the General Schedule takes effect."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd128d33-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4501/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In no event shall the percentage adjustment taking effect under subparagraph (A) in any calendar year (before rounding), in any rate of pay, exceed the percentage adjustment taking effect in such calendar year under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5303"},"text":"section 5303 of title 5","children":[],"tail":" in the rates of pay under the General Schedule."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd128d34-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-02/ch753"},"text":"Aug. 2, 1946, ch. 753","children":[],"tail":", title VI, § 601(a), "},{"tag":"ref","attrib":{"href":"/us/stat/60/850"},"text":"60 Stat. 850","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-01-19/ch2/s1/d"},"text":"Jan. 19, 1949, ch. 2, § 1(d)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/4"},"text":"63 Stat. 4","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1955-03-02/ch9/s4/a"},"text":"Mar. 2, 1955, ch. 9, § 4(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/11"},"text":"69 Stat. 11","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/426/tII/s204"},"text":"Pub. L. 88–426, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-08-14"},"text":"Aug. 14, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/415"},"text":"78 Stat. 415","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/301/s11/e"},"text":"Pub. L. 89–301, § 11(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-10-29"},"text":"Oct. 29, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1120"},"text":"79 Stat. 1120","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/67/s2"},"text":"Pub. L. 91–67, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-09-15"},"text":"Sept. 15, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/107"},"text":"83 Stat. 107","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/82/tII/s204/a"},"text":"Pub. L. 94–82, title II, § 204(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-08-09"},"text":"Aug. 9, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/421"},"text":"89 Stat. 421","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/194/tVII/s704/a/2/B"},"text":"Pub. L. 101–194, title VII, § 704(a)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-30"},"text":"Nov. 30, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1769"},"text":"103 Stat. 1769","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/509/tV/s529/tI/s101/b/4/D"},"text":"Pub. L. 101–509, title V, § 529 [title I, § 101(b)(4)(D)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1427"},"text":"104 Stat. 1427","children":[],"tail":", 1439; "},{"tag":"ref","attrib":{"href":"/us/pl/103/356/tI/s101/1"},"text":"Pub. L. 103–356, title I, § 101(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3410"},"text":"108 Stat. 3410","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd128d35-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd128d36-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd128d37-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The General Schedule, referred to in par. (2), is set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 704(a)(1) of the Ethics Reform Act of 1989, referred to in par. (2)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/194/s704/a/1"},"text":"section 704(a)(1) of Pub. L. 101–194","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5318"},"text":"section 5318 of Title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd128d38-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s31"},"text":"section 31 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd128d39-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/356"},"text":"Pub. L. 103–356","children":[],"tail":" designated existing provisions as subpar. (A), substituted “Subject to subparagraph (B), effective” for “Effective”, and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509"},"text":"Pub. L. 101–509","children":[],"tail":" substituted “5303” for “5305”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/194"},"text":"Pub. L. 101–194","children":[],"tail":" substituted “the most recent percentage change in the ECI (relative to the date described in the next sentence), as determined under section 704(a)(1) of the Ethics Reform Act of 1989. The appropriate date under this sentence is the first day of the fiscal year in which such adjustment in the rates of pay under the General Schedule takes effect” for “the overall average percentage (as set forth in the report transmitted to the Congress under such section 5305) of the adjustment in the rates of pay under the General Schedule”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/82"},"text":"Pub. L. 94–82","children":[],"tail":" designated existing provisions as par. (1), substituted provisions that rate of pay of the specified parties shall be determined under section 351 et seq. of this title, as adjusted by par. (2) for provisions setting rate of compensation at $42,500 for Senators, Representatives, Delegates, and Resident Commissioner, $62,500 for Speaker, and $49,500 for President pro tempore of Senate and Majority and Minority Leaders of House and Senate, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1969—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/67"},"text":"Pub. L. 91–67","children":[],"tail":" increased compensation of Speaker from $43,000 to $62,500 per annum and compensation of Majority and Minority Leaders of both Houses of Congress from $35,000 to $49,500 per annum, and fixed compensation of President pro tempore of Senate at $49,500 per annum."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1965—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/301"},"text":"Pub. L. 89–301","children":[],"tail":" inserted provisions setting rate of compensation of Majority and Minority Leaders of Senate and House of Representatives at $35,000 per annum each."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1964—","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/426"},"text":"Pub. L. 88–426","children":[],"tail":" increased compensation of Senators, Representatives and Resident Commissioner from $22,500 to $30,000 per annum and that of Speaker from $35,000 to $43,000 per annum, and eliminated provisions which related to Delegates from the Territories."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1955—Act ","children":[{"tag":"date","attrib":{"date":"1955-03-02"},"text":"Mar. 2, 1955","children":[],"tail":", increased salaries of Senators, Representatives, Delegates, and Resident Commissioner from $12,500 a year to $22,500 and compensation of Speaker from $30,000 to $35,000 a year."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1949—Act ","children":[{"tag":"date","attrib":{"date":"1949-01-19"},"text":"Jan. 19, 1949","children":[],"tail":", increased Speaker’s salary from $20,000 per year to $30,000."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd128d3a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd128d3b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/356/tI/s101"},"text":"Pub. L. 103–356, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3410"},"text":"108 Stat. 3410","children":[],"tail":", provided that the amendment made by that section is effective "},{"tag":"date","attrib":{"date":"1994-12-31"},"text":"Dec. 31, 1994","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd128d3c-3a6e-11f1-