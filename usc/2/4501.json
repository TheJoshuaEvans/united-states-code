"},"text":"Pub. L. 91–67","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1969-03-01"},"text":"Mar. 1, 1969","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/67/s3"},"text":"section 3 of Pub. L. 91–67","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s104"},"text":"section 104 of Title 3","children":[],"tail":", The President."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd128d3f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1965 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/301"},"text":"Pub. L. 89–301","children":[],"tail":" effective on first day of first pay period which begins on or after "},{"tag":"date","attrib":{"date":"1965-10-01"},"text":"October 1, 1965","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/89/301/s17"},"text":"section 17 of Pub. L. 89–301","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd128d40-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1964 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/426"},"text":"Pub. L. 88–426","children":[],"tail":" effective at noon, "},{"tag":"date","attrib":{"date":"1965-01-03"},"text":"Jan. 3, 1965","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/88/426/s501/b"},"text":"section 501(b) of Pub. L. 88–426","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd128d41-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1955 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1955-03-02/ch9/s5"},"text":"Act Mar. 2, 1955, ch. 9, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/11"},"text":"69 Stat. 11","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/act/1955-03-02/ch9/s5"},"text":"“The provisions of this Act [amending this section, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t3/s104"},"text":"section 104 of Title 3","children":[],"tail":", The President, "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s7443"},"text":"section 7443 of Title 26","children":[],"tail":", Internal Revenue Code, sections 5, 44, 135, 173, 213, 252, and 508 of Title 28, Judiciary and Judicial Procedure, "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s101"},"text":"section 101 of Title 48","children":[],"tail":", Territories and Insular Possessions, and "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s654"},"text":"section 654 of Title 50","children":[],"tail":", War and National Defense, and repealing "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s31a"},"text":"section 31a of this title","children":[],"tail":"] shall take effect "},{"tag":"date","attrib":{"date":"1955-03-01"},"text":"Mar. 1, 1955","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd128d42-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1949 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by act ","children":[{"tag":"date","attrib":{"date":"1949-01-19"},"text":"Jan. 19, 1949","children":[],"tail":", effective at noon, "},{"tag":"date","attrib":{"date":"1949-01-20"},"text":"Jan. 20, 1949","children":[],"tail":", see section 3 of act "},{"tag":"date","attrib":{"date":"1949-01-19"},"text":"Jan. 19, 1949","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd128d43-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-02/ch753/tVI/s601/a"},"text":"Act Aug. 2, 1946, ch. 753, title VI, § 601(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/850"},"text":"60 Stat. 850","children":[],"tail":", provided that the salary rates provided by such section 601(a) are effective "},{"tag":"date","attrib":{"date":"1947-01-03"},"text":"Jan. 3, 1947","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"iddd128d44-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/10/s1"},"text":"Pub. L. 117–10, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-04-23"},"text":"Apr. 23, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/259"},"text":"135 Stat. 259","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/10/s1"},"text":"“This Act [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s4576"},"text":"section 4576 of this title","children":[],"tail":" and enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s4576"},"text":"section 4576 of this title","children":[],"tail":"] may be cited as the ‘Senate Shared Employee Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"iddd128d45-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2013 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/3/s1"},"text":"Pub. L. 113–3, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-02-04"},"text":"Feb. 4, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/51"},"text":"127 Stat. 51","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/3/s1"},"text":"“This Act [see Tables for classification] may be cited as the ‘No Budget, No Pay Act of 2013’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"iddd128d46-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186/s1/a"},"text":"Pub. L. 104–186, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1718"},"text":"110 Stat. 1718","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/186/s1/a"},"text":"“This Act [see Tables for classification] may be cited as the ‘House of Representatives Administrative Reform Technical Corrections Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"iddd128d47-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1964 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/88/426/tII/s201"},"text":"Pub. L. 88–426, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-08-14"},"text":"Aug. 14, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/413"},"text":"78 Stat. 413","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/88/426/tII/s201"},"text":"“This title [see Tables for classification] may be cited as the ‘Federal Legislative Salary Act of 1964’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd128d48-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Holding Salaries of Members of Congress in Escrow Upon Failure To Agree to Budget Resolution","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/3/s3"},"text":"Pub. L. 113–3, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-02-04"},"text":"Feb. 4, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/51"},"text":"127 Stat. 51","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/3/s3"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Holding Salaries in Escrow.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If by ","children":[{"tag":"date","attrib":{"date":"2013-04-15"},"text":"April 15, 2013","children":[],"tail":", a House of Congress has not agreed to a concurrent resolution on the budget for fiscal year 2014 pursuant to section 301 of the Congressional Budget Act of 1974 ["},{"tag":"ref","attrib":{"href":"/us/usc/t2/s632"},"text":"2 U.S.C. 632","children":[],"tail":"], during the period described in paragraph (2) the payroll administrator of that House of Congress shall deposit in an escrow account all payments otherwise required to be made during such period for the compensation of Members of Congress who serve in that House of Congress, and shall release such payments to such Members only upon the expiration of such period."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Period described","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to a House of Congress, the period described in this paragraph is the period which begins on ","children":[{"tag":"date","attrib":{"date":"2013-04-16"},"text":"April 16, 2013","children":[],"tail":", and ends on the earlier of—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the day on which the House of Congress agrees to a concurrent resolution on the budget for fiscal year 2014 pursuant to section 301 of the Congressional Budget Act of 1974 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s632"},"text":"2 U.S.C. 632","children":[],"tail":"]; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the last day of the One Hundred Thirteenth Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Withholding and remittance of amounts from payments held in escrow","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The payroll administrator shall provide for the same withholding and remittance with respect to a payment deposited in an escrow account under paragraph (1) that would apply to the payment if the payment were not subject to paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Release of amounts at end of the congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In order to ensure that this section is carried out in a manner that shall not vary the compensation of Senators or Representatives in violation of the twenty-seventh article of amendment to the Constitution of the United States, the payroll administrator of a House of Congress shall release for payments to Members of that House of Congress any amounts remaining in any escrow account under this section on the last day of the One Hundred Thirteenth Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Role of secretary of the treasury","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Treasury shall provide the payroll administrators of the Houses of Congress with such assistance as may be necessary to enable the payroll administrators to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of Delegates as Members","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term ‘Member’ includes a Delegate or Resident Commissioner to the Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payroll Administrator Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the ‘payroll administrator’ of a House of Congress means—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the House of Representatives, the Chief Administrative Officer of the House of Representatives, or an employee of the Office of the Chief Administrative Officer who is designated by the Chief Administrative Officer to carry out this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the Senate, the Secretary of the Senate, or an employee of the Office of the Secretary of the Senate who is designated by the Secretary to carry out this section.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd128d49-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Cost of Living Adjustment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/37/dC/tII/s210"},"text":"Pub. L. 119–37, div. C, title II, § 210","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-11-12"},"text":"Nov. 12, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/584"},"text":"139 Stat. 584","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/37/dC/tII/s210"},"text":"“Notwithstanding any other provision of law, no adjustment shall be made under section 601(a) of the Legislative Reorganization Act of 1946 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s4501"},"text":"2 U.S.C. 4501","children":[],"tail":") (relating to cost of living adjustments for Members of Congress) during fiscal year 2026.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following prior acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/47/s7"},"text":"Pub. L. 118–47, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-03-23"},"text":"Mar. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/461"},"text":"138 Stat. 461","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s6"},"text":"Pub. L. 117–328, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4462"},"text":"136 Stat. 4462","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s6"},"text":"Pub. L. 117–103, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/52"},"text":"136 Stat. 52","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s7"},"text":"Pub. L. 116–260, § 7","children":[],