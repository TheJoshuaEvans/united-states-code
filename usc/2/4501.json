ildren":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2245"},"text":"129 Stat. 2245","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/s8"},"text":"Pub. L. 113–235, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2133"},"text":"128 Stat. 2133","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/46/dA/s146"},"text":"Pub. L. 113–46, div. A, § 146","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-10-17"},"text":"Oct. 17, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/565"},"text":"127 Stat. 565","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/240/tVIII/s802"},"text":"Pub. L. 112–240, title VIII, § 802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2369"},"text":"126 Stat. 2369","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/165/s1"},"text":"Pub. L. 111–165, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-05-14"},"text":"May 14, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1185"},"text":"124 Stat. 1185","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/8/dJ/s103"},"text":"Pub. L. 111–8, div. J, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-11"},"text":"Mar. 11, 2009","children":[],"tail":", "},{"tag":"ref","