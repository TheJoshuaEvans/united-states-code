dent pro tempore of Senate, Majority Leader of Senate, or Minority Leader of Senate during a calendar year, the annual rate of pay paid to such Member for such service would not be less than the annual rate of pay payable for such position on "},{"tag":"date","attrib":{"date":"1982-12-17"},"text":"Dec. 17, 1982","children":[],"tail":", increased by 15 percent and rounded in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5318"},"text":"section 5318 of Title 5","children":[],"tail":", was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/102/90/tI/s6/c"},"text":"Pub. L. 102–90, title I, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-14"},"text":"Aug. 14, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/451"},"text":"105 Stat. 451","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd128d4b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Salary Increases","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For prior year salary increases per the recommendation of the President, see Prior Salary Recommendations notes under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s358"},"text":"section 358 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"For miscellaneous provisions dealing with adjustments of pay and limitations on use of funds to pay salaries in prior years, see notes under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5318"},"text":"section 5318 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"iddd128d4c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"