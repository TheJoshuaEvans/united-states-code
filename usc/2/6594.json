{"tag":"section","attrib":{"id":"iddd3d957a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6594"},"text":null,"children":[{"tag":"num","attrib":{"value":"6594"},"text":"§ 6594.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation of Deputy Sergeant at Arms and Doorkeeper of Senate","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Effective ","children":[{"tag":"date","attrib":{"date":"1979-08-01"},"text":"August 1, 1979","children":[],"tail":", the Sergeant at Arms and Doorkeeper may fix the compensation of the Deputy Sergeant at Arms and Doorkeeper at an annual rate not to exceed the maximum annual rate of compensation of the Assistant Secretary of the Senate."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd3d957b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/226/s1/a"},"text":"Pub. L. 94–226, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-03-09"},"text":"Mar. 9, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/203"},"text":"90 Stat. 203","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/38/tI/s106/1"},"text":"Pub. L. 96–38, title I, § 106(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-25"},"text":"July 25, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/112"},"text":"93 Stat. 112","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd3d957c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd3d957d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd3d957e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s61e–1"},"text":"section 61e–1 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd3d957f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1979—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/38"},"text":"Pub. L. 96–38","children":[],"tail":" raised the maximum annual rate of compensation of Deputy Sergeant at Arms and Doorkeeper of Senate to a rate the same as the maximum annual rate of compensation of Assistant Secretary of Senate."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd3d9580-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"iddd3d9581-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/226/s1/c"},"text":"Pub. L. 94–226, § 1(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-03-09"},"text":"Mar. 9, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/203"},"text":"90 Stat. 203","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/94/226/s1/c"},"text":"“Effective on the date of enactment of this resolution [","children":[{"tag":"date","attrib":{"date":"1976-03-09"},"text":"Mar. 9, 1976","children":[],"tail":"] the title of the Procurement Officer, Auditor, and Deputy Sergeant at Arms is changed to Deputy Sergeant at Arms and Doorkeeper.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd3d9582-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/226/s1/b"},"text":"Pub. L. 94–226, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-03-09"},"text":"Mar. 9, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/203"},"text":"90 Stat. 203","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/94/226/s1/b"},"text":"“Subsection (a) [enacting this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1976-01-01"},"text":"January 1, 1976","children":[],"tail":", and, notwithstanding any other provision of law, any increase in compensation made under authority of such subsection may take effect on that date or any date thereafter as prescribed by the Sergeant at Arms and Doorkeeper at the time of making such increase.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd3d9583-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Authority of President Pro Tempore of the Senate To Raise or Adjust Rate of Compensation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/226/s1/a"},"text":"Pub. L. 94–226, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-03-09"},"text":"Mar. 9, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/203"},"text":"90 Stat. 203","children":[],"tail":", provided in part that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/94/226/s1/a"},"text":"“This subsection [this section] does not supersede (1) any provision of an order of the President pro tempore of the Senate authorizing a higher rate of compensation, and (2) any authority of the President pro tempore to adjust the rate of compensation referred to in this subsection [this section] under section 4 of the Federal Pay Comparability Act of 1970 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s4571"},"text":"section 4571 of this title","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
