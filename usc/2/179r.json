{"tag":"section","attrib":{"id":"iddc8f7aed-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s179r"},"text":null,"children":[{"tag":"num","attrib":{"value":"179r"},"text":"§ 179r.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remedies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc8f7aee-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s179r/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The several district courts of the United States shall have jurisdiction, for cause shown, to prevent and restrain violations of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s179q/a"},"text":"section 179q(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc8f7aef-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s179r/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relief","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc8f7af0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s179r/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal of seal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), relief for violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s179q/a"},"text":"section 179q(a) of this title","children":[],"tail":" shall be limited to the removal of the seal of the National Film Registry from the film involved in the violation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc8f7af1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s179r/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fine and injunctive relief","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a pattern or practice of the willful violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s179q/a"},"text":"section 179q(a) of this title","children":[],"tail":", the United States district courts may order a civil fine of not more than $10,000 and appropriate injunctive relief."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc8f7af2-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/285/tI/s108"},"text":"Pub. L. 104–285, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3381"},"text":"110 Stat. 3381","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
