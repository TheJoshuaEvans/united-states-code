ag":"date","attrib":{"date":"2011-08-02"},"text":"Aug. 2, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/247"},"text":"125 Stat. 247","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddca9b92e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddca9b92f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddca9b930-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, means ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/344"},"text":"Pub. L. 93–344","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-07-12"},"text":"July 12, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/297"},"text":"88 Stat. 297","children":[],"tail":", known as the Congressional Budget and Impoundment Control Act of 1974, which enacted chapters 17, 17A and 17B, and "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s190a–3"},"text":"section 190a–3 of this title","children":[],"tail":" and sections 11a, 11c, 11d, 1020a of former Title 31, Money and Finance, amended sections 11, 665, 701, 1020, 1151, 1152, 1153, and 1154 of former Title 31, "},{"tag":"ref","attrib":{"href":"/us/usc/t1/s105"},"text":"section 105 of Title 1","children":[],"tail":", General Provisions, sections 190b and 190d of this title, repealed sections 571 and 581c–1 of former Title 31, and sections 66 and 81 of this title, and enacted provisions set out as notes under sections 190a–1, 621, 632, and 682 of this title, "},{"tag":"ref","attrib":{"href":"/us/usc/t1/s105"},"text":"section