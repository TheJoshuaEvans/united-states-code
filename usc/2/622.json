{"tag":"section","attrib":{"id":"iddca9b909-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s622"},"text":null,"children":[{"tag":"num","attrib":{"value":"622"},"text":"§ 622.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this Act—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddca9b90a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s622/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms “budget outlays” and “outlays” mean, with respect to any fiscal year, expenditures and net lending of funds under budget authority during such year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca9b90b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s622/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Budget authority and new budget authority.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddca9b90c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s622/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “budget authority” means the authority provided by Federal law to incur financial obligations, as follows:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddca9b90d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s622/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provisions of law that make funds available for obligation and expenditure (other than borrowing authority), including the authority to obligate and expend the proceeds of offsetting receipts and collections;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddca9b90e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s622/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" borrowing authority, which means authority granted to a Federal entity to borrow and obligate and expend the borrowed funds, including through the issuance of promissory notes or other monetary credits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddca9b90f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s622/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contract authority, which means the making of funds available for obligation but not for expenditure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddca9b910-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s622/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offsetting receipts and collections as negative budget authority, and the reduction thereof as positive budget authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddca9b911-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s622/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations on budget authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"With respect to the Federal Hospital Insurance Trust Fund, the Supplementary Medical Insurance Trust Fund, the Unemployment Trust Fund, and the railroad retirement account, any amount that is precluded from obligation in a fiscal year by a provision of law (such as a limitation or a benefit formula) shall not be budget authority in that year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddca9b912-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s622/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"New budget authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “new budget authority” means, with respect to a fiscal year—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddca9b913-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s622/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" budget authority that first becomes available for obligation in that year, including budget authority that becomes available in that year s ","children":[{"tag":"ref","attrib":{"idref":"fn002024"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002024"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “as”."}],"tail":" a result of a reappropriation; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddca9b914-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s622/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a change in any account in the availability of unobligated balances of budget authority carried over from a prior year, resulting from a provision of law first effective in that year;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"and includes a change in the estimated level of new budget authority provided in indefinite amounts by existing law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca9b915-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s622/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “tax expenditures” means those revenue losses attributable to provisions of the Federal tax laws which allow a special exclusion, exemption, or deduction from gross income or which provide a special credit, a preferential rate of tax, or a deferral of tax liability; and the term “tax expenditures budget” means an enumeration of such tax expenditures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca9b916-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s622/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “concurrent resolution on the budget” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddca9b917-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s622/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a concurrent resolution setting forth the congressional budget for the United States Government for a fiscal year as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s632"},"text":"section 632 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddca9b918-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s622/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other concurrent resolution revising the congressional budget for the United States Government for a fiscal year as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s635"},"text":"section 635 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca9b919-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s622/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “appropriation Act” means an Act referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t1/s105"},"text":"section 105 of title 1","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca9b91a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s622/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “deficit” means, with respect to a fiscal year, the amount by which outlays exceeds ","children":[{"tag":"ref","attrib":{"idref":"fn002025"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002025"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “exceed”."}],"tail":" receipts during that year."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca9b91b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s622/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “surplus” means, with respect to a fiscal year, the amount by which receipts exceeds ","children":[{"tag":"sup","attrib":{},"text":"2","children":[],"tail":" outlays during that year."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca9b91c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s622/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “government-sponsored enterprise” means a corporate entity created by a law of the United States that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddca9b91d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s622/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddca9b91e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s622/8/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a Federal charter authorized by law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddca9b91f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s622/8/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is privately owned, as evidenced by capital stock owned by private entities or individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddca9b920-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s622/8/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is under the direction of a board of directors, a majority of which is elected by private owners;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddca9b921-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s622/8/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is a financial institution with power to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddca9b922-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s622/8/A/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make loans or loan guarantees for limited purposes such as to provide credit for specific borrowers or one sector; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddca9b923-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s622/8/A/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" raise funds by borrowing (which does not carry the full faith and credit of the Federal Government) or to guarantee the debt of others in unlimited amounts; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddca9b924-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s622/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddca9b925-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s622/8/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not exercise powers that are reserved to the Government as sovereign (such as the power to tax or to regulate interstate commerce);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddca9b926-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s622/8/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not have the power to commit the Government financially (but it may be a recipient of a loan guarantee commitment made by the Government); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddca9b927-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s622/8/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has employees whose salaries and expenses are paid by the enterprise and are not Federal employees subject to title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca9b928-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s622/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “entitlement authority” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddca9b929-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s622/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the authority to make payments (including loans and grants), the budget authority for which is not provided for in advance by appropriation Acts, to any person or government if, under the provisions of the law containing that authority, the United States is obligated to make such payments to persons or governments who meet the requirements established by that law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddca9b92a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s622/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the food stamp program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca9b92b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s622/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “credit authority” means authority to incur direct loan obligations or to incur primary loan guarantee commitments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca9b92c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s622/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms “emergency” and “unanticipated” have the meanings given to such terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s900/c"},"text":"section 900(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddca9b92d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/344/s3"},"text":"Pub. L. 93–344, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-07-12"},"text":"July 12, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/299"},"text":"88 Stat. 299","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1946-08-01/ch724"},"text":"Aug. 1, 1946, ch. 724","children":[],"tail":", title I, § 302(c), as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/110/s1"},"text":"Pub. L. 95–110, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-09-20"},"text":"Sept. 20, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/884"},"text":"91 Stat. 884","children":[],"tail":", renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/tIX/s902/a/8"},"text":"Pub. L. 102–486, title IX, § 902(a)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2944"},"text":"106 Stat. 2944","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/177/tII"},"text":"Pub. L. 99–177, title II","children":[],"tail":", §§ 201(a), 232(b), "},{"