{"tag":"section","attrib":{"id":"iddd3d9538-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6575"},"text":null,"children":[{"tag":"num","attrib":{"value":"6575"},"text":"§ 6575.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees for copies from Senate journals","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Senate is entitled, for transcribing and certifying extracts from the journal of the Senate or the executive Journal of the Senate when the injunction of secrecy has been removed, except when such transcripts are required by an officer of the United States in a matter relating to the duties of his office, to receive from the persons for whom such transcripts are prepared the sum of 10 cents for each sheet containing one hundred words.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd3d9539-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(R.S. § 71; ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186/tII/s204/61"},"text":"Pub. L. 104–186, title II, § 204(61)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1738"},"text":"110 Stat. 1738","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd3d953a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd3d953b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd3d953c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s114"},"text":"section 114 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 71 derived from acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1789-09-15/ch14/s6"},"text":"Sept. 15, 1789, ch. 14, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/1/69"},"text":"1 Stat. 69","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1846-08-08/ch107/s2"},"text":"Aug. 8, 1846, ch. 107, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/9/80"},"text":"9 Stat. 80","children":[],"tail":"; and "},{"tag":"ref","attrib":{"href":"/us/act/1856-04-23/ch20"},"text":"Apr. 23, 1856, ch. 20","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/11/5"},"text":"11 Stat. 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd3d953d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186"},"text":"Pub. L. 104–186","children":[],"tail":" substituted “Secretary of the Senate is” for “Secretary of the Senate and the Clerk of the House of Representatives, respectively, are” and struck out “or from the journal of the House of Representatives,” after “has been removed,”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
