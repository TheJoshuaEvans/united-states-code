{"tag":"section","attrib":{"id":"iddce08175-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1555"},"text":null,"children":[{"tag":"num","attrib":{"value":"1555"},"text":"§ 1555.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Federal mandate” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1502"},"text":"section 1502 of this title","children":[],"tail":", for purposes of this subchapter the term “Federal mandate” means any provision in statute or regulation or any Federal court ruling that imposes an enforceable duty upon State, local, or tribal governments including a condition of Federal assistance or a duty arising from participation in a voluntary Federal program."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddce08176-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/4/tIII/s305"},"text":"Pub. L. 104–4, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-03-22"},"text":"Mar. 22, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/70"},"text":"109 Stat. 70","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
