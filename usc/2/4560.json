{"tag":"section","attrib":{"id":"iddd176ff9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4560"},"text":null,"children":[{"tag":"num","attrib":{"value":"4560"},"text":"§ 4560.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deductions by Chief Administrative Officer in disbursement of gratuity appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Chief Administrative Officer of the House of Representatives is authorized, in the disbursement of gratuity appropriations, to make deductions of such amounts as may be due to or through his office or as may be due the House of Representatives.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd176ffa-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1928-05-29/ch853/s1"},"text":"May 29, 1928, ch. 853, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/885"},"text":"45 Stat. 885","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/186/tII/s204/26"},"text":"Pub. L. 104–186, title II, § 204(26)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1734"},"text":"110 Stat. 1734","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd176ffb-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd176ffc-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd176ffd-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s80a"},"text":"section 80a of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd176ffe-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186"},"text":"Pub. L. 104–186","children":[],"tail":" substituted “Chief Administrative Officer of the House of Representatives” for “Sergeant-at-Arms of the House”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
