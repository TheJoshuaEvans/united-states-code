{"tag":"section","attrib":{"id":"iddcff7a21-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2064"},"text":null,"children":[{"tag":"num","attrib":{"value":"2064"},"text":"§ 2064.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Senate Employee Child Care Center employee benefits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcff7a22-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2064/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election for coverage","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The provisions of this section shall apply to any individual who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcff7a23-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2064/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcff7a24-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2064/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on ","children":[{"tag":"date","attrib":{"date":"1992-10-06"},"text":"October 6, 1992","children":[],"tail":", is employed by the Senate day care center (known as the “Senate Employee Child Care Center”) established pursuant to Senate Resolution 269, Ninety-eighth Congress, and "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s2061"},"text":"section 2061 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcff7a25-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2064/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes an election to be covered by this section with the Secretary of the Senate, no later than 60 days after ","children":[{"tag":"date","attrib":{"date":"1992-10-06"},"text":"October 6, 1992","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcff7a26-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2064/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is hired by the Center after ","children":[{"tag":"date","attrib":{"date":"1992-10-06"},"text":"October 6, 1992","children":[],"tail":", and makes an election to be covered by this section with the Secretary of the Senate, no later than 60 days after the date such individual begins employment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcff7a27-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2064/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of deposit; payroll deduction","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcff7a28-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2064/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any individual described under subsection (a) may be credited,","children":[{"tag":"ref","attrib":{"idref":"fn002079"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002079"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The comma probably should not appear."}],"tail":" under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8411"},"text":"section 8411 of title 5","children":[],"tail":" for service as an employee of the Senate day care center before "},{"tag":"date","attrib":{"date":"1993-01-01"},"text":"January 1, 1993","children":[],"tail":", if such employee makes a payment of the deposit under section 8411(f)(2) of such title without application of the provisions of section 8411(b)(3) of such title."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcff7a29-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2064/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual described under subsection (a) shall be credited under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8411"},"text":"section 8411 of title 5","children":[],"tail":" for any service as an employee of the Senate day care center on or after "},{"tag":"date","attrib":{"date":"1992-10-06"},"text":"October 6, 1992","children":[],"tail":", if such employee has such amounts deducted and withheld from his pay as determined by the Office of Personnel Management (in accordance with regulations prescribed by such Office subject to subsection (h) of this section) which would be deducted and withheld from the basic pay of an employee under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8422"},"text":"section 8422 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcff7a2a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2064/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Survivor annuities and disability benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this section, any service performed by an individual described under subsection (a) as an employee of the Senate day care center is deemed to be civilian service creditable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8411"},"text":"section 8411 of title 5","children":[],"tail":" for purposes of qualifying for survivor annuities and disability benefits under subchapters IV and V of chapter 84 of such title, if such individual makes payment of an amount, determined by the Office of Personnel Management, which would have been deducted and withheld from the basic pay of such individual if such individual had been an employee subject to "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8422"},"text":"section 8422 of title 5","children":[],"tail":" for such period so credited, together with interest thereon."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcff7a2b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2064/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation in Thrift Savings Plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual described under subsection (a) shall be deemed a congressional employee for purposes of chapter 84 of title 5 including subchapter III thereof and may make contributions under section 8432 of such title effective for the first applicable pay period beginning on or after ","children":[{"tag":"date","attrib":{"date":"1992-10-06"},"text":"October 6, 1992","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcff7a2c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2064/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Life insurance coverage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual described under subsection (a) shall be deemed an employee under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8701/a/3"},"text":"section 8701(a)(3) of title 5","children":[],"tail":" for purposes of life insurance coverage under chapter 87 of such title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcff7a2d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2064/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Government contributions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Government contributions for individuals receiving benefits under this section, as computed under sections 8423, 8432, and 8708,","children":[{"tag":"ref","attrib":{"idref":"fn002080"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002080"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. The words “of title 5” probably should precede the comma."}],"tail":" shall be made by the Secretary of the Senate from the appropriations account, within the contingent fund of the Senate, “Miscellaneous Items”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcff7a2e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2064/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification of creditable service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office of Personnel Management shall accept the certification of the Secretary of the Senate concerning creditable service for the purpose of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcff7a2f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2064/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment to center of amounts equal to Federal tax on employers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcff7a30-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2064/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to the provisions of paragraph (2), the Secretary of the Senate shall pay such amounts to the Senate day care center equal to the tax on employers under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s3111"},"text":"section 3111 of title 26","children":[],"tail":" with respect to each employee of the Senate day care center. Such payments shall be made from the appropriations account, within the contingent fund of the Senate, “Miscellaneous Items”."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcff7a31-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2064/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Senate day care center shall provide appropriate documentation to the Secretary of the Senate of payment by such center of the tax described under paragraph (1), before the Secretary of the Senate may pay any amount to such center as provided under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcff7a32-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2064/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative provisions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Center shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcff7a33-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2064/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with the Secretary of the Senate on the administration of this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcff7a34-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2064/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain records on all employees covered under this section in such manner as the Secretary of the Senate may require for administrative purposes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcff7a35-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2064/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make deductions and withholdings from the pay of employees in the amounts determined under sections 8422, 8432, and 8707 of title 5; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcff7a36-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2064/i/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transmit such deductions and withholdings to the Secretary of the Senate for deposit and remittance to the Office of Personnel Management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcff7a37-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2064/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office of Personnel Management may prescribe regulations to carry out the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"