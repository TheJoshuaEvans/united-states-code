{"tag":"section","attrib":{"id":"iddd0b8887-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2273"},"text":null,"children":[{"tag":"num","attrib":{"value":"2273"},"text":"§ 2273.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coins treated as gifts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd0b8888-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2273/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “covered grounds” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd0b8889-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2273/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the grounds described under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s5102"},"text":"section 5102 of title 40","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd0b888a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2273/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Capitol Buildings defined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s5101"},"text":"section 5101 of title 40","children":[],"tail":", including the Capitol Visitor Center; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd0b888b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2273/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Library of Congress buildings and grounds described under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s167j"},"text":"section 167j of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd0b888c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2273/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of coins","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any coins in any fountains on covered grounds—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd0b888d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2273/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such coins shall be treated as gifts to the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd0b888e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2273/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Architect of the Capitol shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd0b888f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2273/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect such coins at such times and in such manner as the Architect determines appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd0b8890-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2273/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided under subsection (c), deposit the collected coins in accordance with subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd0b8891-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2273/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost reimbursement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amount collected under this section shall first be used to reimburse the Architect of the Capitol for any costs incurred in the collection and processing of the coins, and maintaining fountains under the jurisdiction of the Architect of the Capitol. The amount of any such reimbursement is appropriated to the account from which such costs were paid and may be used for any authorized purpose of that account.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd0b8892-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2273/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit of coins","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Architect of the Capitol shall deposit coins collected under this section in the Miscellaneous Receipts Account of the Capitol Visitor Center Revolving Fund established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s2231"},"text":"section 2231 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd0b8893-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2273/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized use and availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts deposited in the Miscellaneous Receipts Account of the Capitol Visitor Center Revolving Fund under this section shall be available as provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s2233/b"},"text":"section 2233(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd0b8894-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/437/tV/s504"},"text":"Pub. L. 110–437, title V, § 504","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-20"},"text":"Oct. 20, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4998"},"text":"122 Stat. 4998","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dI/tI/s131"},"text":"Pub. L. 117–103, div. I, title I, § 131","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/516"},"text":"136 Stat. 516","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd0b8895-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd0b8896-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd0b8897-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103"},"text":"Pub. L. 117–103","children":[],"tail":" inserted “, and maintaining fountains under the jurisdiction of the Architect of the Capitol” before period at end of first sentence."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
