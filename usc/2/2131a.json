{"tag":"section","attrib":{"id":"iddd045c26-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2131a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2131a"},"text":"§ 2131a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility for placement of statues in National Statuary Hall","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd045c27-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2131a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No statue of any individual may be placed in National Statuary Hall until after the expiration of the 10-year period which begins on the date of the individual’s death.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd045c28-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2131a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) does not apply with respect to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd045c29-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2131a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the statue obtained and placed in National Statuary Hall under this Act; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd045c2a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2131a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any statue provided and furnished by a State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s2131"},"text":"section 2131 of this title","children":[],"tail":" or any replacement statue provided by a State under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s2132"},"text":"section 2132 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd045c2b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/116/s2"},"text":"Pub. L. 109–116, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-12-01"},"text":"Dec. 1, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2524"},"text":"119 Stat. 2524","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd045c2c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd045c2d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd045c2e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (b)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/116"},"text":"Pub. L. 109–116","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-12-01"},"text":"Dec. 1, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2524"},"text":"119 Stat. 2524","children":[],"tail":", which enacted this section and provisions set out as a note under this section. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd045c2f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd045c30-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Placement of Statue of Rosa Parks in National Statuary Hall","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/116/s1"},"text":"Pub. L. 109–116, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-12-01"},"text":"Dec. 1, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2524"},"text":"119 Stat. 2524","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/110/120/s1/a"},"text":"Pub. L. 110–120, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-11-19"},"text":"Nov. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1348"},"text":"121 Stat. 1348","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/120/s1/a"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Obtaining Statue","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 4 years after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2005-12-01"},"text":"Dec. 1, 2005","children":[],"tail":"], the Joint Committee on the Library shall enter into an agreement to obtain a statue of Rosa Parks, under such terms and conditions as the Joint Committee considers appropriate consistent with applicable law. The Joint Committee may authorize the Architect of the Capitol to enter into the agreement and related contracts required under this subsection on its behalf, under such terms and conditions as the Joint Committee may require."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Placement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Joint Committee shall place the statue obtained under subsection (a) in the United States Capitol in a suitable permanent location in National Statuary Hall.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/120/s1/b"},"text":"Pub. L. 110–120, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-11-19"},"text":"Nov. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1348"},"text":"121 Stat. 1348","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/120/s1/b"},"text":"“The amendments made by subsection (a) [amending ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/116/s1"},"text":"section 1 of Pub. L. 109–116","children":[],"tail":", set out above] shall take effect as if included in the enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/109/116"},"text":"Public Law 109–116","children":[],"tail":".”"}],"tail":"\n]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
