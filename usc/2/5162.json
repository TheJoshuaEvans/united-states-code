{"tag":"section","attrib":{"id":"iddd28119f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5162"},"text":null,"children":[{"tag":"num","attrib":{"value":"5162"},"text":"§ 5162.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Republican Policy Committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd2811a0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5162/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the House of Representatives an office to be known as the Republican Policy Committee, which shall have such responsibilities as may be assigned by the Speaker of the House of Representatives (or, if the Speaker is not a member of the Republican Party, the Minority Leader of the House of Representatives).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2a81a1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5162/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Salaries and expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be a lump sum allowance for the salaries and expenses of the Republican Policy Committee, which shall be treated as a category of House leadership offices for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s5507/c"},"text":"section 5507(c) of this title","children":[],"tail":", and which shall be obligated and expended as directed by the Speaker (or, if the Speaker is not a member of the Republican party, the Minority Leader)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2a81a2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5162/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply with respect to fiscal year 2005 and each succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd2a81a3-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447/dG/tI/s109"},"text":"Pub. L. 108–447, div. G, title I, § 109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3177"},"text":"118 Stat. 3177","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/74/dG/tI/s102/a"},"text":"Pub. L. 112–74, div. G, title I, § 102(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2011-12-23"},"text":"Dec. 23, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1121"},"text":"125 Stat. 1121","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd2a81a4-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd2a81a5-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd2a81a6-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s74a–13"},"text":"section 74a–13 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Legislative Branch Appropriations Act, 2005, which is div. G of the Consolidated Appropriations Act, 2005.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd2a81a7-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/74/s102/a"},"text":"Pub. L. 112–74, § 102(a)","children":[],"tail":", substituted “the Speaker of the House of Representatives (or, if the Speaker is not a member of the Republican Party, the Minority Leader of the House of Representatives)” for “the chair of the Republican Conference”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/74/s102/b"},"text":"Pub. L. 112–74, § 102(b)","children":[],"tail":", inserted “, and which shall be obligated and expended as directed by the Speaker (or, if the Speaker is not a member of the Republican party, the Minority Leader)” before period at end."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd2a81a8-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd2a81a9-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2011 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/74/dG/tI/s102/c"},"text":"Pub. L. 112–74, div. G, title I, § 102(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-23"},"text":"Dec. 23, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1121"},"text":"125 Stat. 1121","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/74/dG/tI/s102/c"},"text":"“The amendment made by subsection (a) [amending this section] shall apply with respect to fiscal year 2012 and each succeeding fiscal year.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
