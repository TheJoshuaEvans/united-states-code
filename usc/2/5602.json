{"tag":"section","attrib":{"id":"iddd31ad8c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5602"},"text":null,"children":[{"tag":"num","attrib":{"value":"5602"},"text":"§ 5602.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tenure of office of Sergeant at Arms","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any person duly elected and qualified as Sergeant at Arms of the House of Representatives shall continue in said office until his successor is chosen and qualified, subject however, to removal by the House of Representatives.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd31ad8d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1890-10-01/ch1256/s6"},"text":"Oct. 1, 1890, ch. 1256, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/26/646"},"text":"26 Stat. 646","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd31ad8e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd31ad8f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd31ad90-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s83"},"text":"section 83 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
