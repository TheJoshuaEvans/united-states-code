{"tag":"section","attrib":{"id":"iddce7ad8b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1824"},"text":null,"children":[{"tag":"num","attrib":{"value":"1824"},"text":"§ 1824.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy and environmental measures in Capitol Complex Master Plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddce7ad8c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1824/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the maximum extent practicable, the Architect of the Capitol shall include energy efficiency and conservation measures, greenhouse gas emission reduction measures, and other appropriate environmental measures in the Capitol Complex Master Plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce7ad8d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1824/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 6 months after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"December 19, 2007","children":[],"tail":", the Architect of the Capitol shall submit to the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Rules and Administration of the Senate, a report on the energy efficiency and conservation measures, greenhouse gas emission reduction measures, and other appropriate environmental measures included in the Capitol Complex Master Plan pursuant to subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddce7ad8e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tV/s503"},"text":"Pub. L. 110–140, title V, § 503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1655"},"text":"121 Stat. 1655","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddce7ad8f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddce7ad90-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddce7ad91-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tXVI/s1601"},"text":"Pub. L. 110–140, title XVI, § 1601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1801"},"text":"121 Stat. 1801","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/140/tXVI/s1601"},"text":"“This Act [see Tables for classification] and the amendments made by this Act take effect on the date that is 1 day after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
