{"tag":"section","attrib":{"id":"iddc9dd2ec-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s363"},"text":null,"children":[{"tag":"num","attrib":{"value":"363"},"text":"§ 363.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional function","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Commission shall, whenever it conducts a review under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s356"},"text":"section 356 of this title","children":[],"tail":", also conduct a review under this section relating to any recruitment or retention problems, and any public policy issues involved in maintaining appropriate ethical standards, with respect to any offices or positions within the Federal public service. Any findings or recommendations under this section shall be included by the Commission as part of its report to the President under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s357"},"text":"section 357 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc9dd2ed-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/206/tII/s225/m"},"text":"Pub. L. 90–206, title II, § 225(m)","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/194/tVII/s701/j"},"text":"Pub. L. 101–194, title VII, § 701(j)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-30"},"text":"Nov. 30, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1767"},"text":"103 Stat. 1767","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
