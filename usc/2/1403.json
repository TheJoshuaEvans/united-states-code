{"tag":"section","attrib":{"id":"iddcd9552f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1403"},"text":null,"children":[{"tag":"num","attrib":{"value":"1403"},"text":"§ 1403.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mediation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcd95530-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1403/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of mediation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcd95531-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1403/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification regarding mediation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcd95532-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1403/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered employee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon receipt of a claim under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1402"},"text":"section 1402 of this title","children":[],"tail":", the Office shall notify the covered employee who filed the claim about the process for mediation under this section and the deadlines applicable to such mediation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcd95533-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1403/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employing office","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon transmission to the employing office of the claim pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1402/b"},"text":"section 1402(b) of this title","children":[],"tail":", the Office shall notify the employing office about the process for mediation under this section and the deadlines applicable to such mediation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd95534-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1403/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initiation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcd95535-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1403/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"During the period described in subparagraph (B), either the covered employee who filed a claim under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1402"},"text":"section 1402 of this title","children":[],"tail":" or the employing office named in the claim may file a request for mediation with the Office, which shall promptly notify the other party. If the other party agrees to the request, the Office shall promptly assign a mediator to the claim, and conduct mediation under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcd95536-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1403/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A covered employee or an employing office may file a request for mediation under subparagraph (A) during the period beginning on the date that the covered employee or employing office, respectively, receives a notification under paragraph (1) regarding a claim under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1402"},"text":"section 1402 of this title","children":[],"tail":" and ending on the date on which a hearing officer issues a written decision relating to the claim under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1405/g"},"text":"section 1405(g) of this title","children":[],"tail":" or the covered employee files a civil action with respect to the claim in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1408"},"text":"section 1408 of this title","children":[],"tail":", as applicable."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd95537-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1403/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to request or accept mediation to have no effect on treatment of claim","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The failure of a party to request mediation under this section with respect to a claim, or the failure of a party to agree to a request for mediation under this section, may not be taken into consideration under any procedure under this title with respect to the claim, including a preliminary review under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1402a"},"text":"section 1402a of this title","children":[],"tail":", a formal hearing under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1405"},"text":"section 1405 of this title","children":[],"tail":", or a civil action under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1408"},"text":"section 1408 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd95538-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1403/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Process","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Mediation under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcd95539-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1403/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may include the Office, the covered employee, the employing office, and one or more individuals appointed by the Executive Director from the master list developed and maintained under subsection (e), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd9553a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1403/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall involve meetings with the parties during which, at the request of any of the parties, the parties shall be separated, for the purpose of resolving the dispute between the covered employee and the employing office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd9553b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1403/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mediation period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The mediation period shall be 30 days, beginning on the first day after the second party agrees to the request for the mediation. The mediation period may be extended for one additional period of 30 days at the joint request of the covered employee and employing office. Any deadline in this chapter relating to a claim for which mediation has been agreed to in this section, that has not already passed by the first day of the mediation period, shall be stayed during the mediation period. The Office shall notify in writing the covered employee and the employing office when the mediation period has ended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd9553c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1403/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Independence of mediation process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No individual, who is appointed by the Executive Director to mediate, may conduct or aid in a hearing conducted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1405"},"text":"section 1405 of this title","children":[],"tail":" with respect to the same matter or shall be subject to subpoena or any other compulsory process with respect to the same matter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd9553d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1403/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Master list of mediators","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcd9553e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1403/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development and maintenance of master list","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Executive Director shall develop and maintain a master list of individuals who are experienced in adjudicating, arbitrating, or mediating the kinds of personnel and other matters for which mediation may be held under this section. Such list may include, but not be limited to, members of the bar of a State or the District of Columbia and retired judges of the United States courts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd9553f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1403/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration of candidates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In developing the master list under this subsection, the Executive Director shall consider candidates recommended by the Federal Mediation and Conciliation Service or the Administrative Conference of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcd95540-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/1/tIV/s404"},"text":"Pub. L. 104–1, title IV, § 404","children":[],"tail":", formerly § 403, "},{"tag":"date","attrib":{"date":"1995-01-23"},"text":"Jan. 23, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/32"},"text":"109 Stat. 32","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/6/s2/a"},"text":"Pub. L. 114–6, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-03-20"},"text":"Mar. 20, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/81"},"text":"129 Stat. 81","children":[],"tail":"; renumbered § 404 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/397/tI"},"text":"Pub. L. 115–397, title I","children":[],"tail":", §§ 101(c)(2), 104, "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5301"},"text":"132 Stat. 5301","children":[],"tail":", 5305.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcd95541-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcd95542-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddcd95543-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (c), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/1"},"text":"Pub. L. 104–1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-01-23"},"text":"Jan. 23, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/3"},"text":"109 Stat. 3","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1301"},"text":"section 1301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"iddcd95544-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/1/s404"},"text":"section 404 of Pub. L. 104–1","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1404"},"text":"section 1404 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/115/397/tI/s101/c/1"},"text":"Pub. L. 115–397, title I, § 101(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5301"},"text":"132 Stat. 5301","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcd95545-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/397/s104/a"},"text":"Pub. L. 115–397, § 104(a)","children":[],"tail":", amended subsec. (a) generally. Prior to amendment, text read as follows: “Not later than 15 days after receipt by the employee of notice of the end of the counseling period under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1402"},"text":"section 1402 of this title","children":[],"tail":", but prior to and as a condition of making an election under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1404"},"text":"section 1404 of this title","children":[],"tail":", the covered employee who alleged a violation of a law shall file a request for mediation with the Office.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/397/s104/b"},"text":"Pub. L. 115–397, § 104(b)","children":[],"tail":", substituted “meetings with the parties during which, at the request of any of the parties, the parties shall be separated,” for “meetings with the parties separately or jointly”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/397/s104/c"},"text":"Pub. L. 115–397, § 104(c)","children":[],"tail":", substituted “The mediation period shall be 30 days, beginning on the first day after the second party agrees to the request for the mediation. The mediation period may be extended for one additional period of 30 days at the joint request of the covered employee and employing office. Any deadline in this chapter relating to a claim for which mediation has been agreed to in this section, that has not already passed by the first day of the mediation period, shall be stayed during the mediation period.” for “The mediation period shall be 30 days beginning on the date the request for mediation is received. The mediation period may be extended for additional periods at the joint request of the covered employee and the employing office.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/6/s2/a/1"},"text":"Pub. L. 114–6, § 2(a)(1)","children":[],"tail":", substituted “from the master list developed and maintained under subsection (e)” for “after considering recommendations by organizations composed primarily of individuals experienced in adjudicating or arbitrating personnel matters”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/6/s2/a/2"},"text":"Pub. L. 114–6, § 2(a)(2)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcd95546-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcd95547-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/397"},"text":"Pub. L. 115–397","children":[],"tail":" effective upon expiration of the 180-day period beginning on "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", with provisions for effect on pending proceedings, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/397/s401"},"text":"section 401 of Pub. L. 115–397","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcd95548-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/6/s2/d"},"text":"Pub. L. 114–6, § 2(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-03-20"},"text":"Mar. 20, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/82"},"text":"129 Stat. 82","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/6/s2/d"},"text":"“The amendments made by this section [amending this section and sections 1404 and 1416 of this title] shall apply with respect to mediations and other proceedings which are first initiated after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2015-03-20"},"text":"Mar. 20, 2015","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
