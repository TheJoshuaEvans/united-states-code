{"tag":"section","attrib":{"id":"iddd09180c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2215"},"text":null,"children":[{"tag":"num","attrib":{"value":"2215"},"text":"§ 2215.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gift Shop","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd09180d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2215/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Architect of the Capitol, acting through the Chief Executive Officer, shall establish a Capitol Visitor Center Gift Shop within the Capitol Visitor Center for the purpose of providing for the sale of gift items. All moneys received from sales and other services by the Capitol Visitor Center Gift Shop shall be deposited in the Capitol Visitor Center Revolving Fund established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s2231"},"text":"section 2231 of this title","children":[],"tail":" and shall be available for purposes of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd09180e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2215/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception to prohibition of sale or solicitation on Capitol grounds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s5104/c"},"text":"Section 5104(c) of title 40","children":[],"tail":" shall not apply to any activity carried out under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd09180f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/437/tII/s205"},"text":"Pub. L. 110–437, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-20"},"text":"Oct. 20, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4988"},"text":"122 Stat. 4988","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
