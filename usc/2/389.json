{"tag":"section","attrib":{"id":"iddca01c4f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s389"},"text":null,"children":[{"tag":"num","attrib":{"value":"389"},"text":"§ 389.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Officer and witness fees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddca01c50-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s389/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each judge, clerk of court, or other officer who issues any subpena or takes a deposition and each person who serves any subpena or other paper herein authorized shall be entitled to receive from the party at whose instance the service shall have been performed such fees as are allowed for similar services in the district courts of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca01c51-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s389/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Witnesses whose depositions are taken shall be entitled to receive from the party at whose instance the witness appeared the same fees and travel allowance paid to witnesses subpenaed to appear before the House of Representatives or its committees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddca01c52-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/138/s10"},"text":"Pub. L. 91–138, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-05"},"text":"Dec. 5, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/288"},"text":"83 Stat. 288","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddca01c53-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddca01c54-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddca01c55-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable with respect to any general or special election for Representative in, or Resident Commissioner to, the Congress of the United States occurring after ","children":[{"tag":"date","attrib":{"date":"1969-12-05"},"text":"Dec. 5, 1969","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/138/s19"},"text":"section 19 of Pub. L. 91–138","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s381"},"text":"section 381 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
