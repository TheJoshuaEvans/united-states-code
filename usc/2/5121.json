{"tag":"section","attrib":{"id":"iddd28112c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5121"},"text":null,"children":[{"tag":"num","attrib":{"value":"5121"},"text":"§ 5121.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expense allowance of Speaker of House of Representatives","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There shall be paid to the Speaker of the House of Representatives in equal monthly installments an expense allowance of $10,000 per annum to assist in defraying expenses relating to or resulting from the discharge of his official duties, for which no accounting, other than for income tax purposes, shall be made by him.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd28112d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-01-19/ch2/s1/e"},"text":"Jan. 19, 1949, ch. 2, § 1(e)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/4"},"text":"63 Stat. 4","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1951-10-20/ch521"},"text":"Oct. 20, 1951, ch. 521","children":[],"tail":", title VI, § 619(c), "},{"tag":"ref","attrib":{"href":"/us/stat/65/570"},"text":"65 Stat. 570","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/186/tII/s203/1"},"text":"Pub. L. 104–186, title II, § 203(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1725"},"text":"110 Stat. 1725","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd28112e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd28112f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b