{"tag":"section","attrib":{"id":"iddd25a052-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4901"},"text":null,"children":[{"tag":"num","attrib":{"value":"4901"},"text":"§ 4901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional pages","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd25a053-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4901/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment conditions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person shall not be appointed as a page of the Senate or House of Representatives—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd25a054-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4901/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unless he agrees that, in the absence of unforeseen circumstances preventing his service as a page after his appointment, he will continue to serve as a page for the period specified in writing at the time of the appointment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd25a055-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4901/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" until complete information in writing is transmitted to his parent or parents, his legal guardian, or other appropriate person or persons acting as his parent or parents, with respect to the nature of the work of pages, their pay, their working conditions (including hours and scheduling of work), and the housing accommodations available to pages.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd25a056-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4901/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person shall not serve as a page—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd25a057-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4901/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of the Senate before he has attained the age of sixteen years; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd25a058-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4901/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of the House of Representatives before he has attained the age of sixteen years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd25a059-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/510/tIV/s491/a"},"text":"Pub. L. 91–510, title IV, § 491(a)","children":[],"tail":"–(d), "},{"tag":"date","attrib":{"date":"1970-10-26"},"text":"Oct. 26, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1198"},"text":"84 Stat. 1198","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/51"},"text":"Pub. L. 97–51","children":[],"tail":", §§ 101(c), 123, "},{"tag":"date","attrib":{"date":"1981-10-01"},"text":"Oct. 1, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/959"},"text":"95 Stat. 959","children":[],"tail":", 965; "},{"tag":"ref","attrib":{"href":"/us/pl/104/186/tII/s204/36"},"text":"Pub. L. 104–186, title II, § 204(36)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1735"},"text":"110 Stat. 1735","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/447/dG/tI/s9"},"text":"Pub. L. 108–447, div. G, title I, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3170"},"text":"118 Stat. 3170","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd25a05a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd25a05b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd25a05c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s88b–1"},"text":"section 88b–1 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Repeal of subsecs. (c) and (d) of this section is based on section 304(a) of H.R. 4120, as reported ","children":[{"tag":"date","attrib":{"date":"1981-07-09"},"text":"July 9, 1981","children":[],"tail":", which was enacted into permanent law by "},{"tag":"ref","attrib":{"href":"/us/pl/97/51/s101/c"},"text":"section 101(c) of Pub. L. 97–51","children":[],"tail":" and amended by "},{"tag":"ref","attrib":{"href":"/us/pl/97/51/s123"},"text":"section 123 of Pub. L. 97–51","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd25a05d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447"},"text":"Pub. L. 108–447","children":[],"tail":" substituted “sixteen” for “fourteen”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186/s204/36/A"},"text":"Pub. L. 104–186, § 204(36)(A)","children":[],"tail":", substituted “the period specified in writing at the time of the appointment” for “a period of not less than two months”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186/s204/36/B"},"text":"Pub. L. 104–186, § 204(36)(B)","children":[],"tail":", substituted a period for “; or” at end of par. (2) and struck out concluding provisions which read as follows: “(except in the case of a chief page, telephone page, or riding page) during any session of the Congress which begins after he has attained the age of eighteen years.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/51"},"text":"Pub. L. 97–51","children":[],"tail":" struck out subsecs. (c) and (d) which had provided, respectively, that pay of pages of the Senate began not more than five days before the convening or reconvening of a session of the Congress or of the Senate and continued until the end of the month during which the Congress or the Senate adjourned or recessed or until the fourteenth day after such adjournment or recess, whichever was the later date, except that, in any case in which the Congress or the Senate adjourned or recessed on or before the last day of July for a period of at least thirty days but not more than forty-five days, such pay would continue until the end of such period of adjournment or recess, and that the pay of pages of the House of Representatives began not more than five days before the convening of a session of the Congress and continued until the end of the month during which the Congress adjourned sine die or recessed or until the fourteenth day after such adjournment or recess, whichever was the later date, except that, in any case in which the House adjourned or recessed on or before the last day of July in any year for a period of at least thirty days but not more than forty-five days, such pay would continue until the end of such period of adjournment or recess."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd25a05e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd25a05f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsecs. (a), (c), and (d) of this section effective immediately prior to noon on ","children":[{"tag":"date","attrib":{"date":"1971-01-03"},"text":"Jan. 3, 1971","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/510/s601/1"},"text":"section 601(1) of Pub. L. 91–510","children":[],"tail":", set out as an Effective Date of 1970 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s4301"},"text":"section 4301 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/91/510/tIV/s491/f"},"text":"Pub. L. 91–510, title IV, § 491(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-26"},"text":"Oct. 26, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1198"},"text":"84 Stat. 1198","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/91/510/tIV/s491/f"},"text":"“Subsection (b) of this section shall become effective on ","children":[{"tag":"date","attrib":{"date":"1971-01-03"},"text":"January 3, 1971","children":[],"tail":", but the provisions of such subsection limiting service as a page to persons who have attained the age of sixteen years shall not be construed to prohibit the continued service of any page appointed prior to the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1970-10-26"},"text":"Oct. 26, 1970","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd25a060-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Pay of Pages Between Recess or Adjournment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior to the repeal of subsecs. (c) and (d) of section 88b–1 (now 4901) of this title by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/51"},"text":"Pub. L. 97–51","children":[],"tail":", provisions for continuing the pay of pages of the Senate and House of Representatives during specific periods of recess or adjournment of Congress by making such subsecs. (b) and (c) inapplicable to the pay of pages during such periods, were contained in the following appropriation acts:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/12/tI"},"text":"Pub. L. 97–12, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-06-05"},"text":"June 5, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/65"},"text":"95 Stat. 65","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/536/s101/c"},"text":"Pub. L. 96–536, § 101(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-16"},"text":"Dec. 16, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3167"},"text":"94 Stat. 3167","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/38/tIII/s303"},"text":"Pub. L. 96–38, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-25"},"text":"July 25, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/142"},"text":"93 Stat. 142","children":[],"tail":". Subsequently repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/97/51"},"text":"Pub. L. 97–51","children":[],"tail":", §§ 101(c), 123, "},{"tag":"date","attrib":{"date":"1981-10-01"},"text":"Oct. 1, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/965"},"text":"95 Stat. 965","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/391/tIII/s305"},"text":"Pub. L. 95–391, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-09-30"},"text":"Sept. 30, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/789"},"text":"92 Stat. 789","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
