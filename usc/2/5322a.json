{"tag":"section","attrib":{"id":"iddd2a8213-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5322a"},"text":null,"children":[{"tag":"num","attrib":{"value":"5322a"},"text":"§ 5322a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowance for compensation of interns in member offices","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd2a8214-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5322a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of allowance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established for the House of Representatives an allowance which shall be available for the compensation of interns who serve in the offices of Members of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2a8215-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5322a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cap on amount available per office","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An office of a Member of the House of Representatives may not use more than $20,000 of the allowance under this section during any calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2a8216-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5322a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benefit exclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s5321/b"},"text":"Section 5321(b) of this title","children":[],"tail":" shall apply with respect to an intern who is compensated under the allowance under this section in the same manner as such section applies with respect to an intern who is compensated under the Members’ Representational Allowance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2a8217-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5322a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No effect on payment of interns under Members’ Representational Allowance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section may be construed to affect the use of the Members’ Representational Allowance for the compensation of interns, as provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s5321"},"text":"section 5321 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2a8218-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5322a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2a8219-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5322a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “intern” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s5321/c/2"},"text":"section 5321(c)(2) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2a821a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5322a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Member of the House of Representatives” means a Representative in, or a Delegate or Resident Commissioner to, the Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2a821b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5322a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section $8,800,000 for fiscal year 2019, and such sums as may be necessary for fiscal year 2020 and each succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd2a821c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/244/dB/tI/s120"},"text":"Pub. L. 115–244, div. B, title I, § 120","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-09-21"},"text":"Sept. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2931"},"text":"132 Stat. 2931","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/94/dE/tI/s112/a"},"text":"Pub. L. 116–94, div. E, title I, § 112(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2759"},"text":"133 Stat. 2759","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd2a821d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd2a821e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd2a821f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94"},"text":"Pub. L. 116–94","children":[],"tail":" substituted “, and such sums as may be necessary for fiscal year 2020 and each succeeding fiscal year.” for period at end."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd2a8220-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd2a8221-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2019 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/dE/tI/s112/c"},"text":"Pub. L. 116–94, div. E, title I, § 112(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2759"},"text":"133 Stat. 2759","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/94/dE/tI/s112/c"},"text":"“The amendments made by this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s5507"},"text":"section 5507 of this title","children":[],"tail":"] shall take effect as if included in the enactment of section 120 of the Legislative Branch Appropriations Act, 2019 ("},{"tag":"ref","attrib":{"href":"/us/usc/t2/s5322a"},"text":"2 U.S.C. 5322a","children":[],"tail":").”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
