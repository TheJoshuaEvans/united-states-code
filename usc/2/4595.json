{"tag":"section","attrib":{"id":"iddd23569a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4595"},"text":null,"children":[{"tag":"num","attrib":{"value":"4595"},"text":"§ 4595.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment for unaccrued leave","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd23569b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4595/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Financial Clerk of the Senate is authorized to accept from an individual whose pay is disbursed by the Secretary of ","children":[{"tag":"ref","attrib":{"idref":"fn002101"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002101"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by “the”."}],"tail":" Senate a payment representing pay for any period of unaccrued annual leave used by that individual, as certified by the head of the employing office of the individual making the payment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd23569c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4595/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withholding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Financial Clerk of the Senate is authorized to withhold the amount referred to in subsection (a) from any amount which is disbursed by the Secretary of the Senate and which is due to or on behalf of the individual described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd23569d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4595/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any payment accepted under this section shall be deposited in the general fund of the Treasury as miscellaneous receipts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd23569e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4595/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Head of the employing office” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As used in this section, the term “head of the employing office” means any person with the final authority to appoint, hire, discharge, and set the terms, conditions, or privileges of the employment of an individual whose pay is disbursed by the Secretary of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd23569f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4595/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply to fiscal year 1996 and each fiscal year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd2356a0-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/197/tI/s9"},"text":"Pub. L. 104–197, title I, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-16"},"text":"Sept. 16, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2398"},"text":"110 Stat. 2398","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd2356a1-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd2356a2-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd2356a3-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s60p"},"text":"section 60p of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Congressional Operations Appropriations Act, 1997, which is title I of the Legislative Branch Appropriations Act, 1997.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
