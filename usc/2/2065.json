{"tag":"section","attrib":{"id":"iddcff7a40-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2065"},"text":null,"children":[{"tag":"num","attrib":{"value":"2065"},"text":"§ 2065.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement of Senate day care center employees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcff7a41-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2065/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost of training classes, conferences, and related expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1345"},"text":"section 1345 of title 31","children":[],"tail":", the Secretary of the Senate may reimburse any individual employed by the Senate day care center for the cost of training classes and conferences in connection with the provision of child care services and for travel, transportation, and subsistence expenses incurred in connection with the training classes and conferences."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcff7a42-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2065/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Documentation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Senate day care center shall certify and provide appropriate documentation to the Secretary of the Senate with respect to any reimbursement under this section. Reimbursements under this section shall be made from the appropriations account “MISCELLANEOUS ITEMS” within the contingent fund of the Senate on vouchers approved by the Secretary of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcff7a43-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2065/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations and limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Reimbursements under this section shall be subject to the regulations and limitations prescribed by the Committee on Rules and Administration of the Senate for travel and related expenses for which payment is authorized to be made from the contingent fund of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcff7a44-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2065/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall be effective on and after ","children":[{"tag":"date","attrib":{"date":"1996-10-01"},"text":"October 1, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcff7a45-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/197/tI/s6"},"text":"Pub. L. 104–197, title I, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-16"},"text":"Sept. 16, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2397"},"text":"110 Stat. 2397","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcff7a46-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcff7a47-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddcff7a48-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was classified to section 214e of former Title 40, prior to the enactment of Title 40, Public Buildings, Property, and Works, by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217/s1"},"text":"Pub. L. 107–217, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1062"},"text":"116 Stat. 1062","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
