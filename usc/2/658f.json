{"tag":"section","attrib":{"id":"iddcb32f9c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s658f"},"text":null,"children":[{"tag":"num","attrib":{"value":"658f"},"text":"§ 658f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requests to Congressional Budget Office from Senators","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"At the written request of a Senator, the Director shall, to the extent practicable, prepare an estimate of the direct costs of a Federal intergovernmental mandate contained in an amendment of such Senator.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddcb32f9d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/344/tIV/s427"},"text":"Pub. L. 93–344, title IV, § 427","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/4/tI/s101/a/2"},"text":"Pub. L. 104–4, title I, § 101(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-03-22"},"text":"Mar. 22, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/59"},"text":"109 Stat. 59","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcb32f9e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcb32f9f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddcb32fa0-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", or on the date 90 days after appropriations are made available as authorized under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1516"},"text":"section 1516 of this title","children":[],"tail":", whichever is earlier, and applicable to legislation considered on and after such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/4/s110"},"text":"section 110 of Pub. L. 104–4","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1511"},"text":"section 1511 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
