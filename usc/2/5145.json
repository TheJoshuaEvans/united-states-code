{"tag":"section","attrib":{"id":"iddd28117f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5145"},"text":null,"children":[{"tag":"num","attrib":{"value":"5145"},"text":"§ 5145.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lump-sum allowances for House Majority Floor Leader, Minority Floor Leader, Majority Whip, and Minority Whip","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd281180-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5145/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Effective with respect to fiscal year 2008 and each succeeding fiscal year, the aggregate amount otherwise authorized to be appropriated for a fiscal year for the lump-sum allowance for each of the following offices is increased as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd281181-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5145/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The allowance for the office of the Majority Floor Leader is increased by $200,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd281182-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5145/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The allowance for the office of the Minority Floor Leader is increased by $200,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd281183-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5145/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Effective with respect to fiscal year 2009 and each succeeding fiscal year, the aggregate amount otherwise authorized to be appropriated for a fiscal year for the lump-sum allowance for each of the following offices is increased as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd281184-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5145/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The allowance for the office of the Majority Whip is increased by $72,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd281185-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5145/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The allowance for the office of the Minority Whip is increased by $72,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd281186-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/8/dG/tI/s104"},"text":"Pub. L. 111–8, div. G, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-11"},"text":"Mar. 11, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/818"},"text":"123 Stat. 818","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd281187-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd281188-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd281189-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s74a–10a"},"text":"section 74a–10a of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Legislative Branch Appropriations Act, 2009, which is div. G of the Omnibus Appropriations Act, 2009.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
