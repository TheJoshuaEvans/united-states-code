{"tag":"section","attrib":{"id":"iddce2f326-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1723"},"text":null,"children":[{"tag":"num","attrib":{"value":"1723"},"text":"§ 1723.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service of members; meetings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddce2f327-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1723/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement of expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the Board shall serve without pay, but may receive travel expenses, including per diem in lieu of subsistence, in accordance with sections 5702 and 5703 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce2f328-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1723/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conflict of interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Librarian shall establish rules and procedures to address any potential conflict of interest between a member of the Board and responsibilities of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce2f329-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1723/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall meet at least once each fiscal year. Meetings shall be at the call of the Librarian.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce2f32a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1723/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quorum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Eleven members of the Board shall constitute a quorum for the transaction of business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddce2f32b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/474/tI/s123"},"text":"Pub. L. 106–474, title I, § 123","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2089"},"text":"114 Stat. 2089","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
