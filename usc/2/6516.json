{"tag":"section","attrib":{"id":"iddd3b2446-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6516"},"text":null,"children":[{"tag":"num","attrib":{"value":"6516"},"text":"§ 6516.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale of waste paper and condemned furniture","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It shall be the duty of the Secretary and Sergeant at Arms of the Senate to cause to be sold all waste paper and useless documents and condemned furniture that may accumulate, in their respective departments or offices, under the direction of the Committee on Rules and Administration of the Senate and cover the proceeds thereof into the Treasury.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd3b2447-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1882-08-07/ch433/s1"},"text":"Aug. 7, 1882, ch. 433, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/22/337"},"text":"22 Stat. 337","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1928-05-29/ch901/s1/122"},"text":"May 29, 1928, ch. 901, § 1(122)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/995"},"text":"45 Stat. 995","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/186/tII/s204/62"},"text":"Pub. L. 104–186, title II, § 204(62)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1739"},"text":"110 Stat. 1739","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd3b2448-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd3b2449-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd3b244a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s117"},"text":"section 117 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd3b244b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186"},"text":"Pub. L. 104–186","children":[],"tail":" struck out “Clerk and Doorkeeper of the House of Representatives and the” before “Secretary and” and substituted “direction of the Committee on Rules and Administration of the Senate and cover” for “direction of the Committee on Accounts of their respective houses and cover”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd3b244c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd3b244d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report on Sales Discontinued","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1928-05-29/ch901/s1/122"},"text":"Act May 29, 1928, ch. 901, § 1(122)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/995"},"text":"45 Stat. 995","children":[],"tail":", provided for the discontinuance of reports on waste paper, etc., as follows: "},{"tag":"quotedContent","attrib":{},"text":"“122. Reports by the Clerk and Doorkeeper of the House and the Secretary and Sergeant at Arms of the Senate of the sales of waste paper and useless documents and condemned furniture, and so forth.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
