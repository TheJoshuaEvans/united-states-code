{"tag":"section","attrib":{"id":"iddcde3739-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1431"},"text":null,"children":[{"tag":"num","attrib":{"value":"1431"},"text":"§ 1431.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exercise of rulemaking powers","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The provisions of sections 1302(b)(3), section ","children":[{"tag":"ref","attrib":{"idref":"fn002062"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002062"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The word “section” probably should not appear."}],"tail":" 1381("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), and 1384(c) of this title are enacted—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcde373a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1431/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as an exercise of the rulemaking power of the House of Representatives and the Senate, respectively, and as such they shall be considered as part of the rules of such House, respectively, and such rules shall supersede other rules only to the extent that they are inconsistent therewith; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcde373b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1431/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with full recognition of the constitutional right of either House to change such rules (so far as relating to such House) at any time, in the same manner, and to the same extent as in the case of any other rule of each House.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcde373c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/1/tV/s501"},"text":"Pub. L. 104–1, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-01-23"},"text":"Jan. 23, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/39"},"text":"109 Stat. 39","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/397/tII/s201/c"},"text":"Pub. L. 115–397, title II, § 201(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5317"},"text":"132 Stat. 5317","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcde373d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcde373e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcde373f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/397"},"text":"Pub. L. 115–397","children":[],"tail":" inserted “, section 1381("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"),” before“and 1384(c) of this title” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcde3740-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"i