,"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd38b293-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd38b294-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd38b295-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s59"},"text":"section 59 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/371/s3"},"text":"section 3 of Pub. L. 93–371","children":[],"tail":". Subsec. (e) of "},{"tag":"ref","attrib":{"href":"/us/pl/93/371/s3"},"text":"section 3 of Pub. L. 93–371","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s6314"},"text":"section 6314 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd38b296-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/36/s1/1"},"text":"Pub. L. 118–36, § 1(1)","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/118/47/s104/1"},"text":"Pub. L. 118–47, § 104(1)","children":[],"tail":", amended subsec. (b) identically, designating existing provisions as par. (1), substituting “Subject to paragraph (2), the aggregate” for “The aggregate” in introductory provisions, redesignating former pars. (1) to (12) as subpars. (A) to (L), respectively, of par. (1), and adding par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/36/s1/2"},"text":"Pub. L. 118–36, § 1(2)","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/118/47/s104/2"},"text":"Pub. L. 118–47, § 104(2)","children":[],"tail":", amended par. (1) identically, designating existing provisions as subpar. (A), substituting “Subject to subparagraph (B), the maximum” for “The maximum”, and adding subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (f)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7"},"text":"Pub. L. 108–7","children":[],"tail":" inserted concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/57/s3/1/A"},"text":"Pub. L. 106–57, § 3(1)(A)","children":[],"tail":", added par. (1) and struck out former par. (1) which read as follows: “4,800 square feet if the population of his State is less than 2,000,000;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/57/s3/1/A"},"text":"Pub. L. 106–57, § 3(1)(A)","children":[],"tail":", (C), redesignated par. (3) as (2) and struck out former par. (2) which read as follows: “5,000 square feet if such population is 2,000,000 but less than 3,000,000;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3) to (12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/57/s3/1/C"},"text":"Pub. L. 106–57, § 3(1)(C)","children":[],"tail":", redesignated pars. (4) to (13) as (3) to (12), respectively. Former par. (3) redesignated (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(13). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/57/s3/1/C"},"text":"Pub. L. 106–57, § 3(1)(C)","children":[],"tail":", redesignated par. (13) as (12)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/57/s3/1/B"},"text":"Pub. L. 106–57, § 3(1)(B)","children":[],"tail":", substituted “8,200” for “8,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/57/s3/2"},"text":"Pub. L. 106–57, § 3(2)","children":[],"tail":", substituted “$40,000” for “$30,000”, “5,000 square feet” for “4,800 square feet”, and “$1,000” for “$734” and inserted at end “Effective beginning with the 106th Congress, the aggregate amount in effect under this paragraph for any Congress shall be increased by the inflation adjustment factor for the calendar year in which the Congress begins. For purposes of the preceding sentence, the inflation adjustment factor for any calendar year is a fraction the numerator of which is the implicit price deflator for the gross domestic product as computed and published by the Department of Commerce for the preceding calendar year and the denominator of which is such deflator for the calendar year 1998.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/197"},"text":"Pub. L. 104–197","children":[],"tail":" substituted “3 years” for “one year” in second sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/90/s7/b/1"},"text":"Pub. L. 102–90, § 7(b)(1)","children":[],"tail":", substituted “the contingent fund of the Senate is available for the rental payments (including by way of reimbursement)” for “shall be reimbursed from the contingent fund of the Senate for the rental payments”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/90/s7/b/2"},"text":"Pub. L. 102–90, § 7(b)(2)","children":[],"tail":", substituted “paid” for “reimbursed”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/90/s7/b/3"},"text":"Pub. L. 102–90, § 7(b)(3)","children":[],"tail":", substituted “payment” for “reimbursement”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/27"},"text":"Pub. L. 102–27","children":[],"tail":" added subpar. (B) and struck out former subpar. (B) which read as follows: “The following inscription shall be clearly visible on three sides of such mobile office in letters not less than four inches high:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“ ‘Mobile Office of Senator (name of Senator)","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“ ‘FOR OFFICIAL OFFICE USE ONLY’.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/90/s7/b/4"},"text":"Pub. L. 102–90, § 7(b)(4)","children":[],"tail":", substituted “payment” for “reimbursement”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/90/s7/b/5"},"text":"Pub. L. 102–90, § 7(b)(5)","children":[],"tail":", substituted “Payment” for “Reimbursement”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/88"},"text":"Pub. L. 99–88","children":[],"tail":" substituted “$30,000” for “$22,550” and “$734” for “$550”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/304/s109/1"},"text":"Pub. L. 96–304, § 109(1)","children":[],"tail":", substituted provision limiting term of a lease of office space to a term not extending beyond the term of office which Senator is serving on first day of such lease, except in case of a Senator whose term is expiring and who has been elected to another term, to end of term for which he has been so elected, for provision limiting term of a lease of office space to a term of not to exceed one year and inserted provision requiring each lease to contain a provision permitting cancellation upon sixty days written notification by Sergeant at Arms and Doorkeeper of Senate, in event of death or resignation of Senator."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/304/s109/2"},"text":"Pub. L. 96–304, § 109(2)","children":[],"tail":", substituted “shall not exceed the highest rate per square foot charged Federal agencies on the first day of the lease of such office” for “shall not at any time exceed the applicable rate per square foot charged Federal agencies”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/94"},"text":"Pub. L. 95–94","children":[],"tail":" substituted “$22,550” for “$20,500” and “$550” for “$500”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/26"},"text":"Pub. L. 95–26","children":[],"tail":" substituted “monthly” for “quarterly”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/59/s107"},"text":"Pub. L. 94–59, § 107","children":[],"tail":", designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/59/s106/a"},"text":"Pub. L. 94–59, § 106(a)","children":[],"tail":", designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (f), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/32"},"text":"Pub. L. 94–32","children":[],"tail":" added subsec. (f) and redesignated former subsec. (f) as (g)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"sta