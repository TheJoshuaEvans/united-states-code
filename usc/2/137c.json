{"tag":"section","attrib":{"id":"iddc839424-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s137c"},"text":null,"children":[{"tag":"num","attrib":{"value":"137c"},"text":"§ 137c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal of books from Library of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The chief judge and associate judges of the United States Court of Appeals for the District of Columbia and the chief judge and associate judges of the United States District Court for the District of Columbia are authorized to use and take books from the Library of Congress in the same manner and subject to the same regulations as justices of the Supreme Court of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc839425-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(Joint Res. No. 9, ","children":[{"tag":"date","attrib":{"date":"1894-01-27"},"text":"Jan. 27, 1894","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/577"},"text":"28 Stat. 577","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1934-06-07/ch426"},"text":"June 7, 1934, ch. 426","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/926"},"text":"48 Stat. 926","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1936-06-25/ch804"},"text":"June 25, 1936, ch. 804","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1921"},"text":"49 Stat. 1921","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646/s32/a"},"text":"June 25, 1948, ch. 646, § 32(a)","children":[],"tail":", (b), "},{"tag":"ref","attrib":{"href":"/us/stat/62/991"},"text":"62 Stat. 991","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-05-24/ch139/s127"},"text":"May 24, 1949, ch. 139, § 127","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/107"},"text":"63 Stat. 107","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc839426-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc839427-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"iddc839428-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1948-06-25"},"text":"June 25, 1948","children":[],"tail":", eff. "},{"tag":"date","attrib":{"date":"1948-09-01"},"text":"Sept. 1, 1948","children":[],"tail":", as amended by act "},{"tag":"date","attrib":{"date":"1949-05-24"},"text":"May 24, 1949","children":[],"tail":", substituted “United States District Court for the District of Columbia” for “District Court of the United States for the District of Columbia”, “chief judge” for “chief justice” and “associate judges” for “associate justices” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1936-06-25"},"text":"June 25, 1936","children":[],"tail":", substituted “District Court of the United States for the said District” for “Supreme Court for the said District”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1934-06-07"},"text":"June 7, 1934","children":[],"tail":", substituted “United States Court of Appeals for the District of Columbia” for “Court of Appeals of the District of Columbia”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
