{"tag":"section","attrib":{"id":"iddd2a81e9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5321"},"text":null,"children":[{"tag":"num","attrib":{"value":"5321"},"text":"§ 5321.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employees of Members of House of Representatives","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd2a81ea-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5321/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under the Members’ Representational Allowance, each Member of the House of Representatives may employ not more than 18 permanent employees and a total of not more than 4 additional employees in the following categories:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2a81eb-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5321/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Interns.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2a81ec-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5321/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Part-time employees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2a81ed-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5321/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Shared employees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2a81ee-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5321/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Temporary employees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2a81ef-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5321/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Employees on leave without pay.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2a81f0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5321/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benefit exclusion","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, interns and temporary employees shall be excluded from the operation of the following provisions of title 5:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2a81f1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5321/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chapter 84 (relating to the Federal Employees’ Retirement System).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2a81f2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5321/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chapter 87 (relating to life insurance).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2a81f3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5321/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chapter 89 (relating to health insurance).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2a81f4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5321/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2a81f5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5321/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Member of the House of Representatives” means a Representative in, or a Delegate or Resident Commissioner to, the Congress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2a81f6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5321/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “intern” means, with respect to a Member of the House of Representatives, an individual who serves in the office of the Member for not more than 120 days in a 12-month period and whose service is primarily for the educational experience of the individual;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2a81f7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5321/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “part-time employee” means, with respect to a Member of the House of Representatives, an individual who is employed by the Member and whose normally assigned work schedule is not more than the equivalent of 15 full working days per month;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2a81f8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5321/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “temporary employee” means, with respect to a Member of the House of Representatives, an individual who is employed for a specific purpose or task and who is employed for not more than 90 days in a 12-month period, except that the term of such employment may be extended with the written approval of the Committee on House Oversight; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2a81f9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5321/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “shared employee” means an employee who is paid by more than one employing authority of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2a81fa-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5321/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Committee on House Oversight shall have authority to prescribe regulations to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd2a81fb-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186/tI/s104"},"text":"Pub. L. 104–186, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1720"},"text":"110 Stat. 1720","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/55/tI/s104/a"},"text":"Pub. L. 105–55, title I, § 104(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-10-07"},"text":"Oct. 7, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1183"},"text":"111 Stat. 1183","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/57/tI/s103/b"},"text":"Pub. L. 106–57, title I, § 103(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-09-29"},"text":"Sept. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/416"},"text":"113 Stat. 416","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd2a81fc-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd2a81fd-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd2a81fe-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s92"},"text":"section 92 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186/s104"},"text":"section 104 of Pub. L. 104–186","children":[],"tail":". Subsec. (e)(1) of "},{"tag":"ref","attrib":{"href":"/us/pl/104/186/s104"},"text":"section 104 of Pub. L. 104–186","children":[],"tail":" repealed former "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s92"},"text":"section 92 of this title","children":[],"tail":". Subsec. (e)(2) and (3) of "},{"tag":"ref","attrib":{"href":"/us/pl/