 subsec. (d) of section 106, and was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/88/454/s104/b"},"text":"section 104(b) of Pub. L. 88–454","children":[],"tail":". Subsec. (c) of section 106 repealed "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s60i"},"text":"section 60i of this title","children":[],"tail":", and the first sentence of subsec. (d) of section 106 repealed section 105 of the Legislative Branch Appropriation Act, 1959."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd128dcd-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1982—Subsec. (b)(1). Figure “463” deemed to refer to the figure “482”, effective ","children":[{"tag":"date","attrib":{"date":"1982-10-01"},"text":"Oct. 1, 1982","children":[],"tail":", pursuant to "},{"tag":"ref","attrib":{"href":"/us/pl/91/656/s4"},"text":"Pub. L. 91–656, § 4","children":[],"tail":", see section 10 of Salary Directive of President pro tempore of the Senate, "},{"tag":"date","attrib":{"date":"1982-10-01"},"text":"Oct. 1, 1982","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s60a–1"},"text":"section 60a–1 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (b)(1). Figure “$441” deemed to refer to the figure “$463”, effective ","children":[{"tag":"date","attrib":{"date":"1981-10-01"},"text":"Oct. 1, 1981","children":[],"tail":", pursuant to "},{"tag":"ref","attrib":{"href":"/us/pl/91/656/s4"},"text":"Pub. L. 91–656, § 4","children":[],"tail":", see section 9 of Salary Directive of President pro tempore of the Senate, "},{"tag":"date","attrib":{"date":"1981-10-05"},"text":"Oct. 5, 1981","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s60a–1"},"text":"section 60a–1 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","att