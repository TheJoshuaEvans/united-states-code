{"tag":"section","attrib":{"id":"iddd128db8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4507"},"text":null,"children":[{"tag":"num","attrib":{"value":"4507"},"text":"§ 4507.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Longevity compensation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd128db9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4507/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible employees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section shall apply ","children":[{"tag":"ref","attrib":{"idref":"fn002093"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002093"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Inapplicability of Section to Certain Employees note below."}],"tail":" to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd128dba-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4507/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" each employee of the Senate whose compensation is paid from the appropriation for Salaries, Officers and Employees under the following headings:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd128dbb-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4507/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Office of the Secretary, including individuals employed under authority of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s6538"},"text":"section 6538 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd128dbc-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4507/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Office of the Sergeant at Arms and Doorkeeper, except employees designated as “special employees”; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd128dbd-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4507/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Offices of the Secretaries for the Majority and the Minority;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd128dbe-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4507/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each employee of the Senate authorized by Senate resolution to be appointed by the Secretary of the Senate or the Sergeant at Arms and Doorkeeper, except employees designated as “special employees”; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd128dbf-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4507/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each employee of the Capitol Guide Service established under section 2166 ","children":[{"tag":"ref","attrib":{"idref":"fn002094"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002094"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd128dc0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4507/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rate of compensation; limitation on increases; computation of service; effective date of payment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd128dc1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4507/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), an employee to whom this section applies shall be paid, during any period of continuous creditable service, additional annual compensation (hereinafter referred to as “longevity compensation”) at the rate of $482 for (A) each year of creditable service performed for the first five years and (B) each two years of creditable service performed during the twenty-year period following the first five years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd128dc2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4507/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of longevity compensation which may be paid to an employee, when added to his regular annual compensation, shall not exceed the maximum annual compensation which may be paid to Senate employees generally as prescribed by law or orders of the President pro tempore issued under authority of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s4571"},"text":"section 4571 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd128dc3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4507/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd128dc4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4507/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" creditable service includes (i) service performed as an employee described in subsection (a), (ii) service performed as a member of the Capitol Police or as an employee of the United States Capitol Telephone Exchange while compensation therefor is disbursed by the Clerk of the House of Representatives, and (iii) service which is creditable for purposes of this section as in effect on ","children":[{"tag":"date","attrib":{"date":"1978-09-30"},"text":"September 30, 1978","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd128dc5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4507/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in computing length of continuous creditable service, only creditable service performed subsequent to ","children":[{"tag":"date","attrib":{"date":"1957-08-31"},"text":"August 31, 1957","children":[],"tail":", shall be taken into account, except that, in the case of service as an employee employed under authority of "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s6538"},"text":"section 6538 of this title","children":[],"tail":", only creditable service performed subsequent to "},{"tag":"date","attrib":{"date":"1971-01-02"},"text":"January 2, 1971","children":[],"tail":", shall be taken into account; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd128dc6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4507/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continuity of creditable service shall not be deemed to be broken by separations from service of not more than thirty days, by the performance of service as an employee (other than an employee subject to the provisions of this section) whose compensation is disbursed by the Secretary of the Senate or the Clerk of the House of Representatives, or by the performance of active military service in the armed forces of the United States, but periods of such separations and service shall not be creditable service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd128dc7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4507/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Longevity compensation shall be payable on and after the first day of the first month following completion of each period of creditable service upon which such compensation is based.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd128dc8-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/730/s106/a"},"text":"Pub. L. 87–730, § 106(a)","children":[],"tail":", (b), (d), "},{"tag":"date","attrib":{"date":"1962-10-02"},"text":"Oct. 2, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/694"},"text":"76 Stat. 694","children":[],"tail":", 695; "},{"tag":"ref","attrib":{"href":"/us/pl/88/454/s104/b"},"text":"Pub. L. 88–454, § 104(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-08-20"},"text":"Aug. 20, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/550"},"text":"78 Stat. 550","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/57/s105/g"},"text":"Pub. L. 90–57, § 105(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-07-28"},"text":"July 28, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/143"},"text":"81 Stat. 143","children":[],"tail":"; "},{"tag":"ref","at