{"tag":"section","attrib":{"id":"iddc72caf3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s30a"},"text":null,"children":[{"tag":"num","attrib":{"value":"30a"},"text":"§ 30a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jury duty exemption of elected officials of legislative branch","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc72caf4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s30a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of Federal, State or local law, no elected official of the legislative branch of the United States Government shall be required to serve on a grand or petit jury, convened by any Federal, State or local court, whether such service is requested by judicial summons or by some other means of compulsion.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc72caf5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s30a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Elected official of the legislative branch” shall mean each Member of the United States House of Representatives, the Delegates from the District of Columbia, Guam, the American Virgin Islands, and American Samoa, and the Resident Commissioner from Puerto Rico, and each United States Senator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc72caf6-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/520/tIII/s310"},"text":"Pub. L. 101–520, title III, § 310","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2278"},"text":"104 Stat. 2278","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc72caf7-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc72caf8-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddc72caf9-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Legislative Branch Appropriations Act, 1991.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
