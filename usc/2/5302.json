{"tag":"section","attrib":{"id":"iddd2a81b2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5302"},"text":null,"children":[{"tag":"num","attrib":{"value":"5302"},"text":"§ 5302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Salaries payable monthly after taking oath","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Each Member and Delegate, after he has taken and subscribed the required oath, is entitled to receive his salary at the end of each month.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd2a81b3-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(R.S. § 39.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd2a81b4-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd2a81b5-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd2a81b6-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s35"},"text":"section 35 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 39 derived from Res. ","children":[{"tag":"date","attrib":{"date":"1867-03-29"},"text":"Mar. 29, 1867","children":[],"tail":", No. 18, "},{"tag":"ref","attrib":{"href":"/us/stat/15/24"},"text":"15 Stat. 24","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
