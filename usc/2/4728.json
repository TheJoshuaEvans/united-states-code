{"tag":"section","attrib":{"id":"iddd25a048-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4728"},"text":null,"children":[{"tag":"num","attrib":{"value":"4728"},"text":"§ 4728.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of post-employment restrictions for Senators and employees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd25a049-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4728/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After a Senator or an elected officer of the Senate leaves office or after the termination of employment with the Senate of an employee of the Senate, the Secretary of the Senate shall notify the Member, officer, or employee of the beginning and ending date of the prohibitions that apply to the Member, officer, or employee under rule XXXVII of the Standing Rules of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd25a04a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4728/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall take effect 60 days after ","children":[{"tag":"date","attrib":{"date":"2007-09-14"},"text":"September 14, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd25a04b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/81/tV/s535"},"text":"Pub. L. 110–81, title V, § 535","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-09-14"},"text":"Sept. 14, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/766"},"text":"121 Stat. 766","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd25a04c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd25a04d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd25a04e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s104f"},"text":"section 104f of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
