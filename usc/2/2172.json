{"tag":"section","attrib":{"id":"iddd09175e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2172"},"text":null,"children":[{"tag":"num","attrib":{"value":"2172"},"text":"§ 2172.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Congressional Accessibility Services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd09175f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2172/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Office of Congressional Accessibility Services","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd091760-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2172/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the legislative branch the Office of Congressional Accessibility Services, to be headed by the Director of Accessibility Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd091761-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2172/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional Accessibility Services Board","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd091762-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2172/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is established the Congressional Accessibility Services Board, which shall be composed of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd091763-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2172/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Sergeant at Arms and Doorkeeper of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd091764-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2172/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd091765-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2172/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Sergeant at Arms of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd091766-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2172/a/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Clerk of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd091767-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2172/a/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Architect of the Capitol.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd091768-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2172/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direction of Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office of Congressional Accessibility Services shall be subject to the direction of the Congressional Accessibility Services Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd091769-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2172/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mission and functions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd09176a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2172/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Office of Congressional Accessibility Services shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd09176b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2172/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide and coordinate accessibility services for individuals with disabilities, including Members of Congress, officers and employees of the House of Representatives and the Senate, and visitors, in the United States Capitol Complex; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd09176c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2172/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide information regarding accessibility for individuals with disabilities, as well as related training and staff development, to Members of Congress and employees of the Senate and the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd09176d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2172/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States Capitol Complex defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this paragraph, the term “United States Capitol Complex” means the Capitol buildings (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s5101"},"text":"section 5101 of title 40","children":[],"tail":") and the United States Capitol Grounds (as described in section 5102 of such title)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd09176e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2172/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director of Accessibility Services","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd09176f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2172/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment, pay, and removal","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd091770-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2172/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment and pay","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of Accessibility Services shall be appointed by the Congressional Accessibility Services Board and shall be paid at a rate of pay determined by the Congressional Accessibility Services Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd091771-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2172/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon removal of the Director of Accessibility Services, the Congressional Accessibility Services Board shall immediately provide notice of the removal to the Committee on Rules and Administration of the Senate, the Committee on House Administration of the House of Representatives, and the Committees on Appropriations of the House of Representatives and Senate. The notice shall include the reasons for the removal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd091772-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2172/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personnel and other administrative functions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd091773-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2172/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personnel, disbursements, and contracts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the functions of the Office of Congressional Accessibility Services under subsection (a), the Director of Accessibility Services shall have the authority to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd091774-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2172/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appoint, hire, and fix the compensation of such personnel as may be necessary for operations of the Office of Congressional Accessibility Services, except that no employee may be paid at an annual rate in excess of the annual rate of pay for the Director of Accessibility Services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd091775-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2172/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take appropriate disciplinary action, including, when circumstances warrant, suspension from duty without pay, reduction in pay, demotion, or termination of employment with the Office of Congressional Accessibility Services, against any employee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd091776-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2172/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disburse funds as may be necessary and available for the needs of the Office of Congressional Accessibility Services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd091777-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2172/b/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as contracting officer for the Office of Congressional Accessibility Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd091778-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2172/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements with the Office of the Architect of the Capitol, with other legislative branch agencies, and with offices of the Senate and House of Representatives","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the approval of the Committee on Rules and Administration of the Senate and the Committee on House Administration of the House of Representatives, the Director of Accessibility Services may place orders and enter into agreements with the Office of the Architect of the Capitol, with other legislative branch agencies, and with any office or other entity of the Senate or House of Representatives for procuring goods and providing financial and administrative services on behalf of the Office of Congressional Accessibility Services, or to otherwise assist the Director in the administration and management of the Office of Congressional Accessibility Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd091779-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2172/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Semiannual reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of Accessibility Services shall submit a report to the Committee on Rules and Administration of the Senate and the Committee on House Administration of the House of Representatives not later than 45 days following the close of each semiannual period ending on March 31 or September 30 of each year on the financial and operational status during the period of each function under the jurisdiction of the Director. Each such report shall include financial statements and a description or explanation of current operations, the implementation of new policies and procedures, and future plans for each function.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd09177a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/163/tIII/s310"},"text":"Pub. L. 101–163, title III, § 310","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-21"},"text":"Nov. 21, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1065"},"text":"103 Stat. 1065","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/53/tI/s112"},"text":"Pub. L. 104–53, title I, § 112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-11-19"},"text":"Nov. 19, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/525"},"text":"109 Stat. 525","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/437/tIV/s411/a"},"text":"Pub. L. 110–437, title IV, § 411(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-20"},"text":"Oct. 20, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4993"},"text":"122 Stat. 4993","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd09177b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd09177c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd09177d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s130e"},"text":"section 130e of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Legislative Branch Appropriations Act, 1990.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd09177e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/437"},"text":"Pub. L. 110–437","children":[],"tail":" amended section generally, substituting provisions relating to Office of Congressional Accessibility Services for provisions relating to Special Services Office."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1995—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/53"},"text":"Pub. L. 104–53","children":[],"tail":" substituted “Sergeant at Arms” for “Clerk” after “comprised of the” and “Architect of the Capitol” for “Librarian of Congress”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd09177f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"iddd091780-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of contracts, liabilities, records, property, appropriations, other assets and interests, and employees of the Congressional Special Services Office of Capitol Guide Service to the Office of Congressional Accessibility Services, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s2252"},"text":"section 2252 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
