{"tag":"section","attrib":{"id":"iddd3d953e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6576"},"text":null,"children":[{"tag":"num","attrib":{"value":"6576"},"text":"§ 6576.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Senate Gift Shop","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd3d953f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6576/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Senate is authorized to establish a Senate Gift Shop for the purpose of providing for the sale of gift items to Members of the Senate, staff, and the general public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3d9540-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6576/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit of receipts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All moneys received from sales and other services by the Senate Gift Shop shall be deposited in the revolving fund established by subsection (c) and shall be available for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3d9541-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6576/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revolving fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd3d9542-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6576/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is established in the Treasury of the United States a revolving fund within the contingent fund of the Senate to be known as the Senate Gift Shop Revolving Fund (hereafter referred to in this section as the “fund”). The fund shall consist of all amounts collected or received by the Secretary of the Senate from sales and services by the Senate Gift Shop. All moneys in the fund shall be available without fiscal year limitation for disbursement by the Secretary of the Senate in connection with the operation of the Senate Gift Shop, including supplies, equipment, and other expenses. In addition, such moneys may be used by the Secretary of the Senate to reimburse the Senate appropriations account, appropriated under the heading “","children":[{"tag":"inline","attrib":{},"text":"Salaries, Officers and Employees","children":[],"tail":"” and “"},{"tag":"inline","attrib":{},"text":"Office of the Secretary","children":[],"tail":"”, for amounts used from such account to pay the salaries of employees of the Senate Gift Shop."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3d9543-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6576/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Senate may transfer from the fund to the Capitol Preservation Fund the net profits (as determined by the Secretary) from sales of items by the Senate Gift Shop which are intended to benefit the Capitol Visitor Center.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3d9544-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6576/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Senate may transfer from the fund to the Senate Employee Child Care Center proceeds from the sale of holiday ornaments by the Senate Gift Shop for the purpose of funding necessary activities and expenses of the Center, including scholarships, educational supplies, and equipment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3d9545-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6576/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception to prohibition of sale or solicitation on Capitol Grounds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s5104/c"},"text":"section 5104(c) of title 40","children":[],"tail":" shall not be applicable to any activity carried out pursuant to this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3d9546-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6576/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of moneys from Stationery Revolving Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To provide capital for the fund, the Secretary of the Senate is authorized to transfer, from moneys in the Stationery Revolving Fund in the contingent fund of the Senate, to the fund such sum as he may determine necessary, not to exceed $300,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3d9547-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6576/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization to expend from appropriations account for initial expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of acquiring supplies, equipment, and meeting other initial expenses in implementing subsection (a), the Secretary of the Senate is authorized, upon ","children":[{"tag":"date","attrib":{"date":"1992-10-06"},"text":"October 6, 1992","children":[],"tail":", to expend, from moneys appropriated to the appropriations account, within the contingent fund of the Senate, for expenses of the Secretary of the Senate, by the Legislative Branch Appropriations Act, 1991, such amounts as may be necessary to carry out this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3d9548-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6576/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disbursement on approved voucher","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Disbursements from the fund shall be made upon vouchers approved by the Secretary of the Senate, or his designee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3d9549-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6576/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Senate is authorized to prescribe such regulations as may be necessary to carry out the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd3d954a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/392/tI/s2"},"text":"Pub. L. 102–392, title I, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-06"},"text":"Oct. 6, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1706"},"text":"106 Stat. 1706","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/68/tI/s107/a"},"text":"Pub. L. 107–68, title I, § 107(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-11-12"},"text":"Nov. 12, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/568"},"text":"115 Stat. 568","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/39/s1"},"text":"Pub. L. 110–39, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-06-21"},"text":"June 21, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/231"},"text":"121 Stat. 231","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd3d954b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd3d954c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd3d954d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Legislative Branch Appropriations Act, 1991, referred to in subsec. (f), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/520"},"text":"Pub. L. 101–520","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2254"},"text":"104 Stat. 2254","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd3d954e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s121d"},"text":"section 121d of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Congressional Operations Appropriations Act, 1993, which is title I of the Legislative Branch Appropriations Act, 1993.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (d), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s5104/c"},"text":"section 5104(c) of title 40","children":[],"tail":"” substituted for “"},{"tag":"ref","attrib":{"href":"/us/act/1946-07-31/s4"},"text":"section 4 of the Act of July 31, 1946","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t40/s193d"},"text":"40 U.S.C. 193d","children":[],"tail":")” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/107/217/s5/c"},"text":"Pub. L. 107–217, § 5(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1303"},"text":"116 Stat. 1303","children":[],"tail":", the first section of which enacted Title 40, Public Buildings, Property, and Works."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd3d954f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/39"},"text":"Pub. L. 110–39","children":[],"tail":" added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/68"},"text":"Pub. L. 107–68","children":[],"tail":" designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd3d9550-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd3d9551-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2001 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/68/tI/s107/b"},"text":"Pub. L. 107–68, title I, § 107(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-11-12"},"text":"Nov. 12, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/569"},"text":"115 Stat. 569","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/68/tI/s107/b"},"text":"“The amendments made by this section [amending this section] shall apply to fiscal years beginning before, on, or after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2001-11-12"},"text":"Nov. 12, 2001","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd3d9552-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Additional Capitalization","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/283/tI/s1"},"text":"Pub. L. 103–283, title I, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-22"},"text":"July 22, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1426"},"text":"108 Stat. 1426","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/283/tI/s1"},"text":"“Effective on and after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1994-07-22"},"text":"July 22, 1994","children":[],"tail":"], the Secretary of the Senate, subject to the approval of the Committee on Appropriations of the Senate, is authorized to transfer up to $300,000 from any Senate appropriations account with respect to which the Secretary has disbursing authority to the revolving fund established under section 2(c) under the subheading ‘ADMINISTRATIVE PROVISIONS’ under the heading ‘SENATE’ in "},{"tag":"ref","attrib":{"href":"/us/pl/102/392"},"text":"Public Law 102–392","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t2/s121d/c"},"text":"2 U.S.C. 121d(c)","children":[],"tail":") [now "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s6576/c"},"text":"2 U.S.C. 6576(c)","children":[],"tail":"] to provide additional capitalization for such revolving fund. Any moneys so transferred shall be available for use in the same manner and to the same extent as the moneys otherwise in such revolving fund.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
