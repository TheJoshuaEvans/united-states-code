{"tag":"section","attrib":{"id":"iddce2f2ee-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1704"},"text":null,"children":[{"tag":"num","attrib":{"value":"1704"},"text":"§ 1704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Recording Registry Collection of the Library of Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddce2f2ef-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1704/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All copies of sound recordings on the National Recording Registry that are received by the Librarian under subsection (b) shall be maintained in the Library of Congress and be known as the “National Recording Registry Collection of the Library of Congress”. The Librarian shall by regulation and in accordance with title 17 provide for reasonable access to the sound recordings and other materials in such collection for scholarly and research purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce2f2f0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1704/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of quality copies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce2f2f1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1704/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Librarian shall seek to obtain, by gift from the owner, a quality copy of the Registry version of each sound recording included in the National Recording Registry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce2f2f2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1704/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limit on number of copies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than one copy of the same version or take of any sound recording may be preserved in the National Recording Registry. Nothing in the preceding sentence may be construed to prohibit the Librarian from making or distributing copies of sound recordings included in the Registry for purposes of carrying out this Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce2f2f3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1704/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Property of United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All copies of sound recordings on the National Recording Registry that are received by the Librarian under subsection (b) shall become the property of the United States Government, subject to the provisions of title 17.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddce2f2f4-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/474/tI/s104"},"text":"Pub. L. 106–474, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2087"},"text":"114 Stat. 2087","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddce2f2f5-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddce2f2f6-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddce2f2f7-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (b)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/474"},"text":"Pub. L. 106–474","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2085"},"text":"114 Stat. 2085","children":[],"tail":", known as the National Recording Preservation Act of 2000, which enacted this chapter and chapter 1524 (§ 152401 et seq.) of Title 36, Patriotic and National Observances, Ceremonies, and Organizations. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1701"},"text":"section 1701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
