{"tag":"section","attrib":{"id":"iddd06a70f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2170"},"text":null,"children":[{"tag":"num","attrib":{"value":"2170"},"text":"§ 2170.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Battery recharging stations for privately owned vehicles in parking areas under the jurisdiction of the Senate at no net cost to the Federal Government","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd06a710-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2170/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “covered employee” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd06a711-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2170/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee whose pay is disbursed by the Secretary of the Senate; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd06a712-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2170/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other individual who is authorized to park in any parking area under the jurisdiction of the Senate on Capitol Grounds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd06a713-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2170/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd06a714-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2170/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (3), funds appropriated to the Architect of the Capitol under the heading “Capitol Power Plant” under the heading “ARCHITECT OF THE CAPITOL” in any fiscal year are available to construct, operate, and maintain on a reimbursable basis battery recharging stations in parking areas under the jurisdiction of the Senate on Capitol Grounds for use by privately owned vehicles used by Senators or covered employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd06a715-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2170/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vendors authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out paragraph (1), the Architect of the Capitol may use 1 or more vendors on a commission basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd06a716-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2170/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Architect of the Capitol may construct or direct the construction of battery recharging stations described under paragraph (1) after—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd06a717-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2170/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submission of written notice detailing the numbers and locations of the battery recharging stations to the Committee on Rules and Administration of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd06a718-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2170/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approval by that Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd06a719-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2170/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees and charges","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd06a71a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2170/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), the Architect of the Capitol shall charge fees or charges for electricity provided to Senators and covered employees sufficient to cover the costs to the Architect of the Capitol to carry out this section, including costs to any vendors or other costs associated with maintaining the battery recharging stations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd06a71b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2170/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of fees or charges","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Architect of the Capitol may establish and adjust fees or charges under paragraph (1) after—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd06a71c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2170/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submission of written notice detailing the amount of the fee or charge to be established or adjusted to the Committee on Rules and Administration of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd06a71d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2170/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approval by that Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd06a71e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2170/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit and availability of fees, charges, and commissions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any fees, charges, or commissions collected by the Architect of the Capitol under this section shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd06a71f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2170/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deposited in the Treasury to the credit of the appropriations account described under subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd06a720-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2170/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" available for obligation without further appropriation during—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd06a721-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2170/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fiscal year collected; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd06a722-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2170/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fiscal year following the fiscal year collected.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd06a723-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2170/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd06a724-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2170/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after the end of each fiscal year, the Architect of the Capitol shall submit a report on the financial administration and cost recovery of activities under this section with respect to that fiscal year to the Committee on Rules and Administration of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd06a725-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2170/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Avoiding subsidy","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd06a726-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2170/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"2012-08-10"},"text":"August 10, 2012","children":[],"tail":", and every 3 years thereafter, the Architect of the Capitol shall submit a report to the Committee on Rules and Administration of the Senate determining whether Senators and covered employees using battery charging stations as authorized by this section are receiving a subsidy from the taxpayers."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd06a727-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2170/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modification of rates and fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a determination is made under subparagraph (A) that a subsidy is being received, the Architect of the Capitol shall submit a plan to the Committee on Rules and Administration of the Senate on how to update the program to ensure no subsidy is being received. If the committee does not act on the plan within 60 days, the Architect of the Capitol shall take appropriate steps to increase rates or fees to ensure reimbursement for the cost of the program consistent with an appropriate schedule for amortization, to be charged to those using the charging stations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd06a728-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2170/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply with respect to fiscal year 2011 and each fiscal year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd06a729-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/167/s1"},"text":"Pub. L. 112–167, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-10"},"text":"Aug. 10, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1296"},"text":"126 Stat. 1296","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
