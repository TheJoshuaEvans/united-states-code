{"tag":"section","attrib":{"id":"iddd14fe4f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4534"},"text":null,"children":[{"tag":"num","attrib":{"value":"4534"},"text":"§ 4534.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Obsolete references in existing law to basic pay rates","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In any case in which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd14fe50-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4534/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rate of pay of any employee or position, or class of employees or positions, the pay for whom or for which is disbursed by the Chief Administrative Officer of the House of Representatives, or any maximum or minimum rate with respect to any such employee, position, or class, is referred to in or provided by statute or House resolution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd14fe51-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4534/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rate so referred to or provided is a basic rate with respect to which additional pay is provided by law;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"such statutory provision or resolution shall be deemed to refer, in lieu of such basic rate, to the per annum gross rate which an employee receiving such basic rate immediately prior to the effective date of this section would receive, without regard to such statutory provision or resolution, under section 334 ","children":[{"tag":"ref","attrib":{"idref":"fn002096"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002096"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title on and after such date."}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd14fe52-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/510/tIV/s475"},"text":"Pub. L. 91–510, title IV, § 475","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-26"},"text":"Oct. 26, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1195"},"text":"84 Stat. 1195","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/186/tII/s210/4"},"text":"Pub. L. 104–186, title II, § 210(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1743"},"text":"110 Stat. 1743","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd14fe53-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd14fe54-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd14fe55-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s334"},"text":"Section 334 of this title","children":[],"tail":", referred to in text, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/104/186/tII/s210/3/A"},"text":"Pub. L. 104–186, title II, § 210(3)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1743"},"text":"110 Stat. 1743","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd14fe56-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s335"},"text":"section 335 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd14fe57-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186"},"text":"Pub. L. 104–186","children":[],"tail":" substituted “Chief Administrative Officer” for “Clerk”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd14fe58-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd14fe59-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective immediately prior to noon on ","children":[{"tag":"date","attrib":{"date":"1971-01-03"},"text":"Jan. 3, 1971","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/510/s601/1"},"text":"section 601(1) of Pub. L. 91–510","children":[],"tail":", set out as an Effective Date of 1970 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s4301"},"text":"section 4301 of this title","children":[],"tail":