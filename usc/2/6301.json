"attrib":{"href":"/us/usc/t2/s33"},"text":"section 33 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd33f8ea-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1981—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/51"},"text":"Pub. L. 97–51","children":[],"tail":" struck out “monthly” after “may receive their compensation”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd33f8eb-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd33f8ec-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1981 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/51/s112/e"},"text":"Pub. L. 97–51, § 112(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-10-01"},"text":"Oct. 1, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/963"},"text":"95 Stat. 963","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/51/s112/e"},"text":"“The amendments and repeals made by this section [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s5303"},"text":"section 5303 of this title","children":[],"tail":" and amending this section and sections 5306 and 4591 of this title] shall be effective in the case of compensation payable for months after December 1981.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n