", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1062"},"text":"116 Stat. 1062","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/117/s901"},"text":"section 901 of Pub. L. 107–117","children":[],"tail":". Subsec. (c)(2) of "},{"tag":"ref","attrib":{"href":"/us/pl/107/117/s901"},"text":"section 901 of Pub. L. 107–117","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1961"},"text":"section 1961 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcfabff5-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/206"},"text":"Pub. L. 107–206","children":[],"tail":" substituted “buildings and facilities, subject to the availability of appropriations,” for “buildings and facilities”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcfabff6-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcfabff7-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/206/tI/s902/c"},"text":"Pub. L. 107–206, title I, § 902(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-02"},"text":"Aug. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/876"},"text":"116 Stat. 876","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/206/tI/s902/c"},"text":"“The amendment made by this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1961"},"text":"section 1961 of this title","children":[],"tail":"] shall take effect as if included in the enactment of the Emergency Supplemental Act, 2002 ["},{"tag":"ref","attrib":{"href":"/us/pl/107/117/dB"},"text":"Pub. L. 107–117, div. B","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
