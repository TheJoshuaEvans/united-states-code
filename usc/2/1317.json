{"tag":"section","attrib":{"id":"iddcd49a11-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1317"},"text":null,"children":[{"tag":"num","attrib":{"value":"1317"},"text":"§ 1317.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of intimidation or reprisal","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcd49a12-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1317/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall be unlawful for an employing office to intimidate, take reprisal against, or otherwise discriminate against, any covered employee because the covered employee has opposed any practice made unlawful by this chapter, or because the covered employee has initiated proceedings, made a charge, or testified, assisted, or participated in any manner in a hearing or other proceeding under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd49a13-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1317/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remedy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The remedy available for a violation of subsection (a) shall be such legal or equitable remedy as may be appropriate to redress a violation of subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcd49a14-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/1/tII/s208"},"text":"Pub. L. 104–1, title II, § 208","children":[],"tail":", formerly § 207, "},{"tag":"date","attrib":{"date":"1995-01-23"},"text":"Jan. 23, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/13"},"text":"109 Stat. 13","children":[],"tail":"; renumbered § 208, "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tXI/s1122/d/1/B"},"text":"Pub. L. 116–92, div. A, title XI, § 1122(d)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1608"},"text":"133 Stat. 1608","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcd49a15-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcd49a16-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddcd49a17-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/1"},"text":"Pub. L. 104–1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-01-23"},"text":"Jan. 23, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/3"},"text":"109 Stat. 3","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1301"},"text":"section 1301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
