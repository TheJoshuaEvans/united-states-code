{"tag":"section","attrib":{"id":"iddc70817a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s25a"},"text":null,"children":[{"tag":"num","attrib":{"value":"25a"},"text":"§ 25a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delegate to House of Representatives from District of Columbia","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc70817b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s25a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The people of the District of Columbia shall be represented in the House of Representatives by a Delegate, to be known as the “Delegate to the House of Representatives from the District of Columbia”, who shall be elected by the voters of the District of Columbia in accordance with the District of Columbia Election Act. The Delegate shall have a seat in the House of Representatives, with the right of debate, but not of voting, shall have all the privileges granted a Representative by section 6 of Article I of the Constitution, and shall be subject to the same restrictions and regulations as are imposed by law or rules on Representatives. The Delegate shall be elected to serve during each Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc70817c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s25a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" No individual may hold the office of Delegate to the House of Representatives from the District of Columbia unless on the date of his election—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc70817d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s25a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" he is a qualified elector (as that term is defined in section 2(2) of the District of Columbia Election Act) of the District of Columbia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc70817e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s25a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" he is at least twenty-five years of age;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc70817f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s25a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" he holds no other paid public office; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc708180-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s25a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" he has resided in the District of Columbia continuously since the beginning of the three-year period ending on such date.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"He shall forfeit his office upon failure to maintain the qualifications required by this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc708181-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/405/tII/s202"},"text":"Pub. L. 91–405, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-09-22"},"text":"Sept. 22, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/848"},"text":"84 Stat. 848","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc708182-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc708183-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddc708184-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The District of Columbia Election Act, referred to in subsecs. (a) and (b)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-08-12/ch862"},"text":"act Aug. 12, 1955, ch. 862","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/699"},"text":"69 Stat. 699","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc708185-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddc708186-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/91/405/tII/s206/b"},"text":"Pub. L. 91–405, title II, § 206(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-09-22"},"text":"Sept. 22, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/855"},"text":"84 Stat. 855","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/91/405/tII/s206/b"},"text":"“This title and the amendments made by this title [enacting this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s25b"},"text":"section 25b of this title","children":[],"tail":" and amending "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s2106"},"text":"section 2106 of Title 5","children":[],"tail":", Government Organization and Employees, sections 4342, 6954, and 9342 of Title 10, Armed Forces, sections 201, 203, 204, 591, 594, and 595 of Title 18, Crimes and Criminal Procedure, and "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s10307"},"text":"section 10307 of Title 52","children":[],"tail":", Voting and Elections] shall take effect on the date of its enactment ["},{"tag":"date","attrib":{"date":"1970-09-22"},"text":"Sept. 22, 1970","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
