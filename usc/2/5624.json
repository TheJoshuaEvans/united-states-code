{"tag":"section","attrib":{"id":"iddd31adcf-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5624"},"text":null,"children":[{"tag":"num","attrib":{"value":"5624"},"text":"§ 5624.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of positions in Corrections Calendar Office","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd31add0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5624/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd31add1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5624/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Effective ","children":[{"tag":"date","attrib":{"date":"2003-10-01"},"text":"October 1, 2003","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd31add2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5624/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3 of the positions in the Corrections Calendar Office, and the functions associated with such positions, shall be transferred to the Office of the Speaker; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd31add3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5624/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 of the positions in the Corrections Calendar Office, and the functions associated with such positions, shall be transferred to the Office of the Minority Leader.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd31add4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5624/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of law, in the case of any individual who is an incumbent of a position transferred under paragraph (1) at the time of the transfer, the total number of days of annual leave and the total number of days of sick leave which were provided by the Corrections Calendar Office to the individual and which remain unused as of the date of the transfer shall remain available for the individual to use after the transfer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd31add5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5624/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Effective with respect to fiscal year 2004 and each succeeding fiscal year, the lump sum allowance for salaries and expenses of the Corrections Calendar Office provided under House Resolution 130, One Hundred Fifth Congress, agreed to ","children":[{"tag":"date","attrib":{"date":"1997-04-24"},"text":"April 24, 1997","children":[],"tail":", as enacted into permanent law by section 101 of the Legislative Branch Appropriations Act, 1998 ("},{"tag":"ref","attrib":{"href":"/us/usc/t2/s74d–1"},"text":"2 U.S.C. 74d–1","children":[],"tail":" et seq.) [now "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s5622"},"text":"2 U.S.C. 5622","children":[],"tail":" and 5623], is transferred as follows:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd31add6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5624/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 63.5 percent of such allowance shall be transferred to the Office of the Speaker.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd31add7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5624/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 36.5 percent of such allowance shall be transferred to the Office of the Minority Leader.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd31add8-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/83/tI/s106"},"text":"Pub. L. 108–83, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-09-30"},"text":"Sept. 30, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1018"},"text":"117 Stat. 1018","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd31add9-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd31adda-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd31addb-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s74d"},"text":"section 74d of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
