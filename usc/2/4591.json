{"tag":"section","attrib":{"id":"iddd23565e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4591"},"text":null,"children":[{"tag":"num","attrib":{"value":"4591"},"text":"§ 4591.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vice President, Senators, officers, and employees paid by Secretary of Senate; payment of salary; advance payment","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The compensation of the Vice President, Senators, and officers and employees, whose compensation is disbursed by the Secretary of the Senate, shall be payable on the fifth day of the month following the month in which such compensation accrued, except that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd23565f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4591/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/51/s111/a/1"},"text":"Pub. L. 97–51, § 111(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-10-01"},"text":"Oct. 1, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/962"},"text":"95 Stat. 962","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd235660-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4591/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when such fifth or twentieth day falls on Saturday, Sunday, or on a legal holiday (including any holiday on which the banks of the District of Columbia are closed pursuant to law), such compensation shall be payable on the next preceding workday; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd235661-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4591/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any part of such compensation accrued for any month may, in the discretion of the Secretary of the Senate, be paid prior to the day specified in the preceding provisions of this section.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of title 26 and for accounting and reporting purposes, disbursements made in accordance with this section on the fifth day of a month, or on the next preceding workday if such fifth day falls on Saturday, Sunday, or a legal holiday, shall be considered to have been made on the last day of the preceding month.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd235662-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/426/s1"},"text":"Pub. L. 86–426, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-04-20"},"text":"Apr. 20, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/53"},"text":"74 Stat. 53","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/136/s6"},"text":"Pub. L. 92–136, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-10-11"},"text":"Oct. 11, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/378"},"text":"85 Stat. 378","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/38/tI/s108/a"},"text":"Pub. L. 96–38, title I, § 108(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-25"},"text":"July 25, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/113"},"text":"93 Stat. 113","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/51"},"text":"Pub. L. 97–51","children":[],"tail":", §§ 111(a), 112(a), "},{"tag":"date","attrib":{"date":"1981-10-01"},"text":"Oct. 1, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/962"},"text":"95 Stat. 962","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/257/tI/s105/a"},"text":"Pub. L. 97–257, title I, § 105(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-10"},"text":"Sept. 10, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/849"},"text":"96 Stat. 849","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd235663-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd235664-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd235665-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s60c–1"},"text":"section 60c–1 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd235666-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" substituted “Internal Revenue Code of 1986” for “Internal Revenue Code of 1954”, which for purposes of codification was translated as “title 26” thus requiring no change in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/257"},"text":"Pub. L. 97–257","children":[],"tail":" inserted reference to the Vice President."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/51"},"text":"Pub. L. 97–51","children":[],"tail":" substituted “Senators and officers and employees” for “officers (other than Senators) and employees”, struck out cl. (1) which provided that all compensation for the month of December be payable on the twentieth of December, inserted “purposes of title 26 and for” after “For” in second sentence, and struck out provisions that, in cases in which officers or employees of the Senate died during the month of December and the full compensation of that officer or employee for that month had been disbursed by the Secretary of the Senate before the Secretary received notice of the death, no recovery could be made of any portion of the compensation so disbursed."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/38"},"text":"Pub. L. 96–38","children":[],"tail":" provided that, in cases in which officers or employees of the Senate die during the month of December and the full compensation of that officer or employee for that month has been disbursed by the Secretary of the Senate before the Secretary receives notice of the death, no recovery shall be made of any portion of the compensation so disbursed."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1971—Cl. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/136"},"text":"Pub. L. 92–136","children":[],"tail":" inserted “(including any holiday on which the banks of the District of Columbia are closed pursuant to law)” after “holiday”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd235667-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd235668-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1982 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/257/tI/s105/c"},"text":"Pub. L. 97–257, title I, § 105(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-10"},"text":"Sept. 10, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/849"},"text":"96 Stat. 849","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/257/tI/s105/c"},"text":"“Amendments and repeals made by the preceding provisions of this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t3/s104"},"text":"section 104 of Title 3","children":[],"tail":", The President] shall be effective in the case of compensation payable for months after December 1981.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd235669-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1981 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/51/s111/b"},"text":"Pub. L. 97–51, § 111(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-10-01"},"text":"Oct. 1, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/962"},"text":"95 Stat. 962","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/51/s111/b"},"text":"“The amendments made by subsection (a) [amending this section] shall be effective in the case of compensation payable for months after December 1982.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/51/s112/a"},"text":"section 112(a) of Pub. L. 97–51","children":[],"tail":" effective in the case of compensation payable for months after December 1981, see "},{"tag":"ref","attrib":{"href":"/us/pl/97/51/s112/e"},"text":"section 112(e) of Pub. L. 97–51","children":[],"tail":", set out as an Effective Date of 1981 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd23566a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1979 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/38/tI/s108/b"},"text":"Pub. L. 96–38, title I, § 108(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-25"},"text":"July 25, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/113"},"text":"93 Stat. 113","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/38/tI/s108/b"},"text":"“The amendment made by subsection (a) [amending this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1978-10-01"},"text":"October 1, 1978","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd23566b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1971 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/92/136/s9/b"},"text":"Pub. L. 92–136, § 9(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-10-11"},"text":"Oct. 11, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/378"},"text":"85 Stat. 378","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/92/136/s9/b"},"text":"“Sections 4 and 6 of this Act [enacting former ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s60c–2"},"text":"section 60c–2 of this title","children":[],"tail":" and amending this section] shall become effective as of "},{"tag":"date","attrib":{"date":"1971-07-01"},"text":"July 1, 1971","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd23566c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/86/426/s3"},"text":"Pub. L. 86–426, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-04-20"},"text":"Apr. 20, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/54"},"text":"74 Stat. 54","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/86/426/s3"},"text":"“This joint resolution [enacting this section and amending former sections 60d, 60e, and 60e–1 of this title] shall be effective with respect to compensation accruing on or after the first day of the month following the month in which it is enacted [","children":[{"tag":"date","attrib":{"date":"1960-04-01"},"text":"Apr. 1, 1960","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
