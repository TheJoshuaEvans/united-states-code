{"tag":"section","attrib":{"id":"iddd3b24d7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6561"},"text":null,"children":[{"tag":"num","attrib":{"value":"6561"},"text":"§ 6561.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advance payments by Secretary of Senate","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd3b24d8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6561/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For fiscal year 1998, and each fiscal year thereafter, the Secretary of the Senate is authorized to make advance payments under a contract or other agreement to provide a service or deliver an article for the United States Government without regard to the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3324"},"text":"section 3324 of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3b24d9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6561/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An advance payment authorized by subsection (a) shall be made in accordance with regulations issued by the Committee on Rules and Administration of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3b24da-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6561/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority granted by subsection (a) shall not take effect until regulations are issued pursuant to subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd3b24db-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/55/tI/s1"},"text":"Pub. L. 105–55, title I, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-10-07"},"text":"Oct. 7, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1179"},"text":"111 Stat. 1179","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd3b24dc-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd3b24dd-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd3b24de-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s68e"},"text":"section 68e of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Congressional Operations Appropriations Act, 1998, which is title I of the Legislative Branch Appropriations Act, 1998.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
