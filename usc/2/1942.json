{"tag":"section","attrib":{"id":"iddcf39405-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1942"},"text":null,"children":[{"tag":"num","attrib":{"value":"1942"},"text":"§ 1942.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uniform to display United States flag or colors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcf39406-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1942/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The uniform of officers and members of the United States Park Police force, the United States Secret Service Uniformed Division, the Capitol Police, and the Metropolitan Police force of the District of Columbia shall bear a distinctive patch, pin, or other emblem depicting the flag of the United States or the colors thereof.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcf39407-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1942/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Interior in the case of the United States Park Police force, the Secretary of the Treasury in the case of the United States Secret Service Uniformed Division, the Capitol Police Board in the case of the Capitol Police, and the Mayor of the District of Columbia in the case of the Metropolitan Police force shall prescribe such regulations as may be necessary to carry out the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcf39408-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/297/tII/s201/a"},"text":"Pub. L. 91–297, title II, § 201(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1970-06-30"},"text":"June 30, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/357"},"text":"84 Stat. 357","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/198/tIV/s421"},"text":"Pub. L. 93–198, title IV, § 421","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-12-24"},"text":"Dec. 24, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/789"},"text":"87 Stat. 789","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/179"},"text":"Pub. L. 95–179","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-11-15"},"text":"Nov. 15, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1371"},"text":"91 Stat. 1371","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcf39409-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcf3940a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddcf3940b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was classified to section 210a of former Title 40, prior to the enactment of Title 40, Public Buildings, Property, and Works, by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217/s1"},"text":"Pub. L. 107–217, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1062"},"text":"116 Stat. 1062","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcf3940c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1977—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/179"},"text":"Pub. L. 95–179","children":[],"tail":" substituted “United States Secret Service Uniformed Division” for “Executive Protective Service” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcf3940d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"iddcf3940e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Office of Commissioner of District of Columbia, as established by Reorg. Plan No. 3 of 1967, abolished as of noon ","children":[{"tag":"date","attrib":{"date":"1975-01-02"},"text":"Jan. 2, 1975","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/pl/93/198/tVII/s711"},"text":"Pub. L. 93–198, title VII, § 711","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-12-24"},"text":"Dec. 24, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/818"},"text":"87 Stat. 818","children":[],"tail":", and replaced by office of Mayor of District of Columbia by "},{"tag":"ref","attrib":{"href":"/us/pl/93/198/s421"},"text":"section 421 of Pub. L. 93–198","children":[],"tail":". Accordingly, “Mayor” substituted in text for “commissioner”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
