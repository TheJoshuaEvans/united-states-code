{"tag":"section","attrib":{"id":"iddcea1e8f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1854"},"text":null,"children":[{"tag":"num","attrib":{"value":"1854"},"text":"§ 1854.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Overtime compensation for certain employees of Architect of Capitol","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For overtime pay purposes, per diem and per hour employees under the Office of the Architect of the Capitol not subject to chapter 51 and subchapter III of chapter 53 of title 5, shall be regarded as subject to the provisions of sections 5544(a) and 6102 of title 5, and sections 60e–3 and 60e–4 of this title shall not be applicable to such employees.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddcea1e90-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-06-30/ch212"},"text":"June 30, 1945, ch. 212","children":[],"tail":", title V, § 503, "},{"tag":"ref","attrib":{"href":"/us/stat/59/301"},"text":"59 Stat. 301","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-10-28/ch782"},"text":"Oct. 28, 1949, ch. 782","children":[],"tail":", title XI, § 1106(a), "},{"tag":"ref","attrib":{"href":"/us/stat/63/972"},"text":"63 Stat. 972","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcea1e91-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcea1e92-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddcea1e93-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","