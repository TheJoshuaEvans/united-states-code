{"tag":"section","attrib":{"id":"iddc9b61cc-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s294"},"text":null,"children":[{"tag":"num","attrib":{"value":"294"},"text":"§ 294.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Position standards and descriptions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc9b61cd-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s294/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc9b61ce-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s294/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" It shall be the duty of the committee to prescribe, revise, and (on a current basis) maintain position standards which shall apply to positions (in existence on, or established after, ","children":[{"tag":"date","attrib":{"date":"1965-01-01"},"text":"January 1, 1965","children":[],"tail":") under the House of Representatives to which this chapter applies."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc9b61cf-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s294/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The position standards shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc9b61d0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s294/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the separation of such positions into appropriate classes for pay and personnel purposes on the basis of reasonable similarity with respect to types of positions, qualification requirements of positions, and levels of difficulty and responsibility of work, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9b61d1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s294/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" govern the placement of such positions in their respective appropriate compensation levels of the appropriate compensation schedule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc9b61d2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s294/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc9b61d3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s294/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to review and approval by the committee, the Clerk, the Sergeant at Arms, the Chief Administrative Officer, and the Inspector General of the House of Representatives, shall prepare, revise, and (on a current basis) maintain, at such times and in such form as the committee deems appropriate, position descriptions of the respective positions (in existence on, or established after, ","children":[{"tag":"date","attrib":{"date":"1965-01-01"},"text":"January 1, 1965","children":[],"tail":") under the House of Representatives to which this chapter applies which are under their respective jurisdictions, including—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc9b61d4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s294/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the Clerk, positions under the House Recording Studio,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9b61d5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s294/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the Sergeant at Arms, the position of minority pair clerk in the House, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9b61d6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s294/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the Chief Administrative Officer, positions under the House Radio and Television Correspondents’ Gallery and the House Periodical Press Gallery.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc9b61d7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s294/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The position descriptions shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc9b61d8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s294/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe in detail the actual duties, responsibilities, and qualification requirements of the work of each of such positions,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9b61d9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s294/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a position title for such position which accurately reflects such duties and responsibilities, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9b61da-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s294/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" govern the placement of such position in its appropriate class.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc9b61db-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s294/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Clerk, the Sergeant at Arms, the Chief Administrative Officer, and the Inspector General of the House of Representatives, shall transmit to the committee, at such times and in such form as the committee deems appropriate, all position descriptions required by subsection (b) of this section to be prepared, provided, and currently maintained by them, together with such other pertinent information as the committee may require, in order that the committee shall have, at all times, current information with respect to such position descriptions, the positions to which such descriptions apply, and related personnel matters within the purview of this chapter. Such information so transmitted shall be kept on file in the committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc9b61dc-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s294/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding any other provision of this chapter, the committee shall have authority, which may be exercised at any time in its discretion, to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc9b61dd-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s294/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct surveys and studies of all organization units, and the positions therein, to which this chapter applies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc9b61de-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s294/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ascertain on a current basis the facts with respect to the duties, responsibilities, and qualification requirements of any position to which this chapter applies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc9b61df-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s294/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare and revise the position description of any such position;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc9b61e0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s294/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" place any such position in its appropriate class and compensation level;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc9b61e1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s294/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" decide whether any such position is in its appropriate class and compensation level;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc9b61e2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s294/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" change any such position from one class or compensation level to any other class or compensation level whenever the facts warrant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc9b61e3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s294/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribe such organization and position titles as may be appropriate to carry out the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"All such actions of the committee shall be binding on the House officer and organization unit concerned and shall be the basis for payment of compensation and for other personnel benefits and transactions until otherwise changed by the committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc9b61e4-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/652/s5"},"text":"Pub. L. 88–652, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-10-13"},"text":"Oct. 13, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/1080"},"text":"78 Stat. 1080","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/53/tI/s108/3"},"text":"Pub. L. 104–53, title I, § 108(3)","children":[],"tail":", (4), "},{"tag":"date","attrib":{"date":"1995-11-19"},"text":"Nov. 19, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/522"},"text":"109 Stat. 522","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/186/tII/s209/2"},"text":"Pub. L. 104–186, title II, § 209(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1743"},"text":"110 Stat. 1743","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc9b61e5-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc9b61e6-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddc9b61e7-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/652"},"text":"Pub. L. 88–652","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-10-13"},"text":"Oct. 13, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/1079"},"text":"78 Stat. 1079","children":[],"tail":", known as the House Employees Position Classification Act, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s291"},"text":"section 291 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc9b61e8-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186"},"text":"Pub. L. 104–186","children":[],"tail":" substituted “Chief Administrative Officer” for “Doorkeeper”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1995—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/53"},"text":"Pub. L. 104–53","children":[],"tail":" substituted “Chief Administrative Officer, and the Inspector General” for “Doorkeeper, and the Postmaster”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/53"},"text":"Pub. L. 104–53","children":[],"tail":" substituted “Chief Administrative Officer, and the Inspector General” for “Doorkeeper, and the Postmaster,”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc9b61e9-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddc9b61ea-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1965-01-01"},"text":"Jan. 1, 1965","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/88/652/s17"},"text":"section 17 of Pub. L. 88–652","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s291"},"text":"section 291 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"iddc9b61eb-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Certain functions of Recording Studio and Officers of House of Representatives transferred to Director of Non-legislative and Financial Services by section 7 of House Resolution No. 423, One Hundred Second Congress, ","children":[{"tag":"date","attrib":{"date":"1992-04-09"},"text":"Apr. 9, 1992","children":[],"tail":". Director of Non-legislative and Financial Services replaced by Chief Administrative Officer of House of Representatives by House Resolution No. 6, One Hundred Fourth Congress, "},{"tag":"date","attrib":{"date":"1995-01-04"},"text":"Jan. 4, 1995","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
