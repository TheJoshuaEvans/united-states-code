{"tag":"section","attrib":{"id":"iddcd49aa8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1361"},"text":null,"children":[{"tag":"num","attrib":{"value":"1361"},"text":"§ 1361.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Generally applicable remedies and limitations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcd49aa9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1361/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attorney’s fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a covered employee, with respect to any claim under this chapter, or a qualified person with a disability, with respect to any claim under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1331"},"text":"section 1331 of this title","children":[],"tail":", is a prevailing party in any proceeding under section 1405, 1406, 1407, or 1408 of this title, the hearing officer, Board, or court, as the case may be, may award attorney’s fees, expert fees, and any other costs as would be appropriate if awarded under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000e–5/k"},"text":"section 2000e–5(k) of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd49aaa-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1361/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any proceeding under section 1405, 1406, 1407, or 1408 of this title, the same interest to compensate for delay in payment shall be made available as would be appropriate if awarded under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000e–16/d"},"text":"section 2000e–16(d) of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd49aab-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1361/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil penalties and punitive damages","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No civil penalty or punitive damages may be awarded with respect to any claim under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd49aac-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1361/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusive procedure","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcd49aad-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1361/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), no person may commence an administrative or judicial proceeding to seek a remedy for the rights and protections afforded by this chapter except as provided in this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd49aae-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1361/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Veterans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A covered employee under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1316"},"text":"section 1316 of this title","children":[],"tail":" may also utilize any provisions of chapter 43 of title 38 that are applicable to that employee."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd49aaf-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1361/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcd49ab0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1361/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions and exemptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except where inconsistent with definitions and exemptions provided in this chapter, the definitions and exemptions in the laws made applicable by this chapter shall apply under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd49ab1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1361/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Size limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraph (1), provisions in the laws made applicable under this chapter (other than the Worker Adjustment and Retraining Notification Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2101"},"text":"29 U.S.C. 2101","children":[],"tail":" et seq.]) determining coverage based on size, whether expressed in terms of numbers of employees, amount of business transacted, or other measure, shall not apply in determining coverage under this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd49ab2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1361/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Executive branch enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This chapter shall not be construed to authorize enforcement by the executive branch of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcd49ab3-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/1/tII/s225"},"text":"Pub. L. 104–1, title II, § 225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-01-23"},"text":"Jan. 23, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/22"},"text":"109 Stat. 22","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/397/tI/s101/d"},"text":"Pub. L. 115–397, title I, § 101(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5301"},"text":"132 Stat. 5301","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcd49ab4-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcd49ab5-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddcd49ab6-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a), (c), (d)(1), and (e), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/1"},"text":"Pub. L. 104–1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-01-23"},"text":"Jan. 23, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/3"},"text":"109 Stat. 3","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1301"},"text":"section 1301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Worker Adjustment and Retraining Notification Act, referred to in subsec. (e)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/379"},"text":"Pub. L. 100–379","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-04"},"text":"Aug. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/890"},"text":"102 Stat. 890","children":[],"tail":", which is classified generally to chapter 23 (§ 2101 et seq.) of Title 29, Labor. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2101"},"text":"section 2101 of Title 29","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcd49ab7-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/397"},"text":"Pub. L. 115–397","children":[],"tail":" redesignated subsec. (f) as (e) and struck out former subsec. (e). Prior to amendment, text of subsec. (e) read as follows: “Only a covered employee who has undertaken and completed the procedures described in sections 1402 and 1403 of this title may be granted a remedy under part A of this subchapter.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcd70ab8-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcd70ab9-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/397"},"text":"Pub. L. 115–397","children":[],"tail":" effective upon expiration of the 180-day period beginning on "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", with provisions for effect on pending proceedings, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/397/s401"},"text":"section 401 of Pub. L. 115–397","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
