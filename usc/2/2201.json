{"tag":"section","attrib":{"id":"iddd0917aa-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2201"},"text":null,"children":[{"tag":"num","attrib":{"value":"2201"},"text":"§ 2201.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of facility as Capitol Visitor Center; purposes of facility; treatment of the Capitol Visitor Center","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd0917ab-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2201/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The facility authorized for construction under the heading “Capitol Visitor Center” under chapter 5 of title II of division B of the Omnibus Consolidated and Emergency Supplemental Appropriations Act, 1999 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Public Law 105–277","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-569"},"text":"112 Stat. 2681–569","children":[],"tail":") is designated as the Capitol Visitor Center and is a part of the Capitol."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd0917ac-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2201/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes of the facility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Capitol Visitor Center shall be used—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd0917ad-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2201/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide enhanced security for persons working in or visiting the United States Capitol;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd0917ae-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2201/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve the visitor experience by providing a structure that will afford improved visitor orientation and enhance the educational experience of those who have come to learn about the Congress and the Capitol; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd0917af-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2201/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for other purposes as determined by Congress or the Committee on Rules and Administration of the Senate and the Committee on House Administration of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd0917b0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2201/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of the Capitol Visitor Center","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd0917b1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2201/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oversight","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Committee on Rules and Administration of the Senate and the Committee on House Administration of the House of Representatives shall have oversight of the Capitol Visitor Center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd0917b2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2201/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of expansion space of the Senate and House of Representatives in the Capitol Visitor Center","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd0917b3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2201/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Senate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The expansion space of the Senate described as unassigned space under the heading “Capitol Visitor Center” under the heading “ARCHITECT OF THE CAPITOL” under title II of the Act entitled “An Act making appropriations for the Legislative Branch for the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"2002-09-30"},"text":"September 30, 2002","children":[],"tail":", and for other purposes”, approved "},{"tag":"date","attrib":{"date":"2001-11-12"},"text":"November 12, 2001","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/107/68"},"text":"Public Law 107–68","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/115/588"},"text":"115 Stat. 588","children":[],"tail":") shall be part of the Senate wing of the Capitol."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd0917b4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2201/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" House of Representatives","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The expansion space of the House of Representatives described as unassigned space under the heading “Capitol Visitor Center” under the heading “ARCHITECT OF THE CAPITOL” under title II of the Act entitled “An Act making appropriations for the Legislative Branch for the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"2002-09-30"},"text":"September 30, 2002","children":[],"tail":", and for other purposes”, approved "},{"tag":"date","attrib":{"date":"2001-11-12"},"text":"November 12, 2001","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/107/68"},"text":"Public Law 107–68","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/115/588"},"text":"115 Stat. 588","children":[],"tail":") shall be part of the House of Representatives wing of the Capitol."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd0917b5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2201/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of Congressional Auditorium and related adjacent areas","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd0917b6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2201/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Committee on Rules and Administration of the Senate and the Committee on House Administration of the House of Representatives shall jointly prescribe regulations for the assignment of the space in the Capitol Visitor Center known as the Congressional Auditorium and the related adjacent areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd0917b7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2201/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Related adjacent areas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The regulations under paragraph (1) shall include a designation of the areas that are related adjacent areas to the Congressional Auditorium.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd0917b8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2201/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd0917b9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2201/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exhibits for displays","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd0917ba-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2201/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd0917bb-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2201/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraph (B), the Architect of the Capitol may enter into loan agreements to place historical objects for display in the Exhibition Hall of the Capitol Visitor Center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd0917bc-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2201/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation and approval","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Architect of the Capitol may exercise the authority under subparagraph (A) with respect to each loan agreement—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd0917bd-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2201/f/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" after consultation with—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddd0917be-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2201/f/1/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Senate Commission on Art; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddd0917bf-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2201/f/1/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the House of Representatives Fine Arts Board; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd0917c0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2201/f/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" subject to the approval of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddd0917c1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2201/f/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Rules and Administration of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddd0917c2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2201/f/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on House Administration of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd0917c3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2201/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This paragraph shall take effect on ","children":[{"tag":"date","attrib":{"date":"2008-12-03"},"text":"December 3, 2008","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd0917c4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2201/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd0917c5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2201/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions to exhibition prohibition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s2134"},"text":"Section 2134 of this title","children":[],"tail":" shall not apply to any historical object placed within an exhibit in the Exhibition Hall of the Capitol Visitor Center that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd0917c6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2201/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd0917c7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2201/f/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is directly related to the purpose of the Capitol Visitor Center under subsection (b)(2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd0917c8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2201/f/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is the subject of a loan agreement entered into by the Architect of the Capitol before ","children":[{"tag":"date","attrib":{"date":"2008-12-02"},"text":"December 2, 2008","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd0917c9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2201/f/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been approved by the Capitol Preservation Commission; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd0917ca-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2201/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is the subject of a loan agreement described under paragraph (1)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd0917cb-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2201/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Substitution of historical object","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A loan agreement described under paragraph (3)(A)(ii) may provide for the removal of an historical object from exhibition for preservation purposes and the substitution of that object with another historical object having a comparable educational purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd0917cc-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/437/tI/s101"},"text":"Pub. L. 110–437, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-20"},"text":"Oct. 20, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4984"},"text":"122 Stat. 4984","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd0917cd-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd0917ce-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd0917cf-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions under the heading “Capitol Visitor Center” in chapter 5 of title II of division B of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Public Law 105–277","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-569"},"text":"112 Stat. 2681–569","children":[],"tail":", referred to in subsec. (a), are not classified to the Code."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions under the headings “Capitol Visitor Center” and “ARCHITECT OF THE CAPITOL” in title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/68"},"text":"Public Law 107–68","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/588"},"text":"115 Stat. 588","children":[],"tail":", referred to in subsec. (c)(2)(A), are not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd0917d0-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/437/s101"},"text":"section 101 of Pub. L. 110–437","children":[],"tail":". Subsec. (e) of "},{"tag":"ref","attrib":{"href":"/us/pl/110/437/s101"},"text":"section 101 of Pub. L. 110–437","children":[],"tail":" repealed "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s2165"},"text":"section 2165 of this title","children":[],"tail":". Subsec. (f)(2) of "},{"tag":"ref","attrib":{"href":"/us/pl/110/437/s101"},"text":"section 101 of Pub. L. 110–437","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s2134"},"text":"section 2134 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd0917d1-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"iddd0917d2-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/437/s1/a"},"text":"Pub. L. 110–437, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-20"},"text":"Oct. 20, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4983"},"text":"122 Stat. 4983","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/437/s1/a"},"text":"“This Act [enacting this chapter, amending sections 130e, 1301, 1331, 1341, and 2134 of this title and sections 2107 and 5379 of Title 5, Government Organization and Employees, repealing sections 1806, 1807, 1825, 2165, and 2166 of this title, enacting provisions set out as notes under sections 1301 and 1831 of this title, and amending provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1831"},"text":"section 1831 of this title","children":[],"tail":"] may be cited as the ‘Capitol Visitor Center Act of 2008’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
