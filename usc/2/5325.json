{"tag":"section","attrib":{"id":"iddd2a8231-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5325"},"text":null,"children":[{"tag":"num","attrib":{"value":"5325"},"text":"§ 5325.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance of duties by clerical assistants of dead or resigned Member of House","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any clerical assistants who continue on the House pay rolls under the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s5324"},"text":"section 5324 of this title","children":[],"tail":" shall, while so continued, perform their duties under the direction of the Clerk of the House, and he is authorized and directed to remove from such pay rolls any such clerks who are not attending to the duties for which their services are continued."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd2a8232-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-21/ch600/s2"},"text":"Aug. 21, 1935, ch. 600, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/680"},"text":"49 Stat. 680","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd2a8233-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd2a8234-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd2a8235-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/