{"tag":"section","attrib":{"id":"iddd14fe11-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4531"},"text":null,"children":[{"tag":"num","attrib":{"value":"4531"},"text":"§ 4531.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" House of Representatives pay adjustments; action by Chief Administrative Officer of House","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd14fe12-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4531/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Whenever an adjustment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5303"},"text":"section 5303 of title 5","children":[],"tail":" becomes effective with respect to rates of pay under the General Schedule, the Chief Administrative Officer of the House of Representatives, in such manner as he considers advisable—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd14fe13-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4531/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" effective on the first day of the month in which such pay adjustment by the President is made effective as described above, shall adjust—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd14fe14-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4531/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each minimum and maximum rate of pay applicable to any employee or class of employees whose pay is disbursed by the Chief Administrative Officer (other than a maximum rate equal to or greater than the maximum rate then currently being paid under the General Schedule of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of title 5","children":[],"tail":" as a result of such adjustment); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd14fe15-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4531/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each monetary limitation on or monetary allowance for pay applicable to any such employee or class of employees;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"by an amount rounded to the nearest $100 and computed on the basis of a percentage equal or equivalent, insofar as practicable and with such variations as the Chief Administrative Officer considers appropriate, to the percentage of the adjustment under such section 5303;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd14fe16-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4531/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall determine, with respect to the employees and classes of employees within the purview of this section whose pay is disbursed by the Chief Administrative Officer, the respective amounts of pay adjustments which are equal or equivalent, insofar as practicable and with such exceptions and modifications as may be necessary to provide for appropriate pay relationships between positions, to corresponding increases in pay, as determined by the Chief Administrative Officer, made by the pay adjustment by the President; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd14fe17-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4531/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall transmit to the appropriate pay-fixing authority concerned in the House of Representatives a copy of his determinations with respect to the pay of those employees whose pay is fixed and adjusted by that authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd14fe18-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4531/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" After consideration of the pay determinations transmitted by the Chief Administrative Officer, the pay-fixing authority concerned may adjust, notwithstanding the provisions contained in sections 1341, 1342, and 1349–1351 and subchapter II of chapter 15 of title 31, the rates of pay concerned in such manner as that authority considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd14fe19-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4531/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this section shall impair any authority pursuant to which rates of pay may be fixed by administrative action.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd14fe1a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4531/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section shall not be deemed to authorize any adjustment in the rates of pay of employees whose rates of pay are disbursed by the Chief Administrative Officer and are fixed and adjusted from time to time as nearly as is consistent with the public interest in accordance with prevailing rates or practices, including employees subject to the House Wage Schedule.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd14fe1b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4531/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No rate of pay for any position shall be adjusted under this section to an amount in excess of the rate of pay in effect for such position under an order issued by the Speaker of the House of Representatives pursuant to the authority of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s4532"},"text":"section 4532 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd14fe1c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/656/s5"},"text":"Pub. L. 91–656, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-01-08"},"text":"Jan. 8, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1952"},"text":"84 Stat. 1952","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/298/s3/b"},"text":"Pub. L. 92–298, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-05-17"},"text":"May 17, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/146"},"text":"86 Stat. 146","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/392/s14/b"},"text":"Pub. L. 92–392, § 14(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-08-19"},"text":"Aug. 19, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/575"},"text":"86 Stat. 575","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/509/tV/s529/tI/s101/b/4/F"},"text":"Pub. L. 101–509, title V, § 529 [title I, § 101(b)(4)(F), (10)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1427"},"text":"104 Stat. 1427","children":[],"tail":", 1440, 1442; "},{"tag":"ref","attrib":{"href":"/us/pl/102/378/s5/b"},"text":"Pub. L. 102–378, § 5(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-02"},"text":"Oct. 2, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1358"},"text":"106 Stat. 1358","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/186/tII/s204/1"},"text":"Pub. L. 104–186, title II, § 204(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1729"},"text":"110 Stat. 1729","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/94/dE/tII/s212/b/2"},"text":"Pub. L. 116–94, div. E, title II, § 212(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2776"},"text":"133 Stat. 2776","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd14fe1d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd14fe1e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd14fe1f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s60a–2"},"text":"section 60a–2 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (b), “sections 1341, 1342, and 1349–1351 and subchapter II of chapter 15 of title 31” substituted for “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s665"},"text":"section 665 of title 31","children":[],"tail":", United States Code” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s4/b"},"text":"Pub. L. 97–258, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1067"},"text":"96 Stat. 1067","children":[],"tail":", the first section of which enacted Title 31, Money and Finance."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd14fe20-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94"},"text":"Pub. L. 116–94","children":[],"tail":", which directed amendment of section “4(e) of the Federal Pay Comparability Act of 1970 ("},{"tag":"ref","attrib":{"href":"/us/usc/t2/s4531/e"},"text":"2 U.S.C. 4531(e)","children":[],"tail":")” by amending subsec. (e) generally, was executed to section 5(e) of the Act, which is subsec. (e) of this section, to reflect the probable intent of Congress. Prior to amendment, subsec. (e) read as follows: “No rate of pay shall be adjusted under this section to an amount in excess of the rate of basic pay of level V of the Executive Schedule contained in "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5316"},"text":"section 5316 of title 5","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186/s204/1/A"},"text":"Pub. L. 104–186, § 204(1)(A)","children":[],"tail":", substituted “Chief Administrative Officer of the House of Representatives” for “Clerk of the House of Representatives” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186/s204/1/D"},"text":"Pub. L. 104–186, § 204(1)(D)","children":[],"tail":", substituted “Chief Administrative Officer” for “Clerk” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186/s204/1/B"},"text":"Pub. L. 104–186, § 204(1)(B)","children":[],"tail":", substituted “Chief Administrative Officer” for “Clerk of the House”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186/s204/1/C"},"text":"Pub. L. 104–186, § 204(1)(C)","children":[],"tail":", struck out “, including but not limited to—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) the clerk hire allowance for each Member of the House of Representatives and the Resident Commissioner from Puerto Rico; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) the allowances for additional office personnel in the offices of the Speaker, the majority leader, the minority leader, the majority whip, and the minority whip, of the House of Representatives”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"after “class of employees”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186/s204/1/E"},"text":"Pub. L. 104–186, § 204(1)(E)","children":[],"tail":", substituted “Chief Administrative Officer” for “Clerk” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186/s204/1/F"},"text":"Pub. L. 104–186, § 204(1)(F)","children":[],"tail":", substituted “Chief Administrative Officer” for “Clerk of the House”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186/s204/1/G"},"text":"Pub. L. 104–186, § 204(1)(G)","children":[],"tail":", substituted “Chief Administrative Officer” for “Clerk of the House of Representatives”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/378"},"text":"Pub. L. 102–378","children":[],"tail":" inserted “of title 5” after “section 5303”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509/s529/tI/s101/b/4/F/i"},"text":"Pub. L. 101–509, § 529 [title I, § 101(b)(4)(F)(i)]","children":[],"tail":", substituted “(a) Whenever an adjustment under section 5303 becomes effective with respect to rates of pay under the General Schedule,” for “(a) Whenever a pay adjustment by the President under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5305"},"text":"section 5305 of title 5","children":[],"tail":" is made effective pursuant to subsection (a)(2), or subsections (c) to (m), inclusive, as the case may be, of such section 5305, or section 3(c) of this Act, then”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509/s529/tI/s101/b/10"},"text":"Pub. L. 101–509, § 529 [title I, § 101(b)(10)]","children":[],"tail":", made technical correction to "},{"tag":"ref","attrib":{"href":"/us/pl/92/298"},"text":"Pub. L. 92–298","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/92/392"},"text":"Pub. L. 92–392","children":[],"tail":", see 1972 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509/s529/tI/s101/b/4/F/iii"},"text":"Pub. L. 101–509, § 529 [title I, § 101(b)(4)(F)(iii)]","children":[],"tail":", in closing provisions, substituted “adjustment under such section 5303;” for “pay adjustment made by the President;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509/s529/tI/s101/b/4/F/ii"},"text":"Pub. L. 101–509, § 529 [title I, § 101(b)(4)(F)(ii)]","children":[],"tail":", substituted “adjustment)” for “pay adjustment by the President)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/298"},"text":"Pub. L. 92–298","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/92/392"},"text":"Pub. L. 92–392","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/101/509/s529/tI/s101/b/10"},"text":"Pub. L. 101–509, § 529 [title I, § 101(b)(10)]","children":[],"tail":", made identical substitutions in introductory provisions of “effective on the first day of the month in which such pay adjustments by the President” for “effective at the beginning of the first pay period commencing on or after the day on which such pay adjustment by the President”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd14fe21-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd14fe22-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2019 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94"},"text":"Pub. L. 116–94","children":[],"tail":" effective on the later of the first day of the first applicable pay period beginning on or after "},{"tag":"date","attrib":{"date":"2020-01-01"},"text":"Jan. 1, 2020","children":[],"tail":", or the first day of the first applicable pay period beginning on or after "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/116/94/s212/c"},"text":"section 212(c) of Pub. L. 116–94","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s282b"},"text":"section 282b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd14fe23-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509"},"text":"Pub. L. 101–509","children":[],"tail":" effective on such date as the President shall determine, but not earlier than 90 days, and not later than 180 days, after "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", see section 529 [title III, § 305] of "},{"tag":"ref","attrib":{"href":"/us/pl/101/509"},"text":"Pub. L. 101–509","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5301"},"text":"section 5301 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd14fe24-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1972 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/392"},"text":"Pub. L. 92–392","children":[],"tail":" effective on first day of first applicable pay period beginning on or after 90th day after "},{"tag":"date","attrib":{"date":"1972-08-19"},"text":"Aug. 19, 1972","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/92/392/s15/a"},"text":"section 15(a) of Pub. L. 92–392","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5341"},"text":"section 5341 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd14fe25-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Directive of the Speaker of the House of Representatives Implementing the Salary Comparability Policy in 1969 for Officers and Employees of the House of Representatives Required by Section 212 of the Federal Salary Act of 1967 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5304"},"text":"5 U.S.C. 5304","children":[],"tail":" note]"}],"tail":null},{"tag":"p","attrib":{},"text":"Salary Directives of the Speaker of the House of Representatives were issued on the following dates:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"date","attrib":{"date":"1969-06-17"},"text":"June 17, 1969","children":[],"tail":", increases eff. "},{"tag":"date","attrib":{"date":"1969-07-01"},"text":"July 1, 1969","children":[],"tail":", Cong. Rec., vol. 115, pt. 12, p. 16196."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"date","attrib":{"date":"1968-06-11"},"text":"June 11, 1968","children":[],"tail":", increases eff. "},{"tag":"date","attrib":{"date":"1968-07-01"},"text":"July 1, 1968","children":[],"tail":", Cong. Rec., vol. 114, pt. 13, p. 16717."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd14fe26-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Increases in Compensation","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The following acts provided increases in compensation for elected officers and certain employees of the House of Representatives:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/85/462/s4/k"},"text":"Pub. L. 85–462, § 4(k)","children":[],"tail":", ("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"1958-06-20"},"text":"June 20, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/209"},"text":"72 Stat. 209","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1955-06-28/ch189/s4/c"},"text":"June 28, 1955, ch. 189, § 4(c)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/176"},"text":"69 Stat. 176","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1951-10-24/ch554/s2/e"},"text":"Oct. 24, 1951, ch. 554, § 2(e)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/65/614"},"text":"65 Stat. 614","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1949-10-28/ch783"},"text":"Oct. 28, 1949, ch. 783","children":[],"tail":", title I, § 101(d), "},{"tag":"ref","attrib":{"href":"/us/stat/63/974"},"text":"63 Stat. 974","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
