{"tag":"section","attrib":{"id":"iddd2ccbf1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5508"},"text":null,"children":[{"tag":"num","attrib":{"value":"5508"},"text":"§ 5508.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Account in House of Representatives for Employees’ Compensation Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd2ccbf2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5508/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby established an account in the House of Representatives for purposes of making payments of the House of Representatives to the Employees’ Compensation Fund under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8147"},"text":"section 8147 of title 5","children":[],"tail":", and for reimbursing the Secretary of Labor for any amounts paid with respect to unemployment compensation payments for former employees of the House."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2ccbf3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5508/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments made from account","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, payments may be made from the account established under subsection (a) at any time after ","children":[{"tag":"date","attrib":{"date":"1997-10-07"},"text":"October 7, 1997","children":[],"tail":", without regard to the fiscal year for which the obligation to make such payments is incurred."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2ccbf4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5508/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Category of allowances and expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The account established under subsection (a) shall be treated as a category of allowances and expenses for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s5507/a"},"text":"section 5507(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd2ccbf5-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/55/tI/s109"},"text":"Pub. L. 105–55, title I, § 109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-10-07"},"text":"Oct. 7, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1184"},"text":"111 Stat. 1184","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/76/dI/tI/s102/a"},"text":"Pub. L. 113–76, div. I, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-01-17"},"text":"Jan. 17, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/422"},"text":"128 Stat. 422","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd2ccbf6-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd2ccbf7-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd2ccbf8-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s95d"},"text":"section 95d of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Congressional Operations Appropriations Act, 1998, which is title I of the Legislative Branch Appropriations Act, 1998.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd2ccbf9-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/76"},"text":"Pub. L. 113–76","children":[],"tail":" substituted “, and for reimbursing the Secretary of Labor for any amounts paid with respect to unemployment compensation payments for former employees of the House.” for period at end."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd2ccbfa-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd2ccbfb-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2014 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/76/dI/tI/s102/b"},"text":"Pub. L. 113–76, div. I, title I, § 102(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-01-17"},"text":"Jan. 17, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/422"},"text":"128 Stat. 422","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/76/dI/tI/s102/b"},"text":"“The amendment made by subsection (a) [amending this section] shall apply with respect to fiscal year 2014 and each succeeding fiscal year.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
