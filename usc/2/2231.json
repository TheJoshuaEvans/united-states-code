{"tag":"section","attrib":{"id":"iddd091819-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2231"},"text":null,"children":[{"tag":"num","attrib":{"value":"2231"},"text":"§ 2231.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and accounts","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"There is established in the Treasury of the United States a revolving fund to be known as the Capitol Visitor Center Revolving Fund (in this section referred to as the “Fund”), consisting of the following individual accounts:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd09181a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2231/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Gift Shop Account.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd09181b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2231/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Miscellaneous Receipts Account.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd09181c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/437/tIII/s301"},"text":"Pub. L. 110–437, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-20"},"text":"Oct. 20, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4989"},"text":"122 Stat. 4989","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
