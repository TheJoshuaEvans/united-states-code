{"tag":"section","attrib":{"id":"iddd2356ac-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4702"},"text":null,"children":[{"tag":"num","attrib":{"value":"4702"},"text":"§ 4702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of post-employment restrictions for Members of Congress and employees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd2356ad-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4702/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of post-employment restrictions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After a Member of Congress or an elected officer of either House of Congress leaves office, or after the termination of employment with the House of Representatives or the Senate of an employee who is covered under paragraph (2), (3), (4), or (5) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s207/e"},"text":"section 207(e) of title 18","children":[],"tail":", the Clerk of the House of Representatives, after consultation with the Committee on Standards of Official Conduct, or the Secretary of the Senate, as the case may be, shall notify the Member, officer, or employee of the beginning and ending date of the prohibitions that apply to the Member, officer, or employee under section 207(e) of that title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2356ae-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4702/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Posting on Internet","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Clerk of the House of Representatives, with respect to notifications under subsection (a) relating to Members, officers, and employees of the House, and the Secretary of the Senate, with respect to such notifications relating to Members, officers, and employees of the Senate, shall post the information contained in such notifications on the public Internet site of the Office of the Clerk or the Secretary of the Senate, as the case may be, in a format that, to the extent technically practicable, is searchable, sortable, and downloadable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd2356af-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/81/tI/s103"},"text":"Pub. L. 110–81, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-09-14"},"text":"Sept. 14, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/739"},"text":"121 Stat. 739","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd2356b0-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd2356b1-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd2356b2-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s104d"},"text":"section 104d of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd2356b3-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"iddd2356b4-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Standards of Official Conduct of House of Representatives changed to Committee on Ethics of House of Representatives by House Resolution No. 5, One Hundred Twelfth Congress, ","children":[{"tag":"date","attrib":{"date":"2011-01-05"},"text":"Jan. 5, 2011","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd2356b5-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/81/tI/s105/c"},"text":"Pub. L. 110–81, title I, § 105(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-09-14"},"text":"Sept. 14, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/741"},"text":"121 Stat. 741","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/81/tI/s105/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification of post-employment restrictions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) of section 103 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s4702/a"},"text":"2 U.S.C. 4702(a)","children":[],"tail":"] shall take effect on the 60th day after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2007-09-14"},"text":"Sept. 14, 2007","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Posting of information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (b) of section 103 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s4702/b"},"text":"2 U.S.C. 4702(b)","children":[],"tail":"] shall take effect "},{"tag":"date","attrib":{"date":"2008-01-01"},"text":"January 1, 2008","children":[],"tail":", except that the Secretary of the Senate and the Clerk of the House of Representatives shall post the information contained in notifications required by that subsection that are made on or after the effective date provided under paragraph (1) of this subsection.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
