{"tag":"section","attrib":{"id":"iddcd499d5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1316"},"text":null,"children":[{"tag":"num","attrib":{"value":"1316"},"text":"§ 1316.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights and protections relating to veterans’ employment and reemployment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcd499d6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1316/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment and reemployment rights of members of uniformed services","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcd499d7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1316/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It shall be unlawful for an employing office to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcd499d8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1316/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" discriminate, within the meaning of subsections (a) and (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s4311"},"text":"section 4311 of title 38","children":[],"tail":", against an eligible employee;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcd499d9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1316/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deny to an eligible employee reemployment rights within the meaning of sections 4312 and 4313 of title 38; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcd499da-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1316/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deny to an eligible employee benefits within the meaning of sections 4316, 4317, and 4318 of title 38.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd499db-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1316/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcd499dc-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1316/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “eligible employee” means a covered employee performing service in the uniformed services, within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s4303/13"},"text":"section 4303(13) of title 38","children":[],"tail":", whose service has not been terminated upon occurrence of any of the events enumerated in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4304"},"text":"section 4304 of title 38","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcd499dd-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1316/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “covered employee” includes employees of the Government Accountability Office, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcd499de-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1316/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “employing office” includes the Government Accountability Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd499df-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1316/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remedy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The remedy for a violation of subsection (a) shall be such remedy as would be appropriate if awarded under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s4323/d"},"text":"section 4323(d) of title 38","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd499e0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1316/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations to implement section","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcd499e1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1316/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall, pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1384"},"text":"section 1384 of this title","children":[],"tail":", issue regulations to implement this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd499e2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1316/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The regulations issued under paragraph (1) shall be the same as substantive regulations promulgated by the Secretary of Labor to implement the statutory provisions referred to in subsection (a) except to the extent that the Board may determine, for good cause shown and stated together with the regulation, that a modification of such regulations would be more effective for the implementation of the rights and protections under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd499e3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1316/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcd499e4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1316/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), subsections (a) and (b) shall be effective 1 year after ","children":[{"tag":"date","attrib":{"date":"1995-01-23"},"text":"January 23, 1995","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd499e5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1316/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Government Accountability Office and Library of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall be effective with respect to the Government Accountability Office and the Library of Congress 1 year after transmission to the Congress of the study under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1371"},"text":"section 1371 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcd499e6-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/1/tII/s206"},"text":"Pub. L. 104–1, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-01-23"},"text":"Jan. 23, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/12"},"text":"109 Stat. 12","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/271/s8/b"},"text":"Pub. L. 108–271, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-07"},"text":"July 7, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/814"},"text":"118 Stat. 814","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/275/tVII/s703/b"},"text":"Pub. L. 111–275, title VII, § 703(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-13"},"text":"Oct. 13, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2888"},"text":"124 Stat. 2888","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dI/tI/s153/a/2/C"},"text":"Pub. L. 115–141, div. I, title I, § 153(a)(2)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/785"},"text":"132 Stat. 785","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcd499e7-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcd499e8-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcd499e9-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(2)(B), (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" struck out “and the Library of Congress” after “the Government Accountability Office”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/275"},"text":"Pub. L. 111–275","children":[],"tail":" substituted “under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4323/d"},"text":"section 4323(d) of title 38","children":[],"tail":"” for “under paragraphs (1), (2)(A), and (3) of "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4323/c"},"text":"section 4323(c) of title 38","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (a)(2)(B), (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271"},"text":"Pub. L. 108–271","children":[],"tail":" substituted “Government Accountability Office” for “General Accounting Office”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271"},"text":"Pub. L. 108–271","children":[],"tail":" substituted “Government Accountability Office” for “General Accounting Office” in heading and text."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
