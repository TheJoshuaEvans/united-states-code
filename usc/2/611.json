{"tag":"section","attrib":{"id":"iddca748ce-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s611"},"text":null,"children":[{"tag":"num","attrib":{"value":"611"},"text":"§ 611.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employee development program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddca748cf-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s611/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Congressional Budget Office may, by regulation, make applicable such provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3396"},"text":"section 3396 of title 5","children":[],"tail":" as the Director determines necessary to establish a program providing opportunities for employees of the Office to engage in details or other temporary assignments in other agencies, study, or uncompensated work experience which will contribute to the employees’ development and effectiveness."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca748d0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s611/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply to fiscal year 2003 and each fiscal year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddca748d1-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7/dH/tI/s1101"},"text":"Pub. L. 108–7, div. H, title I, § 1101","children":[],"tail":", "},{"tag":"date","a